      "meanings": [
        {
          "language": "ar",
          "text": "خصم؛ تخفيض في السعر"
        },
        {
          "language": "ckb",
          "text": "داشکاندنی نرخ"
        },
        {
          "language": "en",
          "text": "discount; price reduction"
        },
        {
          "language": "fa",
          "text": "تخفیف؛ کاهش قیمت"
        },
        {
          "language": "kmr",
          "text": "daxistina bihayê"
        },
        {
          "language": "pl",
          "text": "rabat; obniżka ceny"
        },
        {
          "language": "ro",
          "text": "reducere de preț"
        },
        {
          "language": "ru",
          "text": "скидка; снижение цены"
        },
        {
          "language": "sq",
          "text": "zbritje çmimi"
        },
        {
          "language": "tr",
          "text": "indirim; fiyat düşüşü"
        }
      ],
      "examples": [
        {
          "baseText": "Gibt es einen Preisnachlass für Studenten?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يوجد خصم للطلاب؟"
            },
            {
              "language": "ckb",
              "text": "ئایا داشکاندنی نرخ بۆ خوێندکاران هەیە؟"
            },
            {
              "language": "en",
              "text": "Is there a discount for students?"
            },
            {
              "language": "fa",
              "text": "آیا برای دانشجویان تخفیف وجود دارد؟"
            },
            {
              "language": "kmr",
              "text": "Ji bo xwendekaran daxistina bihayê heye?"
            },
            {
              "language": "pl",
              "text": "Czy jest rabat dla studentów?"
            },
            {
              "language": "ro",
              "text": "Există reducere pentru studenți?"
            },
            {
              "language": "ru",
              "text": "Есть скидка для студентов?"
            },
            {
              "language": "sq",
              "text": "A ka zbritje për studentët?"
            },
            {
              "language": "tr",
              "text": "Öğrenciler için indirim var mı?"
            }
          ]
        },
        {
          "baseText": "Beim Kauf von zwei Jacken bekommen Sie Preisnachlass.",
          "translations": [
            {
              "language": "ar",
              "text": "عند شراء سترتين تحصلون على خصم."
            },
            {
              "language": "ckb",
              "text": "لە کڕینی دوو چاکەتدا داشکاندنتان دەبێت."
            },
            {
              "language": "en",
              "text": "You get a discount when buying two jackets."
            },
            {
              "language": "fa",
              "text": "با خرید دو کاپشن تخفیف می‌گیرید."
            },
            {
              "language": "kmr",
              "text": "Dema du çakêt dikirin hûn daxistina bihayê werdigirin."
            },
            {
              "language": "pl",
              "text": "Przy zakupie dwóch kurtek dostają państwo rabat."
            },
            {
              "language": "ro",
              "text": "La cumpărarea a două geci primiți reducere."
            },
            {
              "language": "ru",
              "text": "При покупке двух курток вы получаете скидку."
            },
            {
              "language": "sq",
              "text": "Kur blini dy xhaketa, merrni zbritje."
            },
            {
              "language": "tr",
              "text": "İki ceket alırsanız indirim alırsınız."
            }
          ]
        }
      ]
