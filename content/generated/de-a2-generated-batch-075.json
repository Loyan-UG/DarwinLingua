      "meanings": [
        {
          "language": "ar",
          "text": "بطاقة بريدية"
        },
        {
          "language": "ckb",
          "text": "کارتپۆست"
        },
        {
          "language": "en",
          "text": "postcard"
        },
        {
          "language": "fa",
          "text": "کارت پستال"
        },
        {
          "language": "kmr",
          "text": "kartpostal"
        },
        {
          "language": "pl",
          "text": "pocztówka"
        },
        {
          "language": "ro",
          "text": "carte poștală"
        },
        {
          "language": "ru",
          "text": "открытка"
        },
        {
          "language": "sq",
          "text": "kartolinë"
        },
        {
          "language": "tr",
          "text": "kartpostal"
        }
      ],
      "examples": [
        {
          "baseText": "Ich schreibe meiner Oma eine Postkarte.",
          "translations": [
            {
              "language": "ar",
              "text": "أكتب بطاقة بريدية لجدتي."
            },
            {
              "language": "ckb",
              "text": "کارتپۆستێک بۆ داپیرم دەنووسم."
            },
            {
              "language": "en",
              "text": "I write a postcard to my grandma."
            },
            {
              "language": "fa",
              "text": "برای مادربزرگم کارت پستال می‌نویسم."
            },
            {
              "language": "kmr",
              "text": "Ez ji dapîra xwe re kartpostalekê dinivîsim."
            },
            {
              "language": "pl",
              "text": "Piszę pocztówkę do babci."
            },
            {
              "language": "ro",
              "text": "Îi scriu bunicii o carte poștală."
            },
            {
              "language": "ru",
              "text": "Я пишу открытку бабушке."
            },
            {
              "language": "sq",
              "text": "I shkruaj gjyshes një kartolinë."
            },
            {
              "language": "tr",
              "text": "Büyükanneme bir kartpostal yazıyorum."
            }
          ]
        },
        {
          "baseText": "Die Postkarte aus Wien ist heute angekommen.",
          "translations": [
            {
              "language": "ar",
              "text": "وصلت البطاقة البريدية من فيينا اليوم."
            },
            {
              "language": "ckb",
              "text": "کارتپۆستەکە لە ڤییەناوە ئەمڕۆ گەیشت."
            },
            {
              "language": "en",
              "text": "The postcard from Vienna arrived today."
            },
            {
              "language": "fa",
              "text": "کارت پستال از وین امروز رسید."
            },
            {
              "language": "kmr",
              "text": "Kartpostala ji Viyanayê îro hat."
            },
            {
              "language": "pl",
              "text": "Pocztówka z Wiednia przyszła dzisiaj."
            },
            {
              "language": "ro",
              "text": "Cartea poștală din Viena a sosit astăzi."
            },
            {
              "language": "ru",
              "text": "Открытка из Вены пришла сегодня."
            },
            {
              "language": "sq",
              "text": "Kartolina nga Vjena mbërriti sot."
            },
            {
              "language": "tr",
              "text": "Viyana’dan kartpostal bugün geldi."
            }
          ]
        }
      ]
