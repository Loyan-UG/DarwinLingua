          "relationLabel": "noun",
          "note": "price"
        },
        {
          "lemma": "angeben",
          "relationLabel": "verb",
          "note": "to state"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بيان السعر؛ ذكر السعر"
        },
        {
          "language": "ckb",
          "text": "نیشاندانی نرخ"
        },
        {
          "language": "en",
          "text": "price indication; price information"
        },
        {
          "language": "fa",
          "text": "اعلام قیمت؛ درج قیمت"
        },
        {
          "language": "kmr",
          "text": "agahiya bihayê"
        },
        {
          "language": "pl",
          "text": "informacja o cenie"
        },
        {
          "language": "ro",
          "text": "indicare a prețului"
        },
        {
          "language": "ru",
          "text": "указание цены"
        },
        {
          "language": "sq",
          "text": "shënim çmimi"
        },
        {
          "language": "tr",
          "text": "fiyat bilgisi; fiyat belirtimi"
        }
      ],
      "examples": [
        {
          "baseText": "Auf dem Schild fehlt die Preisangabe.",
          "translations": [
            {
              "language": "ar",
              "text": "على اللافتة لا توجد معلومة السعر."
            },
            {
              "language": "ckb",
              "text": "لەسەر تابڵۆکە نیشاندانی نرخ نییە."
            },
            {
              "language": "en",
              "text": "The price information is missing on the sign."
            },
            {
              "language": "fa",
              "text": "روی تابلو قیمت نوشته نشده است."
            },
            {
              "language": "kmr",
              "text": "Li ser tabloyê agahiya bihayê tune ye."
            },
            {
              "language": "pl",
              "text": "Na tabliczce brakuje informacji o cenie."
            },
            {
              "language": "ro",
              "text": "Pe afiș lipsește indicarea prețului."
            },
            {
              "language": "ru",
              "text": "На табличке нет указания цены."
            },
            {
              "language": "sq",
              "text": "Në tabelë mungon shënimi i çmimit."
            },
            {
              "language": "tr",
              "text": "Tabelada fiyat bilgisi yok."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie die Preisangabe im Prospekt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق من السعر في النشرة."
            },
            {
              "language": "ckb",
              "text": "تکایە نیشاندانی نرخ لە پڕۆسپێکتەکەدا بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the price information in the brochure."
            },
            {
              "language": "fa",
              "text": "لطفاً قیمت را در بروشور بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe agahiya bihayê di broşurê de kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić cenę w prospekcie."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați prețul în broșură."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте цену в проспекте."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni çmimin në prospekt."
            },
            {
              "language": "tr",
              "text": "Lütfen broşürdeki fiyat bilgisini kontrol edin."
            }
          ]
        }
      ]
    },
