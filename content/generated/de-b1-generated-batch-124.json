  "entries": [
    {
      "word": "die Sperrung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Sperrungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Sper-rung",
      "topics": [
        "public-services",
        "technology-and-it",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Sperrung aufheben",
          "meaning": "to lift a block or closure"
        },
        {
          "text": "die Sperrung einer Karte",
          "meaning": "the blocking of a card"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sperren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إغلاق؛ حظر؛ إيقاف"
        },
        {
          "language": "ckb",
          "text": "داخستن؛ بلۆککردن؛ ڕاگرتن"
        },
        {
          "language": "en",
          "text": "closure; blocking; suspension"
        },
        {
          "language": "fa",
          "text": "مسدودسازی؛ بستن؛ تعلیق"
        },
        {
          "language": "kmr",
          "text": "girtin; astengkirin; rawestandin"
        },
        {
          "language": "pl",
          "text": "zamknięcie; blokada; zawieszenie"
        },
        {
          "language": "ro",
          "text": "închidere; blocare; suspendare"
        },
        {
          "language": "ru",
          "text": "закрытие; блокировка; приостановка"
        },
        {
          "language": "sq",
          "text": "mbyllje; bllokim; pezullim"
        },
        {
          "language": "tr",
          "text": "kapatma; bloke etme; askıya alma"
        }
      ],
      "examples": [
        {
          "baseText": "Wegen Bauarbeiten gibt es ab Montag eine Sperrung der Hauptstraße.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب أعمال البناء سيكون هناك إغلاق للشارع الرئيسي اعتبارًا من يوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "بەهۆی کاری بیناسازییەوە، لە دووشەممەوە شەقامی سەرەکی دادەخرێت."
            },
            {
              "language": "en",
              "text": "Because of construction work, the main road will be closed from Monday."
            },
            {
              "language": "fa",
              "text": "به دلیل کارهای ساختمانی، از دوشنبه خیابان اصلی بسته می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ji ber karên avahîsaziyê, ji duşemê ve rêya sereke tê girtin."
            },
            {
              "language": "pl",
              "text": "Z powodu prac budowlanych od poniedziałku będzie zamknięta główna ulica."
            },
            {
              "language": "ro",
              "text": "Din cauza lucrărilor de construcție, strada principală va fi închisă de luni."
            },
            {
              "language": "ru",
              "text": "Из-за строительных работ с понедельника будет закрыта главная улица."
            },
            {
              "language": "sq",
              "text": "Për shkak të punimeve, rruga kryesore do të mbyllet nga e hëna."
            },
            {
              "language": "tr",
              "text": "İnşaat çalışmaları nedeniyle ana cadde pazartesiden itibaren kapatılacak."
            }
          ]
        },
        {
          "baseText": "Nach drei falschen Passwörtern erfolgt automatisch eine Sperrung des Kontos.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد إدخال كلمة المرور بشكل خاطئ ثلاث مرات، يتم حظر الحساب تلقائيًا."
            },
            {
              "language": "ckb",
              "text": "دوای سێ جار وشەی نهێنی هەڵە، هەژمارەکە خۆکارانە بلۆک دەکرێت."
            },
            {
              "language": "en",
              "text": "After three wrong passwords, the account is automatically blocked."
            },
            {
              "language": "fa",
              "text": "بعد از سه بار رمز عبور اشتباه، حساب به‌صورت خودکار مسدود می‌شود."
            },
            {
              "language": "kmr",
              "text": "Piştî sê şîfreyên şaş, hesab bixweber tê astengkirin."
            },
            {
              "language": "pl",
              "text": "Po trzech błędnych hasłach konto zostaje automatycznie zablokowane."
            },
            {
              "language": "ro",
              "text": "După trei parole greșite, contul este blocat automat."
            },
            {
              "language": "ru",
              "text": "После трех неверных паролей аккаунт автоматически блокируется."
            },
            {
              "language": "sq",
              "text": "Pas tri fjalëkalimeve të gabuara, llogaria bllokohet automatikisht."
            },
            {
              "language": "tr",
              "text": "Üç yanlış şifreden sonra hesap otomatik olarak bloke edilir."
            }
          ]
        }
      ]
    },
    {
      "word": "springen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "springen",
      "pronunciationIpa": null,
      "syllableBreak": "sprin-gen",
      "topics": [
        "everyday-life",
        "technology-and-it"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: springt, sprang, ist gesprungen"
      ],
      "collocations": [
        {
          "text": "über einen Zaun springen",
          "meaning": "to jump over a fence"
        },
        {
          "text": "an eine andere Stelle springen",
          "meaning": "to jump to another place"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Sprung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقفز؛ ينتقل بسرعة"
        },
        {
          "language": "ckb",
          "text": "بازدان؛ بە خێرایی گواستنەوە"
        },
        {
          "language": "en",
          "text": "to jump; to move quickly to another point"
        },
        {
          "language": "fa",
          "text": "پریدن؛ سریع رفتن به نقطه‌ای دیگر"
        },
        {
          "language": "kmr",
          "text": "bazdan; bi lez çûn cihê din"
        },
        {
          "language": "pl",
          "text": "skakać; przeskakiwać"
        },
        {
          "language": "ro",
          "text": "a sări; a trece rapid la alt punct"
        },
        {
          "language": "ru",
          "text": "прыгать; переходить к другому месту"
        },
        {
          "language": "sq",
          "text": "të kërcesh; të kalosh shpejt diku tjetër"
        },
        {
          "language": "tr",
          "text": "atlamak; başka bir noktaya geçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kinder springen im Garten über die kleinen Pfützen.",
          "translations": [
            {
              "language": "ar",
              "text": "يقفز الأطفال في الحديقة فوق البرك الصغيرة."
            },
            {
              "language": "ckb",
              "text": "منداڵەکان لە باخچەدا بەسەر چەڵاوە بچووکەکاندا باز دەدەن."
            },
            {
              "language": "en",
              "text": "The children jump over the small puddles in the garden."
            },
            {
              "language": "fa",
              "text": "بچه‌ها در باغ از روی چاله‌های کوچک آب می‌پرند."
            },
            {
              "language": "kmr",
              "text": "Zarok li baxçe li ser golikên biçûk dibazin."
            },
            {
              "language": "pl",
              "text": "Dzieci skaczą w ogrodzie przez małe kałuże."
            },
            {
              "language": "ro",
              "text": "Copiii sar în grădină peste bălțile mici."
            },
            {
              "language": "ru",
              "text": "Дети в саду прыгают через маленькие лужи."
            },
            {
              "language": "sq",
              "text": "Fëmijët kërcejnë në kopsht mbi pellgjet e vogla."
            },
            {
              "language": "tr",
              "text": "Çocuklar bahçede küçük su birikintilerinin üzerinden atlıyor."
            }
          ]
        },
        {
          "baseText": "Mit dieser Taste können Sie direkt zum nächsten Abschnitt springen.",
          "translations": [
            {
              "language": "ar",
              "text": "باستخدام هذا الزر يمكنك الانتقال مباشرة إلى القسم التالي."
            },
            {
              "language": "ckb",
              "text": "بەم دوگمەیە دەتوانیت ڕاستەوخۆ بۆ بەشی دواتر بچیت."
            },
            {
              "language": "en",
              "text": "With this key, you can jump directly to the next section."
            },
            {
              "language": "fa",
              "text": "با این کلید می‌توانید مستقیم به بخش بعدی بروید."
            },
            {
              "language": "kmr",
              "text": "Bi vê bişkokê hûn dikarin rasterast biçin beşa din."
            },
            {
              "language": "pl",
              "text": "Tym klawiszem można przejść bezpośrednio do następnej sekcji."
            },
            {
              "language": "ro",
              "text": "Cu această tastă puteți trece direct la secțiunea următoare."
            },
            {
              "language": "ru",
              "text": "С помощью этой клавиши можно сразу перейти к следующему разделу."
            },
            {
              "language": "sq",
              "text": "Me këtë tast mund të kaloni drejtpërdrejt te seksioni tjetër."
            },
            {
              "language": "tr",
              "text": "Bu tuşla doğrudan bir sonraki bölüme geçebilirsiniz."
            }
          ]
        }
      ]
    },
