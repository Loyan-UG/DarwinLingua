      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خدمة حفظ الأمتعة"
        },
        {
          "language": "ckb",
          "text": "پاراستنی بار و کەلوپەل"
        },
        {
          "language": "en",
          "text": "luggage storage"
        },
        {
          "language": "fa",
          "text": "امانت بار؛ نگهداری چمدان"
        },
        {
          "language": "kmr",
          "text": "parastina baran"
        },
        {
          "language": "pl",
          "text": "przechowalnia bagażu"
        },
        {
          "language": "ro",
          "text": "depozit de bagaje"
        },
        {
          "language": "ru",
          "text": "камера хранения багажа"
        },
        {
          "language": "sq",
          "text": "ruajtje bagazhesh"
        },
        {
          "language": "tr",
          "text": "bagaj emanet; bagaj muhafaza"
        }
      ],
      "examples": [
        {
          "baseText": "Wo ist die Gepäckaufbewahrung im Bahnhof?",
          "translations": [
            {
              "language": "ar",
              "text": "أين خدمة حفظ الأمتعة في المحطة؟"
            },
            {
              "language": "ckb",
              "text": "پاراستنی بار لە وێستگەکە لە کوێیە؟"
            },
            {
              "language": "en",
              "text": "Where is the luggage storage in the station?"
            },
            {
              "language": "fa",
              "text": "امانت بار در ایستگاه کجاست؟"
            },
            {
              "language": "kmr",
              "text": "Li stasyonê parastina baran li ku ye?"
            },
            {
              "language": "pl",
              "text": "Gdzie jest przechowalnia bagażu na dworcu?"
            },
            {
              "language": "ro",
              "text": "Unde este depozitul de bagaje în gară?"
            },
            {
              "language": "ru",
              "text": "Где камера хранения багажа на вокзале?"
            },
            {
              "language": "sq",
              "text": "Ku është ruajtja e bagazheve në stacion?"
            },
            {
              "language": "tr",
              "text": "İstasyonda bagaj emaneti nerede?"
            }
          ]
        },
        {
          "baseText": "Wir lassen die Koffer in der Gepäckaufbewahrung.",
          "translations": [
            {
              "language": "ar",
              "text": "نترك الحقائب في خدمة حفظ الأمتعة."
            },
            {
              "language": "ckb",
              "text": "جانتا گەورەکان لە شوێنی پاراستنی بار دادەنێین."
            },
            {
              "language": "en",
              "text": "We leave the suitcases in the luggage storage."
            },
            {
              "language": "fa",
              "text": "چمدان‌ها را در امانت بار می‌گذاریم."
            },
            {
              "language": "kmr",
              "text": "Em valîzan di parastina baran de dihêlin."
            },
            {
              "language": "pl",
              "text": "Zostawiamy walizki w przechowalni bagażu."
            },
            {
              "language": "ro",
              "text": "Lăsăm valizele la depozitul de bagaje."
            },
            {
              "language": "ru",
              "text": "Мы оставляем чемоданы в камере хранения."
            },
            {
              "language": "sq",
              "text": "I lëmë valixhet te ruajtja e bagazheve."
            },
            {
              "language": "tr",
              "text": "Valizeleri bagaj emanetine bırakıyoruz."
            }
          ]
        }
      ]
    },
