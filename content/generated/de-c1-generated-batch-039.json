  "entries": [
    {
      "word": "emporsteigen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "emporsteigen",
      "pronunciationIpa": null,
      "syllableBreak": "em-por-stei-gen",
      "topics": [
        "environment-and-sustainability",
        "finance-and-accounting",
        "advanced-analysis"
      ],
      "usageLabels": [
        "written",
        "advanced",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb with directional prefix: steigt empor, stieg empor, ist emporgestiegen"
      ],
      "collocations": [
        {
          "text": "Rauch steigt empor",
          "meaning": "smoke rises upward"
        },
        {
          "text": "Kosten steigen empor",
          "meaning": "costs rise sharply"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Aufstieg",
          "relationLabel": "noun",
          "note": "related idea of rising"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصعد؛ يرتفع إلى الأعلى"
        },
        {
          "language": "ckb",
          "text": "بەرز دەبێتەوە؛ سەر دەکەوێت"
        },
        {
          "language": "en",
          "text": "to rise up; to ascend"
        },
        {
          "language": "fa",
          "text": "بالا رفتن؛ صعود کردن"
        },
        {
          "language": "kmr",
          "text": "bilindbûn; hilkişîn"
        },
        {
          "language": "pl",
          "text": "wznosić się; piąć się w górę"
        },
        {
          "language": "ro",
          "text": "a se ridica; a urca"
        },
        {
          "language": "ru",
          "text": "подниматься; восходить"
        },
        {
          "language": "sq",
          "text": "të ngjitesh; të ngrihesh lart"
        },
        {
          "language": "tr",
          "text": "yükselmek; yukarı çıkmak"
        }
      ],
      "examples": [
        {
          "baseText": "Über dem Industriegebiet stieg am Morgen dichter Rauch empor.",
          "translations": [
            {
              "language": "ar",
              "text": "في الصباح ارتفع دخان كثيف فوق المنطقة الصناعية."
            },
            {
              "language": "ckb",
              "text": "بەیانی دووکەڵێکی چڕ لەسەر ناوچەی پیشەسازی بەرزبووەوە."
            },
            {
              "language": "en",
              "text": "In the morning, thick smoke rose above the industrial area."
            },
            {
              "language": "fa",
              "text": "صبح، دود غلیظی بر فراز منطقه صنعتی بالا رفت."
            },
            {
              "language": "kmr",
              "text": "Serê sibê dûmaneke qelew li ser herêma pîşesaziyê bilind bû."
            },
            {
              "language": "pl",
              "text": "Rano nad terenem przemysłowym unosił się gęsty dym."
            },
            {
              "language": "ro",
              "text": "Dimineața, deasupra zonei industriale s-a ridicat fum dens."
            },
            {
              "language": "ru",
              "text": "Утром над промышленной зоной поднялся густой дым."
            },
            {
              "language": "sq",
              "text": "Në mëngjes, mbi zonën industriale u ngrit tym i dendur."
            },
            {
              "language": "tr",
              "text": "Sabah sanayi bölgesinin üzerinde yoğun duman yükseldi."
            }
          ]
        },
        {
          "baseText": "Nach der Reform stiegen die Verwaltungskosten zunächst deutlich empor.",
          "translations": [
            {
              "language": "ar",
              "text": "پس از الإصلاح ارتفعت التكاليف الإدارية في البداية بشكل واضح."
            },
            {
              "language": "ckb",
              "text": "دوای چاکسازییەکە تێچووی کارگێڕی سەرەتا بە ڕوونی بەرزبووەوە."
            },
            {
              "language": "en",
              "text": "After the reform, administrative costs initially rose significantly."
            },
            {
              "language": "fa",
              "text": "پس از اصلاحات، هزینه‌های اداری در ابتدا به‌طور محسوسی بالا رفت."
            },
            {
              "language": "kmr",
              "text": "Piştî reformê, lêçûnên rêveberiyê di destpêkê de bi eşkere bilind bûn."
            },
            {
              "language": "pl",
              "text": "Po reformie koszty administracyjne początkowo wyraźnie wzrosły."
            },
            {
              "language": "ro",
              "text": "După reformă, costurile administrative au crescut inițial semnificativ."
            },
            {
              "language": "ru",
              "text": "После реформы административные расходы сначала заметно выросли."
            },
            {
              "language": "sq",
              "text": "Pas reformës, kostot administrative fillimisht u rritën ndjeshëm."
            },
            {
              "language": "tr",
              "text": "Reformdan sonra idari maliyetler başlangıçta belirgin biçimde yükseldi."
            }
          ]
        }
      ]
    },
    {
      "word": "entfahren",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entfahren",
      "pronunciationIpa": null,
      "syllableBreak": "ent-fah-ren",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "inseparable verb: entfährt, entfuhr, ist entfahren; usually something slips out of someone"
      ],
      "collocations": [
        {
          "text": "ihm entfährt eine Bemerkung",
          "meaning": "a remark slips out of him"
        },
        {
          "text": "ein Seufzer entfährt ihr",
          "meaning": "a sigh escapes her"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fahren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفلت منه قول؛ يصدر عنه دون قصد"
        },
        {
          "language": "ckb",
          "text": "قسەیەک لێی دەردەچێت؛ بێ مەبەست دەردەکەوێت"
        },
        {
          "language": "en",
          "text": "to slip out; to escape someone unintentionally"
        },
        {
          "language": "fa",
          "text": "بی‌اختیار از دهان کسی پریدن؛ ناخواسته خارج شدن"
        },
        {
          "language": "kmr",
          "text": "bê mebest ji dev derketin; xilasbûn"
        },
        {
          "language": "pl",
          "text": "wyrwać się komuś; wymknąć się"
        },
        {
          "language": "ro",
          "text": "a-i scăpa cuiva; a ieși fără intenție"
        },
        {
          "language": "ru",
          "text": "сорваться с языка; вырваться"
        },
        {
          "language": "sq",
          "text": "t’i shpëtojë dikujt; të dalë pa dashje"
        },
        {
          "language": "tr",
          "text": "ağzından kaçmak; istemeden çıkmak"
        }
      ],
      "examples": [
        {
          "baseText": "In der angespannten Sitzung entfuhr ihm eine Bemerkung, die er sofort bereute.",
          "translations": [
            {
              "language": "ar",
              "text": "في الاجتماع المتوتر أفلتت منه ملاحظة ندم عليها فورًا."
            },
            {
              "language": "ckb",
              "text": "لە کۆبوونەوەی پڕفشارەکەدا تێبینییەک لێی دەرچوو کە دەستبەجێ پەشیمان بووەوە."
            },
            {
              "language": "en",
              "text": "In the tense meeting, a remark slipped out that he immediately regretted."
            },
            {
              "language": "fa",
              "text": "در جلسه پرتنش، جمله‌ای ناخواسته از دهانش پرید که بلافاصله از آن پشیمان شد."
            },
            {
              "language": "kmr",
              "text": "Di civîna tengav de gotinek ji devê wî derket ku yekser poşman bû."
            },
            {
              "language": "pl",
              "text": "Podczas napiętego spotkania wyrwała mu się uwaga, której natychmiast pożałował."
            },
            {
              "language": "ro",
              "text": "În ședința tensionată i-a scăpat o observație pe care a regretat-o imediat."
            },
            {
              "language": "ru",
              "text": "На напряженном совещании у него сорвалась реплика, о которой он сразу пожалел."
            },
            {
              "language": "sq",
              "text": "Në mbledhjen e tensionuar i shpëtoi një vërejtje për të cilën u pendua menjëherë."
            },
            {
              "language": "tr",
              "text": "Gergin toplantıda ağzından hemen pişman olduğu bir söz kaçtı."
            }
          ]
        },
        {
          "baseText": "Als sie die endgültigen Zahlen sah, entfuhr ihr ein hörbarer Seufzer.",
          "translations": [
            {
              "language": "ar",
              "text": "عندما رأت الأرقام النهائية صدر عنها تنهّد مسموع."
            },
            {
              "language": "ckb",
              "text": "کاتێک ژمارە کۆتاییەکانی بینی، هەناسەیەکی بیستراوی لێ دەرچوو."
            },
            {
              "language": "en",
              "text": "When she saw the final figures, an audible sigh escaped her."
            },
            {
              "language": "fa",
              "text": "وقتی ارقام نهایی را دید، آهی شنیدنی از او بلند شد."
            },
            {
              "language": "kmr",
              "text": "Dema hejmarên dawî dîtin, hinek axînek bihîstinbar jê derket."
            },
            {
              "language": "pl",
              "text": "Gdy zobaczyła ostateczne liczby, wyrwało jej się słyszalne westchnienie."
            },
            {
              "language": "ro",
              "text": "Când a văzut cifrele finale, i-a scăpat un oftat auzibil."
            },
            {
              "language": "ru",
              "text": "Когда она увидела окончательные цифры, у нее вырвался слышный вздох."
            },
            {
              "language": "sq",
              "text": "Kur pa shifrat përfundimtare, i shpëtoi një psherëtimë e dëgjueshme."
            },
            {
              "language": "tr",
              "text": "Nihai rakamları görünce duyulur bir iç çekiş ağzından kaçtı."
            }
          ]
        }
      ]
    },
    {
      "word": "entfalten",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entfalten",
      "pronunciationIpa": null,
      "syllableBreak": "ent-fal-ten",
      "topics": [
        "management-and-leadership",
        "education-and-training",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb: entfaltet, entfaltete, hat entfaltet; also reflexive: sich entfalten"
      ],
      "collocations": [
        {
          "text": "Potenzial entfalten",
          "meaning": "to unfold potential"
        },
        {
          "text": "Wirkung entfalten",
          "meaning": "to take effect"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Entfaltung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يطوّر؛ يكشف؛ يطلق أثرًا أو إمكانًا"
        },
        {
          "language": "ckb",
          "text": "پەرە پێدەدات؛ دەردەخات؛ کاریگەری یان توانایی دەخاتە کار"
        },
        {
          "language": "en",
          "text": "to unfold; to develop; to take effect"
        },
        {
          "language": "fa",
          "text": "شکوفا کردن؛ بسط دادن؛ اثر گذاشتن"
        },
        {
          "language": "kmr",
          "text": "vekirin; pêşxistin; bandor nîşandan"
        },
        {
          "language": "pl",
          "text": "rozwinąć; ujawnić; wywrzeć wpływ"
        },
        {
          "language": "ro",
          "text": "a desfășura; a dezvolta; a produce efect"
        },
        {
          "language": "ru",
          "text": "разворачивать; раскрывать; оказывать действие"
        },
        {
          "language": "sq",
          "text": "të zhvillosh; të shpalosësh; të japësh efekt"
        },
        {
          "language": "tr",
          "text": "geliştirmek; açığa çıkarmak; etki göstermek"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Führungsstruktur soll den Teams mehr Raum geben, ihr Potenzial zu entfalten.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي أن تمنح هيكلة القيادة الجديدة الفرق مساحة أكبر لتطوير إمكاناتها."
            },
            {
              "language": "ckb",
              "text": "پێکهاتەی نوێی سەرکردایەتی دەبێت بۆ تیمەکان بوارێکی زیاتر بدات تا تواناکانیان پەرە پێبدەن."
            },
            {
              "language": "en",
              "text": "The new leadership structure is intended to give teams more room to unfold their potential."
            },
            {
              "language": "fa",
              "text": "ساختار جدید رهبری باید فضای بیشتری به تیم‌ها بدهد تا توانایی‌های خود را شکوفا کنند."
            },
