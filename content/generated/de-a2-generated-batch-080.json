      "examples": [
        {
          "baseText": "Ich lasse ein Taxi zur Rezeption reservieren.",
          "translations": [
            {
              "language": "ar",
              "text": "أطلب حجز سيارة أجرة إلى الاستقبال."
            },
            {
              "language": "ckb",
              "text": "دەهێڵم تاکسییەک بۆ ڕیسێپشن حجز بکرێت."
            },
            {
              "language": "en",
              "text": "I have a taxi reserved to the reception."
            },
            {
              "language": "fa",
              "text": "می‌خواهم یک تاکسی برای پذیرش رزرو شود."
            },
            {
              "language": "kmr",
              "text": "Ez taksiyekê ji bo resepsiyonê rezerv didim."
            },
            {
              "language": "pl",
              "text": "Proszę o zarezerwowanie taksówki na recepcję."
            },
            {
              "language": "ro",
              "text": "Cer să fie rezervat un taxi la recepție."
            },
            {
              "language": "ru",
              "text": "Я прошу забронировать такси на ресепшене."
            },
