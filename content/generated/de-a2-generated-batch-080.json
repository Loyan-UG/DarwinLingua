              "language": "sq",
              "text": "Kërkoj të rezervohet një taksi te recepsioni."
            },
            {
              "language": "tr",
              "text": "Resepsiyondan taksi ayırtıyorum."
            }
          ]
        },
        {
          "baseText": "Kann ich hier einen Platz reservieren lassen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني أن أطلب حجز مكان هنا؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم لێرە شوێنێک حجز بکەم؟"
            },
            {
              "language": "en",
              "text": "Can I have a seat reserved here?"
            },
            {
              "language": "fa",
              "text": "می‌توانم اینجا یک جا رزرو کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim li vir cihêkê rezerv bikim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę tutaj zarezerwować miejsce?"
            },
            {
              "language": "ro",
              "text": "Pot să rezerv un loc aici?"
            },
            {
              "language": "ru",
              "text": "Можно здесь забронировать место?"
            },
            {
              "language": "sq",
              "text": "A mund të rezervoj një vend këtu?"
            },
            {
              "language": "tr",
              "text": "Burada bir yer ayırtabilir miyim?"
            }
          ]
        }
