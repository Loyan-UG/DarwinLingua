      "examples": [
        {
          "baseText": "Ich möchte einen Tisch für zwei Personen reservieren.",
          "translations": [
            {
              "language": "ar",
              "text": "أود حجز طاولة لشخصين."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت مێزێک بۆ دوو کەس حجز بکەم."
            },
            {
              "language": "en",
              "text": "I would like to reserve a table for two people."
            },
            {
              "language": "fa",
              "text": "می‌خواهم یک میز برای دو نفر رزرو کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim maseyekê ji bo du kesan rezerv bikim."
            },
            {
              "language": "pl",
              "text": "Chciałbym zarezerwować stolik dla dwóch osób."
            },
            {
              "language": "ro",
              "text": "Aș dori să rezerv o masă pentru două persoane."
            },
            {
              "language": "ru",
              "text": "Я хотел бы забронировать столик на двух человек."
            },
            {
              "language": "sq",
              "text": "Do të doja të rezervoj një tavolinë për dy persona."
            },
            {
              "language": "tr",
              "text": "İki kişilik bir masa ayırtmak istiyorum."
            }
          ]
        },
        {
          "baseText": "Wir reservieren die Tickets online.",
          "translations": [
            {
              "language": "ar",
              "text": "نحجز التذاكر عبر الإنترنت."
            },
            {
              "language": "ckb",
              "text": "بلیتەکان ئۆنلاین حجز دەکەین."
            },
            {
              "language": "en",
              "text": "We book the tickets online."
            },
            {
              "language": "fa",
              "text": "ما بلیت‌ها را آنلاین رزرو می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em bilêtan online rezerv dikin."
            },
            {
              "language": "pl",
              "text": "Rezerwujemy bilety online."
            },
            {
              "language": "ro",
              "text": "Rezervăm biletele online."
            },
            {
              "language": "ru",
              "text": "Мы бронируем билеты онлайн."
            },
            {
              "language": "sq",
              "text": "Ne i rezervojmë biletat online."
            },
            {
              "language": "tr",
              "text": "Biletleri internetten ayırtıyoruz."
            }
          ]
        }
      ]
