  "entries": [
    {
      "word": "allerdings",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "al-ler-dings",
      "topics": [
        "business-communication",
        "everyday-life",
        "work-and-jobs"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "business"
      ],
      "contextLabels": [
        "management",
        "customer-service"
      ],
      "grammarNotes": [
        "adverb",
        "used to add a contrast or limitation; often means however or admittedly"
      ],
      "collocations": [
        {
          "text": "das stimmt allerdings",
          "meaning": "that is true, however/admittedly"
        },
        {
          "text": "allerdings nur",
          "meaning": "however only"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "allerdings",
          "relationLabel": "adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "لكن؛ مع ذلك؛ بالفعل"
        },
        {
          "language": "ckb",
          "text": "بەڵام؛ لەگەڵ ئەوەشدا؛ بەڕاستی"
        },
        {
          "language": "en",
          "text": "however; though; admittedly"
        },
        {
          "language": "fa",
          "text": "البته؛ با این حال؛ اما"
        },
        {
          "language": "kmr",
          "text": "lê; herçend; bi rastî"
        },
        {
          "language": "pl",
          "text": "jednak; co prawda"
        },
        {
          "language": "ro",
          "text": "totuși; însă; ce-i drept"
        },
        {
          "language": "ru",
          "text": "однако; правда; впрочем"
        },
        {
          "language": "sq",
          "text": "megjithatë; sidoqoftë; vërtet"
        },
        {
          "language": "tr",
          "text": "ancak; gerçi; doğrusu"
        }
      ],
      "examples": [
        {
          "baseText": "Der Preis ist gut, allerdings ist die Lieferzeit zu lang.",
          "translations": [
            {
              "language": "ar",
              "text": "السعر جيد، لكن مدة التسليم طويلة جدًا."
            },
            {
              "language": "ckb",
              "text": "نرخەکە باشە، بەڵام ماوەی گەیاندن زۆر درێژە."
            },
            {
              "language": "en",
              "text": "The price is good; however, the delivery time is too long."
            },
            {
              "language": "fa",
              "text": "قیمت خوب است، اما زمان تحویل خیلی طولانی است."
            },
            {
              "language": "kmr",
              "text": "Biha baş e, lê dema radestkirinê pir dirêj e."
            },
            {
              "language": "pl",
              "text": "Cena jest dobra, jednak czas dostawy jest zbyt długi."
            },
            {
              "language": "ro",
              "text": "Prețul este bun, însă termenul de livrare este prea lung."
            },
            {
              "language": "ru",
              "text": "Цена хорошая, однако срок поставки слишком долгий."
            },
            {
              "language": "sq",
              "text": "Çmimi është i mirë, megjithatë koha e dorëzimit është shumë e gjatë."
            },
            {
              "language": "tr",
              "text": "Fiyat iyi, ancak teslim süresi çok uzun."
            }
          ]
        },
        {
          "baseText": "Ich kann morgen kommen, allerdings erst nach dem Arzttermin.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنني أن آتي غدًا، لكن فقط بعد موعد الطبيب."
            },
            {
              "language": "ckb",
              "text": "دەتوانم سبەی بێم، بەڵام تەنها دوای کاتی پزیشک."
            },
            {
              "language": "en",
              "text": "I can come tomorrow, but only after the doctor’s appointment."
            },
            {
              "language": "fa",
              "text": "می‌توانم فردا بیایم، البته فقط بعد از وقت دکتر."
            },
            {
              "language": "kmr",
              "text": "Ez dikarim sibê werim, lê tenê piştî randevûya bijîşk."
            },
            {
              "language": "pl",
              "text": "Mogę przyjść jutro, jednak dopiero po wizycie u lekarza."
            },
            {
              "language": "ro",
              "text": "Pot veni mâine, însă doar după programarea la medic."
            },
            {
              "language": "ru",
              "text": "Я могу прийти завтра, но только после приёма у врача."
            },
            {
              "language": "sq",
              "text": "Mund të vij nesër, por vetëm pas takimit te mjeku."
            },
            {
              "language": "tr",
              "text": "Yarın gelebilirim, ancak doktor randevusundan sonra."
            }
          ]
        }
      ]
    },
