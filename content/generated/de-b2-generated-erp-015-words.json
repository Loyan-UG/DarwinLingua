  "entries": [
    {
      "word": "Kundenkategorie",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kundenkategorien",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kun-den-ka-te-go-rie",
      "topics": [
        "sales-and-customers",
        "erp-and-business-systems",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; category used to classify customers"
      ],
      "collocations": [
        {
          "text": "eine Kundenkategorie zuordnen",
          "meaning": "to assign a customer category"
        },
        {
          "text": "nach Kundenkategorie auswerten",
          "meaning": "to analyze by customer category"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Kunde",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Kategorie",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فئة العميل"
        },
        {
          "language": "ckb",
          "text": "پۆلی کڕیار"
        },
        {
          "language": "en",
          "text": "customer category"
        },
        {
          "language": "fa",
          "text": "دسته‌بندی مشتری"
        },
        {
          "language": "kmr",
          "text": "kategorîya mişterî"
        },
        {
          "language": "pl",
          "text": "kategoria klienta"
        },
        {
          "language": "ro",
          "text": "categorie de client"
        },
        {
          "language": "ru",
          "text": "категория клиента"
        },
        {
          "language": "sq",
          "text": "kategori klienti"
        },
        {
          "language": "tr",
          "text": "müşteri kategorisi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kundenkategorie steuert im ERP, welche Rabatte automatisch vorgeschlagen werden.",
          "translations": [
            {
              "language": "ar",
              "text": "تحدد فئة العميل في ERP أي خصومات تُقترح تلقائيًا."
            },
            {
              "language": "ckb",
              "text": "پۆلی کڕیار لە ERP دا دیاری دەکات کام داشکاندنەکان خۆکارانە پێشنیار دەکرێن."
            },
            {
              "language": "en",
              "text": "The customer category controls in the ERP which discounts are suggested automatically."
            },
            {
              "language": "fa",
              "text": "دسته‌بندی مشتری در ERP تعیین می‌کند کدام تخفیف‌ها به‌صورت خودکار پیشنهاد شوند."
            },
            {
              "language": "kmr",
              "text": "Kategorîya mişterî di ERP de kontrol dike kîjan daxistin xweber têne pêşniyarkirin."
            },
            {
              "language": "pl",
              "text": "Kategoria klienta steruje w ERP tym, które rabaty są automatycznie proponowane."
            },
            {
              "language": "ro",
              "text": "Categoria de client controlează în ERP ce discounturi sunt propuse automat."
            },
            {
              "language": "ru",
              "text": "Категория клиента в ERP управляет тем, какие скидки предлагаются автоматически."
            },
            {
              "language": "sq",
              "text": "Kategoria e klientit kontrollon në ERP cilat zbritje sugjerohen automatikisht."
            },
            {
              "language": "tr",
              "text": "Müşteri kategorisi ERP’de hangi indirimlerin otomatik önerileceğini yönetir."
            }
          ]
        },
        {
          "baseText": "Für die Auswertung trennt der Vertrieb die Kunden nach Kundenkategorie und Region.",
          "translations": [
            {
              "language": "ar",
              "text": "لأجل التحليل يفصل قسم المبيعات العملاء حسب فئة العميل والمنطقة."
            },
            {
              "language": "ckb",
              "text": "بۆ شیکردنەوە، بەشی فرۆشتن کڕیاران بە پێی پۆلی کڕیار و ناوچە جیا دەکاتەوە."
            },
            {
              "language": "en",
              "text": "For the analysis, sales separates customers by customer category and region."
            },
            {
              "language": "fa",
              "text": "برای تحلیل، فروش مشتریان را بر اساس دسته‌بندی مشتری و منطقه جدا می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ji bo analîzê, firotan mişteriyan li gorî kategorîya mişterî û herêmê cuda dike."
            },
            {
              "language": "pl",
              "text": "Do analizy sprzedaż dzieli klientów według kategorii klienta i regionu."
            },
            {
              "language": "ro",
              "text": "Pentru analiză, vânzările separă clienții după categoria de client și regiune."
            },
            {
              "language": "ru",
              "text": "Для анализа отдел продаж разделяет клиентов по категории и региону."
            },
            {
              "language": "sq",
              "text": "Për analizë, shitjet i ndajnë klientët sipas kategorisë së klientit dhe rajonit."
            },
            {
              "language": "tr",
              "text": "Analiz için satış ekibi müşterileri müşteri kategorisine ve bölgeye göre ayırır."
            }
          ]
        }
      ]
    },
    {
      "word": "Kundenreklamation",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kundenreklamationen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kun-den-re-kla-ma-ti-on",
      "topics": [
        "customer-service",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; complaint made by a customer"
      ],
      "collocations": [
        {
          "text": "eine Kundenreklamation erfassen",
          "meaning": "to record a customer complaint"
        },
        {
          "text": "eine Kundenreklamation bearbeiten",
          "meaning": "to handle a customer complaint"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Kunde",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "reklamieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شكوى العميل"
        },
        {
          "language": "ckb",
          "text": "سکاڵای کڕیار"
        },
        {
          "language": "en",
          "text": "customer complaint"
        },
        {
          "language": "fa",
          "text": "شکایت مشتری؛ اعتراض مشتری"
        },
        {
          "language": "kmr",
          "text": "gilîkirina mişterî"
        },
        {
          "language": "pl",
          "text": "reklamacja klienta"
        },
        {
          "language": "ro",
          "text": "reclamație client"
        },
        {
          "language": "ru",
          "text": "претензия клиента"
        },
        {
          "language": "sq",
          "text": "ankesë klienti"
        },
        {
          "language": "tr",
          "text": "müşteri şikayeti"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kundenreklamation wird im ERP mit Fotos und Lieferscheinnummer dokumentiert.",
          "translations": [
            {
              "language": "ar",
              "text": "تُوثق شكوى العميل في ERP بالصور ورقم سند التسليم."
            },
            {
              "language": "ckb",
              "text": "سکاڵای کڕیار لە ERP دا بە وێنە و ژمارەی پسوڵەی گەیاندن بەڵگەدار دەکرێت."
            },
            {
              "language": "en",
              "text": "The customer complaint is documented in the ERP with photos and the delivery note number."
            },
            {
              "language": "fa",
              "text": "شکایت مشتری در ERP با عکس‌ها و شماره برگه تحویل مستند می‌شود."
            },
            {
              "language": "kmr",
              "text": "Gilîkirina mişterî di ERP de bi wêne û hejmara belgeya radestkirinê tê belgekirin."
            },
            {
              "language": "pl",
              "text": "Reklamacja klienta jest dokumentowana w ERP zdjęciami i numerem dokumentu dostawy."
            },
            {
              "language": "ro",
              "text": "Reclamația clientului este documentată în ERP cu fotografii și numărul avizului de livrare."
            },
            {
              "language": "ru",
              "text": "Претензия клиента документируется в ERP с фотографиями и номером накладной."
            },
            {
              "language": "sq",
              "text": "Ankesa e klientit dokumentohet në ERP me fotografi dhe numrin e fletëdorëzimit."
            },
            {
              "language": "tr",
              "text": "Müşteri şikayeti ERP’de fotoğraflar ve teslimat belgesi numarasıyla belgelenir."
            }
          ]
        },
        {
          "baseText": "Der Service ruft den Kunden zurück, sobald die Kundenreklamation geprüft wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "يتصل قسم الخدمة بالعميل بعد فحص الشكوى مباشرة."
            },
            {
              "language": "ckb",
              "text": "بەشی خزمەتگوزاری پەیوەندی بە کڕیارەوە دەکات هەر کات سکاڵاکە پشکنرا."
            },
            {
              "language": "en",
              "text": "Service calls the customer back as soon as the complaint has been checked."
            },
            {
              "language": "fa",
              "text": "خدمات پس از بررسی شکایت مشتری با او تماس می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Xizmet gava gilîkirina mişterî hat kontrolkirin vedigere bi mişterî re telefon dike."
            },
            {
              "language": "pl",
              "text": "Serwis oddzwania do klienta, gdy tylko reklamacja zostanie sprawdzona."
            },
            {
              "language": "ro",
              "text": "Service-ul sună clientul înapoi imediat ce reclamația a fost verificată."
            },
            {
              "language": "ru",
              "text": "Сервис перезванивает клиенту, как только претензия проверена."
            },
            {
              "language": "sq",
              "text": "Shërbimi e telefonon klientin sapo ankesa të jetë kontrolluar."
            },
            {
              "language": "tr",
              "text": "Servis, müşteri şikayeti kontrol edilir edilmez müşteriyi geri arar."
            }
          ]
        }
      ]
    },
