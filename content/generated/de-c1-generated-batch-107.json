      ],
      "collocations": [
        {
          "text": "ein Gebiet umschließen",
          "meaning": "to enclose an area"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schließen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Einschluss",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحيط؛ يضم داخل حدود"
        },
        {
          "language": "ckb",
          "text": "دەورە دەدات؛ لە ناو سنووردا دەگرێت"
        },
        {
          "language": "en",
          "text": "to enclose; to surround; to include"
        },
        {
          "language": "fa",
          "text": "احاطه کردن؛ دربر گرفتن"
        },
        {
          "language": "kmr",
          "text": "dor girtin; di nav sînorekê de girtin"
        },
        {
          "language": "pl",
          "text": "otaczać; obejmować"
        },
        {
          "language": "ro",
          "text": "a înconjura; a cuprinde"
        },
        {
          "language": "ru",
          "text": "окружать; включать в границы"
        },
        {
          "language": "sq",
          "text": "të rrethosh; të përfshish"
        },
        {
          "language": "tr",
          "text": "çevrelemek; içine almak"
        }
      ],
      "examples": [
        {
          "baseText": "Die alte Mauer umschließt den Innenhof vollständig und schützt ihn vor Straßenlärm.",
          "translations": [
            {
              "language": "ar",
