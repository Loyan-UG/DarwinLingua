  "entries": [
    {
      "word": "umgraben",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "umgraben",
      "pronunciationIpa": null,
      "syllableBreak": "um-gra-ben",
      "topics": [
        "environment-and-sustainability",
        "housing-and-real-estate",
        "everyday-life"
      ],
      "usageLabels": [
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong verb; means to dig over soil, often for gardening, construction, or environmental work"
      ],
      "collocations": [
        {
          "text": "den Boden umgraben",
          "meaning": "to dig over the soil"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "graben",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Graben",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقلب التربة بالحفر"
        },
        {
          "language": "ckb",
          "text": "خاکەکە هەڵدەکۆڵێت و دەیگۆڕێت"
        },
        {
          "language": "en",
          "text": "to dig over; to turn over soil"
        },
        {
          "language": "fa",
          "text": "زیرورو کردن خاک؛ شخم زدن با بیل"
        },
        {
          "language": "kmr",
          "text": "axê kolandin û vegerandin"
        },
        {
          "language": "pl",
          "text": "przekopać ziemię"
        },
        {
          "language": "ro",
          "text": "a săpa și a întoarce solul"
        },
        {
          "language": "ru",
          "text": "перекапывать землю"
        },
        {
          "language": "sq",
          "text": "të gërmosh dhe kthesh dheun"
        },
        {
          "language": "tr",
          "text": "toprağı kazıp çevirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Vor der Sanierung musste der kontaminierte Boden großflächig umgegraben und untersucht werden.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل أعمال الترميم كان لا بد من قلب التربة الملوثة على مساحة واسعة وفحصها."
            },
            {
              "language": "ckb",
              "text": "پێش چاکسازییەکە پێویست بوو خاکی پیسکراو بە فراوانی هەڵبکەندرێت و پشکنین بکرێت."
            },
            {
              "language": "en",
              "text": "Before the remediation, the contaminated soil had to be extensively dug over and examined."
            },
            {
              "language": "fa",
              "text": "پیش از پاکسازی، خاک آلوده باید در سطح وسیع زیرورو و بررسی می‌شد."
            },
            {
              "language": "kmr",
              "text": "Berî paqijkirinê diviya axa qirêjkirî bi firehî were kolandin û lêkolînkirin."
            },
            {
              "language": "pl",
              "text": "Przed rekultywacją skażoną ziemię trzeba było przekopać na dużej powierzchni i zbadać."
            },
            {
              "language": "ro",
              "text": "Înainte de remediere, solul contaminat a trebuit să fie săpat pe suprafețe mari și analizat."
            },
            {
              "language": "ru",
              "text": "Перед санацией загрязненную почву пришлось широко перекопать и исследовать."
            },
            {
              "language": "sq",
              "text": "Para sanimit, toka e ndotur duhej gërmuar gjerësisht dhe analizuar."
            },
            {
              "language": "tr",
              "text": "Islah çalışmasından önce kirlenmiş toprağın geniş ölçekte kazılıp incelenmesi gerekiyordu."
            }
          ]
        },
        {
          "baseText": "Im Gemeinschaftsgarten wurden die Beete umgegraben, damit der Boden im Frühjahr lockerer ist.",
          "translations": [
            {
              "language": "ar",
              "text": "في الحديقة المشتركة قُلبت الأحواض كي تكون التربة أرخى في الربيع."
            },
            {
              "language": "ckb",
              "text": "لە باخی هاوبەشدا کێڵگە بچووکەکان هەڵکەندران بۆ ئەوەی خاکەکە لە بەهاردا نەرمتر بێت."
            },
            {
              "language": "en",
              "text": "In the community garden, the beds were dug over so the soil would be looser in spring."
            },
            {
              "language": "fa",
              "text": "در باغچه مشترک، کرت‌ها زیرورو شدند تا خاک در بهار نرم‌تر باشد."
            },
            {
              "language": "kmr",
              "text": "Di baxçeya hevpar de bejgeh hatin kolandin da ku ax di biharanê de hêsantir be."
            },
            {
              "language": "pl",
              "text": "W ogrodzie społecznym przekopano grządki, aby wiosną ziemia była luźniejsza."
            },
            {
              "language": "ro",
              "text": "În grădina comunitară, straturile au fost săpate pentru ca solul să fie mai afânat primăvara."
            },
            {
              "language": "ru",
              "text": "В общественном саду грядки перекопали, чтобы весной почва была рыхлее."
            },
            {
              "language": "sq",
              "text": "Në kopshtin e përbashkët u gërmuan parcelat që toka të ishte më e shkrifët në pranverë."
            },
            {
              "language": "tr",
              "text": "Topluluk bahçesinde ilkbaharda toprak daha gevşek olsun diye tarhlar kazılıp çevrildi."
            }
          ]
        }
      ]
    },
    {
      "word": "umschlagen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "umschlagen",
      "pronunciationIpa": null,
      "syllableBreak": "um-schla-gen",
      "topics": [
        "warehouse-and-logistics",
        "advanced-analysis",
        "social-and-relationships"
      ],
      "usageLabels": [
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong verb; can mean to turn suddenly, change into the opposite, fold over, or handle goods in logistics"
      ],
      "collocations": [
        {
          "text": "in Ablehnung umschlagen",
          "meaning": "to turn into rejection"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Umschlag",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "schlagen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينقلب؛ يتحول فجأة؛ يداول بضائع"
        },
        {
          "language": "ckb",
          "text": "لەناکاو دەگۆڕێت؛ دەسووڕێتەوە؛ کاڵا دەگوازێتەوە"
        },
        {
          "language": "en",
          "text": "to turn suddenly; to change; to handle cargo"
        },
        {
          "language": "fa",
          "text": "ناگهان تغییر کردن؛ برگشتن؛ جابه‌جایی کالا کردن"
        },
        {
          "language": "kmr",
          "text": "ji nişka ve guhertin; barkirin û dakirin"
        },
        {
          "language": "pl",
          "text": "zmienić się gwałtownie; przeładowywać towary"
        },
        {
          "language": "ro",
          "text": "a se schimba brusc; a manipula mărfuri"
        },
        {
          "language": "ru",
          "text": "резко меняться; переваливать грузы"
        },
        {
          "language": "sq",
          "text": "të ndryshojë papritur; të përpunojë mallra"
        },
        {
          "language": "tr",
          "text": "ani şekilde dönüşmek; yük elleçlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Die anfängliche Zustimmung kann schnell in Widerstand umschlagen, wenn die Folgen nicht transparent erklärt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "قد يتحول القبول الأولي سريعاً إلى مقاومة إذا لم تُشرح العواقب بشفافية."
            },
            {
              "language": "ckb",
              "text": "ڕەزامەندیی سەرەتایی دەتوانێت خێرا بگۆڕێت بۆ بەرەنگاری ئەگەر ئەنجامەکان بە ڕوونی ڕوون نەکرێنەوە."
            },
            {
              "language": "en",
              "text": "Initial approval can quickly turn into resistance if the consequences are not explained transparently."
            },
            {
              "language": "fa",
              "text": "موافقت اولیه می‌تواند سریعاً به مقاومت تبدیل شود اگر پیامدها شفاف توضیح داده نشوند."
            },
            {
              "language": "kmr",
              "text": "Pejirandina destpêkê dikare zû veguhere berxwedanê heke encam bi zelalî neyên ravekirin."
            },
            {
              "language": "pl",
              "text": "Początkowa zgoda może szybko przerodzić się w opór, jeśli skutki nie zostaną przejrzyście wyjaśnione."
            },
            {
              "language": "ro",
              "text": "Aprobarea inițială se poate transforma rapid în rezistență dacă efectele nu sunt explicate transparent."
            },
            {
              "language": "ru",
              "text": "Первоначальное согласие может быстро перейти в сопротивление, если последствия не объяснить прозрачно."
            },
            {
              "language": "sq",
              "text": "Miratimi fillestar mund të kthehet shpejt në rezistencë nëse pasojat nuk shpjegohen qartë."
            },
            {
              "language": "tr",
              "text": "İlk onay, sonuçlar şeffaf biçimde açıklanmazsa hızla dirence dönüşebilir."
            }
          ]
        },
        {
          "baseText": "Im Hafen werden täglich mehrere tausend Container umgeschlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "في الميناء تُناوَل يومياً عدة آلاف من الحاويات."
            },
            {
              "language": "ckb",
              "text": "لە بەندەرەکەدا ڕۆژانە چەند هەزار کۆنتێنەر دەگوازرێنەوە و دادەگیرێن."
            },
            {
              "language": "en",
              "text": "Several thousand containers are handled at the port every day."
            },
            {
              "language": "fa",
              "text": "در بندر هر روز چند هزار کانتینر جابه‌جا می‌شود."
            },
            {
              "language": "kmr",
              "text": "Li benderê rojane çend hezar konteyner tên barkirin û dakirin."
            },
            {
              "language": "pl",
              "text": "W porcie codziennie przeładowuje się kilka tysięcy kontenerów."
            },
            {
              "language": "ro",
              "text": "În port sunt manipulate zilnic câteva mii de containere."
            },
            {
              "language": "ru",
              "text": "В порту ежедневно переваливают несколько тысяч контейнеров."
            },
            {
              "language": "sq",
              "text": "Në port përpunohen çdo ditë disa mijëra kontejnerë."
            },
            {
              "language": "tr",
              "text": "Limanda her gün birkaç bin konteyner elleçleniyor."
            }
          ]
        }
      ]
    },
    {
      "word": "umschließen",
