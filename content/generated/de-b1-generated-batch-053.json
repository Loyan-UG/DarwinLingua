      "collocations": [
        {
          "text": "die Arbeit erleichtern",
          "meaning": "to make the work easier"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erleichterung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسهّل؛ يخفف"
        },
        {
          "language": "ckb",
          "text": "ئاسانکردن؛ سووککردن"
        },
        {
          "language": "en",
          "text": "to make easier; to relieve"
        },
        {
          "language": "fa",
          "text": "آسان کردن؛ سبک کردن"
        },
        {
          "language": "kmr",
          "text": "hêsan kirin; sivik kirin"
        },
        {
          "language": "pl",
          "text": "ułatwiać; odciążać"
        },
        {
          "language": "ro",
          "text": "a ușura; a facilita"
        },
        {
          "language": "ru",
          "text": "облегчать; упрощать"
        },
        {
          "language": "sq",
          "text": "të lehtësosh"
        },
        {
          "language": "tr",
          "text": "kolaylaştırmak; hafifletmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Suchfunktion erleichtert die Arbeit im Support.",
          "translations": [
            {
              "language": "ar",
              "text": "تسهّل وظيفة البحث الجديدة العمل في الدعم."
            },
            {
              "language": "ckb",
              "text": "تایبەتمەندی گەڕانی نوێ کار لە پاڵپشتیدا ئاسانتر دەکات."
            },
            {
              "language": "en",
              "text": "The new search function makes the work in support easier."
            },
            {
              "language": "fa",
              "text": "قابلیت جستجوی جدید کار در پشتیبانی را آسان‌تر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Taybetmendiya lêgerînê ya nû karê piştgiriyê hêsantir dike."
            },
            {
              "language": "pl",
              "text": "Nowa funkcja wyszukiwania ułatwia pracę w dziale wsparcia."
            },
            {
              "language": "ro",
              "text": "Noua funcție de căutare ușurează munca în suport."
            },
            {
              "language": "ru",
              "text": "Новая функция поиска облегчает работу службы поддержки."
            },
            {
              "language": "sq",
              "text": "Funksioni i ri i kërkimit e lehtëson punën në mbështetje."
            },
            {
              "language": "tr",
              "text": "Yeni arama özelliği destek birimindeki işi kolaylaştırıyor."
            }
          ]
        },
        {
          "baseText": "Ein klarer Plan erleichtert den Umzug für die ganze Familie.",
          "translations": [
            {
              "language": "ar",
              "text": "تسهّل خطة واضحة الانتقال على كل العائلة."
            },
            {
              "language": "ckb",
              "text": "پلانێکی ڕوون گواستنەوە بۆ هەموو خێزانەکە ئاسانتر دەکات."
            },
            {
              "language": "en",
              "text": "A clear plan makes the move easier for the whole family."
            },
            {
              "language": "fa",
              "text": "یک برنامه روشن اسباب‌کشی را برای کل خانواده آسان‌تر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Planeke zelal barkirinê ji bo hemû malbatê hêsantir dike."
            },
            {
              "language": "pl",
              "text": "Jasny plan ułatwia przeprowadzkę całej rodzinie."
            },
            {
              "language": "ro",
              "text": "Un plan clar ușurează mutarea pentru întreaga familie."
            },
            {
              "language": "ru",
              "text": "Четкий план облегчает переезд для всей семьи."
            },
            {
              "language": "sq",
              "text": "Një plan i qartë e lehtëson shpërnguljen për gjithë familjen."
            },
            {
              "language": "tr",
              "text": "Net bir plan taşınmayı tüm aile için kolaylaştırır."
            }
          ]
        }
      ]
    },
