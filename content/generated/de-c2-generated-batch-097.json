      ],
      "contextLabels": [],
      "grammarNotes": [
        "fixed phrase; literally between the lines, figuratively meaning implicitly or indirectly"
      ],
      "collocations": [
        {
          "text": "zwischen den Zeilen lesen",
          "meaning": "to read between the lines"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zeile",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ضمنيًا؛ بين السطور"
        },
        {
          "language": "ckb",
          "text": "بە ناڕاستەوخۆ؛ لە نێوان دێڕەکاندا"
        },
        {
          "language": "en",
          "text": "implicitly; between the lines"
        },
        {
          "language": "fa",
          "text": "ضمنی؛ بین سطرها"
        },
        {
          "language": "kmr",
          "text": "bi nerasterast; di navbera rêzan de"
        },
        {
          "language": "pl",
          "text": "między wierszami; domyślnie"
        },
        {
          "language": "ro",
          "text": "printre rânduri; implicit"
        },
        {
          "language": "ru",
          "text": "между строк; неявно"
        },
        {
          "language": "sq",
          "text": "mes rreshtave; në mënyrë të nënkuptuar"
        },
        {
          "language": "tr",
          "text": "satır aralarında; dolaylı olarak"
        }
      ],
      "examples": [
        {
          "baseText": "Zwischen den Zeilen machte die E-Mail deutlich, dass der Kunde die nächste Verzögerung nicht mehr akzeptieren würde.",
          "translations": [
            {
              "language": "ar",
              "text": "أوضحت الرسالة ضمنيًا أن العميل لن يقبل أي تأخير آخر."
            },
            {
              "language": "ckb",
              "text": "لە نێوان دێڕەکاندا ئیمەیڵەکە ڕوونی دەکردەوە کە کڕیار چیتر دواخستنی داهاتوو قبوڵ ناکات."
            },
            {
              "language": "en",
              "text": "Between the lines, the email made clear that the customer would no longer accept another delay."
            },
            {
              "language": "fa",
              "text": "ایمیل به‌صورت ضمنی روشن می‌کرد که مشتری تأخیر بعدی را دیگر قبول نخواهد کرد."
            },
            {
              "language": "kmr",
              "text": "Di navbera rêzan de e-nameyê zelal dikir ku xerîdar êdî derengmayîneke din qebûl nake."
            },
            {
              "language": "pl",
              "text": "Między wierszami e-mail jasno pokazywał, że klient nie zaakceptuje już kolejnego opóźnienia."
            },
            {
              "language": "ro",
              "text": "Printre rânduri, e-mailul arăta clar că clientul nu va mai accepta încă o întârziere."
            },
            {
              "language": "ru",
              "text": "Между строк письмо ясно давало понять, что клиент больше не примет очередную задержку."
            },
            {
              "language": "sq",
              "text": "Mes rreshtave, emaili e bënte të qartë se klienti nuk do të pranonte më një vonesë tjetër."
            },
            {
              "language": "tr",
              "text": "E-posta satır aralarında müşterinin bir sonraki gecikmeyi artık kabul etmeyeceğini açıkça gösteriyordu."
            }
          ]
        },
        {
          "baseText": "Wer den Brief zwischen den Zeilen liest, erkennt weniger Dankbarkeit als eine vorsichtige Distanzierung.",
          "translations": [
            {
              "language": "ar",
              "text": "من يقرأ الرسالة بين السطور يلاحظ فيها حذرًا في الابتعاد أكثر من الامتنان."
            },
            {
              "language": "ckb",
              "text": "ئەوەی نامەکە لە نێوان دێڕەکاندا بخوێنێتەوە، زیاتر دوورکەوتنەوەیەکی وریا دەبینێت نەک سوپاسگوزاری."
            },
            {
              "language": "en",
              "text": "Anyone who reads the letter between the lines recognizes less gratitude than cautious distancing."
            },
            {
              "language": "fa",
              "text": "کسی که نامه را بین سطرها بخواند، کمتر قدردانی می‌بیند و بیشتر فاصله‌گذاری محتاطانه."
            },
            {
              "language": "kmr",
              "text": "Kesê ku nameyê di navbera rêzan de dixwîne, kêmtir spasdarî û bêtir dûrketineke baldar dibîne."
            },
            {
              "language": "pl",
              "text": "Kto czyta list między wierszami, dostrzega mniej wdzięczności niż ostrożne dystansowanie się."
            },
            {
              "language": "ro",
              "text": "Cine citește scrisoarea printre rânduri vede mai puțin recunoștință și mai degrabă o distanțare prudentă."
            },
            {
              "language": "ru",
              "text": "Тот, кто читает письмо между строк, видит не столько благодарность, сколько осторожное дистанцирование."
            },
            {
              "language": "sq",
              "text": "Kush e lexon letrën mes rreshtave, sheh më pak mirënjohje dhe më shumë distancim të kujdesshëm."
            },
            {
              "language": "tr",
              "text": "Mektubu satır aralarında okuyan kişi minnettarlıktan çok temkinli bir mesafe koyma görür."
            }
          ]
        }
      ]
    }
  ],
