      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective/adverb; means compelling, mandatory, or logically unavoidable"
      ],
      "collocations": [
        {
          "text": "zwingende Gründe",
          "meaning": "compelling reasons"
        },
        {
          "text": "zwingend erforderlich sein",
          "meaning": "to be strictly necessary"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zwingen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إلزامي أو مقنع لا مفر منه"
        },
        {
          "language": "ckb",
          "text": "ناچارکەر؛ پێویستیی بێگومان"
        },
        {
          "language": "en",
          "text": "compelling; mandatory; unavoidable"
        },
        {
          "language": "fa",
          "text": "الزام‌آور؛ ناگزیر؛ قانع‌کننده"
        },
        {
          "language": "kmr",
          "text": "neçar; pêwîst û bêguman"
        },
        {
          "language": "pl",
          "text": "konieczny; nieodzowny; przekonujący"
        },
        {
          "language": "ro",
          "text": "imperativ; obligatoriu; inevitabil"
        },
        {
          "language": "ru",
          "text": "обязательный; убедительный; неизбежный"
        },
        {
          "language": "sq",
          "text": "i detyrueshëm; bindës; i pashmangshëm"
        },
        {
          "language": "tr",
          "text": "zorunlu; kaçınılmaz; ikna edici"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Verarbeitung sensibler Kundendaten ist eine zwingende Rechtsgrundlage erforderlich, nicht nur eine interne Freigabe.",
          "translations": [
            {
              "language": "ar",
              "text": "لمعالجة بيانات العملاء الحساسة يلزم أساس قانوني إلزامي، وليس مجرد موافقة داخلية."
            },
            {
              "language": "ckb",
              "text": "بۆ چارەسەرکردنی داتای هەستیاری کڕیاران بنەمایەکی یاسایی ناچارکەر پێویستە، نەک تەنها پەسەندی ناوخۆیی."
            },
            {
              "language": "en",
              "text": "A mandatory legal basis is required for processing sensitive customer data, not merely internal approval."
            },
            {
              "language": "fa",
              "text": "برای پردازش داده‌های حساس مشتریان، مبنای حقوقی الزام‌آور لازم است، نه فقط تأیید داخلی."
            },
            {
              "language": "kmr",
              "text": "Ji bo pêvajokirina daneyên hestiyar ên xerîdaran bingehê hiqûqî yê neçar pêwîst e, ne tenê erêkirina hundirîn."
            },
            {
              "language": "pl",
              "text": "Do przetwarzania wrażliwych danych klientów wymagana jest konieczna podstawa prawna, a nie tylko wewnętrzna zgoda."
            },
            {
              "language": "ro",
              "text": "Pentru prelucrarea datelor sensibile ale clienților este necesară o bază juridică obligatorie, nu doar o aprobare internă."
            },
            {
              "language": "ru",
              "text": "Для обработки чувствительных данных клиентов требуется обязательное правовое основание, а не только внутреннее согласование."
            },
            {
              "language": "sq",
              "text": "Për përpunimin e të dhënave të ndjeshme të klientëve kërkohet një bazë ligjore e detyrueshme, jo vetëm miratim i brendshëm."
            },
            {
              "language": "tr",
              "text": "Hassas müşteri verilerinin işlenmesi için yalnızca iç onay değil, zorunlu bir hukuki dayanak gerekir."
            }
          ]
        },
        {
          "baseText": "Die Argumentation ist nicht in jedem Detail elegant, aber in ihrem Ergebnis zwingend.",
          "translations": [
            {
              "language": "ar",
              "text": "الحجة ليست أنيقة في كل تفاصيلها، لكنها في نتيجتها مقنعة ولا مفر منها."
            },
            {
              "language": "ckb",
              "text": "ئارگومێنتەکە لە هەموو وردەکارییەکدا جوان نییە، بەڵام لە ئەنجامەکەیدا ناچارکەرە."
            },
            {
              "language": "en",
              "text": "The argument is not elegant in every detail, but its conclusion is compelling."
            },
            {
              "language": "fa",
              "text": "استدلال در همه جزئیات ظریف نیست، اما نتیجه‌اش قانع‌کننده و ناگزیر است."
            },
            {
              "language": "kmr",
              "text": "Argûman di her hûrguliyê de xweşik nîne, lê di encama xwe de neçar e."
            },
            {
              "language": "pl",
              "text": "Argumentacja nie jest elegancka w każdym szczególe, ale jej wniosek jest przekonujący."
            },
            {
              "language": "ro",
              "text": "Argumentația nu este elegantă în fiecare detaliu, dar concluzia ei este convingătoare."
            },
            {
              "language": "ru",
              "text": "Аргументация не во всех деталях изящна, но ее вывод убедителен."
            },
            {
              "language": "sq",
              "text": "Argumentimi nuk është elegant në çdo detaj, por përfundimi i tij është bindës."
            },
            {
              "language": "tr",
              "text": "Argüman her ayrıntıda zarif değil, ancak sonucu ikna edicidir."
            }
          ]
        }
      ]
    },
    {
      "word": "zwischen den Zeilen",
      "language": "de",
      "cefrLevel": "C2",
