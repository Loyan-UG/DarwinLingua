      ],
      "grammarNotes": [
        "adjective",
        "means that a system, process, or business model can grow without losing performance"
      ],
      "collocations": [
        {
          "text": "eine skalierbare Lösung",
          "meaning": "a scalable solution"
        },
        {
          "text": "skalierbar aufgebaut sein",
          "meaning": "to be built in a scalable way"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "skalieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Skalierbarkeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قابل للتوسع؛ قابل للتدرج"
        },
        {
          "language": "ckb",
          "text": "توانای گەورەبوونی هەیە؛ سکەیل‌کردن‌پذیر"
        },
        {
          "language": "en",
          "text": "scalable"
        },
        {
          "language": "fa",
          "text": "مقیاس‌پذیر؛ قابل گسترش"
        },
        {
          "language": "kmr",
          "text": "skalebar; dikare mezin bibe"
        },
        {
          "language": "pl",
          "text": "skalowalny"
        },
        {
          "language": "ro",
          "text": "scalabil"
        },
        {
          "language": "ru",
          "text": "масштабируемый"
        },
        {
          "language": "sq",
          "text": "i shkallëzueshëm"
        },
        {
          "language": "tr",
          "text": "ölçeklenebilir"
        }
      ],
      "examples": [
        {
          "baseText": "Die Architektur muss skalierbar sein, damit der Dienst auch bei vielen gleichzeitigen Nutzern stabil bleibt.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن تكون البنية قابلة للتوسع لكي تبقى الخدمة مستقرة حتى مع عدد كبير من المستخدمين المتزامنين."
            },
            {
              "language": "ckb",
              "text": "ئەندازیارەکە دەبێ سکەیل‌کردن‌پذیر بێت بۆ ئەوەی خزمەتەکە لەگەڵ بەکارهێنەری هاوکاتی زۆریش جێگیر بمێنێتەوە."
            },
            {
              "language": "en",
              "text": "The architecture must be scalable so the service remains stable even with many simultaneous users."
            },
            {
              "language": "fa",
              "text": "معماری باید مقیاس‌پذیر باشد تا سرویس حتی با کاربران همزمان زیاد پایدار بماند."
            },
            {
              "language": "kmr",
              "text": "Avahî divê skalebar be da ku xizmet heta bi gelek bikarhênerên hevdem jî saxlem bimîne."
            },
            {
              "language": "pl",
              "text": "Architektura musi być skalowalna, aby usługa pozostała stabilna także przy wielu jednoczesnych użytkownikach."
            },
            {
              "language": "ro",
              "text": "Arhitectura trebuie să fie scalabilă, astfel încât serviciul să rămână stabil chiar și cu mulți utilizatori simultani."
            },
            {
              "language": "ru",
              "text": "Архитектура должна быть масштабируемой, чтобы сервис оставался стабильным даже при большом числе одновременных пользователей."
            },
            {
              "language": "sq",
              "text": "Arkitektura duhet të jetë e shkallëzueshme që shërbimi të mbetet i qëndrueshëm edhe me shumë përdorues njëkohësisht."
            },
            {
              "language": "tr",
              "text": "Mimari ölçeklenebilir olmalı ki hizmet çok sayıda eş zamanlı kullanıcıda bile stabil kalsın."
            }
          ]
        },
        {
          "baseText": "Das Schulungskonzept ist skalierbar, weil neue Standorte die Materialien direkt übernehmen können.",
          "translations": [
            {
              "language": "ar",
              "text": "مفهوم التدريب قابل للتوسع لأن المواقع الجديدة يمكنها استخدام المواد مباشرة."
            },
            {
              "language": "ckb",
              "text": "کۆنسێپتی ڕاهێنانەکە سکەیل‌کردن‌پذیرە، چونکە شوێنە نوێیەکان دەتوانن کەرەستەکان ڕاستەوخۆ وەربگرن."
            },
            {
              "language": "en",
              "text": "The training concept is scalable because new locations can use the materials directly."
            },
            {
              "language": "fa",
              "text": "طرح آموزشی مقیاس‌پذیر است، چون شعبه‌های جدید می‌توانند مواد را مستقیم به کار بگیرند."
            },
            {
              "language": "kmr",
              "text": "Konsepta perwerdeyê skalebar e, ji ber ku cihên nû dikarin materyalan rasterast bistînin."
            },
            {
              "language": "pl",
              "text": "Koncepcja szkolenia jest skalowalna, ponieważ nowe lokalizacje mogą bezpośrednio przejąć materiały."
            },
            {
              "language": "ro",
              "text": "Conceptul de instruire este scalabil, deoarece noile locații pot prelua direct materialele."
            },
            {
              "language": "ru",
              "text": "Концепция обучения масштабируема, потому что новые площадки могут сразу использовать материалы."
            },
            {
              "language": "sq",
              "text": "Koncepti i trajnimit është i shkallëzueshëm, sepse vendndodhjet e reja mund t’i marrin materialet drejtpërdrejt."
            },
            {
              "language": "tr",
              "text": "Eğitim konsepti ölçeklenebilir, çünkü yeni lokasyonlar materyalleri doğrudan devralabilir."
            }
          ]
        }
      ]
    },
