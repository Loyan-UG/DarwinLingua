      "meanings": [
        {
          "language": "ar",
          "text": "يبرز بالمقارنة؛ يتباين"
        },
        {
          "language": "ckb",
          "text": "جیا دەردەکەوێت؛ جیاوازیی ڕوون هەیە"
        },
        {
          "language": "en",
          "text": "to contrast; to stand out"
        },
        {
          "language": "fa",
          "text": "در تضاد بودن؛ برجسته دیده شدن"
        },
        {
          "language": "kmr",
          "text": "cuda xuya bûn; ji hev derketin"
        },
        {
          "language": "pl",
          "text": "odcinać się; wyróżniać się"
        },
        {
          "language": "ro",
          "text": "a contrasta; a ieși în evidență"
        },
        {
          "language": "ru",
          "text": "выделяться; контрастировать"
        },
        {
          "language": "sq",
          "text": "të bëjë kontrast; të dallohet"
        },
        {
          "language": "tr",
          "text": "ayırt edilmek; belirgin şekilde farklı durmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die rote Warnmeldung stach deutlich vom grauen Hintergrund der Anwendung ab.",
          "translations": [
            {
