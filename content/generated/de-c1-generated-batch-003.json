  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "abschwören",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abschwören",
      "syllableBreak": "ab-schwö-ren",
      "topics": [
        "law-and-compliance",
        "social-and-relationships",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong verb; often used with dative object"
      ],
      "collocations": [
        {
          "text": "einer Praxis abschwören",
          "meaning": "to renounce a practice"
        },
        {
          "text": "einer Überzeugung abschwören",
          "meaning": "to renounce a conviction"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Schwur",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يتخلى رسميًا عن؛ ينبذ"
        },
        {
          "language": "ckb",
          "text": "دەستبەرداری دەبێت لە؛ بە فەرمی وازی لێ دێنێت"
        },
        {
          "language": "en",
          "text": "to renounce; to swear off"
        },
        {
          "language": "fa",
          "text": "رسماً کنار گذاشتن؛ دست کشیدن از"
        },
        {
          "language": "kmr",
          "text": "dev jê berdan; sond xwarin ku nema bike"
        },
        {
          "language": "pl",
          "text": "wyrzec się; odstąpić od"
        },
        {
          "language": "ro",
          "text": "a renunța la; a se dezice de"
        },
        {
          "language": "ru",
          "text": "отрекаться от; зарекаться"
        },
        {
          "language": "sq",
          "text": "të heqësh dorë; të betohesh se nuk do ta bësh më"
        },
        {
          "language": "tr",
          "text": "vazgeçmek; tövbe etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Compliance-Verstoß schwor der Manager allen informellen Absprachen mit Lieferanten ab.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد انتهاك قواعد الامتثال، تخلى المدير عن كل التفاهمات غير الرسمية مع الموردين."
            },
            {
              "language": "ckb",
              "text": "دوای پێشێلکردنی پابەندبوون، بەڕێوەبەرەکە دەستبەرداری هەموو ڕێککەوتنە نافەرمییەکان لەگەڵ دابینکەران بوو."
            },
            {
              "language": "en",
              "text": "After the compliance violation, the manager renounced all informal arrangements with suppliers."
            },
            {
              "language": "fa",
              "text": "پس از تخلف در انطباق، مدیر از همه توافق‌های غیررسمی با تأمین‌کنندگان دست کشید."
            },
            {
              "language": "kmr",
              "text": "Piştî binpêkirina lihevhatinê, rêveber ji hemû lihevkirinên nefermî bi dabînkeran re dev berda."
            },
            {
              "language": "pl",
              "text": "Po naruszeniu zasad zgodności menedżer wyrzekł się wszystkich nieformalnych ustaleń z dostawcami."
            },
            {
              "language": "ro",
              "text": "După încălcarea regulilor de conformitate, managerul a renunțat la toate înțelegerile informale cu furnizorii."
            },
            {
              "language": "ru",
              "text": "После нарушения требований комплаенса менеджер отказался от всех неформальных договоренностей с поставщиками."
            },
            {
              "language": "sq",
              "text": "Pas shkeljes së rregullave të përputhshmërisë, menaxheri hoqi dorë nga të gjitha marrëveshjet joformale me furnitorët."
            },
            {
              "language": "tr",
              "text": "Uyumluluk ihlalinden sonra yönetici tedarikçilerle yapılan tüm gayriresmî anlaşmalardan vazgeçti."
            }
          ]
        },
        {
          "baseText": "Die Zeugin schwor ihrer früheren Aussage nicht ab, relativierte aber mehrere Details.",
          "translations": [
            {
              "language": "ar",
              "text": "لم تتراجع الشاهدة عن إفادتها السابقة، لكنها خففت من أهمية عدة تفاصيل."
            },
            {
              "language": "ckb",
              "text": "شایەتەکە دەستبەرداری لێدوانی پێشووی نەبوو، بەڵام چەند وردەکارییەکی ڕێژەیی کرد."
            },
            {
              "language": "en",
              "text": "The witness did not renounce her earlier statement, but she qualified several details."
            },
            {
              "language": "fa",
              "text": "شاهد از گفته قبلی خود برنگشت، اما چند جزئیات را نسبی‌تر بیان کرد."
            },
            {
              "language": "kmr",
              "text": "Şahid ji daxuyaniya xwe ya berê venegeriya, lê çend hûrgulî bi şert û mercan got."
            },
            {
              "language": "pl",
              "text": "Świadek nie wycofała wcześniejszego zeznania, ale doprecyzowała kilka szczegółów."
            },
            {
              "language": "ro",
              "text": "Martora nu s-a dezis de declarația anterioară, dar a nuanțat mai multe detalii."
            },
            {
              "language": "ru",
              "text": "Свидетельница не отказалась от прежних показаний, но уточнила несколько деталей."
            },
            {
              "language": "sq",
              "text": "Dëshmitarja nuk hoqi dorë nga deklarata e mëparshme, por zbuti disa hollësi."
            },
            {
              "language": "tr",
              "text": "Tanık önceki ifadesinden dönmedi, ancak birkaç ayrıntıyı yumuşatarak açıkladı."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "absitzen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "absitzen",
      "syllableBreak": "ab-sit-zen",
      "topics": [
        "law-and-compliance",
        "work-and-jobs",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "separable verb"
      ],
      "collocations": [
        {
          "text": "eine Haftstrafe absitzen",
          "meaning": "to serve a prison sentence"
        },
        {
          "text": "eine Sitzung absitzen",
          "meaning": "to sit through a meeting reluctantly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sitzen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يقضي عقوبة أو فترة؛ يتحمل الجلوس خلالها"
        },
        {
          "language": "ckb",
          "text": "ماوەیەک یان سزایەک تێدەپەڕێنێت"
        },
        {
          "language": "en",
          "text": "to serve or sit out a sentence or period"
        },
        {
          "language": "fa",
          "text": "دوران محکومیت یا مدتی را گذراندن"
        },
        {
          "language": "kmr",
          "text": "maweyek an cezayek derbas kirin"
        },
        {
          "language": "pl",
          "text": "odsiedzieć; przeczekać"
        },
        {
          "language": "ro",
          "text": "a executa o pedeapsă; a sta până la capăt"
        },
        {
          "language": "ru",
          "text": "отбывать срок; высиживать"
        },
        {
          "language": "sq",
          "text": "të vuash një dënim; të rrish deri në fund"
        },
        {
          "language": "tr",
          "text": "cezasını çekmek; oturup bitmesini beklemek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Verurteilte musste die restliche Haftstrafe ohne Bewährung absitzen.",
          "translations": [
            {
              "language": "ar",
              "text": "كان على المدان أن يقضي بقية عقوبة السجن دون إفراج مشروط."
            },
            {
              "language": "ckb",
              "text": "حوکم‌دراوەکە دەبوو ماوەی ماوەیی زیندانەکە بەبێ لێخۆشبوون تێپەڕێنێت."
            },
            {
              "language": "en",
              "text": "The convicted man had to serve the remaining prison sentence without probation."
            },
            {
              "language": "fa",
              "text": "فرد محکوم باید باقی‌مانده حکم زندان را بدون تعلیق می‌گذراند."
            },
            {
              "language": "kmr",
              "text": "Kesê mehkûm diviya mayîna cezayê girtîgehê bê betalkirin derbas bikira."
            },
            {
              "language": "pl",
              "text": "Skazany musiał odsiedzieć resztę kary pozbawienia wolności bez zawieszenia."
            },
            {
              "language": "ro",
              "text": "Condamnatul a trebuit să execute restul pedepsei cu închisoarea fără suspendare."
            },
            {
              "language": "ru",
              "text": "Осужденный должен был отбыть оставшийся срок без условного освобождения."
            },
            {
              "language": "sq",
              "text": "I dënuari duhej të vuante pjesën e mbetur të dënimit pa lirim me kusht."
            },
            {
              "language": "tr",
              "text": "Hükümlü kalan hapis cezasını erteleme olmadan çekmek zorundaydı."
            }
          ]
        },
        {
          "baseText": "Viele Mitarbeitende saßen die endlose Pflichtschulung nur widerwillig ab.",
          "translations": [
            {
              "language": "ar",
              "text": "جلس كثير من الموظفين في التدريب الإلزامي الطويل جدًا على مضض فقط."
            },
            {
              "language": "ckb",
              "text": "زۆرێک لە کارمەندان بە ناڕەزاییەوە دانیشتنەکەی ڕاهێنانی زۆر درێژی ئیجباریان تێپەڕاند."
            },
            {
              "language": "en",
              "text": "Many employees only reluctantly sat through the endless mandatory training."
            },
            {
              "language": "fa",
              "text": "بسیاری از کارکنان آموزش اجباری بی‌پایان را فقط با بی‌میلی تحمل کردند."
            },
            {
              "language": "kmr",
              "text": "Gelek karmend perwerdehiya mecbûrî ya bêdawî bi dilnexwazî tenê rûniştin û qedandin."
            },
            {
              "language": "pl",
              "text": "Wielu pracowników z niechęcią przesiedziało niekończące się szkolenie obowiązkowe."
            },
            {
              "language": "ro",
              "text": "Mulți angajați au stat cu greu până la capăt la instruirea obligatorie interminabilă."
            },
            {
              "language": "ru",
              "text": "Многие сотрудники неохотно высидели бесконечное обязательное обучение."
            },
            {
              "language": "sq",
              "text": "Shumë punonjës e qëndruan me zor trajnimin e pafund të detyrueshëm."
            },
            {
              "language": "tr",
              "text": "Birçok çalışan bitmek bilmeyen zorunlu eğitimi isteksizce oturup tamamladı."
            }
          ]
        }
      ]
    },
