    {
      "word": "Mitarbeitergruppe",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Mitarbeitergruppen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Mit-ar-bei-ter-grup-pe",
      "topics": [
        "work-and-jobs",
        "erp-and-business-systems",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "administrative",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; group used to classify employees for permissions, planning, or reporting"
      ],
      "collocations": [
        {
          "text": "eine Mitarbeitergruppe zuordnen",
          "meaning": "to assign an employee group"
        },
        {
          "text": "nach Mitarbeitergruppe auswerten",
          "meaning": "to analyze by employee group"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Mitarbeiter",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Gruppe",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مجموعة الموظفين"
        },
        {
          "language": "ckb",
          "text": "گرووپی کارمەندان"
        },
        {
          "language": "en",
          "text": "employee group"
        },
        {
          "language": "fa",
          "text": "گروه کارکنان"
        },
        {
          "language": "kmr",
          "text": "koma karmendan"
        },
        {
          "language": "pl",
          "text": "grupa pracowników"
        },
        {
          "language": "ro",
          "text": "grup de angajați"
        },
        {
          "language": "ru",
          "text": "группа сотрудников"
        },
        {
          "language": "sq",
          "text": "grup punonjësish"
        },
        {
          "language": "tr",
          "text": "çalışan grubu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Mitarbeitergruppe steuert im ERP, welche Lageraufträge ein Benutzer sehen darf.",
          "translations": [
            {
              "language": "ar",
              "text": "تحدد مجموعة الموظفين في ERP أوامر المستودع التي يُسمح للمستخدم برؤيتها."
            },
            {
              "language": "ckb",
              "text": "گرووپی کارمەندان لە ERP دا دیاری دەکات بەکارهێنەر دەتوانێت کام داواکارییەکانی کۆگا ببینێت."
            },
            {
              "language": "en",
              "text": "The employee group controls in the ERP which warehouse tasks a user may see."
            },
            {
              "language": "fa",
              "text": "گروه کارکنان در ERP کنترل می‌کند کاربر مجاز است کدام دستورهای انبار را ببیند."
            },
            {
              "language": "kmr",
              "text": "Koma karmendan di ERP de kontrol dike bikarhêner dikare kîjan fermanên embarê bibîne."
            },
            {
              "language": "pl",
              "text": "Grupa pracowników steruje w ERP tym, które zlecenia magazynowe użytkownik może widzieć."
            },
            {
              "language": "ro",
              "text": "Grupul de angajați controlează în ERP ce ordine de depozit poate vedea un utilizator."
            },
            {
              "language": "ru",
              "text": "Группа сотрудников в ERP управляет тем, какие складские задания может видеть пользователь."
            },
            {
              "language": "sq",
              "text": "Grupi i punonjësve kontrollon në ERP cilat urdhra magazine mund të shohë përdoruesi."
            },
            {
              "language": "tr",
              "text": "Çalışan grubu ERP’de bir kullanıcının hangi depo görevlerini görebileceğini yönetir."
            }
          ]
        },
        {
          "baseText": "Für die Auswertung wurden die Arbeitszeiten nach Mitarbeitergruppe zusammengefasst.",
          "translations": [
            {
              "language": "ar",
              "text": "لأجل التحليل تم تجميع ساعات العمل حسب مجموعة الموظفين."
            },
            {
              "language": "ckb",
              "text": "بۆ شیکردنەوە، کاتەکانی کار بە پێی گرووپی کارمەندان کۆکرانەوە."
            },
            {
              "language": "en",
              "text": "For the analysis, working times were summarized by employee group."
            },
            {
              "language": "fa",
              "text": "برای تحلیل، زمان‌های کاری بر اساس گروه کارکنان خلاصه شد."
            },
            {
              "language": "kmr",
              "text": "Ji bo analîzê, demên kar li gorî koma karmendan hatin komkirin."
            },
            {
              "language": "pl",
              "text": "Do analizy czasy pracy zostały podsumowane według grup pracowników."
            },
            {
              "language": "ro",
              "text": "Pentru analiză, timpii de lucru au fost grupați după grupul de angajați."
            },
            {
              "language": "ru",
              "text": "Для анализа рабочее время было суммировано по группам сотрудников."
            },
            {
              "language": "sq",
              "text": "Për analizë, orët e punës u përmblodhën sipas grupit të punonjësve."
            },
            {
              "language": "tr",
              "text": "Analiz için çalışma süreleri çalışan grubuna göre özetlendi."
            }
          ]
        }
      ]
    },
    {
      "word": "Monatsendbestand",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Monatsendbestände",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Mo-nats-end-be-stand",
      "topics": [
        "warehouse-and-logistics",
        "finance-and-accounting",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; stock balance at the end of a month"
      ],
      "collocations": [
        {
          "text": "den Monatsendbestand berechnen",
          "meaning": "to calculate the month-end stock balance"
        },
        {
          "text": "den Monatsendbestand melden",
          "meaning": "to report the month-end stock"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Monat",
          "relationLabel": "component noun",
          "note": null
        },
        {
          "lemma": "der Bestand",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "رصيد المخزون في نهاية الشهر"
        },
        {
          "language": "ckb",
          "text": "کۆگای کۆتایی مانگ"
        },
        {
          "language": "en",
          "text": "month-end stock balance"
        },
        {
          "language": "fa",
          "text": "موجودی پایان ماه"
        },
        {
          "language": "kmr",
          "text": "stoka dawiya mehê"
        },
        {
          "language": "pl",
          "text": "stan na koniec miesiąca"
        },
        {
          "language": "ro",
          "text": "stoc la sfârșit de lună"
        },
        {
          "language": "ru",
          "text": "остаток на конец месяца"
        },
        {
          "language": "sq",
          "text": "stoku në fund të muajit"
        },
        {
          "language": "tr",
          "text": "ay sonu stok bakiyesi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Monatsendbestand wird im ERP nach dem letzten Warenausgang automatisch berechnet.",
          "translations": [
            {
              "language": "ar",
              "text": "يُحسب رصيد المخزون في نهاية الشهر في ERP تلقائيًا بعد آخر خروج للبضائع."
            },
            {
              "language": "ckb",
              "text": "کۆگای کۆتایی مانگ لە ERP دا دوای دوا دەرچوونی کاڵا خۆکارانە هەژمار دەکرێت."
            },
            {
              "language": "en",
              "text": "The month-end stock balance is calculated automatically in the ERP after the last goods issue."
            },
            {
              "language": "fa",
              "text": "موجودی پایان ماه در ERP پس از آخرین خروج کالا به‌صورت خودکار محاسبه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Stoka dawiya mehê di ERP de piştî derketina dawî ya malan xweber tê hesibandin."
            },
            {
              "language": "pl",
              "text": "Stan na koniec miesiąca jest automatycznie obliczany w ERP po ostatnim wydaniu towaru."
            },
            {
              "language": "ro",
              "text": "Stocul de la sfârșit de lună este calculat automat în ERP după ultima ieșire de marfă."
            },
            {
              "language": "ru",
              "text": "Остаток на конец месяца автоматически рассчитывается в ERP после последней выдачи товара."
            },
            {
              "language": "sq",
              "text": "Stoku në fund të muajit llogaritet automatikisht në ERP pas daljes së fundit të mallrave."
            },
            {
              "language": "tr",
              "text": "Ay sonu stok bakiyesi son mal çıkışından sonra ERP’de otomatik hesaplanır."
            }
          ]
        },
        {
          "baseText": "Controlling vergleicht den Monatsendbestand mit den Zahlen aus der Inventur.",
          "translations": [
            {
              "language": "ar",
              "text": "يقارن قسم الرقابة المالية رصيد نهاية الشهر بأرقام الجرد."
            },
            {
              "language": "ckb",
              "text": "بەشی کۆنترۆڵینگ کۆگای کۆتایی مانگ لەگەڵ ژمارەکانی ژماردنی کۆگا بەراورد دەکات."
            },
            {
              "language": "en",
              "text": "Controlling compares the month-end stock balance with the inventory count figures."
            },
            {
              "language": "fa",
              "text": "واحد کنترل مالی موجودی پایان ماه را با اعداد انبارگردانی مقایسه می‌کند."
            },
            {
              "language": "kmr",
              "text": "Beşa kontrolê stoka dawiya mehê bi hejmarên jimartina stokê re berawird dike."
            },
            {
              "language": "pl",
              "text": "Controlling porównuje stan na koniec miesiąca z wynikami inwentaryzacji."
            },
            {
              "language": "ro",
              "text": "Controllingul compară stocul de sfârșit de lună cu cifrele inventarierii."
            },
            {
              "language": "ru",
              "text": "Контроллинг сравнивает остаток на конец месяца с данными инвентаризации."
            },
            {
              "language": "sq",
              "text": "Kontrollingu krahason stokun në fund të muajit me shifrat e inventarizimit."
            },
            {
              "language": "tr",
              "text": "Kontrol departmanı ay sonu stok bakiyesini envanter sayımı rakamlarıyla karşılaştırır."
            }
          ]
        }
      ]
    },
