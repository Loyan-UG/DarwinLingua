      "word": "das Depot",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Depots",
      "infinitive": null,
      "syllableBreak": "De-pot",
      "topics": [
        "warehouse-and-logistics",
        "finance-and-accounting",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "technical"
      ],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "ein Depot verwalten",
          "meaning": "to manage a depot or securities account"
        },
        {
          "text": "im Depot lagern",
          "meaning": "to store in the depot"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مستودع؛ حساب أوراق مالية"
        },
        {
          "language": "ckb",
          "text": "کۆگا؛ ئەکاونتی وەبەرهێنان"
        },
        {
          "language": "en",
          "text": "depot; securities account"
        },
        {
          "language": "fa",
          "text": "انبار؛ حساب سرمایه‌گذاری"
        },
        {
          "language": "kmr",
          "text": "depo; hesabê sermayeyê"
        },
        {
          "language": "pl",
          "text": "depozyt; magazyn; rachunek papierów wartościowych"
        },
        {
          "language": "ro",
          "text": "depozit; cont de valori mobiliare"
        },
        {
          "language": "ru",
          "text": "депо; склад; счет ценных бумаг"
        },
        {
          "language": "sq",
          "text": "depo; llogari letrash me vlerë"
        },
        {
          "language": "tr",
          "text": "depo; menkul kıymet hesabı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Ersatzteile liegen im Depot und sind im ERP-System reserviert.",
          "translations": [
            {
              "language": "ar",
              "text": "قطع الغيار موجودة في المستودع ومحجوزة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "پارچەی یەدەگەکان لە کۆگادان و لە سیستەمی ERPدا حجزکراون."
            },
            {
              "language": "en",
              "text": "The spare parts are in the depot and reserved in the ERP system."
            },
            {
              "language": "fa",
              "text": "قطعات یدکی در انبار هستند و در سیستم ERP رزرو شده‌اند."
            },
            {
              "language": "kmr",
              "text": "Parçeyên yedek di depoyê de ne û di pergala ERP de hatine veqetandin."
            },
            {
              "language": "pl",
              "text": "Części zamienne są w magazynie i są zarezerwowane w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Piesele de schimb sunt în depozit și sunt rezervate în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Запчасти находятся на складе и зарезервированы в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Pjesët rezervë janë në depo dhe janë të rezervuara në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Yedek parçalar depoda ve ERP sisteminde rezerve edilmiş durumda."
            }
          ]
        },
        {
          "baseText": "Meine Bank zeigt den aktuellen Wert meines Depots an.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض بنكي القيمة الحالية لحسابي الاستثماري."
            },
            {
              "language": "ckb",
              "text": "بانکەکەم بەهای ئێستای ئەکاونتی وەبەرهێنانەکەم پیشان دەدات."
            },
            {
              "language": "en",
              "text": "My bank shows the current value of my securities account."
            },
            {
              "language": "fa",
              "text": "بانکم ارزش فعلی حساب سرمایه‌گذاری‌ام را نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Banka min nirxê niha yê hesabê sermayeyê min nîşan dide."
            },
            {
              "language": "pl",
              "text": "Mój bank pokazuje aktualną wartość mojego rachunku papierów wartościowych."
            },
            {
              "language": "ro",
              "text": "Banca mea arată valoarea actuală a portofoliului meu."
            },
            {
              "language": "ru",
              "text": "Мой банк показывает текущую стоимость моего инвестиционного счета."
            },
            {
              "language": "sq",
              "text": "Banka ime tregon vlerën aktuale të llogarisë sime të investimeve."
            },
            {
              "language": "tr",
