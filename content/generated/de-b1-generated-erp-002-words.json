  "entries": [
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Buchung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Buchungen",
      "infinitive": null,
      "syllableBreak": "Bu-chung",
      "topics": [
        "finance-and-accounting",
        "documents-and-administration",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "written"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Buchung erfassen",
          "meaning": "to record a posting or booking"
        },
        {
          "text": "die Buchung stornieren",
          "meaning": "to cancel a booking or accounting entry"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "buchen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "قيد؛ حجز"
        },
        {
          "language": "ckb",
          "text": "تۆمارکردن؛ حجزکردن"
        },
        {
          "language": "en",
          "text": "posting; booking"
        },
        {
          "language": "fa",
          "text": "ثبت حسابداری؛ رزرو"
        },
        {
          "language": "kmr",
          "text": "tomarkirin; rezervasyon"
        },
        {
          "language": "pl",
          "text": "księgowanie; rezerwacja"
        },
        {
          "language": "ro",
          "text": "înregistrare contabilă; rezervare"
        },
        {
          "language": "ru",
          "text": "проводка; бронирование"
        },
        {
          "language": "sq",
          "text": "regjistrim; rezervim"
        },
        {
          "language": "tr",
          "text": "kayıt; rezervasyon"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du die Buchung im ERP-System heute noch prüfen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك التحقق من القيد في نظام تخطيط موارد المؤسسة اليوم؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت ئەمڕۆ پشکنینی تۆمارکردنەکە لە سیستەمی ERP بکەیت؟"
            },
            {
              "language": "en",
              "text": "Can you check the posting in the ERP system today?"
            },
            {
              "language": "fa",
              "text": "می‌توانی امروز ثبت را در سیستم ERP بررسی کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî îro tomarkirinê di pergala ERP de kontrol bikî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz dziś sprawdzić księgowanie w systemie ERP?"
            },
            {
              "language": "ro",
              "text": "Poți verifica astăzi înregistrarea în sistemul ERP?"
            },
            {
              "language": "ru",
              "text": "Можешь сегодня проверить проводку в ERP-системе?"
            },
            {
              "language": "sq",
              "text": "A mund ta kontrollosh sot regjistrimin në sistemin ERP?"
            },
            {
              "language": "tr",
              "text": "ERP sistemindeki kaydı bugün kontrol edebilir misin?"
            }
          ]
        },
        {
          "baseText": "Ich sehe die Buchung für das Hotel in meiner E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "أرى حجز الفندق في بريدي الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "حجزکردنی هۆتێلەکە لە ئیمەیڵەکەم دەبینم."
            },
            {
              "language": "en",
              "text": "I can see the hotel booking in my email."
            },
            {
              "language": "fa",
              "text": "رزرو هتل را در ایمیلم می‌بینم."
            },
            {
              "language": "kmr",
              "text": "Ez rezervasyona hotelê di e-nameya xwe de dibînim."
            },
            {
              "language": "pl",
              "text": "Widzę rezerwację hotelu w moim e-mailu."
            },
            {
              "language": "ro",
              "text": "Văd rezervarea la hotel în e-mailul meu."
            },
            {
              "language": "ru",
              "text": "Я вижу бронирование отеля в своей электронной почте."
            },
            {
              "language": "sq",
              "text": "E shoh rezervimin e hotelit në emailin tim."
            },
            {
              "language": "tr",
              "text": "Otel rezervasyonunu e-postamda görüyorum."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "der Deckungsbeitrag",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Deckungsbeiträge",
      "infinitive": null,
      "syllableBreak": "De-ckungs-bei-trag",
      "topics": [
        "finance-and-accounting",
        "data-and-reporting",
        "sales-and-customers"
      ],
      "usageLabels": [
        "business",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "den Deckungsbeitrag berechnen",
          "meaning": "to calculate the contribution margin"
        },
        {
          "text": "ein positiver Deckungsbeitrag",
          "meaning": "a positive contribution margin"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "decken",
          "relationLabel": "verb",
          "note": "in accounting sense: to cover costs"
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "هامش المساهمة"
        },
        {
          "language": "ckb",
          "text": "بەشداریی داپۆشینی تێچوو"
        },
        {
          "language": "en",
          "text": "contribution margin"
        },
        {
          "language": "fa",
          "text": "حاشیه سود پوششی"
        },
        {
          "language": "kmr",
          "text": "para beşdariyê ya mesrefan"
        },
        {
          "language": "pl",
          "text": "marża pokrycia"
        },
        {
          "language": "ro",
          "text": "marjă de contribuție"
        },
        {
          "language": "ru",
          "text": "маржинальный доход"
        },
        {
          "language": "sq",
          "text": "marzh kontributi"
        },
        {
          "language": "tr",
          "text": "katkı payı"
        }
      ],
      "examples": [
        {
          "baseText": "Im ERP-Bericht sehen wir den Deckungsbeitrag pro Produktgruppe.",
          "translations": [
            {
              "language": "ar",
              "text": "في تقرير نظام تخطيط موارد المؤسسة نرى هامش المساهمة لكل مجموعة منتجات."
            },
            {
              "language": "ckb",
              "text": "لە ڕاپۆرتی ERPدا بەشداریی داپۆشینی تێچوو بۆ هەر گرووپی بەرهەم دەبینین."
            },
            {
              "language": "en",
              "text": "In the ERP report, we see the contribution margin for each product group."
            },
            {
              "language": "fa",
              "text": "در گزارش ERP حاشیه سود پوششی هر گروه محصول را می‌بینیم."
            },
            {
              "language": "kmr",
              "text": "Di rapora ERP de em para beşdariyê ya her koma hilberan dibînin."
            },
            {
              "language": "pl",
              "text": "W raporcie ERP widzimy marżę pokrycia dla każdej grupy produktów."
            },
            {
              "language": "ro",
              "text": "În raportul ERP vedem marja de contribuție pentru fiecare grupă de produse."
            },
            {
              "language": "ru",
              "text": "В ERP-отчете мы видим маржинальный доход по каждой группе товаров."
            },
            {
              "language": "sq",
              "text": "Në raportin ERP shohim marzhin e kontributit për çdo grup produktesh."
            },
            {
              "language": "tr",
              "text": "ERP raporunda her ürün grubu için katkı payını görüyoruz."
            }
          ]
        },
        {
          "baseText": "Bei diesem Auftrag ist der Deckungsbeitrag leider sehr niedrig.",
          "translations": [
            {
              "language": "ar",
              "text": "للأسف هامش المساهمة في هذا الطلب منخفض جدًا."
            },
            {
              "language": "ckb",
              "text": "بەداخەوە لەم داواکارییەدا بەشداریی داپۆشینی تێچوو زۆر کەمە."
            },
            {
              "language": "en",
              "text": "Unfortunately, the contribution margin on this order is very low."
            },
            {
              "language": "fa",
              "text": "متأسفانه حاشیه سود پوششی این سفارش خیلی پایین است."
            },
            {
              "language": "kmr",
              "text": "Mixabin, para beşdariyê li ser vê fermarişê pir kêm e."
            },
            {
              "language": "pl",
              "text": "Niestety marża pokrycia przy tym zamówieniu jest bardzo niska."
            },
            {
              "language": "ro",
              "text": "Din păcate, marja de contribuție pentru această comandă este foarte mică."
            },
            {
              "language": "ru",
              "text": "К сожалению, маржинальный доход по этому заказу очень низкий."
            },
            {
              "language": "sq",
              "text": "Fatkeqësisht, marzhi i kontributit për këtë porosi është shumë i ulët."
            },
            {
              "language": "tr",
              "text": "Bu siparişte katkı payı maalesef çok düşük."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
