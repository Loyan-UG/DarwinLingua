  "entries": [
    {
      "word": "während",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Conjunction",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "wäh-rend",
      "topics": [
        "business-communication",
        "everyday-life",
        "education-and-training"
      ],
      "usageLabels": [
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "subordinating conjunction; also preposition with genitive"
      ],
      "collocations": [
        {
          "text": "während der Arbeit",
          "meaning": "during work"
        },
        {
          "text": "während ich telefoniere",
          "meaning": "while I am on the phone"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أثناء؛ بينما"
        },
        {
          "language": "ckb",
          "text": "لە کاتی؛ کاتێک"
        },
        {
          "language": "en",
          "text": "during; while"
        },
        {
          "language": "fa",
          "text": "در طول؛ هنگام؛ در حالی که"
        },
        {
          "language": "kmr",
          "text": "di dema; dema ku"
        },
        {
          "language": "pl",
          "text": "podczas; gdy"
        },
        {
          "language": "ro",
          "text": "în timpul; în timp ce"
        },
        {
          "language": "ru",
          "text": "во время; пока"
        },
        {
          "language": "sq",
          "text": "gjatë; ndërsa"
        },
        {
          "language": "tr",
          "text": "sırasında; iken"
        }
      ],
      "examples": [
        {
          "baseText": "Während der Besprechung bleibt das Telefon auf lautlos.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء الاجتماع يبقى الهاتف على الوضع الصامت."
            },
            {
              "language": "ckb",
              "text": "لە کاتی کۆبوونەوەکەدا مۆبایلەکە بێدەنگ دەمێنێتەوە."
            },
            {
              "language": "en",
              "text": "During the meeting, the phone stays on silent."
            },
            {
              "language": "fa",
              "text": "در طول جلسه، تلفن روی حالت بی‌صدا می‌ماند."
            },
            {
              "language": "kmr",
              "text": "Di dema civînê de telefon bêdeng dimîne."
            },
            {
              "language": "pl",
              "text": "Podczas spotkania telefon pozostaje wyciszony."
            },
            {
              "language": "ro",
              "text": "În timpul ședinței, telefonul rămâne pe silențios."
            },
            {
              "language": "ru",
              "text": "Во время встречи телефон остается в беззвучном режиме."
            },
            {
              "language": "sq",
              "text": "Gjatë mbledhjes telefoni qëndron pa zë."
            },
            {
              "language": "tr",
              "text": "Toplantı sırasında telefon sessizde kalır."
            }
          ]
        },
        {
          "baseText": "Ich koche das Abendessen, während die Kinder ihre Hausaufgaben machen.",
          "translations": [
            {
              "language": "ar",
              "text": "أطبخ العشاء بينما يقوم الأطفال بواجباتهم."
            },
            {
              "language": "ckb",
              "text": "من نانی ئێوارە دەکەم کاتێک منداڵەکان ئەرکی ماڵەوەیان دەکەن."
            },
            {
              "language": "en",
              "text": "I cook dinner while the children do their homework."
            },
            {
              "language": "fa",
              "text": "من شام می‌پزم در حالی که بچه‌ها تکالیفشان را انجام می‌دهند."
            },
            {
              "language": "kmr",
              "text": "Ez şîvê çêdikim dema zarok dersên malê dikin."
            },
            {
              "language": "pl",
              "text": "Gotuję kolację, podczas gdy dzieci odrabiają lekcje."
            },
            {
              "language": "ro",
              "text": "Gătesc cina în timp ce copiii își fac temele."
            },
            {
              "language": "ru",
              "text": "Я готовлю ужин, пока дети делают домашние задания."
            },
            {
              "language": "sq",
              "text": "Unë gatuaj darkën ndërsa fëmijët bëjnë detyrat."
            },
            {
              "language": "tr",
              "text": "Çocuklar ödevlerini yaparken ben akşam yemeğini pişiriyorum."
            }
          ]
        }
      ]
    },
    {
      "word": "die Wahrheit",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Wahrheiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Wahr-heit",
      "topics": [
        "social-and-relationships",
        "business-communication",
        "law-and-compliance"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Wahrheit sagen",
          "meaning": "to tell the truth"
        },
        {
          "text": "die Wahrheit herausfinden",
          "meaning": "to find out the truth"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "wahr",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الحقيقة"
        },
        {
          "language": "ckb",
          "text": "ڕاستی"
        },
        {
          "language": "en",
          "text": "truth"
        },
        {
          "language": "fa",
          "text": "حقیقت؛ راستى"
        },
        {
          "language": "kmr",
          "text": "rastî"
        },
        {
          "language": "pl",
          "text": "prawda"
        },
        {
          "language": "ro",
          "text": "adevăr"
        },
        {
          "language": "ru",
          "text": "правда; истина"
        },
        {
          "language": "sq",
          "text": "e vërteta"
        },
        {
          "language": "tr",
          "text": "gerçek; doğru"
        }
      ],
      "examples": [
        {
          "baseText": "Im Gespräch mit dem Kunden sollten wir bei der Wahrheit bleiben.",
          "translations": [
            {
              "language": "ar",
              "text": "في الحديث مع العميل يجب أن نلتزم بالحقيقة."
            },
            {
              "language": "ckb",
              "text": "لە گفتوگۆ لەگەڵ کڕیاردا دەبێت لەسەر ڕاستی بمێنینەوە."
            },
            {
              "language": "en",
              "text": "In the conversation with the customer, we should stick to the truth."
            },
            {
              "language": "fa",
              "text": "در گفت‌وگو با مشتری باید حقیقت را بگوییم."
            },
            {
              "language": "kmr",
              "text": "Di axaftina bi xerîdar re divê em li ser rastiyê bimînin."
            },
            {
              "language": "pl",
              "text": "W rozmowie z klientem powinniśmy trzymać się prawdy."
            },
            {
              "language": "ro",
              "text": "În discuția cu clientul ar trebui să rămânem la adevăr."
            },
            {
              "language": "ru",
              "text": "В разговоре с клиентом нам следует придерживаться правды."
            },
            {
              "language": "sq",
              "text": "Në bisedën me klientin duhet t’i qëndrojmë së vërtetës."
            },
            {
              "language": "tr",
              "text": "Müşteriyle görüşmede gerçeğe bağlı kalmalıyız."
            }
          ]
        },
        {
          "baseText": "Es ist manchmal schwer, die Wahrheit zu sagen.",
          "translations": [
            {
              "language": "ar",
              "text": "أحيانًا يكون من الصعب قول الحقيقة."
            },
            {
              "language": "ckb",
              "text": "هەندێک جار گوتنی ڕاستی قورسە."
            },
            {
              "language": "en",
              "text": "Sometimes it is hard to tell the truth."
            },
            {
              "language": "fa",
              "text": "گاهی گفتن حقیقت سخت است."
            },
            {
              "language": "kmr",
              "text": "Carinan gotina rastiyê zehmet e."
            },
            {
              "language": "pl",
              "text": "Czasami trudno jest powiedzieć prawdę."
            },
            {
              "language": "ro",
              "text": "Uneori este greu să spui adevărul."
            },
            {
              "language": "ru",
              "text": "Иногда трудно сказать правду."
            },
            {
              "language": "sq",
              "text": "Ndonjëherë është e vështirë të thuash të vërtetën."
            },
            {
              "language": "tr",
              "text": "Bazen gerçeği söylemek zordur."
            }
          ]
        }
      ]
    },
    {
      "word": "wahrnehmen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "wahrnehmen",
      "pronunciationIpa": null,
      "syllableBreak": "wahr-neh-men",
      "topics": [
        "business-communication",
        "healthcare-and-appointments",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: nimmt wahr, nahm wahr, hat wahrgenommen"
      ],
      "collocations": [
        {
          "text": "einen Termin wahrnehmen",
          "meaning": "to attend an appointment"
        },
        {
          "text": "eine Veränderung wahrnehmen",
          "meaning": "to notice a change"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Wahrnehmung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدرك؛ يلاحظ؛ يحضر موعدًا"
        },
        {
          "language": "ckb",
          "text": "تێبینیکردن؛ هەست پێکردن؛ بەژداری کاتێک کردن"
        },
        {
          "language": "en",
          "text": "to perceive; to notice; to attend"
        },
        {
          "language": "fa",
          "text": "درک کردن؛ متوجه شدن؛ حضور یافتن در قرار"
        },
        {
          "language": "kmr",
          "text": "têgihîştin; dîtin; beşdarî randevû bûn"
        },
        {
          "language": "pl",
          "text": "dostrzec; zauważyć; stawić się na termin"
        },
        {
          "language": "ro",
          "text": "a percepe; a observa; a participa la o programare"
        },
        {
          "language": "ru",
          "text": "воспринимать; замечать; явиться на прием"
        },
        {
          "language": "sq",
          "text": "të perceptosh; të vësh re; të marrësh pjesë në takim"
        },
        {
          "language": "tr",
          "text": "algılamak; fark etmek; randevuya gitmek"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie den Termin morgen um neun Uhr wahrnehmen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك حضور الموعد غدًا الساعة التاسعة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن سبەی کاتژمێر نۆ لە کاتەکە بەژدار بن؟"
            },
            {
              "language": "en",
              "text": "Can you attend the appointment tomorrow at nine o’clock?"
            },
            {
              "language": "fa",
              "text": "می‌توانید فردا ساعت نه در قرار حاضر شوید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin sibê saet nehê randevûyê beşdar bibin?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan/Pani stawić się na termin jutro o dziewiątej?"
            },
            {
              "language": "ro",
              "text": "Puteți participa la programare mâine la ora nouă?"
            },
            {
              "language": "ru",
              "text": "Вы можете прийти на прием завтра в девять часов?"
            },
            {
              "language": "sq",
              "text": "A mund të merrni pjesë në takim nesër në orën nëntë?"
            },
            {
              "language": "tr",
              "text": "Yarın saat dokuzdaki randevuya katılabilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Viele Nutzer nehmen die neue Funktion zuerst gar nicht wahr.",
          "translations": [
            {
              "language": "ar",
              "text": "كثير من المستخدمين لا يلاحظون الميزة الجديدة في البداية."
            },
            {
              "language": "ckb",
              "text": "زۆر بەکارهێنەر لە سەرەتادا تایبەتمەندییە نوێیەکە هەر تێبینی ناکەن."
            },
            {
              "language": "en",
              "text": "Many users do not notice the new feature at first."
            },
            {
              "language": "fa",
              "text": "بسیاری از کاربران در ابتدا اصلاً متوجه قابلیت جدید نمی‌شوند."
            },
            {
              "language": "kmr",
              "text": "Gelek bikarhêner destpêkê taybetmendiya nû hîç nabînin."
            },
            {
              "language": "pl",
