            {
              "language": "ar",
              "text": "نشوي اليوم في الحديقة."
            },
            {
              "language": "ckb",
              "text": "ئێمە ئەمڕۆ لە باخچە کباب دەکەین."
            },
            {
              "language": "en",
              "text": "We are barbecuing in the garden today."
            },
            {
              "language": "fa",
              "text": "ما امروز در باغچه کباب می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em îro li baxçeyê kebab dikin."
            },
            {
              "language": "pl",
              "text": "Dzisiaj grillujemy w ogrodzie."
            },
            {
              "language": "ro",
              "text": "Astăzi facem grătar în grădină."
            },
            {
              "language": "ru",
              "text": "Сегодня мы жарим на гриле в саду."
            },
            {
              "language": "sq",
              "text": "Sot pjekim në skarë në kopsht."
            },
            {
              "language": "tr",
              "text": "Bugün bahçede mangal yapıyoruz."
            }
          ]
        },
        {
          "baseText": "Am Samstag grillen wir mit Freunden.",
          "translations": [
            {
              "language": "ar",
              "text": "يوم السبت نشوي مع الأصدقاء."
            },
            {
              "language": "ckb",
              "text": "شەممە لەگەڵ هاوڕێکان کباب دەکەین."
            },
            {
              "language": "en",
              "text": "On Saturday we barbecue with friends."
            },
            {
              "language": "fa",
              "text": "شنبه با دوستان کباب می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Roja Şemiyê em bi hevalan re kebab dikin."
            },
            {
              "language": "pl",
              "text": "W sobotę grillujemy z przyjaciółmi."
            },
            {
              "language": "ro",
              "text": "Sâmbătă facem grătar cu prietenii."
            },
            {
              "language": "ru",
              "text": "В субботу мы жарим на гриле с друзьями."
            },
            {
              "language": "sq",
              "text": "Të shtunën bëjmë skarë me miqtë."
            },
            {
              "language": "tr",
              "text": "Cumartesi arkadaşlarla mangal yapıyoruz."
            }
