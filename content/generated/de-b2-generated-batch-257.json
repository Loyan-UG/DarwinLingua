  "entries": [
    {
      "word": "verwerfen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verwerfen",
      "pronunciationIpa": null,
      "syllableBreak": "ver-wer-fen",
      "topics": [
        "planning-and-projects",
        "management-and-leadership",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "strategy",
        "risk"
      ],
      "grammarNotes": [
        "irregular verb: verwirft, verwarf, hat verworfen; means to reject or discard"
      ],
      "collocations": [
        {
          "text": "einen Vorschlag verwerfen",
          "meaning": "to reject a proposal"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Entwurf",
          "relationLabel": "related noun",
          "note": null
        },
        {
          "lemma": "werfen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يرفض؛ يستبعد"
        },
        {
          "language": "ckb",
          "text": "ڕەت دەکاتەوە؛ وازی لێ دەهێنێت"
        },
        {
          "language": "en",
          "text": "to reject; to discard"
        },
        {
          "language": "fa",
          "text": "رد کردن؛ کنار گذاشتن"
        },
        {
          "language": "kmr",
          "text": "red kirin; avêtin derve"
        },
        {
          "language": "pl",
          "text": "odrzucić; porzucić"
        },
        {
          "language": "ro",
          "text": "a respinge; a abandona"
        },
        {
          "language": "ru",
          "text": "отклонить; отбросить"
        },
        {
          "language": "sq",
          "text": "të hedhësh poshtë; të refuzosh"
        },
        {
          "language": "tr",
          "text": "reddetmek; elemek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Team hat den ersten Entwurf verworfen, weil er zu teuer gewesen wäre.",
          "translations": [
            {
              "language": "ar",
              "text": "رفض الفريق المسودة الأولى لأنها كانت ستكون مكلفة جدًا."
            },
            {
              "language": "ckb",
              "text": "تیمەکە یەکەم داڕشتەی ڕەت کردەوە، چونکە زۆر گران دەبوو."
            },
            {
              "language": "en",
              "text": "The team rejected the first draft because it would have been too expensive."
            },
            {
              "language": "fa",
              "text": "تیم پیش‌نویس اول را رد کرد، چون بیش از حد پرهزینه می‌شد."
            },
            {
              "language": "kmr",
              "text": "Tîm şêweya yekem red kir, ji ber ku dê pir biha bûya."
            },
            {
              "language": "pl",
              "text": "Zespół odrzucił pierwszy projekt, ponieważ byłby zbyt drogi."
            },
            {
              "language": "ro",
              "text": "Echipa a respins primul proiect deoarece ar fi fost prea scump."
            },
            {
              "language": "ru",
              "text": "Команда отклонила первый проект, потому что он был бы слишком дорогим."
            },
            {
              "language": "sq",
              "text": "Ekipi e hodhi poshtë draftin e parë sepse do të ishte shumë i shtrenjtë."
            },
            {
              "language": "tr",
              "text": "Ekip ilk taslağı çok pahalı olacağı için reddetti."
            }
          ]
        },
        {
          "baseText": "Nach der Risikoanalyse wurde die Idee einer schnellen Migration verworfen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تحليل المخاطر تم استبعاد فكرة الترحيل السريع."
            },
            {
              "language": "ckb",
              "text": "دوای شیکردنەوەی مەترسی، بیرۆکەی گواستنەوەی خێرا ڕەت کرایەوە."
            },
            {
              "language": "en",
              "text": "After the risk analysis, the idea of a quick migration was discarded."
            },
            {
              "language": "fa",
              "text": "پس از تحلیل ریسک، ایده مهاجرت سریع کنار گذاشته شد."
            },
            {
              "language": "kmr",
              "text": "Piştî analîza xetereyê, ramana koçberiya lezgîn hate redkirin."
            },
            {
              "language": "pl",
              "text": "Po analizie ryzyka odrzucono pomysł szybkiej migracji."
            },
            {
              "language": "ro",
              "text": "După analiza riscurilor, ideea unei migrări rapide a fost abandonată."
            },
            {
              "language": "ru",
              "text": "После анализа рисков идею быстрой миграции отклонили."
            },
            {
              "language": "sq",
              "text": "Pas analizës së rrezikut, ideja e migrimit të shpejtë u hodh poshtë."
            },
            {
              "language": "tr",
              "text": "Risk analizinden sonra hızlı geçiş fikri elendi."
            }
          ]
        }
      ]
    },
    {
      "word": "verziehen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verziehen",
