      "grammarNotes": [
        "irregular verb: verzieht, verzog, hat verzogen; can mean to forgive, move away, or warp"
      ],
      "collocations": [
        {
          "text": "jemandem einen Fehler verziehen",
          "meaning": "to forgive someone a mistake"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "ziehen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "verzogen",
          "relationLabel": "participle/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسامح؛ ينتقل؛ يتشوه"
        },
        {
          "language": "ckb",
          "text": "لێخۆش دەبێت؛ دەگوازرێتەوە؛ خوار دەبێت"
        },
        {
          "language": "en",
          "text": "to forgive; to move away; to warp"
        },
        {
          "language": "fa",
          "text": "بخشیدن؛ نقل مکان کردن؛ تاب برداشتن"
        },
        {
          "language": "kmr",
          "text": "lêborîn; koç kirin; xwar bûn"
        },
        {
          "language": "pl",
          "text": "wybaczyć; przeprowadzić się; wypaczyć się"
        },
        {
          "language": "ro",
          "text": "a ierta; a se muta; a se deforma"
        },
        {
          "language": "ru",
          "text": "простить; переехать; покоробиться"
        },
        {
          "language": "sq",
          "text": "të falësh; të zhvendosesh; të shtrembërohesh"
        },
        {
          "language": "tr",
          "text": "affetmek; taşınmak; eğrilmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kunde hat uns die Verzögerung verziehen, weil wir offen kommuniziert haben.",
          "translations": [
            {
              "language": "ar",
              "text": "سامحنا العميل على التأخير لأننا تواصلنا بصراحة."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە دواكەوتنەکەی لێخۆش بوو، چونکە بە کراوەیی پەیوەندیمان کرد."
            },
            {
