  "entries": [
    {
      "word": "die Gleichberechtigung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Gleich-be-rech-ti-gung",
      "topics": [
        "work-and-jobs",
        "law-and-compliance",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "workplace",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually used in singular"
      ],
      "collocations": [
        {
          "text": "für Gleichberechtigung sorgen",
          "meaning": "to ensure equal rights"
        },
        {
          "text": "Gleichberechtigung am Arbeitsplatz",
          "meaning": "equality in the workplace"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gleichberechtigt",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "berechtigen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "المساواة في الحقوق"
        },
        {
          "language": "ckb",
          "text": "یەکسانی مافەکان"
        },
        {
          "language": "en",
          "text": "equal rights; equality"
        },
        {
          "language": "fa",
          "text": "برابری حقوق؛ برابری"
        },
        {
          "language": "kmr",
          "text": "wekhevîya mafan"
        },
        {
          "language": "pl",
          "text": "równouprawnienie; równość praw"
        },
        {
          "language": "ro",
          "text": "egalitate în drepturi"
        },
        {
          "language": "ru",
          "text": "равноправие; равенство прав"
        },
        {
          "language": "sq",
          "text": "barazi në të drejta"
        },
        {
          "language": "tr",
          "text": "eşit haklar; eşitlik"
        }
      ],
      "examples": [
        {
          "baseText": "Das Unternehmen will mehr für Gleichberechtigung in Führungspositionen tun.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد الشركة أن تفعل المزيد من أجل المساواة في المناصب القيادية."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە دەیەوێت زیاتر بۆ یەکسانی لە پۆستەکانی بەڕێوەبردن بکات."
            },
            {
              "language": "en",
              "text": "The company wants to do more for equality in leadership positions."
            },
            {
              "language": "fa",
              "text": "شرکت می‌خواهد برای برابری در سمت‌های مدیریتی بیشتر تلاش کند."
            },
            {
              "language": "kmr",
              "text": "Şîrket dixwaze ji bo wekheviyê di pozîsyonên rêveberiyê de zêdetir bike."
            },
            {
              "language": "pl",
              "text": "Firma chce zrobić więcej dla równouprawnienia na stanowiskach kierowniczych."
            },
            {
              "language": "ro",
              "text": "Compania vrea să facă mai mult pentru egalitatea în funcțiile de conducere."
            },
            {
              "language": "ru",
              "text": "Компания хочет больше делать для равноправия на руководящих должностях."
            },
            {
              "language": "sq",
              "text": "Kompania dëshiron të bëjë më shumë për barazi në pozicionet drejtuese."
            },
            {
              "language": "tr",
              "text": "Şirket yönetici pozisyonlarında eşitlik için daha fazlasını yapmak istiyor."
            }
          ]
        },
        {
          "baseText": "In der Schule sprechen die Jugendlichen über Gleichberechtigung im Alltag.",
          "translations": [
            {
              "language": "ar",
              "text": "يتحدث الشباب في المدرسة عن المساواة في الحياة اليومية."
            },
            {
              "language": "ckb",
              "text": "گەنجان لە قوتابخانەدا باس لە یەکسانی لە ژیانی ڕۆژانە دەکەن."
            },
            {
              "language": "en",
              "text": "At school, the young people talk about equality in everyday life."
            },
            {
              "language": "fa",
              "text": "نوجوانان در مدرسه درباره برابری در زندگی روزمره صحبت می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Li dibistanê ciwan li ser wekheviyê di jiyana rojane de diaxivin."
            },
            {
              "language": "pl",
              "text": "W szkole młodzież rozmawia o równouprawnieniu w życiu codziennym."
            },
            {
              "language": "ro",
              "text": "La școală, tinerii vorbesc despre egalitate în viața de zi cu zi."
            },
            {
              "language": "ru",
              "text": "В школе подростки говорят о равноправии в повседневной жизни."
            },
            {
              "language": "sq",
              "text": "Në shkollë të rinjtë flasin për barazinë në jetën e përditshme."
            },
            {
              "language": "tr",
              "text": "Gençler okulda günlük yaşamda eşitlik hakkında konuşuyor."
            }
          ]
        }
      ]
    },
