      "examples": [
        {
          "baseText": "Die Bauarbeiter müssen zuerst einen Graben für die neue Leitung graben.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على عمال البناء أولاً حفر خندق للخط الجديد."
            },
            {
              "language": "ckb",
              "text": "کرێکارانی بیناسازی دەبێت سەرەتا کەندەکێک بۆ هێڵە نوێیەکە هەڵکەنن."
            },
            {
              "language": "en",
              "text": "The construction workers first have to dig a trench for the new line."
            },
            {
              "language": "fa",
