      "examples": [
        {
          "baseText": "Heute gibt es zwanzig Prozent Rabatt.",
          "translations": [
            {
              "language": "ar",
              "text": "اليوم يوجد خصم عشرون بالمئة."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ بیست لەسەدا داشکاندن هەیە."
            },
            {
              "language": "en",
              "text": "Today there is a twenty percent discount."
            },
            {
              "language": "fa",
              "text": "امروز بیست درصد تخفیف وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Îro bîst ji sedî daxistin heye."
            },
            {
              "language": "pl",
              "text": "Dzisiaj jest dwadzieścia procent rabatu."
            },
            {
              "language": "ro",
              "text": "Astăzi este reducere de douăzeci la sută."
            },
            {
              "language": "ru",
              "text": "Сегодня скидка двадцать процентов."
            },
            {
              "language": "sq",
              "text": "Sot ka njëzet përqind zbritje."
            },
            {
              "language": "tr",
              "text": "Bugün yüzde yirmi indirim var."
            }
          ]
        },
        {
          "baseText": "Fünfzig Prozent der Klasse kommen mit.",
          "translations": [
            {
              "language": "ar",
              "text": "خمسون بالمئة من الصف سيأتون معنا."
            },
            {
              "language": "ckb",
              "text": "پەنجا لەسەدی پۆلەکە لەگەڵمان دێن."
            },
            {
              "language": "en",
              "text": "Fifty percent of the class is coming along."
            },
            {
              "language": "fa",
              "text": "پنجاه درصد کلاس همراه می‌آیند."
            },
            {
              "language": "kmr",
              "text": "Pêncî ji sedî ya polê bi me re tê."
            },
            {
              "language": "pl",
              "text": "Pięćdziesiąt procent klasy idzie z nami."
            },
            {
              "language": "ro",
              "text": "Cincizeci la sută din clasă vine cu noi."
            },
            {
              "language": "ru",
              "text": "Пятьдесят процентов класса идут с нами."
            },
            {
              "language": "sq",
              "text": "Pesëdhjetë përqind e klasës vijnë me ne."
            },
            {
              "language": "tr",
              "text": "Sınıfın yüzde ellisi bizimle geliyor."
            }
          ]
        }
      ]
