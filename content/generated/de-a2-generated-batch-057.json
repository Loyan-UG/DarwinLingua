      ],
      "examples": [
        {
          "baseText": "Die Koffer liegen im Kofferraum.",
          "translations": [
            {
              "language": "ar",
              "text": "الحقائب في صندوق السيارة."
            },
            {
              "language": "ckb",
              "text": "جانتا گەورەکان لە سندوقی دواوەی ئۆتۆمبێل دان."
            },
            {
              "language": "en",
              "text": "The suitcases are in the trunk."
            },
            {
              "language": "fa",
              "text": "چمدان‌ها در صندوق عقب هستند."
            },
            {
              "language": "kmr",
              "text": "Valîz di bagaja erebeyê de ne."
            },
            {
              "language": "pl",
              "text": "Walizki leżą w bagażniku."
            },
            {
              "language": "ro",
              "text": "Valizele sunt în portbagaj."
            },
            {
              "language": "ru",
              "text": "Чемоданы лежат в багажнике."
            },
            {
              "language": "sq",
              "text": "Valixhet janë në bagazhin e makinës."
            },
            {
              "language": "tr",
              "text": "Valizler bagajda."
            }
          ]
        },
        {
          "baseText": "Kannst du bitte den Kofferraum öffnen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك فتح صندوق السيارة من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "تکایە دەتوانیت سندوقی دواوەی ئۆتۆمبێل بکەیتەوە؟"
            },
            {
              "language": "en",
              "text": "Can you please open the trunk?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً صندوق عقب را باز کنی؟"
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe dikarî bagaja erebeyê vekî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz otworzyć bagażnik?"
            },
            {
              "language": "ro",
              "text": "Poți să deschizi portbagajul, te rog?"
            },
            {
              "language": "ru",
              "text": "Можешь, пожалуйста, открыть багажник?"
            },
            {
              "language": "sq",
              "text": "A mund ta hapësh bagazhin, të lutem?"
            },
            {
              "language": "tr",
              "text": "Lütfen bagajı açabilir misin?"
            }
          ]
        }
      ]
