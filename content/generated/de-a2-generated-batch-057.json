      "examples": [
        {
          "baseText": "Ich habe morgen einen Termin im Konsulat.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي غداً موعد في القنصلية."
            },
            {
              "language": "ckb",
              "text": "سبەی لە کونسوڵخانە کاتم هەیە."
            },
            {
              "language": "en",
              "text": "I have an appointment at the consulate tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا در کنسولگری وقت دارم."
            },
            {
              "language": "kmr",
              "text": "Min sibê li konsolxaneyê dem heye."
            },
            {
              "language": "pl",
              "text": "Jutro mam termin w konsulacie."
            },
            {
              "language": "ro",
              "text": "Mâine am programare la consulat."
            },
            {
              "language": "ru",
              "text": "Завтра у меня запись в консульстве."
            },
            {
              "language": "sq",
              "text": "Nesër kam takim në konsullatë."
            },
            {
              "language": "tr",
              "text": "Yarın konsoloslukta randevum var."
            }
          ]
        },
        {
          "baseText": "Das Konsulat braucht eine Kopie vom Pass.",
          "translations": [
            {
              "language": "ar",
              "text": "القنصلية تحتاج إلى نسخة من جواز السفر."
            },
            {
              "language": "ckb",
              "text": "کونسوڵخانە پێویستی بە کۆپی پاسپۆرتەکە هەیە."
            },
            {
              "language": "en",
              "text": "The consulate needs a copy of the passport."
            },
            {
              "language": "fa",
              "text": "کنسولگری به یک کپی از گذرنامه نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Konsolxane hewceyê kopiyeke pasaportê ye."
            },
            {
              "language": "pl",
              "text": "Konsulat potrzebuje kopii paszportu."
            },
            {
              "language": "ro",
              "text": "Consulatul are nevoie de o copie a pașaportului."
            },
            {
              "language": "ru",
              "text": "Консульству нужна копия паспорта."
            },
            {
              "language": "sq",
              "text": "Konsullata ka nevojë për një kopje të pasaportës."
            },
            {
              "language": "tr",
              "text": "Konsolosluğun pasaport kopyasına ihtiyacı var."
