  "entries": [
    {
      "word": "produzieren",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "produzieren",
      "pronunciationIpa": null,
      "syllableBreak": "pro-du-zie-ren",
      "topics": [
        "production-and-maintenance",
        "work-and-jobs",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "formal",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "Waren produzieren",
          "meaning": "to produce goods"
        },
        {
          "text": "in Serie produzieren",
          "meaning": "to produce in series"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Produktion",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "das Produkt",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينتج؛ يصنّع"
        },
        {
          "language": "ckb",
          "text": "بەرهەم دەهێنێت؛ دروست دەکات"
        },
        {
          "language": "en",
          "text": "to produce; to manufacture"
        },
        {
          "language": "fa",
          "text": "تولید کردن؛ ساختن"
        },
        {
          "language": "kmr",
          "text": "hilberandin; çêkirin"
        },
        {
          "language": "pl",
          "text": "produkować; wytwarzać"
        },
        {
          "language": "ro",
          "text": "a produce; a fabrica"
        },
        {
          "language": "ru",
          "text": "производить; изготавливать"
        },
        {
          "language": "sq",
          "text": "të prodhosh; të fabrikosh"
        },
        {
          "language": "tr",
          "text": "üretmek; imal etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Firma produziert Ersatzteile für Maschinen.",
          "translations": [
            {
              "language": "ar",
              "text": "تنتج الشركة قطع غيار للآلات."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە پارچەی جێگرەوە بۆ ئامێرەکان بەرهەم دەهێنێت."
            },
            {
              "language": "en",
              "text": "The company produces spare parts for machines."
            },
            {
              "language": "fa",
              "text": "شرکت قطعات یدکی برای ماشین‌آلات تولید می‌کند."
            },
            {
              "language": "kmr",
              "text": "Şîrket parçeyên cîgir ji bo makîneyan hilberîne."
            },
            {
              "language": "pl",
              "text": "Firma produkuje części zamienne do maszyn."
            },
            {
              "language": "ro",
              "text": "Firma produce piese de schimb pentru mașini."
            },
            {
              "language": "ru",
              "text": "Компания производит запчасти для машин."
            },
            {
              "language": "sq",
              "text": "Kompania prodhon pjesë këmbimi për makineri."
            },
            {
              "language": "tr",
              "text": "Şirket makineler için yedek parçalar üretiyor."
            }
          ]
        },
        {
          "baseText": "Wir können das neue Modell erst ab Mai produzieren.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يمكننا إنتاج الطراز الجديد إلا اعتبارًا من مايو."
            },
            {
              "language": "ckb",
              "text": "تەنها لە مانگی ئایارەوە دەتوانین مۆدێلی نوێ بەرهەم بهێنین."
            },
            {
              "language": "en",
              "text": "We can only produce the new model from May onward."
            },
            {
              "language": "fa",
              "text": "ما می‌توانیم مدل جدید را فقط از ماه مه تولید کنیم."
            },
            {
              "language": "kmr",
              "text": "Em dikarin modela nû tenê ji gulanê û pê ve hilberînin."
            },
            {
              "language": "pl",
              "text": "Nowy model możemy produkować dopiero od maja."
            },
            {
              "language": "ro",
              "text": "Putem produce noul model abia din mai."
            },
            {
              "language": "ru",
              "text": "Мы сможем производить новую модель только с мая."
            },
            {
              "language": "sq",
              "text": "Modelin e ri mund ta prodhojmë vetëm nga maji."
            },
            {
              "language": "tr",
              "text": "Yeni modeli ancak mayıstan itibaren üretebiliriz."
            }
          ]
        }
      ]
    },
    {
      "word": "der Professor",
