        "education-and-training",
        "work-and-jobs",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; female form: die Professorin"
      ],
      "collocations": [
        {
          "text": "der Professor hält eine Vorlesung",
          "meaning": "the professor gives a lecture"
        },
        {
          "text": "den Professor fragen",
          "meaning": "to ask the professor"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Professorin",
          "relationLabel": "female form",
          "note": null
        },
        {
          "lemma": "die Professur",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أستاذ جامعي"
        },
        {
          "language": "ckb",
          "text": "پرۆفیسۆر؛ مامۆستای زانکۆ"
        },
        {
          "language": "en",
          "text": "professor; male professor"
        },
        {
          "language": "fa",
          "text": "استاد دانشگاه؛ پروفسور مرد"
        },
        {
          "language": "kmr",
          "text": "profesorê mêr"
        },
        {
          "language": "pl",
          "text": "profesor"
        },
        {
          "language": "ro",
          "text": "profesor universitar"
        },
        {
          "language": "ru",
          "text": "профессор"
        },
        {
          "language": "sq",
          "text": "profesor"
        },
        {
          "language": "tr",
          "text": "profesör; erkek profesör"
        }
      ],
      "examples": [
        {
          "baseText": "Der Professor erklärt das Thema mit einfachen Beispielen.",
          "translations": [
            {
              "language": "ar",
              "text": "يشرح الأستاذ الجامعي الموضوع بأمثلة بسيطة."
            },
            {
              "language": "ckb",
              "text": "پرۆفیسۆرەکە بابەتەکە بە نموونەی ئاسان ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The professor explains the topic with simple examples."
            },
            {
              "language": "fa",
              "text": "استاد موضوع را با مثال‌های ساده توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Profesor mijarê bi mînakên hêsan rave dike."
            },
            {
              "language": "pl",
              "text": "Profesor wyjaśnia temat prostymi przykładami."
            },
            {
              "language": "ro",
              "text": "Profesorul explică tema cu exemple simple."
            },
            {
              "language": "ru",
              "text": "Профессор объясняет тему простыми примерами."
            },
            {
              "language": "sq",
              "text": "Profesori e shpjegon temën me shembuj të thjeshtë."
            },
            {
              "language": "tr",
              "text": "Profesör konuyu basit örneklerle açıklıyor."
            }
          ]
        },
        {
          "baseText": "Nach der Vorlesung können die Studierenden den Professor sprechen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد المحاضرة يمكن للطلاب التحدث مع الأستاذ."
            },
            {
              "language": "ckb",
              "text": "دوای وانەکە خوێندکاران دەتوانن قسە لەگەڵ پرۆفیسۆرەکە بکەن."
            },
            {
              "language": "en",
              "text": "After the lecture, the students can speak with the professor."
            },
            {
              "language": "fa",
              "text": "بعد از درس، دانشجویان می‌توانند با استاد صحبت کنند."
            },
            {
              "language": "kmr",
              "text": "Piştî dersê xwendekar dikarin bi profesor re biaxivin."
            },
            {
              "language": "pl",
              "text": "Po wykładzie studenci mogą porozmawiać z profesorem."
            },
            {
              "language": "ro",
              "text": "După curs, studenții pot vorbi cu profesorul."
            },
            {
              "language": "ru",
              "text": "После лекции студенты могут поговорить с профессором."
            },
            {
              "language": "sq",
              "text": "Pas ligjëratës, studentët mund të flasin me profesorin."
            },
            {
              "language": "tr",
              "text": "Dersten sonra öğrenciler profesörle konuşabilir."
            }
          ]
        }
      ]
    },
