          "text": "çiklist"
        },
        {
          "language": "tr",
          "text": "bisikletli; erkek bisikletçi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Radfahrer wartet an der Ampel.",
          "translations": [
            {
              "language": "ar",
              "text": "راكب الدراجة ينتظر عند إشارة المرور."
            },
            {
              "language": "ckb",
              "text": "پاسکیلسوارەکە لە چرای هاتوچۆ چاوەڕێ دەکات."
            },
            {
              "language": "en",
              "text": "The cyclist waits at the traffic light."
            },
            {
              "language": "fa",
              "text": "دوچرخه‌سوار پشت چراغ راهنمایی منتظر است."
            },
            {
              "language": "kmr",
              "text": "Duçerxesuwar li ronahiya trafîkê li benda ye."
            },
            {
              "language": "pl",
              "text": "Rowerzysta czeka na światłach."
            },
            {
              "language": "ro",
              "text": "Biciclistul așteaptă la semafor."
            },
            {
              "language": "ru",
              "text": "Велосипедист ждёт у светофора."
            },
            {
              "language": "sq",
              "text": "Çiklisti pret te semafori."
            },
            {
              "language": "tr",
              "text": "Bisikletli trafik ışığında bekliyor."
            }
          ]
        },
        {
          "baseText": "Ein Radfahrer fährt jeden Morgen durch den Park.",
          "translations": [
            {
              "language": "ar",
              "text": "راكب دراجة يمر كل صباح عبر الحديقة."
            },
            {
              "language": "ckb",
              "text": "پاسکیلسوارێک هەموو بەیانییەک بە ناو پارکدا دەڕوات."
            },
            {
              "language": "en",
              "text": "A cyclist rides through the park every morning."
            },
            {
              "language": "fa",
              "text": "یک دوچرخه‌سوار هر صبح از پارک عبور می‌کند."
            },
            {
              "language": "kmr",
              "text": "Duçerxesuwarek her sibeh di nav parkê re diçe."
            },
            {
              "language": "pl",
              "text": "Rowerzysta codziennie rano jedzie przez park."
            },
            {
              "language": "ro",
              "text": "Un biciclist trece prin parc în fiecare dimineață."
            },
            {
              "language": "ru",
              "text": "Велосипедист каждое утро едет через парк."
            },
            {
              "language": "sq",
              "text": "Një çiklist kalon çdo mëngjes nëpër park."
            },
            {
              "language": "tr",
              "text": "Bir bisikletli her sabah parktan geçiyor."
            }
          ]
        }
      ]
    },
