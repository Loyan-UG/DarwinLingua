        },
        {
          "baseText": "Die Radfahrerin fährt langsam neben dem Bus.",
          "translations": [
            {
              "language": "ar",
              "text": "راكبة الدراجة تسير ببطء بجانب الحافلة."
            },
            {
              "language": "ckb",
              "text": "پاسکیلسوارە ژنەکە هێواش لە تەنیشت پاسەکە دەڕوات."
            },
            {
              "language": "en",
              "text": "The cyclist rides slowly next to the bus."
            },
            {
              "language": "fa",
              "text": "دوچرخه‌سوار زن آرام کنار اتوبوس حرکت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Duçerxesuwara jin hêdî li kêleka otobusê diçe."
            },
            {
              "language": "pl",
              "text": "Rowerzystka jedzie wolno obok autobusu."
            },
            {
              "language": "ro",
              "text": "Biciclista merge încet lângă autobuz."
            },
            {
              "language": "ru",
              "text": "Велосипедистка медленно едет рядом с автобусом."
            },
            {
              "language": "sq",
              "text": "Çiklistja ecën ngadalë pranë autobusit."
            },
            {
              "language": "tr",
              "text": "Kadın bisikletçi otobüsün yanında yavaş gidiyor."
