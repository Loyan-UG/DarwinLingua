            {
              "language": "en",
              "text": "The cyclist is wearing a helmet."
            },
            {
              "language": "fa",
              "text": "دوچرخه‌سوار زن کلاه ایمنی دارد."
            },
            {
              "language": "kmr",
              "text": "Duçerxesuwara jin kaskek li serê xwe kiriye."
