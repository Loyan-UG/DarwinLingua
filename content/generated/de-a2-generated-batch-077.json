        {
          "baseText": "Die Radfahrerin trägt einen Helm.",
          "translations": [
            {
              "language": "ar",
              "text": "راكبة الدراجة ترتدي خوذة."
            },
            {
              "language": "ckb",
              "text": "پاسکیلسوارە ژنەکە کڵاوێکی پاراستن لەسەرە."
