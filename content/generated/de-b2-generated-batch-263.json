  "entries": [
    {
      "word": "widerfahren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "widerfahren",
      "pronunciationIpa": null,
      "syllableBreak": "wi-der-fah-ren",
      "topics": [
        "business-communication",
        "quality-and-risk",
        "social-and-relationships"
      ],
      "usageLabels": [
        "written",
        "spoken"
      ],
      "contextLabels": [
        "management",
        "risk",
        "customer-service"
      ],
      "grammarNotes": [
        "formal/intransitive verb: widerfährt, widerfuhr, ist widerfahren; usually with dative person"
      ],
      "collocations": [
        {
          "text": "jemandem Unrecht widerfahren",
          "meaning": "for someone to suffer injustice"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Widerfahrnis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "fahren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحدث لشخص؛ يتعرض له"
        },
        {
          "language": "ckb",
          "text": "بەسەر کەسێکدا دێت؛ ڕووی دەدات"
        },
        {
          "language": "en",
          "text": "to happen to someone; to befall"
        },
        {
          "language": "fa",
          "text": "برای کسی رخ دادن؛ بر سر کسی آمدن"
        },
        {
          "language": "kmr",
          "text": "li kesekî hatin; qewimîn"
        },
        {
          "language": "pl",
          "text": "przydarzyć się komuś"
        },
        {
          "language": "ro",
          "text": "a i se întâmpla cuiva"
        },
        {
          "language": "ru",
          "text": "случиться с кем-то"
        },
        {
          "language": "sq",
          "text": "t’i ndodhë dikujt"
        },
        {
          "language": "tr",
          "text": "başına gelmek"
        }
      ],
      "examples": [
        {
          "baseText": "Dem Kunden ist durch die falsche Abbuchung ein klarer Nachteil widerfahren.",
          "translations": [
            {
              "language": "ar",
              "text": "تعرض العميل لضرر واضح بسبب الخصم الخاطئ."
            },
            {
              "language": "ckb",
              "text": "بەهۆی لابردنی پارەی هەڵەوە زیانێکی ڕوون بە کڕیارەکە گەیشتووە."
            },
            {
              "language": "en",
              "text": "The customer suffered a clear disadvantage because of the incorrect debit."
            },
            {
              "language": "fa",
              "text": "به دلیل برداشت اشتباه، زیان مشخصی به مشتری وارد شد."
            },
            {
              "language": "kmr",
              "text": "Ji ber kişandina pereyan a şaş zirarekî zelal li xerîdar hat."
            },
            {
              "language": "pl",
              "text": "Klient doznał wyraźnej szkody przez błędne obciążenie."
            },
            {
              "language": "ro",
              "text": "Clientului i s-a întâmplat un dezavantaj clar din cauza debitării greșite."
            },
            {
              "language": "ru",
              "text": "Клиенту был причинен явный ущерб из-за ошибочного списания."
            },
            {
              "language": "sq",
              "text": "Klientit i ndodhi një dëm i qartë për shkak të debitimit të gabuar."
            },
            {
              "language": "tr",
              "text": "Yanlış tahsilat nedeniyle müşterinin açık bir zarara uğradığı görüldü."
            }
          ]
        },
        {
          "baseText": "Was ihr im alten Team widerfahren ist, darf sich hier nicht wiederholen.",
          "translations": [
            {
              "language": "ar",
              "text": "ما حدث لها في الفريق القديم لا يجوز أن يتكرر هنا."
            },
            {
              "language": "ckb",
              "text": "ئەوەی لە تیمە کۆنەکەدا بەسەری هات، نابێت لێرە دووبارە ببێتەوە."
            },
            {
              "language": "en",
              "text": "What happened to her in the old team must not happen again here."
            },
            {
              "language": "fa",
              "text": "آنچه در تیم قبلی برای او رخ داد، نباید اینجا تکرار شود."
            },
            {
              "language": "kmr",
              "text": "Tiştê ku di tîma kevn de li wê hat, nabe li vir dubare bibe."
            },
            {
              "language": "pl",
              "text": "To, co przydarzyło jej się w starym zespole, nie może się tutaj powtórzyć."
            },
            {
              "language": "ro",
              "text": "Ceea ce i s-a întâmplat în vechea echipă nu trebuie să se repete aici."
            },
            {
              "language": "ru",
              "text": "То, что случилось с ней в прежней команде, не должно повториться здесь."
            },
            {
              "language": "sq",
              "text": "Ajo që i ndodhi në ekipin e vjetër nuk duhet të përsëritet këtu."
            },
            {
              "language": "tr",
              "text": "Eski ekipte başına gelen şey burada tekrarlanmamalı."
            }
          ]
        }
      ]
    },
    {
      "word": "widerlegen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "widerlegen",
      "pronunciationIpa": null,
      "syllableBreak": "wi-der-le-gen",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "analytics",
        "research",
        "management"
      ],
      "grammarNotes": [
        "regular verb: widerlegt, widerlegte, hat widerlegt"
      ],
      "collocations": [
        {
          "text": "eine Behauptung widerlegen",
          "meaning": "to refute a claim"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Widerlegung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "belegen",
          "relationLabel": "contrast verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدحض؛ يفنّد"
        },
        {
          "language": "ckb",
          "text": "ڕەت دەکاتەوە بە بەڵگە"
        },
        {
          "language": "en",
          "text": "to refute; to disprove"
        },
        {
          "language": "fa",
          "text": "رد کردن با دلیل؛ ابطال کردن"
        },
        {
          "language": "kmr",
          "text": "bi belge red kirin"
        },
        {
          "language": "pl",
          "text": "obalić; podważyć"
        },
        {
          "language": "ro",
          "text": "a infirma; a contrazice"
        },
        {
          "language": "ru",
          "text": "опровергнуть"
        },
        {
          "language": "sq",
          "text": "të përgënjeshtrosh; të rrëzosh"
        },
        {
          "language": "tr",
          "text": "çürütmek; yalanlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Die neuen Messdaten widerlegen die Annahme, dass der Fehler nur nachts auftritt.",
          "translations": [
            {
              "language": "ar",
              "text": "تفند بيانات القياس الجديدة الافتراض بأن الخطأ يحدث ليلًا فقط."
            },
            {
              "language": "ckb",
              "text": "داتای پێوانەی نوێ ئەو گریمانەیە ڕەت دەکاتەوە کە هەڵەکە تەنها شەوان ڕوودەدات."
            },
            {
              "language": "en",
              "text": "The new measurement data refutes the assumption that the error occurs only at night."
            },
