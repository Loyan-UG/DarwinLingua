  "entries": [
    {
      "word": "auffliegen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auffliegen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-flie-gen",
      "topics": [
        "work-and-jobs",
        "customer-service",
        "technology-and-it"
      ],
      "usageLabels": [
        "spoken",
        "workplace",
        "formal"
      ],
      "contextLabels": [
        "risk",
        "customer-service"
      ],
      "grammarNotes": [
        "inseparable particle verb",
        "used in past tense as aufgeflogen"
      ],
      "collocations": [
        {
          "text": "ein Fehler auffliegen",
          "meaning": "a mistake becomes visible"
        },
        {
          "text": "der Mangel wurde auffliegen",
          "meaning": "the defect became apparent"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "آشکار شدن"
        },
        {
          "language": "ckb",
          "text": "راگرتنەوەی وورد"
        },
        {
          "language": "en",
          "text": "become visible; be exposed"
        },
        {
          "language": "fa",
          "text": "آشکار شدن"
        },
        {
          "language": "kmr",
          "text": "xuyang bûn"
        },
        {
          "language": "pl",
          "text": "wyjść na jaw"
        },
        {
          "language": "ro",
          "text": "a ieși la iveală"
        },
        {
          "language": "ru",
          "text": "стать явным"
        },
        {
          "language": "sq",
          "text": "zbulohet"
        },
        {
          "language": "tr",
          "text": "ortaya çıkmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der kritische Konfigurationsfehler ist im letzten Testlauf aufgeflogen.",
          "translations": [
            {
              "language": "ar",
              "text": "خطأ التكوين الحرج ظهر في آخر دورة اختبار."
            },
            {
              "language": "ckb",
              "text": "هەڵەی گرنگی ڕێکخستن لە دوایین دووبارەچوونی تاقیکردنەوەدا ڕوون بوو."
            },
            {
              "language": "en",
              "text": "The critical configuration error became visible in the latest test run."
            },
            {
              "language": "fa",
              "text": "خطای پیکربندی بحرانی در آخرین اجرای آزمایش آشکار شد."
            },
            {
              "language": "kmr",
              "text": "Şaşyekî girîng a mîhengê di testkirina dawî de xuyang bû."
            },
            {
              "language": "pl",
              "text": "Poważny błąd konfiguracyjny ujawnił się w ostatnim przebiegu testu."
            },
            {
              "language": "ro",
              "text": "Problema critică de configurare a ieșit la iveală la ultima rulare de test."
            },
            {
              "language": "ru",
              "text": "Критическая ошибка конфигурации проявилась в последнем прогоне тестов."
            },
            {
              "language": "sq",
              "text": "Një gabim kritik i konfigurimit u bë i dukshëm në testimin e fundit."
            },
            {
              "language": "tr",
              "text": "Kritik konfigürasyon hatası son test koşusunda ortaya çıktı."
            }
          ]
        },
        {
          "baseText": "Der Kunde merkte an, dass der Datenschutzfehler sofort auffliegen könnte.",
          "translations": [
            {
              "language": "ar",
              "text": "مشتری اشاره کرد که شکست امنیت داده می‌تواند فوراً آشکار شود."
            },
            {
              "language": "ckb",
              "text": "بەکارهێنەر ئاگاداریم کرد کە هەڵەی سەلامەتی داتا بە خێرایی دەربهێنرێت."
            },
            {
              "language": "en",
              "text": "The client warned that the data privacy issue could surface immediately."
            },
            {
              "language": "fa",
              "text": "مشتری هشدار داد که مشکل حریم‌خصوصی داده می‌تواند فوراً آشکار شود."
            },
            {
              "language": "kmr",
              "text": "Ezberker got ku pirsgirêka nepeniyê daneyê dikare zû xuyang bibe."
            },
            {
              "language": "pl",
              "text": "Klient ostrzegł, że problem prywatności danych może ujawnić się natychmiast."
            },
            {
              "language": "ro",
              "text": "Clientul a avertizat că incidentul de confidențialitate a datelor se poate manifesta imediat."
            },
            {
              "language": "ru",
              "text": "Клиент предупредил, что проблема конфиденциальности данных может всплыть немедленно."
            },
            {
              "language": "sq",
              "text": "Klienti paralajmëroi se problemi i privatësisë së të dhënave mund të bëhej i dukshëm menjëherë."
            },
            {
              "language": "tr",
              "text": "Müşteri, veri gizliliği sorununun hemen açığa çıkabileceğini uyardı."
            }
          ]
        }
      ]
    },
    {
      "word": "auffressen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auffressen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-fres-sen",
      "topics": [
        "work-and-jobs",
        "production-and-maintenance",
        "technology-and-it"
      ],
      "usageLabels": [
        "spoken",
        "technical",
        "workplace"
      ],
      "contextLabels": [
        "risk",
        "documents"
      ],
      "grammarNotes": [
        "separable prefix verb"
      ],
      "collocations": [
        {
          "text": "ein Teil wird aufgefressen",
          "meaning": "a part is being consumed"
        },
        {
          "text": "Serverzeit aufgefressen",
          "meaning": "CPU resources consumed"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مصرف کردن/بلعیدن"
        },
        {
          "language": "ckb",
          "text": "به‌قەدەر چوونە ژور"
        },
        {
          "language": "en",
          "text": "erode; consume"
        },
        {
          "language": "fa",
          "text": "مصرف کردن؛ فرسودن"
        },
        {
          "language": "kmr",
          "text": "xêrkêşîna dereng"
        },
        {
          "language": "pl",
          "text": "pożerać; zużywać"
        },
        {
          "language": "ro",
          "text": "a eroda; a consuma"
        },
        {
          "language": "ru",
          "text": "съедать; изнашивать"
        },
        {
          "language": "sq",
          "text": "ta konsumojë"
        },
        {
          "language": "tr",
          "text": "tüketmek; aşındırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der falsche Batch-Prozess hat zu viele Ressourcen aufgefressen.",
          "translations": [
            {
              "language": "ar",
              "text": "فرآیند نادرست بچ باعث مصرف بیش از حد منابع شد."
            },
            {
              "language": "ckb",
              "text": "ڕێگەپێدی باچەی ھەڵە زیادەی سەرچاوە بە دەوڵەمەند کرد."
            },
            {
              "language": "en",
              "text": "The faulty batch process consumed too many resources."
            },
            {
              "language": "fa",
              "text": "فرآیند نادرست دسته‌ای منابع زیادی را مصرف کرد."
            },
            {
              "language": "kmr",
              "text": "Pêvajoya batch ya çewt gelek resûrên têkçûnî xêrkêşî kir."
            },
            {
              "language": "pl",
              "text": "Błędny proces wsadowy zużył zbyt wiele zasobów."
            },
            {
              "language": "ro",
              "text": "Procesul de lot defect a consumat prea multe resurse."
            },
            {
              "language": "ru",
              "text": "Ошибочный пакетный процесс израсходовал слишком много ресурсов."
            },
            {
              "language": "sq",
              "text": "Procesi i gabuar i batch-it konsumoi shumë burime."
            },
            {
              "language": "tr",
              "text": "Hatalı toplu işleme süreci çok fazla kaynak tüketti."
            }
          ]
        },
        {
          "baseText": "Der Rost auf der Leitungsanlage wurde im letzten Jahr langsam aufgefressen.",
          "translations": [
            {
              "language": "ar",
              "text": "زنگ روی سیستم لوله‌کشی در سال گذشته به‌تدریج خورده شده بود."
            },
            {
              "language": "ckb",
              "text": "زەنگ لە سیستمەکەدا لە ساڵی ڕابردووەوە به‌هێواشی خواردەبوو."
            },
            {
              "language": "en",
              "text": "The rust on the piping system had been slowly eaten away over the last year."
            },
            {
              "language": "fa",
              "text": "زنگ روی سیستم لوله‌کشی در سال گذشته به تدریج خورده شده بود."
            },
            {
              "language": "kmr",
              "text": "zirhê li ser pergala tevliheviyê di salê borî de hêsan hat xwarin."
            },
            {
              "language": "pl",
              "text": "Rdza na systemie rur na przestrzeni zeszłego roku powoli się wyżarła."
            },
            {
              "language": "ro",
              "text": "Rugină din sistemul de conducte a fost mâncată lent anul trecut."
            },
            {
              "language": "ru",
              "text": "Ржавчина на трубопроводной системе за последний год медленно съела металл."
            },
            {
              "language": "sq",
              "text": "Ike i tubacionit ngadalë është konsumuar nga ndryshku gjatë vitit të kaluar."
            },
            {
              "language": "tr",
