    {
      "word": "Lieferantenartikel",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Lieferantenartikel",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Lie-fe-ran-ten-ar-ti-kel",
      "topics": [
        "procurement-and-suppliers",
        "erp-and-business-systems",
        "warehouse-and-logistics"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; supplier-specific item or item number"
      ],
      "collocations": [
        {
          "text": "einen Lieferantenartikel zuordnen",
          "meaning": "to assign a supplier item"
        },
        {
          "text": "den Lieferantenartikel prüfen",
          "meaning": "to check the supplier item"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Lieferant",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Artikel",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "صنف المورد؛ رقم صنف المورد"
        },
        {
          "language": "ckb",
          "text": "ماددەی دابینکەر"
        },
        {
          "language": "en",
          "text": "supplier item; supplier item number"
        },
        {
          "language": "fa",
          "text": "کالای تأمین‌کننده؛ کد کالای تأمین‌کننده"
        },
        {
          "language": "kmr",
          "text": "babetê dabînker"
        },
        {
          "language": "pl",
          "text": "artykuł dostawcy"
        },
        {
          "language": "ro",
          "text": "articol furnizor"
        },
        {
          "language": "ru",
          "text": "товар поставщика; артикул поставщика"
        },
        {
          "language": "sq",
          "text": "artikull i furnitorit"
        },
        {
          "language": "tr",
          "text": "tedarikçi ürünü; tedarikçi ürün kodu"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lieferantenartikel wird im ERP mit unserer internen Artikelnummer verknüpft.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم ربط صنف المورد في ERP برقم الصنف الداخلي لدينا."
            },
            {
              "language": "ckb",
              "text": "ماددەی دابینکەر لە ERP دا بە ژمارەی ناوخۆی ماددەکەمان دەبەسترێتەوە."
            },
            {
              "language": "en",
              "text": "The supplier item is linked in the ERP to our internal item number."
            },
            {
              "language": "fa",
              "text": "کالای تأمین‌کننده در ERP به شماره کالای داخلی ما متصل می‌شود."
            },
            {
              "language": "kmr",
              "text": "Babetê dabînker di ERP de bi hejmara hundirîn a babetê me ve tê girêdan."
            },
            {
              "language": "pl",
              "text": "Artykuł dostawcy jest w ERP powiązany z naszym wewnętrznym numerem artykułu."
            },
            {
              "language": "ro",
              "text": "Articolul furnizor este legat în ERP de numărul nostru intern de articol."
            },
            {
              "language": "ru",
              "text": "Товар поставщика связывается в ERP с нашим внутренним номером товара."
            },
            {
              "language": "sq",
              "text": "Artikulli i furnitorit lidhet në ERP me numrin tonë të brendshëm të artikullit."
            },
            {
              "language": "tr",
              "text": "Tedarikçi ürünü ERP’de bizim dahili ürün numaramızla eşleştirilir."
            }
          ]
        },
        {
          "baseText": "Bitte kontrollieren Sie den Lieferantenartikel, bevor wir die Bestellung freigeben.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى فحص صنف المورد قبل أن نحرر طلب الشراء."
            },
            {
              "language": "ckb",
              "text": "تکایە ماددەی دابینکەر بپشکنن پێش ئەوەی داواکاریی کڕین ئازاد بکەین."
            },
            {
              "language": "en",
              "text": "Please check the supplier item before we release the purchase order."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از آزاد کردن سفارش خرید، کالای تأمین‌کننده را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe babetê dabînker kontrol bikin berî ku em fermana kirînê berdin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić artykuł dostawcy, zanim zwolnimy zamówienie zakupu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați articolul furnizor înainte să aprobăm comanda de achiziție."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте товар поставщика, прежде чем мы разблокируем заказ на закупку."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni artikullin e furnitorit para se të lirojmë porosinë e blerjes."
            },
            {
              "language": "tr",
              "text": "Satın alma siparişini serbest bırakmadan önce lütfen tedarikçi ürününü kontrol edin."
            }
          ]
        }
      ]
    },
    {
      "word": "Lieferantenbestellung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Lieferantenbestellungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Lie-fe-ran-ten-be-stel-lung",
      "topics": [
        "procurement-and-suppliers",
        "erp-and-business-systems",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; purchase order sent to a supplier"
      ],
      "collocations": [
        {
          "text": "eine Lieferantenbestellung senden",
          "meaning": "to send a supplier purchase order"
        },
        {
          "text": "eine Lieferantenbestellung ändern",
          "meaning": "to change a supplier purchase order"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Lieferant",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Bestellung",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "طلب شراء إلى المورد"
        },
        {
          "language": "ckb",
          "text": "داواکاریی کڕین بۆ دابینکەر"
        },
        {
          "language": "en",
          "text": "supplier purchase order"
        },
        {
          "language": "fa",
          "text": "سفارش خرید از تأمین‌کننده"
        },
        {
          "language": "kmr",
          "text": "fermana kirînê ji dabînker"
        },
        {
          "language": "pl",
          "text": "zamówienie do dostawcy"
        },
        {
          "language": "ro",
          "text": "comandă către furnizor"
        },
        {
          "language": "ru",
          "text": "заказ поставщику"
        },
        {
          "language": "sq",
          "text": "porosi ndaj furnitorit"
        },
        {
          "language": "tr",
          "text": "tedarikçi siparişi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Lieferantenbestellung wird im ERP erst gesendet, wenn der Preis freigegeben ist.",
          "translations": [
            {
              "language": "ar",
              "text": "لا تُرسل طلبية المورد من ERP إلا بعد اعتماد السعر."
            },
            {
              "language": "ckb",
              "text": "داواکاریی کڕین بۆ دابینکەر لە ERP دا تەنها دوای پەسەندکردنی نرخ دەنێردرێت."
            },
            {
              "language": "en",
              "text": "The supplier purchase order is sent from the ERP only after the price has been approved."
            },
            {
              "language": "fa",
              "text": "سفارش خرید از تأمین‌کننده در ERP فقط پس از تأیید قیمت ارسال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Fermana kirînê ji dabînker di ERP de tenê piştî erêkirina bihayê tê şandin."
            },
            {
              "language": "pl",
              "text": "Zamówienie do dostawcy jest wysyłane z ERP dopiero po zatwierdzeniu ceny."
            },
            {
              "language": "ro",
              "text": "Comanda către furnizor este trimisă din ERP doar după aprobarea prețului."
            },
            {
              "language": "ru",
              "text": "Заказ поставщику отправляется из ERP только после утверждения цены."
            },
            {
              "language": "sq",
              "text": "Porosia ndaj furnitorit dërgohet nga ERP vetëm pasi çmimi të miratohet."
            },
            {
              "language": "tr",
              "text": "Tedarikçi siparişi ERP’den ancak fiyat onaylandıktan sonra gönderilir."
            }
          ]
        },
        {
          "baseText": "Der Lieferant hat die Lieferantenbestellung bestätigt, aber den Termin um zwei Tage verschoben.",
          "translations": [
            {
              "language": "ar",
              "text": "أكد المورد طلب الشراء لكنه أجل الموعد يومين."
            },
            {
              "language": "ckb",
              "text": "دابینکەر داواکاریی کڕینی پشتڕاست کردەوە، بەڵام کاتەکەی دوو ڕۆژ دواخست."
            },
            {
              "language": "en",
              "text": "The supplier confirmed the purchase order but postponed the date by two days."
            },
            {
              "language": "fa",
              "text": "تأمین‌کننده سفارش خرید را تأیید کرد، اما تاریخ را دو روز عقب انداخت."
            },
            {
              "language": "kmr",
              "text": "Dabînker fermana kirînê piştrast kir, lê demê du roj paş xist."
            },
            {
              "language": "pl",
              "text": "Dostawca potwierdził zamówienie, ale przesunął termin o dwa dni."
            },
            {
              "language": "ro",
              "text": "Furnizorul a confirmat comanda, dar a amânat termenul cu două zile."
            },
            {
              "language": "ru",
              "text": "Поставщик подтвердил заказ, но перенес срок на два дня."
            },
            {
              "language": "sq",
              "text": "Furnitori e konfirmoi porosinë, por e shtyu afatin me dy ditë."
            },
            {
              "language": "tr",
              "text": "Tedarikçi siparişi onayladı, ancak tarihi iki gün erteledi."
            }
          ]
        }
      ]
    },
