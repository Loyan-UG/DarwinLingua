        },
        {
          "language": "ckb",
          "text": "فاکتورەی دابینکەر"
        },
        {
          "language": "en",
          "text": "supplier invoice"
        },
        {
          "language": "fa",
          "text": "فاکتور تأمین‌کننده"
        },
        {
          "language": "kmr",
          "text": "fatûreya dabînker"
        },
        {
          "language": "pl",
          "text": "faktura dostawcy"
        },
        {
          "language": "ro",
          "text": "factură furnizor"
        },
        {
          "language": "ru",
