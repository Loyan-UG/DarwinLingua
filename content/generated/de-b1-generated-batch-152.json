  "entries": [
    {
      "word": "wesentlich",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "we-sent-lich",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective/adverb; means essential or significantly"
      ],
      "collocations": [
        {
          "text": "wesentlich wichtiger",
          "meaning": "significantly more important"
        },
        {
          "text": "ein wesentlicher Punkt",
          "meaning": "an essential point"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Wesen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أساسي؛ مهم؛ بشكل كبير"
        },
        {
          "language": "ckb",
          "text": "بنەڕەتی؛ گرنگ؛ بە شێوەیەکی بەرچاو"
        },
        {
          "language": "en",
          "text": "essential; significant; substantially"
        },
        {
          "language": "fa",
          "text": "اساسی؛ مهم؛ به‌طور قابل توجه"
        },
        {
          "language": "kmr",
          "text": "bingehîn; girîng; bi awayekî berbiçav"
        },
        {
          "language": "pl",
          "text": "istotny; zasadniczy; znacznie"
        },
        {
          "language": "ro",
          "text": "esențial; semnificativ"
        },
        {
          "language": "ru",
          "text": "существенный; значительно"
        },
        {
          "language": "sq",
          "text": "thelbësor; i rëndësishëm; dukshëm"
        },
        {
          "language": "tr",
          "text": "esas; önemli; belirgin şekilde"
        }
      ],
      "examples": [
        {
          "baseText": "Ein wesentlicher Punkt im Vertrag ist die Kündigungsfrist.",
          "translations": [
            {
              "language": "ar",
              "text": "نقطة أساسية في العقد هي مهلة الإلغاء."
            },
            {
              "language": "ckb",
              "text": "خاڵێکی بنەڕەتی لە گرێبەستەکەدا وادەی هەڵوەشاندنەوەیە."
            },
            {
              "language": "en",
              "text": "An essential point in the contract is the notice period."
            },
            {
              "language": "fa",
              "text": "یک نکته اساسی در قرارداد، مهلت فسخ است."
            },
            {
              "language": "kmr",
              "text": "Xalekî bingehîn di peymanê de dema betalkirinê ye."
            },
            {
              "language": "pl",
              "text": "Istotnym punktem w umowie jest okres wypowiedzenia."
            },
            {
              "language": "ro",
              "text": "Un punct esențial în contract este termenul de reziliere."
            },
            {
              "language": "ru",
              "text": "Существенный пункт договора — срок уведомления."
            },
            {
              "language": "sq",
              "text": "Një pikë thelbësore në kontratë është afati i anulimit."
            },
            {
              "language": "tr",
              "text": "Sözleşmedeki önemli bir nokta fesih süresidir."
            }
          ]
        },
        {
          "baseText": "Mit der neuen Lösung arbeitet das Team wesentlich schneller.",
          "translations": [
            {
              "language": "ar",
              "text": "بالحل الجديد يعمل الفريق بسرعة أكبر بكثير."
            },
            {
              "language": "ckb",
              "text": "بە چارەسەری نوێ تیمەکە بە شێوەیەکی بەرچاو خێراتر کار دەکات."
            },
            {
              "language": "en",
              "text": "With the new solution, the team works significantly faster."
            },
            {
              "language": "fa",
              "text": "با راه‌حل جدید، تیم به‌طور قابل توجهی سریع‌تر کار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Bi çareseriya nû tîm bi awayekî berbiçav lezgîntir dixebite."
            },
            {
              "language": "pl",
              "text": "Dzięki nowemu rozwiązaniu zespół pracuje znacznie szybciej."
            },
            {
              "language": "ro",
              "text": "Cu noua soluție, echipa lucrează mult mai repede."
            },
            {
              "language": "ru",
              "text": "С новым решением команда работает значительно быстрее."
            },
            {
              "language": "sq",
              "text": "Me zgjidhjen e re ekipi punon dukshëm më shpejt."
            },
            {
              "language": "tr",
              "text": "Yeni çözümle ekip belirgin şekilde daha hızlı çalışıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "widersprechen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "widersprechen",
      "pronunciationIpa": null,
      "syllableBreak": "wi-der-spre-chen",
      "topics": [
        "business-communication",
        "law-and-compliance",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb with dative: widerspricht, widersprach, hat widersprochen"
      ],
      "collocations": [
        {
          "text": "einer Aussage widersprechen",
          "meaning": "to contradict a statement"
        },
        {
          "text": "dem Bescheid widersprechen",
          "meaning": "to object to a decision"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Widerspruch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعارض؛ يناقض"
        },
        {
          "language": "ckb",
          "text": "دژایەتی کردن؛ پێچەوانە قسەکردن"
        },
        {
          "language": "en",
          "text": "to contradict; to object"
        },
        {
          "language": "fa",
          "text": "مخالفت کردن؛ تناقض داشتن"
        },
        {
          "language": "kmr",
          "text": "li dijî gotin; nerazî bûn"
        },
        {
          "language": "pl",
          "text": "sprzeciwiać się; zaprzeczać"
        },
        {
          "language": "ro",
          "text": "a contrazice; a se opune"
        },
        {
          "language": "ru",
          "text": "возражать; противоречить"
        },
        {
          "language": "sq",
          "text": "të kundërshtosh; të biesh ndesh"
        },
        {
          "language": "tr",
          "text": "itiraz etmek; çelişmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte Ihnen nicht widersprechen, aber die Zahlen sehen anders aus.",
          "translations": [
            {
              "language": "ar",
              "text": "لا أريد أن أعترض عليك، لكن الأرقام تبدو مختلفة."
            },
            {
              "language": "ckb",
              "text": "نامەوێت دژایەتیتان بکەم، بەڵام ژمارەکان بە شێوەیەکی تر دیارن."
            },
            {
              "language": "en",
              "text": "I do not want to contradict you, but the figures look different."
            },
            {
              "language": "fa",
              "text": "نمی‌خواهم با شما مخالفت کنم، اما اعداد چیز دیگری نشان می‌دهند."
            },
            {
              "language": "kmr",
              "text": "Ez naxwazim li dijî we bibêjim, lê hejmar cuda xuya dikin."
            },
            {
              "language": "pl",
              "text": "Nie chcę Panu/Pani zaprzeczać, ale liczby wyglądają inaczej."
            },
            {
              "language": "ro",
              "text": "Nu vreau să vă contrazic, dar cifrele arată altfel."
            },
            {
              "language": "ru",
              "text": "Я не хочу вам возражать, но цифры выглядят иначе."
            },
            {
              "language": "sq",
              "text": "Nuk dua t’ju kundërshtoj, por shifrat duken ndryshe."
            },
            {
              "language": "tr",
              "text": "Size karşı çıkmak istemem ama rakamlar farklı görünüyor."
            }
          ]
        },
        {
          "baseText": "Sie kann dem Bescheid innerhalb eines Monats widersprechen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنها الاعتراض على القرار خلال شهر واحد."
            },
            {
              "language": "ckb",
              "text": "ئەو دەتوانێت لە ماوەی مانگێکدا دژایەتی بڕیارەکە بکات."
            },
            {
              "language": "en",
              "text": "She can object to the decision within one month."
            },
            {
              "language": "fa",
              "text": "او می‌تواند ظرف یک ماه به این تصمیم اعتراض کند."
            },
            {
              "language": "kmr",
              "text": "Ew dikare di nav mehekê de li dijî biryarê nerazî bibe."
            },
            {
              "language": "pl",
              "text": "Może wnieść sprzeciw wobec decyzji w ciągu miesiąca."
            },
            {
              "language": "ro",
              "text": "Ea poate contesta decizia în termen de o lună."
            },
            {
              "language": "ru",
              "text": "Она может оспорить решение в течение месяца."
            },
            {
              "language": "sq",
              "text": "Ajo mund ta kundërshtojë vendimin brenda një muaji."
            },
            {
              "language": "tr",
              "text": "Karara bir ay içinde itiraz edebilir."
            }
          ]
        }
      ]
    },
