      "meanings": [
        {
          "language": "ar",
          "text": "اعتراض؛ تناقض"
        },
        {
          "language": "ckb",
          "text": "ناڕەزایی؛ دژایەتی؛ پێچەوانەیی"
        },
        {
          "language": "en",
          "text": "objection; contradiction"
        },
        {
          "language": "fa",
          "text": "اعتراض؛ تناقض"
        },
        {
          "language": "kmr",
          "text": "nerazîbûn; dijberî; nakokî"
        },
        {
          "language": "pl",
          "text": "sprzeciw; sprzeczność"
        },
        {
          "language": "ro",
          "text": "contestație; contradicție"
        },
        {
          "language": "ru",
          "text": "возражение; противоречие"
        },
        {
          "language": "sq",
          "text": "kundërshtim; kontradiktë"
        },
        {
          "language": "tr",
          "text": "itiraz; çelişki"
        }
      ],
      "examples": [
        {
          "baseText": "Der Widerspruch muss schriftlich bei der Behörde eingehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن يصل الاعتراض كتابيًا إلى الجهة الإدارية."
            },
            {
              "language": "ckb",
              "text": "ناڕەزاییەکە دەبێت بە نووسراوە بگات بە دەزگاکە."
            },
            {
              "language": "en",
              "text": "The objection must be received by the authority in writing."
            },
            {
              "language": "fa",
              "text": "اعتراض باید به‌صورت کتبی به اداره برسد."
            },
            {
              "language": "kmr",
              "text": "Nerazîbûn divê bi nivîskî bigihêje desthilatdariyê."
            },
            {
              "language": "pl",
              "text": "Sprzeciw musi wpłynąć do urzędu w formie pisemnej."
            },
            {
              "language": "ro",
              "text": "Contestația trebuie să ajungă în scris la autoritate."
            },
            {
              "language": "ru",
              "text": "Возражение должно поступить в орган власти в письменной форме."
            },
            {
              "language": "sq",
              "text": "Kundërshtimi duhet të mbërrijë me shkrim te autoriteti."
            },
            {
              "language": "tr",
              "text": "İtiraz kuruma yazılı olarak ulaşmalıdır."
            }
          ]
        },
        {
          "baseText": "Zwischen den beiden Aussagen gibt es einen klaren Widerspruch.",
          "translations": [
            {
              "language": "ar",
              "text": "يوجد تناقض واضح بين التصريحين."
            },
            {
              "language": "ckb",
              "text": "لە نێوان هەردوو وتەکەدا پێچەوانەییەکی ڕوون هەیە."
