      "word": "das Zeugnis",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Zeugnisse",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Zeug-nis",
      "topics": [
        "education-and-training",
        "documents-and-administration",
        "work-and-jobs"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
