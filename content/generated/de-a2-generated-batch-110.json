      ],
      "collocations": [
        {
          "text": "an der Tür ziehen",
          "meaning": "to pull the door"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "umziehen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسحب؛ ينتقل"
        },
        {
          "language": "ckb",
          "text": "ڕادەکێشێت؛ دەچێتە شوێنێکی تر"
        },
        {
          "language": "en",
          "text": "to pull; to move"
        },
        {
          "language": "fa",
          "text": "کشیدن؛ نقل مکان کردن"
        },
        {
          "language": "kmr",
          "text": "kişandin; bar kirin"
        },
        {
          "language": "pl",
          "text": "ciągnąć; przeprowadzać się"
        },
        {
          "language": "ro",
          "text": "a trage; a se muta"
        },
        {
          "language": "ru",
          "text": "тянуть; переезжать"
        },
        {
          "language": "sq",
          "text": "të tërheqësh; të shpërngulesh"
        },
        {
          "language": "tr",
          "text": "çekmek; taşınmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte ziehen Sie an der Tür, nicht drücken.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى سحب الباب، لا دفعه."
            },
            {
              "language": "ckb",
              "text": "تکایە دەرگاکە ڕابکێشن، پاڵی پێوە مەنێن."
            },
            {
              "language": "en",
              "text": "Please pull the door, do not push."
            },
            {
              "language": "fa",
              "text": "لطفاً در را بکشید، هل ندهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe derî bikişînin, ne paş bidin."
            },
            {
              "language": "pl",
              "text": "Proszę ciągnąć drzwi, nie pchać."
            },
            {
              "language": "ro",
              "text": "Vă rog să trageți de ușă, nu să împingeți."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, тяните дверь, не толкайте."
            },
            {
              "language": "sq",
              "text": "Ju lutem tërhiqeni derën, mos e shtyni."
            },
            {
              "language": "tr",
              "text": "Lütfen kapıyı çekin, itmeyin."
            }
          ]
        },
        {
          "baseText": "Wir ziehen im Mai nach Köln.",
          "translations": [
            {
              "language": "ar",
              "text": "سننتقل في مايو إلى كولونيا."
            },
            {
              "language": "ckb",
              "text": "لە مانگی ئایاردا دەچینە کۆڵن."
            },
            {
              "language": "en",
              "text": "We are moving to Cologne in May."
            },
            {
              "language": "fa",
              "text": "ما در ماه مه به کلن نقل مکان می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em di gulanê de diçin Kölnê."
            },
            {
              "language": "pl",
              "text": "W maju przeprowadzamy się do Kolonii."
            },
            {
              "language": "ro",
              "text": "Ne mutăm la Köln în mai."
            },
            {
              "language": "ru",
              "text": "В мае мы переезжаем в Кёльн."
            },
            {
              "language": "sq",
              "text": "Në maj shpërngulemi në Këln."
            },
            {
              "language": "tr",
              "text": "Mayısta Köln’e taşınıyoruz."
            }
          ]
        }
      ]
    },
