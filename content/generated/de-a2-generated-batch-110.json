      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "ein Zeugnis bekommen",
          "meaning": "to receive a certificate/report card"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شهادة؛ كشف علامات"
        },
        {
          "language": "ckb",
          "text": "بڕوانامە؛ کارنامە"
        },
        {
          "language": "en",
          "text": "certificate; report card"
        },
        {
          "language": "fa",
          "text": "گواهی؛ کارنامه"
        },
        {
          "language": "kmr",
          "text": "belge; şahadetname"
        },
        {
          "language": "pl",
          "text": "świadectwo; zaświadczenie"
        },
        {
          "language": "ro",
          "text": "certificat; foaie matricolă"
        },
        {
          "language": "ru",
          "text": "свидетельство; аттестат"
        },
        {
          "language": "sq",
          "text": "certifikatë; dëftesë"
        },
        {
          "language": "tr",
          "text": "karne; sertifika"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte bringen Sie Ihr letztes Zeugnis mit.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إحضار آخر شهادة لكم."
            },
            {
              "language": "ckb",
              "text": "تکایە دوا بڕوانامەکەتان لەگەڵ خۆتان بهێنن."
            },
            {
              "language": "en",
              "text": "Please bring your latest certificate."
            },
            {
              "language": "fa",
              "text": "لطفاً آخرین کارنامه خود را همراه بیاورید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeya xwe ya dawî bînin."
            },
            {
              "language": "pl",
              "text": "Proszę przynieść ostatnie świadectwo."
            },
            {
              "language": "ro",
              "text": "Vă rog să aduceți ultimul certificat."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, принесите последний аттестат."
            },
            {
              "language": "sq",
              "text": "Ju lutem sillni certifikatën tuaj të fundit."
            },
            {
              "language": "tr",
              "text": "Lütfen son karnenizi getirin."
            }
          ]
        },
        {
          "baseText": "Mein Sohn bekommt morgen sein Zeugnis.",
          "translations": [
            {
              "language": "ar",
              "text": "سيحصل ابني غداً على شهادته."
            },
            {
              "language": "ckb",
              "text": "کوڕەکەم سبەی کارنامەکەی وەردەگرێت."
            },
            {
              "language": "en",
              "text": "My son gets his report card tomorrow."
            },
            {
              "language": "fa",
              "text": "پسرم فردا کارنامه‌اش را می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Kurê min sibê belgeya xwe werdigire."
            },
            {
              "language": "pl",
              "text": "Mój syn dostanie jutro świadectwo."
            },
            {
              "language": "ro",
              "text": "Fiul meu primește mâine foaia matricolă."
            },
            {
              "language": "ru",
              "text": "Мой сын завтра получит табель."
            },
            {
              "language": "sq",
              "text": "Djali im merr nesër dëftesën."
            },
            {
              "language": "tr",
              "text": "Oğlum yarın karnesini alacak."
            }
          ]
        }
      ]
    },
    {
      "word": "ziehen",
