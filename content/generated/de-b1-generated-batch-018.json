  "entries": [
    {
      "word": "aufschreiben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufschreiben",
      "pronunciationIpa": null,
      "syllableBreak": "auf-schrei-ben",
      "topics": [
        "documents-and-administration",
        "education-and-training",
        "work-and-jobs"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "documents",
        "training",
        "administration"
      ],
      "grammarNotes": [
        "separable verb",
        "means to write something down"
      ],
      "collocations": [
        {
          "text": "eine Nummer aufschreiben",
          "meaning": "to write down a number"
        },
        {
          "text": "Notizen aufschreiben",
          "meaning": "to write down notes"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schreiben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدوّن؛ يكتب"
        },
        {
          "language": "ckb",
          "text": "نووسینەوە؛ تۆمارکردن"
        },
        {
          "language": "en",
          "text": "to write down"
        },
        {
          "language": "fa",
          "text": "یادداشت کردن؛ نوشتن"
        },
        {
          "language": "kmr",
          "text": "nivîsandin; tomar kirin"
        },
        {
          "language": "pl",
          "text": "zapisać"
        },
        {
          "language": "ro",
          "text": "a nota; a scrie"
        },
        {
          "language": "ru",
          "text": "записать"
        },
        {
          "language": "sq",
          "text": "të shënosh; të shkruash"
        },
        {
          "language": "tr",
          "text": "not almak; yazmak"
        }
      ],
      "examples": [
        {
          "baseText": "Schreiben Sie bitte die Kundennummer auf, bevor Sie im System suchen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تدوين رقم العميل قبل البحث في النظام."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش گەڕان لە سیستەمدا ژمارەی کڕیارەکە بنووسنەوە."
            },
            {
              "language": "en",
              "text": "Please write down the customer number before searching in the system."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از جستجو در سیستم، شماره مشتری را یادداشت کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî lêgerînê di pergalê de hejmara xerîdar binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę zapisać numer klienta przed wyszukiwaniem w systemie."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să notați numărul clientului înainte de a căuta în sistem."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, запишите номер клиента перед поиском в системе."
            },
            {
              "language": "sq",
              "text": "Ju lutem shënoni numrin e klientit para se të kërkoni në sistem."
            },
            {
              "language": "tr",
              "text": "Sistemde arama yapmadan önce lütfen müşteri numarasını yazın."
            }
          ]
        },
        {
          "baseText": "Ich schreibe mir die Adresse auf, damit ich sie nicht vergesse.",
          "translations": [
            {
              "language": "ar",
              "text": "سأدوّن العنوان حتى لا أنساه."
            },
            {
              "language": "ckb",
              "text": "ناونیشانەکە بۆ خۆم دەنووسمەوە بۆ ئەوەی لەبیرم نەچێت."
            },
            {
              "language": "en",
              "text": "I am writing down the address so I do not forget it."
            },
            {
              "language": "fa",
              "text": "آدرس را یادداشت می‌کنم تا فراموشش نکنم."
            },
            {
              "language": "kmr",
              "text": "Ez navnîşanê dinivîsim da ku ji bîr nekim."
            },
            {
              "language": "pl",
              "text": "Zapisuję adres, żeby go nie zapomnieć."
            },
            {
              "language": "ro",
              "text": "Îmi notez adresa ca să nu o uit."
            },
            {
              "language": "ru",
              "text": "Я записываю адрес, чтобы его не забыть."
            },
            {
              "language": "sq",
              "text": "Po e shënoj adresën që të mos e harroj."
            },
            {
              "language": "tr",
              "text": "Unutmamak için adresi yazıyorum."
            }
          ]
        }
      ]
    },
