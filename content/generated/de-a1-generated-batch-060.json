              "language": "sq",
              "text": "Fëmijët qeshin shumë."
            },
            {
              "language": "tr",
              "text": "Çocuklar çok gülüyor."
            }
          ]
        },
        {
          "baseText": "Wir lachen über den Film.",
          "translations": [
            {
              "language": "ar",
              "text": "نضحك على الفيلم."
            },
            {
              "language": "ckb",
              "text": "ئێمە بە فیلمەکە پێدەکەنین."
            },
            {
              "language": "en",
              "text": "We laugh about the film."
            },
            {
              "language": "fa",
              "text": "ما به فیلم می‌خندیم."
            },
            {
              "language": "kmr",
              "text": "Em li ser fîlmê dikenin."
            },
            {
              "language": "pl",
              "text": "Śmiejemy się z filmu."
            },
            {
              "language": "ro",
              "text": "Râdem de film."
            },
            {
              "language": "ru",
              "text": "Мы смеемся над фильмом."
            },
            {
              "language": "sq",
              "text": "Qeshim me filmin."
            },
            {
              "language": "tr",
