      "examples": [
        {
          "baseText": "Die Kinder lachen viel.",
          "translations": [
            {
              "language": "ar",
              "text": "الأطفال يضحكون كثيراً."
            },
            {
              "language": "ckb",
              "text": "منداڵەکان زۆر پێدەکەنن."
            },
            {
              "language": "en",
              "text": "The children laugh a lot."
            },
            {
              "language": "fa",
              "text": "بچه‌ها زیاد می‌خندند."
            },
            {
              "language": "kmr",
              "text": "Zarok gelek dikenin."
            },
            {
              "language": "pl",
              "text": "Dzieci dużo się śmieją."
            },
