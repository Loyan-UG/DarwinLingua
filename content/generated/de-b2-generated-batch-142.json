      "examples": [
        {
          "baseText": "Die Stadt will die Bodenversiegelung bei neuen Parkplätzen deutlich reduzieren.",
          "translations": [
            { "language": "ar", "text": "تريد المدينة تقليل ختم التربة بوضوح في مواقف السيارات الجديدة." },
            { "language": "ckb", "text": "شارەوانی دەیەوێت داپۆشینی زەوی لە پارکینگە نوێیەکان بە ڕوونی کەم بکاتەوە." },
            { "language": "en", "text": "The city wants to significantly reduce soil sealing in new parking areas." },
            { "language": "fa", "text": "شهرداری می‌خواهد پوشش نفوذناپذیر خاک را در پارکینگ‌های جدید به‌طور محسوسی کاهش دهد." },
            { "language": "kmr", "text": "Bajar dixwaze girtina axê li parkîngên nû bi awayekî eşkere kêm bike." },
            { "language": "pl", "text": "Miasto chce wyraźnie zmniejszyć uszczelnienie gleby przy nowych parkingach." },
            { "language": "ro", "text": "Orașul vrea să reducă semnificativ sigilarea solului la noile parcări." },
            { "language": "ru", "text": "Город хочет заметно сократить запечатывание почвы на новых парковках." },
            { "language": "sq", "text": "Qyteti dëshiron të ulë ndjeshëm vulosjen e tokës në parkingjet e reja." },
            { "language": "tr", "text": "Şehir, yeni otoparklarda toprak geçirimsizleştirmeyi belirgin şekilde azaltmak istiyor." }
          ]
        },
        {
          "baseText": "Im Umweltbericht wird die Bodenversiegelung als Risiko für Starkregen genannt.",
          "translations": [
            { "language": "ar", "text": "يذكر التقرير البيئي ختم التربة كخطر عند الأمطار الغزيرة." },
            { "language": "ckb", "text": "لە ڕاپۆرتی ژینگەدا داپۆشینی زەوی وەک مەترسی بۆ بارانی زۆر ناودەبرێت." },
            { "language": "en", "text": "The environmental report identifies soil sealing as a risk during heavy rain." },
            { "language": "fa", "text": "در گزارش محیط‌زیست، پوشاندن خاک به‌عنوان ریسک هنگام باران شدید ذکر شده است." },
            { "language": "kmr", "text": "Di rapora jîngehê de girtina axê wek rîskek di barana giran de tê gotin." },
            { "language": "pl", "text": "W raporcie środowiskowym uszczelnienie gleby wskazano jako ryzyko przy ulewnych deszczach." },
            { "language": "ro", "text": "Raportul de mediu menționează sigilarea solului ca risc la ploi torențiale." },
            { "language": "ru", "text": "В экологическом отчете запечатывание почвы названо риском при сильных дождях." },
            { "language": "sq", "text": "Në raportin mjedisor, vulosja e tokës përmendet si rrezik gjatë reshjeve të forta." },
            { "language": "tr", "text": "Çevre raporunda toprak geçirimsizleştirme, şiddetli yağmur için risk olarak belirtiliyor." }
          ]
