          "text": "das richtige Werkzeug benutzen",
          "meaning": "to use the right tool"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Werk",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أداة؛ عدة"
        },
        {
          "language": "ckb",
          "text": "ئامراز؛ کەرەستەی کار"
        },
        {
          "language": "en",
          "text": "tool"
        },
        {
          "language": "fa",
          "text": "ابزار"
        },
        {
          "language": "kmr",
          "text": "amûr; alav"
        },
        {
          "language": "pl",
          "text": "narzędzie"
        },
        {
          "language": "ro",
          "text": "unealtă; instrument"
        },
        {
          "language": "ru",
          "text": "инструмент"
        },
        {
          "language": "sq",
          "text": "vegël; mjet pune"
        },
        {
          "language": "tr",
          "text": "alet"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Reparatur brauchen wir gutes Werkzeug.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج إلى أدوات جيدة للإصلاح."
            },
            {
              "language": "ckb",
              "text": "بۆ چاککردنەوەکە پێویستمان بە ئامرازی باش هەیە."
            },
            {
              "language": "en",
              "text": "We need good tools for the repair."
            },
            {
              "language": "fa",
              "text": "برای تعمیر به ابزار خوب نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo tamîrê em hewceyê amûrên baş in."
            },
            {
              "language": "pl",
              "text": "Do naprawy potrzebujemy dobrych narzędzi."
            },
            {
              "language": "ro",
              "text": "Pentru reparație avem nevoie de unelte bune."
            },
            {
              "language": "ru",
              "text": "Для ремонта нам нужны хорошие инструменты."
            },
            {
              "language": "sq",
              "text": "Për riparimin na duhen vegla të mira."
            },
            {
              "language": "tr",
              "text": "Tamir için iyi aletlere ihtiyacımız var."
            }
          ]
        },
        {
          "baseText": "Bitte legen Sie das Werkzeug nach der Arbeit zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إعادة الأداة بعد العمل."
            },
            {
              "language": "ckb",
              "text": "تکایە دوای کار ئامرازەکە بگەڕێننەوە."
            },
            {
              "language": "en",
              "text": "Please put the tool back after work."
            },
            {
              "language": "fa",
              "text": "لطفاً بعد از کار ابزار را سر جایش بگذارید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe piştî kar amûrê vegerînin cihê xwe."
            },
            {
              "language": "pl",
              "text": "Proszę odłożyć narzędzie po pracy."
            },
            {
              "language": "ro",
              "text": "Vă rog să puneți unealta la loc după lucru."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, положите инструмент обратно после работы."
            },
            {
              "language": "sq",
              "text": "Ju lutem vendoseni veglën në vend pas punës."
            },
            {
              "language": "tr",
              "text": "Lütfen işten sonra aleti yerine koyun."
            }
          ]
        }
      ]
    },
    {
      "word": "wiedergeben",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "wiedergeben",
      "pronunciationIpa": null,
      "syllableBreak": "wie-der-ge-ben",
      "topics": [
        "education-and-training",
        "culture-and-media",
        "technology-and-it"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable irregular verb: gibt wieder, gab wieder, hat wiedergegeben"
      ],
      "collocations": [
        {
          "text": "den Inhalt wiedergeben",
          "meaning": "to reproduce/summarize the content"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Wiedergabe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعيد عرض؛ يلخص"
        },
        {
          "language": "ckb",
          "text": "دووبارە دەردەخات؛ کورت دەگێڕێتەوە"
        },
        {
          "language": "en",
          "text": "to reproduce; to play back; to summarize"
        },
        {
          "language": "fa",
          "text": "بازگو کردن؛ پخش کردن"
        },
        {
          "language": "kmr",
          "text": "dubare pêşkêş kirin; kurt vegotin"
        },
        {
          "language": "pl",
          "text": "odtwarzać; streszczać"
        },
        {
          "language": "ro",
          "text": "a reda; a reproduce"
        },
        {
          "language": "ru",
          "text": "воспроизводить; передавать"
        },
        {
          "language": "sq",
          "text": "të riprodhosh; të përmbledhësh"
        },
        {
          "language": "tr",
          "text": "aktarmak; oynatmak; özetlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du den Text kurz wiedergeben?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك تلخيص النص باختصار؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت دەقەکە بە کورتی بگێڕیتەوە؟"
            },
            {
              "language": "en",
              "text": "Can you briefly summarize the text?"
            },
            {
              "language": "fa",
              "text": "می‌توانی متن را کوتاه بازگو کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî nivîsê bi kurtî vegêrî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz krótko streścić tekst?"
            },
            {
              "language": "ro",
              "text": "Poți reda pe scurt textul?"
            },
            {
              "language": "ru",
              "text": "Можешь кратко передать текст?"
            },
            {
              "language": "sq",
              "text": "A mund ta përmbledhësh shkurt tekstin?"
            },
            {
              "language": "tr",
              "text": "Metni kısaca özetleyebilir misin?"
            }
          ]
        },
        {
          "baseText": "Das Gerät kann die Aufnahme nicht wiedergeben.",
          "translations": [
            {
              "language": "ar",
              "text": "الجهاز لا يستطيع تشغيل التسجيل."
            },
            {
              "language": "ckb",
              "text": "ئامێرەکە ناتوانێت تۆمارەکە پخش بکات."
            },
            {
              "language": "en",
              "text": "The device cannot play back the recording."
            },
            {
              "language": "fa",
              "text": "دستگاه نمی‌تواند ضبط را پخش کند."
            },
            {
              "language": "kmr",
              "text": "Amûr nikare tomarkirinê dubare bilîze."
            },
            {
              "language": "pl",
              "text": "Urządzenie nie może odtworzyć nagrania."
            },
            {
              "language": "ro",
              "text": "Aparatul nu poate reda înregistrarea."
            },
            {
              "language": "ru",
              "text": "Устройство не может воспроизвести запись."
            },
            {
              "language": "sq",
              "text": "Pajisja nuk mund ta riprodhojë regjistrimin."
            },
            {
              "language": "tr",
              "text": "Cihaz kaydı oynatamıyor."
            }
          ]
        }
      ]
    },
