      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عاصف؛ كثير الرياح"
        },
        {
          "language": "ckb",
          "text": "باخەڵ؛ بادی"
        },
        {
          "language": "en",
          "text": "windy"
        },
        {
          "language": "fa",
          "text": "بادخیز؛ بادی"
        },
        {
          "language": "kmr",
          "text": "bayî; bi ba"
        },
        {
          "language": "pl",
          "text": "wietrzny"
        },
        {
          "language": "ro",
          "text": "vântos"
        },
        {
          "language": "ru",
          "text": "ветреный"
        },
        {
          "language": "sq",
          "text": "me erë"
        },
        {
          "language": "tr",
          "text": "rüzgarlı"
        }
      ],
      "examples": [
        {
          "baseText": "Heute ist es sehr windig.",
          "translations": [
            {
              "language": "ar",
              "text": "الجو اليوم عاصف جداً."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ زۆر بایە."
            },
            {
              "language": "en",
              "text": "It is very windy today."
            },
            {
              "language": "fa",
              "text": "امروز هوا خیلی بادی است."
            },
            {
              "language": "kmr",
              "text": "Îro hewa pir bayî ye."
            },
            {
              "language": "pl",
              "text": "Dzisiaj jest bardzo wietrznie."
            },
            {
              "language": "ro",
              "text": "Astăzi este foarte vântos."
            },
            {
              "language": "ru",
              "text": "Сегодня очень ветрено."
            },
            {
              "language": "sq",
              "text": "Sot është shumë me erë."
            },
            {
              "language": "tr",
              "text": "Bugün hava çok rüzgarlı."
            }
          ]
        },
        {
          "baseText": "Nimm eine Jacke mit, es wird windig.",
          "translations": [
            {
              "language": "ar",
              "text": "خذ سترة معك، سيصبح الجو عاصفاً."
            },
            {
              "language": "ckb",
              "text": "چاکەتێک لەگەڵ خۆت ببە، با دەبێت."
            },
            {
              "language": "en",
              "text": "Take a jacket with you; it will get windy."
            },
            {
              "language": "fa",
              "text": "یک کاپشن بردار، هوا بادی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Çaketekê bi xwe re bibe, hewa dê bayî bibe."
            },
            {
              "language": "pl",
              "text": "Weź kurtkę, będzie wietrznie."
            },
            {
              "language": "ro",
              "text": "Ia o jachetă, va fi vânt."
            },
            {
              "language": "ru",
              "text": "Возьми куртку, будет ветрено."
            },
            {
              "language": "sq",
              "text": "Merr një xhaketë, do të bëhet me erë."
            },
            {
              "language": "tr",
              "text": "Yanına bir ceket al, hava rüzgarlı olacak."
            }
          ]
        }
      ]
    },
