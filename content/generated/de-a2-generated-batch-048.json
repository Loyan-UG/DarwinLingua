      "examples": [
        {
          "baseText": "Ich mache meine Hausaufgabe nach dem Essen.",
          "translations": [
            {
              "language": "ar",
              "text": "أقوم بواجبي بعد الطعام."
            },
            {
              "language": "ckb",
              "text": "دوای خواردن ئەرکی ماڵەوەکەم دەکەم."
            },
            {
              "language": "en",
              "text": "I do my homework after eating."
            },
            {
              "language": "fa",
              "text": "بعد از غذا تکلیفم را انجام می‌دهم."
            },
            {
              "language": "kmr",
              "text": "Ez piştî xwarinê erkê mala xwe dikim."
            },
            {
              "language": "pl",
              "text": "Robię zadanie domowe po jedzeniu."
            },
            {
              "language": "ro",
              "text": "Îmi fac tema după masă."
            },
            {
              "language": "ru",
              "text": "Я делаю домашнее задание после еды."
            },
            {
              "language": "sq",
              "text": "E bëj detyrën e shtëpisë pas ushqimit."
            },
            {
              "language": "tr",
              "text": "Ödevimi yemekten sonra yapıyorum."
            }
          ]
        },
        {
          "baseText": "Die Hausaufgabe ist nicht schwer.",
          "translations": [
            {
              "language": "ar",
              "text": "الواجب المنزلي ليس صعباً."
            },
            {
              "language": "ckb",
              "text": "ئەرکی ماڵەوەکە قورس نییە."
            },
            {
              "language": "en",
              "text": "The homework is not difficult."
            },
            {
              "language": "fa",
              "text": "تکلیف سخت نیست."
            },
            {
              "language": "kmr",
              "text": "Erkê malê ne dijwar e."
            },
            {
              "language": "pl",
              "text": "Zadanie domowe nie jest trudne."
            },
            {
              "language": "ro",
              "text": "Tema nu este grea."
            },
            {
              "language": "ru",
              "text": "Домашнее задание не трудное."
            },
            {
              "language": "sq",
              "text": "Detyra e shtëpisë nuk është e vështirë."
