  "entries": [
    {
      "word": "die Belehrung",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Belehrungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-leh-rung",
      "topics": [
        "law-and-compliance",
        "documents-and-administration",
        "education-and-training"
      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; formal instruction, legal advisement, or didactic correction"
      ],
      "collocations": [
        {
          "text": "eine rechtliche Belehrung",
          "meaning": "a legal advisement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "belehren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إرشاد رسمي؛ تنبيه قانوني؛ توجيه تعليمي"
        },
        {
          "language": "ckb",
          "text": "ڕێنمایی فەرمی؛ ئاگادارکردنەوەی یاسایی؛ فێرکردن"
        },
        {
          "language": "en",
          "text": "instruction; legal advisement; formal explanation"
        },
        {
          "language": "fa",
          "text": "آموزش رسمی؛ تفهیم قانونی؛ تذکر آموزشی"
        },
        {
          "language": "kmr",
          "text": "rêberiya fermî; agahdariya hiqûqî; fêrkirin"
        },
        {
          "language": "pl",
          "text": "pouczenie; instrukcja prawna; objaśnienie"
        },
        {
          "language": "ro",
          "text": "instruire; informare legală; explicație formală"
        },
        {
          "language": "ru",
          "text": "разъяснение; правовое уведомление; наставление"
        },
        {
          "language": "sq",
          "text": "udhëzim; këshillim ligjor; shpjegim formal"
        },
        {
          "language": "tr",
          "text": "bilgilendirme; hukuki ihtar; resmi açıklama"
        }
      ],
      "examples": [
        {
          "baseText": "Vor der Unterschrift erhielt der Kunde eine Belehrung über sein Widerrufsrecht.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل التوقيع تلقى العميل إرشاداً حول حقه في التراجع."
            },
            {
              "language": "ckb",
              "text": "پێش واژۆکردن، کڕیارەکە ڕێنماییەکی دەربارەی مافی پاشگەزبوونەوەی وەرگرت."
            },
            {
              "language": "en",
              "text": "Before signing, the customer received an explanation of his right of withdrawal."
            },
            {
              "language": "fa",
              "text": "پیش از امضا، مشتری توضیحی درباره حق انصراف خود دریافت کرد."
            },
            {
              "language": "kmr",
              "text": "Berî îmzekirinê, xerîdar agahdariyek li ser mafê vekişînê wergirt."
            },
            {
              "language": "pl",
              "text": "Przed podpisaniem klient otrzymał pouczenie o prawie odstąpienia."
            },
            {
              "language": "ro",
              "text": "Înainte de semnare, clientul a primit o informare despre dreptul de retragere."
            },
            {
              "language": "ru",
              "text": "Перед подписанием клиент получил разъяснение о праве на отказ."
            },
            {
              "language": "sq",
              "text": "Para nënshkrimit, klienti mori një udhëzim për të drejtën e tërheqjes."
            },
            {
              "language": "tr",
              "text": "İmzadan önce müşteri cayma hakkı hakkında bilgilendirildi."
            }
          ]
        },
        {
          "baseText": "Ihre Belehrung klang sachlich, wurde von den Studierenden aber als herablassend empfunden.",
          "translations": [
            {
              "language": "ar",
              "text": "بدت توجيهاتها موضوعية، لكن الطلاب شعروا بها متعالية."
            },
            {
              "language": "ckb",
              "text": "ڕێنماییەکەی بابەتی دەنگیدا، بەڵام خوێندکاران وەک سووککردنەوە هەستیان پێکرد."
            },
            {
              "language": "en",
              "text": "Her instruction sounded factual, but the students perceived it as condescending."
            },
            {
              "language": "fa",
              "text": "تذکر او بی‌طرفانه به نظر می‌رسید، اما دانشجویان آن را تحقیرآمیز برداشت کردند."
            },
            {
              "language": "kmr",
              "text": "Rêberiya wê wek rastîn xuya kir, lê xwendekaran ew wek ji jor ve axaftin hest kir."
            },
            {
              "language": "pl",
              "text": "Jej pouczenie brzmiało rzeczowo, ale studenci odebrali je jako protekcjonalne."
            },
            {
              "language": "ro",
              "text": "Explicația ei suna obiectiv, dar studenții au perceput-o ca fiind condescendentă."
            },
            {
              "language": "ru",
              "text": "Её наставление звучало деловито, но студенты восприняли его как снисходительное."
            },
            {
              "language": "sq",
              "text": "Udhëzimi i saj dukej faktik, por studentët e perceptuan si përbuzës."
            },
            {
              "language": "tr",
              "text": "Açıklaması nesnel geliyordu, ancak öğrenciler bunu küçümseyici buldu."
            }
          ]
        }
      ]
    },
    {
      "word": "belobigen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "belobigen",
      "pronunciationIpa": null,
      "syllableBreak": "be-lo-bi-gen",
      "topics": [
        "human-resources",
        "work-and-jobs",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "transitive verb; belobigt, belobigte, hat belobigt; formal: to commend or praise officially"
      ],
      "collocations": [
        {
          "text": "jemanden offiziell belobigen",
          "meaning": "to officially commend someone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Belobigung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "loben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يثني رسمياً على؛ يمدح"
        },
        {
          "language": "ckb",
          "text": "بە فەرمی ستایش بکات؛ پێزانین بکات"
        },
        {
          "language": "en",
          "text": "to commend; to praise officially"
        },
        {
          "language": "fa",
          "text": "رسماً تقدیر کردن؛ ستودن"
        },
        {
          "language": "kmr",
          "text": "bi fermî pesn dan; pîroz kirin"
        },
        {
          "language": "pl",
          "text": "pochwalić oficjalnie; wyróżnić"
        },
        {
          "language": "ro",
          "text": "a lăuda oficial; a elogia"
        },
        {
          "language": "ru",
          "text": "официально похвалить; отметить"
        },
        {
          "language": "sq",
          "text": "të lavdërosh zyrtarisht; të përgëzosh"
        },
        {
          "language": "tr",
          "text": "resmen takdir etmek; övmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Mitarbeiterin wurde für ihren ruhigen Umgang mit einem eskalierten Kundenfall belobigt.",
          "translations": [
            {
              "language": "ar",
              "text": "أُثني على الموظفة بسبب تعاملها الهادئ مع حالة عميل تصاعدت."
            },
            {
              "language": "ckb",
              "text": "کارمەندەکە بۆ مامەڵەی ئارامی لەگەڵ کەیسی کڕیارێکی توندبووەوەدا ستایش کرا."
            },
            {
              "language": "en",
              "text": "The employee was commended for her calm handling of an escalated customer case."
            },
            {
              "language": "fa",
              "text": "از کارمند به‌خاطر برخورد آرامش با یک پرونده مشتری بحرانی تقدیر شد."
            },
            {
              "language": "kmr",
              "text": "Karmend ji bo rêvebirina aram a rewşa xerîdarekî aloztirbûyî hate pesindan."
            },
            {
              "language": "pl",
              "text": "Pracownicę wyróżniono za spokojne podejście do eskalowanej sprawy klienta."
            },
            {
              "language": "ro",
              "text": "Angajata a fost lăudată pentru gestionarea calmă a unui caz de client escaladat."
            },
            {
              "language": "ru",
              "text": "Сотрудницу отметили за спокойную работу с обострившимся клиентским случаем."
            },
            {
              "language": "sq",
              "text": "Punonjësja u përgëzua për trajtimin e qetë të një rasti klienti të përshkallëzuar."
            },
            {
              "language": "tr",
              "text": "Çalışan, tırmanan bir müşteri vakasını sakin yönetmesi nedeniyle takdir edildi."
            }
          ]
        },
        {
          "baseText": "Der Bürgermeister belobigte die freiwilligen Helfer nach dem Hochwasser öffentlich.",
          "translations": [
            {
              "language": "ar",
              "text": "أشاد العمدة علناً بالمتطوعين بعد الفيضان."
            },
            {
              "language": "ckb",
              "text": "شارەوان دوای لافاوەکە بە ئاشکرا ستایشی یارمەتیدەرە خۆبەخشەکانی کرد."
            },
            {
              "language": "en",
              "text": "The mayor publicly commended the volunteers after the flood."
            },
            {
              "language": "fa",
              "text": "شهردار پس از سیل به‌طور عمومی از داوطلبان تقدیر کرد."
            },
            {
              "language": "kmr",
              "text": "Şaredar piştî lehiyê bi eşkere alîkarên dilxwaz pesind kir."
            },
            {
              "language": "pl",
              "text": "Burmistrz publicznie pochwalił wolontariuszy po powodzi."
            },
            {
              "language": "ro",
              "text": "Primarul i-a elogiat public pe voluntari după inundație."
            },
            {
              "language": "ru",
              "text": "Мэр публично поблагодарил добровольцев после наводнения."
            },
            {
              "language": "sq",
              "text": "Kryetari i bashkisë i lavdëroi publikisht vullnetarët pas përmbytjes."
            },
            {
              "language": "tr",
              "text": "Belediye başkanı selden sonra gönüllüleri kamuoyu önünde takdir etti."
            }
          ]
        }
      ]
    },
