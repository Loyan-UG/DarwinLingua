      "examples": [
        {
          "baseText": "Der Transport ist im ERP-System geplant.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تخطيط النقل في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "گواستنەوەکە لە سیستەمی ERPدا پلاندانراوە."
            },
            {
              "language": "en",
              "text": "The transport is planned in the ERP system."
            },
            {
              "language": "fa",
              "text": "حمل‌ونقل در سیستم ERP برنامه‌ریزی شده است."
            },
            {
              "language": "kmr",
              "text": "Veguhastin di pergala ERP de hatiye plansazkirin."
            },
            {
              "language": "pl",
              "text": "Transport jest zaplanowany w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Transportul este planificat în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Транспортировка запланирована в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Transporti është planifikuar në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Taşıma ERP sisteminde planlandı."
            }
          ]
        },
        {
          "baseText": "Der Transport dauert zwei Tage.",
          "translations": [
            {
              "language": "ar",
              "text": "يستغرق النقل يومين."
            },
            {
              "language": "ckb",
              "text": "گواستنەوەکە دوو ڕۆژ دەخایەنێت."
            },
            {
              "language": "en",
              "text": "The transport takes two days."
            },
            {
              "language": "fa",
              "text": "حمل‌ونقل دو روز طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Veguhastin du roj diajo."
            },
            {
              "language": "pl",
              "text": "Transport trwa dwa dni."
            },
            {
              "language": "ro",
              "text": "Transportul durează două zile."
            },
            {
              "language": "ru",
              "text": "Транспортировка занимает два дня."
