          "language": "sq",
          "text": "grup gjaku"
        },
        {
          "language": "tr",
          "text": "kan grubu"
        }
      ],
      "examples": [
        {
          "baseText": "Kennen Sie Ihre Blutgruppe?",
          "translations": [
            {
              "language": "ar",
              "text": "هل تعرفون فصيلة دمكم؟"
            },
            {
              "language": "ckb",
              "text": "گرووپی خوێنی خۆتان دەزانن؟"
            },
            {
              "language": "en",
              "text": "Do you know your blood type?"
            },
            {
              "language": "fa",
              "text": "گروه خونی خود را می‌دانید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn koma xwîna xwe dizanin?"
            },
            {
              "language": "pl",
              "text": "Czy zna Pan/Pani swoją grupę krwi?"
            },
            {
              "language": "ro",
              "text": "Vă cunoașteți grupa sanguină?"
            },
            {
              "language": "ru",
              "text": "Вы знаете свою группу крови?"
            },
            {
              "language": "sq",
              "text": "A e dini grupin tuaj të gjakut?"
            },
            {
              "language": "tr",
              "text": "Kan grubunuzu biliyor musunuz?"
            }
          ]
        },
        {
          "baseText": "Die Blutgruppe steht im medizinischen Dokument.",
          "translations": [
            {
              "language": "ar",
              "text": "فصيلة الدم موجودة في الوثيقة الطبية."
            },
            {
              "language": "ckb",
              "text": "گرووپی خوێن لە بەڵگەنامەی پزیشکیدا نووسراوە."
            },
            {
              "language": "en",
              "text": "The blood type is written in the medical document."
            },
            {
              "language": "fa",
              "text": "گروه خونی در سند پزشکی نوشته شده است."
            },
            {
              "language": "kmr",
              "text": "Koma xwînê di belgeya bijîşkî de hatiye nivîsîn."
            },
            {
              "language": "pl",
              "text": "Grupa krwi jest wpisana w dokumencie medycznym."
            },
            {
              "language": "ro",
              "text": "Grupa sanguină este trecută în documentul medical."
            },
            {
              "language": "ru",
              "text": "Группа крови указана в медицинском документе."
            },
            {
              "language": "sq",
              "text": "Grupi i gjakut është shkruar në dokumentin mjekësor."
            },
            {
              "language": "tr",
              "text": "Kan grubu tıbbi belgede yazıyor."
            }
          ]
        }
      ]
    },
