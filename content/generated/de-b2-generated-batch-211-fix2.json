      "meanings": [
        {
          "language": "ar",
          "text": "موضوعي؛ غير متحيز"
        },
        {
          "language": "ckb",
          "text": "بابەتی؛ بێلایەن"
        },
        {
          "language": "en",
          "text": "objective; unbiased"
        },
        {
          "language": "fa",
          "text": "عینی؛ بی‌طرفانه"
        },
        {
          "language": "kmr",
          "text": "objektîf; bêalî"
        },
        {
          "language": "pl",
          "text": "obiektywny; bezstronny"
        },
        {
          "language": "ro",
          "text": "obiectiv; imparțial"
        },
        {
          "language": "ru",
          "text": "объективный; беспристрастный"
        },
        {
          "language": "sq",
          "text": "objektiv; i paanshëm"
        },
        {
          "language": "tr",
          "text": "nesnel; tarafsız"
        }
      ],
      "examples": [
        {
          "baseText": "Die Bewerbungen sollen nach objektiven Kriterien bewertet werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب تقييم طلبات التوظيف وفق معايير موضوعية."
            },
            {
              "language": "ckb",
              "text": "داواکارییەکانی کار دەبێ بەپێی پێوەری بابەتی هەڵسەنگێنرێن."
            },
            {
              "language": "en",
              "text": "The applications should be evaluated according to objective criteria."
            },
            {
              "language": "fa",
              "text": "درخواست‌های استخدام باید بر اساس معیارهای عینی ارزیابی شوند."
            },
            {
              "language": "kmr",
              "text": "Serlêdan divê li gor pîvanên objektîf werin nirxandin."
            },
            {
              "language": "pl",
              "text": "Aplikacje powinny być oceniane według obiektywnych kryteriów."
            },
            {
              "language": "ro",
              "text": "Candidaturile ar trebui evaluate după criterii obiective."
            },
            {
              "language": "ru",
              "text": "Заявки следует оценивать по объективным критериям."
            },
            {
              "language": "sq",
              "text": "Aplikimet duhet të vlerësohen sipas kritereve objektive."
            },
            {
              "language": "tr",
              "text": "Başvurular nesnel kriterlere göre değerlendirilmelidir."
            }
          ]
        },
        {
          "baseText": "Auch wenn sie enttäuscht war, blieb ihre Analyse der Situation erstaunlich objektiv.",
          "translations": [
            {
              "language": "ar",
              "text": "رغم أنها كانت محبطة، بقي تحليلها للوضع موضوعياً بشكل لافت."
            },
            {
              "language": "ckb",
              "text": "هەرچەندە دڵشکاو بوو، شیکردنەوەی دۆخەکەی بە شێوەیەکی سەرسوڕهێنەر بابەتی مایەوە."
            },
            {
              "language": "en",
              "text": "Even though she was disappointed, her analysis of the situation remained surprisingly objective."
            },
            {
              "language": "fa",
              "text": "با اینکه ناامید شده بود، تحلیلش از وضعیت به شکل عجیبی بی‌طرفانه باقی ماند."
            },
            {
              "language": "kmr",
              "text": "Her çend ew bêhêvî bû, analîza wê ya rewşê bi awayekî ecêb objektîf ma."
            },
            {
              "language": "pl",
              "text": "Choć była rozczarowana, jej analiza sytuacji pozostała zaskakująco obiektywna."
            },
            {
              "language": "ro",
              "text": "Deși era dezamăgită, analiza ei asupra situației a rămas surprinzător de obiectivă."
            },
            {
              "language": "ru",
              "text": "Хотя она была разочарована, ее анализ ситуации оставался удивительно объективным."
            },
            {
              "language": "sq",
              "text": "Edhe pse ishte e zhgënjyer, analiza e saj e situatës mbeti çuditërisht objektive."
            },
            {
              "language": "tr",
              "text": "Hayal kırıklığına uğramış olsa da durum analizi şaşırtıcı derecede nesnel kaldı."
            }
          ]
        }
      ]
    }
