  "entries": [
    {
      "word": "die Legitimation",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Legitimationen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Le-gi-ti-ma-ti-on",
      "topics": [
        "law-and-compliance",
        "public-services",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "academic",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "politische Legitimation gewinnen",
          "meaning": "to gain political legitimacy or justification"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "legitim",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "legitimieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إضفاء الشرعية؛ تبرير رسمي"
        },
        {
          "language": "ckb",
          "text": "ڕەوایەتی‌دان؛ پاساوکردنی فەرمی"
        },
        {
          "language": "en",
          "text": "legitimation; formal justification"
        },
        {
          "language": "fa",
          "text": "مشروعیت‌بخشی؛ توجیه رسمی"
        },
        {
          "language": "kmr",
          "text": "rewayetîdan; sedemkirina fermî"
        },
        {
          "language": "pl",
          "text": "legitymizacja; formalne uzasadnienie"
        },
        {
          "language": "ro",
          "text": "legitimare; justificare formală"
        },
        {
          "language": "ru",
          "text": "легитимация; официальное обоснование"
        },
        {
          "language": "sq",
          "text": "legjitimim; justifikim zyrtar"
        },
        {
          "language": "tr",
          "text": "meşrulaştırma; resmi gerekçelendirme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Legitimation der Maßnahme hängt davon ab, ob die Betroffenen transparent informiert wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "تعتمد مشروعية الإجراء على ما إذا كان المتضررون قد أُبلغوا بشفافية."
            },
            {
              "language": "ckb",
              "text": "ڕەوایەتی ڕێکارەکە پەیوەستە بەوەی ئایا پەیوەندیداران بە شێوەی ڕوون ئاگادار کراونەتەوە."
            },
            {
              "language": "en",
              "text": "The legitimation of the measure depends on whether those affected were informed transparently."
            },
            {
              "language": "fa",
              "text": "مشروعیت‌بخشی به این اقدام بستگی دارد به اینکه افراد درگیر شفاف اطلاع‌رسانی شده‌اند یا نه."
            },
            {
              "language": "kmr",
              "text": "Rewayetîdana tedbîrê girêdayî ye ka kesên bandor lêkirî bi zelalî hatine agahdarkirin an na."
            },
            {
              "language": "pl",
              "text": "Legitymizacja działania zależy od tego, czy osoby dotknięte zostały transparentnie poinformowane."
            },
            {
              "language": "ro",
              "text": "Legitimarea măsurii depinde de informarea transparentă a celor afectați."
            },
            {
              "language": "ru",
              "text": "Легитимация меры зависит от того, были ли затронутые лица прозрачно информированы."
            },
            {
              "language": "sq",
              "text": "Legjitimimi i masës varet nga fakti nëse të prekurit janë informuar në mënyrë transparente."
            },
            {
              "language": "tr",
              "text": "Önlemin meşrulaştırılması, etkilenen kişilerin şeffaf biçimde bilgilendirilip bilgilendirilmediğine bağlıdır."
            }
          ]
        },
        {
          "baseText": "In der Organisation fehlt der neuen Strategie noch die Legitimation durch die Führungskräfte.",
          "translations": [
            {
              "language": "ar",
              "text": "في المنظمة لا تزال الاستراتيجية الجديدة تفتقر إلى إضفاء الشرعية من قبل القيادات."
            },
            {
              "language": "ckb",
              "text": "لە ڕێکخراوەکەدا ستراتیژیی نوێ هێشتا ڕەوایەتی لەلایەن بەڕێوەبەرانی سەرەوەوە نییە."
            },
            {
              "language": "en",
              "text": "Within the organization, the new strategy still lacks legitimation by senior managers."
            },
            {
              "language": "fa",
              "text": "در سازمان، استراتژی جدید هنوز از سوی مدیران مشروعیت کافی پیدا نکرده است."
            },
            {
              "language": "kmr",
              "text": "Di rêxistinê de stratejiya nû hîn rewayetîya rêveberên bilind tune ye."
            },
            {
              "language": "pl",
              "text": "W organizacji nowej strategii brakuje jeszcze legitymizacji ze strony kadry kierowniczej."
            },
            {
              "language": "ro",
              "text": "În organizație, noua strategie încă nu are legitimarea liderilor."
            },
            {
              "language": "ru",
              "text": "В организации новой стратегии пока не хватает легитимации со стороны руководителей."
            },
            {
              "language": "sq",
              "text": "Në organizatë, strategjisë së re ende i mungon legjitimimi nga drejtuesit."
            },
            {
              "language": "tr",
              "text": "Organizasyonda yeni stratejinin yöneticiler tarafından meşrulaştırılması hâlâ eksik."
            }
          ]
        }
      ]
    },
    {
      "word": "der Legitimationsanspruch",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Legitimationsansprüche",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Le-gi-ti-ma-ti-ons-an-spruch",
      "topics": [
        "advanced-analysis",
        "law-and-compliance",
        "management-and-leadership"
      ],
      "usageLabels": [
        "academic",
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun"
      ],
      "collocations": [
        {
          "text": "einen Legitimationsanspruch erheben",
          "meaning": "to claim legitimacy"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Legitimation",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Anspruch",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ادعاء الشرعية؛ مطالبة بالتبرير"
        },
        {
          "language": "ckb",
          "text": "داوای ڕەوایەتی؛ بانگەشەی ڕەوایەتی"
        },
        {
          "language": "en",
          "text": "claim to legitimacy"
        },
        {
          "language": "fa",
          "text": "ادعای مشروعیت؛ مطالبه مشروعیت"
        },
        {
          "language": "kmr",
          "text": "daxwaza rewayetiyê"
        },
        {
          "language": "pl",
          "text": "roszczenie do legitymizacji"
        },
        {
          "language": "ro",
          "text": "pretenție de legitimitate"
        },
        {
          "language": "ru",
          "text": "претензия на легитимность"
        },
        {
          "language": "sq",
          "text": "pretendim për legjitimitet"
        },
        {
          "language": "tr",
          "text": "meşruiyet iddiası"
        }
      ],
      "examples": [
        {
          "baseText": "Der Legitimationsanspruch des Gremiums wirkt schwach, solange seine Mitglieder nicht gewählt sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يبدو ادعاء الهيئة بالشرعية ضعيفاً ما دام أعضاؤها غير منتخبين."
            },
            {
              "language": "ckb",
              "text": "داوای ڕەوایەتیی لیژنەکە لاواز دەردەکەوێت تا ئەندامەکانی هەڵنەبژێردرابن."
            },
            {
              "language": "en",
              "text": "The body’s claim to legitimacy appears weak as long as its members are not elected."
            },
            {
              "language": "fa",
              "text": "ادعای مشروعیت این نهاد تا وقتی اعضایش انتخاب نشده‌اند، ضعیف به نظر می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Daxwaza rewayetiyê ya komîteyê lawaz dixuye heta endamên wê nehatibin hilbijartin."
            },
            {
              "language": "pl",
              "text": "Roszczenie tego gremium do legitymizacji wydaje się słabe, dopóki jego członkowie nie są wybierani."
            },
            {
              "language": "ro",
              "text": "Pretenția de legitimitate a organismului pare slabă cât timp membrii săi nu sunt aleși."
            },
            {
              "language": "ru",
              "text": "Претензия органа на легитимность выглядит слабой, пока его члены не избраны."
            },
            {
              "language": "sq",
              "text": "Pretendimi i organit për legjitimitet duket i dobët për sa kohë anëtarët nuk janë zgjedhur."
            },
            {
              "language": "tr",
              "text": "Kurulun meşruiyet iddiası, üyeleri seçilmediği sürece zayıf görünür."
            }
          ]
        },
        {
          "baseText": "Ein hoher Legitimationsanspruch verlangt im Unternehmen nachvollziehbare Entscheidungswege.",
          "translations": [
            {
              "language": "ar",
              "text": "يتطلب الادعاء العالي بالشرعية داخل الشركة مسارات قرار قابلة للتتبع."
            },
            {
              "language": "ckb",
              "text": "داوای بەرزی ڕەوایەتی لە کۆمپانیاکەدا ڕێگای بڕیاری تێگەیشتنی پێویست دەکات."
            },
            {
              "language": "en",
              "text": "A strong claim to legitimacy requires traceable decision paths within the company."
            },
            {
              "language": "fa",
              "text": "ادعای مشروعیت بالا در شرکت نیازمند مسیرهای تصمیم‌گیری قابل پیگیری است."
            },
            {
              "language": "kmr",
              "text": "Daxwaza bilind a rewayetiyê di şîrketê de rêyên biryardanê yên şopandbar dixwaze."
            },
            {
              "language": "pl",
              "text": "Wysokie roszczenie do legitymizacji wymaga w firmie przejrzystych ścieżek decyzyjnych."
            },
            {
              "language": "ro",
              "text": "O pretenție ridicată de legitimitate cere în companie trasee decizionale urmărite clar."
            },
            {
              "language": "ru",
              "text": "Высокая претензия на легитимность требует в компании прослеживаемых путей принятия решений."
            },
            {
              "language": "sq",
              "text": "Një pretendim i lartë për legjitimitet kërkon rrugë vendimmarrjeje të gjurmueshme në kompani."
            },
            {
              "language": "tr",
              "text": "Yüksek bir meşruiyet iddiası şirkette izlenebilir karar süreçleri gerektirir."
            }
          ]
        }
      ]
    },
