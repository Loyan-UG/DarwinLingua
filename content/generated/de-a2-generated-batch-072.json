      ],
      "examples": [
        {
          "baseText": "Mein Onkel wohnt in Hamburg.",
          "translations": [
            {
              "language": "ar",
              "text": "عمي/خالي يعيش في هامبورغ."
            },
            {
              "language": "ckb",
              "text": "مامم لە هامبۆرگ دەژیت."
            },
            {
              "language": "en",
              "text": "My uncle lives in Hamburg."
            },
            {
              "language": "fa",
              "text": "عمو/دایی من در هامبورگ زندگی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Apê min li Hamburgê dijî."
            },
            {
              "language": "pl",
              "text": "Mój wujek mieszka w Hamburgu."
            },
            {
              "language": "ro",
              "text": "Unchiul meu locuiește în Hamburg."
            },
            {
              "language": "ru",
              "text": "Мой дядя живёт в Гамбурге."
            },
            {
              "language": "sq",
              "text": "Xhaxhai im jeton në Hamburg."
            },
            {
              "language": "tr",
              "text": "Amcam Hamburg’da yaşıyor."
            }
          ]
        },
        {
          "baseText": "Am Sonntag besuchen wir meinen Onkel.",
          "translations": [
            {
              "language": "ar",
              "text": "يوم الأحد نزور عمي/خالي."
            },
            {
              "language": "ckb",
              "text": "یەکشەممە سەردانی مامم دەکەین."
            },
            {
              "language": "en",
              "text": "On Sunday we visit my uncle."
            },
            {
              "language": "fa",
              "text": "یکشنبه به دیدن عمو/دایی‌ام می‌رویم."
            },
            {
              "language": "kmr",
              "text": "Yekşemê em serdana apê min dikin."
            },
            {
              "language": "pl",
              "text": "W niedzielę odwiedzamy mojego wujka."
            },
            {
              "language": "ro",
              "text": "Duminică îl vizităm pe unchiul meu."
            },
            {
              "language": "ru",
              "text": "В воскресенье мы навещаем моего дядю."
            },
            {
              "language": "sq",
              "text": "Të dielën vizitojmë xhaxhain tim."
            },
            {
              "language": "tr",
              "text": "Pazar günü amcamı ziyaret ediyoruz."
            }
          ]
        }
      ]
    },
