  "entries": [
    {
      "word": "abverlangen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abverlangen",
      "pronunciationIpa": null,
      "syllableBreak": "ab-ver-lan-gen",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; verlangt ab, verlangte ab, hat abverlangt; typically used with dative person and accusative demand"
      ],
      "collocations": [
        {
          "text": "jemandem viel abverlangen",
          "meaning": "to demand a great deal from someone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verlangen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتطلب من شخص شيئاً كثيراً؛ يفرض عبئاً على"
        },
        {
          "language": "ckb",
          "text": "شتێکی زۆر لە کەسێک داوا بکات؛ بارێکی قورس بخاتە سەر"
        },
        {
          "language": "en",
          "text": "to demand or require something difficult from someone"
        },
        {
          "language": "fa",
          "text": "چیزی دشوار از کسی طلبیدن؛ فشار زیادی وارد کردن"
        },
        {
          "language": "kmr",
          "text": "tiştekî giran ji kesekî xwestin; barê zêde dan ser kesekî"
        },
        {
          "language": "pl",
          "text": "wymagać od kogoś czegoś trudnego"
        },
        {
          "language": "ro",
          "text": "a cere sau a solicita ceva dificil de la cineva"
        },
        {
          "language": "ru",
          "text": "требовать от кого-либо чего-то трудного"
        },
        {
          "language": "sq",
          "text": "t’i kërkosh dikujt diçka të vështirë"
        },
        {
          "language": "tr",
          "text": "birinden zorlayıcı bir şey talep etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Umstellung auf das neue ERP-System verlangte den Teams viel Geduld und Disziplin ab.",
          "translations": [
            {
              "language": "ar",
              "text": "تطلب الانتقال إلى نظام ERP الجديد كثيراً من الصبر والانضباط من الفرق."
            },
            {
              "language": "ckb",
              "text": "گۆڕان بۆ سیستەمی نوێی ERP زۆر ئارامی و ڕێکخراوی لە تیمەکان داوا کرد."
            },
            {
              "language": "en",
              "text": "The transition to the new ERP system demanded a great deal of patience and discipline from the teams."
            },
            {
              "language": "fa",
              "text": "تغییر به سیستم ERP جدید صبر و انضباط زیادی از تیم‌ها طلب کرد."
            },
            {
              "language": "kmr",
              "text": "Veguhastina bo pergala ERP ya nû gelek sebr û dîsîplîn ji tîman xwest."
            },
            {
              "language": "pl",
              "text": "Przejście na nowy system ERP wymagało od zespołów dużo cierpliwości i dyscypliny."
            },
            {
              "language": "ro",
              "text": "Trecerea la noul sistem ERP le-a cerut echipelor multă răbdare și disciplină."
            },
            {
              "language": "ru",
              "text": "Переход на новую ERP-систему потребовал от команд большого терпения и дисциплины."
            },
            {
              "language": "sq",
              "text": "Kalimi në sistemin e ri ERP u kërkoi ekipeve shumë durim dhe disiplinë."
            },
            {
              "language": "tr",
              "text": "Yeni ERP sistemine geçiş ekiplerden büyük sabır ve disiplin talep etti."
            }
          ]
        },
        {
          "baseText": "Die Pflege eines schwerkranken Angehörigen kann einer Familie über Monate enorme Kraft abverlangen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن أن تتطلب رعاية قريب شديد المرض قوة هائلة من الأسرة على مدى أشهر."
            },
            {
              "language": "ckb",
              "text": "چاودێریکردنی خزمێکی زۆر نەخۆش دەتوانێت بۆ چەند مانگ هێزێکی زۆر لە خێزانێک داوا بکات."
            },
            {
              "language": "en",
              "text": "Caring for a seriously ill relative can demand enormous strength from a family for months."
            },
            {
              "language": "fa",
              "text": "مراقبت از یک عضو خانواده که به‌شدت بیمار است می‌تواند ماه‌ها نیروی زیادی از خانواده طلب کند."
            },
            {
              "language": "kmr",
              "text": "Xwedîkirina xizmê nexweşekî giran dikare bi mehan hêzeke mezin ji malbatekê bixwaze."
            },
            {
              "language": "pl",
              "text": "Opieka nad ciężko chorym krewnym może przez miesiące wymagać od rodziny ogromnej siły."
            },
            {
              "language": "ro",
              "text": "Îngrijirea unei rude grav bolnave poate cere unei familii o forță enormă timp de luni întregi."
            },
            {
              "language": "ru",
              "text": "Уход за тяжело больным родственником может месяцами требовать от семьи огромных сил."
            },
            {
              "language": "sq",
              "text": "Kujdesi për një të afërm rëndë të sëmurë mund t’i kërkojë një familjeje forcë të madhe për muaj të tërë."
            },
            {
              "language": "tr",
              "text": "Ağır hasta bir yakına bakmak, aylar boyunca bir aileden büyük güç isteyebilir."
            }
          ]
        }
      ]
    },
    {
      "word": "abwegig",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ab-we-gig",
      "topics": [
        "advanced-analysis",
        "business-communication",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "analysis",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; often used to reject an idea as implausible or beside the point"
      ],
      "collocations": [
        {
          "text": "eine abwegige Annahme",
          "meaning": "an implausible or far-fetched assumption"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Weg",
          "relationLabel": "noun",
          "note": "etymologically related"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بعيد عن الصواب؛ غير معقول"
        },
        {
          "language": "ckb",
          "text": "بێبنەما؛ زۆر دوور لە ڕاستی"
        },
        {
          "language": "en",
          "text": "far-fetched; absurd; misguided"
        },
        {
          "language": "fa",
          "text": "بی‌راه؛ نامعقول؛ دور از ذهن"
        },
        {
          "language": "kmr",
          "text": "ji rastiyê dûr; bêbingeh; neaqilane"
        },
        {
          "language": "pl",
          "text": "niedorzeczny; chybiony; mało prawdopodobny"
        },
        {
          "language": "ro",
          "text": "absurd; nefondat; improbabil"
        },
        {
          "language": "ru",
          "text": "абсурдный; надуманный; ошибочный"
        },
        {
          "language": "sq",
          "text": "i pabazë; absurd; i paarsyeshëm"
        },
        {
          "language": "tr",
          "text": "akla uzak; yersiz; saçma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Annahme, dass alle Kunden ohne Schulung mit der neuen Oberfläche zurechtkommen, ist abwegig.",
          "translations": [
            {
              "language": "ar",
              "text": "الافتراض بأن جميع العملاء سيتعاملون مع الواجهة الجديدة دون تدريب افتراض غير معقول."
            },
            {
              "language": "ckb",
              "text": "ئەو گریمانەیەی هەموو کڕیاران بەبێ ڕاهێنان لەگەڵ ڕووکاری نوێ ڕادێن، بێبنەمایە."
            },
            {
              "language": "en",
              "text": "The assumption that all customers will manage the new interface without training is far-fetched."
            },
            {
              "language": "fa",
              "text": "این فرض که همه مشتریان بدون آموزش با رابط کاربری جدید کنار می‌آیند، نامعقول است."
            },
            {
              "language": "kmr",
              "text": "Ew texmîn ku hemû xerîdar bê perwerdekarî bi navrûya nû re baş bikin, ji rastiyê dûr e."
            },
            {
              "language": "pl",
              "text": "Założenie, że wszyscy klienci poradzą sobie z nowym interfejsem bez szkolenia, jest niedorzeczne."
            },
            {
              "language": "ro",
              "text": "Presupunerea că toți clienții se vor descurca fără instruire cu noua interfață este absurdă."
            },
            {
              "language": "ru",
              "text": "Предположение, что все клиенты справятся с новым интерфейсом без обучения, надуманно."
            },
            {
              "language": "sq",
              "text": "Supozimi se të gjithë klientët do ta përdorin ndërfaqen e re pa trajnim është i paarsyeshëm."
            },
            {
              "language": "tr",
              "text": "Tüm müşterilerin yeni arayüzü eğitim almadan kullanabileceği varsayımı akla uzaktır."
            }
          ]
        },
        {
          "baseText": "Es wäre abwegig, die Verantwortung allein bei einzelnen Mitarbeitenden zu suchen.",
          "translations": [
            {
              "language": "ar",
              "text": "سيكون من غير المعقول البحث عن المسؤولية لدى موظفين أفراد فقط."
            },
            {
              "language": "ckb",
              "text": "بێبنەما دەبێت ئەگەر بەرپرسیارێتی تەنها لای کارمەندانی تاکەکەسی بگەڕێین."
            },
            {
              "language": "en",
              "text": "It would be misguided to look for responsibility solely among individual employees."
            },
            {
              "language": "fa",
              "text": "این بی‌راهه است که مسئولیت را فقط نزد کارکنان منفرد جست‌وجو کنیم."
            },
            {
              "language": "kmr",
              "text": "Ne rast e ku berpirsiyariyê tenê li cem karmendên takekesî bigerin."
            },
            {
              "language": "pl",
              "text": "Byłoby chybione szukać odpowiedzialności wyłącznie u pojedynczych pracowników."
            },
            {
              "language": "ro",
              "text": "Ar fi greșit să căutăm responsabilitatea doar la angajați individuali."
            },
            {
              "language": "ru",
              "text": "Было бы ошибочно искать ответственность только у отдельных сотрудников."
            },
            {
              "language": "sq",
              "text": "Do të ishte e gabuar të kërkohej përgjegjësia vetëm te punonjës të veçantë."
            },
            {
              "language": "tr",
              "text": "Sorumluluğu yalnızca tek tek çalışanlarda aramak yersiz olurdu."
            }
          ]
        }
      ]
    },
    {
      "word": "die Ätiologie",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
