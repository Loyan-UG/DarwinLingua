      "meanings": [
        {
          "language": "ar",
          "text": "يطرح موضوعاً للنقاش؛ يتناول"
        },
        {
          "language": "ckb",
          "text": "بابەتێک دەهێنێتە گفتوگۆ؛ باس دەکات"
        },
        {
          "language": "en",
          "text": "to address; to bring up as a topic"
        },
        {
          "language": "fa",
          "text": "مطرح کردن؛ به بحث گذاشتن"
        },
        {
          "language": "kmr",
          "text": "wek mijar anîn; behs kirin"
        },
        {
          "language": "pl",
          "text": "poruszyć temat; omówić"
        },
        {
          "language": "ro",
          "text": "a tematiza; a aduce în discuție"
        },
        {
          "language": "ru",
          "text": "поднимать тему; обсуждать"
        },
        {
          "language": "sq",
          "text": "ta trajtosh si temë; ta ngresh për diskutim"
        },
        {
          "language": "tr",
          "text": "konu etmek; gündeme getirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Projektleiterin thematisierte die Verzögerungen früh, damit der Kunde nicht überrascht wird.",
          "translations": [
            {
              "language": "ar",
              "text": "طرحت مديرة المشروع التأخيرات مبكراً حتى لا يتفاجأ العميل."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری پرۆژەکە دواخستنەکانی زوو باس کرد بۆ ئەوەی کڕیار تووشی سەرسوڕمان نەبێت."
            },
            {
              "language": "en",
              "text": "The project manager addressed the delays early so the customer would not be surprised."
            },
            {
              "language": "fa",
              "text": "مدیر پروژه تأخیرها را زود مطرح کرد تا مشتری غافلگیر نشود."
            },
            {
              "language": "kmr",
              "text": "Rêvebera projeyê derengmayînan zû anî ziman da ku mişterî şaş nemîne."
            },
            {
              "language": "pl",
              "text": "Kierowniczka projektu wcześnie poruszyła temat opóźnień, aby klient nie był zaskoczony."
            },
            {
              "language": "ro",
              "text": "Managera de proiect a adus întârzierile în discuție devreme, pentru ca clientul să nu fie surprins."
            },
            {
              "language": "ru",
              "text": "Руководитель проекта рано подняла тему задержек, чтобы клиент не был удивлен."
            },
            {
              "language": "sq",
              "text": "Menaxherja e projektit i trajtoi vonesat herët, që klienti të mos befasohej."
            },
            {
              "language": "tr",
              "text": "Proje yöneticisi, müşterinin şaşırmaması için gecikmeleri erken gündeme getirdi."
            }
          ]
        },
        {
          "baseText": "Im Seminar wurde thematisiert, wie Sprache gesellschaftliche Ausschlüsse verstärken kann.",
          "translations": [
            {
              "language": "ar",
              "text": "في الندوة نوقش كيف يمكن للغة أن تعزز أشكال الإقصاء الاجتماعي."
            },
            {
              "language": "ckb",
              "text": "لە سیمینارەکەدا باس کرا کە زمان چۆن دەتوانێت دوورخستنەوە کۆمەڵایەتییەکان بەهێزتر بکات."
            },
            {
              "language": "en",
              "text": "The seminar addressed how language can reinforce social exclusion."
            },
            {
              "language": "fa",
              "text": "در سمینار مطرح شد که زبان چگونه می‌تواند طرد اجتماعی را تقویت کند."
            },
            {
              "language": "kmr",
              "text": "Di semînerê de hate behskirin ka ziman çawa dikare dûrxistina civakî xurt bike."
            },
            {
              "language": "pl",
              "text": "Na seminarium poruszono temat tego, jak język może wzmacniać wykluczenie społeczne."
            },
            {
              "language": "ro",
              "text": "În seminar s-a discutat cum limbajul poate întări excluderea socială."
            },
            {
              "language": "ru",
              "text": "На семинаре обсуждалось, как язык может усиливать социальное исключение."
            },
            {
              "language": "sq",
              "text": "Në seminar u trajtua se si gjuha mund të forcojë përjashtimin shoqëror."
            },
            {
              "language": "tr",
              "text": "Seminerde dilin toplumsal dışlanmayı nasıl güçlendirebileceği ele alındı."
            }
          ]
        }
      ]
    }
