        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "management",
        "administration"
      ],
      "grammarNotes": [
        "regular verb; used when something requires effort, time, or documents"
      ],
      "collocations": [
        {
          "text": "viel Zeit erfordern",
          "meaning": "to require a lot of time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erforderung",
          "relationLabel": "rare noun",
          "note": null
        },
        {
          "lemma": "erforderlich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتطلب؛ يستلزم"
        },
        {
          "language": "ckb",
          "text": "پێویستی هەبوون بە؛ داواکاری کردن"
        },
        {
          "language": "en",
          "text": "to require; to demand"
        },
        {
          "language": "fa",
          "text": "نیاز داشتن؛ مستلزم بودن"
        },
        {
          "language": "kmr",
          "text": "hewce kirin; pêwîst kirin"
        },
        {
          "language": "pl",
          "text": "wymagać"
        },
        {
          "language": "ro",
          "text": "a necesita; a cere"
        },
        {
          "language": "ru",
          "text": "требовать"
        },
        {
          "language": "sq",
          "text": "të kërkojë; të nevojitet"
        },
        {
          "language": "tr",
          "text": "gerektirmek; ihtiyaç duymak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Umstellung auf das neue System erfordert eine kurze Schulung.",
          "translations": [
            {
              "language": "ar",
              "text": "يتطلب الانتقال إلى النظام الجديد تدريبًا قصيرًا."
            },
            {
              "language": "ckb",
              "text": "گۆڕین بۆ سیستەمی نوێ پێویستی بە ڕاهێنانێکی کورت هەیە."
            },
            {
              "language": "en",
              "text": "The changeover to the new system requires a short training session."
            },
            {
              "language": "fa",
              "text": "تغییر به سیستم جدید به یک آموزش کوتاه نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Guhertina bo pergala nû perwerdeyeke kurt hewce dike."
            },
            {
              "language": "pl",
              "text": "Przejście na nowy system wymaga krótkiego szkolenia."
            },
            {
              "language": "ro",
              "text": "Trecerea la noul sistem necesită o scurtă instruire."
            },
            {
              "language": "ru",
              "text": "Переход на новую систему требует короткого обучения."
            },
            {
              "language": "sq",
              "text": "Kalimi në sistemin e ri kërkon një trajnim të shkurtër."
            },
            {
              "language": "tr",
              "text": "Yeni sisteme geçiş kısa bir eğitim gerektirir."
            }
          ]
        },
        {
          "baseText": "Die Bearbeitung des Antrags erfordert alle aktuellen Unterlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "تتطلب معالجة الطلب جميع المستندات الحالية."
            },
            {
              "language": "ckb",
              "text": "چارەسەرکردنی داواکارییەکە پێویستی بە هەموو بەڵگەنامە نوێیەکان هەیە."
            },
            {
              "language": "en",
              "text": "Processing the application requires all current documents."
            },
            {
              "language": "fa",
              "text": "بررسی درخواست به همه مدارک به‌روز نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Xebitandina daxwazê hemû belgeyên rojane hewce dike."
            },
            {
              "language": "pl",
              "text": "Rozpatrzenie wniosku wymaga wszystkich aktualnych dokumentów."
            },
            {
              "language": "ro",
              "text": "Procesarea cererii necesită toate documentele actuale."
            },
            {
              "language": "ru",
              "text": "Обработка заявления требует всех актуальных документов."
            },
            {
              "language": "sq",
              "text": "Përpunimi i kërkesës kërkon të gjitha dokumentet aktuale."
            },
            {
              "language": "tr",
              "text": "Başvurunun işleme alınması tüm güncel belgeleri gerektirir."
            }
          ]
        }
      ]
    },
