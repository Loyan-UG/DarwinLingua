        {
          "language": "ckb",
          "text": "پشوودان؛ چاکبوونەوە"
        },
        {
          "language": "en",
          "text": "recovery; rest"
        },
        {
          "language": "fa",
          "text": "استراحت؛ بهبود"
        },
