    {
      "word": "Bearbeitungsende",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Bearbeitungsenden",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-ar-bei-tungs-en-de",
      "topics": [
        "erp-and-business-systems",
        "planning-and-projects",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter compound noun; end point of processing a task, order, or case"
      ],
      "collocations": [
        {
          "text": "das Bearbeitungsende erfassen",
          "meaning": "to record the end of processing"
        },
        {
          "text": "das Bearbeitungsende verschieben",
          "meaning": "to postpone the processing end"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bearbeiten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "enden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نهاية المعالجة"
        },
        {
          "language": "ckb",
          "text": "کۆتایی چارەسەرکردن"
        },
        {
          "language": "en",
          "text": "end of processing"
        },
        {
          "language": "fa",
          "text": "پایان پردازش؛ پایان رسیدگی"
        },
        {
          "language": "kmr",
          "text": "dawiya xebitandinê"
        },
        {
          "language": "pl",
          "text": "koniec przetwarzania; zakończenie obsługi"
        },
        {
          "language": "ro",
          "text": "sfârșitul procesării"
        },
        {
          "language": "ru",
          "text": "окончание обработки"
        },
        {
          "language": "sq",
          "text": "fundi i përpunimit"
        },
        {
          "language": "tr",
          "text": "işleme bitişi"
        }
      ],
      "examples": [
        {
          "baseText": "Das Bearbeitungsende wird im ERP erst gesetzt, wenn alle Pflichtfelder geprüft wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تعيين نهاية المعالجة في ERP فقط بعد فحص جميع الحقول الإلزامية."
            },
            {
              "language": "ckb",
              "text": "کۆتایی چارەسەرکردن لە ERP دا تەنها دوای پشکنینی هەموو خانە پێویستەکان دادەنرێت."
            },
            {
              "language": "en",
              "text": "The end of processing is set in the ERP only after all mandatory fields have been checked."
            },
            {
              "language": "fa",
              "text": "پایان پردازش در ERP فقط وقتی ثبت می‌شود که همه فیلدهای اجباری بررسی شده باشند."
            },
            {
              "language": "kmr",
              "text": "Dawiya xebitandinê di ERP de tenê piştî kontrolkirina hemû qadên pêwîst tê danîn."
            },
            {
              "language": "pl",
              "text": "Koniec przetwarzania jest ustawiany w ERP dopiero po sprawdzeniu wszystkich pól obowiązkowych."
            },
            {
              "language": "ro",
              "text": "Sfârșitul procesării este setat în ERP doar după verificarea tuturor câmpurilor obligatorii."
            },
            {
              "language": "ru",
              "text": "Окончание обработки устанавливается в ERP только после проверки всех обязательных полей."
            },
            {
              "language": "sq",
              "text": "Fundi i përpunimit vendoset në ERP vetëm pasi të jenë kontrolluar të gjitha fushat e detyrueshme."
            },
            {
              "language": "tr",
              "text": "İşleme bitişi ERP’de ancak tüm zorunlu alanlar kontrol edildikten sonra belirlenir."
            }
          ]
        },
        {
          "baseText": "Bitte informieren Sie den Kunden, wenn das Bearbeitungsende heute nicht mehr erreicht wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إبلاغ العميل إذا لم نصل إلى نهاية المعالجة اليوم."
            },
            {
              "language": "ckb",
              "text": "تکایە کڕیار ئاگادار بکەنەوە ئەگەر کۆتایی چارەسەرکردن ئەمڕۆ چیتر بەدەست نەهێنرێت."
            },
            {
              "language": "en",
              "text": "Please inform the customer if the end of processing can no longer be reached today."
            },
            {
              "language": "fa",
              "text": "لطفاً اگر پایان رسیدگی امروز دیگر ممکن نیست، مشتری را مطلع کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe mişterî agahdar bikin heke dawiya xebitandinê îro êdî negihîje."
            },
            {
              "language": "pl",
              "text": "Proszę poinformować klienta, jeśli zakończenie obsługi nie będzie dziś możliwe."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să informați clientul dacă procesarea nu mai poate fi finalizată astăzi."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сообщите клиенту, если сегодня обработку уже не удастся завершить."
            },
            {
              "language": "sq",
              "text": "Ju lutemi informoni klientin nëse përpunimi nuk mund të përfundojë më sot."
            },
            {
              "language": "tr",
              "text": "İşleme bugün artık tamamlanamayacaksa lütfen müşteriyi bilgilendirin."
            }
          ]
        }
      ]
    },
    {
      "word": "Beladung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Beladungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-la-dung",
      "topics": [
