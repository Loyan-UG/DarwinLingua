      ],
      "examples": [
        {
          "baseText": "Für eine Gutschrift muss im ERP die richtige Belegart gewählt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة للإشعار الدائن يجب اختيار نوع المستند الصحيح في ERP."
            },
            {
              "language": "ckb",
              "text": "بۆ قەرزنامەی گەڕاوە پێویستە لە ERP دا جۆری بەڵگەنامەی دروست هەڵبژێردرێت."
            },
            {
              "language": "en",
              "text": "For a credit memo, the correct document type must be selected in the ERP."
            },
            {
              "language": "fa",
              "text": "برای یک بستانکارنامه باید در ERP نوع سند درست انتخاب شود."
            },
            {
              "language": "kmr",
              "text": "Ji bo nota krediyê divê di ERP de cureyê belgeyê yê rast were hilbijartin."
            },
            {
              "language": "pl",
              "text": "Dla faktury korygującej należy wybrać w ERP właściwy typ dokumentu."
            },
            {
              "language": "ro",
              "text": "Pentru o notă de credit trebuie ales în ERP tipul corect de document."
            },
            {
