      "collocations": [
        {
          "text": "die Beladung planen",
          "meaning": "to plan the loading"
        },
        {
          "text": "mit der Beladung beginnen",
          "meaning": "to start loading"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "beladen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "التحميل"
        },
        {
          "language": "ckb",
          "text": "بارکردن"
        },
        {
          "language": "en",
          "text": "loading"
        },
        {
          "language": "fa",
          "text": "بارگیری"
        },
        {
          "language": "kmr",
          "text": "barkirin"
        },
        {
          "language": "pl",
          "text": "załadunek"
        },
        {
          "language": "ro",
          "text": "încărcare"
        },
        {
          "language": "ru",
          "text": "погрузка"
        },
        {
          "language": "sq",
          "text": "ngarkim"
        },
        {
          "language": "tr",
          "text": "yükleme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Beladung des Lkw ist im ERP für 14 Uhr eingeplant.",
          "translations": [
            {
              "language": "ar",
              "text": "تمت جدولة تحميل الشاحنة في ERP للساعة الثانية بعد الظهر."
            },
            {
              "language": "ckb",
              "text": "بارکردنی بارهەڵگرەکە لە ERP دا بۆ کاتژمێر ١٤ پلاندانراوە."
            },
            {
              "language": "en",
              "text": "The loading of the truck is scheduled in the ERP for 2 p.m."
            },
            {
              "language": "fa",
              "text": "بارگیری کامیون در ERP برای ساعت ۱۴ برنامه‌ریزی شده است."
            },
            {
              "language": "kmr",
              "text": "Barkirina kamyonê di ERP de ji bo saet 14 hatiye plansazkirin."
            },
            {
              "language": "pl",
              "text": "Załadunek ciężarówki jest zaplanowany w ERP na godzinę 14."
            },
            {
              "language": "ro",
              "text": "Încărcarea camionului este planificată în ERP pentru ora 14."
            },
            {
              "language": "ru",
              "text": "Погрузка грузовика запланирована в ERP на 14:00."
            },
            {
              "language": "sq",
              "text": "Ngarkimi i kamionit është planifikuar në ERP për orën 14:00."
            },
            {
              "language": "tr",
              "text": "Kamyonun yüklemesi ERP’de saat 14:00 için planlandı."
            }
          ]
        },
        {
          "baseText": "Wegen des starken Regens musste die Beladung kurz unterbrochen werden.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب المطر الغزير كان لا بد من إيقاف التحميل مؤقتًا."
            },
            {
              "language": "ckb",
              "text": "بەهۆی بارانی توندەوە پێویست بوو بارکردنەکە بۆ ماوەیەک بوەستێنرێت."
            },
            {
              "language": "en",
              "text": "Because of the heavy rain, the loading had to be interrupted briefly."
            },
            {
              "language": "fa",
              "text": "به دلیل باران شدید، بارگیری برای مدت کوتاهی متوقف شد."
            },
            {
              "language": "kmr",
              "text": "Ji ber barana giran, barkirin demek kurt hate rawestandin."
            },
            {
              "language": "pl",
              "text": "Z powodu silnego deszczu załadunek musiał zostać na krótko przerwany."
            },
            {
              "language": "ro",
              "text": "Din cauza ploii puternice, încărcarea a trebuit întreruptă scurt."
            },
            {
              "language": "ru",
              "text": "Из-за сильного дождя погрузку пришлось ненадолго прервать."
            },
            {
              "language": "sq",
              "text": "Për shkak të shiut të fortë, ngarkimi duhej të ndërpritej për pak kohë."
            },
            {
              "language": "tr",
              "text": "Şiddetli yağmur nedeniyle yüklemeye kısa süre ara verilmek zorunda kalındı."
            }
          ]
        }
      ]
    },
