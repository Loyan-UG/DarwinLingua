        {
          "text": "einen Konsens erzielen",
          "meaning": "to reach a consensus"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "konsensfähig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "توافق؛ إجماع"
        },
        {
          "language": "ckb",
          "text": "ڕێککەوتن؛ کۆدەنگی"
        },
        {
          "language": "en",
          "text": "consensus; agreement"
        },
        {
          "language": "fa",
          "text": "اجماع؛ توافق"
        },
        {
          "language": "kmr",
          "text": "lihevhatin; hevpeymanî"
        },
        {
          "language": "pl",
          "text": "konsensus; porozumienie"
        },
        {
          "language": "ro",
          "text": "consens; acord"
        },
        {
          "language": "ru",
          "text": "консенсус; согласие"
        },
        {
          "language": "sq",
          "text": "konsensus; marrëveshje"
        },
        {
          "language": "tr",
          "text": "uzlaşı; mutabakat"
        }
      ],
      "examples": [
        {
          "baseText": "Nach mehreren Verhandlungsrunden zeichnete sich ein tragfähiger Konsens ab.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد عدة جولات تفاوضية بدأ يظهر توافق قابل للاستمرار."
            },
            {
              "language": "ckb",
              "text": "دوای چەند خولی دانوستان، ڕێککەوتنێکی بەهێز دەستی پێکرد بە دەرکەوتن."
            },
            {
              "language": "en",
              "text": "After several rounds of negotiation, a viable consensus began to emerge."
            },
            {
              "language": "fa",
              "text": "پس از چند دور مذاکره، یک توافق قابل اتکا در حال شکل‌گیری بود."
            },
            {
              "language": "kmr",
              "text": "Piştî çend gerên danûstandinê, lihevhatinek bihêz dest bi xuya bûnê kir."
            },
            {
              "language": "pl",
              "text": "Po kilku rundach negocjacji zaczął się wyłaniać trwały konsensus."
            },
            {
              "language": "ro",
              "text": "După mai multe runde de negociere, a început să se contureze un consens solid."
            },
            {
              "language": "ru",
              "text": "После нескольких раундов переговоров начал вырисовываться жизнеспособный консенсус."
            },
            {
              "language": "sq",
              "text": "Pas disa raundeve negociatash, filloi të shfaqej një konsensus i qëndrueshëm."
            },
            {
              "language": "tr",
              "text": "Birkaç müzakere turundan sonra uygulanabilir bir uzlaşı belirmeye başladı."
            }
          ]
        },
        {
          "baseText": "Im Team bestand Konsens darüber, dass die Kundendaten nicht ohne Prüfung migriert werden dürfen.",
          "translations": [
            {
              "language": "ar",
              "text": "كان هناك توافق في الفريق على أنه لا يجوز ترحيل بيانات العملاء من دون فحص."
            },
            {
              "language": "ckb",
              "text": "لە تیمەکەدا کۆدەنگی هەبوو کە داتای کڕیاران نابێت بەبێ پشکنین بگوازرێتەوە."
            },
            {
              "language": "en",
              "text": "The team agreed that customer data must not be migrated without review."
            },
            {
              "language": "fa",
              "text": "در تیم توافق وجود داشت که داده‌های مشتریان نباید بدون بررسی منتقل شوند."
            },
            {
              "language": "kmr",
              "text": "Di tîmê de lihevhatin hebû ku daneyên xerîdaran bê kontrol nayên veguhestin."
            },
            {
              "language": "pl",
              "text": "W zespole panował konsensus, że danych klientów nie wolno migrować bez kontroli."
            },
            {
              "language": "ro",
              "text": "În echipă exista consens că datele clienților nu trebuie migrate fără verificare."
            },
            {
              "language": "ru",
              "text": "В команде был консенсус, что данные клиентов нельзя мигрировать без проверки."
            },
            {
              "language": "sq",
              "text": "Në ekip kishte konsensus se të dhënat e klientëve nuk duhet të migrohen pa kontroll."
            },
            {
              "language": "tr",
              "text": "Ekipte müşteri verilerinin kontrol edilmeden taşınmaması gerektiği konusunda uzlaşı vardı."
            }
          ]
        }
      ]
    },
    {
      "word": "konsensfähig",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "kon-sens-fä-hig",
      "topics": [
