      "meanings": [
        {
          "language": "ar",
          "text": "في الأمام"
        },
        {
          "language": "ckb",
          "text": "لە پێشەوە"
        },
        {
          "language": "en",
          "text": "at the front; in front"
        },
        {
          "language": "fa",
          "text": "جلو؛ در جلو"
        },
        {
          "language": "kmr",
          "text": "li pêş"
        },
        {
          "language": "pl",
          "text": "z przodu"
        },
        {
          "language": "ro",
          "text": "în față"
        },
        {
          "language": "ru",
          "text": "спереди; впереди"
        },
        {
          "language": "sq",
          "text": "përpara"
        },
        {
          "language": "tr",
          "text": "önde"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte sitzen Sie vorne.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك اجلس في الأمام."
            },
            {
              "language": "ckb",
              "text": "تکایە لە پێشەوە دابنیشە."
            },
            {
              "language": "en",
              "text": "Please sit at the front."
            },
            {
              "language": "fa",
              "text": "لطفاً جلو بنشینید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li pêş rûnin."
            },
            {
              "language": "pl",
              "text": "Proszę usiąść z przodu."
            },
            {
              "language": "ro",
              "text": "Vă rog să stați în față."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сядьте впереди."
            },
            {
              "language": "sq",
              "text": "Ju lutem uluni përpara."
            },
            {
              "language": "tr",
              "text": "Lütfen önde oturun."
            }
          ]
        },
        {
          "baseText": "Der Eingang ist vorne links.",
          "translations": [
            {
              "language": "ar",
              "text": "المدخل في الأمام على اليسار."
            },
            {
              "language": "ckb",
              "text": "دەروازەکە لە پێشەوە لای چەپە."
            },
            {
              "language": "en",
              "text": "The entrance is at the front on the left."
            },
            {
              "language": "fa",
              "text": "ورودی جلو سمت چپ است."
            },
            {
              "language": "kmr",
              "text": "Derketin li pêş li çepê ye."
            },
            {
              "language": "pl",
              "text": "Wejście jest z przodu po lewej."
            },
            {
              "language": "ro",
              "text": "Intrarea este în față, la stânga."
            },
            {
              "language": "ru",
              "text": "Вход спереди слева."
            },
            {
              "language": "sq",
              "text": "Hyrja është përpara majtas."
            },
            {
              "language": "tr",
              "text": "Giriş önde solda."
            }
          ]
        }
      ]
    },
