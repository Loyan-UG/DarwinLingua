      "examples": [
        {
          "baseText": "Wie ist die Vorwahl von Berlin?",
          "translations": [
            {
              "language": "ar",
              "text": "ما رمز الاتصال لبرلين؟"
            },
            {
              "language": "ckb",
              "text": "کۆدی تەلەفۆنی بەرلین چەندە؟"
            },
            {
              "language": "en",
              "text": "What is the area code for Berlin?"
            },
            {
              "language": "fa",
              "text": "پیش‌شماره برلین چیست؟"
            },
            {
              "language": "kmr",
              "text": "Koda telefona Berlînê çi ye?"
            },
            {
              "language": "pl",
              "text": "Jaki jest numer kierunkowy do Berlina?"
            },
            {
              "language": "ro",
              "text": "Care este prefixul telefonic pentru Berlin?"
            },
            {
              "language": "ru",
              "text": "Какой телефонный код Берлина?"
            },
            {
              "language": "sq",
              "text": "Cili është prefiksi telefonik i Berlinit?"
            },
            {
              "language": "tr",
              "text": "Berlin’in alan kodu nedir?"
            }
          ]
        },
        {
          "baseText": "Bitte schreiben Sie die Vorwahl mit der Nummer.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك اكتب رمز الاتصال مع الرقم."
            },
            {
              "language": "ckb",
              "text": "تکایە کۆدی پەیوەندی لەگەڵ ژمارەکە بنووسە."
            },
            {
              "language": "en",
              "text": "Please write the area code with the number."
            },
            {
              "language": "fa",
              "text": "لطفاً پیش‌شماره را همراه شماره بنویسید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe koda telefonê bi hejmarê re binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę wpisać numer kierunkowy razem z numerem."
            },
            {
              "language": "ro",
              "text": "Vă rog să scrieți prefixul împreună cu numărul."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, укажите код вместе с номером."
            },
            {
              "language": "sq",
              "text": "Ju lutem shkruani prefiksin bashkë me numrin."
            },
            {
              "language": "tr",
              "text": "Lütfen alan kodunu numarayla birlikte yazın."
            }
          ]
        }
