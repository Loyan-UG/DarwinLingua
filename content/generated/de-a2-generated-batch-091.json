            },
            {
              "language": "ckb",
              "text": "بەم چراوە کارەبا پاشەکەوت دەکەن."
            },
            {
              "language": "en",
              "text": "With this lamp, you save electricity."
            },
            {
              "language": "fa",
              "text": "با این لامپ در برق صرفه‌جویی می‌کنید."
            },
            {
              "language": "kmr",
              "text": "Bi vê lampê hûn elektrîkê kêm xerc dikin."
            },
            {
              "language": "pl",
              "text": "Dzięki tej lampie oszczędzają państwo prąd."
            },
            {
              "language": "ro",
              "text": "Cu această lampă economisiți curent."
