      "meanings": [
        {
          "language": "ar",
          "text": "إسباني؛ اللغة الإسبانية"
        },
        {
          "language": "ckb",
          "text": "ئیسپانی؛ زمانی ئیسپانی"
        },
        {
          "language": "en",
          "text": "Spanish"
        },
        {
          "language": "fa",
          "text": "اسپانیایی؛ زبان اسپانیایی"
        },
        {
          "language": "kmr",
          "text": "spanî; zimanê spanî"
        },
        {
          "language": "pl",
          "text": "hiszpański"
        },
        {
          "language": "ro",
          "text": "spaniol; limba spaniolă"
        },
        {
          "language": "ru",
          "text": "испанский; испанский язык"
        },
        {
          "language": "sq",
          "text": "spanjisht; spanjoll"
        },
        {
          "language": "tr",
          "text": "İspanyolca; İspanyol"
        }
      ],
      "examples": [
        {
          "baseText": "Ich lerne seit einem Jahr Spanisch.",
          "translations": [
            {
              "language": "ar",
              "text": "أتعلم الإسبانية منذ سنة."
            },
            {
              "language": "ckb",
              "text": "ساڵێکە فێری زمانی ئیسپانی دەبم."
            },
            {
              "language": "en",
              "text": "I have been learning Spanish for a year."
            },
            {
              "language": "fa",
              "text": "من یک سال است اسپانیایی یاد می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Salek e ez spanî hîn dibim."
            },
            {
              "language": "pl",
              "text": "Uczę się hiszpańskiego od roku."
            },
            {
              "language": "ro",
              "text": "Învăț spaniolă de un an."
            },
            {
              "language": "ru",
              "text": "Я учу испанский уже год."
            },
            {
              "language": "sq",
              "text": "Kam një vit që mësoj spanjisht."
            },
            {
              "language": "tr",
              "text": "Bir yıldır İspanyolca öğreniyorum."
            }
          ]
        },
        {
          "baseText": "Das spanische Restaurant ist in der Nähe.",
          "translations": [
            {
              "language": "ar",
              "text": "المطعم الإسباني قريب."
            },
            {
              "language": "ckb",
              "text": "چێشتخانە ئیسپانییەکە لە نزیکە."
            },
            {
              "language": "en",
              "text": "The Spanish restaurant is nearby."
            },
            {
              "language": "fa",
              "text": "رستوران اسپانیایی نزدیک است."
            },
            {
              "language": "kmr",
              "text": "Restoranta spanî li nêzîk e."
            },
            {
              "language": "pl",
              "text": "Hiszpańska restauracja jest blisko."
            },
            {
              "language": "ro",
              "text": "Restaurantul spaniol este aproape."
            },
            {
              "language": "ru",
              "text": "Испанский ресторан находится рядом."
            },
            {
              "language": "sq",
              "text": "Restoranti spanjoll është afër."
            },
            {
              "language": "tr",
              "text": "İspanyol restoranı yakında."
            }
          ]
        }
      ]
