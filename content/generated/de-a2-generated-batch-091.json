      "examples": [
        {
          "baseText": "Wir sparen Geld für ein neues Auto.",
          "translations": [
            {
              "language": "ar",
              "text": "نوفر المال لشراء سيارة جديدة."
            },
            {
              "language": "ckb",
              "text": "ئێمە پارە بۆ ئۆتۆمبێلێکی نوێ پاشەکەوت دەکەین."
            },
            {
              "language": "en",
              "text": "We are saving money for a new car."
            },
            {
              "language": "fa",
              "text": "ما برای یک ماشین جدید پول پس‌انداز می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em ji bo erebeyeke nû pere parastin dikin."
            },
            {
              "language": "pl",
              "text": "Oszczędzamy pieniądze na nowy samochód."
            },
            {
              "language": "ro",
              "text": "Economisim bani pentru o mașină nouă."
            },
            {
              "language": "ru",
              "text": "Мы копим деньги на новую машину."
            },
            {
              "language": "sq",
              "text": "Po kursejmë para për një makinë të re."
            },
            {
              "language": "tr",
              "text": "Yeni bir araba için para biriktiriyoruz."
            }
          ]
        },
        {
          "baseText": "Mit dieser Lampe sparen Sie Strom.",
