      "examples": [
        {
          "baseText": "Der Service im Restaurant ist sehr freundlich.",
          "translations": [
            {
              "language": "ar",
              "text": "الخدمة في المطعم ودودة جداً."
            },
            {
              "language": "ckb",
              "text": "خزمەتگوزارییەکە لە چێشتخانەکەدا زۆر دۆستانەیە."
            },
            {
              "language": "en",
              "text": "The service in the restaurant is very friendly."
            },
            {
              "language": "fa",
              "text": "خدمات در رستوران خیلی دوستانه است."
            },
            {
              "language": "kmr",
              "text": "Xizmet li restorantê pir dostane ye."
            },
            {
              "language": "pl",
              "text": "Obsługa w restauracji jest bardzo miła."
            },
            {
              "language": "ro",
              "text": "Serviciul la restaurant este foarte prietenos."
            },
            {
              "language": "ru",
              "text": "Обслуживание в ресторане очень дружелюбное."
            },
            {
              "language": "sq",
              "text": "Shërbimi në restorant është shumë miqësor."
            },
            {
              "language": "tr",
              "text": "Restorandaki servis çok güler yüzlü."
            }
          ]
        },
        {
          "baseText": "Bei Fragen hilft Ihnen unser Service gern.",
          "translations": [
