        },
        {
          "language": "fa",
          "text": "نادر؛ به‌ندرت"
        },
        {
          "language": "kmr",
          "text": "kêm; bi kêmî"
        },
        {
          "language": "pl",
          "text": "rzadki; rzadko"
        },
        {
          "language": "ro",
          "text": "rar; rareori"
        },
        {
          "language": "ru",
          "text": "редкий; редко"
        },
        {
          "language": "sq",
          "text": "i rrallë; rrallë"
        },
        {
          "language": "tr",
          "text": "nadir; seyrek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich esse selten Fleisch.",
          "translations": [
            {
              "language": "ar",
              "text": "نادراً ما آكل اللحم."
            },
            {
              "language": "ckb",
              "text": "من بە دەگمەن گۆشت دەخۆم."
            },
            {
              "language": "en",
              "text": "I rarely eat meat."
            },
            {
              "language": "fa",
              "text": "من به‌ندرت گوشت می‌خورم."
            },
            {
              "language": "kmr",
              "text": "Ez bi kêmî goşt dixwim."
            },
            {
              "language": "pl",
              "text": "Rzadko jem mięso."
            },
            {
              "language": "ro",
              "text": "Mănânc rar carne."
            },
            {
              "language": "ru",
              "text": "Я редко ем мясо."
            },
            {
              "language": "sq",
              "text": "Unë rrallë ha mish."
            },
            {
              "language": "tr",
              "text": "Nadiren et yerim."
            }
          ]
        },
        {
          "baseText": "Der Bus kommt hier nur selten.",
          "translations": [
            {
              "language": "ar",
              "text": "الحافلة تأتي هنا نادراً فقط."
            },
            {
              "language": "ckb",
              "text": "پاسەکە لێرە تەنها بە دەگمەن دێت."
            },
            {
              "language": "en",
              "text": "The bus only comes here rarely."
            },
            {
              "language": "fa",
              "text": "اتوبوس اینجا فقط به‌ندرت می‌آید."
            },
            {
              "language": "kmr",
              "text": "Otobûs li vir tenê bi kêmî tê."
            },
            {
              "language": "pl",
              "text": "Autobus przyjeżdża tu tylko rzadko."
            },
            {
              "language": "ro",
              "text": "Autobuzul vine aici doar rareori."
            },
            {
              "language": "ru",
              "text": "Автобус здесь ходит редко."
            },
            {
              "language": "sq",
              "text": "Autobusi vjen këtu vetëm rrallë."
            },
            {
              "language": "tr",
              "text": "Otobüs buraya sadece seyrek gelir."
            }
          ]
        }
      ]
