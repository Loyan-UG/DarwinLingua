      ],
      "examples": [
        {
          "baseText": "Darf ich hier fotografieren?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني أن أصوّر هنا؟"
            },
            {
              "language": "ckb",
              "text": "ئایا دەتوانم لێرە وێنە بگرم؟"
            },
            {
              "language": "en",
              "text": "May I take pictures here?"
            },
            {
              "language": "fa",
              "text": "می‌توانم اینجا عکس بگیرم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim li vir wêne bigirim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę tutaj fotografować?"
            },
            {
              "language": "ro",
              "text": "Pot să fac poze aici?"
            },
            {
              "language": "ru",
              "text": "Можно здесь фотографировать?"
            },
            {
              "language": "sq",
              "text": "A mund të fotografoj këtu?"
            },
            {
              "language": "tr",
              "text": "Burada fotoğraf çekebilir miyim?"
            }
          ]
        },
        {
          "baseText": "Sie fotografiert den Kuchen für ihre Freundin.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تصوّر الكعكة لصديقتها."
            },
            {
              "language": "ckb",
              "text": "ئەو وێنەی کێکەکە بۆ هاوڕێکەی دەگرێت."
            },
            {
              "language": "en",
              "text": "She takes a picture of the cake for her friend."
            },
            {
              "language": "fa",
              "text": "او از کیک برای دوستش عکس می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Ew ji bo hevala xwe wêneyê kekê digire."
            },
            {
              "language": "pl",
              "text": "Ona fotografuje ciasto dla swojej przyjaciółki."
            },
            {
              "language": "ro",
              "text": "Ea fotografiază tortul pentru prietena ei."
            },
            {
              "language": "ru",
              "text": "Она фотографирует торт для своей подруги."
            },
            {
              "language": "sq",
              "text": "Ajo fotografon tortën për shoqen e saj."
            },
            {
              "language": "tr",
              "text": "Arkadaşı için pastanın fotoğrafını çekiyor."
            }
          ]
        }
      ]
