      "examples": [
        {
          "baseText": "Ich frage im Hotel nach dem WLAN-Passwort.",
          "translations": [
            {
              "language": "ar",
              "text": "أسأل في الفندق عن كلمة مرور الواي فاي."
            },
            {
              "language": "ckb",
              "text": "لە هۆتێل پرسیاری وشەی نهێنی وایفای دەکەم."
            },
            {
              "language": "en",
              "text": "I ask at the hotel for the Wi-Fi password."
            },
            {
              "language": "fa",
              "text": "در هتل درباره رمز وای‌فای می‌پرسم."
            },
            {
              "language": "kmr",
              "text": "Ez li otêlê li ser şîfreya Wi-Fi-yê dipirsim."
            },
            {
              "language": "pl",
              "text": "Pytam w hotelu o hasło do Wi-Fi."
            },
            {
              "language": "ro",
              "text": "Întreb la hotel despre parola Wi-Fi."
            },
            {
              "language": "ru",
              "text": "Я спрашиваю в отеле пароль от Wi-Fi."
            },
            {
              "language": "sq",
              "text": "Pyes në hotel për fjalëkalimin e Wi-Fi-t."
            },
            {
              "language": "tr",
              "text": "Otelde Wi-Fi şifresini soruyorum."
            }
          ]
        },
        {
          "baseText": "Der Kunde fragt nach einer kleineren Größe.",
          "translations": [
            {
              "language": "ar",
              "text": "الزبون يسأل عن مقاس أصغر."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە پرسیاری قەبارەیەکی بچووکتر دەکات."
            },
            {
              "language": "en",
              "text": "The customer asks for a smaller size."
            },
            {
              "language": "fa",
              "text": "مشتری یک سایز کوچک‌تر می‌خواهد."
            },
            {
              "language": "kmr",
              "text": "Mişterî li ser mezinahiyeke biçûktir dipirse."
            },
            {
              "language": "pl",
              "text": "Klient pyta o mniejszy rozmiar."
            },
            {
              "language": "ro",
              "text": "Clientul întreabă de o mărime mai mică."
            },
            {
              "language": "ru",
              "text": "Клиент спрашивает размер поменьше."
            },
            {
              "language": "sq",
              "text": "Klienti pyet për një masë më të vogël."
            },
            {
              "language": "tr",
              "text": "Müşteri daha küçük bir beden soruyor."
            }
          ]
        }
