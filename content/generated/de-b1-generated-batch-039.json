  "entries": [
    {
      "word": "die Chefin",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Chefinnen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Che-fin",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "business-communication"
      ],
      "usageLabels": [
        "spoken",
        "business",
        "formal"
      ],
      "contextLabels": [
        "management",
        "hr"
      ],
      "grammarNotes": [
        "feminine noun; female boss or manager"
      ],
      "collocations": [
        {
          "text": "mit der Chefin sprechen",
          "meaning": "to speak with the female boss"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Chef",
          "relationLabel": "masculine noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "المديرة؛ الرئيسة"
        },
        {
          "language": "ckb",
          "text": "سەرۆکە ژن؛ بەڕێوەبەری ژن"
        },
        {
          "language": "en",
          "text": "female boss; manager"
        },
        {
          "language": "fa",
          "text": "رئیس زن؛ مدیر زن"
        },
        {
          "language": "kmr",
          "text": "seroka jin; rêvebera jin"
        },
        {
          "language": "pl",
          "text": "szefowa; kierowniczka"
        },
        {
          "language": "ro",
          "text": "șefă; directoare"
        },
        {
          "language": "ru",
          "text": "начальница; руководительница"
        },
        {
          "language": "sq",
          "text": "shefe; menaxhere"
        },
        {
          "language": "tr",
          "text": "kadın patron; yönetici"
        }
      ],
      "examples": [
        {
          "baseText": "Meine Chefin hat das Meeting auf morgen verschoben.",
          "translations": [
            {
              "language": "ar",
              "text": "أجلت مديرتي الاجتماع إلى الغد."
            },
            {
              "language": "ckb",
              "text": "سەرۆکەکەم کۆبوونەوەکەی بۆ سبەی دواخست."
            },
            {
              "language": "en",
              "text": "My boss postponed the meeting until tomorrow."
            },
            {
              "language": "fa",
              "text": "رئیس من جلسه را به فردا موکول کرد."
            },
            {
              "language": "kmr",
              "text": "Seroka min civînê heta sibê paş xist."
            },
            {
              "language": "pl",
              "text": "Moja szefowa przełożyła spotkanie na jutro."
            },
            {
              "language": "ro",
              "text": "Șefa mea a amânat ședința pe mâine."
            },
            {
              "language": "ru",
              "text": "Моя начальница перенесла встречу на завтра."
            },
            {
              "language": "sq",
              "text": "Shefja ime e shtyu takimin për nesër."
            },
            {
              "language": "tr",
              "text": "Kadın yöneticim toplantıyı yarına erteledi."
            }
          ]
        },
        {
          "baseText": "Die Chefin erklärt den neuen Mitarbeitenden die wichtigsten Abläufe.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح المديرة للموظفين الجدد أهم الإجراءات."
            },
            {
              "language": "ckb",
              "text": "سەرۆکە ژنەکە گرنگترین ڕێڕەوەکان بۆ کارمەندانی نوێ ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The manager explains the most important processes to the new employees."
            },
            {
              "language": "fa",
              "text": "مدیر زن مهم‌ترین روندها را برای کارکنان جدید توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Rêvebera jin pêvajoyên herî girîng ji karmendên nû re şirove dike."
            },
            {
              "language": "pl",
              "text": "Szefowa wyjaśnia nowym pracownikom najważniejsze procesy."
            },
            {
              "language": "ro",
              "text": "Șefa le explică noilor angajați cele mai importante proceduri."
            },
            {
              "language": "ru",
              "text": "Руководительница объясняет новым сотрудникам основные процессы."
            },
            {
              "language": "sq",
              "text": "Shefja u shpjegon punonjësve të rinj proceset më të rëndësishme."
            },
            {
              "language": "tr",
              "text": "Kadın yönetici yeni çalışanlara en önemli süreçleri açıklıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "der Container",
      "language": "de",
