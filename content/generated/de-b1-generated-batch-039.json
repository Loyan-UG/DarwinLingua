      "meanings": [
        {
          "language": "ar",
          "text": "حاوية"
        },
        {
          "language": "ckb",
          "text": "کۆنتێنەر"
        },
        {
          "language": "en",
          "text": "container"
        },
        {
          "language": "fa",
          "text": "کانتینر"
        },
        {
          "language": "kmr",
          "text": "konteyner"
        },
        {
          "language": "pl",
          "text": "kontener"
        },
        {
          "language": "ro",
          "text": "container"
        },
        {
          "language": "ru",
          "text": "контейнер"
        },
        {
          "language": "sq",
          "text": "kontejner"
        },
        {
          "language": "tr",
          "text": "konteyner"
        }
      ],
      "examples": [
        {
          "baseText": "Der Container mit den Ersatzteilen kommt erst am Freitag an.",
          "translations": [
            {
              "language": "ar",
              "text": "تصل الحاوية التي تحتوي على قطع الغيار يوم الجمعة فقط."
            },
            {
              "language": "ckb",
              "text": "کۆنتێنەری پارچە یەدەگەکان تەنها ڕۆژی هەینی دەگات."
            },
            {
              "language": "en",
              "text": "The container with the spare parts will not arrive until Friday."
            },
            {
              "language": "fa",
              "text": "کانتینر قطعات یدکی تازه جمعه می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Konteynera bi parçeyên rezerve tenê roja înê digihîje."
            },
            {
              "language": "pl",
              "text": "Kontener z częściami zamiennymi przyjedzie dopiero w piątek."
            },
            {
              "language": "ro",
              "text": "Containerul cu piese de schimb ajunge abia vineri."
            },
            {
              "language": "ru",
              "text": "Контейнер с запчастями прибудет только в пятницу."
            },
            {
              "language": "sq",
              "text": "Kontejneri me pjesët rezervë arrin vetëm të premten."
            },
            {
              "language": "tr",
              "text": "Yedek parçaların olduğu konteyner ancak cuma günü gelecek."
            }
          ]
        },
        {
          "baseText": "Bitte stellen Sie den leeren Container nicht vor die Einfahrt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى عدم وضع الحاوية الفارغة أمام المدخل."
            },
            {
              "language": "ckb",
              "text": "تکایە کۆنتێنەری بەتاڵ لەبەردەم دەروازەکە دانەنێن."
            },
            {
              "language": "en",
              "text": "Please do not place the empty container in front of the driveway."
            },
            {
              "language": "fa",
              "text": "لطفاً کانتینر خالی را جلوی ورودی نگذارید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe konteynera vala li ber dergehê daneynin."
            },
            {
              "language": "pl",
              "text": "Proszę nie stawiać pustego kontenera przed wjazdem."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să nu puneți containerul gol în fața intrării."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не ставьте пустой контейнер перед въездом."
            },
            {
              "language": "sq",
              "text": "Ju lutemi mos e vendosni kontejnerin bosh para hyrjes."
            },
            {
              "language": "tr",
              "text": "Lütfen boş konteyneri girişin önüne koymayın."
            }
          ]
        }
      ]
    },
