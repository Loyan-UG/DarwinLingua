  "entries": [
    {
      "word": "deshalb",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "des-halb",
      "topics": [
        "business-communication",
        "everyday-life",
        "documents-and-administration"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "formal"
      ],
      "contextLabels": [
        "documents",
        "administration"
      ],
      "grammarNotes": [
        "adverb connecting a reason with a consequence; finite verb normally follows directly after deshalb"
      ],
      "collocations": [
        {
          "text": "deshalb müssen wir",
          "meaning": "therefore we have to"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "لذلك؛ لهذا السبب"
        },
        {
          "language": "ckb",
          "text": "بۆیە؛ لەبەر ئەوە"
        },
        {
          "language": "en",
          "text": "therefore; for that reason"
        },
        {
          "language": "fa",
          "text": "به همین دلیل؛ بنابراین"
        },
        {
          "language": "kmr",
          "text": "ji ber vê yekê; lewra"
        },
        {
          "language": "pl",
          "text": "dlatego; z tego powodu"
        },
        {
          "language": "ro",
          "text": "de aceea; din acest motiv"
        },
        {
          "language": "ru",
          "text": "поэтому; по этой причине"
        },
        {
          "language": "sq",
          "text": "prandaj; për këtë arsye"
        },
        {
          "language": "tr",
          "text": "bu yüzden; bu nedenle"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kunde hat die falsche Adresse angegeben, deshalb kommt das Paket später an.",
          "translations": [
            {
              "language": "ar",
              "text": "أعطى العميل عنوانًا خاطئًا، لذلك ستصل الطرد لاحقًا."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە ناونیشانی هەڵەی داوە، بۆیە پاکەتەکە درەنگتر دەگات."
            },
            {
              "language": "en",
              "text": "The customer gave the wrong address, so the package will arrive later."
            },
            {
              "language": "fa",
              "text": "مشتری آدرس اشتباه داده است، به همین دلیل بسته دیرتر می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Xerîdar navnîşana şaş daye, ji ber vê yekê pakêt derengtir digihîje."
            },
            {
              "language": "pl",
              "text": "Klient podał zły adres, dlatego paczka dotrze później."
            },
            {
              "language": "ro",
              "text": "Clientul a indicat adresa greșită, de aceea coletul va ajunge mai târziu."
            },
            {
              "language": "ru",
              "text": "Клиент указал неправильный адрес, поэтому посылка придет позже."
            },
            {
              "language": "sq",
              "text": "Klienti dha adresën e gabuar, prandaj pakoja do të arrijë më vonë."
            },
            {
              "language": "tr",
              "text": "Müşteri yanlış adres verdi, bu yüzden paket daha geç ulaşacak."
            }
          ]
        },
        {
          "baseText": "Ich habe morgen früh einen Arzttermin, deshalb komme ich später ins Büro.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي موعد طبي صباح الغد، لذلك سآتي إلى المكتب متأخرًا."
            },
            {
              "language": "ckb",
              "text": "سبەی بەیانی کاتی پزیشکم هەیە، بۆیە درەنگتر دێم بۆ ئۆفیس."
            },
            {
              "language": "en",
              "text": "I have a doctor’s appointment tomorrow morning, so I will come to the office later."
            },
            {
              "language": "fa",
              "text": "فردا صبح وقت دکتر دارم، به همین دلیل دیرتر به دفتر می‌آیم."
            },
            {
              "language": "kmr",
              "text": "Sibê sibehê hevdîtina bijîşk heye, ji ber vê yekê ez derengtir têm nivîsgehê."
            },
            {
              "language": "pl",
              "text": "Jutro rano mam wizytę u lekarza, dlatego przyjdę później do biura."
            },
            {
              "language": "ro",
              "text": "Mâine dimineață am o programare la medic, de aceea voi veni mai târziu la birou."
            },
            {
              "language": "ru",
              "text": "Завтра утром у меня прием у врача, поэтому я приду в офис позже."
            },
            {
              "language": "sq",
              "text": "Nesër në mëngjes kam takim te mjeku, prandaj do të vij më vonë në zyrë."
            },
            {
              "language": "tr",
              "text": "Yarın sabah doktor randevum var, bu yüzden ofise daha geç geleceğim."
            }
          ]
        }
      ]
    },
    {
      "word": "detailliert",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "de-tail-liert",
      "topics": [
        "business-communication",
        "documents-and-administration",
        "data-and-reporting"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "documents",
        "administration"
      ],
      "grammarNotes": [
        "adjective/adverb; describes something with many details"
      ],
      "collocations": [
        {
          "text": "eine detaillierte Beschreibung",
          "meaning": "a detailed description"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Detail",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مفصل؛ دقيق التفاصيل"
        },
        {
          "language": "ckb",
          "text": "ورد؛ بە تەفصیل"
        },
        {
          "language": "en",
          "text": "detailed"
        },
        {
          "language": "fa",
          "text": "جزئی؛ مفصل"
        },
        {
          "language": "kmr",
          "text": "bi hûrgilî; berfireh"
        },
        {
          "language": "pl",
          "text": "szczegółowy"
        },
        {
          "language": "ro",
          "text": "detaliat"
        },
        {
          "language": "ru",
          "text": "подробный; детальный"
        },
        {
          "language": "sq",
          "text": "i detajuar"
        },
        {
          "language": "tr",
          "text": "ayrıntılı; detaylı"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schicken Sie uns eine detaillierte Beschreibung des Fehlers.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال وصف مفصل للخطأ إلينا."
            },
            {
              "language": "ckb",
              "text": "تکایە وەسفێکی وردی هەڵەکە بۆمان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us a detailed description of the error."
            },
            {
              "language": "fa",
              "text": "لطفاً توضیح دقیقی از خطا برای ما بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe danasîneke bi hûrgilî ya çewtiyê ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać nam szczegółowy opis błędu."
            },
            {
