  "entries": [
    {
      "word": "Fahrzeugortung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Fahrzeugortungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fahr-zeug-or-tung",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP/business term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تتبع المركبات"
        },
        {
          "language": "ckb",
          "text": "شوێنپێهەڵگرتنی ئۆتۆمبێل"
        },
        {
          "language": "en",
          "text": "vehicle tracking"
        },
        {
          "language": "fa",
          "text": "ردیابی خودرو"
        },
        {
          "language": "kmr",
          "text": "şopandina wesayîtê"
        },
        {
          "language": "pl",
          "text": "lokalizacja pojazdów"
        },
        {
          "language": "ro",
          "text": "localizare vehicule"
        },
        {
          "language": "ru",
          "text": "отслеживание транспорта"
        },
        {
          "language": "sq",
          "text": "gjurmim automjetesh"
        },
        {
          "language": "tr",
          "text": "araç takibi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Fahrzeugortung übermittelt dem ERP die aktuelle Position des Lkw, damit der Wareneingang die Rampe rechtzeitig planen kann.",
          "translations": [
            {
              "language": "ar",
              "text": "يرسل تتبع المركبات إلى ERP موقع الشاحنة الحالي كي يخطط استلام البضائع للرصيف في الوقت المناسب."
            },
            {
              "language": "ckb",
              "text": "شوێنپێهەڵگرتنی ئۆتۆمبێل شوێنی لۆری بۆ ERP دەنێرێت."
            },
            {
              "language": "en",
              "text": "Vehicle tracking sends the truck position to the ERP system so goods receipt can plan the dock in time."
            },
            {
              "language": "fa",
              "text": "ردیابی خودرو موقعیت کامیون را به ERP می‌فرستد تا ورود کالا سکو را به‌موقع برنامه‌ریزی کند."
            },
            {
              "language": "kmr",
              "text": "Şopandina wesayîtê cihê kamyonê dişîne ERP."
            },
            {
              "language": "pl",
              "text": "Lokalizacja pojazdów przekazuje do ERP pozycję ciężarówki."
            },
            {
              "language": "ro",
              "text": "Localizarea vehiculelor trimite în ERP poziția camionului."
            },
            {
              "language": "ru",
              "text": "Отслеживание транспорта передает в ERP положение грузовика."
            },
            {
              "language": "sq",
              "text": "Gjurmimi i automjeteve dërgon në ERP pozicionin e kamionit."
            },
            {
              "language": "tr",
              "text": "Araç takibi kamyon konumunu ERP sistemine gönderir."
            }
          ]
        },
        {
          "baseText": "Aus Datenschutzgründen darf die Fahrzeugortung außerhalb der Arbeitszeit nur in begründeten Ausnahmefällen aktiv bleiben.",
          "translations": [
            {
              "language": "ar",
              "text": "لأسباب حماية البيانات لا يبقى تتبع المركبات نشطًا خارج وقت العمل إلا في حالات مبررة."
            },
            {
              "language": "ckb",
              "text": "بەهۆی پاراستنی داتا، شوێنپێهەڵگرتن دەرەوەی کاتی کار تەنها بە هۆکارێکی ڕوون چالاک دەبێت."
            },
            {
              "language": "en",
              "text": "For data protection reasons, vehicle tracking may stay active outside working hours only in justified exceptions."
            },
            {
              "language": "fa",
              "text": "به دلایل حفاظت داده، ردیابی خودرو خارج از ساعت کاری فقط در موارد موجه فعال می‌ماند."
            },
            {
              "language": "kmr",
              "text": "Ji ber parastina daneyan, şopandin tenê di rewşên hincetdar de çalak dimîne."
            },
            {
              "language": "pl",
              "text": "Ze względów ochrony danych lokalizacja działa poza pracą tylko w uzasadnionych wyjątkach."
            },
            {
              "language": "ro",
              "text": "Din motive de protecție a datelor, localizarea rămâne activă doar în excepții justificate."
            },
            {
              "language": "ru",
              "text": "По защите данных отслеживание вне работы допустимо только в обоснованных исключениях."
            },
            {
              "language": "sq",
              "text": "Për mbrojtjen e të dhënave, gjurmimi jashtë orarit lejohet vetëm në raste të arsyetuara."
            },
            {
              "language": "tr",
              "text": "Veri koruma nedeniyle araç takibi mesai dışında yalnızca gerekçeli istisnalarda açık kalır."
            }
          ]
        }
      ]
    },
    {
      "word": "Festplatzzuordnung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Festplatzzuordnungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fest-platz-zu-ord-nung",
      "topics": [
        "warehouse-and-logistics",
        "erp-and-business-systems",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP/business term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تخصيص موقع ثابت"
        },
        {
          "language": "ckb",
          "text": "تەرخانکردنی شوێنی جێگیر"
        },
        {
          "language": "en",
          "text": "fixed-bin assignment"
        },
        {
          "language": "fa",
          "text": "تخصیص محل ثابت"
        },
        {
          "language": "kmr",
          "text": "tayînkirina cihê sabît"
        },
        {
          "language": "pl",
          "text": "przypisanie stałego miejsca"
        },
        {
          "language": "ro",
          "text": "alocare locație fixă"
        },
        {
          "language": "ru",
          "text": "назначение фиксированного места"
        },
        {
          "language": "sq",
          "text": "caktim vendi fiks"
        },
        {
          "language": "tr",
          "text": "sabit göz ataması"
        }
      ],
      "examples": [
        {
          "baseText": "Die Festplatzzuordnung sorgt im ERP dafür, dass schnell drehende Artikel nahe der Kommissionierzone liegen.",
          "translations": [
            {
              "language": "ar",
              "text": "يضمن تخصيص الموقع الثابت في ERP بقاء الأصناف سريعة الدوران قرب منطقة الانتقاء."
            },
            {
              "language": "ckb",
              "text": "تەرخانکردنی شوێنی جێگیر کاڵای خێراگەر نزیک ناوچەی کۆکردنەوە دادەنێت."
            },
            {
              "language": "en",
              "text": "The fixed-bin assignment ensures in ERP that fast-moving items are stored near the picking zone."
            },
            {
              "language": "fa",
              "text": "تخصیص محل ثابت در ERP کالاهای پرگردش را نزدیک منطقه برداشت نگه می‌دارد."
            },
            {
              "language": "kmr",
              "text": "Tayînkirina cihê sabît gotarên zû digerin nêzîkî qada komkirinê datîne."
            },
            {
              "language": "pl",
              "text": "Przypisanie stałego miejsca trzyma szybko rotujące artykuły blisko kompletacji."
            },
            {
              "language": "ro",
              "text": "Alocarea locației fixe ține articolele rapide lângă zona de picking."
            },
            {
              "language": "ru",
              "text": "Фиксированное место держит быстрооборачиваемые товары рядом с зоной подбора."
            },
            {
              "language": "sq",
              "text": "Caktimi i vendit fiks i mban artikujt e shpejtë pranë zonës së përzgjedhjes."
            },
            {
              "language": "tr",
              "text": "Sabit göz ataması hızlı ürünleri toplama bölgesine yakın tutar."
            }
          ]
        },
        {
          "baseText": "Nach der Erweiterung des Lagers musste die Festplatzzuordnung neu bewertet werden, weil alte Laufwege nicht mehr effizient waren.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد توسعة المستودع أُعيد تقييم تخصيص المواقع الثابتة لأن المسارات القديمة لم تعد فعالة."
            },
            {
              "language": "ckb",
              "text": "دوای فراوانکردنی کۆگا، تەرخانکردنی شوێنەکان دووبارە هەڵسەنگێنرا."
            },
            {
              "language": "en",
              "text": "After the warehouse expansion, the fixed-bin assignment had to be reassessed because old walking routes were no longer efficient."
            },
            {
              "language": "fa",
              "text": "بعد از توسعه انبار، تخصیص محل ثابت دوباره ارزیابی شد چون مسیرهای قدیمی کارآمد نبودند."
            },
            {
              "language": "kmr",
              "text": "Piştî firehkirina depoyê, tayînkirina cihê sabît ji nû ve hat nirxandin."
            },
            {
              "language": "pl",
              "text": "Po rozbudowie magazynu ponownie oceniono przypisanie stałych miejsc."
            },
            {
              "language": "ro",
              "text": "După extinderea depozitului, alocarea locațiilor fixe a fost reevaluată."
            },
            {
              "language": "ru",
              "text": "После расширения склада назначение фиксированных мест пересмотрели."
            },
            {
              "language": "sq",
              "text": "Pas zgjerimit të magazinës, caktimi i vendeve fikse u rivlerësua."
            },
            {
              "language": "tr",
              "text": "Depo genişletilince sabit göz ataması yeniden değerlendirildi."
            }
          ]
        }
      ]
    },
    {
      "word": "Folgekommissionierung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Folgekommissionierungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fol-ge-kom-mis-si-o-nie-rung",
      "topics": [
        "warehouse-and-logistics",
        "erp-and-business-systems",
        "sales-and-customers"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP/business term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "انتقاء لاحق"
        },
        {
          "language": "ckb",
          "text": "کۆکردنەوەی دواتر"
        },
        {
          "language": "en",
          "text": "subsequent picking"
        },
        {
          "language": "fa",
          "text": "برداشت بعدی کالا"
        },
        {
          "language": "kmr",
          "text": "komkirina paşîn"
        },
        {
          "language": "pl",
          "text": "kompletacja następcza"
        },
        {
          "language": "ro",
          "text": "picking ulterior"
        },
        {
          "language": "ru",
          "text": "последующий подбор"
        },
        {
          "language": "sq",
          "text": "përzgjedhje pasuese"
        },
        {
          "language": "tr",
          "text": "sonraki toplama"
        }
      ],
      "examples": [
        {
          "baseText": "Die Folgekommissionierung wird im ERP ausgelöst, wenn nach der ersten Welle noch Restmengen verfügbar werden.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدأ عملية الانتقاء اللاحق في ERP عندما تصبح كميات متبقية متاحة بعد الموجة الأولى."
            },
            {
              "language": "ckb",
              "text": "کۆکردنەوەی دواتر لە ERPدا دەستپێدەکات کاتێک بڕی ماوە بەردەست دەبێت."
            },
            {
              "language": "en",
              "text": "Subsequent picking is triggered in ERP when remaining quantities become available after the first wave."
            },
            {
              "language": "fa",
              "text": "برداشت بعدی در ERP وقتی فعال می‌شود که بعد از موج اول مقدار باقی‌مانده موجود شود."
            },
            {
              "language": "kmr",
              "text": "Komkirina paşîn di ERP de dest pê dike dema hejmarên mayî berdest dibin."
            },
            {
              "language": "pl",
              "text": "Kompletacja następcza uruchamia się w ERP, gdy dostępne są pozostałe ilości."
            },
            {
              "language": "ro",
              "text": "Pickingul ulterior pornește în ERP când devin disponibile cantități rămase."
            },
            {
              "language": "ru",
              "text": "Последующий подбор запускается в ERP, когда становятся доступны остатки."
            },
            {
              "language": "sq",
              "text": "Përzgjedhja pasuese nis në ERP kur sasitë e mbetura bëhen të disponueshme."
            },
            {
              "language": "tr",
              "text": "Sonraki toplama ERP içinde kalan miktarlar kullanılabilir olunca tetiklenir."
            }
          ]
        },
        {
          "baseText": "Der Schichtleiter verschob die Folgekommissionierung, damit ein dringender Ersatzteilauftrag vor der Abholung fertig wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "أجل رئيس الوردية الانتقاء اللاحق كي يكتمل طلب قطع غيار عاجل قبل الاستلام."
            },
            {
              "language": "ckb",
              "text": "سەرپەرشتیاری شیفت کۆکردنەوەی دواتری دواخست تاکو داواکاری پەلە تەواو بێت."
            },
            {
              "language": "en",
              "text": "The shift supervisor postponed subsequent picking so an urgent spare-parts order was ready before pickup."
            },
            {
              "language": "fa",
