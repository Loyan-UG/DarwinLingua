      "examples": [
        {
          "baseText": "Der Energieverbrauch im Büro ist im Winter deutlich höher.",
          "translations": [
            {
              "language": "ar",
              "text": "استهلاك الطاقة في المكتب أعلى بكثير في الشتاء."
            },
            {
              "language": "ckb",
              "text": "بەکارهێنانی وزە لە ئۆفیسدا لە زستاندا بە شێوەیەکی بەرچاو زیاترە."
            },
            {
