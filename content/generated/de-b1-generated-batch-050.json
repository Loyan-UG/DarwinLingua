  "entries": [
    {
      "word": "die Energiesparlampe",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Energiesparlampen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "E-ner-gie-spar-lam-pe",
      "topics": [
        "environment-and-sustainability",
        "everyday-life",
        "shopping-and-services"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "sustainability",
        "customer-service"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Energiesparlampe einsetzen",
          "meaning": "to use an energy-saving lamp"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Energie",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "sparen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مصباح موفر للطاقة"
        },
        {
          "language": "ckb",
          "text": "گڵۆپی پاشەکەوتی وزە"
        },
        {
          "language": "en",
          "text": "energy-saving lamp"
        },
        {
          "language": "fa",
          "text": "لامپ کم‌مصرف"
        },
        {
          "language": "kmr",
          "text": "lampaya enerjîspar"
        },
        {
          "language": "pl",
          "text": "żarówka energooszczędna"
        },
        {
          "language": "ro",
          "text": "lampă economică"
        },
        {
          "language": "ru",
          "text": "энергосберегающая лампа"
        },
        {
          "language": "sq",
          "text": "llambë kursimi energjie"
        },
        {
          "language": "tr",
          "text": "enerji tasarruflu lamba"
        }
      ],
      "examples": [
        {
          "baseText": "Im Flur wurde die alte Lampe durch eine Energiesparlampe ersetzt.",
          "translations": [
            {
              "language": "ar",
              "text": "في الممر تم استبدال المصباح القديم بمصباح موفر للطاقة."
            },
            {
              "language": "ckb",
              "text": "لە ڕاڕەوەکەدا گڵۆپی کۆن بە گڵۆپی پاشەکەوتی وزە گۆڕدرایەوە."
            },
            {
              "language": "en",
              "text": "In the hallway, the old lamp was replaced with an energy-saving lamp."
            },
            {
              "language": "fa",
              "text": "در راهرو، لامپ قدیمی با یک لامپ کم‌مصرف جایگزین شد."
            },
            {
              "language": "kmr",
              "text": "Li korîdorê lampaya kevn bi lampayeke enerjîspar hate guhertin."
            },
            {
              "language": "pl",
              "text": "Na korytarzu starą lampę zastąpiono żarówką energooszczędną."
            },
            {
              "language": "ro",
              "text": "Pe hol, lampa veche a fost înlocuită cu o lampă economică."
            },
            {
              "language": "ru",
              "text": "В коридоре старую лампу заменили на энергосберегающую."
            },
            {
              "language": "sq",
              "text": "Në korridor, llamba e vjetër u zëvendësua me një llambë kursimi energjie."
            },
            {
              "language": "tr",
              "text": "Koridordaki eski lamba enerji tasarruflu bir lambayla değiştirildi."
            }
          ]
        },
        {
          "baseText": "Die Energiesparlampe kostet etwas mehr, verbraucht aber weniger Strom.",
          "translations": [
            {
              "language": "ar",
              "text": "المصباح الموفر للطاقة يكلف أكثر قليلًا، لكنه يستهلك كهرباء أقل."
            },
            {
              "language": "ckb",
              "text": "گڵۆپی پاشەکەوتی وزە کەمێک گرانترە، بەڵام کارەبای کەمتر بەکاردەهێنێت."
            },
            {
              "language": "en",
              "text": "The energy-saving lamp costs a little more but uses less electricity."
            },
            {
              "language": "fa",
              "text": "لامپ کم‌مصرف کمی گران‌تر است، اما برق کمتری مصرف می‌کند."
            },
            {
              "language": "kmr",
              "text": "Lampaya enerjîspar hinekî bihatir e, lê elektrîka kêmtir dixwe."
            },
            {
              "language": "pl",
              "text": "Żarówka energooszczędna kosztuje trochę więcej, ale zużywa mniej prądu."
            },
            {
              "language": "ro",
              "text": "Lampa economică costă puțin mai mult, dar consumă mai puțin curent."
            },
            {
              "language": "ru",
              "text": "Энергосберегающая лампа стоит немного дороже, но потребляет меньше электричества."
            },
            {
              "language": "sq",
              "text": "Llamba kursyese kushton pak më shumë, por harxhon më pak energji."
            },
            {
              "language": "tr",
              "text": "Enerji tasarruflu lamba biraz daha pahalıdır ama daha az elektrik tüketir."
            }
          ]
        }
      ]
    },
