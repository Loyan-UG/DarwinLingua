      ],
      "examples": [
        {
          "baseText": "Vor der Einführung der neuen Software brauchen wir eine ehrliche Nutzenabwägung.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل إدخال البرنامج الجديد نحتاج إلى موازنة صادقة للفوائد."
            },
            {
