  "entries": [
    {
      "word": "die Normsetzung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Normsetzungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Norm-set-zung",
      "topics": [
        "law-and-compliance",
        "documents-and-administration",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "Normsetzung und Kontrolle trennen",
          "meaning": "to separate standard-setting and control"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "normsetzend",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Norm",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وضع المعايير؛ سنّ القواعد"
        },
        {
          "language": "ckb",
          "text": "دانانی پێوەر؛ دانانی هەنجار"
        },
        {
          "language": "en",
          "text": "standard-setting; norm-setting"
        },
        {
          "language": "fa",
          "text": "هنجارگذاری؛ تعیین معیار"
        },
        {
          "language": "kmr",
          "text": "danîna norman"
        },
        {
          "language": "pl",
          "text": "ustanawianie norm"
        },
        {
          "language": "ro",
          "text": "stabilire de norme"
        },
        {
          "language": "ru",
          "text": "установление норм"
        },
        {
          "language": "sq",
          "text": "vendosje normash"
        },
        {
          "language": "tr",
          "text": "norm koyma; standart belirleme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Normsetzung sollte transparent erfolgen, damit Betroffene die Regeln nachvollziehen können.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي أن يتم وضع المعايير بشفافية حتى يتمكن المتأثرون من فهم القواعد."
            },
            {
              "language": "ckb",
              "text": "دانانی پێوەر دەبێت بە ڕوونی ئەنجام بدرێت بۆ ئەوەی پەیوەندیداران بتوانن یاساکان تێبگەن."
            },
            {
              "language": "en",
              "text": "Standard-setting should be transparent so that those affected can understand the rules."
            },
            {
              "language": "fa",
              "text": "هنجارگذاری باید شفاف انجام شود تا افراد درگیر بتوانند قواعد را درک کنند."
            },
            {
              "language": "kmr",
              "text": "Danîna norman divê bi zelalî were kirin da ku kesên bandor lêkirî bikarin rêzikan fêm bikin."
            },
            {
              "language": "pl",
              "text": "Ustanawianie norm powinno odbywać się przejrzyście, aby osoby dotknięte mogły zrozumieć zasady."
            },
            {
              "language": "ro",
              "text": "Stabilirea normelor ar trebui să fie transparentă, pentru ca persoanele afectate să poată înțelege regulile."
            },
            {
              "language": "ru",
              "text": "Установление норм должно быть прозрачным, чтобы затронутые лица могли понять правила."
            },
            {
              "language": "sq",
              "text": "Vendosja e normave duhet të bëhet në mënyrë transparente, që të prekurit t’i kuptojnë rregullat."
            },
            {
              "language": "tr",
              "text": "Norm koyma süreci şeffaf olmalıdır ki etkilenen kişiler kuralları anlayabilsin."
            }
          ]
        },
        {
          "baseText": "In vielen Branchen übernehmen private Zertifizierer faktisch Aufgaben der Normsetzung.",
          "translations": [
            {
              "language": "ar",
              "text": "في كثير من القطاعات يتولى المصدّقون الخاصون فعلياً مهام وضع المعايير."
            },
            {
              "language": "ckb",
              "text": "لە زۆر پیشەدا پەسەندکەرانی تایبەت بە کردەوە ئەرکی دانانی پێوەر دەگرنە ئەستۆ."
            },
            {
              "language": "en",
              "text": "In many industries, private certifiers effectively take on standard-setting tasks."
            },
            {
              "language": "fa",
              "text": "در بسیاری از صنایع، گواهی‌دهندگان خصوصی عملاً وظایف هنجارگذاری را بر عهده می‌گیرند."
            },
            {
              "language": "kmr",
              "text": "Di gelek sektoran de belgekerên taybet bi rastî erkên danîna norman digirin ser xwe."
            },
            {
              "language": "pl",
              "text": "W wielu branżach prywatni certyfikatorzy faktycznie przejmują zadania ustanawiania norm."
            },
            {
              "language": "ro",
              "text": "În multe industrii, certificatorii privați preiau în fapt sarcini de stabilire a normelor."
            },
            {
              "language": "ru",
              "text": "Во многих отраслях частные сертифицирующие организации фактически берут на себя задачи установления норм."
            },
            {
              "language": "sq",
              "text": "Në shumë industri, certifikuesit privatë faktikisht marrin përsipër detyra të vendosjes së normave."
            },
            {
              "language": "tr",
              "text": "Birçok sektörde özel sertifikasyon kuruluşları fiilen standart belirleme görevleri üstlenir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Nuance",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Nuancen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Nu-an-ce",
      "topics": [
        "business-communication",
        "culture-and-media",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine feine Nuance",
          "meaning": "a subtle nuance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "nuanciert",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فارق دقيق؛ درجة خفيفة"
        },
        {
          "language": "ckb",
          "text": "جیاوازییەکی ناسک؛ نوانس"
        },
        {
          "language": "en",
          "text": "nuance; subtle difference"
        },
        {
          "language": "fa",
          "text": "ظرافت معنایی؛ تفاوت جزئی"
        },
        {
          "language": "kmr",
          "text": "nuans; cudahiya hûr"
        },
        {
          "language": "pl",
          "text": "niuans; subtelna różnica"
        },
        {
          "language": "ro",
          "text": "nuanță; diferență subtilă"
        },
        {
          "language": "ru",
          "text": "нюанс; тонкое различие"
        },
        {
          "language": "sq",
          "text": "nuancë; dallim i hollë"
        },
        {
          "language": "tr",
          "text": "nüans; ince fark"
        }
      ],
      "examples": [
        {
          "baseText": "In der Übersetzung ging eine wichtige Nuance der ursprünglichen Aussage verloren.",
          "translations": [
            {
              "language": "ar",
              "text": "في الترجمة ضاعت Nuance مهمة من العبارة الأصلية."
            },
            {
              "language": "ckb",
              "text": "لە وەرگێڕانەکەدا نوانسێکی گرنگی وتەی سەرەکی ون بوو."
            },
            {
              "language": "en",
              "text": "An important nuance of the original statement was lost in translation."
            },
            {
              "language": "fa",
              "text": "در ترجمه، ظرافت مهمی از گفته اصلی از بین رفت."
            },
            {
              "language": "kmr",
              "text": "Di wergerê de nuanseke girîng a gotina resen winda bû."
            },
            {
              "language": "pl",
              "text": "W tłumaczeniu zginął ważny niuans pierwotnej wypowiedzi."
            },
            {
              "language": "ro",
              "text": "În traducere s-a pierdut o nuanță importantă a afirmației originale."
            },
            {
              "language": "ru",
              "text": "В переводе потерялся важный нюанс исходного высказывания."
            },
            {
              "language": "sq",
              "text": "Në përkthim humbi një nuancë e rëndësishme e deklaratës origjinale."
            },
            {
              "language": "tr",
              "text": "Çeviride özgün ifadenin önemli bir nüansı kayboldu."
            }
          ]
        },
        {
          "baseText": "Im Kundengespräch macht oft eine kleine Nuance im Ton den Unterschied zwischen Kritik und Vorwurf.",
          "translations": [
            {
              "language": "ar",
              "text": "في حديث العميل غالباً ما تصنع Nuance صغيرة في النبرة الفرق بين النقد والاتهام."
            },
            {
              "language": "ckb",
              "text": "لە گفتوگۆی کڕیاردا زۆرجار نوانسێکی بچووک لە دەنگدا جیاوازی نێوان ڕەخنە و تۆمەت دروست دەکات."
            },
            {
              "language": "en",
              "text": "In a customer conversation, a small nuance in tone often makes the difference between criticism and accusation."
            },
            {
              "language": "fa",
              "text": "در گفت‌وگو با مشتری، اغلب یک ظرافت کوچک در لحن تفاوت میان نقد و سرزنش را می‌سازد."
            },
            {
              "language": "kmr",
              "text": "Di axaftina bi xerîdar re gelek caran nuanseke biçûk di deng de cihê di navbera rexne û tawanbarî de çêdike."
            },
            {
              "language": "pl",
              "text": "W rozmowie z klientem drobny niuans tonu często decyduje o różnicy między krytyką a zarzutem."
            },
            {
              "language": "ro",
              "text": "În discuția cu un client, o mică nuanță de ton face adesea diferența dintre critică și reproș."
            },
            {
              "language": "ru",
              "text": "В разговоре с клиентом небольшой нюанс тона часто определяет разницу между критикой и обвинением."
            },
            {
              "language": "sq",
              "text": "Në bisedën me klientin, një nuancë e vogël në ton shpesh bën dallimin midis kritikës dhe akuzës."
            },
            {
              "language": "tr",
              "text": "Müşteri görüşmesinde tondaki küçük bir nüans çoğu zaman eleştiri ile suçlama arasındaki farkı yaratır."
            }
          ]
        }
      ]
    },
