        "customer-service"
      ],
      "usageLabels": [
        "everyday",
        "customer-facing",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; abbreviation for persönliche Identifikationsnummer"
      ],
      "collocations": [
        {
          "text": "die PIN eingeben",
          "meaning": "to enter the PIN"
        },
        {
          "text": "eine neue PIN anfordern",
          "meaning": "to request a new PIN"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Nummer",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "identifizieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "رمز PIN؛ رقم التعريف الشخصي"
        },
        {
          "language": "ckb",
          "text": "ژمارەی نهێنی PIN"
        },
        {
          "language": "en",
          "text": "PIN; personal identification number"
        },
        {
          "language": "fa",
          "text": "رمز PIN؛ شماره شناسایی شخصی"
        },
        {
          "language": "kmr",
          "text": "PIN; hejmara nasnameya kesane"
        },
        {
          "language": "pl",
          "text": "PIN; osobisty numer identyfikacyjny"
        },
        {
          "language": "ro",
          "text": "PIN; număr personal de identificare"
        },
        {
          "language": "ru",
          "text": "ПИН-код; персональный идентификационный номер"
        },
        {
          "language": "sq",
          "text": "PIN; numër personal identifikimi"
        },
        {
          "language": "tr",
          "text": "PIN; kişisel kimlik numarası"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte geben Sie Ihre PIN nicht an andere Personen weiter.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى عدم إعطاء رمز PIN الخاص بكم لأشخاص آخرين."
            },
            {
              "language": "ckb",
              "text": "تکایە ژمارەی نهێنی PIN ـەکەتان مەدەن بە کەسانی تر."
            },
            {
              "language": "en",
              "text": "Please do not share your PIN with other people."
            },
            {
              "language": "fa",
              "text": "لطفاً رمز PIN خود را به افراد دیگر ندهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe PIN-a xwe nedin kesên din."
            },
            {
              "language": "pl",
              "text": "Proszę nie przekazywać swojego PIN-u innym osobom."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să nu transmiteți PIN-ul altor persoane."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не передавайте свой ПИН-код другим людям."
            },
            {
              "language": "sq",
              "text": "Ju lutem mos ua jepni PIN-in tuaj personave të tjerë."
            },
            {
              "language": "tr",
              "text": "Lütfen PIN’inizi başka kişilerle paylaşmayın."
            }
          ]
        },
        {
          "baseText": "Wenn Sie die PIN dreimal falsch eingeben, wird die Karte gesperrt.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا أدخلتم رمز PIN خطأ ثلاث مرات، سيتم حظر البطاقة."
            },
            {
              "language": "ckb",
              "text": "ئەگەر PIN سێ جار بە هەڵە بنووسن، کارتەکە دادەخرێت."
            },
            {
              "language": "en",
              "text": "If you enter the PIN incorrectly three times, the card will be blocked."
            },
            {
              "language": "fa",
              "text": "اگر رمز PIN را سه بار اشتباه وارد کنید، کارت مسدود می‌شود."
            },
            {
              "language": "kmr",
              "text": "Heke hûn PIN sê caran şaş binivîsin, kart tê girtin."
            },
            {
              "language": "pl",
              "text": "Jeśli trzy razy wpiszą państwo błędny PIN, karta zostanie zablokowana."
            },
            {
              "language": "ro",
              "text": "Dacă introduceți PIN-ul greșit de trei ori, cardul va fi blocat."
            },
            {
              "language": "ru",
              "text": "Если вы трижды введёте ПИН неправильно, карта будет заблокирована."
            },
            {
              "language": "sq",
              "text": "Nëse e vendosni PIN-in gabim tri herë, karta do të bllokohet."
            },
            {
              "language": "tr",
              "text": "PIN’i üç kez yanlış girerseniz kart bloke edilir."
            }
          ]
        }
      ]
    },
