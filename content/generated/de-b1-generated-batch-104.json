  "entries": [
    {
      "word": "die Pflichtversicherung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Pflichtversicherungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Pflicht-ver-si-che-rung",
      "topics": [
        "law-and-compliance",
        "finance-and-accounting",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine gesetzliche Pflichtversicherung",
          "meaning": "a statutory compulsory insurance"
        },
        {
          "text": "Beiträge zur Pflichtversicherung",
          "meaning": "contributions to compulsory insurance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Pflicht",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Versicherung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تأمين إلزامي"
        },
        {
          "language": "ckb",
          "text": "بیمەی ئیجباری"
        },
        {
          "language": "en",
          "text": "compulsory insurance; mandatory insurance"
        },
        {
          "language": "fa",
          "text": "بیمه اجباری؛ بیمه الزامی"
        },
        {
          "language": "kmr",
          "text": "sîgorteya mecbûrî"
        },
        {
          "language": "pl",
          "text": "ubezpieczenie obowiązkowe"
        },
        {
          "language": "ro",
          "text": "asigurare obligatorie"
        },
        {
          "language": "ru",
          "text": "обязательное страхование"
        },
        {
          "language": "sq",
          "text": "sigurim i detyrueshëm"
        },
        {
          "language": "tr",
          "text": "zorunlu sigorta"
        }
      ],
      "examples": [
        {
          "baseText": "Die Krankenversicherung ist in Deutschland für viele Menschen eine Pflichtversicherung.",
          "translations": [
            {
              "language": "ar",
              "text": "التأمين الصحي في ألمانيا تأمين إلزامي لكثير من الناس."
            },
            {
              "language": "ckb",
              "text": "بیمەی تەندروستی لە ئەڵمانیا بۆ زۆر کەس بیمەی ئیجبارییە."
            },
            {
              "language": "en",
              "text": "Health insurance is compulsory insurance for many people in Germany."
            },
            {
              "language": "fa",
              "text": "بیمه درمانی در آلمان برای بسیاری از افراد بیمه اجباری است."
            },
            {
              "language": "kmr",
              "text": "Li Almanyayê sîgorteya tenduristiyê ji bo gelek kesan sîgorteyeke mecbûrî ye."
            },
            {
              "language": "pl",
              "text": "Ubezpieczenie zdrowotne jest w Niemczech dla wielu osób ubezpieczeniem obowiązkowym."
            },
            {
              "language": "ro",
              "text": "Asigurarea de sănătate este în Germania o asigurare obligatorie pentru mulți oameni."
            },
            {
              "language": "ru",
              "text": "Медицинское страхование в Германии для многих людей является обязательным."
            },
            {
              "language": "sq",
              "text": "Sigurimi shëndetësor në Gjermani është sigurim i detyrueshëm për shumë njerëz."
            },
            {
              "language": "tr",
              "text": "Sağlık sigortası Almanya’da birçok kişi için zorunlu sigortadır."
            }
          ]
        },
        {
          "baseText": "Die Personalabteilung erklärt, welche Pflichtversicherung für den Job gilt.",
          "translations": [
            {
              "language": "ar",
              "text": "يشرح قسم الموارد البشرية أي تأمين إلزامي ينطبق على الوظيفة."
            },
            {
              "language": "ckb",
              "text": "بەشی کارمەندان ڕوون دەکاتەوە کام بیمەی ئیجباری بۆ کارەکە دەگونجێت."
            },
            {
              "language": "en",
              "text": "The HR department explains which compulsory insurance applies to the job."
            },
            {
              "language": "fa",
              "text": "بخش منابع انسانی توضیح می‌دهد کدام بیمه اجباری برای این شغل اعمال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Beşa karmendan rave dike ka kîjan sîgorteya mecbûrî ji bo karê derbas dibe."
            },
            {
              "language": "pl",
              "text": "Dział kadr wyjaśnia, jakie ubezpieczenie obowiązkowe dotyczy tej pracy."
            },
            {
              "language": "ro",
              "text": "Departamentul de resurse umane explică ce asigurare obligatorie se aplică pentru job."
            },
            {
              "language": "ru",
              "text": "Отдел кадров объясняет, какое обязательное страхование действует для этой работы."
            },
            {
              "language": "sq",
              "text": "Departamenti i burimeve njerëzore shpjegon cili sigurim i detyrueshëm vlen për punën."
            },
            {
              "language": "tr",
              "text": "İnsan kaynakları departmanı iş için hangi zorunlu sigortanın geçerli olduğunu açıklar."
            }
          ]
        }
      ]
    },
    {
      "word": "die PIN",
