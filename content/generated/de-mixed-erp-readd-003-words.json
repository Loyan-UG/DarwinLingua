      "word": "das Gesamtgewicht",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Gesamtgewichte",
      "infinitive": null,
      "syllableBreak": "Ge-samt-ge-wicht",
      "topics": [
        "warehouse-and-logistics",
        "sales-and-customers",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "das Gesamtgewicht prüfen",
          "meaning": "to check the total weight"
        },
        {
          "text": "das Gesamtgewicht angeben",
          "meaning": "to state the total weight"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gesamt",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "das Gewicht",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "الوزن الإجمالي"
        },
        {
          "language": "ckb",
          "text": "کێشی گشتی"
        },
        {
          "language": "en",
          "text": "total weight"
        },
        {
          "language": "fa",
          "text": "وزن کل"
        },
        {
          "language": "kmr",
          "text": "giranahiya giştî"
        },
        {
          "language": "pl",
          "text": "waga całkowita"
        },
        {
          "language": "ro",
          "text": "greutate totală"
        },
        {
          "language": "ru",
          "text": "общий вес"
        },
        {
          "language": "sq",
          "text": "peshë totale"
        },
        {
          "language": "tr",
          "text": "toplam ağırlık"
        }
      ],
      "examples": [
        {
          "baseText": "Das Gesamtgewicht der Lieferung steht im ERP-System und auf dem Lieferschein.",
          "translations": [
            {
              "language": "ar",
              "text": "الوزن الإجمالي للتسليم موجود في نظام تخطيط موارد المؤسسة وعلى مذكرة التسليم."
            },
            {
              "language": "ckb",
              "text": "کێشی گشتیی گەیاندنەکە لە سیستەمی ERP و لە پسوولەی گەیاندندا نووسراوە."
            },
            {
              "language": "en",
              "text": "The total weight of the delivery is in the ERP system and on the delivery note."
            },
            {
              "language": "fa",
              "text": "وزن کل ارسال در سیستم ERP و روی حواله تحویل نوشته شده است."
            },
            {
              "language": "kmr",
              "text": "Giranahiya giştî ya radestkirinê di pergala ERP û ser belgeya radestkirinê de heye."
            },
            {
              "language": "pl",
              "text": "Waga całkowita dostawy jest w systemie ERP i na dokumencie dostawy."
            },
            {
              "language": "ro",
              "text": "Greutatea totală a livrării este în sistemul ERP și pe avizul de livrare."
            },
            {
              "language": "ru",
              "text": "Общий вес поставки указан в ERP-системе и в накладной."
            },
            {
              "language": "sq",
              "text": "Pesha totale e dërgesës është në sistemin ERP dhe në fletë-dorëzim."
            },
            {
              "language": "tr",
              "text": "Teslimatın toplam ağırlığı ERP sisteminde ve irsaliyede yer alıyor."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie das Gesamtgewicht, bevor der Fahrer losfährt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق من الوزن الإجمالي قبل أن ينطلق السائق."
            },
            {
              "language": "ckb",
              "text": "تکایە کێشی گشتی بپشکنن پێش ئەوەی شۆفێرەکە بڕوات."
            },
            {
              "language": "en",
              "text": "Please check the total weight before the driver leaves."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از حرکت راننده، وزن کل را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî ku ajokar biçe giranahiya giştî kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić wagę całkowitą, zanim kierowca odjedzie."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați greutatea totală înainte ca șoferul să plece."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте общий вес до выезда водителя."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni peshën totale para se shoferi të niset."
            },
            {
              "language": "tr",
              "text": "Şoför yola çıkmadan önce toplam ağırlığı kontrol edin."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "der Hersteller",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Hersteller",
      "infinitive": null,
      "syllableBreak": "Her-stel-ler",
      "topics": [
        "procurement-and-suppliers",
        "production-and-maintenance",
        "warehouse-and-logistics"
      ],
      "usageLabels": [
        "business",
        "workplace"
      ],
      "grammarNotes": [
        "masculine noun; feminine form: die Herstellerin is rare for companies"
      ],
      "collocations": [
        {
          "text": "den Hersteller kontaktieren",
          "meaning": "to contact the manufacturer"
        },
        {
          "text": "Angaben des Herstellers",
          "meaning": "manufacturer information"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "herstellen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Herstellung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "الشركة المصنعة؛ المصنّع"
        },
        {
          "language": "ckb",
          "text": "بەرهەمهێنەر"
        },
        {
          "language": "en",
          "text": "manufacturer"
        },
        {
          "language": "fa",
          "text": "تولیدکننده"
        },
        {
          "language": "kmr",
          "text": "çêker; hilberîner"
        },
        {
          "language": "pl",
          "text": "producent"
        },
        {
          "language": "ro",
          "text": "producător"
        },
        {
          "language": "ru",
          "text": "производитель"
        },
        {
          "language": "sq",
          "text": "prodhues"
        },
        {
          "language": "tr",
          "text": "üretici"
        }
      ],
      "examples": [
        {
          "baseText": "Der Hersteller hat die neuen Artikelnummern an unser ERP-System gesendet.",
          "translations": [
            {
              "language": "ar",
              "text": "أرسل المصنع أرقام المواد الجديدة إلى نظام تخطيط موارد المؤسسة لدينا."
            },
            {
              "language": "ckb",
              "text": "بەرهەمهێنەرەکە ژمارە نوێیەکانی کاڵا بۆ سیستەمی ERPی ئێمە نارد."
            },
            {
              "language": "en",
              "text": "The manufacturer sent the new item numbers to our ERP system."
            },
            {
              "language": "fa",
              "text": "تولیدکننده شماره‌های کالای جدید را به سیستم ERP ما فرستاد."
            },
            {
              "language": "kmr",
              "text": "Hilberîner hejmarên nû yên tiştan ji pergala ERP ya me re şand."
            },
            {
              "language": "pl",
              "text": "Producent wysłał nowe numery artykułów do naszego systemu ERP."
            },
            {
              "language": "ro",
              "text": "Producătorul a trimis noile coduri de articol către sistemul nostru ERP."
            },
            {
              "language": "ru",
              "text": "Производитель отправил новые номера товаров в нашу ERP-систему."
            },
            {
              "language": "sq",
              "text": "Prodhuesi i dërgoi numrat e rinj të artikujve në sistemin tonë ERP."
            },
            {
              "language": "tr",
              "text": "Üretici yeni ürün numaralarını ERP sistemimize gönderdi."
            }
          ]
        },
        {
          "baseText": "Bei einem Defekt wenden Sie sich bitte direkt an den Hersteller.",
          "translations": [
            {
              "language": "ar",
              "text": "في حال وجود عطل يرجى التواصل مباشرة مع الشركة المصنعة."
            },
            {
              "language": "ckb",
              "text": "لە کاتی کێشەدا تکایە ڕاستەوخۆ پەیوەندی بە بەرهەمهێنەرەکە بکەن."
            },
            {
              "language": "en",
              "text": "If there is a defect, please contact the manufacturer directly."
            },
            {
              "language": "fa",
              "text": "در صورت خرابی، لطفاً مستقیم با تولیدکننده تماس بگیرید."
            },
            {
              "language": "kmr",
              "text": "Ger kêmasiyek hebe, ji kerema xwe rasterast bi çêker re têkilî daynin."
            },
            {
              "language": "pl",
              "text": "W przypadku usterki proszę skontaktować się bezpośrednio z producentem."
            },
            {
              "language": "ro",
              "text": "În caz de defect, vă rugăm să contactați direct producătorul."
            },
            {
              "language": "ru",
              "text": "При неисправности, пожалуйста, обращайтесь напрямую к производителю."
            },
            {
              "language": "sq",
              "text": "Në rast defekti, ju lutemi kontaktoni drejtpërdrejt prodhuesin."
            },
            {
              "language": "tr",
              "text": "Bir arıza durumunda lütfen doğrudan üreticiyle iletişime geçin."
            }
          ]
        }
      ]
    },
