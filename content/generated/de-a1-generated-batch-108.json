            },
            {
              "language": "en",
              "text": "Can I pay by card?"
            },
            {
              "language": "fa",
              "text": "می‌توانم با کارت پرداخت کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim bi kartê pere bidim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę zapłacić kartą?"
            },
            {
              "language": "ro",
              "text": "Pot plăti cu cardul?"
            },
            {
              "language": "ru",
              "text": "Можно оплатить картой?"
            },
            {
              "language": "sq",
              "text": "A mund të paguaj me kartë?"
            },
