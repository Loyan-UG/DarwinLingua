      ],
      "examples": [
        {
          "baseText": "Ich lerne ein neues Wort.",
          "translations": [
            {
              "language": "ar",
              "text": "أتعلم كلمة جديدة."
            },
            {
              "language": "ckb",
              "text": "وشەیەکی نوێ فێر دەبم."
            },
            {
              "language": "en",
              "text": "I am learning a new word."
            },
            {
              "language": "fa",
              "text": "من یک کلمه جدید یاد می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez peyveke nû fêr dibim."
            },
            {
              "language": "pl",
              "text": "Uczę się nowego słowa."
            },
            {
              "language": "ro",
              "text": "Învăț un cuvânt nou."
            },
            {
              "language": "ru",
              "text": "Я учу новое слово."
            },
            {
              "language": "sq",
              "text": "Po mësoj një fjalë të re."
            },
            {
              "language": "tr",
              "text": "Yeni bir kelime öğreniyorum."
            }
          ]
        },
        {
          "baseText": "Bitte schreiben Sie das Wort an die Tafel.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك اكتب الكلمة على اللوح."
            },
            {
              "language": "ckb",
              "text": "تکایە وشەکە لەسەر تەختەکە بنووسە."
            },
            {
              "language": "en",
              "text": "Please write the word on the board."
            },
            {
              "language": "fa",
              "text": "لطفاً کلمه را روی تخته بنویسید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe peyvê li ser texteyê binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę napisać słowo na tablicy."
            },
            {
              "language": "ro",
              "text": "Vă rog să scrieți cuvântul pe tablă."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, напишите слово на доске."
            },
            {
              "language": "sq",
              "text": "Ju lutem shkruani fjalën në tabelë."
            },
            {
              "language": "tr",
              "text": "Lütfen kelimeyi tahtaya yazın."
            }
          ]
        }
      ]
