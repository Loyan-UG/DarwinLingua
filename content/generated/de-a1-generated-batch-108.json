      "examples": [
        {
          "baseText": "Haben Sie einen Wunsch?",
          "translations": [
            {
              "language": "ar",
              "text": "هل لديك طلب؟"
            },
            {
              "language": "ckb",
              "text": "داواکارییەکت هەیە؟"
            },
            {
              "language": "en",
              "text": "Do you have a request?"
            },
            {
              "language": "fa",
              "text": "درخواستی دارید؟"
            },
            {
              "language": "kmr",
              "text": "Xwesteka we heye?"
            },
            {
              "language": "pl",
              "text": "Czy ma pan/pani jakieś życzenie?"
            },
            {
              "language": "ro",
              "text": "Aveți o dorință?"
            },
            {
              "language": "ru",
              "text": "У вас есть пожелание?"
            },
            {
              "language": "sq",
              "text": "A keni ndonjë dëshirë?"
            },
            {
              "language": "tr",
              "text": "Bir isteğiniz var mı?"
            }
          ]
        },
        {
          "baseText": "Mein Wunsch ist ein ruhiges Zimmer.",
          "translations": [
            {
              "language": "ar",
              "text": "رغبتي هي غرفة هادئة."
            },
            {
              "language": "ckb",
              "text": "ئاواتم ژوورێکی ئارامە."
            },
            {
              "language": "en",
              "text": "My wish is a quiet room."
            },
            {
              "language": "fa",
              "text": "خواسته من یک اتاق ساکت است."
            },
            {
              "language": "kmr",
              "text": "Xwesteka min odeyeke aram e."
            },
            {
              "language": "pl",
              "text": "Moje życzenie to cichy pokój."
            },
            {
              "language": "ro",
              "text": "Dorința mea este o cameră liniștită."
            },
            {
              "language": "ru",
              "text": "Моё пожелание — тихая комната."
            },
            {
              "language": "sq",
              "text": "Dëshira ime është një dhomë e qetë."
            },
            {
              "language": "tr",
              "text": "İsteğim sessiz bir oda."
            }
          ]
        }
      ]
