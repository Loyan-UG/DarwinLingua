              "text": "The customer says: goodbye."
            },
            {
              "language": "fa",
              "text": "مشتری می‌گوید: خداحافظ."
            },
            {
              "language": "kmr",
              "text": "Mişterî dibêje: xatirê we."
            },
            {
              "language": "pl",
              "text": "Klientka mówi: do widzenia."
            },
            {
              "language": "ro",
              "text": "Clienta spune: la revedere."
            },
            {
              "language": "ru",
              "text": "Клиентка говорит: до свидания."
