      "examples": [
        {
          "baseText": "Ich gehe morgen zum Arzt.",
          "translations": [
            {
              "language": "ar",
              "text": "سأذهب غداً إلى الطبيب."
            },
            {
              "language": "ckb",
              "text": "سبەی دەچمە لای پزیشک."
            },
            {
              "language": "en",
              "text": "I am going to the doctor tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا به دکتر می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez sibê diçim cem bijîşk."
            },
            {
              "language": "pl",
              "text": "Jutro idę do lekarza."
            },
            {
              "language": "ro",
              "text": "Mâine merg la doctor."
            },
            {
              "language": "ru",
              "text": "Завтра я иду к врачу."
            },
            {
              "language": "sq",
              "text": "Nesër shkoj te mjeku."
            },
            {
              "language": "tr",
              "text": "Yarın doktora gidiyorum."
            }
          ]
        },
        {
          "baseText": "Der Arzt ist sehr freundlich.",
          "translations": [
            {
              "language": "ar",
              "text": "الطبيب لطيف جداً."
            },
            {
              "language": "ckb",
              "text": "پزیشکەکە زۆر دۆستانەیە."
            },
            {
              "language": "en",
              "text": "The doctor is very friendly."
            },
            {
              "language": "fa",
              "text": "دکتر خیلی مهربان است."
            },
            {
              "language": "kmr",
              "text": "Bijîşk pir dostane ye."
            },
            {
              "language": "pl",
              "text": "Lekarz jest bardzo miły."
            },
            {
              "language": "ro",
              "text": "Doctorul este foarte prietenos."
            },
            {
              "language": "ru",
              "text": "Врач очень дружелюбный."
            },
            {
              "language": "sq",
              "text": "Mjeku është shumë miqësor."
            },
            {
              "language": "tr",
              "text": "Doktor çok güler yüzlü."
            }
