      "examples": [
        {
          "baseText": "Das Unternehmen fördert Mitarbeitende, die sich weiterbilden möchten.",
          "translations": [
            {
              "language": "ar",
              "text": "تدعم الشركة الموظفين الذين يرغبون في مواصلة التدريب."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە پاڵپشتی ئەو کارمەندانە دەکات کە دەیانەوێت فێربوونیان بەردەوام بکەن."
            },
            {
              "language": "en",
              "text": "The company supports employees who want further training."
            },
