      ],
      "collocations": [
        {
          "text": "Fördermöglichkeiten prüfen",
          "meaning": "to check funding options"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fördern",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Förderung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إمكانية تمويل؛ فرصة دعم"
        },
        {
          "language": "ckb",
          "text": "دەرفەتی پاڵپشتی دارایی"
        },
        {
          "language": "en",
          "text": "funding opportunity; support option"
        },
        {
          "language": "fa",
          "text": "امکان حمایت مالی؛ فرصت کمک‌هزینه"
        },
        {
          "language": "kmr",
          "text": "derfeta piştgiriyê"
        },
        {
          "language": "pl",
          "text": "możliwość dofinansowania"
        },
        {
          "language": "ro",
          "text": "posibilitate de finanțare"
        },
        {
          "language": "ru",
          "text": "возможность финансирования; программа поддержки"
        },
        {
          "language": "sq",
          "text": "mundësi financimi"
        },
        {
          "language": "tr",
          "text": "destek/finansman imkânı"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Weiterbildung gibt es verschiedene Fördermöglichkeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "توجد إمكانيات دعم مختلفة للتدريب الإضافي."
            },
            {
              "language": "ckb",
              "text": "بۆ فێربوونی زیاتر چەند دەرفەتی پاڵپشتی هەیە."
            },
            {
              "language": "en",
              "text": "There are various funding opportunities for further training."
            },
            {
              "language": "fa",
              "text": "برای آموزش تکمیلی امکانات مختلف حمایت مالی وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Ji bo perwerdeya zêdetir derfetên piştgiriyê yên cuda hene."
            },
            {
              "language": "pl",
              "text": "Na szkolenie uzupełniające są różne możliwości dofinansowania."
            },
            {
              "language": "ro",
              "text": "Pentru formarea suplimentară există diferite posibilități de finanțare."
            },
            {
              "language": "ru",
              "text": "Для повышения квалификации есть разные возможности финансирования."
            },
            {
              "language": "sq",
              "text": "Për trajnimin e mëtejshëm ka mundësi të ndryshme financimi."
            },
            {
              "language": "tr",
              "text": "Ek eğitim için çeşitli destek imkânları var."
            }
          ]
        },
        {
          "baseText": "Die Beratungsstelle hilft dabei, passende Fördermöglichkeiten zu finden.",
          "translations": [
            {
              "language": "ar",
              "text": "يساعد مركز الاستشارة في العثور على فرص دعم مناسبة."
            },
            {
              "language": "ckb",
              "text": "ناوەندی ڕاوێژکاری یارمەتی دەدات دەرفەتی پاڵپشتی گونجاو بدۆزرێتەوە."
            },
            {
              "language": "en",
              "text": "The counseling center helps find suitable funding opportunities."
            },
            {
              "language": "fa",
              "text": "مرکز مشاوره کمک می‌کند فرصت‌های حمایت مالی مناسب پیدا شود."
            },
            {
              "language": "kmr",
              "text": "Navenda şêwirmendiyê alîkar e ku derfetên piştgiriyê yên guncaw werin dîtin."
            },
            {
              "language": "pl",
              "text": "Punkt doradczy pomaga znaleźć odpowiednie możliwości dofinansowania."
            },
            {
              "language": "ro",
              "text": "Centrul de consiliere ajută la găsirea posibilităților potrivite de finanțare."
            },
            {
              "language": "ru",
              "text": "Консультационный центр помогает найти подходящие возможности поддержки."
            },
            {
              "language": "sq",
              "text": "Qendra e këshillimit ndihmon të gjenden mundësi të përshtatshme financimi."
            },
            {
              "language": "tr",
              "text": "Danışma merkezi uygun destek imkânlarını bulmaya yardımcı olur."
            }
          ]
        }
      ]
    },
