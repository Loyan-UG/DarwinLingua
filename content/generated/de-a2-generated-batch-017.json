        },
        {
          "language": "ru",
          "text": "описывать"
        },
        {
          "language": "sq",
          "text": "të përshkruash"
        },
        {
          "language": "tr",
          "text": "tanımlamak; anlatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie das Problem kurz beschreiben?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم وصف المشكلة بإيجاز؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن کێشەکە بە کورتی وەسف بکەن؟"
            },
            {
              "language": "en",
              "text": "Can you briefly describe the problem?"
            },
            {
              "language": "fa",
              "text": "می‌توانید مشکل را کوتاه توضیح دهید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin pirsgirêkê bi kurtî vegerin?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan/Pani krótko opisać problem?"
            },
            {
              "language": "ro",
              "text": "Puteți descrie pe scurt problema?"
            },
            {
              "language": "ru",
              "text": "Можете кратко описать проблему?"
            },
            {
              "language": "sq",
              "text": "A mund ta përshkruani shkurt problemin?"
            },
            {
              "language": "tr",
              "text": "Sorunu kısaca anlatabilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Die Schülerin beschreibt ein Bild im Kurs.",
          "translations": [
            {
              "language": "ar",
              "text": "تصف الطالبة صورة في الدورة."
            },
            {
              "language": "ckb",
              "text": "قوتابییەکە لە کۆرسەکەدا وێنەیەک وەسف دەکات."
            },
            {
              "language": "en",
              "text": "The student describes a picture in the course."
            },
            {
              "language": "fa",
              "text": "دانش‌آموز در کلاس یک تصویر را توصیف می‌کند."
            },
            {
              "language": "kmr",
              "text": "Xwendekar di kursê de wêneyekê vedibêje."
            },
            {
              "language": "pl",
              "text": "Uczennica opisuje obrazek na kursie."
            },
            {
              "language": "ro",
              "text": "Eleva descrie o imagine la curs."
            },
            {
              "language": "ru",
              "text": "Ученица описывает картинку на курсе."
            },
            {
              "language": "sq",
              "text": "Nxënësja përshkruan një figurë në kurs."
            },
            {
              "language": "tr",
              "text": "Öğrenci kursta bir resmi anlatıyor."
            }
          ]
        }
      ]
