        {
          "language": "ckb",
          "text": "وەسفکردن؛ باسکردن"
        },
        {
          "language": "en",
          "text": "to describe"
        },
        {
          "language": "fa",
          "text": "توصیف کردن؛ شرح دادن"
        },
        {
