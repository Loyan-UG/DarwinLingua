        }
      ],
      "examples": [
        {
          "baseText": "Wir besichtigen morgen eine Wohnung.",
          "translations": [
            {
              "language": "ar",
              "text": "سنعاين شقة غداً."
            },
            {
              "language": "ckb",
              "text": "سبەی خانوویەک دەبینین."
            },
            {
              "language": "en",
              "text": "We are viewing an apartment tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا از یک آپارتمان بازدید می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em ê sibê apartmanekê bibînin."
            },
            {
              "language": "pl",
              "text": "Jutro oglądamy mieszkanie."
            },
            {
              "language": "ro",
              "text": "Mâine vizităm un apartament."
            },
            {
              "language": "ru",
              "text": "Завтра мы осматриваем квартиру."
            },
            {
              "language": "sq",
              "text": "Nesër do të shohim një apartament."
            },
            {
              "language": "tr",
              "text": "Yarın bir daireyi gezeceğiz."
            }
          ]
        },
        {
          "baseText": "Am Nachmittag besichtigen wir das Museum.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الظهر سنزور المتحف."
            },
            {
              "language": "ckb",
              "text": "دوای نیوەڕۆ سەردانی مۆزەخانەکە دەکەین."
            },
            {
              "language": "en",
              "text": "In the afternoon, we visit the museum."
            },
            {
              "language": "fa",
              "text": "بعدازظهر از موزه بازدید می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Piştî nîvro em serdana muzeyê dikin."
            },
            {
              "language": "pl",
              "text": "Po południu zwiedzamy muzeum."
            },
            {
              "language": "ro",
              "text": "După-amiază vizităm muzeul."
            },
            {
              "language": "ru",
              "text": "После обеда мы осматриваем музей."
            },
            {
              "language": "sq",
              "text": "Pasdite vizitojmë muzeun."
            },
            {
              "language": "tr",
              "text": "Öğleden sonra müzeyi geziyoruz."
            }
          ]
        }
      ]
    },
