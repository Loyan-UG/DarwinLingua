  "entries": [
    {
      "word": "tariflich",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ta-rif-lich",
      "topics": [
        "human-resources",
        "finance-and-accounting",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "workplace"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; often used in employment and salary contexts"
      ],
      "collocations": [
        {
          "text": "tariflich geregelt",
          "meaning": "regulated by collective agreement"
        },
        {
          "text": "tariflich bezahlt",
          "meaning": "paid according to a collective agreement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Tarif",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متعلق بالتعرفة أو الاتفاقية الجماعية"
        },
        {
          "language": "ckb",
          "text": "پەیوەندیدار بە تاریف یان ڕێککەوتنی گشتی کار"
        },
        {
          "language": "en",
          "text": "related to a tariff or collective agreement"
        },
        {
          "language": "fa",
          "text": "مربوط به تعرفه یا قرارداد جمعی کار"
        },
        {
          "language": "kmr",
          "text": "girêdayî tarîfê an peymana kolektîf"
        },
        {
          "language": "pl",
          "text": "taryfowy; wynikający z układu zbiorowego"
        },
        {
          "language": "ro",
          "text": "tarifar; stabilit prin contract colectiv"
        },
        {
          "language": "ru",
          "text": "тарифный; по коллективному договору"
        },
        {
          "language": "sq",
          "text": "tarifor; sipas marrëveshjes kolektive"
        },
        {
          "language": "tr",
          "text": "tarifeye veya toplu sözleşmeye bağlı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Löhne sind in diesem Betrieb tariflich geregelt.",
          "translations": [
            {
              "language": "ar",
              "text": "الأجور في هذه الشركة منظمة باتفاقية جماعية."
            },
            {
              "language": "ckb",
              "text": "مووچەکان لەم دامەزراوەیەدا بە ڕێککەوتنی گشتی کار ڕێکخراون."
            },
            {
              "language": "en",
              "text": "Wages in this company are regulated by a collective agreement."
            },
            {
              "language": "fa",
              "text": "دستمزدها در این شرکت بر اساس قرارداد جمعی تنظیم شده‌اند."
            },
            {
              "language": "kmr",
              "text": "Di vê kargehê de mûçe bi peymana kolektîf hatine rêxistin."
            },
            {
              "language": "pl",
              "text": "Wynagrodzenia w tym zakładzie są regulowane układem zbiorowym."
            },
            {
              "language": "ro",
              "text": "Salariile din această companie sunt reglementate prin contract colectiv."
            },
            {
              "language": "ru",
              "text": "Зарплаты на этом предприятии регулируются коллективным договором."
            },
            {
              "language": "sq",
              "text": "Pagat në këtë ndërmarrje rregullohen me marrëveshje kolektive."
            },
            {
              "language": "tr",
              "text": "Bu işletmede ücretler toplu sözleşmeye göre düzenlenir."
            }
          ]
        },
        {
          "baseText": "Für die Stelle gilt eine tarifliche Arbeitszeit von 38 Stunden pro Woche.",
          "translations": [
            {
              "language": "ar",
              "text": "لهذه الوظيفة تسري ساعات عمل جماعية مقدارها 38 ساعة في الأسبوع."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم پۆستە کاتی کاری ڕێککەوتنی گشتی ٣٨ کاتژمێر لە هەفتەیەکدایە."
            },
            {
              "language": "en",
              "text": "For this position, the collectively agreed working time is 38 hours per week."
            },
            {
              "language": "fa",
              "text": "برای این موقعیت، زمان کار طبق قرارداد جمعی ۳۸ ساعت در هفته است."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê karê dema karê li gor peymana kolektîf 38 saet di hefteyê de ye."
            },
            {
              "language": "pl",
              "text": "Dla tego stanowiska obowiązuje taryfowy czas pracy 38 godzin tygodniowo."
            },
            {
              "language": "ro",
              "text": "Pentru acest post se aplică un program de lucru tarifar de 38 de ore pe săptămână."
            },
            {
              "language": "ru",
              "text": "Для этой должности действует тарифное рабочее время 38 часов в неделю."
            },
            {
              "language": "sq",
              "text": "Për këtë vend pune vlen koha e punës sipas marrëveshjes kolektive prej 38 orësh në javë."
            },
            {
              "language": "tr",
              "text": "Bu pozisyon için toplu sözleşmeye göre haftalık çalışma süresi 38 saattir."
            }
          ]
        }
      ]
    },
    {
      "word": "der Tarifvertrag",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Tarifverträge",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ta-rif-ver-trag",
      "topics": [
        "human-resources",
        "contracts-and-negotiation",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "business",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "einen Tarifvertrag abschließen",
          "meaning": "to conclude a collective agreement"
        },
        {
          "text": "nach Tarifvertrag bezahlt werden",
          "meaning": "to be paid according to a collective agreement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "tariflich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اتفاقية عمل جماعية"
        },
        {
          "language": "ckb",
          "text": "ڕێککەوتنی گشتی کار"
        },
        {
          "language": "en",
          "text": "collective agreement; collective bargaining agreement"
        },
        {
          "language": "fa",
          "text": "قرارداد جمعی کار"
        },
        {
          "language": "kmr",
          "text": "peymana kolektîf a karê"
        },
        {
          "language": "pl",
          "text": "układ zbiorowy pracy"
        },
        {
          "language": "ro",
          "text": "contract colectiv de muncă"
        },
        {
          "language": "ru",
          "text": "коллективный договор"
        },
        {
          "language": "sq",
          "text": "marrëveshje kolektive pune"
        },
        {
          "language": "tr",
          "text": "toplu iş sözleşmesi"
        }
      ],
      "examples": [
        {
          "baseText": "Der neue Tarifvertrag bringt den Beschäftigten mehr Urlaubstage.",
          "translations": [
            {
              "language": "ar",
              "text": "تمنح اتفاقية العمل الجماعية الجديدة الموظفين أيام إجازة أكثر."
            },
            {
              "language": "ckb",
              "text": "ڕێککەوتنی گشتی کاری نوێ ڕۆژی پشووی زیاتر بۆ کارمەندان دەهێنێت."
            },
            {
              "language": "en",
              "text": "The new collective agreement gives employees more vacation days."
            },
            {
              "language": "fa",
              "text": "قرارداد جمعی جدید روزهای مرخصی بیشتری برای کارکنان می‌آورد."
            },
            {
              "language": "kmr",
              "text": "Peymana kolektîf a nû rojên betlaneyê yên zêdetir dide karmendan."
            },
            {
              "language": "pl",
              "text": "Nowy układ zbiorowy daje pracownikom więcej dni urlopu."
            },
            {
              "language": "ro",
              "text": "Noul contract colectiv le aduce angajaților mai multe zile de concediu."
            },
            {
              "language": "ru",
              "text": "Новый коллективный договор дает работникам больше дней отпуска."
            },
            {
              "language": "sq",
              "text": "Marrëveshja e re kolektive u jep punonjësve më shumë ditë pushimi."
            },
            {
              "language": "tr",
              "text": "Yeni toplu iş sözleşmesi çalışanlara daha fazla izin günü sağlıyor."
            }
          ]
        },
        {
          "baseText": "Im Tarifvertrag steht genau, wann Zuschläge gezahlt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "توضح اتفاقية العمل الجماعية بدقة متى تُدفع البدلات الإضافية."
            },
            {
              "language": "ckb",
              "text": "لە ڕێککەوتنی گشتی کارەکەدا بە وردی نووسراوە کەی زیادەپارە دەدرێت."
            },
            {
              "language": "en",
              "text": "The collective agreement states exactly when bonuses are paid."
            },
            {
              "language": "fa",
              "text": "در قرارداد جمعی دقیقاً نوشته شده چه زمانی اضافه‌پرداخت‌ها پرداخت می‌شوند."
            },
            {
              "language": "kmr",
              "text": "Di peymana kolektîf de bi rastî nivîsandî ye kengî zêdeheq tê dayîn."
            },
            {
              "language": "pl",
              "text": "W układzie zbiorowym dokładnie zapisano, kiedy wypłacane są dodatki."
            },
            {
              "language": "ro",
              "text": "În contractul colectiv scrie exact când se plătesc sporurile."
            },
            {
              "language": "ru",
              "text": "В коллективном договоре точно указано, когда выплачиваются надбавки."
            },
            {
              "language": "sq",
              "text": "Në marrëveshjen kolektive shkruhet saktë kur paguhen shtesat."
            },
            {
              "language": "tr",
              "text": "Toplu iş sözleşmesinde ek ödemelerin ne zaman yapılacağı tam olarak yazıyor."
            }
          ]
        }
      ]
    },
