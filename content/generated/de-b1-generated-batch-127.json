      "examples": [
        {
          "baseText": "Der Teamleiter verteilt die Aufgaben für den nächsten Sprint.",
          "translations": [
            {
              "language": "ar",
              "text": "يوزع قائد الفريق المهام للسبرنت القادم."
            },
            {
              "language": "ckb",
              "text": "سەرپەرشتیاری تیم ئەرکەکانی سپرینتی داهاتوو دابەش دەکات."
            },
            {
              "language": "en",
              "text": "The team lead assigns the tasks for the next sprint."
            },
            {
              "language": "fa",
              "text": "سرپرست تیم وظایف اسپرینت بعدی را تقسیم می‌کند."
            },
            {
              "language": "kmr",
              "text": "Serokê tîmê erkên sprinta bê dabeş dike."
            },
            {
              "language": "pl",
              "text": "Lider zespołu rozdziela zadania na następny sprint."
            },
