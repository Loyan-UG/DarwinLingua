      "word": "die Rechtsstaatlichkeit",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "syllableBreak": "Rechts-staat-lich-keit",
      "topics": [
        "law-and-compliance",
        "public-services",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "academic",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "Rechtsstaatlichkeit gewährleisten",
          "meaning": "to ensure the rule of law"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Rechtsstaat",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "rechtsstaatlich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "سيادة القانون؛ دولة القانون"
        },
        {
          "language": "ckb",
          "text": "سەروەری یاسا؛ یاساداری"
        },
        {
          "language": "en",
          "text": "rule of law"
        },
        {
          "language": "fa",
          "text": "حاکمیت قانون؛ قانون‌مداری"
        },
        {
          "language": "kmr",
          "text": "serweriya qanûnê"
        },
        {
          "language": "pl",
          "text": "praworządność"
        },
        {
          "language": "ro",
          "text": "stat de drept; legalitate constituțională"
        },
        {
          "language": "ru",
          "text": "верховенство права; правовое государство"
        },
        {
          "language": "sq",
          "text": "sundim i ligjit"
        },
        {
          "language": "tr",
          "text": "hukukun üstünlüğü"
        }
      ],
      "examples": [
        {
          "baseText": "Rechtsstaatlichkeit zeigt sich daran, dass staatliches Handeln wirksam überprüft werden kann.",
          "translations": [
            {
              "language": "ar",
              "text": "تظهر سيادة القانون في إمكانية مراجعة أعمال الدولة بشكل فعّال."
            },
            {
              "language": "ckb",
              "text": "یاساداری لەوەدا دەردەکەوێت کە کردەوەی دەوڵەت بە کاریگەر بتوانرێت بپشکنرێت."
            },
            {
              "language": "en",
              "text": "The rule of law is evident when state action can be effectively reviewed."
            },
            {
              "language": "fa",
              "text": "حاکمیت قانون زمانی آشکار می‌شود که اقدامات دولت به‌طور مؤثر قابل بررسی باشد."
            },
            {
              "language": "kmr",
              "text": "Serweriya qanûnê di vê de xuya dibe ku kiryarên dewletê bi karîgerî werin kontrolkirin."
            },
            {
              "language": "pl",
              "text": "Praworządność przejawia się w tym, że działania państwa można skutecznie kontrolować."
            },
            {
              "language": "ro",
              "text": "Statul de drept se vede în faptul că acțiunile statului pot fi verificate eficient."
            },
            {
              "language": "ru",
              "text": "Верховенство права проявляется в том, что действия государства можно эффективно проверять."
            },
            {
              "language": "sq",
              "text": "Sundimi i ligjit shfaqet kur veprimet shtetërore mund të kontrollohen në mënyrë efektive."
            },
            {
              "language": "tr",
              "text": "Hukukun üstünlüğü, devlet eylemlerinin etkili biçimde denetlenebilmesinde görülür."
            }
          ]
        },
        {
          "baseText": "Internationale Investoren achten zunehmend auf Rechtsstaatlichkeit und stabile Verfahren.",
          "translations": [
            {
              "language": "ar",
              "text": "يهتم المستثمرون الدوليون بشكل متزايد بسيادة القانون والإجراءات المستقرة."
            },
            {
              "language": "ckb",
              "text": "وەبەرهێنەرانی نێودەوڵەتی زیاتر گرنگی بە یاساداری و ڕێکارە جێگیرەکان دەدەن."
            },
            {
              "language": "en",
              "text": "International investors increasingly pay attention to the rule of law and stable procedures."
            },
            {
              "language": "fa",
              "text": "سرمایه‌گذاران بین‌المللی بیش از پیش به حاکمیت قانون و فرایندهای پایدار توجه می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Veberhênerên navneteweyî her ku diçe bêtir bala xwe didin serweriya qanûnê û pêvajoyên sabît."
            },
            {
              "language": "pl",
              "text": "Międzynarodowi inwestorzy coraz bardziej zwracają uwagę na praworządność i stabilne procedury."
            },
            {
              "language": "ro",
              "text": "Investitorii internaționali acordă tot mai multă atenție statului de drept și procedurilor stabile."
            },
            {
              "language": "ru",
              "text": "Международные инвесторы все больше обращают внимание на верховенство права и стабильные процедуры."
            },
            {
              "language": "sq",
              "text": "Investitorët ndërkombëtarë po i kushtojnë gjithnjë e më shumë vëmendje sundimit të ligjit dhe procedurave të qëndrueshme."
            },
            {
              "language": "tr",
              "text": "Uluslararası yatırımcılar hukukun üstünlüğüne ve istikrarlı süreçlere giderek daha fazla dikkat ediyor."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Reflexionsebene",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Reflexionsebenen",
      "infinitive": null,
      "syllableBreak": "Re-fle-xi-ons-e-be-ne",
      "topics": [
        "advanced-analysis",
        "education-and-training",
        "culture-and-media"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "auf einer Reflexionsebene argumentieren",
          "meaning": "to argue on a level of reflection"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Reflexion",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Ebene",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "مستوى التأمل؛ مستوى التحليل الذاتي"
        },
        {
          "language": "ckb",
          "text": "ئاستی بیرکردنەوە؛ ئاستی ڕەنگدانەوە"
        },
        {
          "language": "en",
          "text": "level of reflection"
        },
        {
          "language": "fa",
          "text": "سطح تأمل؛ لایه بازاندیشی"
        },
        {
          "language": "kmr",
          "text": "asta refleksiyonê"
        },
        {
          "language": "pl",
          "text": "poziom refleksji"
        },
        {
          "language": "ro",
          "text": "nivel de reflecție"
        },
        {
          "language": "ru",
          "text": "уровень рефлексии"
        },
        {
          "language": "sq",
          "text": "nivel reflektimi"
        },
        {
          "language": "tr",
          "text": "düşünüm düzeyi"
        }
      ],
      "examples": [
        {
          "baseText": "Auf der Reflexionsebene geht es nicht um einzelne Fehler, sondern um die Muster dahinter.",
          "translations": [
            {
              "language": "ar",
              "text": "على مستوى التأمل لا يتعلق الأمر بأخطاء فردية، بل بالأنماط الكامنة خلفها."
            },
            {
              "language": "ckb",
              "text": "لە ئاستی بیرکردنەوەدا باس لە هەڵەی تاکەکەسی نییە، بەڵکو لەو پاترنانەیە کە لە پشتەوەیانن."
            },
            {
              "language": "en",
              "text": "On the level of reflection, the issue is not individual mistakes but the patterns behind them."
            },
            {
              "language": "fa",
              "text": "در سطح تأمل، مسئله خطاهای منفرد نیست، بلکه الگوهای پشت آن‌هاست."
            },
            {
              "language": "kmr",
              "text": "Li asta refleksiyonê pirsgirêk ne şaşiyên takekesî ne, lê modelên li pişt wan in."
            },
            {
              "language": "pl",
              "text": "Na poziomie refleksji nie chodzi o pojedyncze błędy, lecz o wzorce stojące za nimi."
            },
            {
              "language": "ro",
              "text": "La nivelul de reflecție nu este vorba despre greșeli individuale, ci despre tiparele din spatele lor."
            },
            {
              "language": "ru",
              "text": "На уровне рефлексии речь идет не об отдельных ошибках, а о стоящих за ними моделях."
            },
            {
              "language": "sq",
              "text": "Në nivel reflektimi nuk bëhet fjalë për gabime të veçanta, por për modelet pas tyre."
            },
            {
              "language": "tr",
              "text": "Düşünüm düzeyinde mesele tek tek hatalar değil, arkalarındaki örüntülerdir."
            }
          ]
        },
        {
          "baseText": "Der Roman wechselt ständig zwischen Handlungsebene und Reflexionsebene.",
          "translations": [
            {
              "language": "ar",
              "text": "تتنقل الرواية باستمرار بين مستوى الحدث ومستوى التأمل."
            },
            {
              "language": "ckb",
              "text": "ڕۆمانەکە بەردەوام لە نێوان ئاستی ڕووداو و ئاستی بیرکردنەوەدا دەگۆڕێت."
            },
            {
              "language": "en",
              "text": "The novel constantly shifts between the level of action and the level of reflection."
            },
            {
              "language": "fa",
              "text": "رمان مدام میان سطح روایت رویداد و سطح تأمل جابه‌جا می‌شود."
            },
            {
              "language": "kmr",
              "text": "Roman her dem di navbera asta kiryarê û asta refleksiyonê de diguhere."
            },
            {
              "language": "pl",
              "text": "Powieść stale przechodzi między poziomem akcji a poziomem refleksji."
            },
            {
              "language": "ro",
              "text": "Romanul trece constant între nivelul acțiunii și nivelul de reflecție."
            },
            {
              "language": "ru",
              "text": "Роман постоянно переключается между уровнем действия и уровнем рефлексии."
            },
            {
              "language": "sq",
              "text": "Romani kalon vazhdimisht midis nivelit të veprimit dhe nivelit të reflektimit."
            },
            {
              "language": "tr",
              "text": "Roman sürekli eylem düzeyi ile düşünüm düzeyi arasında geçiş yapar."
            }
          ]
        }
      ]
    },
