        }
      ],
      "examples": [
        {
          "baseText": "Der Kunde biss erst an, als der Händler die Finanzierung transparent erklärte.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يُبدِ العميل اهتمامًا إلا عندما شرح التاجر التمويل بشفافية."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە تەنها کاتێک ڕاکێشرا کە فرۆشیارەکە داراییەکەی بە ڕوونی ڕوون کردەوە."
            },
            {
              "language": "en",
              "text": "The customer only took the bait when the dealer explained the financing transparently."
            },
            {
              "language": "fa",
              "text": "مشتری فقط وقتی جذب شد که فروشنده تأمین مالی را شفاف توضیح داد."
            },
            {
              "language": "kmr",
              "text": "Xerîdar tenê hingê anbeißen kir ku firoşkar darayîkirinê bi zelalî rave kir."
            },
            {
              "language": "pl",
              "text": "Klient dał się przekonać dopiero, gdy sprzedawca jasno wyjaśnił finansowanie."
            },
            {
              "language": "ro",
              "text": "Clientul a mușcat momeala abia când dealerul a explicat finanțarea transparent."
            },
            {
              "language": "ru",
              "text": "Клиент заинтересовался только тогда, когда продавец прозрачно объяснил финансирование."
            },
            {
              "language": "sq",
              "text": "Klienti u tërhoq vetëm kur tregtari e shpjegoi financimin në mënyrë transparente."
            },
            {
              "language": "tr",
              "text": "Müşteri ancak satıcı finansmanı şeffaf biçimde açıklayınca teklife ilgi gösterdi."
            }
          ]
        },
        {
          "baseText": "Sie biss vorsichtig in das Brot an, weil es noch sehr heiß war.",
          "translations": [
            {
              "language": "ar",
              "text": "قضمت الخبز بحذر لأنه كان لا يزال ساخنًا جدًا."
            },
            {
              "language": "ckb",
              "text": "بە وریایی گازی لە نانەکە دا چونکە هێشتا زۆر گەرم بوو."
            },
            {
              "language": "en",
              "text": "She carefully bit into the bread because it was still very hot."
            },
            {
              "language": "fa",
              "text": "او با احتیاط به نان گاز زد، چون هنوز خیلی داغ بود."
            },
            {
              "language": "kmr",
              "text": "Wê bi baldarî gez ji nan kir, ji ber ku hîn gelek germ bû."
            },
            {
              "language": "pl",
              "text": "Ostrożnie nadgryzła chleb, bo był jeszcze bardzo gorący."
            },
            {
              "language": "ro",
              "text": "A mușcat cu grijă din pâine, deoarece era încă foarte fierbinte."
            },
            {
              "language": "ru",
              "text": "Она осторожно надкусила хлеб, потому что он был еще очень горячим."
            },
            {
              "language": "sq",
              "text": "Ajo kafshoi me kujdes bukën, sepse ishte ende shumë e nxehtë."
            },
            {
              "language": "tr",
              "text": "Ekmek hâlâ çok sıcak olduğu için dikkatlice ısırdı."
            }
          ]
        }
      ]
