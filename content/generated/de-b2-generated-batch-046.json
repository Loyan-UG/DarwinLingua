  "entries": [
    {
      "word": "der Ansatz",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "die Ansätze",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "der An-satz",
      "topics": [
        "planning-and-projects",
        "work-and-jobs",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "written",
        "workplace"
      ],
      "contextLabels": [
        "management",
        "analysis"
      ],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "einen neuen Ansatz ausprobieren",
          "meaning": "to try a new approach"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نهج؛ طريقة"
        },
        {
          "language": "ckb",
          "text": "ڕێگەڕەوە؛ ڕێبەری"
        },
        {
          "language": "en",
          "text": "approach; method"
        },
        {
          "language": "fa",
          "text": "رویکرد؛ روش"
        },
        {
          "language": "kmr",
          "text": "rêbaz; şêwaz"
        },
        {
          "language": "pl",
          "text": "podejście; metodyka"
        },
        {
          "language": "ro",
          "text": "abordare; metodă"
        },
        {
          "language": "ru",
          "text": "подход; метод"
        },
        {
          "language": "sq",
          "text": "qasje; metodë"
        },
        {
          "language": "tr",
          "text": "yaklaşım; yöntem"
        }
      ],
      "examples": [
        {
          "baseText": "Wir brauchen einen klaren Ansatz für den Umgang mit Produktionsausfällen im Support.",
          "translations": [
            {
              "language": "ar",
              "text": "نحن بحاجة إلى نهج واضح للتعامل مع تعطل الإنتاج في الدعم."
            },
            {
              "language": "ckb",
              "text": "پێویستمان بە ڕێگەرەوەیەکی ڕوونە لەگەڵ خراپیەکانی بەرهەمهێنان لە پاڵپشتیەوەیەوە."
            },
            {
              "language": "en",
              "text": "We need a clear approach for handling production incidents in support."
            },
            {
              "language": "fa",
              "text": "به یک رویکرد روشن برای رسیدگی به خرابی‌های تولیدی در پشتیبانی نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo birêvebirina xeraskirinanî berdewamî di alîkarîyê de pêdivî ye meriv re awayê vekirîk hebe."
            },
            {
              "language": "pl",
              "text": "Potrzebujemy jasnego podejścia do obsługi incydentów produkcyjnych w dziale wsparcia."
            },
            {
              "language": "ro",
              "text": "Avem nevoie de o abordare clară pentru gestionarea incidentelor de producție în echipa de suport."
            },
            {
              "language": "ru",
              "text": "Нам нужен четкий подход к обработке производственных инцидентов в поддержке."
            },
            {
              "language": "sq",
              "text": "Na duhet një qasje e qartë për menaxhimin e incidenteve të prodhimit në suport."
            },
            {
              "language": "tr",
              "text": "Destek biriminde üretim arızalarını ele almak için net bir yaklaşımımıza ihtiyacımız var."
            }
          ]
        },
        {
          "baseText": "Der neue Ansatz des Teams hat die Reaktionszeit bei Störmeldungen deutlich verbessert.",
          "translations": [
            {
              "language": "ar",
              "text": "رویکرد جدید تیم، زمان واکنش به هشدارهای خرابی را به طور محسوسی بهبود داده است."
            },
            {
              "language": "ckb",
              "text": "ڕێگەڕەوەیەکی نوێی تیمەکە کاتی وەڵامدانەوە لە ئاگاداری سەروەری خەریکیەتی زۆر باشکردووە."
            },
            {
              "language": "en",
              "text": "The team’s new approach has significantly improved alarm response time."
            },
            {
              "language": "fa",
              "text": "رویکرد جدید تیم باعث بهبود قابل توجه زمان پاسخ‌گویی به هشدارها شده است."
            },
            {
              "language": "kmr",
              "text": "Rêbaza nû ya tîmayê demê bersivdanê ya ji hêla hilanînên hişyariyê re zêde baş kir."
            },
            {
              "language": "pl",
              "text": "Nowe podejście zespołu wyraźnie poprawiło czas reakcji na zgłoszenia alarmowe."
            },
            {
              "language": "ro",
              "text": "Abordarea nouă a echipei a îmbunătățit semnificativ timpul de răspuns la alerte."
            },
            {
              "language": "ru",
              "text": "Новый подход команды заметно улучшил время реакции на предупреждения о сбоях."
            },
            {
              "language": "sq",
              "text": "Qasja e re e ekipit përmirësoi ndjeshëm kohën e reagimit ndaj alarmeve."
            },
            {
              "language": "tr",
              "text": "Ekibin yeni yaklaşımı alarm yanıt süresini belirgin biçimde iyileştirdi."
            }
          ]
        }
      ]
    },
    {
      "word": "anschieben",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anschieben",
      "pronunciationIpa": null,
      "syllableBreak": "an-schie-ben",
      "topics": [
        "work-and-jobs",
        "meetings-and-presentations",
        "management-and-leadership"
      ],
      "usageLabels": [
        "spoken",
        "workplace"
      ],
      "contextLabels": [
        "management"
      ],
      "grammarNotes": [
        "separable verb"
      ],
      "collocations": [
        {
          "text": "einen Vorschlag anschieben",
          "meaning": "to push forward a proposal"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدفع إلى الأمام؛ يقترح"
        },
        {
          "language": "ckb",
          "text": "پێش دەهێنێت؛ پێشنیار دەکات"
        },
        {
          "language": "en",
          "text": "to push forward; to propose"
        },
        {
          "language": "fa",
          "text": "جلو انداختن؛ پیشنهاد کردن"
        },
        {
          "language": "kmr",
          "text": "pêşvebirin; pêşniyarkirin"
        },
        {
          "language": "pl",
          "text": "przesuwać do przodu; proponować"
        },
        {
          "language": "ro",
          "text": "a avansa; a propune"
        },
        {
          "language": "ru",
          "text": "продвигать; предлагать"
        },
        {
          "language": "sq",
          "text": "shtyjë; propozojë"
        },
        {
          "language": "tr",
          "text": "ileriye taşımak; önermek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Abteilungsleiter hat den Vorschlag für das neue Monitoring-Tool in die Sitzung angeschoben.",
          "translations": [
            {
              "language": "ar",
              "text": "مدير القسم طرح اقتراح أداة المراقبة الجديدة في الاجتماع."
            },
            {
              "language": "ckb",
              "text": "سەردەمی بەڕێزەی بەشەکە پێشنیاری تووڵەی تازەی چاودێریکردن لەکانا گرت."
            },
            {
              "language": "en",
              "text": "The department head brought the proposal for the new monitoring tool into the meeting."
            },
            {
              "language": "fa",
