          "text": "të printosh"
        },
        {
          "language": "tr",
          "text": "çıktı almak; yazdırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie das Formular bitte ausdrucken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم طباعة الاستمارة من فضلكم؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن تکایە فۆرمەکە چاپ بکەن؟"
            },
            {
              "language": "en",
              "text": "Can you please print out the form?"
            },
            {
              "language": "fa",
              "text": "می‌توانید لطفاً فرم را چاپ کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji kerema xwe formê çap bikin?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan/Pani wydrukować formularz?"
            },
            {
              "language": "ro",
              "text": "Puteți, vă rog, să tipăriți formularul?"
            },
            {
              "language": "ru",
              "text": "Можете, пожалуйста, распечатать форму?"
            },
            {
              "language": "sq",
              "text": "A mund ta printoni formularin, ju lutem?"
            },
            {
              "language": "tr",
              "text": "Formu lütfen yazdırabilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Ich drucke die Tickets zu Hause aus.",
          "translations": [
            {
              "language": "ar",
              "text": "سأطبع التذاكر في البيت."
            },
            {
              "language": "ckb",
              "text": "بلیتەکان لە ماڵەوە چاپ دەکەم."
            },
            {
              "language": "en",
              "text": "I print the tickets at home."
            },
            {
              "language": "fa",
              "text": "بلیط‌ها را در خانه چاپ می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez bilêtan li malê çap dikim."
            },
            {
              "language": "pl",
              "text": "Drukuję bilety w domu."
            },
            {
              "language": "ro",
              "text": "Tipăresc biletele acasă."
            },
            {
              "language": "ru",
              "text": "Я распечатаю билеты дома."
            },
            {
              "language": "sq",
              "text": "I printoj biletat në shtëpi."
            },
            {
              "language": "tr",
              "text": "Biletleri evde yazdırıyorum."
            }
          ]
        }
      ]
    },
