      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تدريب مهني؛ تعليم"
        },
        {
          "language": "ckb",
          "text": "ڕاهێنانی پیشەیی؛ فێرکردن"
        },
        {
          "language": "en",
          "text": "vocational training; education"
        },
        {
          "language": "fa",
          "text": "آموزش حرفه‌ای؛ دوره آموزشی"
        },
        {
          "language": "kmr",
          "text": "perwerdeya pîşeyî; perwerde"
        },
        {
          "language": "pl",
          "text": "kształcenie zawodowe; szkolenie"
        },
        {
          "language": "ro",
          "text": "formare profesională; educație"
        },
        {
          "language": "ru",
          "text": "профессиональное обучение; образование"
        },
        {
          "language": "sq",
          "text": "trajnim profesional; arsim"
        },
        {
          "language": "tr",
          "text": "mesleki eğitim; eğitim"
        }
      ],
      "examples": [
        {
          "baseText": "Sie macht eine Ausbildung im Krankenhaus.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تقوم بتدريب مهني في المستشفى."
            },
            {
              "language": "ckb",
              "text": "ئەو لە نەخۆشخانە ڕاهێنانی پیشەیی دەکات."
            },
            {
              "language": "en",
              "text": "She is doing vocational training at the hospital."
            },
            {
              "language": "fa",
              "text": "او در بیمارستان آموزش حرفه‌ای می‌بیند."
            },
            {
              "language": "kmr",
              "text": "Ew li nexweşxaneyê perwerdeya pîşeyî dike."
            },
            {
              "language": "pl",
              "text": "Ona odbywa szkolenie zawodowe w szpitalu."
            },
            {
              "language": "ro",
              "text": "Ea face o formare profesională la spital."
            },
            {
              "language": "ru",
              "text": "Она проходит профессиональное обучение в больнице."
            },
            {
              "language": "sq",
              "text": "Ajo po bën trajnim profesional në spital."
            },
            {
              "language": "tr",
              "text": "Hastanede mesleki eğitim yapıyor."
            }
          ]
        },
        {
          "baseText": "Die Ausbildung beginnt im September.",
          "translations": [
            {
              "language": "ar",
              "text": "يبدأ التدريب المهني في سبتمبر."
            },
            {
              "language": "ckb",
              "text": "ڕاهێنانە پیشەییەکە لە ئەیلوول دەست پێدەکات."
            },
            {
              "language": "en",
              "text": "The vocational training starts in September."
            },
            {
              "language": "fa",
              "text": "دوره آموزشی در سپتامبر شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Perwerdeya pîşeyî di îlonê de dest pê dike."
            },
            {
              "language": "pl",
              "text": "Szkolenie zawodowe zaczyna się we wrześniu."
            },
            {
              "language": "ro",
              "text": "Formarea profesională începe în septembrie."
            },
            {
              "language": "ru",
              "text": "Профессиональное обучение начинается в сентябре."
            },
            {
              "language": "sq",
              "text": "Trajnimi profesional fillon në shtator."
            },
            {
              "language": "tr",
              "text": "Mesleki eğitim eylülde başlıyor."
            }
          ]
        }
      ]
    },
