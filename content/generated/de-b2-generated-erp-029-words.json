      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; shipping or dispatch of goods"
      ],
      "collocations": [
        {
          "text": "den Versand vorbereiten",
          "meaning": "to prepare shipping"
        },
        {
          "text": "im Versand arbeiten",
          "meaning": "to work in shipping"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "versenden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الشحن؛ الإرسال"
        },
        {
          "language": "ckb",
          "text": "ناردن"
        },
        {
          "language": "en",
          "text": "shipping; dispatch"
        },
        {
          "language": "fa",
          "text": "ارسال؛ حمل کالا"
        },
        {
          "language": "kmr",
          "text": "şandin"
        },
        {
          "language": "pl",
          "text": "wysyłka"
        },
        {
          "language": "ro",
          "text": "expediere"
        },
        {
          "language": "ru",
          "text": "отправка; отгрузка"
        },
        {
          "language": "sq",
          "text": "dërgesë"
        },
        {
          "language": "tr",
          "text": "sevkiyat; gönderim"
        }
      ],
      "examples": [
        {
          "baseText": "Der Versand startet im ERP, sobald die Kommissionierung abgeschlossen ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يبدأ الشحن في ERP بمجرد اكتمال تجهيز الطلب."
            },
            {
              "language": "ckb",
              "text": "ناردن لە ERP دا دەست پێدەکات هەر کات کۆکردنەوەی داواکاری تەواو بوو."
            },
            {
              "language": "en",
              "text": "Shipping starts in the ERP as soon as picking is completed."
            },
            {
              "language": "fa",
              "text": "ارسال در ERP به‌محض تکمیل جمع‌آوری سفارش شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Şandin di ERP de dest pê dike dema hilbijartina fermanê qediya."
            },
            {
              "language": "pl",
              "text": "Wysyłka rozpoczyna się w ERP, gdy tylko kompletacja zostanie zakończona."
            },
            {
              "language": "ro",
              "text": "Expedierea începe în ERP imediat ce pickingul este finalizat."
            },
            {
              "language": "ru",
              "text": "Отгрузка запускается в ERP, как только комплектация завершена."
            },
            {
              "language": "sq",
              "text": "Dërgesa nis në ERP sapo përgatitja e porosisë të përfundojë."
            },
            {
              "language": "tr",
              "text": "Sipariş toplama tamamlanır tamamlanmaz ERP’de sevkiyat başlar."
            }
          ]
        },
        {
          "baseText": "Der Kunde möchte eine kurze Nachricht, wenn der Versand heute noch rausgeht.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد العميل رسالة قصيرة إذا خرجت الشحنة اليوم."
            },
            {
              "language": "ckb",
              "text": "کڕیار نامەیەکی کورت دەیەوێت ئەگەر ناردنەکە ئەمڕۆ بنێردرێت."
            },
            {
              "language": "en",
              "text": "The customer wants a short message if the shipment goes out today."
            },
            {
              "language": "fa",
              "text": "مشتری می‌خواهد اگر ارسال امروز انجام می‌شود، یک پیام کوتاه دریافت کند."
            },
            {
              "language": "kmr",
              "text": "Mişterî peyameke kurt dixwaze heke şandin îro derkeve."
            },
            {
              "language": "pl",
              "text": "Klient chce krótką wiadomość, jeśli wysyłka wyjdzie jeszcze dziś."
            },
            {
              "language": "ro",
              "text": "Clientul dorește un mesaj scurt dacă expedierea pleacă astăzi."
            },
            {
              "language": "ru",
              "text": "Клиент хочет короткое сообщение, если отправка уйдет сегодня."
            },
            {
              "language": "sq",
              "text": "Klienti dëshiron një mesazh të shkurtër nëse dërgesa del sot."
            },
            {
              "language": "tr",
              "text": "Müşteri sevkiyat bugün çıkarsa kısa bir mesaj istiyor."
            }
          ]
        }
      ]
    },
    {
      "word": "Versandausgang",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Versandausgänge",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-sand-aus-gang",
      "topics": [
        "warehouse-and-logistics",
        "transport-and-travel",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; outbound shipping area or dispatch exit"
      ],
      "collocations": [
        {
          "text": "am Versandausgang scannen",
          "meaning": "to scan at the dispatch exit"
        },
        {
          "text": "den Versandausgang prüfen",
          "meaning": "to check the outbound dispatch area"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Versand",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Ausgang",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مخرج الشحن؛ خروج الإرسال"
        },
        {
          "language": "ckb",
          "text": "دەرچوونی ناردن"
        },
        {
          "language": "en",
          "text": "shipping exit; outbound dispatch area"
        },
        {
          "language": "fa",
          "text": "خروجی ارسال؛ بخش خروج کالا"
        },
        {
          "language": "kmr",
          "text": "derketina şandinê"
        },
        {
          "language": "pl",
          "text": "wyjście wysyłkowe"
        },
        {
          "language": "ro",
          "text": "ieșire de expediere"
        },
        {
          "language": "ru",
          "text": "выход отгрузки"
        },
        {
          "language": "sq",
          "text": "dalje dërgese"
        },
        {
          "language": "tr",
          "text": "sevkiyat çıkışı"
        }
      ],
      "examples": [
        {
          "baseText": "Am Versandausgang wird jede Ladeeinheit im ERP gescannt.",
          "translations": [
            {
              "language": "ar",
              "text": "عند مخرج الشحن تُمسح كل وحدة تحميل في ERP."
            },
            {
              "language": "ckb",
              "text": "لە دەرچوونی ناردن هەر یەکەی بارکردن لە ERP دا سکان دەکرێت."
            },
            {
              "language": "en",
              "text": "At the shipping exit, every loading unit is scanned in the ERP."
            },
            {
              "language": "fa",
              "text": "در خروجی ارسال، هر واحد بارگیری در ERP اسکن می‌شود."
            },
            {
              "language": "kmr",
              "text": "Li derketina şandinê her yekîneya barkirinê di ERP de tê skenkirin."
            },
            {
              "language": "pl",
              "text": "Przy wyjściu wysyłkowym każda jednostka ładunkowa jest skanowana w ERP."
            },
            {
              "language": "ro",
              "text": "La ieșirea de expediere, fiecare unitate de încărcare este scanată în ERP."
            },
            {
              "language": "ru",
              "text": "На выходе отгрузки каждая грузовая единица сканируется в ERP."
            },
            {
              "language": "sq",
              "text": "Në daljen e dërgesës çdo njësi ngarkese skanohet në ERP."
            },
            {
              "language": "tr",
              "text": "Sevkiyat çıkışında her yükleme birimi ERP’de taranır."
            }
          ]
        },
        {
          "baseText": "Die Ware steht schon am Versandausgang, aber der Lkw ist noch nicht da.",
          "translations": [
            {
              "language": "ar",
              "text": "البضاعة موجودة بالفعل عند مخرج الشحن، لكن الشاحنة لم تصل بعد."
            },
            {
              "language": "ckb",
              "text": "کاڵاکە پێشتر لە دەرچوونی ناردندا دانراوە، بەڵام بارهەڵگرەکە هێشتا نەگەیشتووە."
            },
            {
              "language": "en",
              "text": "The goods are already at the shipping exit, but the truck has not arrived yet."
            },
            {
              "language": "fa",
              "text": "کالا از قبل در خروجی ارسال است، اما کامیون هنوز نرسیده است."
            },
            {
              "language": "kmr",
              "text": "Mal jixwe li derketina şandinê ye, lê kamyon hîn negihîştiye."
            },
            {
              "language": "pl",
              "text": "Towar stoi już przy wyjściu wysyłkowym, ale ciężarówka jeszcze nie przyjechała."
            },
            {
              "language": "ro",
              "text": "Marfa este deja la ieșirea de expediere, dar camionul nu a sosit încă."
            },
            {
              "language": "ru",
              "text": "Товар уже стоит на выходе отгрузки, но грузовик еще не приехал."
            },
            {
              "language": "sq",
              "text": "Malli është tashmë te dalja e dërgesës, por kamioni ende nuk ka mbërritur."
            },
            {
              "language": "tr",
              "text": "Mal zaten sevkiyat çıkışında, ancak kamyon henüz gelmedi."
            }
          ]
        }
      ]
    },
    {
      "word": "Versandkontrolle",
      "language": "de",
