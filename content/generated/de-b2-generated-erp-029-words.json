      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Versände",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-sand",
      "topics": [
        "warehouse-and-logistics",
        "transport-and-travel",
