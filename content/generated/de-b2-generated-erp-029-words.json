        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Versand",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Kontrolle",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فحص الشحن"
        },
        {
          "language": "ckb",
          "text": "کۆنترۆڵی ناردن"
        },
        {
          "language": "en",
          "text": "shipping check"
        },
        {
          "language": "fa",
          "text": "کنترل ارسال"
        },
        {
          "language": "kmr",
          "text": "kontrola şandinê"
        },
        {
          "language": "pl",
          "text": "kontrola wysyłki"
        },
        {
          "language": "ro",
          "text": "control de expediere"
        },
        {
          "language": "ru",
          "text": "контроль отгрузки"
        },
        {
          "language": "sq",
          "text": "kontroll dërgese"
        },
        {
          "language": "tr",
          "text": "sevkiyat kontrolü"
        }
      ],
      "examples": [
        {
          "baseText": "Die Versandkontrolle verhindert im ERP, dass falsche Artikel verladen werden.",
          "translations": [
            {
              "language": "ar",
              "text": "تمنع فحص الشحن في ERP تحميل أصناف خاطئة."
            },
            {
              "language": "ckb",
              "text": "کۆنترۆڵی ناردن لە ERP دا ڕێگری دەکات ماددەی هەڵە بار بکرێت."
            },
            {
              "language": "en",
              "text": "The shipping check in the ERP prevents wrong items from being loaded."
            },
            {
              "language": "fa",
              "text": "کنترل ارسال در ERP مانع بارگیری کالاهای اشتباه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kontrola şandinê di ERP de rê nade ku babetên şaş werin barkirin."
            },
            {
              "language": "pl",
              "text": "Kontrola wysyłki w ERP zapobiega załadunkowi błędnych artykułów."
            },
            {
              "language": "ro",
              "text": "Controlul de expediere din ERP împiedică încărcarea articolelor greșite."
            },
            {
              "language": "ru",
              "text": "Контроль отгрузки в ERP предотвращает загрузку неправильных товаров."
            },
            {
              "language": "sq",
              "text": "Kontrolli i dërgesës në ERP pengon ngarkimin e artikujve të gabuar."
            },
            {
              "language": "tr",
