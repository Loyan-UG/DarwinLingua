  "entries": [
    {
      "word": "umkommen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "umkommen",
      "pronunciationIpa": null,
      "syllableBreak": "um-kom-men",
      "topics": [
        "quality-and-risk",
        "transport-and-travel",
        "public-services"
      ],
      "usageLabels": [
        "written",
        "spoken"
      ],
      "contextLabels": [
        "risk",
        "transport",
        "public-services"
      ],
      "grammarNotes": [
        "inseparable irregular verb: kommt um, kam um, ist umgekommen; means to die in an accident or disaster"
      ],
      "collocations": [
        {
          "text": "bei einem Unfall umkommen",
          "meaning": "to die in an accident"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kommen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يموت في حادث أو كارثة"
        },
        {
          "language": "ckb",
          "text": "لە ڕووداو یان کارەساتدا دەمرێت"
        },
        {
          "language": "en",
          "text": "to die in an accident or disaster"
        },
        {
          "language": "fa",
          "text": "در حادثه یا فاجعه جان باختن"
        },
        {
          "language": "kmr",
          "text": "di qezayê an felaketê de mirin"
        },
        {
          "language": "pl",
          "text": "zginąć w wypadku lub katastrofie"
        },
        {
          "language": "ro",
          "text": "a muri într-un accident sau dezastru"
        },
        {
          "language": "ru",
          "text": "погибнуть в аварии или катастрофе"
        },
        {
          "language": "sq",
          "text": "të vdesësh në aksident ose katastrofë"
        },
        {
          "language": "tr",
          "text": "kazada veya felakette ölmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bei dem schweren Unfall ist zum Glück niemand umgekommen.",
          "translations": [
            {
              "language": "ar",
              "text": "في الحادث الخطير لم يمت أحد لحسن الحظ."
            },
            {
              "language": "ckb",
              "text": "لە ڕووداوە قورسەکەدا بەختەوەرانە کەس نەمر."
            },
            {
              "language": "en",
              "text": "Fortunately, no one died in the serious accident."
            },
            {
              "language": "fa",
              "text": "خوشبختانه در آن حادثه شدید کسی جان نباخت."
            },
            {
              "language": "kmr",
              "text": "Di qezaya giran de bi kêfxweşî kes nemir."
            },
            {
              "language": "pl",
              "text": "W poważnym wypadku na szczęście nikt nie zginął."
            },
            {
              "language": "ro",
              "text": "Din fericire, nimeni nu a murit în accidentul grav."
            },
            {
              "language": "ru",
              "text": "К счастью, в серьезной аварии никто не погиб."
            },
            {
              "language": "sq",
              "text": "Fatmirësisht, askush nuk vdiq në aksidentin e rëndë."
            },
            {
              "language": "tr",
              "text": "Ağır kazada neyse ki kimse ölmedi."
            }
          ]
        },
        {
          "baseText": "Die Behörde prüft, warum bei dem Brand mehrere Tiere umgekommen sind.",
          "translations": [
            {
              "language": "ar",
              "text": "تفحص الهيئة سبب نفوق عدة حيوانات في الحريق."
            },
            {
              "language": "ckb",
              "text": "دەزگاکە دەکۆڵێتەوە بۆچی لە ئاگرەکەدا چەند ئاژەڵێک مردوون."
            },
            {
              "language": "en",
              "text": "The authority is investigating why several animals died in the fire."
            },
            {
              "language": "fa",
              "text": "اداره بررسی می‌کند چرا چند حیوان در آتش‌سوزی تلف شدند."
            },
            {
              "language": "kmr",
              "text": "Dezgeh lêkolîn dike ka çima di şewatê de çend ajal mirin."
            },
            {
              "language": "pl",
              "text": "Urząd sprawdza, dlaczego w pożarze zginęło kilka zwierząt."
            },
            {
              "language": "ro",
              "text": "Autoritatea verifică de ce au murit mai multe animale în incendiu."
            },
            {
              "language": "ru",
              "text": "Ведомство проверяет, почему при пожаре погибло несколько животных."
            },
            {
              "language": "sq",
              "text": "Autoriteti po heton pse disa kafshë ngordhën në zjarr."
            },
            {
              "language": "tr",
