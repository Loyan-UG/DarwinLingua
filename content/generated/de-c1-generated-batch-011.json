      "word": "die Anschlussfähigkeit",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Anschlussfähigkeiten",
      "infinitive": null,
      "syllableBreak": "An-schluss-fä-hig-keit",
      "topics": [
        "technology-and-it",
        "education-and-training",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "technical",
        "analysis",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun; plural is uncommon"
      ],
      "collocations": [
        {
          "text": "technische Anschlussfähigkeit",
          "meaning": "technical compatibility/connectability"
        },
        {
          "text": "soziale Anschlussfähigkeit",
          "meaning": "social or discursive compatibility"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "anschlussfähig",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "der Anschluss",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "قابلية الارتباط؛ قابلية التوافق"
        },
        {
          "language": "ckb",
          "text": "توانای پەیوەستبوون؛ گونجاوی بۆ بەستنەوە"
        },
        {
          "language": "en",
          "text": "connectability; compatibility"
        },
        {
          "language": "fa",
          "text": "قابلیت اتصال؛ قابلیت پیوند و سازگاری"
        },
        {
          "language": "kmr",
          "text": "karîna girêdanê; guncawbûn"
        },
        {
          "language": "pl",
          "text": "zdolność do połączenia; kompatybilność"
        },
        {
          "language": "ro",
          "text": "capacitate de conectare; compatibilitate"
        },
        {
          "language": "ru",
          "text": "совместимость; способность к подключению"
        },
        {
          "language": "sq",
          "text": "aftësi lidhjeje; përputhshmëri"
        },
        {
          "language": "tr",
          "text": "bağlanabilirlik; uyumluluk"
        }
      ],
      "examples": [
        {
          "baseText": "Die Anschlussfähigkeit der neuen Schnittstelle entscheidet darüber, wie schnell Partner angebunden werden können.",
          "translations": [
            {
              "language": "ar",
              "text": "تحدد قابلية اتصال الواجهة الجديدة مدى سرعة ربط الشركاء."
            },
            {
              "language": "ckb",
              "text": "توانای پەیوەستبوونی ڕووکاری نوێ بڕیار دەدات هاوبەشان بە چ خێراییەک پەیوەست دەکرێن."
            },
            {
              "language": "en",
              "text": "The compatibility of the new interface determines how quickly partners can be connected."
            },
            {
              "language": "fa",
              "text": "قابلیت اتصال رابط جدید تعیین می‌کند که شرکا با چه سرعتی متصل شوند."
            },
            {
              "language": "kmr",
              "text": "Guncawbûna navrûya nû diyar dike ka hevkar çiqas zû dikarin werin girêdan."
            },
            {
              "language": "pl",
              "text": "Kompatybilność nowego interfejsu decyduje o tym, jak szybko można podłączyć partnerów."
            },
            {
              "language": "ro",
              "text": "Compatibilitatea noii interfețe decide cât de repede pot fi conectați partenerii."
            },
            {
              "language": "ru",
              "text": "Совместимость нового интерфейса определяет, насколько быстро можно подключить партнеров."
            },
            {
              "language": "sq",
              "text": "Përputhshmëria e ndërfaqes së re përcakton sa shpejt mund të lidhen partnerët."
            },
            {
              "language": "tr",
              "text": "Yeni arayüzün uyumluluğu, iş ortaklarının ne kadar hızlı bağlanabileceğini belirler."
            }
          ]
        },
        {
          "baseText": "Der Vortrag gewann an Anschlussfähigkeit, als die Professorin Beispiele aus der beruflichen Praxis einbezog.",
          "translations": [
            {
              "language": "ar",
              "text": "زاد ارتباط المحاضرة بالجمهور عندما أدرجت الأستاذة أمثلة من الممارسة المهنية."
            },
            {
              "language": "ckb",
              "text": "وتارەکە توانای پەیوەندیی زیاتر بەدەستهێنا کاتێک پرۆفیسۆرەکە نموونەی کرداری پیشەییی خستە ناوەوە."
            },
            {
              "language": "en",
              "text": "The lecture became more accessible when the professor included examples from professional practice."
            },
            {
              "language": "fa",
              "text": "سخنرانی وقتی ارتباط‌پذیرتر شد که استاد مثال‌هایی از عمل حرفه‌ای آورد."
            },
            {
              "language": "kmr",
              "text": "Axaftin zêdetir guncaw bû dema profesorê nimûneyên ji pratîka pîşeyî tevlî kir."
            },
            {
              "language": "pl",
              "text": "Wykład zyskał na przystępności, gdy profesorka włączyła przykłady z praktyki zawodowej."
            },
            {
              "language": "ro",
              "text": "Prelegerea a devenit mai relevantă când profesoara a inclus exemple din practica profesională."
            },
            {
              "language": "ru",
              "text": "Лекция стала более связанной с опытом слушателей, когда профессор включила примеры из профессиональной практики."
            },
            {
              "language": "sq",
              "text": "Ligjërata u bë më e kapshme kur profesoresha përfshiu shembuj nga praktika profesionale."
            },
            {
              "language": "tr",
              "text": "Profesör mesleki uygulamadan örnekler ekleyince sunum daha bağlantı kurulabilir hale geldi."
            }
          ]
        }
      ]
    },
