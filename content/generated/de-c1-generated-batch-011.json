  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "anschleichen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anschleichen",
      "syllableBreak": "an-schlei-chen",
      "topics": [
        "social-and-relationships",
        "quality-and-risk",
        "technology-and-it"
      ],
      "usageLabels": [
        "written",
        "advanced",
        "sensitive"
      ],
      "grammarNotes": [
        "strong separable verb; literal or figurative"
      ],
      "collocations": [
        {
          "text": "sich unbemerkt anschleichen",
          "meaning": "to sneak up unnoticed"
        },
        {
          "text": "ein Risiko schleicht sich an",
          "meaning": "a risk emerges gradually"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schleichen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يتسلل مقتربًا؛ يقترب خفية"
        },
        {
          "language": "ckb",
          "text": "بە نهێنی نزیک دەبێتەوە؛ هێواشە هێواش دێتە پێش"
        },
        {
          "language": "en",
          "text": "to sneak up; to approach stealthily"
        },
        {
          "language": "fa",
          "text": "مخفیانه نزدیک شدن؛ آرام‌آرام پدیدار شدن"
        },
        {
          "language": "kmr",
          "text": "bi dizî nêzîk bûn; hêdî hêdî derketin"
        },
        {
          "language": "pl",
          "text": "podkraść się; zbliżać się ukradkiem"
        },
        {
          "language": "ro",
          "text": "a se furișa; a se apropia pe ascuns"
        },
        {
          "language": "ru",
          "text": "подкрадываться; незаметно приближаться"
        },
        {
          "language": "sq",
          "text": "të afrohesh fshehurazi; të zvarritesh pranë"
        },
        {
          "language": "tr",
          "text": "sinsice yaklaşmak; gizlice sokulmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Sicherheitsdienst bemerkte, dass sich eine Person von der Rückseite des Gebäudes anschlich.",
          "translations": [
            {
              "language": "ar",
              "text": "لاحظ الأمن أن شخصًا كان يقترب خفية من الجهة الخلفية للمبنى."
            },
            {
              "language": "ckb",
              "text": "ئاسایشەکە تێبینی کرد کە کەسێک بە نهێنی لە پشتەوەی بیناکە نزیک دەبێتەوە."
            },
            {
              "language": "en",
              "text": "Security noticed that a person was sneaking up from the back of the building."
            },
            {
              "language": "fa",
              "text": "نیروی امنیتی متوجه شد فردی از پشت ساختمان مخفیانه نزدیک می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ewlehî têbînî kir ku kesek ji pişta avahiyê bi dizî nêzîk dibû."
            },
            {
              "language": "pl",
              "text": "Ochrona zauważyła, że od tyłu budynku podkrada się jakaś osoba."
            },
            {
              "language": "ro",
              "text": "Serviciul de securitate a observat că o persoană se apropia pe furiș din spatele clădirii."
            },
            {
              "language": "ru",
              "text": "Охрана заметила, что с задней стороны здания кто-то подкрадывается."
            },
            {
              "language": "sq",
              "text": "Siguria vuri re se një person po afrohej fshehurazi nga pjesa e pasme e ndërtesës."
            },
            {
              "language": "tr",
              "text": "Güvenlik, binanın arka tarafından bir kişinin gizlice yaklaştığını fark etti."
            }
          ]
        },
        {
          "baseText": "In langen Projekten schleichen sich Qualitätsprobleme oft an, bevor sie im Reporting sichtbar werden.",
          "translations": [
            {
              "language": "ar",
              "text": "في المشاريع الطويلة غالبًا ما تظهر مشكلات الجودة تدريجيًا قبل أن تصبح مرئية في التقارير."
            },
            {
              "language": "ckb",
              "text": "لە پڕۆژە درێژەکاندا کێشەکانی کوالیتی زۆرجار هێواشە هێواش دێنە پێش پێش ئەوەی لە ڕاپۆرتدا دیار بن."
            },
            {
              "language": "en",
              "text": "In long projects, quality problems often creep up before they become visible in reporting."
            },
            {
              "language": "fa",
              "text": "در پروژه‌های طولانی، مشکلات کیفیت اغلب آرام‌آرام ظاهر می‌شوند پیش از آنکه در گزارش‌ها دیده شوند."
            },
            {
              "language": "kmr",
              "text": "Di projeyên dirêj de pirsgirêkên kalîteyê gelek caran hêdî hêdî têne pêş berî ku di raporê de xuya bibin."
            },
            {
              "language": "pl",
              "text": "W długich projektach problemy jakościowe często narastają niezauważenie, zanim staną się widoczne w raportach."
            },
            {
              "language": "ro",
              "text": "În proiectele lungi, problemele de calitate apar adesea treptat înainte să devină vizibile în raportare."
            },
            {
              "language": "ru",
              "text": "В длинных проектах проблемы качества часто подкрадываются до того, как становятся видны в отчетности."
            },
            {
              "language": "sq",
              "text": "Në projekte të gjata, problemet e cilësisë shpesh afrohen gradualisht para se të duken në raportim."
            },
            {
              "language": "tr",
              "text": "Uzun projelerde kalite sorunları raporlamada görünür olmadan önce çoğu zaman yavaşça belirir."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
