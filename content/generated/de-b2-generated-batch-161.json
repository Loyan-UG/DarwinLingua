      "meanings": [
        {
          "language": "ar",
          "text": "يحضر؛ يصل إلى مكان"
        },
        {
          "language": "ckb",
          "text": "دەگات؛ لە شوێنێک ئامادە دەبێت"
        },
        {
          "language": "en",
          "text": "to arrive; to appear; to gather"
        },
        {
          "language": "fa",
          "text": "حاضر شدن؛ رسیدن"
        },
        {
          "language": "kmr",
          "text": "hatin; li cihê xwe amade bûn"
        },
        {
          "language": "pl",
          "text": "stawić się; przybyć"
        },
        {
          "language": "ro",
          "text": "a se prezenta; a sosi"
        },
        {
          "language": "ru",
          "text": "явиться; прибыть"
        },
        {
          "language": "sq",
          "text": "të paraqitesh; të mbërrish"
        },
        {
          "language": "tr",
          "text": "hazır bulunmak; gelmek"
        }
      ],
      "examples": [
        {
          "baseText": "Alle Teilnehmenden sollen sich bitte zehn Minuten vor Beginn im Schulungsraum einfinden.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى من جميع المشاركين الحضور إلى قاعة التدريب قبل البداية بعشر دقائق."
            },
            {
              "language": "ckb",
              "text": "تکایە هەموو بەشداربووان دە خولەک پێش دەستپێکردن لە ژووری ڕاهێنان ئامادە بن."
            },
            {
              "language": "en",
              "text": "All participants should please arrive in the training room ten minutes before the start."
            },
            {
              "language": "fa",
              "text": "همه شرکت‌کنندگان لطفاً ده دقیقه قبل از شروع در اتاق آموزش حاضر شوند."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe hemû beşdar deh xulek beriya destpêkê li odeya perwerdehiyê amade bin."
            },
            {
              "language": "pl",
              "text": "Wszyscy uczestnicy proszeni są o stawienie się w sali szkoleniowej dziesięć minut przed rozpoczęciem."
            },
            {
              "language": "ro",
              "text": "Toți participanții sunt rugați să se prezinte în sala de instruire cu zece minute înainte de începere."
            },
            {
              "language": "ru",
              "text": "Всех участников просят явиться в учебный зал за десять минут до начала."
            },
            {
              "language": "sq",
              "text": "Të gjithë pjesëmarrësit lutemi të paraqiten në sallën e trajnimit dhjetë minuta para fillimit."
            },
            {
              "language": "tr",
              "text": "Tüm katılımcıların başlangıçtan on dakika önce eğitim odasında hazır bulunmaları rica olunur."
            }
          ]
        },
        {
          "baseText": "Zur Bürgerversammlung fanden sich deutlich mehr Menschen ein als erwartet.",
          "translations": [
            {
              "language": "ar",
              "text": "حضر اجتماع المواطنين عدد أكبر بكثير من المتوقع."
            },
            {
              "language": "ckb",
              "text": "بۆ کۆبوونەوەی هاووڵاتیان زۆر کەسی زیاتر لە چاوەڕوانکراو ئامادە بوون."
            },
            {
              "language": "en",
              "text": "Significantly more people turned up for the citizens’ meeting than expected."
            },
            {
              "language": "fa",
              "text": "برای نشست شهروندان، افراد بسیار بیشتری از حد انتظار حاضر شدند."
            },
            {
              "language": "kmr",
              "text": "Ji bo civîna welatiyan ji ya hatibû hêvîkirin gelek kesên zêdetir hatin."
            },
            {
              "language": "pl",
              "text": "Na zebranie mieszkańców stawiło się znacznie więcej osób, niż oczekiwano."
            },
            {
              "language": "ro",
              "text": "La adunarea cetățenească s-au prezentat mult mai mulți oameni decât se aștepta."
            },
            {
              "language": "ru",
              "text": "На собрание жителей пришло значительно больше людей, чем ожидалось."
            },
            {
              "language": "sq",
              "text": "Në mbledhjen qytetare u paraqitën shumë më tepër njerëz sesa pritej."
            },
            {
              "language": "tr",
              "text": "Vatandaş toplantısına beklenenden çok daha fazla kişi geldi."
            }
          ]
        }
      ]
    }
  ],
