        {
          "language": "fa",
          "text": "دوش گرفتن"
        },
        {
          "language": "kmr",
          "text": "duş kirin"
        },
        {
          "language": "pl",
          "text": "brać prysznic"
        },
        {
          "language": "ro",
          "text": "a face duș"
        },
        {
          "language": "ru",
          "text": "принимать душ"
        },
        {
          "language": "sq",
          "text": "bëj dush"
        },
        {
          "language": "tr",
          "text": "duş almak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich dusche jeden Morgen.",
          "translations": [
            {
              "language": "ar",
              "text": "أستحم كل صباح."
            },
            {
              "language": "ckb",
              "text": "من هەموو بەیانییەک دوش دەکەم."
            },
            {
              "language": "en",
              "text": "I shower every morning."
            },
            {
              "language": "fa",
              "text": "من هر صبح دوش می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez her sibeh duş dikim."
            },
            {
              "language": "pl",
              "text": "Biorę prysznic każdego ranka."
            },
            {
              "language": "ro",
              "text": "Fac duș în fiecare dimineață."
            },
            {
              "language": "ru",
              "text": "Я принимаю душ каждое утро."
            },
            {
              "language": "sq",
              "text": "Bëj dush çdo mëngjes."
            },
            {
              "language": "tr",
              "text": "Her sabah duş alıyorum."
            }
          ]
        },
        {
          "baseText": "Kann ich hier duschen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني الاستحمام هنا؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم لێرە دوش بکەم؟"
            },
            {
              "language": "en",
              "text": "Can I shower here?"
            },
            {
              "language": "fa",
              "text": "می‌توانم اینجا دوش بگیرم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim li vir duş bikim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę tutaj wziąć prysznic?"
            },
            {
              "language": "ro",
              "text": "Pot să fac duș aici?"
            },
            {
              "language": "ru",
              "text": "Можно здесь принять душ?"
            },
            {
              "language": "sq",
              "text": "A mund të bëj dush këtu?"
            },
            {
              "language": "tr",
              "text": "Burada duş alabilir miyim?"
            }
          ]
        }
      ]
    },
