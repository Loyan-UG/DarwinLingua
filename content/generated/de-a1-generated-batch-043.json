      "examples": [
        {
          "baseText": "Ich möchte ein kaltes Getränk.",
          "translations": [
            {
              "language": "ar",
              "text": "أريد مشروباً بارداً."
            },
            {
              "language": "ckb",
              "text": "دەمەوێ خواردنەوەیەکی سارد."
            },
            {
              "language": "en",
              "text": "I would like a cold drink."
            },
            {
              "language": "fa",
              "text": "یک نوشیدنی سرد می‌خواهم."
            },
            {
              "language": "kmr",
              "text": "Ez vexwarinek sar dixwazim."
            },
            {
              "language": "pl",
              "text": "Chciałbym zimny napój."
            },
            {
              "language": "ro",
              "text": "Aș dori o băutură rece."
            },
            {
              "language": "ru",
              "text": "Я хотел бы холодный напиток."
            },
            {
              "language": "sq",
              "text": "Dua një pije të ftohtë."
            },
            {
              "language": "tr",
              "text": "Soğuk bir içecek istiyorum."
            }
          ]
        },
        {
          "baseText": "Sind die Getränke schon da?",
          "translations": [
            {
              "language": "ar",
              "text": "هل وصلت المشروبات بالفعل؟"
            },
            {
              "language": "ckb",
              "text": "خواردنەوەکان ئێستا هاتوون؟"
            },
            {
              "language": "en",
              "text": "Are the drinks here already?"
            },
            {
              "language": "fa",
              "text": "نوشیدنی‌ها رسیده‌اند؟"
            },
            {
              "language": "kmr",
              "text": "Vexwarin jixwe hatine?"
            },
            {
              "language": "pl",
              "text": "Czy napoje już są?"
            },
            {
              "language": "ro",
              "text": "Au venit deja băuturile?"
            },
            {
              "language": "ru",
              "text": "Напитки уже принесли?"
            },
            {
              "language": "sq",
              "text": "A kanë ardhur pijet tashmë?"
            },
            {
              "language": "tr",
              "text": "İçecekler geldi mi?"
            }
          ]
        }
