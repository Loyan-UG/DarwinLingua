      "meanings": [
        {
          "language": "ar",
          "text": "محبوب؛ رائج"
        },
        {
          "language": "ckb",
          "text": "خۆشەویست؛ بەناوبانگ"
        },
        {
          "language": "en",
          "text": "popular; well-liked"
        },
        {
          "language": "fa",
          "text": "محبوب؛ پرطرفدار"
        },
        {
          "language": "kmr",
          "text": "navdar; hezkirî"
        },
        {
          "language": "pl",
          "text": "popularny; lubiany"
        },
        {
          "language": "ro",
          "text": "popular; apreciat"
        },
        {
          "language": "ru",
          "text": "популярный; любимый"
        },
        {
          "language": "sq",
          "text": "i njohur; i pëlqyer"
        },
        {
          "language": "tr",
          "text": "popüler; sevilen"
        }
      ],
      "examples": [
        {
          "baseText": "Dieses Café ist bei Studenten sehr beliebt.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا المقهى محبوب جداً لدى الطلاب."
            },
            {
              "language": "ckb",
              "text": "ئەم کافێیە لای قوتابیان زۆر خۆشەویستە."
            },
            {
              "language": "en",
              "text": "This café is very popular with students."
            },
            {
              "language": "fa",
              "text": "این کافه بین دانشجویان خیلی محبوب است."
            },
            {
              "language": "kmr",
              "text": "Ev kafe li ba xwendekaran pir navdar e."
            },
            {
              "language": "pl",
              "text": "Ta kawiarnia jest bardzo popularna wśród studentów."
            },
            {
              "language": "ro",
              "text": "Această cafenea este foarte populară printre studenți."
            },
            {
              "language": "ru",
              "text": "Это кафе очень популярно среди студентов."
            },
            {
              "language": "sq",
              "text": "Kjo kafene është shumë e pëlqyer nga studentët."
            },
            {
              "language": "tr",
              "text": "Bu kafe öğrenciler arasında çok popüler."
            }
          ]
        },
        {
          "baseText": "Das Produkt ist bei unseren Kunden beliebt.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا المنتج محبوب لدى عملائنا."
            },
            {
              "language": "ckb",
              "text": "ئەم بەرهەمە لای کڕیارەکانمان خۆشەویستە."
            },
            {
              "language": "en",
              "text": "The product is popular with our customers."
            },
            {
              "language": "fa",
              "text": "این محصول بین مشتریان ما محبوب است."
            },
            {
              "language": "kmr",
              "text": "Ev berhem li ba xerîdarên me hezkirî ye."
            },
            {
              "language": "pl",
              "text": "Produkt jest popularny wśród naszych klientów."
            },
            {
              "language": "ro",
              "text": "Produsul este apreciat de clienții noștri."
            },
            {
              "language": "ru",
              "text": "Этот продукт популярен у наших клиентов."
            },
            {
              "language": "sq",
              "text": "Produkti është i pëlqyer nga klientët tanë."
            },
            {
              "language": "tr",
              "text": "Ürün müşterilerimiz arasında popüler."
            }
          ]
        }
      ]
    },
