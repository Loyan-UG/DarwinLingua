      "examples": [
        {
          "baseText": "Mach bitte die Tür zu.",
          "translations": [
            {
              "language": "ar",
              "text": "أغلق الباب من فضلك."
            },
            {
              "language": "ckb",
              "text": "تکایە دەرگاکە دابخە."
            },
            {
              "language": "en",
              "text": "Please close the door."
            },
            {
              "language": "fa",
              "text": "لطفاً در را ببند."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe derî bigire."
            },
            {
              "language": "pl",
              "text": "Zamknij proszę drzwi."
            },
            {
              "language": "ro",
              "text": "Închide ușa, te rog."
            },
            {
              "language": "ru",
              "text": "Закрой дверь, пожалуйста."
            },
            {
              "language": "sq",
              "text": "Mbylle derën, të lutem."
            },
            {
              "language": "tr",
              "text": "Lütfen kapıyı kapat."
            }
          ]
        },
        {
          "baseText": "Wir machen das Fenster zu.",
          "translations": [
            {
              "language": "ar",
              "text": "نغلق النافذة."
            },
            {
              "language": "ckb",
              "text": "پەنجەرەکە دادەخەین."
            },
            {
              "language": "en",
              "text": "We are closing the window."
            },
            {
              "language": "fa",
              "text": "ما پنجره را می‌بندیم."
            },
            {
              "language": "kmr",
              "text": "Em pencereyê digirin."
            },
            {
              "language": "pl",
              "text": "Zamykamy okno."
            },
            {
              "language": "ro",
              "text": "Închidem fereastra."
            },
            {
              "language": "ru",
              "text": "Мы закрываем окно."
            },
            {
              "language": "sq",
              "text": "Ne po mbyllim dritaren."
            },
            {
              "language": "tr",
              "text": "Pencereyi kapatıyoruz."
            }
          ]
        }
      ]
    },
