      "contextLabels": [],
      "grammarNotes": [
        "adverb meaning at home; often also written zu Hause"
      ],
      "collocations": [
        {
          "text": "zuhause bleiben",
          "meaning": "to stay at home"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Zuhause",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "في البيت"
        },
        {
          "language": "ckb",
          "text": "لە ماڵەوە"
        },
        {
          "language": "en",
          "text": "at home"
        },
        {
          "language": "fa",
          "text": "در خانه"
        },
        {
          "language": "kmr",
          "text": "li malê"
        },
        {
          "language": "pl",
          "text": "w domu"
        },
        {
          "language": "ro",
          "text": "acasă"
        },
        {
          "language": "ru",
          "text": "дома"
        },
        {
          "language": "sq",
          "text": "në shtëpi"
        },
        {
          "language": "tr",
          "text": "evde"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin heute zuhause.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا في البيت اليوم."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ لە ماڵەوەم."
            },
            {
              "language": "en",
              "text": "I am at home today."
            },
            {
              "language": "fa",
              "text": "امروز در خانه هستم."
            },
            {
              "language": "kmr",
              "text": "Ez îro li malê me."
            },
            {
              "language": "pl",
              "text": "Jestem dziś w domu."
            },
            {
              "language": "ro",
              "text": "Sunt acasă astăzi."
            },
            {
              "language": "ru",
              "text": "Сегодня я дома."
            },
            {
              "language": "sq",
              "text": "Sot jam në shtëpi."
            },
            {
              "language": "tr",
              "text": "Bugün evdeyim."
            }
          ]
        },
        {
          "baseText": "Am Wochenende bleiben wir zuhause.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع نبقى في البيت."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا لە ماڵەوە دەمێنین."
            },
            {
              "language": "en",
              "text": "At the weekend we stay at home."
            },
            {
              "language": "fa",
              "text": "آخر هفته در خانه می‌مانیم."
            },
            {
              "language": "kmr",
              "text": "Di dawiya hefteyê de em li malê dimînin."
            },
            {
              "language": "pl",
              "text": "W weekend zostajemy w domu."
            },
            {
              "language": "ro",
              "text": "În weekend stăm acasă."
            },
            {
              "language": "ru",
              "text": "На выходных мы остаёмся дома."
            },
            {
              "language": "sq",
              "text": "Në fundjavë rrimë në shtëpi."
            },
            {
              "language": "tr",
              "text": "Hafta sonu evde kalıyoruz."
            }
          ]
        }
      ]
    },
