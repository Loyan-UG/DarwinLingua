  "entries": [
    {
      "word": "Gesamtvolumen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Gesamtvolumen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ge-samt-vo-lu-men",
      "topics": [
        "warehouse-and-logistics",
        "transport-and-travel",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter compound noun; total volume of goods, shipment, or load"
      ],
      "collocations": [
        {
          "text": "das Gesamtvolumen berechnen",
          "meaning": "to calculate the total volume"
        },
        {
          "text": "das Gesamtvolumen überschreiten",
          "meaning": "to exceed the total volume"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gesamt",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "das Volumen",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الحجم الإجمالي"
        },
        {
          "language": "ckb",
          "text": "قەبارەی گشتی"
        },
        {
          "language": "en",
          "text": "total volume"
        },
        {
          "language": "fa",
          "text": "حجم کل"
        },
        {
          "language": "kmr",
          "text": "qebareya giştî"
        },
        {
          "language": "pl",
          "text": "całkowita objętość"
        },
        {
          "language": "ro",
          "text": "volum total"
        },
        {
          "language": "ru",
          "text": "общий объем"
        },
        {
          "language": "sq",
          "text": "vëllimi total"
        },
        {
          "language": "tr",
          "text": "toplam hacim"
        }
      ],
      "examples": [
        {
          "baseText": "Das Gesamtvolumen der Lieferung wird im ERP für die Tourplanung berechnet.",
          "translations": [
            {
              "language": "ar",
              "text": "يُحسب الحجم الإجمالي للتسليم في ERP من أجل تخطيط الجولة."
            },
            {
              "language": "ckb",
              "text": "قەبارەی گشتیی گەیاندنەکە لە ERP دا بۆ پلاندانی گەشتەکە هەژمار دەکرێت."
            },
            {
              "language": "en",
              "text": "The total volume of the delivery is calculated in the ERP for route planning."
            },
            {
              "language": "fa",
              "text": "حجم کل تحویل در ERP برای برنامه‌ریزی مسیر محاسبه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Qebareya giştî ya radestkirinê di ERP de ji bo plansaziya rêyê tê hesibandin."
            },
            {
              "language": "pl",
              "text": "Całkowita objętość dostawy jest obliczana w ERP do planowania trasy."
            },
            {
              "language": "ro",
              "text": "Volumul total al livrării este calculat în ERP pentru planificarea rutei."
            },
            {
              "language": "ru",
              "text": "Общий объем поставки рассчитывается в ERP для планирования маршрута."
            },
            {
              "language": "sq",
              "text": "Vëllimi total i dorëzimit llogaritet në ERP për planifikimin e turit."
            },
            {
              "language": "tr",
              "text": "Teslimatın toplam hacmi rota planlaması için ERP’de hesaplanır."
            }
          ]
        },
        {
          "baseText": "Das Gesamtvolumen ist zu groß für den kleinen Transporter.",
          "translations": [
            {
              "language": "ar",
              "text": "الحجم الإجمالي كبير جدًا بالنسبة للشاحنة الصغيرة."
            },
            {
              "language": "ckb",
              "text": "قەبارەی گشتی بۆ ئۆتۆمبێلی گواستنەوەی بچووک زۆر گەورەیە."
            },
            {
              "language": "en",
              "text": "The total volume is too large for the small van."
            },
            {
              "language": "fa",
              "text": "حجم کل برای ون کوچک بیش از حد زیاد است."
            },
            {
              "language": "kmr",
              "text": "Qebareya giştî ji bo vana biçûk pir mezin e."
            },
            {
              "language": "pl",
              "text": "Całkowita objętość jest za duża dla małego samochodu dostawczego."
            },
            {
              "language": "ro",
              "text": "Volumul total este prea mare pentru duba mică."
            },
            {
              "language": "ru",
              "text": "Общий объем слишком большой для маленького фургона."
            },
            {
              "language": "sq",
              "text": "Vëllimi total është shumë i madh për furgonin e vogël."
            },
            {
              "language": "tr",
              "text": "Toplam hacim küçük kamyonet için çok fazla."
            }
          ]
        }
      ]
    },
    {
      "word": "GPS",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "GPS-Systeme",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "G-P-S",
      "topics": [
        "technology-and-it",
        "transport-and-travel",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter abbreviation; Global Positioning System"
      ],
      "collocations": [
        {
          "text": "GPS-Daten übertragen",
          "meaning": "to transmit GPS data"
        },
        {
          "text": "per GPS verfolgen",
          "meaning": "to track by GPS"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "Global Positioning System",
          "relationLabel": "full form",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نظام تحديد المواقع العالمي"
        },
        {
          "language": "ckb",
          "text": "سیستەمی دیاریکردنی شوێن GPS"
        },
        {
          "language": "en",
          "text": "GPS; Global Positioning System"
        },
        {
          "language": "fa",
          "text": "سامانه موقعیت‌یابی جهانی؛ GPS"
        },
        {
          "language": "kmr",
          "text": "GPS; Pergala Cîh Diyarkirinê ya Cîhanî"
        },
        {
          "language": "pl",
          "text": "GPS; globalny system pozycjonowania"
        },
        {
          "language": "ro",
          "text": "GPS; sistem global de poziționare"
        },
        {
          "language": "ru",
          "text": "GPS; глобальная система позиционирования"
        },
        {
          "language": "sq",
          "text": "GPS; sistemi global i pozicionimit"
        },
        {
          "language": "tr",
          "text": "GPS; Küresel Konumlandırma Sistemi"
        }
      ],
      "examples": [
        {
          "baseText": "Die GPS-Daten des Fahrzeugs werden alle fünf Minuten an das ERP übertragen.",
          "translations": [
            {
              "language": "ar",
              "text": "تُنقل بيانات GPS الخاصة بالمركبة إلى ERP كل خمس دقائق."
            },
            {
              "language": "ckb",
              "text": "داتای GPS ـی ئۆتۆمبێل هەر پێنج خولەک جارێک بۆ ERP دەنێردرێت."
            },
            {
              "language": "en",
              "text": "The vehicle’s GPS data is transmitted to the ERP every five minutes."
            },
            {
              "language": "fa",
              "text": "داده‌های GPS خودرو هر پنج دقیقه به ERP ارسال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Daneyên GPS ên wesayîtê her pênc deqeyan ji ERP re têne şandin."
            },
            {
              "language": "pl",
              "text": "Dane GPS pojazdu są przesyłane do ERP co pięć minut."
            },
            {
              "language": "ro",
              "text": "Datele GPS ale vehiculului sunt transmise către ERP la fiecare cinci minute."
            },
            {
              "language": "ru",
              "text": "GPS-данные транспортного средства передаются в ERP каждые пять минут."
            },
            {
              "language": "sq",
              "text": "Të dhënat GPS të automjetit dërgohen në ERP çdo pesë minuta."
            },
            {
              "language": "tr",
              "text": "Aracın GPS verileri her beş dakikada bir ERP’ye aktarılır."
            }
          ]
        },
        {
          "baseText": "Dank GPS konnte der Kunde sehen, wann die Lieferung ungefähr ankommt.",
          "translations": [
            {
              "language": "ar",
              "text": "بفضل GPS استطاع العميل معرفة موعد وصول التسليم تقريبًا."
            },
            {
              "language": "ckb",
              "text": "بەهۆی GPS ـەوە کڕیار توانی ببینێت گەیاندنەکە نزیکەی کەی دەگات."
            },
            {
              "language": "en",
              "text": "Thanks to GPS, the customer could see approximately when the delivery would arrive."
            },
            {
              "language": "fa",
              "text": "به کمک GPS مشتری توانست ببیند تحویل تقریباً چه زمانی می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Bi saya GPS, mişterî karî bibîne radestkirin nêzîkî kengê digihîje."
            },
            {
              "language": "pl",
              "text": "Dzięki GPS klient mógł zobaczyć, kiedy dostawa mniej więcej dotrze."
            },
            {
              "language": "ro",
              "text": "Datorită GPS-ului, clientul a putut vedea aproximativ când ajunge livrarea."
            },
            {
              "language": "ru",
              "text": "Благодаря GPS клиент смог увидеть, когда примерно прибудет доставка."
            },
            {
              "language": "sq",
              "text": "Falë GPS-it, klienti mundi të shihte afërsisht kur mbërrin dorëzimi."
            },
            {
              "language": "tr",
              "text": "GPS sayesinde müşteri teslimatın yaklaşık ne zaman ulaşacağını görebildi."
            }
          ]
        }
      ]
    },
    {
      "word": "Gruppenrabatt",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Gruppenrabatte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Grup-pen-ra-batt",
      "topics": [
        "sales-and-customers",
        "finance-and-accounting",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "administrative",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; discount applied to a customer or product group"
      ],
      "collocations": [
        {
          "text": "einen Gruppenrabatt gewähren",
          "meaning": "to grant a group discount"
        },
        {
          "text": "den Gruppenrabatt berechnen",
          "meaning": "to calculate the group discount"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Gruppe",
          "relationLabel": "component noun",
          "note": null
        },
        {
          "lemma": "der Rabatt",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خصم جماعي"
        },
        {
          "language": "ckb",
          "text": "داشکاندنی گرووپی"
        },
        {
          "language": "en",
          "text": "group discount"
        },
        {
          "language": "fa",
          "text": "تخفیف گروهی"
        },
        {
          "language": "kmr",
          "text": "daxistina komê"
        },
        {
          "language": "pl",
          "text": "rabat grupowy"
        },
        {
          "language": "ro",
          "text": "discount de grup"
        },
        {
          "language": "ru",
          "text": "групповая скидка"
        },
        {
          "language": "sq",
          "text": "zbritje grupore"
        },
        {
          "language": "tr",
          "text": "grup indirimi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Gruppenrabatt wird im ERP automatisch auf alle Kunden dieser Preisgruppe angewendet.",
          "translations": [
            {
              "language": "ar",
              "text": "يُطبق الخصم الجماعي في ERP تلقائيًا على جميع عملاء مجموعة الأسعار هذه."
            },
            {
              "language": "ckb",
              "text": "داشکاندنی گرووپی لە ERP دا خۆکارانە بۆ هەموو کڕیارانی ئەم گرووپی نرخە بەکاردێت."
            },
            {
              "language": "en",
              "text": "The group discount is automatically applied in the ERP to all customers in this price group."
            },
            {
              "language": "fa",
              "text": "تخفیف گروهی در ERP به‌صورت خودکار برای همه مشتریان این گروه قیمتی اعمال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Daxistina komê di ERP de xweber li hemû mişteriyên vê koma bihayê tê sepandin."
            },
            {
              "language": "pl",
              "text": "Rabat grupowy jest automatycznie stosowany w ERP dla wszystkich klientów tej grupy cenowej."
            },
            {
              "language": "ro",
              "text": "Discountul de grup este aplicat automat în ERP tuturor clienților din această grupă de preț."
            },
            {
              "language": "ru",
