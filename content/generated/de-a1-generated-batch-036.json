          "language": "en",
          "text": "to be fit; to be well"
        },
        {
          "language": "fa",
          "text": "سرحال بودن؛ آماده بودن"
        },
        {
          "language": "kmr",
          "text": "saxlem bûn; fit bûn"
        },
        {
          "language": "pl",
          "text": "być w formie"
        },
        {
          "language": "ro",
          "text": "a fi în formă"
        },
        {
          "language": "ru",
          "text": "быть в форме; быть здоровым"
        },
        {
          "language": "sq",
          "text": "jam në formë"
        },
        {
          "language": "tr",
          "text": "formda olmak; iyi olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin wieder fit.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا بخير مرة أخرى."
            },
            {
              "language": "ckb",
              "text": "من دیسان لەشساغم."
            },
            {
              "language": "en",
              "text": "I am fit again."
            },
            {
              "language": "fa",
              "text": "من دوباره سرحالم."
            },
            {
              "language": "kmr",
              "text": "Ez dîsa fit im."
            },
            {
              "language": "pl",
              "text": "Znowu jestem w formie."
            },
            {
              "language": "ro",
              "text": "Sunt din nou în formă."
            },
            {
              "language": "ru",
              "text": "Я снова в форме."
            },
            {
              "language": "sq",
              "text": "Jam përsëri në formë."
            },
            {
              "language": "tr",
              "text": "Tekrar iyiyim."
            }
          ]
        },
        {
          "baseText": "Bist du fit für die Arbeit?",
          "translations": [
            {
              "language": "ar",
              "text": "هل أنت مستعد للعمل؟"
            },
            {
              "language": "ckb",
              "text": "تۆ بۆ کارکردن ئامادەیت؟"
            },
            {
              "language": "en",
              "text": "Are you fit for work?"
            },
            {
              "language": "fa",
              "text": "برای کار آماده‌ای؟"
            },
            {
              "language": "kmr",
              "text": "Tu ji bo kar fit î?"
            },
            {
              "language": "pl",
              "text": "Czy jesteś w formie do pracy?"
            },
            {
              "language": "ro",
              "text": "Ești în formă pentru muncă?"
            },
            {
              "language": "ru",
              "text": "Ты готов к работе?"
            },
            {
              "language": "sq",
              "text": "A je në formë për punë?"
            },
            {
              "language": "tr",
              "text": "İş için hazır mısın?"
            }
          ]
        }
      ]
