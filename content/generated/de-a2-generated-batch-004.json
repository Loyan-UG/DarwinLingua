      ],
      "examples": [
        {
          "baseText": "Bitte halten Sie zwei Meter Abstand.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الحفاظ على مسافة مترين."
            },
            {
              "language": "ckb",
              "text": "تکایە دوو مەتر دووری بگرن."
            },
            {
              "language": "en",
              "text": "Please keep two meters distance."
            },
            {
              "language": "fa",
              "text": "لطفاً دو متر فاصله نگه دارید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe du metre navber bigirin."
            },
            {
              "language": "pl",
              "text": "Proszę zachować dwa metry odstępu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să păstrați doi metri distanță."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, держите дистанцию два метра."
            },
            {
              "language": "sq",
              "text": "Ju lutem mbani dy metra distancë."
            },
            {
              "language": "tr",
              "text": "Lütfen iki metre mesafe bırakın."
            }
          ]
        },
        {
          "baseText": "Der Abstand zwischen den Autos ist zu klein.",
          "translations": [
            {
              "language": "ar",
              "text": "المسافة بين السيارتين صغيرة جداً."
            },
            {
              "language": "ckb",
              "text": "دووری نێوان ئۆتۆمبێلەکان زۆر کەمە."
            },
            {
              "language": "en",
              "text": "The distance between the cars is too small."
            },
            {
              "language": "fa",
              "text": "فاصله بین ماشین‌ها خیلی کم است."
            },
            {
              "language": "kmr",
              "text": "Navbera di navbera erebeyan de pir biçûk e."
            },
            {
              "language": "pl",
              "text": "Odstęp między samochodami jest za mały."
            },
            {
              "language": "ro",
              "text": "Distanța dintre mașini este prea mică."
            },
            {
              "language": "ru",
              "text": "Расстояние между машинами слишком маленькое."
            },
            {
              "language": "sq",
              "text": "Distanca midis makinave është shumë e vogël."
            },
            {
              "language": "tr",
              "text": "Arabalar arasındaki mesafe çok az."
            }
          ]
        }
      ]
    },
