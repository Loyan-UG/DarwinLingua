      ],
      "examples": [
        {
          "baseText": "Der Absender steht oben links auf dem Brief.",
          "translations": [
            {
              "language": "ar",
              "text": "يوجد اسم المرسل في أعلى يسار الرسالة."
            },
            {
              "language": "ckb",
              "text": "ناوی نێرەر لە سەرەوەی چەپی نامەکەدایە."
            },
            {
              "language": "en",
              "text": "The sender is at the top left of the letter."
            },
            {
              "language": "fa",
              "text": "فرستنده بالای سمت چپ نامه نوشته شده است."
            },
            {
              "language": "kmr",
              "text": "Şander li jorê çepê nameyê ye."
            },
            {
              "language": "pl",
              "text": "Nadawca jest u góry po lewej stronie listu."
            },
            {
              "language": "ro",
              "text": "Expeditorul este sus, în stânga, pe scrisoare."
            },
            {
              "language": "ru",
              "text": "Отправитель указан вверху слева на письме."
            },
            {
              "language": "sq",
              "text": "Dërguesi është lart majtas në letër."
            },
            {
              "language": "tr",
              "text": "Gönderen mektubun sol üstünde yazar."
            }
          ]
        },
        {
          "baseText": "Bitte schreiben Sie den Absender auf das Paket.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى كتابة المرسل على الطرد."
            },
            {
              "language": "ckb",
              "text": "تکایە ناوی نێرەر لەسەر پاکەتەکە بنووسن."
            },
            {
              "language": "en",
              "text": "Please write the sender on the parcel."
            },
            {
              "language": "fa",
              "text": "لطفاً فرستنده را روی بسته بنویسید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe şander li ser pakêtê binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę napisać nadawcę na paczce."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să scrieți expeditorul pe colet."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, напишите отправителя на посылке."
            },
            {
              "language": "sq",
              "text": "Ju lutem shkruani dërguesin në pako."
            },
            {
              "language": "tr",
              "text": "Lütfen paketin üzerine göndereni yazın."
            }
          ]
        }
      ]
    },
