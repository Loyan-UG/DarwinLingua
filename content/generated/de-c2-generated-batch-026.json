      "meanings": [
        {
          "language": "ar",
          "text": "يدفع إلى الداخل؛ يخلع بقوة؛ يكسر نحو الداخل"
        },
        {
          "language": "ckb",
          "text": "بۆ ناوەوە پاڵ بنێت؛ بە زور بشکێنێت"
