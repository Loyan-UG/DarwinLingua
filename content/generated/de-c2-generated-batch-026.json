  "entries": [
    {
      "word": "die Einlassung",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Einlassungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ein-las-sung",
      "topics": [
        "law-and-compliance",
        "business-communication",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; formal/legal: statement or submission; also opening/recess in technical contexts"
      ],
      "collocations": [
        {
          "text": "eine schriftliche Einlassung abgeben",
          "meaning": "to submit a written statement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sich einlassen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إفادة؛ تصريح رسمي؛ مرافعة"
        },
        {
          "language": "ckb",
          "text": "لێدوانی فەرمی؛ دەربڕینی یاسایی؛ پێشکەشکردنی بەرگری"
        },
        {
          "language": "en",
          "text": "statement; formal submission; plea"
        },
        {
          "language": "fa",
          "text": "اظهار رسمی؛ دفاعیه؛ توضیح حقوقی"
        },
        {
          "language": "kmr",
          "text": "daxuyaniya fermî; bersiva hiqûqî"
        },
        {
          "language": "pl",
          "text": "oświadczenie; wyjaśnienie procesowe"
        },
        {
          "language": "ro",
          "text": "declarație; susținere formală; apărare"
        },
        {
          "language": "ru",
          "text": "объяснение; официальное заявление; позиция защиты"
        },
        {
          "language": "sq",
          "text": "deklarim formal; parashtresë; mbrojtje"
        },
        {
          "language": "tr",
          "text": "resmî beyan; savunma açıklaması"
        }
      ],
      "examples": [
        {
          "baseText": "Die Einlassung des Beschuldigten widersprach in mehreren Punkten den vorliegenden Protokollen.",
          "translations": [
            {
              "language": "ar",
              "text": "تعارضت إفادة المتهم في عدة نقاط مع المحاضر المتوفرة."
            },
            {
              "language": "ckb",
              "text": "لێدوانی تۆمەتبارکراوەکە لە چەند خاڵێکدا لەگەڵ پڕۆتۆکۆڵە بەردەستەکان ناکۆک بوو."
            },
            {
              "language": "en",
              "text": "The accused person’s statement contradicted the available records on several points."
            },
            {
              "language": "fa",
              "text": "اظهارات متهم در چند مورد با صورت‌جلسه‌های موجود تناقض داشت."
            },
            {
              "language": "kmr",
              "text": "Daxuyaniya tawanbar li çend xalan bi protokolên heyî re nakok bû."
            },
            {
              "language": "pl",
              "text": "Wyjaśnienia oskarżonego w kilku punktach przeczyły dostępnym protokołom."
            },
            {
              "language": "ro",
              "text": "Declarația persoanei acuzate contrazicea în mai multe puncte procesele-verbale existente."
            },
            {
              "language": "ru",
              "text": "Объяснение обвиняемого в нескольких пунктах противоречило имеющимся протоколам."
            },
            {
              "language": "sq",
              "text": "Deklarimi i të akuzuarit kundërshtonte në disa pika procesverbalet ekzistuese."
            },
            {
              "language": "tr",
              "text": "Sanığın beyanı mevcut tutanaklarla birkaç noktada çelişiyordu."
            }
          ]
        },
        {
          "baseText": "In ihrer Einlassung zur Strategie vermied die Vorstandsvorsitzende jede konkrete Aussage zum Stellenabbau.",
          "translations": [
            {
              "language": "ar",
              "text": "في تصريحها حول الاستراتيجية تجنبت رئيسة المجلس أي قول ملموس بشأن خفض الوظائف."
            },
            {
              "language": "ckb",
              "text": "لە لێدوانەکەی دەربارەی ستراتیژیدا، سەرۆکی ئەنجومەن خۆی لە هەر وتەیەکی دیاریکراو دەربارەی کەمکردنەوەی کار دوور گرت."
            },
            {
              "language": "en",
              "text": "In her statement on the strategy, the chairwoman avoided any concrete comment on job cuts."
            },
            {
              "language": "fa",
              "text": "رئیس هیئت‌مدیره در توضیح خود درباره استراتژی از هر اظهار مشخصی درباره کاهش نیرو پرهیز کرد."
            },
            {
              "language": "kmr",
              "text": "Di daxuyaniya xwe ya li ser stratejiyê de, seroka lijneyê ji her gotina konkret li ser kêmkirina karmendan dûr ket."
            },
            {
              "language": "pl",
              "text": "W swoim oświadczeniu dotyczącym strategii przewodnicząca zarządu unikała konkretnych wypowiedzi o redukcji etatów."
            },
            {
              "language": "ro",
              "text": "În declarația sa privind strategia, președinta consiliului a evitat orice afirmație concretă despre reducerea posturilor."
            },
            {
              "language": "ru",
              "text": "В своём заявлении о стратегии председатель правления избегала любых конкретных высказываний о сокращении рабочих мест."
            },
            {
              "language": "sq",
              "text": "Në deklarimin e saj mbi strategjinë, kryetarja e bordit shmangu çdo pohim konkret për shkurtimin e vendeve të punës."
            },
            {
              "language": "tr",
              "text": "Yönetim kurulu başkanı stratejiye ilişkin beyanında işten çıkarmalar hakkında hiçbir somut açıklama yapmadı."
            }
          ]
        }
      ]
    },
    {
      "word": "einschmelzen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "einschmelzen",
      "pronunciationIpa": null,
      "syllableBreak": "ein-schmel-zen",
      "topics": [
        "production-and-maintenance",
        "environment-and-sustainability",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; schmilzt ein, schmolz ein, hat eingeschmolzen; to melt down, often for reuse"
      ],
      "collocations": [
        {
          "text": "Metall einschmelzen",
          "meaning": "to melt down metal"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schmelzen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصهر؛ يذيب لإعادة الاستخدام"
        },
        {
          "language": "ckb",
          "text": "بتوێنێتەوە؛ بۆ دووبارە بەکارهێنان بتوێنێت"
        },
        {
          "language": "en",
          "text": "to melt down; to smelt for reuse"
        },
        {
          "language": "fa",
          "text": "ذوب کردن؛ برای استفاده دوباره آب کردن"
        },
        {
          "language": "kmr",
          "text": "hel kirin; ji bo dubare bikaranînê helandin"
        },
        {
          "language": "pl",
          "text": "przetapiać; topić ponownie"
        },
        {
          "language": "ro",
          "text": "a topi; a retopi pentru reutilizare"
        },
        {
          "language": "ru",
          "text": "переплавлять; расплавлять"
        },
        {
          "language": "sq",
          "text": "ta shkrijmë; ta ritretësh për ripërdorim"
        },
        {
          "language": "tr",
          "text": "eritmek; yeniden kullanım için ergitmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die alten Aluminiumteile werden eingeschmolzen und in der nächsten Produktionsserie wiederverwendet.",
          "translations": [
            {
              "language": "ar",
              "text": "تُصهر قطع الألمنيوم القديمة وتُعاد استخدامها في سلسلة الإنتاج التالية."
            },
            {
              "language": "ckb",
              "text": "پارچە ئەلۆمینیۆمە کۆنەکان دەتوێنرێنەوە و لە زنجیرەی بەرهەمهێنانی داهاتوودا دووبارە بەکاردەهێنرێن."
            },
            {
              "language": "en",
              "text": "The old aluminum parts are melted down and reused in the next production run."
            },
            {
              "language": "fa",
              "text": "قطعات آلومینیومی قدیمی ذوب می‌شوند و در سری تولید بعدی دوباره استفاده می‌شوند."
            },
            {
              "language": "kmr",
              "text": "Parçeyên alumînyûmê yên kevn tên helandin û di rêza hilberîna din de dîsa tên bikaranîn."
            },
            {
              "language": "pl",
              "text": "Stare części aluminiowe są przetapiane i ponownie wykorzystywane w kolejnej serii produkcyjnej."
            },
            {
              "language": "ro",
              "text": "Piesele vechi din aluminiu sunt topite și reutilizate în următoarea serie de producție."
            },
            {
              "language": "ru",
              "text": "Старые алюминиевые детали переплавляют и повторно используют в следующей производственной серии."
            },
            {
              "language": "sq",
              "text": "Pjesët e vjetra të aluminit shkrihen dhe ripërdoren në serinë tjetër të prodhimit."
            },
            {
              "language": "tr",
              "text": "Eski alüminyum parçalar eritilir ve bir sonraki üretim serisinde yeniden kullanılır."
            }
          ]
        },
        {
          "baseText": "Nach der Währungsreform ließ die Stadt ungültige Münzen einschmelzen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد إصلاح العملة جعلت المدينة العملات غير الصالحة تُصهر."
            },
            {
              "language": "ckb",
              "text": "دوای چاکسازی دراو، شارەکە سikkە بێکارەکان داتواندن."
            },
            {
              "language": "en",
              "text": "After the currency reform, the city had invalid coins melted down."
            },
            {
              "language": "fa",
              "text": "پس از اصلاح پولی، شهر سکه‌های نامعتبر را ذوب کرد."
            },
            {
              "language": "kmr",
              "text": "Piştî reforma pereyan, bajarê pereyên bêderbasdar helandin."
            },
            {
              "language": "pl",
              "text": "Po reformie walutowej miasto kazało przetopić nieważne monety."
            },
            {
              "language": "ro",
              "text": "După reforma monetară, orașul a dispus topirea monedelor nevalabile."
            },
            {
              "language": "ru",
              "text": "После денежной реформы город распорядился переплавить недействительные монеты."
            },
            {
              "language": "sq",
              "text": "Pas reformës monetare, qyteti urdhëroi shkrirjen e monedhave të pavlefshme."
            },
            {
              "language": "tr",
              "text": "Para reformundan sonra şehir geçersiz madeni paraları erittirdi."
            }
          ]
        }
      ]
    },
