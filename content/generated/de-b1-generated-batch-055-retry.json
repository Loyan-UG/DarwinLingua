      "examples": [
        {
          "baseText": "Die Expertin für Datenschutz prüft den Vertrag vor der Freigabe.",
          "translations": [
            {
              "language": "ar",
              "text": "تراجع خبيرة حماية البيانات العقد قبل الموافقة عليه."
            },
            {
              "language": "ckb",
              "text": "شارەزای ژنی پاراستنی داتا پێش ڕێگەدان گرێبەستەکە دەپشکنێت."
            },
            {
              "language": "en",
              "text": "The data protection expert checks the contract before approval."
            },
            {
              "language": "fa",
              "text": "متخصص حفاظت از داده‌ها قبل از تأیید قرارداد را بررسی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pisporê parastina daneyan berî pejirandinê peymanê kontrol dike."
            },
            {
              "language": "pl",
              "text": "Ekspertka ds. ochrony danych sprawdza umowę przed zatwierdzeniem."
            },
            {
              "language": "ro",
              "text": "Experta în protecția datelor verifică contractul înainte de aprobare."
            },
            {
              "language": "ru",
              "text": "Эксперт по защите данных проверяет договор перед утверждением."
            },
            {
              "language": "sq",
              "text": "Ekspertja për mbrojtjen e të dhënave kontrollon kontratën para miratimit."
            },
            {
              "language": "tr",
              "text": "Veri koruma uzmanı onaydan önce sözleşmeyi kontrol eder."
            }
          ]
        },
        {
          "baseText": "In der Schulung beantwortet die Expertin viele praktische Fragen.",
          "translations": [
            {
              "language": "ar",
              "text": "في التدريب تجيب الخبيرة عن كثير من الأسئلة العملية."
            },
            {
              "language": "ckb",
              "text": "لە ڕاهێنانەکەدا شارەزای ژن وەڵامی زۆر پرسیاری پراکتیکی دەداتەوە."
            },
            {
              "language": "en",
              "text": "In the training, the expert answers many practical questions."
            },
            {
              "language": "fa",
              "text": "در آموزش، متخصص به بسیاری از پرسش‌های عملی پاسخ می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Di perwerdeyê de pispor bersiva gelek pirsên praktîkî dide."
            },
            {
              "language": "pl",
              "text": "Podczas szkolenia ekspertka odpowiada na wiele praktycznych pytań."
            },
            {
              "language": "ro",
              "text": "În cadrul instruirii, experta răspunde la multe întrebări practice."
            },
            {
              "language": "ru",
              "text": "На обучении эксперт отвечает на многие практические вопросы."
            },
            {
              "language": "sq",
              "text": "Në trajnim, ekspertja u përgjigjet shumë pyetjeve praktike."
            },
            {
              "language": "tr",
              "text": "Eğitimde kadın uzman birçok pratik soruyu yanıtlar."
            }
          ]
        }
      ]
