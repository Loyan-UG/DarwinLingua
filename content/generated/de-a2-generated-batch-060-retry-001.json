          "text": "سەڵت؛ هاوسەرگیری نەکردوو"
        },
        {
          "language": "en",
          "text": "single; unmarried"
        },
        {
          "language": "fa",
          "text": "مجرد؛ ازدواج‌نکرده"
        },
        {
          "language": "kmr",
          "text": "nezewicî; tenê"
        },
        {
          "language": "pl",
          "text": "stanu wolnego; niezamężny/nieżonaty"
        },
        {
          "language": "ro",
          "text": "necăsătorit"
        },
        {
          "language": "ru",
          "text": "холостой; незамужняя"
