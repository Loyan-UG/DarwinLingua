          "text": "beqar; i/e pamartuar"
        },
        {
          "language": "tr",
          "text": "bekâr"
        }
      ],
      "examples": [
        {
          "baseText": "Im Formular steht: ledig.",
          "translations": [
            {
              "language": "ar",
              "text": "في الاستمارة مكتوب: أعزب."
            },
            {
              "language": "ckb",
              "text": "لە فۆڕمەکەدا نووسراوە: سەڵت."
            },
            {
              "language": "en",
              "text": "The form says: single."
            },
            {
              "language": "fa",
              "text": "در فرم نوشته شده: مجرد."
            },
            {
              "language": "kmr",
              "text": "Di formê de nivîsî ye: nezewicî."
            },
            {
              "language": "pl",
              "text": "W formularzu jest napisane: stan wolny."
            },
            {
              "language": "ro",
              "text": "În formular scrie: necăsătorit."
            },
            {
              "language": "ru",
              "text": "В форме написано: холост/не замужем."
            },
            {
              "language": "sq",
              "text": "Në formular shkruan: beqar."
            },
            {
              "language": "tr",
              "text": "Formda şöyle yazıyor: bekâr."
            }
          ]
        },
        {
          "baseText": "Sie ist ledig und wohnt allein.",
          "translations": [
            {
              "language": "ar",
              "text": "هي عزباء وتعيش وحدها."
            },
            {
              "language": "ckb",
              "text": "ئەو سەڵتە و بە تەنیا دەژیت."
            },
            {
              "language": "en",
              "text": "She is single and lives alone."
            },
            {
              "language": "fa",
              "text": "او مجرد است و تنها زندگی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ew nezewicî ye û bi tenê dijî."
            },
            {
              "language": "pl",
              "text": "Ona jest stanu wolnego i mieszka sama."
            },
            {
              "language": "ro",
              "text": "Ea este necăsătorită și locuiește singură."
            },
            {
              "language": "ru",
              "text": "Она не замужем и живёт одна."
            },
            {
              "language": "sq",
              "text": "Ajo është beqare dhe jeton vetëm."
            },
            {
              "language": "tr",
              "text": "O bekâr ve yalnız yaşıyor."
            }
          ]
        }
      ]
    }
