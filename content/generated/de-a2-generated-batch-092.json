          "language": "sq",
          "text": "të ruash; të depozitosh"
        },
        {
          "language": "tr",
          "text": "kaydetmek; depolamak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte speichern Sie die Datei vor der Pause.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى حفظ الملف قبل الاستراحة."
            },
            {
              "language": "ckb",
              "text": "تکایە پەڕگەکە پێش پشوودانەکە هەڵبگرن."
            },
            {
              "language": "en",
              "text": "Please save the file before the break."
            },
            {
              "language": "fa",
              "text": "لطفاً فایل را قبل از استراحت ذخیره کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pelê berî bêhnvedanê tomar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zapisać plik przed przerwą."
            },
            {
              "language": "ro",
              "text": "Vă rog să salvați fișierul înainte de pauză."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сохраните файл перед перерывом."
            },
            {
              "language": "sq",
              "text": "Ju lutem ruajeni skedarin para pushimit."
            },
            {
              "language": "tr",
              "text": "Lütfen dosyayı moladan önce kaydedin."
            }
          ]
        },
        {
          "baseText": "Ich speichere die Fotos auf meinem Handy.",
          "translations": [
            {
              "language": "ar",
              "text": "أحفظ الصور على هاتفي."
            },
            {
              "language": "ckb",
              "text": "من وێنەکان لەسەر مۆبایلەکەم هەڵدەگرم."
            },
            {
              "language": "en",
              "text": "I save the photos on my phone."
            },
            {
              "language": "fa",
              "text": "من عکس‌ها را روی گوشی‌ام ذخیره می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez wêneyan li ser telefona xwe tomar dikim."
            },
            {
              "language": "pl",
              "text": "Zapisuję zdjęcia w telefonie."
            },
            {
              "language": "ro",
              "text": "Salvez fotografiile pe telefonul meu."
            },
            {
              "language": "ru",
              "text": "Я сохраняю фотографии на своем телефоне."
            },
            {
              "language": "sq",
              "text": "I ruaj fotot në telefonin tim."
            },
            {
              "language": "tr",
              "text": "Fotoğrafları telefonuma kaydediyorum."
            }
          ]
        }
      ]
