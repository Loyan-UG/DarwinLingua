      "meanings": [
        {
          "language": "ar",
          "text": "تأشيرة"
        },
        {
          "language": "ckb",
          "text": "ڤیزا"
        },
        {
          "language": "en",
          "text": "visa"
        },
        {
          "language": "fa",
          "text": "ویزا"
        },
        {
          "language": "kmr",
          "text": "vîza"
        },
        {
          "language": "pl",
          "text": "wiza"
        },
        {
          "language": "ro",
          "text": "viză"
        },
        {
          "language": "ru",
          "text": "виза"
        },
        {
          "language": "sq",
          "text": "vizë"
        },
        {
          "language": "tr",
          "text": "vize"
        }
      ],
      "examples": [
        {
          "baseText": "Für diese Reise brauche ich ein Visum.",
          "translations": [
            {
              "language": "ar",
              "text": "أحتاج إلى تأشيرة لهذه الرحلة."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم گەشتە پێویستم بە ڤیزا هەیە."
            },
            {
              "language": "en",
              "text": "I need a visa for this trip."
            },
            {
              "language": "fa",
              "text": "برای این سفر به ویزا نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê rêwîtiyê ez hewceyê vîzayê me."
            },
            {
              "language": "pl",
              "text": "Na tę podróż potrzebuję wizy."
            },
            {
              "language": "ro",
              "text": "Pentru această călătorie am nevoie de viză."
            },
            {
              "language": "ru",
              "text": "Для этой поездки мне нужна виза."
            },
            {
              "language": "sq",
              "text": "Për këtë udhëtim më duhet vizë."
            },
            {
              "language": "tr",
              "text": "Bu seyahat için vizeye ihtiyacım var."
            }
          ]
        },
        {
          "baseText": "Das Visum ist bis Ende Juni gültig.",
          "translations": [
            {
              "language": "ar",
              "text": "التأشيرة صالحة حتى نهاية يونيو."
            },
            {
              "language": "ckb",
              "text": "ڤیزاکە تا کۆتایی حوزەیران بەکاردێت."
            },
            {
              "language": "en",
              "text": "The visa is valid until the end of June."
            },
            {
              "language": "fa",
              "text": "ویزا تا پایان ژوئن معتبر است."
            },
            {
              "language": "kmr",
              "text": "Vîza heta dawiya hezîranê derbasdar e."
            },
            {
              "language": "pl",
              "text": "Wiza jest ważna do końca czerwca."
            },
            {
              "language": "ro",
              "text": "Viza este valabilă până la sfârșitul lunii iunie."
            },
            {
              "language": "ru",
              "text": "Виза действительна до конца июня."
            },
            {
              "language": "sq",
              "text": "Viza është e vlefshme deri në fund të qershorit."
            },
            {
              "language": "tr",
              "text": "Vize haziran sonuna kadar geçerli."
            }
          ]
        }
      ]
    },
