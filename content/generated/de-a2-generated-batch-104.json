      ],
      "collocations": [
        {
          "text": "eine Vollmacht unterschreiben",
          "meaning": "to sign an authorization"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bevollmächtigen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "توكيل؛ تفويض"
        },
        {
          "language": "ckb",
          "text": "وەکالەتنامە؛ ڕێپێدان"
        },
        {
          "language": "en",
          "text": "authorization; power of attorney"
        },
        {
          "language": "fa",
          "text": "وکالت‌نامه؛ اختیارنامه"
        },
        {
          "language": "kmr",
          "text": "destûrname; wekâletname"
        },
        {
          "language": "pl",
          "text": "pełnomocnictwo"
        },
        {
          "language": "ro",
          "text": "împuternicire; procură"
        },
        {
          "language": "ru",
          "text": "доверенность"
        },
        {
          "language": "sq",
          "text": "autorizim; prokurë"
        },
        {
          "language": "tr",
          "text": "vekaletname; yetki belgesi"
        }
      ],
      "examples": [
        {
          "baseText": "Ohne Vollmacht kann ich die Unterlagen nicht abholen.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون توكيل لا أستطيع استلام المستندات."
            },
            {
              "language": "ckb",
              "text": "بەبێ وەکالەتنامە ناتوانم بەڵگەنامەکان وەربگرم."
            },
            {
              "language": "en",
              "text": "Without authorization, I cannot pick up the documents."
            },
            {
              "language": "fa",
              "text": "بدون وکالت‌نامه نمی‌توانم مدارک را تحویل بگیرم."
            },
            {
              "language": "kmr",
              "text": "Bê destûrname ez nikarim belgeyan bistînim."
            },
            {
              "language": "pl",
              "text": "Bez pełnomocnictwa nie mogę odebrać dokumentów."
            },
            {
              "language": "ro",
              "text": "Fără împuternicire nu pot ridica documentele."
            },
            {
              "language": "ru",
              "text": "Без доверенности я не могу забрать документы."
            },
            {
              "language": "sq",
              "text": "Pa autorizim nuk mund t’i marr dokumentet."
            },
            {
              "language": "tr",
              "text": "Vekaletname olmadan belgeleri alamam."
            }
          ]
        },
        {
          "baseText": "Bitte bringen Sie die Vollmacht und Ihren Ausweis mit.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إحضار التوكيل وبطاقة هويتكم."
            },
            {
              "language": "ckb",
              "text": "تکایە وەکالەتنامەکە و ناسنامەکەتان لەگەڵ خۆتان بهێنن."
            },
            {
              "language": "en",
              "text": "Please bring the authorization and your ID."
            },
            {
              "language": "fa",
              "text": "لطفاً وکالت‌نامه و کارت شناسایی خود را همراه بیاورید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe destûrname û nasnameya xwe bînin."
            },
            {
              "language": "pl",
              "text": "Proszę przynieść pełnomocnictwo i dowód osobisty."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să aduceți împuternicirea și actul de identitate."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, принесите доверенность и удостоверение личности."
            },
            {
              "language": "sq",
              "text": "Ju lutem sillni autorizimin dhe dokumentin tuaj të identitetit."
            },
            {
              "language": "tr",
              "text": "Lütfen vekaletnameyi ve kimliğinizi getirin."
            }
          ]
        }
      ]
    },
