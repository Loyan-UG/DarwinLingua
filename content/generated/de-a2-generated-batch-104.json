          "text": "të përgatitësh"
        },
        {
          "language": "tr",
          "text": "hazırlamak; hazırlanmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bereite die Unterlagen für den Termin vor.",
          "translations": [
            {
              "language": "ar",
              "text": "أحضّر المستندات للموعد."
            },
            {
              "language": "ckb",
              "text": "من بەڵگەنامەکان بۆ کاتەکە ئامادە دەکەم."
            },
            {
              "language": "en",
              "text": "I prepare the documents for the appointment."
            },
            {
              "language": "fa",
              "text": "من مدارک را برای وقت ملاقات آماده می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez belgeyan ji bo demê amade dikim."
            },
            {
              "language": "pl",
              "text": "Przygotowuję dokumenty na termin."
            },
            {
              "language": "ro",
              "text": "Pregătesc documentele pentru programare."
            },
            {
              "language": "ru",
              "text": "Я готовлю документы к встрече."
            },
            {
              "language": "sq",
              "text": "I përgatis dokumentet për takimin."
            },
            {
              "language": "tr",
              "text": "Randevu için belgeleri hazırlıyorum."
            }
          ]
        },
        {
          "baseText": "Wir müssen den Raum für den Kurs vorbereiten.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن نجهز الغرفة للدورة."
            },
            {
              "language": "ckb",
              "text": "دەبێت ژوورەکە بۆ خولەکە ئامادە بکەین."
            },
            {
              "language": "en",
              "text": "We have to prepare the room for the course."
            },
            {
              "language": "fa",
              "text": "باید اتاق را برای دوره آماده کنیم."
            },
            {
              "language": "kmr",
              "text": "Divê em odeyê ji bo kursê amade bikin."
            },
            {
              "language": "pl",
              "text": "Musimy przygotować salę na kurs."
            },
            {
              "language": "ro",
              "text": "Trebuie să pregătim sala pentru curs."
            },
            {
              "language": "ru",
              "text": "Нам нужно подготовить комнату для курса."
            },
            {
              "language": "sq",
              "text": "Duhet ta përgatisim dhomën për kursin."
            },
            {
              "language": "tr",
              "text": "Odayı kurs için hazırlamamız gerekiyor."
            }
          ]
        }
      ]
    },
