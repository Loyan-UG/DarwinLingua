      "examples": [
        {
          "baseText": "Die Kaffeemaschine steht in der Küche.",
          "translations": [
            {
              "language": "ar",
              "text": "آلة القهوة في المطبخ."
            },
            {
              "language": "ckb",
              "text": "ماشێنی قاوەکە لە چێشتخانەدایە."
            },
            {
              "language": "en",
              "text": "The coffee machine is in the kitchen."
            },
            {
              "language": "fa",
              "text": "قهوه‌ساز در آشپزخانه است."
            },
            {
              "language": "kmr",
              "text": "Makîneya qehwê li metbexê ye."
            },
            {
              "language": "pl",
              "text": "Ekspres do kawy stoi w kuchni."
            },
            {
              "language": "ro",
              "text": "Aparatul de cafea este în bucătărie."
            },
            {
              "language": "ru",
              "text": "Кофемашина стоит на кухне."
            },
            {
              "language": "sq",
              "text": "Makina e kafesë është në kuzhinë."
            },
            {
              "language": "tr",
              "text": "Kahve makinesi mutfakta."
            }
          ]
        },
        {
          "baseText": "Kannst du die Kaffeemaschine bitte ausmachen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك إطفاء آلة القهوة من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "تکایە دەتوانیت ماشێنی قاوەکە بکوژێنیتەوە؟"
            },
            {
              "language": "en",
              "text": "Can you please turn off the coffee machine?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً قهوه‌ساز را خاموش کنی؟"
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe dikarî makîneya qehwê bigirî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz wyłączyć ekspres do kawy?"
            },
            {
              "language": "ro",
              "text": "Poți să oprești aparatul de cafea, te rog?"
            },
            {
              "language": "ru",
              "text": "Можешь, пожалуйста, выключить кофемашину?"
            },
            {
              "language": "sq",
              "text": "A mund ta fikësh makinën e kafesë, të lutem?"
            },
            {
              "language": "tr",
              "text": "Lütfen kahve makinesini kapatabilir misin?"
            }
          ]
        }
