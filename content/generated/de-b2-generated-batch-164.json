  "entries": [
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "einschlagen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "einschlagen",
      "syllableBreak": "ein-schla-gen",
      "topics": [
        "planning-and-projects",
        "work-and-jobs",
        "transport-and-travel"
      ],
      "usageLabels": [
        "business",
        "spoken",
        "workplace"
      ],
      "contextLabels": [
        "management",
        "transport"
      ],
      "grammarNotes": [
        "separable strong verb; meanings include to take a path/direction or to hit into something"
      ],
      "collocations": [
        {
          "text": "einen neuen Weg einschlagen",
          "meaning": "to take a new path"
        },
        {
          "text": "eine Richtung einschlagen",
          "meaning": "to take a direction"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schlagen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يسلك؛ يتخذ اتجاهًا؛ يطرق"
        },
        {
          "language": "ckb",
          "text": "ڕێگایەک دەگرێتەبەر؛ ئاراستەیەک هەڵدەبژێرێت"
        },
        {
          "language": "en",
          "text": "to take; to pursue; to strike into"
        },
        {
          "language": "fa",
          "text": "در پیش گرفتن؛ وارد شدن به مسیر؛ کوبیدن"
        },
        {
          "language": "kmr",
          "text": "rêyek girtin; arasteyek hilbijartin"
        },
        {
          "language": "pl",
          "text": "obrać; wybrać kierunek; uderzyć"
        },
        {
          "language": "ro",
          "text": "a apuca; a lua o direcție; a lovi"
        },
        {
          "language": "ru",
          "text": "избрать путь; повернуть; ударить"
        },
        {
          "language": "sq",
          "text": "të marrësh një drejtim; të ndjekësh një rrugë"
        },
        {
          "language": "tr",
          "text": "bir yola girmek; yönelmek; vurmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Analyse der Verkaufszahlen will das Management eine neue Strategie einschlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تحليل أرقام المبيعات تريد الإدارة اتباع استراتيجية جديدة."
            },
            {
              "language": "ckb",
              "text": "دوای شیکردنەوەی ژمارەکانی فرۆشتن، بەڕێوەبەرایەتی دەیەوێت ستراتیژییەکی نوێ بگرێتەبەر."
            },
            {
              "language": "en",
              "text": "After analyzing the sales figures, management wants to pursue a new strategy."
            },
            {
              "language": "fa",
              "text": "پس از تحلیل ارقام فروش، مدیریت می‌خواهد استراتژی جدیدی در پیش بگیرد."
            },
            {
              "language": "kmr",
              "text": "Piştî analîza hejmarên firotanê, rêveberî dixwaze stratejiyeke nû bigire."
            },
            {
              "language": "pl",
              "text": "Po analizie wyników sprzedaży kierownictwo chce obrać nową strategię."
            },
            {
              "language": "ro",
              "text": "După analiza cifrelor de vânzări, conducerea vrea să adopte o nouă strategie."
            },
            {
              "language": "ru",
              "text": "После анализа показателей продаж руководство хочет выбрать новую стратегию."
            },
            {
              "language": "sq",
              "text": "Pas analizës së shifrave të shitjeve, menaxhmenti dëshiron të ndjekë një strategji të re."
            },
            {
              "language": "tr",
              "text": "Satış rakamlarının analizinden sonra yönetim yeni bir strateji izlemek istiyor."
            }
          ]
        },
        {
          "baseText": "Am Kreisverkehr müssen Sie die zweite Ausfahrt einschlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "عند الدوار يجب أن تسلك المخرج الثاني."
            },
            {
              "language": "ckb",
              "text": "لە بازنەی هاتوچۆدا دەبێت دەرچوونی دووەم بگرن."
            },
            {
              "language": "en",
              "text": "At the roundabout, you need to take the second exit."
            },
            {
              "language": "fa",
              "text": "در میدان باید خروجی دوم را بگیرید."
            },
            {
              "language": "kmr",
              "text": "Li çerxeriya trafîkê divê hûn derketina duyem bigirin."
            },
            {
              "language": "pl",
              "text": "Na rondzie trzeba wybrać drugi zjazd."
            },
            {
              "language": "ro",
              "text": "La sensul giratoriu trebuie să luați a doua ieșire."
            },
            {
              "language": "ru",
              "text": "На круговом движении нужно выбрать второй съезд."
            },
            {
              "language": "sq",
              "text": "Në rrethrrotullim duhet të merrni daljen e dytë."
            },
            {
              "language": "tr",
              "text": "Döner kavşakta ikinci çıkışı kullanmalısınız."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
