      "examples": [
        {
          "baseText": "Aus Sicherheitsgründen müssen wir den Zugriff auf Kundendaten stärker einschränken.",
          "translations": [
            {
              "language": "ar",
              "text": "لأسباب أمنية يجب أن نقيّد الوصول إلى بيانات العملاء بشكل أكبر."
            },
            {
              "language": "ckb",
              "text": "بەهۆی هۆکاری ئاسایشەوە دەبێت دەستگەیشتن بە داتای کڕیاران زیاتر سنوردار بکەین."
            },
            {
              "language": "en",
              "text": "For security reasons, we need to restrict access to customer data more strongly."
            },
            {
              "language": "fa",
              "text": "به دلایل امنیتی باید دسترسی به داده‌های مشتریان را بیشتر محدود کنیم."
            },
            {
              "language": "kmr",
              "text": "Ji ber sedemên ewlehiyê divê em gihîştina daneyên xerîdaran bêtir sînordar bikin."
            },
            {
              "language": "pl",
              "text": "Ze względów bezpieczeństwa musimy bardziej ograniczyć dostęp do danych klientów."
            },
            {
              "language": "ro",
              "text": "Din motive de securitate trebuie să restricționăm mai mult accesul la datele clienților."
            },
            {
              "language": "ru",
              "text": "По соображениям безопасности нам нужно сильнее ограничить доступ к данным клиентов."
            },
            {
              "language": "sq",
              "text": "Për arsye sigurie duhet ta kufizojmë më shumë qasjen në të dhënat e klientëve."
            },
            {
              "language": "tr",
              "text": "Güvenlik nedeniyle müşteri verilerine erişimi daha fazla kısıtlamamız gerekiyor."
            }
          ]
        },
        {
          "baseText": "Während der Bauarbeiten wird die Stadt den Verkehr in der Innenstadt einschränken.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء أعمال البناء ستحد المدينة من حركة المرور في وسط المدينة."
            },
            {
              "language": "ckb",
              "text": "لە کاتی کاری بنیاتناندا شارەکە هاتوچۆ لە ناوەندی شار سنوردار دەکات."
            },
            {
              "language": "en",
              "text": "During construction work, the city will restrict traffic in the city center."
            },
            {
              "language": "fa",
              "text": "در طول عملیات ساخت‌وساز، شهر ترافیک مرکز شهر را محدود خواهد کرد."
            },
            {
              "language": "kmr",
              "text": "Di dema karên avakirinê de bajar dê trafîka navenda bajêr sînordar bike."
            },
            {
              "language": "pl",
              "text": "Podczas robót budowlanych miasto ograniczy ruch w centrum."
            },
            {
              "language": "ro",
              "text": "În timpul lucrărilor, orașul va restricționa traficul în centru."
            },
            {
              "language": "ru",
              "text": "Во время строительных работ город ограничит движение в центре."
            },
            {
              "language": "sq",
              "text": "Gjatë punimeve, qyteti do të kufizojë trafikun në qendër."
            },
            {
              "language": "tr",
              "text": "İnşaat çalışmaları sırasında belediye şehir merkezindeki trafiği kısıtlayacak."
            }
          ]
        }
      ]
