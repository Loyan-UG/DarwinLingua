        },
        {
          "lemma": "einschließlich",
          "relationLabel": "preposition/adverb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يشمل؛ يحبس داخل"
        },
        {
          "language": "ckb",
          "text": "لەخۆ دەگرێت؛ لەژووردا قوفڵ دەکات"
        },
        {
          "language": "en",
          "text": "to include; to lock in"
        },
        {
          "language": "fa",
          "text": "شامل شدن؛ درون جایی قفل کردن"
        },
        {
          "language": "kmr",
          "text": "di nav de girtin; hundur qefil kirin"
        },
        {
          "language": "pl",
          "text": "obejmować; zamknąć w środku"
        },
        {
          "language": "ro",
          "text": "a include; a închide înăuntru"
        },
        {
          "language": "ru",
          "text": "включать; запереть внутри"
        },
        {
          "language": "sq",
          "text": "të përfshish; të mbyllësh brenda"
        },
        {
          "language": "tr",
          "text": "dahil etmek; içeri kilitlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Angebot schließt Wartung und telefonischen Support für zwölf Monate ein.",
          "translations": [
            {
              "language": "ar",
              "text": "يشمل العرض الصيانة والدعم الهاتفي لمدة اثني عشر شهرًا."
            },
            {
              "language": "ckb",
              "text": "پێشکەشنامەکە چاککردنەوە و پشتگیری تەلەفۆنی بۆ دوازدە مانگ لەخۆ دەگرێت."
            },
            {
              "language": "en",
              "text": "The offer includes maintenance and phone support for twelve months."
            },
            {
              "language": "fa",
              "text": "این پیشنهاد شامل نگهداری و پشتیبانی تلفنی برای دوازده ماه است."
            },
            {
              "language": "kmr",
              "text": "Pêşniyar lênêrîn û piştgiriya telefonê ji bo diwanzdeh mehan di nav de digire."
            },
            {
              "language": "pl",
