  "entries": [
    {
      "word": "Konsolidierung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Konsolidierungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kon-so-li-die-rung",
      "topics": [
        "finance-and-accounting",
        "erp-and-business-systems",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; combining data, companies, orders, or reports into one consolidated view"
      ],
      "collocations": [
        {
          "text": "eine Konsolidierung durchführen",
          "meaning": "to carry out a consolidation"
        },
        {
          "text": "Daten konsolidieren",
          "meaning": "to consolidate data"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "konsolidieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "konsolidiert",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تجميع؛ توحيد"
        },
        {
          "language": "ckb",
          "text": "یەکخستن؛ کۆکردنەوە"
        },
        {
          "language": "en",
          "text": "consolidation"
        },
        {
          "language": "fa",
          "text": "تجمیع؛ یکپارچه‌سازی"
        },
        {
          "language": "kmr",
          "text": "yekgirtin"
        },
        {
          "language": "pl",
          "text": "konsolidacja"
        },
        {
          "language": "ro",
          "text": "consolidare"
        },
        {
          "language": "ru",
          "text": "консолидация"
        },
        {
          "language": "sq",
          "text": "konsolidim"
        },
        {
          "language": "tr",
          "text": "konsolidasyon"
        }
      ],
      "examples": [
        {
          "baseText": "Die Konsolidierung der Umsätze aus drei Niederlassungen erfolgt im ERP über Nacht.",
          "translations": [
            {
              "language": "ar",
              "text": "تتم عملية تجميع المبيعات من ثلاثة فروع في ERP خلال الليل."
            },
            {
              "language": "ckb",
              "text": "یەکخستنی فرۆشتنەکانی سێ لق لە ERP دا بە شەو ئەنجام دەدرێت."
            },
            {
              "language": "en",
              "text": "The consolidation of sales from three branches is performed in the ERP overnight."
            },
            {
              "language": "fa",
              "text": "تجمیع فروش سه شعبه در ERP شبانه انجام می‌شود."
            },
            {
              "language": "kmr",
              "text": "Yekgirtina firotanên ji sê şaxan di ERP de bi şev tê kirin."
            },
            {
              "language": "pl",
              "text": "Konsolidacja obrotów z trzech oddziałów odbywa się w ERP w nocy."
            },
            {
              "language": "ro",
              "text": "Consolidarea vânzărilor din trei filiale se face în ERP peste noapte."
            },
            {
              "language": "ru",
              "text": "Консолидация продаж из трех филиалов выполняется в ERP ночью."
            },
            {
              "language": "sq",
              "text": "Konsolidimi i shitjeve nga tri degë bëhet në ERP gjatë natës."
            },
            {
              "language": "tr",
              "text": "Üç şubeden gelen satışların konsolidasyonu ERP’de gece yapılır."
            }
          ]
        },
        {
          "baseText": "Für den Monatsbericht brauchen wir eine Konsolidierung der offenen Bestellungen.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل تقرير الشهر نحتاج إلى تجميع الطلبات المفتوحة."
            },
            {
              "language": "ckb",
              "text": "بۆ ڕاپۆرتی مانگ پێویستمان بە یەکخستنی داواکارییە کراوەکان هەیە."
            },
            {
              "language": "en",
              "text": "For the monthly report, we need a consolidation of the open orders."
            },
            {
              "language": "fa",
              "text": "برای گزارش ماهانه به تجمیع سفارش‌های باز نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo rapora mehane em hewceyê yekgirtina fermanên vekirî ne."
            },
            {
              "language": "pl",
              "text": "Do raportu miesięcznego potrzebujemy konsolidacji otwartych zamówień."
            },
            {
              "language": "ro",
              "text": "Pentru raportul lunar avem nevoie de consolidarea comenzilor deschise."
            },
            {
              "language": "ru",
              "text": "Для месячного отчета нам нужна консолидация открытых заказов."
            },
            {
              "language": "sq",
              "text": "Për raportin mujor na duhet konsolidimi i porosive të hapura."
            },
            {
              "language": "tr",
              "text": "Aylık rapor için açık siparişlerin konsolidasyonuna ihtiyacımız var."
            }
          ]
        }
      ]
    },
    {
      "word": "Kontrakt",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Kontrakte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kon-trakt",
      "topics": [
        "procurement-and-suppliers",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; business contract or framework agreement"
      ],
      "collocations": [
        {
          "text": "einen Kontrakt anlegen",
          "meaning": "to create a contract"
        },
        {
          "text": "aus einem Kontrakt abrufen",
          "meaning": "to call off from a contract"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Vertrag",
          "relationLabel": "synonym",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عقد؛ اتفاقية"
        },
        {
          "language": "ckb",
          "text": "گرێبەست"
        },
        {
          "language": "en",
          "text": "contract; framework agreement"
        },
        {
          "language": "fa",
          "text": "قرارداد؛ توافق‌نامه چارچوب"
        },
        {
          "language": "kmr",
          "text": "kontrakt; peyman"
        },
        {
          "language": "pl",
          "text": "kontrakt; umowa ramowa"
        },
        {
          "language": "ro",
          "text": "contract; acord-cadru"
        },
        {
          "language": "ru",
          "text": "контракт; рамочный договор"
        },
        {
          "language": "sq",
          "text": "kontratë; marrëveshje kornizë"
        },
        {
          "language": "tr",
          "text": "kontrat; çerçeve anlaşması"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kontrakt ist im ERP hinterlegt und gilt für alle Bestellungen dieses Lieferanten.",
          "translations": [
            {
              "language": "ar",
              "text": "العقد محفوظ في ERP وينطبق على جميع طلبات الشراء من هذا المورد."
            },
            {
              "language": "ckb",
              "text": "گرێبەستەکە لە ERP دا تۆمارکراوە و بۆ هەموو داواکارییەکانی ئەم دابینکەرە کار دەکات."
            },
            {
              "language": "en",
              "text": "The contract is stored in the ERP and applies to all orders from this supplier."
            },
            {
              "language": "fa",
              "text": "قرارداد در ERP ثبت شده و برای همه سفارش‌های این تأمین‌کننده معتبر است."
            },
            {
              "language": "kmr",
              "text": "Kontrakt di ERP de hatiye tomarkirin û ji bo hemû fermanên vî dabînkerî derbas e."
            },
            {
              "language": "pl",
              "text": "Kontrakt jest zapisany w ERP i obowiązuje dla wszystkich zamówień tego dostawcy."
            },
            {
              "language": "ro",
              "text": "Contractul este salvat în ERP și se aplică tuturor comenzilor acestui furnizor."
            },
            {
              "language": "ru",
              "text": "Контракт сохранен в ERP и действует для всех заказов этого поставщика."
            },
            {
              "language": "sq",
              "text": "Kontrata është ruajtur në ERP dhe vlen për të gjitha porositë e këtij furnitori."
            },
            {
              "language": "tr",
              "text": "Kontrat ERP’de kayıtlıdır ve bu tedarikçinin tüm siparişleri için geçerlidir."
            }
          ]
        },
        {
          "baseText": "Vor der Preisänderung muss der Einkauf prüfen, ob der Kontrakt noch gültig ist.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل تغيير السعر يجب على قسم المشتريات التحقق مما إذا كان العقد لا يزال ساريًا."
            },
            {
              "language": "ckb",
              "text": "پێش گۆڕینی نرخ، بەشی کڕین پێویستە بپشکنێت ئایا گرێبەستەکە هێشتا کارایە."
            },
            {
              "language": "en",
              "text": "Before the price change, purchasing must check whether the contract is still valid."
            },
            {
              "language": "fa",
              "text": "قبل از تغییر قیمت، خرید باید بررسی کند که قرارداد هنوز معتبر است یا نه."
            },
            {
              "language": "kmr",
              "text": "Berî guherîna bihayê, beşa kirînê divê kontrol bike gelo kontrakt hîn derbasdar e."
            },
            {
              "language": "pl",
              "text": "Przed zmianą ceny dział zakupów musi sprawdzić, czy kontrakt jest nadal ważny."
            },
            {
              "language": "ro",
              "text": "Înainte de schimbarea prețului, achizițiile trebuie să verifice dacă contractul este încă valabil."
            },
            {
              "language": "ru",
              "text": "Перед изменением цены отдел закупок должен проверить, действителен ли контракт."
            },
            {
              "language": "sq",
              "text": "Para ndryshimit të çmimit, blerja duhet të kontrollojë nëse kontrata është ende e vlefshme."
            },
            {
              "language": "tr",
              "text": "Fiyat değişikliğinden önce satın alma kontratın hâlâ geçerli olup olmadığını kontrol etmelidir."
            }
          ]
        }
      ]
    },
    {
