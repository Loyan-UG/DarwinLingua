      ],
      "grammarNotes": [
        "irregular verb: ringt, rang, hat gerungen",
        "means to wrestle literally or to struggle for a decision, solution, or words"
      ],
      "collocations": [
        {
          "text": "um eine Lösung ringen",
          "meaning": "to struggle for a solution"
        },
        {
          "text": "nach Worten ringen",
          "meaning": "to struggle for words"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Ringkampf",
          "relationLabel": "noun",
          "note": "literal wrestling"
        },
        {
          "lemma": "das Ringen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يناضل من أجل؛ يصارع؛ يكافح للوصول إلى"
        },
        {
          "language": "ckb",
          "text": "خەبات دەکات بۆ؛ ملمڵانێ دەکات؛ بەدوای چارەسەر دەگەڕێت"
        },
        {
          "language": "en",
          "text": "to wrestle; to struggle for; to grapple with"
        },
        {
          "language": "fa",
          "text": "کشمکش کردن؛ تلاش سخت کردن؛ دست‌وپنجه نرم کردن"
        },
        {
          "language": "kmr",
          "text": "tekoşîn kirin; şer kirin; bi dijwarî geriyan"
        },
        {
          "language": "pl",
          "text": "zmagać się; walczyć o; mocować się"
        },
        {
          "language": "ro",
          "text": "a se lupta; a se zbate pentru"
        },
        {
          "language": "ru",
          "text": "бороться; добиваться; мучительно искать"
        },
        {
          "language": "sq",
          "text": "të luftosh për; të përleshesh; të përpiqesh fort"
        },
        {
          "language": "tr",
          "text": "mücadele etmek; boğuşmak; uğraşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Verhandlungspartner ringen seit Stunden um einen Kompromiss.",
          "translations": [
            {
              "language": "ar",
              "text": "يتفاوض الطرفان منذ ساعات للوصول إلى حل وسط."
            },
            {
              "language": "ckb",
              "text": "لایەنە گفتوگۆکەرەکان چەند کاتژمێرە لەسەر کۆمپرۆمایسێک ملمڵانێ دەکەن."
            },
            {
              "language": "en",
              "text": "The negotiating partners have been struggling for hours to reach a compromise."
            },
            {
              "language": "fa",
              "text": "طرف‌های مذاکره ساعت‌هاست برای رسیدن به یک مصالحه تلاش می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Hevpeymanên danûstandinê ji saetan ve ji bo kompromîsekê têdikoşin."
            },
            {
              "language": "pl",
              "text": "Partnerzy negocjacyjni od godzin walczą o kompromis."
            },
            {
              "language": "ro",
              "text": "Partenerii de negociere se luptă de ore întregi pentru un compromis."
            },
            {
              "language": "ru",
              "text": "Участники переговоров уже несколько часов борются за компромисс."
            },
            {
              "language": "sq",
              "text": "Partnerët negociues po përpiqen prej orësh për një kompromis."
            },
            {
              "language": "tr",
              "text": "Müzakere tarafları saatlerdir bir uzlaşma için mücadele ediyor."
            }
          ]
        },
        {
          "baseText": "Nach der Diagnose rang sie kurz nach Worten und bat dann um einen zweiten Termin.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد التشخيص عجزت للحظة عن إيجاد الكلمات ثم طلبت موعداً ثانياً."
            },
            {
              "language": "ckb",
              "text": "دوای دەستنیشانکردنی نەخۆشییەکە، کەمێک بەدوای وشەدا گەڕا و پاشان داوای کاتێکی دووەمی کرد."
            },
            {
              "language": "en",
              "text": "After the diagnosis, she briefly struggled for words and then asked for a second appointment."
            },
            {
              "language": "fa",
              "text": "بعد از تشخیص، او لحظه‌ای دنبال کلمات گشت و بعد درخواست وقت دوم کرد."
            },
            {
              "language": "kmr",
              "text": "Piştî teşhîsê, wê demeke kurt li pey peyvan geriya û paşê daxwaza randevûyek duyemîn kir."
            },
            {
              "language": "pl",
              "text": "Po diagnozie przez chwilę szukała słów, a potem poprosiła o drugi termin."
            },
            {
              "language": "ro",
              "text": "După diagnostic, ea s-a chinuit puțin să găsească cuvintele și apoi a cerut o a doua programare."
            },
            {
              "language": "ru",
              "text": "После диагноза она на мгновение потеряла дар речи, а затем попросила о второй встрече."
            },
            {
              "language": "sq",
              "text": "Pas diagnozës, ajo kërkoi pak fjalët dhe pastaj kërkoi një takim të dytë."
            },
            {
              "language": "tr",
              "text": "Tanıdan sonra kısa süre kelimeleri bulmakta zorlandı ve ardından ikinci bir randevu istedi."
            }
          ]
        }
      ]
    }
  ],
