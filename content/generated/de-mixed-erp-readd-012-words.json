      ],
      "examples": [
        {
          "baseText": "Der Status der Bestellung ist im ERP-System offen.",
          "translations": [
            {
              "language": "ar",
              "text": "حالة الطلب في نظام تخطيط موارد المؤسسة مفتوحة."
            },
            {
              "language": "ckb",
              "text": "دۆخی داواکارییەکە لە سیستەمی ERPدا کراوەیە."
            },
            {
              "language": "en",
              "text": "The status of the order is open in the ERP system."
            },
            {
              "language": "fa",
              "text": "وضعیت سفارش در سیستم ERP باز است."
            },
            {
              "language": "kmr",
              "text": "Rewşa fermarişê di pergala ERP de vekirî ye."
            },
            {
              "language": "pl",
              "text": "Status zamówienia w systemie ERP jest otwarty."
            },
            {
              "language": "ro",
              "text": "Statusul comenzii în sistemul ERP este deschis."
            },
            {
              "language": "ru",
              "text": "Статус заказа в ERP-системе открыт."
            },
            {
              "language": "sq",
              "text": "Statusi i porosisë në sistemin ERP është i hapur."
            },
            {
              "language": "tr",
              "text": "Siparişin ERP sistemindeki durumu açık."
            }
          ]
        },
        {
          "baseText": "Kannst du den Status kurz prüfen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك التحقق من الحالة بسرعة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت دۆخەکە بە خێرایی بپشکنیت؟"
            },
            {
              "language": "en",
              "text": "Can you quickly check the status?"
            },
            {
              "language": "fa",
              "text": "می‌توانی سریع وضعیت را بررسی کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî rewşê bi lez kontrol bikî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz szybko sprawdzić status?"
            },
            {
              "language": "ro",
              "text": "Poți verifica rapid statusul?"
            },
            {
              "language": "ru",
              "text": "Можешь быстро проверить статус?"
            },
            {
              "language": "sq",
              "text": "A mund ta kontrollosh shpejt statusin?"
            },
            {
              "language": "tr",
              "text": "Durumu hızlıca kontrol edebilir misin?"
            }
          ]
        }
      ]
    },
