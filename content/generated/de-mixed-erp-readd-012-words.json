      "examples": [
        {
          "baseText": "Der Verkauf wird im ERP-System gebucht.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تسجيل البيع في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "فرۆشتنەکە لە سیستەمی ERPدا تۆمار دەکرێت."
            },
            {
              "language": "en",
              "text": "The sale is recorded in the ERP system."
