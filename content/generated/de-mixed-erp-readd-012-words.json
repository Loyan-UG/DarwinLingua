        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "قيمة البداية"
        },
        {
          "language": "ckb",
          "text": "بەهای دەستپێک"
        },
        {
          "language": "en",
          "text": "start value"
        },
        {
          "language": "fa",
          "text": "مقدار شروع"
        },
        {
          "language": "kmr",
          "text": "nirxê destpêkê"
        },
        {
          "language": "pl",
          "text": "wartość początkowa"
        },
        {
          "language": "ro",
          "text": "valoare inițială"
        },
        {
          "language": "ru",
          "text": "начальное значение"
        },
        {
          "language": "sq",
          "text": "vlerë fillestare"
        },
        {
          "language": "tr",
          "text": "başlangıç değeri"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte geben Sie den Startwert im ERP-System ein.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إدخال قيمة البداية في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "تکایە بەهای دەستپێک لە سیستەمی ERPدا بنووسن."
            },
            {
              "language": "en",
              "text": "Please enter the start value in the ERP system."
            },
            {
              "language": "fa",
              "text": "لطفاً مقدار شروع را در سیستم ERP وارد کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe nirxê destpêkê di pergala ERP de binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę wpisać wartość początkową w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să introduceți valoarea inițială în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, введите начальное значение в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Ju lutemi shkruani vlerën fillestare në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Lütfen başlangıç değerini ERP sistemine girin."
            }
          ]
        },
        {
          "baseText": "Der Startwert ist null.",
          "translations": [
            {
              "language": "ar",
              "text": "قيمة البداية هي صفر."
            },
            {
              "language": "ckb",
              "text": "بەهای دەستپێک سفرە."
            },
            {
              "language": "en",
              "text": "The start value is zero."
            },
            {
              "language": "fa",
              "text": "مقدار شروع صفر است."
            },
            {
              "language": "kmr",
              "text": "Nirxê destpêkê sifir e."
            },
            {
              "language": "pl",
              "text": "Wartość początkowa wynosi zero."
            },
            {
              "language": "ro",
              "text": "Valoarea inițială este zero."
            },
            {
              "language": "ru",
              "text": "Начальное значение равно нулю."
            },
            {
              "language": "sq",
              "text": "Vlera fillestare është zero."
            },
            {
              "language": "tr",
              "text": "Başlangıç değeri sıfır."
            }
          ]
        }
      ]
    },
