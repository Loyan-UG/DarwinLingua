          "meaning": "to enter a start value"
        },
        {
          "text": "Startwert ändern",
          "meaning": "to change a start value"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Start",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Wert",
          "relationLabel": "noun",
