  "entries": [
    {
      "word": "die Figurenkonstellation",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Figurenkonstellationen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fi-gu-ren-kon-stel-la-ti-on",
      "topics": [
        "culture-and-media",
        "education-and-training",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Figurenkonstellationen"
      ],
      "collocations": [
        {
          "text": "die Figurenkonstellation analysieren",
          "meaning": "to analyze the character constellation"
        },
        {
          "text": "eine komplexe Figurenkonstellation",
          "meaning": "a complex arrangement of characters"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Figur",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Konstellation",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ترتيب الشخصيات؛ شبكة العلاقات بين الشخصيات"
        },
        {
          "language": "ckb",
          "text": "پێکهاتەی کارەکتەرەکان؛ تۆڕی پەیوەندی نێوان کارەکتەرەکان"
        },
        {
          "language": "en",
          "text": "character constellation; network of character relationships"
        },
        {
          "language": "fa",
          "text": "آرایش شخصیت‌ها؛ شبکه روابط شخصیت‌ها"
        },
        {
          "language": "kmr",
          "text": "konstelasyona karakteran; tora têkiliyên karakteran"
        },
        {
          "language": "pl",
          "text": "układ postaci; sieć relacji między postaciami"
        },
        {
          "language": "ro",
          "text": "constelație de personaje; rețea de relații între personaje"
        },
        {
          "language": "ru",
          "text": "расстановка персонажей; сеть отношений между героями"
        },
        {
          "language": "sq",
          "text": "konstelacion personazhesh; rrjet marrëdhëniesh mes personazheve"
        },
        {
          "language": "tr",
          "text": "karakterler dizilimi; karakter ilişkileri ağı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Figurenkonstellation macht den sozialen Druck innerhalb der Familie sichtbar.",
          "translations": [
            {
              "language": "ar",
              "text": "تجعل شبكة الشخصيات الضغط الاجتماعي داخل العائلة مرئيًا."
            },
            {
              "language": "ckb",
              "text": "پێکهاتەی کارەکتەرەکان فشاری کۆمەڵایەتی ناو خێزانەکە دەردەخات."
            },
            {
              "language": "en",
              "text": "The character constellation makes the social pressure within the family visible."
            },
            {
              "language": "fa",
              "text": "آرایش شخصیت‌ها فشار اجتماعی درون خانواده را آشکار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Konstelasyona karakteran zexta civakî ya nav malbatê xuya dike."
            },
            {
              "language": "pl",
              "text": "Układ postaci uwidacznia presję społeczną wewnątrz rodziny."
            },
            {
              "language": "ro",
              "text": "Constelația personajelor face vizibilă presiunea socială din familie."
            },
            {
              "language": "ru",
              "text": "Расстановка персонажей делает видимым социальное давление внутри семьи."
            },
            {
              "language": "sq",
              "text": "Konstelacioni i personazheve e bën të dukshëm presionin social brenda familjes."
            },
            {
              "language": "tr",
              "text": "Karakterler dizilimi aile içindeki toplumsal baskıyı görünür kılar."
            }
          ]
        },
        {
          "baseText": "Im Unterricht vergleichen wir die Figurenkonstellation des Romans mit der Verfilmung.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدرس نقارن شبكة الشخصيات في الرواية بالفيلم المقتبس."
            },
            {
              "language": "ckb",
              "text": "لە وانەکەدا پێکهاتەی کارەکتەرەکانی ڕۆمانەکە لەگەڵ فیلمەکە بەراورد دەکەین."
            },
            {
              "language": "en",
              "text": "In class, we compare the novel’s character constellation with the film adaptation."
            },
            {
              "language": "fa",
              "text": "در کلاس، آرایش شخصیت‌های رمان را با اقتباس سینمایی مقایسه می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di dersê de em konstelasyona karakterên romanê bi fîlmê re berhev dikin."
            },
            {
              "language": "pl",
              "text": "Na zajęciach porównujemy układ postaci w powieści z ekranizacją."
            },
            {
              "language": "ro",
              "text": "La curs comparăm constelația personajelor din roman cu ecranizarea."
            },
            {
              "language": "ru",
              "text": "На занятии мы сравниваем расстановку персонажей романа с экранизацией."
            },
            {
              "language": "sq",
              "text": "Në mësim krahasojmë konstelacionin e personazheve të romanit me ekranizimin."
            },
            {
              "language": "tr",
              "text": "Derste romanın karakterler dizilimini film uyarlamasıyla karşılaştırıyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "die Finanzierungsstruktur",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Finanzierungsstrukturen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fi-nan-zie-rungs-struk-tur",
      "topics": [
        "finance-and-accounting",
        "management-and-leadership",
        "advanced-analysis"
      ],
      "usageLabels": [
        "business",
        "finance",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Finanzierungsstrukturen"
      ],
      "collocations": [
        {
          "text": "eine tragfähige Finanzierungsstruktur",
          "meaning": "a viable financing structure"
        },
        {
          "text": "die Finanzierungsstruktur anpassen",
          "meaning": "to adjust the financing structure"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Finanzierung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "finanzieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "هيكل التمويل؛ بنية التمويل"
        },
        {
          "language": "ckb",
          "text": "پێکهاتەی دارایی؛ شێوازی دابینکردنی پارە"
        },
        {
          "language": "en",
          "text": "financing structure; funding structure"
        },
        {
          "language": "fa",
          "text": "ساختار تأمین مالی؛ ترکیب منابع مالی"
        },
        {
          "language": "kmr",
          "text": "avahiya fînansmanê; şêwaza dabînkirina pere"
        },
        {
          "language": "pl",
          "text": "struktura finansowania"
        },
        {
          "language": "ro",
          "text": "structură de finanțare"
        },
        {
          "language": "ru",
          "text": "структура финансирования"
        },
        {
          "language": "sq",
          "text": "strukturë financimi"
        },
        {
          "language": "tr",
          "text": "finansman yapısı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Finanzierungsstruktur des Projekts hängt zu stark von kurzfristigen Krediten ab.",
          "translations": [
            {
              "language": "ar",
              "text": "يعتمد هيكل تمويل المشروع بشكل مفرط على قروض قصيرة الأجل."
            },
            {
              "language": "ckb",
              "text": "پێکهاتەی دارایی پڕۆژەکە زۆر پشت بە قەرزی کورتخایەن دەبەستێت."
            },
            {
              "language": "en",
              "text": "The project’s financing structure depends too heavily on short-term loans."
            },
            {
              "language": "fa",
              "text": "ساختار تأمین مالی پروژه بیش از حد به وام‌های کوتاه‌مدت وابسته است."
            },
            {
              "language": "kmr",
              "text": "Avahiya fînansmana projeyê pir zêde girêdayî krediyên demkurt e."
            },
            {
              "language": "pl",
              "text": "Struktura finansowania projektu zbyt mocno zależy od krótkoterminowych kredytów."
            },
            {
              "language": "ro",
              "text": "Structura de finanțare a proiectului depinde prea mult de credite pe termen scurt."
            },
            {
              "language": "ru",
              "text": "Структура финансирования проекта слишком сильно зависит от краткосрочных кредитов."
            },
            {
              "language": "sq",
              "text": "Struktura e financimit të projektit varet tepër nga kreditë afatshkurtra."
            },
            {
              "language": "tr",
              "text": "Projenin finansman yapısı kısa vadeli kredilere fazla bağımlı."
            }
          ]
        },
        {
          "baseText": "Vor der Expansion müssen wir die Finanzierungsstruktur stabiler aufstellen.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل التوسع يجب أن نجعل هيكل التمويل أكثر استقرارًا."
            },
            {
              "language": "ckb",
              "text": "پێش فراوانبوونەوە دەبێت پێکهاتەی دارایی جێگیرتر ڕێکبخەین."
            },
            {
              "language": "en",
              "text": "Before expansion, we need to make the financing structure more stable."
            },
            {
              "language": "fa",
              "text": "پیش از توسعه، باید ساختار تأمین مالی را پایدارتر کنیم."
            },
            {
              "language": "kmr",
              "text": "Berî firehbûnê divê em avahiya fînansmanê stabîltir bikin."
            },
            {
              "language": "pl",
              "text": "Przed ekspansją musimy stabilniej ukształtować strukturę finansowania."
            },
            {
              "language": "ro",
              "text": "Înainte de extindere trebuie să stabilizăm structura de finanțare."
            },
            {
              "language": "ru",
              "text": "Перед расширением нам нужно сделать структуру финансирования более устойчивой."
            },
            {
              "language": "sq",
              "text": "Para zgjerimit duhet ta bëjmë strukturën e financimit më të qëndrueshme."
            },
            {
              "language": "tr",
              "text": "Genişlemeden önce finansman yapısını daha istikrarlı hale getirmeliyiz."
            }
          ]
        }
      ]
    },
