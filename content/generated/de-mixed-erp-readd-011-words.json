      "word": "das Lager",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Lager",
      "infinitive": null,
      "syllableBreak": "La-ger",
      "topics": [
        "warehouse-and-logistics",
        "erp-and-business-systems",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "workplace"
      ],
      "grammarNotes": [
        "neuter noun; plural often same as singular"
      ],
      "collocations": [
        {
          "text": "im Lager arbeiten",
          "meaning": "to work in the warehouse"
        },
        {
          "text": "Lager prüfen",
          "meaning": "to check the warehouse/stock"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "lagern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "مستودع؛ مخزن"
        },
        {
          "language": "ckb",
          "text": "کۆگا"
        },
        {
          "language": "en",
          "text": "warehouse; storage"
        },
        {
          "language": "fa",
          "text": "انبار"
        },
        {
          "language": "kmr",
          "text": "embar"
        },
        {
          "language": "pl",
          "text": "magazyn"
        },
        {
          "language": "ro",
          "text": "depozit; magazie"
        },
        {
          "language": "ru",
          "text": "склад"
        },
        {
          "language": "sq",
          "text": "depo"
        },
        {
          "language": "tr",
          "text": "depo"
        }
      ],
      "examples": [
        {
          "baseText": "Das Lager hat heute neue Ware bekommen.",
          "translations": [
            {
              "language": "ar",
              "text": "استلم المستودع بضاعة جديدة اليوم."
            },
            {
              "language": "ckb",
              "text": "کۆگا ئەمڕۆ کاڵای نوێی وەرگرت."
            },
            {
              "language": "en",
              "text": "The warehouse received new goods today."
            },
            {
              "language": "fa",
              "text": "انبار امروز کالای جدید دریافت کرد."
            },
            {
              "language": "kmr",
              "text": "Embar îro malên nû wergirt."
            },
            {
              "language": "pl",
              "text": "Magazyn otrzymał dziś nowy towar."
            },
            {
              "language": "ro",
              "text": "Depozitul a primit astăzi marfă nouă."
            },
            {
              "language": "ru",
              "text": "Склад сегодня получил новый товар."
            },
            {
              "language": "sq",
              "text": "Depoja mori mall të ri sot."
            },
            {
              "language": "tr",
              "text": "Depo bugün yeni mal aldı."
            }
          ]
        },
        {
          "baseText": "Im ERP-System sehen wir das richtige Lager.",
          "translations": [
            {
              "language": "ar",
              "text": "في نظام تخطيط موارد المؤسسة نرى المستودع الصحيح."
            },
            {
              "language": "ckb",
              "text": "لە سیستەمی ERPدا کۆگای دروست دەبینین."
            },
            {
              "language": "en",
              "text": "In the ERP system, we see the correct warehouse."
            },
            {
              "language": "fa",
              "text": "در سیستم ERP انبار درست را می‌بینیم."
            },
            {
              "language": "kmr",
              "text": "Di pergala ERP de em embara rast dibînin."
            },
            {
              "language": "pl",
              "text": "W systemie ERP widzimy właściwy magazyn."
            },
            {
              "language": "ro",
              "text": "În sistemul ERP vedem depozitul corect."
            },
            {
              "language": "ru",
              "text": "В ERP-системе мы видим правильный склад."
            },
            {
              "language": "sq",
              "text": "Në sistemin ERP shohim depon e saktë."
            },
            {
              "language": "tr",
              "text": "ERP sisteminde doğru depoyu görüyoruz."
            }
          ]
        }
      ]
    },
