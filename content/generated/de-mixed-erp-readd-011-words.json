      ],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "Ortung aktivieren",
          "meaning": "to activate location tracking"
        },
        {
          "text": "Ortung des Fahrzeugs",
          "meaning": "tracking of the vehicle"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "orten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تحديد الموقع"
        },
        {
          "language": "ckb",
          "text": "شوێن دیاریکردن"
        },
        {
          "language": "en",
          "text": "location tracking"
        },
        {
          "language": "fa",
          "text": "مکان‌یابی"
        },
        {
          "language": "kmr",
          "text": "cih-dîtin"
        },
        {
          "language": "pl",
          "text": "lokalizacja"
        },
        {
          "language": "ro",
          "text": "localizare"
        },
        {
          "language": "ru",
          "text": "определение местоположения"
        },
        {
          "language": "sq",
          "text": "lokalizim"
        },
        {
          "language": "tr",
          "text": "konum tespiti"
        }
      ],
      "examples": [
        {
          "baseText": "Die Ortung des Fahrzeugs ist im ERP-System aktiv.",
          "translations": [
            {
              "language": "ar",
              "text": "تحديد موقع المركبة فعال في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "شوێن دیاریکردنی ئامرازەکە لە سیستەمی ERPدا چالاکە."
            },
            {
              "language": "en",
              "text": "Vehicle tracking is active in the ERP system."
            },
            {
              "language": "fa",
              "text": "مکان‌یابی وسیله نقلیه در سیستم ERP فعال است."
            },
            {
              "language": "kmr",
              "text": "Cih-dîtina wesayîtê di pergala ERP de çalak e."
            },
            {
              "language": "pl",
              "text": "Lokalizacja pojazdu jest aktywna w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Localizarea vehiculului este activă în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Отслеживание автомобиля активно в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Lokalizimi i automjetit është aktiv në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Araç konum takibi ERP sisteminde aktif."
            }
          ]
        },
        {
          "baseText": "Die Ortung hilft uns, das Handy zu finden.",
          "translations": [
            {
              "language": "ar",
              "text": "تساعدنا خاصية تحديد الموقع في العثور على الهاتف."
            },
            {
              "language": "ckb",
              "text": "شوێن دیاریکردن یارمەتیمان دەدات مۆبایلەکە بدۆزینەوە."
            },
            {
              "language": "en",
              "text": "Location tracking helps us find the phone."
            },
            {
              "language": "fa",
              "text": "مکان‌یابی به ما کمک می‌کند گوشی را پیدا کنیم."
            },
            {
              "language": "kmr",
              "text": "Cih-dîtin alîkariya me dike ku telefonê bibînin."
            },
            {
              "language": "pl",
              "text": "Lokalizacja pomaga nam znaleźć telefon."
            },
            {
              "language": "ro",
              "text": "Localizarea ne ajută să găsim telefonul."
            },
            {
              "language": "ru",
              "text": "Геолокация помогает нам найти телефон."
            },
            {
              "language": "sq",
              "text": "Lokalizimi na ndihmon të gjejmë telefonin."
            },
            {
              "language": "tr",
              "text": "Konum takibi telefonu bulmamıza yardım eder."
            }
          ]
        }
      ]
    },
