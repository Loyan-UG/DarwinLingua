              "language": "ar",
              "text": "على الباليت توجد عشرة صناديق."
            },
            {
              "language": "ckb",
              "text": "لەسەر پالێتەکە دە کارتۆن هەیە."
            },
            {
              "language": "en",
              "text": "There are ten boxes on the pallet."
            },
            {
              "language": "fa",
              "text": "روی پالت ده کارتن قرار دارد."
            },
            {
              "language": "kmr",
              "text": "Li ser paletê deh karton hene."
            },
            {
              "language": "pl",
              "text": "Na palecie stoi dziesięć kartonów."
