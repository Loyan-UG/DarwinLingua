          "baseText": "Die Palette wurde im Lager gescannt.",
          "translations": [
            {
              "language": "ar",
              "text": "تم مسح الباليت في المستودع."
            },
            {
              "language": "ckb",
              "text": "پالێتەکە لە کۆگادا سکەن کرا."
            },
            {
              "language": "en",
              "text": "The pallet was scanned in the warehouse."
            },
            {
              "language": "fa",
              "text": "پالت در انبار اسکن شد."
            },
            {
              "language": "kmr",
              "text": "Palet di embarê de hate skankirin."
            },
            {
              "language": "pl",
              "text": "Paleta została zeskanowana w magazynie."
            },
            {
              "language": "ro",
              "text": "Paletul a fost scanat în depozit."
            },
            {
              "language": "ru",
              "text": "Палета была отсканирована на складе."
            },
            {
              "language": "sq",
              "text": "Paleta u skanua në depo."
            },
            {
              "language": "tr",
              "text": "Palet depoda tarandı."
            }
          ]
        },
        {
          "baseText": "Auf der Palette stehen zehn Kartons.",
          "translations": [
