  "entries": [
    {
      "word": "gerecht",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ge-recht",
      "topics": [
        "work-and-jobs",
        "social-and-relationships",
        "law-and-compliance"
      ],
      "usageLabels": [
        "everyday",
        "formal",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; means fair or just"
      ],
      "collocations": [
        {
          "text": "eine gerechte Lösung",
          "meaning": "a fair solution"
        },
        {
          "text": "gerecht behandeln",
          "meaning": "to treat fairly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Gerechtigkeit",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "ungerecht",
          "relationLabel": "opposite adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عادل؛ منصف"
        },
        {
          "language": "ckb",
          "text": "دادپەروەر؛ ڕەوا"
        },
        {
          "language": "en",
          "text": "fair; just"
        },
        {
          "language": "fa",
          "text": "عادلانه؛ منصفانه"
        },
        {
          "language": "kmr",
          "text": "dadperwer; adil"
        },
        {
          "language": "pl",
          "text": "sprawiedliwy; uczciwy"
        },
        {
          "language": "ro",
          "text": "corect; drept"
        },
        {
          "language": "ru",
          "text": "справедливый; честный"
        },
        {
          "language": "sq",
          "text": "i drejtë; i ndershëm"
        },
        {
          "language": "tr",
          "text": "adil; hakkaniyetli"
        }
      ],
      "examples": [
        {
          "baseText": "Wir brauchen eine gerechte Lösung für alle Mitarbeiter.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج إلى حل عادل لجميع الموظفين."
            },
            {
              "language": "ckb",
              "text": "پێویستمان بە چارەسەرێکی دادپەروەرانە بۆ هەموو کارمەندان هەیە."
            },
            {
              "language": "en",
              "text": "We need a fair solution for all employees."
            },
            {
              "language": "fa",
              "text": "ما به یک راه‌حل عادلانه برای همه کارکنان نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Em hewceyê çareseriyeke adil ji bo hemû karmendan in."
            },
            {
              "language": "pl",
              "text": "Potrzebujemy sprawiedliwego rozwiązania dla wszystkich pracowników."
            },
            {
              "language": "ro",
              "text": "Avem nevoie de o soluție corectă pentru toți angajații."
            },
            {
              "language": "ru",
              "text": "Нам нужно справедливое решение для всех сотрудников."
            },
            {
              "language": "sq",
              "text": "Na duhet një zgjidhje e drejtë për të gjithë punonjësit."
            },
            {
              "language": "tr",
              "text": "Tüm çalışanlar için adil bir çözüme ihtiyacımız var."
            }
          ]
        },
        {
          "baseText": "Die Kundin fand es gerecht, dass sie den beschädigten Artikel zurückgeben konnte.",
          "translations": [
            {
              "language": "ar",
              "text": "وجدت الزبونة أنه من العدل أن تتمكن من إرجاع المنتج التالف."
            },
            {
              "language": "ckb",
              "text": "کڕیارە ژنەکە بە دادپەروەرانەی زانی کە توانی شتە زیانلێکەوتووەکە بگەڕێنێتەوە."
            },
            {
              "language": "en",
              "text": "The customer felt it was fair that she could return the damaged item."
            },
            {
              "language": "fa",
              "text": "مشتری این را عادلانه دانست که توانست کالای آسیب‌دیده را پس بدهد."
            },
            {
              "language": "kmr",
              "text": "Xerîdara jin ew adil dît ku karî tiştê zirarkirî vegerîne."
            },
            {
              "language": "pl",
              "text": "Klientka uznała za sprawiedliwe, że mogła zwrócić uszkodzony artykuł."
            },
            {
              "language": "ro",
              "text": "Clienta a considerat corect că a putut returna articolul deteriorat."
            },
            {
              "language": "ru",
              "text": "Покупательница сочла справедливым, что смогла вернуть поврежденный товар."
            },
            {
              "language": "sq",
              "text": "Klientja e pa si të drejtë që mundi ta kthente artikullin e dëmtuar."
            },
            {
              "language": "tr",
              "text": "Müşteri, hasarlı ürünü iade edebilmesini adil buldu."
            }
          ]
        }
      ]
    },
    {
      "word": "geschehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "geschehen",
      "pronunciationIpa": null,
      "syllableBreak": "ge-sche-hen",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb; often used like passieren; mostly in third person"
      ],
      "collocations": [
        {
          "text": "Was ist geschehen?",
          "meaning": "What happened?"
        },
        {
          "text": "aus Versehen geschehen",
          "meaning": "to happen by mistake"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Geschehen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحدث؛ يقع"
        },
        {
          "language": "ckb",
          "text": "ڕوودان؛ بەسەرهاتن"
        },
        {
          "language": "en",
          "text": "to happen; to occur"
        },
        {
          "language": "fa",
          "text": "اتفاق افتادن؛ رخ دادن"
        },
        {
          "language": "kmr",
          "text": "qewimîn; çêbûn"
        },
        {
          "language": "pl",
          "text": "wydarzyć się; zdarzyć się"
        },
        {
          "language": "ro",
          "text": "a se întâmpla; a avea loc"
        },
        {
          "language": "ru",
          "text": "происходить; случаться"
        },
        {
          "language": "sq",
          "text": "të ndodhë"
        },
        {
          "language": "tr",
          "text": "olmak; gerçekleşmek"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie kurz erklären, was gestern im Lager geschehen ist?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن تشرح بإيجاز ما حدث أمس في المستودع؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت بە کورتی ڕوون بکەیتەوە دوێنێ لە کۆگادا چی ڕوویدا؟"
            },
            {
              "language": "en",
              "text": "Can you briefly explain what happened in the warehouse yesterday?"
            },
            {
              "language": "fa",
              "text": "می‌توانید کوتاه توضیح دهید دیروز در انبار چه اتفاقی افتاد؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî bi kurtî rave bikî ka duh li embarê çi qewimî?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan krótko wyjaśnić, co wydarzyło się wczoraj w magazynie?"
            },
            {
              "language": "ro",
              "text": "Puteți explica pe scurt ce s-a întâmplat ieri în depozit?"
            },
            {
              "language": "ru",
              "text": "Можете кратко объяснить, что вчера произошло на складе?"
            },
            {
              "language": "sq",
              "text": "A mund të shpjegoni shkurt çfarë ndodhi dje në magazinë?"
            },
            {
              "language": "tr",
              "text": "Dün depoda ne olduğunu kısaca açıklayabilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Es ist nichts Schlimmes geschehen, aber wir sollten vorsichtiger sein.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يحدث شيء خطير، لكن ينبغي أن نكون أكثر حذراً."
            },
            {
              "language": "ckb",
              "text": "هیچ شتێکی خراپ ڕووی نەدا، بەڵام دەبێت زیاتر ئاگادار بین."
            },
            {
              "language": "en",
              "text": "Nothing serious happened, but we should be more careful."
            },
            {
              "language": "fa",
              "text": "اتفاق بدی نیفتاد، اما باید محتاط‌تر باشیم."
            },
            {
              "language": "kmr",
              "text": "Tiştek xirab neqewimî, lê divê em zêdetir baldar bin."
            },
            {
              "language": "pl",
              "text": "Nie stało się nic złego, ale powinniśmy być ostrożniejsi."
            },
            {
              "language": "ro",
              "text": "Nu s-a întâmplat nimic grav, dar ar trebui să fim mai atenți."
            },
            {
              "language": "ru",
              "text": "Ничего серьезного не произошло, но нам стоит быть осторожнее."
            },
            {
              "language": "sq",
              "text": "Nuk ndodhi asgjë e keqe, por duhet të jemi më të kujdesshëm."
            },
            {
              "language": "tr",
              "text": "Ciddi bir şey olmadı, ama daha dikkatli olmalıyız."
            }
          ]
        }
      ]
    },
