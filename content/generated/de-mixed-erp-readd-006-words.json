      "word": "das Personenkonto",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Personenkonten",
      "infinitive": null,
      "syllableBreak": "Per-so-nen-kon-to",
      "topics": [
        "finance-and-accounting",
        "documents-and-administration",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "technical",
        "administrative"
      ],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "ein Personenkonto anlegen",
          "meaning": "to create a personal/customer/vendor account"
        },
        {
          "text": "auf dem Personenkonto buchen",
          "meaning": "to post to the personal account"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Person",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "das Konto",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "حساب شخصي/عميل أو مورد"
        },
        {
          "language": "ckb",
          "text": "ئەکاونتی کەس/کڕیار یان دابینکەر"
        },
        {
          "language": "en",
          "text": "personal account; customer or vendor account"
        },
        {
          "language": "fa",
          "text": "حساب شخصی/مشتری یا تأمین‌کننده"
        },
        {
          "language": "kmr",
          "text": "hesabê kesî; hesabê xerîdar an dabînker"
        },
        {
          "language": "pl",
          "text": "konto osobowe; konto klienta lub dostawcy"
        },
        {
          "language": "ro",
          "text": "cont personal; cont client sau furnizor"
        },
        {
          "language": "ru",
          "text": "лицевой счет; счет клиента или поставщика"
        },
        {
          "language": "sq",
          "text": "llogari personale; llogari klienti ose furnizuesi"
        },
        {
          "language": "tr",
          "text": "cari hesap; müşteri veya tedarikçi hesabı"
        }
      ],
      "examples": [
        {
          "baseText": "Für den neuen Lieferanten wurde ein Personenkonto im ERP-System angelegt.",
          "translations": [
            {
              "language": "ar",
              "text": "تم إنشاء حساب للمورّد الجديد في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "بۆ دابینکەری نوێ ئەکاونتێکی کەسی لە سیستەمی ERPدا دروست کرا."
            },
            {
              "language": "en",
              "text": "A personal account was created for the new supplier in the ERP system."
            },
            {
              "language": "fa",
              "text": "برای تأمین‌کننده جدید یک حساب در سیستم ERP ایجاد شد."
            },
            {
              "language": "kmr",
              "text": "Ji bo dabînkerê nû hesabek kesî di pergala ERP de hate çêkirin."
            },
            {
              "language": "pl",
              "text": "Dla nowego dostawcy utworzono konto osobowe w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Pentru noul furnizor a fost creat un cont în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Для нового поставщика в ERP-системе был создан лицевой счет."
            },
            {
              "language": "sq",
              "text": "Për furnizuesin e ri u krijua një llogari në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Yeni tedarikçi için ERP sisteminde bir cari hesap açıldı."
            }
          ]
        },
        {
          "baseText": "Die Zahlung ist schon auf dem Personenkonto des Kunden gebucht.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تسجيل الدفعة بالفعل في حساب العميل."
            },
            {
              "language": "ckb",
              "text": "پارەدانەکە پێشتر لە ئەکاونتی کڕیارەکەدا تۆمار کراوە."
            },
            {
              "language": "en",
              "text": "The payment has already been posted to the customer account."
            },
            {
              "language": "fa",
              "text": "پرداخت قبلاً در حساب مشتری ثبت شده است."
            },
            {
              "language": "kmr",
              "text": "Pere dayîn berê li ser hesabê xerîdar hatiye tomarkirin."
            },
            {
              "language": "pl",
              "text": "Płatność została już zaksięgowana na koncie klienta."
            },
            {
              "language": "ro",
              "text": "Plata a fost deja înregistrată în contul clientului."
            },
            {
              "language": "ru",
              "text": "Платеж уже проведен по счету клиента."
            },
            {
              "language": "sq",
              "text": "Pagesa është regjistruar tashmë në llogarinë e klientit."
            },
            {
              "language": "tr",
              "text": "Ödeme müşteri hesabına zaten kaydedildi."
            }
          ]
        }
      ]
    },
    {
