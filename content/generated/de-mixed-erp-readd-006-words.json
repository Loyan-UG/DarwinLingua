      "word": "die Preisliste",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Preislisten",
      "infinitive": null,
      "syllableBreak": "Preis-lis-te",
      "topics": [
        "sales-and-customers",
        "procurement-and-suppliers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "written",
        "customer-facing"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Preisliste aktualisieren",
          "meaning": "to update a price list"
        },
        {
          "text": "die aktuelle Preisliste senden",
          "meaning": "to send the current price list"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Preis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Liste",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "قائمة أسعار"
        },
        {
          "language": "ckb",
          "text": "لیستی نرخ"
        },
        {
          "language": "en",
          "text": "price list"
        },
        {
          "language": "fa",
          "text": "لیست قیمت"
        },
        {
          "language": "kmr",
          "text": "lîsteya bihayan"
        },
        {
          "language": "pl",
          "text": "cennik"
        },
        {
          "language": "ro",
          "text": "listă de prețuri"
        },
        {
          "language": "ru",
          "text": "прайс-лист"
        },
        {
          "language": "sq",
          "text": "listë çmimesh"
        },
        {
          "language": "tr",
          "text": "fiyat listesi"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Preisliste ist seit heute im ERP-System aktiv.",
          "translations": [
            {
              "language": "ar",
              "text": "قائمة الأسعار الجديدة مفعّلة منذ اليوم في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "لیستی نرخی نوێ لە ئەمڕۆوە لە سیستەمی ERPدا چالاکە."
            },
            {
              "language": "en",
              "text": "The new price list has been active in the ERP system since today."
            },
            {
              "language": "fa",
              "text": "لیست قیمت جدید از امروز در سیستم ERP فعال است."
            },
            {
              "language": "kmr",
              "text": "Lîsteya bihayên nû ji îro ve di pergala ERP de çalak e."
            },
            {
              "language": "pl",
              "text": "Nowy cennik jest od dziś aktywny w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Noua listă de prețuri este activă de astăzi în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Новый прайс-лист с сегодняшнего дня активен в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Lista e re e çmimeve është aktive në sistemin ERP që nga sot."
            },
            {
              "language": "tr",
              "text": "Yeni fiyat listesi bugünden itibaren ERP sisteminde aktif."
            }
          ]
        },
        {
          "baseText": "Können Sie mir bitte die aktuelle Preisliste schicken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك إرسال قائمة الأسعار الحالية إليّ من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن تکایە لیستی نرخی ئێستام بۆ بنێرن؟"
            },
            {
              "language": "en",
              "text": "Could you please send me the current price list?"
            },
            {
              "language": "fa",
              "text": "ممکن است لطفاً لیست قیمت فعلی را برای من بفرستید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji kerema xwe lîsteya bihayên niha ji min re bişînin?"
            },
            {
              "language": "pl",
              "text": "Czy może mi Pan/Pani przesłać aktualny cennik?"
            },
            {
              "language": "ro",
              "text": "Îmi puteți trimite, vă rog, lista actuală de prețuri?"
            },
            {
              "language": "ru",
              "text": "Можете, пожалуйста, отправить мне актуальный прайс-лист?"
            },
            {
              "language": "sq",
              "text": "A mund të më dërgoni ju lutem listën aktuale të çmimeve?"
            },
            {
              "language": "tr",
              "text": "Bana güncel fiyat listesini gönderebilir misiniz?"
            }
          ]
        }
      ]
    },
