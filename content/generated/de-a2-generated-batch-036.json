        "masculine noun: der Fahrplan, die Fahrpläne"
      ],
      "collocations": [
        {
          "text": "den Fahrplan prüfen",
          "meaning": "to check the timetable"
        },
        {
          "text": "laut Fahrplan",
          "meaning": "according to the timetable"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fahren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Plan",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جدول المواعيد؛ جدول الرحلات"
        },
        {
          "language": "ckb",
          "text": "خشتەی هاتووچۆ"
        },
        {
          "language": "en",
          "text": "timetable; schedule"
        },
        {
          "language": "fa",
          "text": "برنامه حرکت؛ جدول زمانی"
        },
        {
          "language": "kmr",
          "text": "bernameya rêwîtiyê"
        },
        {
          "language": "pl",
          "text": "rozkład jazdy"
        },
        {
          "language": "ro",
          "text": "orar; program de circulație"
        },
        {
          "language": "ru",
          "text": "расписание движения"
        },
        {
          "language": "sq",
          "text": "orar udhëtimi"
        },
        {
          "language": "tr",
          "text": "sefer tarifesi"
        }
      ],
      "examples": [
        {
          "baseText": "Ich prüfe den Fahrplan in der App.",
          "translations": [
            {
              "language": "ar",
              "text": "أتحقق من جدول المواعيد في التطبيق."
            },
            {
              "language": "ckb",
              "text": "خشتەی هاتووچۆ لە ئەپەکەدا دەپشکنم."
            },
            {
              "language": "en",
              "text": "I check the timetable in the app."
            },
            {
              "language": "fa",
              "text": "برنامه حرکت را در اپلیکیشن بررسی می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez bernameya rêwîtiyê di sepanê de kontrol dikim."
            },
            {
              "language": "pl",
              "text": "Sprawdzam rozkład jazdy w aplikacji."
            },
            {
              "language": "ro",
              "text": "Verific orarul în aplicație."
            },
            {
              "language": "ru",
              "text": "Я проверяю расписание в приложении."
            },
            {
              "language": "sq",
              "text": "E kontrolloj orarin në aplikacion."
            },
            {
              "language": "tr",
              "text": "Sefer tarifesini uygulamada kontrol ediyorum."
            }
          ]
        },
        {
          "baseText": "Laut Fahrplan fährt der Bus um acht Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "حسب جدول المواعيد تنطلق الحافلة في الساعة الثامنة."
            },
            {
              "language": "ckb",
              "text": "بەپێی خشتەکە پاسەکە کاتژمێر هەشت دەڕوات."
            },
            {
              "language": "en",
              "text": "According to the timetable, the bus leaves at eight."
            },
            {
              "language": "fa",
              "text": "طبق برنامه، اتوبوس ساعت هشت حرکت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Li gorî bernameyê otobus di saet heştan de diçe."
            },
            {
              "language": "pl",
              "text": "Według rozkładu autobus odjeżdża o ósmej."
            },
            {
              "language": "ro",
              "text": "Conform orarului, autobuzul pleacă la ora opt."
            },
            {
              "language": "ru",
              "text": "По расписанию автобус отправляется в восемь."
            },
            {
              "language": "sq",
              "text": "Sipas orarit, autobusi niset në orën tetë."
            },
            {
              "language": "tr",
              "text": "Tarifeye göre otobüs saat sekizde kalkıyor."
            }
          ]
        }
      ]
    },
