      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسقط؛ ينخفض"
        },
        {
          "language": "ckb",
          "text": "کەوتن؛ دابەزین"
        },
        {
          "language": "en",
          "text": "to fall; to drop"
        },
        {
          "language": "fa",
          "text": "افتادن؛ کاهش یافتن"
        },
        {
          "language": "kmr",
          "text": "ketin; daketin"
        },
        {
          "language": "pl",
          "text": "spadać; upaść"
        },
        {
          "language": "ro",
          "text": "a cădea; a scădea"
        },
        {
          "language": "ru",
          "text": "падать; снижаться"
        },
        {
          "language": "sq",
          "text": "të biesh; të ulesh"
        },
        {
          "language": "tr",
          "text": "düşmek"
        }
      ],
      "examples": [
        {
          "baseText": "Pass auf, das Glas kann fallen.",
          "translations": [
            {
              "language": "ar",
              "text": "انتبه، يمكن أن يسقط الكأس."
            },
            {
              "language": "ckb",
              "text": "ئاگادار بە، پەرداخەکە دەتوانێت بکەوێت."
            },
            {
              "language": "en",
              "text": "Be careful, the glass can fall."
            },
            {
              "language": "fa",
              "text": "مواظب باش، لیوان ممکن است بیفتد."
            },
            {
              "language": "kmr",
              "text": "Baldar be, qedeh dikare bikeve."
            },
            {
              "language": "pl",
              "text": "Uważaj, szklanka może spaść."
            },
            {
              "language": "ro",
              "text": "Ai grijă, paharul poate cădea."
            },
            {
              "language": "ru",
              "text": "Осторожно, стакан может упасть."
            },
            {
              "language": "sq",
              "text": "Kujdes, gota mund të bjerë."
            },
            {
              "language": "tr",
              "text": "Dikkat et, bardak düşebilir."
            }
          ]
        },
        {
          "baseText": "Im Winter fallen die Temperaturen oft unter null Grad.",
          "translations": [
            {
              "language": "ar",
              "text": "في الشتاء تنخفض درجات الحرارة غالباً تحت الصفر."
            },
            {
              "language": "ckb",
              "text": "لە زستاندا پلەی گەرمی زۆرجار دەکەوێتە خوار سفر."
            },
            {
              "language": "en",
              "text": "In winter, temperatures often fall below zero degrees."
            },
            {
              "language": "fa",
              "text": "در زمستان دما اغلب زیر صفر می‌افتد."
            },
            {
              "language": "kmr",
              "text": "Di zivistanê de germî gelek caran dikeve bin sifir derece."
            },
            {
              "language": "pl",
              "text": "Zimą temperatury często spadają poniżej zera."
            },
            {
              "language": "ro",
              "text": "Iarna temperaturile scad adesea sub zero grade."
            },
            {
              "language": "ru",
              "text": "Зимой температуры часто падают ниже нуля."
            },
            {
              "language": "sq",
              "text": "Në dimër temperaturat shpesh bien nën zero gradë."
            },
            {
              "language": "tr",
              "text": "Kışın sıcaklıklar sık sık sıfırın altına düşer."
            }
          ]
        }
      ]
    },
