        },
        {
          "language": "fa",
          "text": "جشن خانوادگی"
        },
        {
          "language": "kmr",
          "text": "cejna malbatê"
        },
        {
          "language": "pl",
          "text": "uroczystość rodzinna"
        },
        {
          "language": "ro",
          "text": "sărbătoare de familie"
        },
        {
          "language": "ru",
          "text": "семейный праздник"
        },
        {
          "language": "sq",
          "text": "festë familjare"
        },
        {
          "language": "tr",
          "text": "aile kutlaması"
        }
      ],
      "examples": [
        {
          "baseText": "Am Sonntag haben wir eine Familienfeier.",
          "translations": [
            {
              "language": "ar",
              "text": "يوم الأحد لدينا احتفال عائلي."
            },
            {
              "language": "ckb",
              "text": "یەکشەممە ئاهەنگێکی خێزانیمان هەیە."
            },
            {
              "language": "en",
              "text": "On Sunday we have a family celebration."
            },
            {
              "language": "fa",
              "text": "یکشنبه جشن خانوادگی داریم."
            },
            {
              "language": "kmr",
              "text": "Yekşemê cejna malbatê ya me heye."
            },
            {
              "language": "pl",
              "text": "W niedzielę mamy uroczystość rodzinną."
            },
            {
              "language": "ro",
              "text": "Duminică avem o sărbătoare de familie."
            },
            {
              "language": "ru",
              "text": "В воскресенье у нас семейный праздник."
            },
            {
              "language": "sq",
              "text": "Të dielën kemi një festë familjare."
            },
            {
              "language": "tr",
              "text": "Pazar günü aile kutlamamız var."
            }
          ]
        },
        {
          "baseText": "Für die Familienfeier backt meine Mutter einen Kuchen.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل الاحتفال العائلي تخبز أمي كعكة."
            },
            {
              "language": "ckb",
              "text": "بۆ ئاهەنگە خێزانییەکە دایکم کێکێک دەکات."
            },
            {
              "language": "en",
              "text": "For the family celebration, my mother bakes a cake."
            },
            {
              "language": "fa",
              "text": "برای جشن خانوادگی مادرم کیک می‌پزد."
            },
            {
              "language": "kmr",
              "text": "Ji bo cejna malbatê dayika min kekekê dipêje."
            },
            {
              "language": "pl",
              "text": "Na uroczystość rodzinną moja mama piecze ciasto."
            },
            {
              "language": "ro",
              "text": "Pentru sărbătoarea de familie, mama coace o prăjitură."
            },
            {
              "language": "ru",
              "text": "К семейному празднику моя мама печет пирог."
            },
            {
              "language": "sq",
              "text": "Për festën familjare, nëna ime pjek një tortë."
            },
            {
              "language": "tr",
              "text": "Aile kutlaması için annem kek yapıyor."
            }
          ]
        }
      ]
