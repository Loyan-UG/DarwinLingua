  "entries": [
    {
      "word": "eingießen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "eingießen",
      "pronunciationIpa": null,
      "syllableBreak": "ein-gie-ßen",
      "topics": [
        "everyday-life",
        "shopping-and-services",
        "customer-service"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "customer-service"
      ],
      "grammarNotes": [
        "separable strong verb: gießt ein, goss ein, hat eingegossen"
      ],
      "collocations": [
        {
          "text": "Tee in eine Tasse eingießen",
          "meaning": "to pour tea into a cup"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gießen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصب في؛ يسكب في"
        },
        {
          "language": "ckb",
          "text": "تێکردن؛ ڕشتنە ناو"
        },
        {
          "language": "en",
          "text": "to pour in; to pour into"
        },
        {
          "language": "fa",
          "text": "ریختن در؛ داخل ریختن"
        },
        {
          "language": "kmr",
          "text": "rijandin nav; tê rijandin"
        },
        {
          "language": "pl",
          "text": "wlać; nalać"
        },
        {
          "language": "ro",
          "text": "a turna în"
        },
        {
          "language": "ru",
          "text": "наливать; влить"
        },
        {
          "language": "sq",
          "text": "të derdhësh brenda"
        },
        {
          "language": "tr",
          "text": "içine dökmek; doldurmak"
        }
      ],
      "examples": [
        {
          "baseText": "Könnten Sie mir bitte noch etwas Kaffee eingießen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن تصب لي قليلًا من القهوة من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن تکایە کەمێک قاوەی ترم بۆ تێبکەن؟"
            },
            {
              "language": "en",
              "text": "Could you please pour me a little more coffee?"
            },
            {
              "language": "fa",
              "text": "می‌توانید لطفاً کمی قهوه بیشتر برایم بریزید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji kerema xwe hinek qehweya din ji min re birijînin?"
            },
            {
              "language": "pl",
              "text": "Czy może mi Pan/Pani dolać trochę kawy?"
            },
            {
              "language": "ro",
              "text": "Ați putea, vă rog, să-mi mai turnați puțină cafea?"
            },
            {
              "language": "ru",
              "text": "Не могли бы вы налить мне еще немного кофе?"
            },
            {
              "language": "sq",
              "text": "A mund të më hidhni edhe pak kafe, ju lutem?"
            },
            {
              "language": "tr",
              "text": "Bana biraz daha kahve koyabilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Gießen Sie die Soße erst kurz vor dem Servieren ein.",
          "translations": [
            {
              "language": "ar",
              "text": "اسكب الصلصة فقط قبل التقديم مباشرة."
            },
            {
              "language": "ckb",
              "text": "سۆسەکە تەنها کەمێک پێش پێشکەشکردن تێبکەن."
            },
            {
              "language": "en",
              "text": "Pour in the sauce only shortly before serving."
            },
            {
              "language": "fa",
              "text": "سس را فقط کمی قبل از سرو کردن اضافه کنید."
            },
            {
              "language": "kmr",
              "text": "Sosê tenê hinek berî pêşkêşkirinê birijînin."
            },
            {
              "language": "pl",
              "text": "Sos należy wlać dopiero tuż przed podaniem."
            },
            {
              "language": "ro",
              "text": "Turnați sosul abia cu puțin înainte de servire."
            },
            {
              "language": "ru",
              "text": "Влейте соус только незадолго до подачи."
            },
            {
              "language": "sq",
              "text": "Hidheni salcën vetëm pak para servirjes."
            },
            {
              "language": "tr",
              "text": "Sosu servis etmeden hemen önce dökün."
            }
          ]
        }
      ]
    },
