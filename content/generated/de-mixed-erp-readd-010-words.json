      ],
      "examples": [
        {
          "baseText": "Das Ergebnis der Suche steht im ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "نتيجة البحث موجودة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "ئەنجامی گەڕانەکە لە سیستەمی ERPدا هەیە."
            },
            {
              "language": "en",
              "text": "The search result is in the ERP system."
            },
            {
              "language": "fa",
              "text": "نتیجه جستجو در سیستم ERP است."
            },
            {
              "language": "kmr",
              "text": "Encama lêgerînê di pergala ERP de ye."
            },
            {
              "language": "pl",
              "text": "Wynik wyszukiwania jest w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Rezultatul căutării este în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Результат поиска находится в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Rezultati i kërkimit është në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Arama sonucu ERP sisteminde."
            }
          ]
        },
        {
          "baseText": "Das Ergebnis ist besser als gestern.",
          "translations": [
            {
              "language": "ar",
              "text": "النتيجة أفضل من أمس."
            },
            {
              "language": "ckb",
              "text": "ئەنجامەکە لە دوێنێ باشترە."
            },
            {
              "language": "en",
              "text": "The result is better than yesterday."
            },
            {
              "language": "fa",
              "text": "نتیجه بهتر از دیروز است."
            },
            {
              "language": "kmr",
              "text": "Encam ji duh baştir e."
            },
            {
              "language": "pl",
              "text": "Wynik jest lepszy niż wczoraj."
            },
            {
              "language": "ro",
              "text": "Rezultatul este mai bun decât ieri."
            },
            {
              "language": "ru",
              "text": "Результат лучше, чем вчера."
            },
            {
              "language": "sq",
              "text": "Rezultati është më i mirë se dje."
            },
            {
              "language": "tr",
              "text": "Sonuç dünden daha iyi."
            }
          ]
        }
      ]
    },
