      ],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "im Einkauf arbeiten",
          "meaning": "to work in purchasing"
        },
        {
          "text": "den Einkauf planen",
          "meaning": "to plan purchasing"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "einkaufen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Einkäufer",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "شراء؛ قسم المشتريات"
        },
        {
          "language": "ckb",
          "text": "کڕین؛ بەشی کڕین"
        },
        {
          "language": "en",
          "text": "purchase; purchasing department"
        },
        {
          "language": "fa",
          "text": "خرید؛ بخش خرید"
        },
        {
          "language": "kmr",
          "text": "kirîn; beşa kirînê"
        },
        {
          "language": "pl",
          "text": "zakup; dział zakupów"
        },
        {
          "language": "ro",
          "text": "achiziție; departamentul de achiziții"
        },
        {
          "language": "ru",
          "text": "закупка; отдел закупок"
        },
        {
          "language": "sq",
          "text": "blerje; departamenti i blerjeve"
        },
        {
          "language": "tr",
          "text": "satın alma"
        }
      ],
      "examples": [
        {
          "baseText": "Der Einkauf bestellt die Ware über das ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "يقوم قسم المشتريات بطلب البضاعة عبر نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "بەشی کڕین کاڵاکە لە ڕێی سیستەمی ERP داوا دەکات."
            },
            {
              "language": "en",
              "text": "Purchasing orders the goods through the ERP system."
            },
            {
              "language": "fa",
              "text": "بخش خرید کالا را از طریق سیستم ERP سفارش می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Beşa kirînê malê bi pergala ERP sipariş dike."
            },
            {
              "language": "pl",
              "text": "Dział zakupów zamawia towar przez system ERP."
            },
            {
              "language": "ro",
              "text": "Departamentul de achiziții comandă marfa prin sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Отдел закупок заказывает товар через ERP-систему."
            },
            {
              "language": "sq",
              "text": "Departamenti i blerjeve porosit mallin përmes sistemit ERP."
            },
            {
              "language": "tr",
              "text": "Satın alma, malı ERP sistemi üzerinden sipariş eder."
            }
          ]
        },
        {
          "baseText": "Ich mache den Einkauf am Samstag.",
          "translations": [
            {
              "language": "ar",
              "text": "من يوم السبت أقوم بالتسوق."
            },
            {
              "language": "ckb",
              "text": "من شەممە کڕین دەکەم."
            },
            {
              "language": "en",
              "text": "I do the shopping on Saturday."
            },
            {
              "language": "fa",
              "text": "من خرید را شنبه انجام می‌دهم."
            },
            {
              "language": "kmr",
              "text": "Ez roja şemiyê kirînê dikim."
            },
            {
              "language": "pl",
              "text": "Robię zakupy w sobotę."
            },
            {
              "language": "ro",
              "text": "Fac cumpărăturile sâmbătă."
            },
            {
              "language": "ru",
              "text": "Я делаю покупки в субботу."
            },
            {
              "language": "sq",
              "text": "Unë bëj pazarin të shtunën."
            },
            {
              "language": "tr",
              "text": "Alışverişi cumartesi yapıyorum."
            }
          ]
        }
      ]
    },
