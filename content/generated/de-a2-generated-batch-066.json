      ],
      "examples": [
        {
          "baseText": "Mein Mitschüler hilft mir in Mathematik.",
          "translations": [
            {
              "language": "ar",
              "text": "زميلي في الصف يساعدني في الرياضيات."
            },
            {
              "language": "ckb",
              "text": "هاوپۆلە کوڕەکەم لە بیرکاری یارمەتیم دەدات."
            },
            {
              "language": "en",
              "text": "My classmate helps me with math."
            },
            {
              "language": "fa",
              "text": "همکلاسی‌ام در ریاضی به من کمک می‌کند."
            },
            {
              "language": "kmr",
              "text": "Hevalê min ê polê di matematîkê de alîkariya min dike."
            },
            {
              "language": "pl",
              "text": "Mój kolega z klasy pomaga mi z matematyką."
            },
            {
              "language": "ro",
              "text": "Colegul meu de clasă mă ajută la matematică."
            },
            {
              "language": "ru",
              "text": "Мой одноклассник помогает мне с математикой."
            },
            {
              "language": "sq",
              "text": "Shoku im i klasës më ndihmon në matematikë."
            },
            {
              "language": "tr",
              "text": "Sınıf arkadaşım matematikte bana yardım ediyor."
            }
          ]
        },
        {
          "baseText": "Der Mitschüler sitzt neben mir.",
          "translations": [
            {
              "language": "ar",
              "text": "زميل الصف يجلس بجانبي."
            },
            {
              "language": "ckb",
              "text": "هاوپۆلەکە لە تەنیشتم دادەنیشێت."
            },
            {
              "language": "en",
              "text": "The classmate sits next to me."
            },
            {
              "language": "fa",
              "text": "همکلاسی کنار من می‌نشیند."
            },
            {
              "language": "kmr",
              "text": "Hevalê polê li kêleka min rûdine."
            },
            {
              "language": "pl",
              "text": "Kolega z klasy siedzi obok mnie."
            },
            {
              "language": "ro",
              "text": "Colegul de clasă stă lângă mine."
            },
            {
              "language": "ru",
              "text": "Одноклассник сидит рядом со мной."
            },
            {
              "language": "sq",
              "text": "Shoku i klasës ulet pranë meje."
            },
            {
              "language": "tr",
              "text": "Sınıf arkadaşı yanımda oturuyor."
            }
          ]
        }
      ]
