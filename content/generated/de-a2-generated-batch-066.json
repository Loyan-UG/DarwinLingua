      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; kommt mit; ist mitgekommen"
      ],
      "collocations": [
        {
          "text": "zum Termin mitkommen",
          "meaning": "to come along to the appointment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kommen",
          "relationLabel": "verb",
          "note": "to come"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يأتي مع؛ يرافق"
        },
        {
          "language": "ckb",
          "text": "لەگەڵ دێت"
        },
        {
          "language": "en",
          "text": "to come along; to come with"
        },
        {
          "language": "fa",
          "text": "همراه آمدن"
        },
        {
          "language": "kmr",
          "text": "bi kesekî re hatin"
        },
        {
          "language": "pl",
          "text": "iść/przyjść z kimś"
        },
        {
          "language": "ro",
          "text": "a veni împreună"
        },
        {
          "language": "ru",
          "text": "пойти/прийти вместе"
        },
        {
          "language": "sq",
          "text": "vij bashkë"
        },
        {
          "language": "tr",
          "text": "birlikte gelmek"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du morgen zum Termin mitkommen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن تأتي معي إلى الموعد غداً؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت سبەی لەگەڵم بۆ کاتەکە بێیت؟"
            },
            {
              "language": "en",
              "text": "Can you come along to the appointment tomorrow?"
            },
            {
              "language": "fa",
              "text": "می‌توانی فردا همراه من به وقت ملاقات بیایی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî sibê bi min re bêyî hevdîtinê?"
            },
            {
              "language": "pl",
              "text": "Czy możesz jutro pójść ze mną na termin?"
            },
            {
              "language": "ro",
              "text": "Poți veni mâine cu mine la programare?"
            },
            {
              "language": "ru",
              "text": "Можешь завтра пойти со мной на встречу?"
            },
            {
              "language": "sq",
              "text": "A mund të vish nesër me mua në takim?"
            },
            {
              "language": "tr",
              "text": "Yarın randevuya benimle gelebilir misin?"
            }
          ]
        },
        {
          "baseText": "Meine Schwester kommt heute Abend mit.",
          "translations": [
            {
              "language": "ar",
              "text": "أختي ستأتي معنا هذا المساء."
            },
            {
              "language": "ckb",
              "text": "خوشکەکەم ئەم ئێوارەیە لەگەڵمان دێت."
            },
            {
              "language": "en",
              "text": "My sister is coming along this evening."
            },
            {
              "language": "fa",
              "text": "خواهرم امشب همراه ما می‌آید."
            },
            {
              "language": "kmr",
              "text": "Xwişka min îvarê bi me re tê."
            },
            {
              "language": "pl",
              "text": "Moja siostra idzie dziś wieczorem z nami."
            },
            {
              "language": "ro",
              "text": "Sora mea vine cu noi în seara aceasta."
            },
            {
              "language": "ru",
              "text": "Моя сестра сегодня вечером пойдёт с нами."
            },
            {
              "language": "sq",
              "text": "Motra ime vjen me ne sonte."
            },
            {
              "language": "tr",
              "text": "Kız kardeşim bu akşam bizimle geliyor."
            }
          ]
        }
      ]
    },
