      "meanings": [
        {
          "language": "ar",
          "text": "يأخذ معه"
        },
        {
          "language": "ckb",
          "text": "لەگەڵ خۆی دەبات"
        },
        {
          "language": "en",
          "text": "to take along; to bring with"
        },
        {
          "language": "fa",
          "text": "همراه بردن"
        },
        {
          "language": "kmr",
          "text": "bi xwe re birin"
        },
        {
          "language": "pl",
          "text": "zabrać ze sobą"
        },
        {
          "language": "ro",
          "text": "a lua cu sine"
        },
        {
          "language": "ru",
          "text": "взять с собой"
        },
        {
          "language": "sq",
          "text": "marr me vete"
        },
        {
          "language": "tr",
          "text": "yanına almak; götürmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nimm bitte deinen Ausweis mit.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك خذ هويتك معك."
            },
            {
              "language": "ckb",
              "text": "تکایە ناسنامەکەت لەگەڵ خۆت ببە."
            },
            {
              "language": "en",
              "text": "Please take your ID with you."
            },
            {
              "language": "fa",
              "text": "لطفاً کارت شناسایی‌ات را همراه ببر."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe nasnameya xwe bi xwe re bibe."
            },
            {
              "language": "pl",
              "text": "Weź proszę ze sobą dokument tożsamości."
            },
            {
              "language": "ro",
              "text": "Te rog să iei actul de identitate cu tine."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, возьми с собой удостоверение."
            },
            {
              "language": "sq",
              "text": "Të lutem merre dokumentin e identitetit me vete."
            },
            {
              "language": "tr",
              "text": "Lütfen kimliğini yanına al."
            }
          ]
        },
        {
          "baseText": "Wir nehmen Wasser für die Fahrt mit.",
          "translations": [
            {
              "language": "ar",
              "text": "نأخذ ماءً معنا للرحلة."
            },
            {
              "language": "ckb",
              "text": "ئاو بۆ گەشتەکە لەگەڵ خۆمان دەبەین."
            },
            {
              "language": "en",
              "text": "We take water with us for the trip."
            },
            {
              "language": "fa",
              "text": "برای مسیر آب همراه می‌بریم."
            },
            {
              "language": "kmr",
              "text": "Em ji bo rêwiyê av bi xwe re dibin."
            },
            {
              "language": "pl",
              "text": "Zabieramy wodę na podróż."
            },
            {
              "language": "ro",
              "text": "Luăm apă cu noi pentru drum."
            },
            {
              "language": "ru",
              "text": "Мы берём воду с собой в дорогу."
            },
            {
              "language": "sq",
              "text": "Marrim ujë me vete për udhëtimin."
            },
            {
              "language": "tr",
              "text": "Yolculuk için yanımıza su alıyoruz."
            }
          ]
        }
      ]
    },
