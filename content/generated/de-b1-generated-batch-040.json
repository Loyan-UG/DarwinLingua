  "entries": [
    {
      "word": "darstellen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "darstellen",
      "pronunciationIpa": null,
      "syllableBreak": "dar-stel-len",
      "topics": [
        "business-communication",
        "data-and-reporting",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "documents",
        "data",
        "administration"
      ],
      "grammarNotes": [
        "regular separable verb: stellt dar, stellte dar, hat dargestellt"
      ],
      "collocations": [
        {
          "text": "Daten in einer Grafik darstellen",
          "meaning": "to present data in a chart"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Darstellung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعرض؛ يبيّن؛ يمثل"
        },
        {
          "language": "ckb",
          "text": "پیشاندان؛ ڕوونکردنەوە؛ نوێنەرایەتی کردن"
        },
        {
          "language": "en",
          "text": "to present; to show; to represent"
        },
        {
          "language": "fa",
          "text": "نمایش دادن؛ نشان دادن؛ بیان کردن"
        },
        {
          "language": "kmr",
          "text": "nîşan dan; pêşkêş kirin"
        },
        {
          "language": "pl",
          "text": "przedstawiać; pokazywać"
        },
        {
          "language": "ro",
          "text": "a prezenta; a reprezenta"
        },
        {
          "language": "ru",
          "text": "представлять; показывать"
        },
        {
          "language": "sq",
          "text": "të paraqesësh; të përfaqësosh"
        },
        {
          "language": "tr",
          "text": "göstermek; sunmak; temsil etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie die Ergebnisse bitte in einer einfachen Tabelle darstellen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك عرض النتائج من فضلك في جدول بسيط؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن تکایە ئەنجامەکان لە خشتەیەکی سادەدا پیشان بدەن؟"
            },
            {
              "language": "en",
              "text": "Can you please present the results in a simple table?"
            },
            {
              "language": "fa",
              "text": "می‌توانید لطفاً نتایج را در یک جدول ساده نمایش دهید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin encaman di tabloyeke sade de nîşan bidin?"
            },
            {
              "language": "pl",
              "text": "Czy mogą Państwo przedstawić wyniki w prostej tabeli?"
            },
            {
              "language": "ro",
              "text": "Puteți, vă rog, să prezentați rezultatele într-un tabel simplu?"
            },
            {
              "language": "ru",
              "text": "Можете, пожалуйста, представить результаты в простой таблице?"
            },
            {
              "language": "sq",
              "text": "A mund t’i paraqisni rezultatet në një tabelë të thjeshtë?"
            },
            {
              "language": "tr",
              "text": "Sonuçları lütfen basit bir tabloda gösterebilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Der Film stellt das Leben in einer kleinen Stadt sehr realistisch dar.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض الفيلم الحياة في مدينة صغيرة بطريقة واقعية جدًا."
            },
            {
              "language": "ckb",
              "text": "فیلمەکە ژیان لە شارۆچکەیەکدا زۆر بە ڕاستی پیشان دەدات."
            },
            {
              "language": "en",
              "text": "The film portrays life in a small town very realistically."
            },
            {
              "language": "fa",
              "text": "فیلم زندگی در یک شهر کوچک را بسیار واقع‌گرایانه نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Fîlm jiyana li bajarekî biçûk pir rastîn nîşan dide."
            },
            {
              "language": "pl",
              "text": "Film bardzo realistycznie przedstawia życie w małym mieście."
            },
            {
              "language": "ro",
              "text": "Filmul prezintă foarte realist viața într-un oraș mic."
            },
            {
              "language": "ru",
              "text": "Фильм очень реалистично показывает жизнь в маленьком городе."
            },
            {
              "language": "sq",
              "text": "Filmi e paraqet shumë realisht jetën në një qytet të vogël."
            },
            {
              "language": "tr",
              "text": "Film küçük bir şehirdeki yaşamı çok gerçekçi gösteriyor."
            }
          ]
        }
      ]
    },
