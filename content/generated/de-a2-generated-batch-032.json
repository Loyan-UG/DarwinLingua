      "usageLabels": [
        "spoken",
        "polite",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb; reflexive in apologies: sich entschuldigen"
      ],
      "collocations": [
        {
          "text": "sich entschuldigen",
          "meaning": "to apologize"
        },
        {
          "text": "jemanden entschuldigen",
          "meaning": "to excuse someone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Entschuldigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعتذر؛ يعفو عن"
        },
        {
          "language": "ckb",
          "text": "داوای لێبووردن کردن؛ ببورە کردن"
        },
        {
          "language": "en",
          "text": "to apologize; to excuse"
        },
        {
          "language": "fa",
          "text": "عذرخواهی کردن؛ بخشیدن/معذور دانستن"
        },
        {
          "language": "kmr",
          "text": "lêborîn xwestin; bibore kirin"
        },
        {
          "language": "pl",
          "text": "przeprosić; usprawiedliwić"
        },
        {
          "language": "ro",
          "text": "a-și cere scuze; a scuza"
        },
        {
          "language": "ru",
          "text": "извиняться; извинять"
        },
        {
          "language": "sq",
          "text": "të kërkosh falje; të justifikosh"
        },
        {
          "language": "tr",
          "text": "özür dilemek; affetmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte mich für die Verspätung entschuldigen.",
          "translations": [
            {
              "language": "ar",
              "text": "أود أن أعتذر عن التأخير."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت بۆ دواكەوتنەکە داوای لێبووردن بکەم."
            },
            {
              "language": "en",
              "text": "I would like to apologize for the delay."
            },
            {
              "language": "fa",
              "text": "می‌خواهم بابت تأخیر عذرخواهی کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim ji bo derengmayînê lêborînê bixwazim."
            },
            {
              "language": "pl",
              "text": "Chciałbym przeprosić za spóźnienie."
            },
            {
              "language": "ro",
              "text": "Aș dori să îmi cer scuze pentru întârziere."
            },
            {
              "language": "ru",
              "text": "Я хочу извиниться за опоздание."
            },
            {
              "language": "sq",
              "text": "Dua të kërkoj falje për vonesën."
            },
            {
              "language": "tr",
              "text": "Gecikme için özür dilemek istiyorum."
            }
          ]
        },
        {
          "baseText": "Entschuldigen Sie bitte, ist dieser Platz frei?",
          "translations": [
            {
              "language": "ar",
              "text": "عذراً، هل هذا المكان شاغر؟"
            },
            {
              "language": "ckb",
              "text": "ببورە، ئەم شوێنە بەتاڵە؟"
            },
            {
              "language": "en",
              "text": "Excuse me, is this seat free?"
            },
            {
              "language": "fa",
              "text": "ببخشید، این جا خالی است؟"
            },
            {
              "language": "kmr",
              "text": "Bibore, ev cih vala ye?"
            },
            {
              "language": "pl",
              "text": "Przepraszam, czy to miejsce jest wolne?"
            },
            {
              "language": "ro",
              "text": "Scuzați-mă, este liber acest loc?"
            },
            {
              "language": "ru",
              "text": "Извините, это место свободно?"
            },
            {
              "language": "sq",
              "text": "Më falni, a është i lirë ky vend?"
            },
            {
              "language": "tr",
              "text": "Affedersiniz, bu yer boş mu?"
            }
          ]
        }
      ]
    },
