        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دورة لغة إنجليزية"
        },
        {
          "language": "ckb",
          "text": "کۆرسی ئینگلیزی"
        },
        {
          "language": "en",
          "text": "English course"
        },
        {
          "language": "fa",
          "text": "کلاس انگلیسی؛ دوره انگلیسی"
        },
        {
          "language": "kmr",
          "text": "kursa Îngilîzî"
        },
        {
          "language": "pl",
          "text": "kurs angielskiego"
        },
        {
          "language": "ro",
          "text": "curs de engleză"
        },
        {
          "language": "ru",
          "text": "курс английского языка"
        },
        {
          "language": "sq",
          "text": "kurs anglishteje"
        },
        {
          "language": "tr",
          "text": "İngilizce kursu"
        }
      ],
      "examples": [
        {
          "baseText": "Mein Englischkurs beginnt am Montag.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدأ دورة الإنجليزية الخاصة بي يوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "کۆرسی ئینگلیزییەکەم دووشەممە دەست پێدەکات."
            },
            {
              "language": "en",
              "text": "My English course starts on Monday."
            },
            {
              "language": "fa",
              "text": "کلاس انگلیسی من دوشنبه شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kursa min a Îngilîzî duşemê dest pê dike."
            },
            {
              "language": "pl",
              "text": "Mój kurs angielskiego zaczyna się w poniedziałek."
            },
            {
              "language": "ro",
              "text": "Cursul meu de engleză începe luni."
            },
            {
              "language": "ru",
              "text": "Мой курс английского начинается в понедельник."
            },
            {
              "language": "sq",
              "text": "Kursi im i anglishtes fillon të hënën."
            },
            {
              "language": "tr",
              "text": "İngilizce kursum pazartesi başlıyor."
            }
          ]
        },
        {
          "baseText": "Für die Arbeit brauche ich einen Englischkurs.",
          "translations": [
            {
              "language": "ar",
              "text": "أحتاج إلى دورة إنجليزية من أجل العمل."
            },
            {
              "language": "ckb",
              "text": "بۆ کار پێویستم بە کۆرسی ئینگلیزی هەیە."
            },
            {
              "language": "en",
              "text": "I need an English course for work."
            },
            {
              "language": "fa",
              "text": "برای کار به کلاس انگلیسی نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ji bo kar ez hewceyê kursa Îngilîzî me."
            },
            {
              "language": "pl",
              "text": "Do pracy potrzebuję kursu angielskiego."
            },
            {
              "language": "ro",
              "text": "Pentru muncă am nevoie de un curs de engleză."
            },
            {
              "language": "ru",
              "text": "Для работы мне нужен курс английского."
            },
            {
              "language": "sq",
              "text": "Për punë më duhet një kurs anglishteje."
            },
            {
              "language": "tr",
              "text": "İş için İngilizce kursuna ihtiyacım var."
            }
          ]
        }
      ]
    },
