  "entries": [
    {
      "word": "die Entsagung",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Entsagungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ent-sa-gung",
      "topics": [
        "social-and-relationships",
        "culture-and-media",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; act of renunciation or self-denial"
      ],
      "collocations": [
        {
          "text": "freiwillige Entsagung",
          "meaning": "voluntary renunciation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "entsagen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تخلٍّ؛ زهد؛ تنازل"
        },
        {
          "language": "ckb",
          "text": "وازهێنان؛ خۆبەدوورگرتن؛ خۆبەخشینەوە"
        },
        {
          "language": "en",
          "text": "renunciation; self-denial"
        },
        {
          "language": "fa",
          "text": "چشم‌پوشی؛ ترک خواسته؛ ریاضت"
        },
        {
          "language": "kmr",
          "text": "devjêberdan; xweparastin; riyazet"
        },
        {
          "language": "pl",
          "text": "wyrzeczenie; rezygnacja"
        },
        {
          "language": "ro",
          "text": "renunțare; abnegație"
        },
        {
          "language": "ru",
          "text": "отречение; самоотречение"
        },
        {
          "language": "sq",
          "text": "heqje dorë; vetëmohim"
        },
        {
          "language": "tr",
          "text": "vazgeçiş; feragat; özveri"
        }
      ],
      "examples": [
        {
          "baseText": "Die Entsagung persönlicher Vorteile war die Voraussetzung für glaubwürdige Führung.",
          "translations": [
            {
              "language": "ar",
              "text": "كان التخلي عن المزايا الشخصية شرطاً لقيادة ذات مصداقية."
            },
            {
              "language": "ckb",
              "text": "وازهێنان لە سوودە کەسییەکان مەرجی سەرکردایەتیی متمانەپێکراو بوو."
            },
            {
              "language": "en",
              "text": "Renouncing personal advantages was the prerequisite for credible leadership."
            },
            {
              "language": "fa",
              "text": "چشم‌پوشی از مزایای شخصی شرط رهبری قابل اعتماد بود."
            },
            {
              "language": "kmr",
              "text": "Devjêberdana berjewendiyên kesane merca rêveberiya bawerbar bû."
            },
            {
              "language": "pl",
              "text": "Wyrzeczenie się osobistych korzyści było warunkiem wiarygodnego przywództwa."
            },
            {
              "language": "ro",
              "text": "Renunțarea la avantaje personale era condiția unei conduceri credibile."
            },
            {
              "language": "ru",
              "text": "Отказ от личных преимуществ был условием убедительного лидерства."
            },
            {
              "language": "sq",
              "text": "Heqja dorë nga përfitimet personale ishte parakusht për udhëheqje të besueshme."
            },
            {
              "language": "tr",
              "text": "Kişisel avantajlardan feragat etmek güvenilir liderliğin ön koşuluydu."
            }
          ]
        },
        {
          "baseText": "Im Gedicht erscheint Entsagung nicht als Niederlage, sondern als bewusste Form der Freiheit.",
          "translations": [
            {
              "language": "ar",
              "text": "في القصيدة لا يظهر التخلي كهزيمة، بل كشكل واعٍ من الحرية."
            },
            {
              "language": "ckb",
              "text": "لە شیعرەکەدا وازهێنان وەک شکست دەرناکەوێت، بەڵکو وەک شێوەیەکی ئاگادارانەی ئازادی."
            },
            {
              "language": "en",
              "text": "In the poem, renunciation appears not as defeat but as a conscious form of freedom."
            },
            {
              "language": "fa",
              "text": "در شعر، چشم‌پوشی نه شکست، بلکه شکلی آگاهانه از آزادی است."
            },
            {
              "language": "kmr",
              "text": "Di helbestê de devjêberdan ne wek têkçûn, lê wek awayekî zanebûnî yê azadiyê xuya dike."
            },
            {
              "language": "pl",
              "text": "W wierszu wyrzeczenie jawi się nie jako porażka, lecz jako świadoma forma wolności."
            },
            {
              "language": "ro",
              "text": "În poem, renunțarea apare nu ca înfrângere, ci ca formă conștientă a libertății."
            },
            {
              "language": "ru",
              "text": "В стихотворении отречение предстает не поражением, а осознанной формой свободы."
            },
            {
              "language": "sq",
              "text": "Në poezi, heqja dorë nuk shfaqet si humbje, por si formë e vetëdijshme lirie."
            },
            {
              "language": "tr",
              "text": "Şiirde feragat yenilgi olarak değil, özgürlüğün bilinçli bir biçimi olarak görünür."
            }
          ]
        }
      ]
    },
    {
      "word": "entwachsen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entwachsen",
      "pronunciationIpa": null,
      "syllableBreak": "ent-wach-sen",
      "topics": [
        "management-and-leadership",
        "social-and-relationships",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "intransitive verb; entwächst, entwuchs, ist entwachsen; often with dative"
      ],
      "collocations": [
        {
          "text": "einer Rolle entwachsen",
          "meaning": "to outgrow a role"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "wachsen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتجاوز؛ ينمو خارج إطار؛ يتخطى مرحلة"
        },
        {
          "language": "ckb",
          "text": "لە قۆناغێک گەورەتر ببێت؛ تێپەڕێت"
        },
        {
          "language": "en",
          "text": "to outgrow; to develop beyond"
        },
        {
          "language": "fa",
          "text": "فراتر رفتن از؛ از مرحله‌ای گذشتن"
        },
        {
          "language": "kmr",
          "text": "ji tiştekî mezin bûn; derbas bûn"
        },
        {
          "language": "pl",
          "text": "wyrosnąć z; przerosnąć"
        },
        {
          "language": "ro",
          "text": "a depăși; a crește dincolo de"
        },
        {
          "language": "ru",
          "text": "перерастать; выходить за рамки"
        },
        {
          "language": "sq",
          "text": "ta tejkalosh; të rritesh përtej"
        },
        {
          "language": "tr",
          "text": "aşmak; dışına büyümek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Start-up war der improvisierten Arbeitsweise längst entwachsen.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت الشركة الناشئة قد تجاوزت منذ زمن أسلوب العمل المرتجل."
            },
            {
              "language": "ckb",
              "text": "ستارتاپەکە زۆر پێش ئێستا لە شێوازی کاری کاتی و نائامادە گەورەتر ببوو."
            },
            {
              "language": "en",
              "text": "The start-up had long outgrown its improvised way of working."
            },
            {
              "language": "fa",
              "text": "استارتاپ مدت‌ها بود از شیوه کاری بداهه و موقتی فراتر رفته بود."
            },
            {
              "language": "kmr",
              "text": "Start-up demek dirêj bû ji şêwaza xebata improvîzekirî mezin bûbû."
            },
            {
              "language": "pl",
              "text": "Start-up już dawno wyrósł z improwizowanego sposobu pracy."
            },
            {
              "language": "ro",
              "text": "Start-upul depășise de mult modul de lucru improvizat."
            },
            {
              "language": "ru",
              "text": "Стартап давно перерос импровизированный стиль работы."
            },
            {
              "language": "sq",
              "text": "Start-up-i e kishte tejkaluar prej kohësh mënyrën e improvizuar të punës."
            },
            {
              "language": "tr",
              "text": "Start-up doğaçlama çalışma biçimini çoktan aşmıştı."
            }
          ]
        },
        {
          "baseText": "Sie war den Erwartungen ihrer Herkunftsfamilie entwachsen, ohne die Verbindung zu ihr abzubrechen.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت قد تجاوزت توقعات أسرتها الأصلية من دون قطع الصلة بها."
            },
            {
              "language": "ckb",
              "text": "ئەو لە چاوەڕوانییەکانی خێزانی سەرەتایی خۆی تێپەڕیبوو، بەبێ ئەوەی پەیوەندییەکە بپچڕێنێت."
            },
            {
              "language": "en",
              "text": "She had outgrown her family of origin’s expectations without breaking ties with them."
            },
            {
              "language": "fa",
              "text": "او از انتظارهای خانواده اصلی‌اش فراتر رفته بود، بی‌آنکه رابطه‌اش را قطع کند."
            },
            {
              "language": "kmr",
              "text": "Ew ji hêviyên malbata xwe ya bingehîn mezin bûbû bê ku têkiliyê qut bike."
            },
            {
              "language": "pl",
              "text": "Wyrosła z oczekiwań swojej rodziny pochodzenia, nie zrywając z nią więzi."
            },
            {
              "language": "ro",
              "text": "Depășise așteptările familiei de origine fără să rupă legătura cu ea."
            },
            {
              "language": "ru",
              "text": "Она переросла ожидания своей родной семьи, не разрывая с ней связь."
            },
            {
              "language": "sq",
              "text": "Ajo i kishte tejkaluar pritjet e familjes së origjinës pa ndërprerë lidhjen me të."
            },
            {
              "language": "tr",
              "text": "Köken ailesinin beklentilerini aşmıştı, onlarla bağını koparmadan."
            }
          ]
        }
      ]
    },
    {
      "word": "entwaffnen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entwaffnen",
      "pronunciationIpa": null,
      "syllableBreak": "ent-waff-nen",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "transitive verb; literal disarm or figurative disarm through charm/honesty"
      ],
      "collocations": [
        {
          "text": "eine Kritik entwaffnen",
          "meaning": "to disarm a criticism"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Waffe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينزع السلاح؛ يجرّد من الحدة أو المقاومة"
        },
        {
          "language": "ckb",
          "text": "چەک لێبسەنێت؛ تووندی یان بەرگری کەم بکاتەوە"
        },
        {
          "language": "en",
          "text": "to disarm; to take the force out of"
        },
        {
          "language": "fa",
          "text": "خلع سلاح کردن؛ بی‌اثر کردن مقاومت یا تندی"
        },
        {
          "language": "kmr",
          "text": "çek jê standin; tundî kêm kirin"
        },
        {
          "language": "pl",
          "text": "rozbroić; odebrać siłę argumentowi"
        },
        {
          "language": "ro",
          "text": "a dezarma; a neutraliza tensiunea"
        },
        {
          "language": "ru",
          "text": "разоружать; обезоруживать"
        },
        {
          "language": "sq",
          "text": "të çarmatosësh; të zbutësh kundërshtimin"
        },
        {
          "language": "tr",
          "text": "silahsızlandırmak; etkisizleştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ihre offene Fehleranalyse entwaffnete einen Teil der Kritik im Kundengespräch.",
          "translations": [
            {
              "language": "ar",
              "text": "حلّلها الصريح للأخطاء جرّد جزءاً من النقد في حديث العميل من حدته."
            },
            {
              "language": "ckb",
              "text": "شیکردنەوەی کراوەی هەڵەکان بەشێک لە ڕەخنەکەی لە گفتوگۆی کڕیاردا بێهێز کرد."
            },
            {
              "language": "en",
              "text": "Her open analysis of the mistakes disarmed part of the criticism in the customer conversation."
            },
            {
              "language": "fa",
              "text": "تحلیل صریح او از خطاها بخشی از نقد را در گفت‌وگو با مشتری بی‌اثر کرد."
            },
