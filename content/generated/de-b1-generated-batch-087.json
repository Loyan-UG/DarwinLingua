  "entries": [
    {
      "word": "lebendig",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "le-ben-dig",
      "topics": [
        "everyday-life",
        "culture-and-media",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes something lively, vivid, or alive"
      ],
      "collocations": [
        {
          "text": "lebendig wirken",
          "meaning": "to seem lively"
        },
        {
          "text": "eine lebendige Diskussion",
          "meaning": "a lively discussion"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "leben",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "das Leben",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "حي؛ مفعم بالحيوية"
        },
        {
          "language": "ckb",
          "text": "زیندوو؛ پڕ ژیان"
        },
        {
          "language": "en",
          "text": "lively; vivid; alive"
        },
        {
          "language": "fa",
          "text": "زنده؛ پرجنب‌وجوش"
        },
        {
          "language": "kmr",
          "text": "zindî; tijî jiyan"
        },
        {
          "language": "pl",
          "text": "żywy; pełen życia"
        },
        {
          "language": "ro",
          "text": "viu; plin de viață"
        },
        {
          "language": "ru",
          "text": "живой; оживлённый"
        },
        {
          "language": "sq",
          "text": "i gjallë; plot jetë"
        },
        {
          "language": "tr",
          "text": "canlı; hayat dolu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Präsentation wirkt lebendig, weil viele Beispiele aus dem Arbeitsalltag vorkommen.",
          "translations": [
            {
              "language": "ar",
              "text": "يبدو العرض حيوياً لأن فيه أمثلة كثيرة من الحياة العملية اليومية."
            },
            {
              "language": "ckb",
              "text": "پێشکەشکارییەکە زیندوو دیارە، چونکە نموونەی زۆر لە ژیانی کاری ڕۆژانەی تێدایە."
            },
            {
              "language": "en",
              "text": "The presentation feels lively because it includes many examples from everyday work."
            },
            {
              "language": "fa",
              "text": "ارائه زنده و جذاب به نظر می‌رسد، چون مثال‌های زیادی از کار روزمره دارد."
            },
            {
              "language": "kmr",
              "text": "Pêşkêşkirin zindî xuya dike, ji ber ku gelek nimûneyên ji jiyana karê rojane tê de hene."
            },
            {
              "language": "pl",
              "text": "Prezentacja wydaje się żywa, ponieważ zawiera wiele przykładów z codziennej pracy."
            },
            {
              "language": "ro",
              "text": "Prezentarea pare vie, deoarece include multe exemple din munca de zi cu zi."
            },
            {
              "language": "ru",
              "text": "Презентация выглядит живой, потому что в ней много примеров из рабочей повседневности."
            },
            {
              "language": "sq",
              "text": "Prezantimi duket i gjallë sepse përmban shumë shembuj nga puna e përditshme."
            },
            {
              "language": "tr",
              "text": "Sunum, günlük iş hayatından birçok örnek içerdiği için canlı görünüyor."
            }
          ]
        },
        {
          "baseText": "Der Marktplatz ist am Samstag besonders lebendig.",
          "translations": [
            {
              "language": "ar",
              "text": "ساحة السوق تكون يوم السبت مفعمة بالحيوية بشكل خاص."
            },
            {
              "language": "ckb",
              "text": "بازاڕەکە لە ڕۆژی شەممەدا بە تایبەتی پڕ ژیانە."
            },
            {
              "language": "en",
              "text": "The market square is especially lively on Saturdays."
            },
            {
              "language": "fa",
              "text": "میدان بازار روز شنبه به‌ویژه پرجنب‌وجوش است."
            },
            {
              "language": "kmr",
              "text": "Qada sûkê roja şemiyê bi taybetî gelek zindî ye."
            },
            {
              "language": "pl",
              "text": "Rynek jest w sobotę szczególnie żywy."
            },
            {
              "language": "ro",
              "text": "Piața este deosebit de animată sâmbăta."
            },
            {
              "language": "ru",
              "text": "Рыночная площадь по субботам особенно оживлённая."
            },
            {
              "language": "sq",
              "text": "Sheshi i tregut është veçanërisht i gjallë të shtunave."
            },
            {
              "language": "tr",
              "text": "Pazar meydanı cumartesi günleri özellikle canlıdır."
            }
          ]
        }
      ]
    },
    {
