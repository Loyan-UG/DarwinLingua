      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تكاليف المعيشة"
        },
        {
          "language": "ckb",
          "text": "تێچووی ژیان"
        },
        {
          "language": "en",
          "text": "cost of living; living expenses"
        },
        {
          "language": "fa",
          "text": "هزینه‌های زندگی؛ مخارج زندگی"
        },
        {
          "language": "kmr",
          "text": "lêçûnên jiyanê"
        },
        {
          "language": "pl",
          "text": "koszty utrzymania"
        },
        {
          "language": "ro",
          "text": "costuri de trai"
        },
        {
          "language": "ru",
          "text": "стоимость жизни; расходы на жизнь"
        },
        {
          "language": "sq",
          "text": "kosto të jetesës"
        },
        {
          "language": "tr",
          "text": "yaşam giderleri; geçim masrafları"
        }
      ],
      "examples": [
        {
          "baseText": "Die Lebenshaltungskosten sind in der Stadt deutlich höher als auf dem Land.",
          "translations": [
            {
              "language": "ar",
              "text": "تكاليف المعيشة في المدينة أعلى بكثير من الريف."
            },
            {
              "language": "ckb",
              "text": "تێچووی ژیان لە شاردا بە ڕوونی لە گوند بەرزترە."
            },
            {
              "language": "en",
              "text": "The cost of living in the city is significantly higher than in the countryside."
            },
            {
              "language": "fa",
              "text": "هزینه‌های زندگی در شهر به‌طور قابل توجهی بیشتر از روستا است."
            },
            {
              "language": "kmr",
              "text": "Lêçûnên jiyanê li bajêr ji gundan bi awayekî berbiçav bilindtir in."
            },
            {
              "language": "pl",
              "text": "Koszty utrzymania w mieście są wyraźnie wyższe niż na wsi."
            },
            {
              "language": "ro",
              "text": "Costurile de trai în oraș sunt semnificativ mai mari decât la țară."
            },
            {
              "language": "ru",
              "text": "Стоимость жизни в городе заметно выше, чем в сельской местности."
            },
            {
              "language": "sq",
