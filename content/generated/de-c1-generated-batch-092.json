        "social-and-relationships",
        "business-communication"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "adjective; means mutual or reciprocal"
      ],
      "collocations": [
        {
          "text": "eine reziproke Beziehung",
          "meaning": "a reciprocal relationship"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Reziprozität",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "متبادل؛ تبادلي"
        },
        {
          "language": "ckb",
          "text": "دوولایەنە؛ ئاڵوگۆڕی"
        },
        {
          "language": "en",
          "text": "reciprocal; mutual"
        },
        {
          "language": "fa",
          "text": "متقابل؛ دوسویه"
        },
        {
          "language": "kmr",
          "text": "dualî; hevber"
        },
        {
          "language": "pl",
          "text": "wzajemny; reziproczny"
        },
        {
          "language": "ro",
          "text": "reciproc; mutual"
        },
        {
          "language": "ru",
          "text": "взаимный; реципрокный"
        },
        {
          "language": "sq",
          "text": "reciprok; i ndërsjellë"
        },
        {
          "language": "tr",
          "text": "karşılıklı; resiprok"
        }
      ],
      "examples": [
        {
          "baseText": "Vertrauen entsteht oft durch reziproke Erfahrungen, nicht durch formale Regeln allein.",
          "translations": [
            {
              "language": "ar",
              "text": "تنشأ الثقة غالباً من تجارب متبادلة، لا من القواعد الرسمية وحدها."
            },
            {
              "language": "ckb",
              "text": "متمانە زۆرجار لە ئەزموونی دوولایەنەوە دروست دەبێت، نە تەنها لە یاسای فەرمی."
            },
            {
              "language": "en",
              "text": "Trust often arises through reciprocal experiences, not through formal rules alone."
            },
            {
              "language": "fa",
              "text": "اعتماد اغلب از تجربه‌های متقابل شکل می‌گیرد، نه فقط از قواعد رسمی."
            },
            {
              "language": "kmr",
              "text": "Bawerî gelek caran bi ezmûnên dualî çêdibe, ne tenê bi rêzikên fermî."
            },
            {
              "language": "pl",
              "text": "Zaufanie często powstaje dzięki wzajemnym doświadczeniom, a nie samym regułom formalnym."
            },
            {
              "language": "ro",
              "text": "Încrederea apare adesea prin experiențe reciproce, nu doar prin reguli formale."
            },
            {
              "language": "ru",
