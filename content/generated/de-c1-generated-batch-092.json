    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Rezeptionsgeschichte",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Rezeptionsgeschichten",
      "infinitive": null,
      "syllableBreak": "Re-zepti-ons-ge-schich-te",
      "topics": [
        "culture-and-media",
        "advanced-analysis",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "die Rezeptionsgeschichte eines Romans untersuchen",
          "meaning": "to examine the reception history of a novel"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Rezeption",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Geschichte",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تاريخ التلقي؛ تاريخ استقبال عمل ما"
        },
        {
          "language": "ckb",
          "text": "مێژووی وەرگرتن؛ مێژووی پێشوازی لە کارێک"
        },
        {
          "language": "en",
          "text": "reception history"
        },
        {
          "language": "fa",
          "text": "تاریخ دریافت/پذیرش اثر"
        },
        {
          "language": "kmr",
          "text": "dîroka wergirtinê"
        },
        {
          "language": "pl",
          "text": "historia recepcji"
        },
        {
          "language": "ro",
          "text": "istorie a receptării"
        },
        {
          "language": "ru",
          "text": "история рецепции; история восприятия"
        },
        {
          "language": "sq",
          "text": "histori e receptimit"
        },
        {
          "language": "tr",
          "text": "alımlama tarihi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rezeptionsgeschichte des Romans zeigt, wie stark sich moralische Maßstäbe verändert haben.",
          "translations": [
            {
              "language": "ar",
              "text": "يُظهر تاريخ تلقي الرواية مدى تغير المعايير الأخلاقية."
            },
            {
              "language": "ckb",
              "text": "مێژووی وەرگرتنی ڕۆمانەکە پیشان دەدات پێوەرە ئەخلاقییەکان چەندە گۆڕاون."
            },
            {
              "language": "en",
              "text": "The reception history of the novel shows how much moral standards have changed."
            },
            {
              "language": "fa",
              "text": "تاریخ دریافت رمان نشان می‌دهد معیارهای اخلاقی چقدر تغییر کرده‌اند."
            },
            {
              "language": "kmr",
              "text": "Dîroka wergirtina romanê nîşan dide ku pîvanên exlaqî çiqas guherîne."
            },
            {
              "language": "pl",
              "text": "Historia recepcji powieści pokazuje, jak bardzo zmieniły się normy moralne."
            },
            {
              "language": "ro",
              "text": "Istoria receptării romanului arată cât de mult s-au schimbat standardele morale."
            },
            {
              "language": "ru",
              "text": "История восприятия романа показывает, насколько изменились моральные нормы."
            },
            {
              "language": "sq",
              "text": "Historia e receptimit të romanit tregon sa shumë kanë ndryshuar standardet morale."
            },
            {
              "language": "tr",
              "text": "Romanın alımlama tarihi ahlaki ölçütlerin ne kadar değiştiğini gösterir."
            }
          ]
        },
        {
          "baseText": "Für die Ausstellung wurde die Rezeptionsgeschichte des Gemäldes in verschiedenen Ländern nachgezeichnet.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل المعرض تم تتبع تاريخ تلقي اللوحة في بلدان مختلفة."
            },
            {
              "language": "ckb",
              "text": "بۆ پێشانگاکە مێژووی وەرگرتنی وێنەکە لە وڵاتانی جیاوازدا دووبارە شوێنکەوت کرا."
            },
            {
              "language": "en",
              "text": "For the exhibition, the reception history of the painting was traced in different countries."
            },
            {
              "language": "fa",
              "text": "برای نمایشگاه، تاریخ دریافت نقاشی در کشورهای مختلف بازسازی شد."
            },
            {
              "language": "kmr",
              "text": "Ji bo pêşangehê dîroka wergirtina wêneyê li welatên cuda hate şopandin."
            },
            {
              "language": "pl",
              "text": "Na potrzeby wystawy odtworzono historię recepcji obrazu w różnych krajach."
            },
            {
              "language": "ro",
              "text": "Pentru expoziție a fost reconstituită istoria receptării tabloului în diferite țări."
            },
            {
              "language": "ru",
              "text": "Для выставки проследили историю восприятия картины в разных странах."
            },
            {
              "language": "sq",
              "text": "Për ekspozitën u gjurmua historia e receptimit të pikturës në vende të ndryshme."
            },
            {
              "language": "tr",
              "text": "Sergi için tablonun farklı ülkelerdeki alımlama tarihi izleriyle ortaya kondu."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Rezession",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Rezessionen",
      "infinitive": null,
      "syllableBreak": "Re-zes-si-on",
      "topics": [
        "finance-and-accounting",
        "advanced-analysis",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun; economic term"
      ],
      "collocations": [
        {
          "text": "in eine Rezession geraten",
          "meaning": "to enter a recession"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "rezessiv",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ركود اقتصادي"
        },
        {
          "language": "ckb",
          "text": "دابەزینی ئابووری؛ ڕیکەشن"
        },
        {
          "language": "en",
          "text": "recession"
        },
        {
          "language": "fa",
          "text": "رکود اقتصادی"
        },
        {
          "language": "kmr",
          "text": "recesyon; paşketina aborî"
        },
        {
          "language": "pl",
          "text": "recesja"
        },
        {
          "language": "ro",
          "text": "recesiune"
        },
        {
          "language": "ru",
          "text": "рецессия; экономический спад"
        },
        {
          "language": "sq",
          "text": "recesion"
        },
        {
          "language": "tr",
          "text": "resesyon; ekonomik durgunluk"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rezession traf besonders jene Branchen, die stark von kurzfristigem Konsum abhängen.",
          "translations": [
            {
              "language": "ar",
              "text": "أصاب الركود خصوصاً القطاعات التي تعتمد بشدة على الاستهلاك قصير الأجل."
            },
            {
              "language": "ckb",
              "text": "ڕیکەشن بە تایبەتی ئەو پیشانەی گرت کە زۆر پشت بە بەکارهێنانی کورتخایەن دەبەستن."
            },
            {
              "language": "en",
              "text": "The recession hit especially those sectors that depend heavily on short-term consumption."
            },
            {
              "language": "fa",
              "text": "رکود به‌ویژه صنایعی را تحت تأثیر قرار داد که به مصرف کوتاه‌مدت وابسته‌اند."
            },
            {
              "language": "kmr",
              "text": "Recesyon bi taybetî li wan sektorên ku gelek bi xerckirina kurt ve girêdayî ne ket."
            },
            {
              "language": "pl",
              "text": "Recesja szczególnie dotknęła branże silnie zależne od krótkoterminowej konsumpcji."
            },
            {
              "language": "ro",
              "text": "Recesiunea a lovit în special sectoarele care depind puternic de consumul pe termen scurt."
            },
            {
              "language": "ru",
              "text": "Рецессия особенно ударила по отраслям, сильно зависящим от краткосрочного потребления."
            },
            {
              "language": "sq",
              "text": "Recesioni goditi veçanërisht sektorët që varen shumë nga konsumi afatshkurtër."
            },
            {
              "language": "tr",
              "text": "Resesyon özellikle kısa vadeli tüketime güçlü biçimde bağlı sektörleri vurdu."
            }
          ]
        },
        {
          "baseText": "Trotz Rezession hielt das Unternehmen an der Ausbildung neuer Fachkräfte fest.",
          "translations": [
            {
              "language": "ar",
              "text": "رغم الركود تمسكت الشركة بتدريب كوادر متخصصة جديدة."
            },
            {
              "language": "ckb",
              "text": "سەرەڕای ڕیکەشن، کۆمپانیاکە پێداگری لە ڕاهێنانی پسپۆڕی نوێ کرد."
            },
            {
              "language": "en",
              "text": "Despite the recession, the company continued training new skilled workers."
            },
            {
              "language": "fa",
              "text": "با وجود رکود، شرکت آموزش نیروهای متخصص جدید را ادامه داد."
            },
            {
              "language": "kmr",
              "text": "Tevî recesyonê, şîrket li perwerdekirina pisporên nû ma."
            },
            {
              "language": "pl",
              "text": "Mimo recesji firma utrzymała szkolenie nowych specjalistów."
            },
            {
              "language": "ro",
              "text": "În ciuda recesiunii, compania a menținut formarea noilor specialiști."
            },
            {
              "language": "ru",
              "text": "Несмотря на рецессию, компания продолжила обучение новых специалистов."
            },
            {
              "language": "sq",
              "text": "Pavarësisht recesionit, kompania vazhdoi trajnimin e specialistëve të rinj."
            },
            {
              "language": "tr",
              "text": "Resesyona rağmen şirket yeni uzmanların eğitimini sürdürdü."
            }
          ]
        }
      ]
    },
    {
