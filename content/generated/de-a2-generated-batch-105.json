      "meanings": [
        {
          "language": "ar",
          "text": "حذر؛ بحذر"
        },
        {
          "language": "ckb",
          "text": "وریای؛ بە وریایی"
        },
        {
          "language": "en",
          "text": "careful; carefully"
        },
        {
          "language": "fa",
          "text": "مراقب؛ با احتیاط"
        },
        {
          "language": "kmr",
          "text": "hişyar; bi baldarî"
        },
        {
          "language": "pl",
          "text": "ostrożny; ostrożnie"
        },
        {
          "language": "ro",
          "text": "atent; cu grijă"
        },
        {
          "language": "ru",
          "text": "осторожный; осторожно"
        },
        {
          "language": "sq",
          "text": "i kujdesshëm; me kujdes"
        },
        {
          "language": "tr",
          "text": "dikkatli; dikkatlice"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte seien Sie auf der Treppe vorsichtig.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى توخي الحذر على الدرج."
            },
            {
              "language": "ckb",
              "text": "تکایە لەسەر پلەکان وریابن."
            },
            {
              "language": "en",
              "text": "Please be careful on the stairs."
            },
            {
              "language": "fa",
              "text": "لطفاً روی پله‌ها مراقب باشید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li ser derenceyan baldar bin."
            },
            {
              "language": "pl",
              "text": "Proszę uważać na schodach."
            },
            {
              "language": "ro",
              "text": "Vă rog să fiți atent pe scări."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, будьте осторожны на лестнице."
            },
            {
              "language": "sq",
              "text": "Ju lutem kini kujdes në shkallë."
            },
            {
              "language": "tr",
              "text": "Lütfen merdivenlerde dikkatli olun."
            }
          ]
        },
        {
          "baseText": "Fahren Sie vorsichtig, die Straße ist nass.",
          "translations": [
            {
              "language": "ar",
              "text": "قُد بحذر، فالطريق مبلل."
            },
            {
              "language": "ckb",
              "text": "بە وریایی شۆفێری بکە، شەقامەکە تەڕە."
            },
            {
              "language": "en",
              "text": "Drive carefully; the road is wet."
            },
            {
              "language": "fa",
              "text": "با احتیاط رانندگی کنید، خیابان خیس است."
            },
            {
              "language": "kmr",
              "text": "Bi baldarî ajotinê bikin, rê şil e."
            },
            {
              "language": "pl",
              "text": "Proszę jechać ostrożnie, droga jest mokra."
            },
            {
              "language": "ro",
              "text": "Conduceți cu grijă, drumul este ud."
            },
            {
              "language": "ru",
              "text": "Езжайте осторожно, дорога мокрая."
            },
            {
              "language": "sq",
              "text": "Drejtoni me kujdes, rruga është e lagur."
            },
            {
              "language": "tr",
              "text": "Dikkatli sürün, yol ıslak."
            }
          ]
        }
      ]
    },
