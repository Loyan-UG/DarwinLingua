        }
      ],
      "examples": [
        {
          "baseText": "Die Pflanzen wachsen gut am Fenster.",
          "translations": [
            {
              "language": "ar",
              "text": "تنمو النباتات جيداً عند النافذة."
            },
            {
              "language": "ckb",
              "text": "ڕووەکەکان لە لای پەنجەرەکە باش گەشە دەکەن."
            },
            {
              "language": "en",
              "text": "The plants grow well by the window."
            },
            {
              "language": "fa",
              "text": "گیاهان کنار پنجره خوب رشد می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Nebat li kêleka paceyê baş mezin dibin."
            },
            {
              "language": "pl",
              "text": "Rośliny dobrze rosną przy oknie."
            },
            {
              "language": "ro",
              "text": "Plantele cresc bine lângă fereastră."
            },
            {
              "language": "ru",
              "text": "Растения хорошо растут у окна."
            },
            {
              "language": "sq",
              "text": "Bimët rriten mirë pranë dritares."
            },
            {
              "language": "tr",
              "text": "Bitkiler pencerenin yanında iyi büyüyor."
            }
          ]
        },
        {
          "baseText": "Unsere kleine Firma wächst langsam.",
          "translations": [
            {
              "language": "ar",
              "text": "شركتنا الصغيرة تنمو ببطء."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیا بچووکەکەمان هێواش هێواش گەشە دەکات."
            },
            {
              "language": "en",
              "text": "Our small company is growing slowly."
            },
            {
              "language": "fa",
              "text": "شرکت کوچک ما آرام‌آرام رشد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Şîrketa me ya biçûk hêdî hêdî mezin dibe."
            },
            {
              "language": "pl",
              "text": "Nasza mała firma powoli rośnie."
            },
            {
              "language": "ro",
              "text": "Firma noastră mică crește încet."
            },
            {
              "language": "ru",
              "text": "Наша маленькая фирма медленно растет."
            },
            {
              "language": "sq",
              "text": "Kompania jonë e vogël po rritet ngadalë."
            },
            {
              "language": "tr",
              "text": "Küçük şirketimiz yavaş yavaş büyüyor."
            }
          ]
        }
      ]
    },
