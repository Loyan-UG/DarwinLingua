      "relations": [],
      "word": "die Fakturierung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Fakturierungen",
      "infinitive": null,
      "syllableBreak": "Fak-tu-rie-rung",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "process"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Fakturierung starten",
          "meaning": "to start invoicing"
        },
        {
          "text": "automatische Fakturierung",
          "meaning": "automatic invoicing"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fakturieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Faktura",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "إصدار الفواتير"
        },
        {
          "language": "ckb",
          "text": "فاکتورکردن"
        },
        {
          "language": "en",
          "text": "invoicing"
        },
        {
          "language": "fa",
          "text": "صدور فاکتور"
        },
        {
          "language": "kmr",
          "text": "fatûrekirin"
        },
        {
          "language": "pl",
          "text": "fakturowanie"
        },
        {
          "language": "ro",
          "text": "facturare"
        },
        {
          "language": "ru",
          "text": "выставление счетов"
        },
        {
          "language": "sq",
          "text": "faturim"
        },
        {
          "language": "tr",
          "text": "faturalandırma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Fakturierung läuft jeden Abend automatisch im ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "تتم عملية إصدار الفواتير تلقائيًا كل مساء في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "فاکتورکردنەکە هەموو ئێوارەیەک خۆکارانە لە سیستەمی ERPدا دەچێتەڕێوە."
            },
            {
              "language": "en",
              "text": "Invoicing runs automatically in the ERP system every evening."
            },
            {
              "language": "fa",
              "text": "صدور فاکتور هر شب به صورت خودکار در سیستم ERP انجام می‌شود."
            },
            {
              "language": "kmr",
              "text": "Fatûrekirin her êvarê bixweber di pergala ERP de dimeşe."
            },
            {
              "language": "pl",
              "text": "Fakturowanie uruchamia się automatycznie każdego wieczoru w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Facturarea rulează automat în fiecare seară în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Выставление счетов каждый вечер автоматически выполняется в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Faturimi kryhet automatikisht çdo mbrëmje në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Faturalandırma her akşam ERP sisteminde otomatik çalışır."
            }
          ]
        },
        {
          "baseText": "Bitte warten Sie mit der Fakturierung, bis der Kunde die Ware bestätigt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الانتظار في إصدار الفاتورة حتى يؤكد العميل استلام البضاعة."
            },
            {
              "language": "ckb",
              "text": "تکایە چاوەڕێ بکە بۆ فاکتورکردن تا کڕیارەکە کاڵاکە پشتڕاست دەکاتەوە."
            },
            {
              "language": "en",
              "text": "Please wait with invoicing until the customer confirms the goods."
            },
            {
              "language": "fa",
              "text": "لطفاً تا وقتی مشتری کالا را تأیید نکرده، فاکتور صادر نکنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe heta xerîdar malê piştrast neke bi fatûrekirinê bisekinin."
            },
            {
              "language": "pl",
              "text": "Proszę wstrzymać fakturowanie, aż klient potwierdzi towar."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să așteptați cu facturarea până când clientul confirmă marfa."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, подождите с выставлением счета, пока клиент не подтвердит товар."
            },
            {
              "language": "sq",
              "text": "Ju lutemi prisni me faturimin derisa klienti të konfirmojë mallin."
            },
            {
              "language": "tr",
              "text": "Müşteri malı onaylayana kadar faturalandırmayı bekletin."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Filiale",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Filialen",
      "infinitive": null,
      "syllableBreak": "Fi-li-a-le",
      "topics": [
        "sales-and-customers",
        "work-and-jobs",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Filiale eröffnen",
          "meaning": "to open a branch"
        },
        {
          "text": "in der Filiale arbeiten",
          "meaning": "to work at the branch"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فرع"
        },
        {
          "language": "ckb",
          "text": "لق"
        },
        {
          "language": "en",
          "text": "branch"
        },
        {
          "language": "fa",
          "text": "شعبه"
        },
        {
          "language": "kmr",
          "text": "şax; filial"
        },
        {
          "language": "pl",
          "text": "oddział; filia"
        },
        {
          "language": "ro",
          "text": "filială"
        },
        {
          "language": "ru",
          "text": "филиал"
        },
        {
          "language": "sq",
          "text": "degë"
        },
        {
          "language": "tr",
          "text": "şube"
        }
      ],
      "examples": [
        {
          "baseText": "Die Filiale in Köln meldet den Bestand direkt im ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "يقوم فرع كولونيا بتسجيل المخزون مباشرة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "لقی کۆڵن کۆگا ڕاستەوخۆ لە سیستەمی ERPدا تۆمار دەکات."
            },
            {
              "language": "en",
              "text": "The branch in Cologne reports its stock directly in the ERP system."
            },
            {
              "language": "fa",
              "text": "شعبه کلن موجودی را مستقیم در سیستم ERP ثبت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Şaxa li Köln stokê rasterast di pergala ERP de tomar dike."
            },
            {
              "language": "pl",
              "text": "Oddział w Kolonii zgłasza stan magazynowy bezpośrednio w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Filiala din Köln raportează stocul direct în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Филиал в Кёльне передает остатки напрямую в ERP-систему."
            },
            {
              "language": "sq",
              "text": "Dega në Këln e raporton stokun direkt në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Köln şubesi stoğu doğrudan ERP sistemine bildiriyor."
            }
          ]
        },
        {
          "baseText": "Unsere neue Filiale ist montags bis samstags geöffnet.",
          "translations": [
            {
              "language": "ar",
              "text": "فرعنا الجديد مفتوح من الاثنين إلى السبت."
            },
            {
              "language": "ckb",
              "text": "لقە نوێیەکەمان لە دووشەممە تا شەممە کراوەیە."
            },
            {
              "language": "en",
              "text": "Our new branch is open from Monday to Saturday."
            },
            {
              "language": "fa",
              "text": "شعبه جدید ما از دوشنبه تا شنبه باز است."
            },
            {
              "language": "kmr",
              "text": "Şaxa me ya nû ji duşemê heta şemiyê vekirî ye."
            },
            {
              "language": "pl",
              "text": "Nasza nowa filia jest otwarta od poniedziałku do soboty."
            },
            {
              "language": "ro",
              "text": "Noua noastră filială este deschisă de luni până sâmbătă."
            },
            {
              "language": "ru",
              "text": "Наш новый филиал открыт с понедельника по субботу."
            },
            {
              "language": "sq",
              "text": "Dega jonë e re është e hapur nga e hëna deri të shtunën."
            },
            {
              "language": "tr",
              "text": "Yeni şubemiz pazartesiden cumartesiye açıktır."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Frachtkosten",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Frachtkosten",
      "infinitive": null,
      "syllableBreak": "Fracht-kos-ten",
      "topics": [
        "warehouse-and-logistics",
        "finance-and-accounting",
        "procurement-and-suppliers"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "written"
      ],
      "grammarNotes": [
        "plural noun; usually used in plural"
      ],
      "collocations": [
        {
          "text": "Frachtkosten berechnen",
          "meaning": "to calculate freight costs"
        },
        {
          "text": "Frachtkosten übernehmen",
          "meaning": "to cover freight costs"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Fracht",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Kosten",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تكاليف الشحن"
        },
        {
          "language": "ckb",
          "text": "تێچووی گواستنەوە"
        },
        {
          "language": "en",
          "text": "freight costs; shipping costs"
        },
        {
          "language": "fa",
          "text": "هزینه حمل"
        },
        {
          "language": "kmr",
          "text": "mesrefên barkirinê"
        },
        {
          "language": "pl",
          "text": "koszty frachtu; koszty transportu"
        },
        {
          "language": "ro",
          "text": "costuri de transport"
        },
        {
          "language": "ru",
          "text": "транспортные расходы"
        },
        {
          "language": "sq",
          "text": "kosto transporti"
        },
        {
          "language": "tr",
          "text": "navlun maliyetleri"
        }
      ],
      "examples": [
        {
          "baseText": "Die Frachtkosten werden im ERP-System automatisch zum Auftrag addiert.",
          "translations": [
            {
              "language": "ar",
              "text": "تُضاف تكاليف الشحن تلقائيًا إلى الطلب في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "تێچووی گواستنەوە خۆکارانە لە سیستەمی ERPدا بۆ داواکارییەکە زیاد دەکرێت."
            },
            {
              "language": "en",
              "text": "The freight costs are added automatically to the order in the ERP system."
            },
            {
              "language": "fa",
              "text": "هزینه حمل در سیستم ERP به صورت خودکار به سفارش اضافه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Mesrefên barkirinê di pergala ERP de bixweber li fermarişê tên zêdekirin."
            },
            {
              "language": "pl",
              "text": "Koszty transportu są automatycznie dodawane do zamówienia w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Costurile de transport sunt adăugate automat la comandă în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Транспортные расходы автоматически добавляются к заказу в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Kostot e transportit shtohen automatikisht në porosi në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Navlun maliyetleri ERP sisteminde siparişe otomatik eklenir."
            }
          ]
        },
        {
          "baseText": "Für kleine Bestellungen sind die Frachtkosten oft zu hoch.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة للطلبات الصغيرة تكون تكاليف الشحن غالبًا مرتفعة جدًا."
            },
            {
              "language": "ckb",
              "text": "بۆ داواکاریی بچووک تێچووی گواستنەوە زۆرجار زۆر بەرزە."
            },
            {
              "language": "en",
              "text": "For small orders, freight costs are often too high."
            },
            {
              "language": "fa",
              "text": "برای سفارش‌های کوچک، هزینه حمل اغلب خیلی زیاد است."
            },
            {
              "language": "kmr",
              "text": "Ji bo fermarişên biçûk mesrefên barkirinê gelek caran pir zêde ne."
            },
            {
              "language": "pl",
              "text": "Przy małych zamówieniach koszty transportu są często zbyt wysokie."
            },
            {
              "language": "ro",
              "text": "Pentru comenzile mici, costurile de transport sunt adesea prea mari."
            },
            {
              "language": "ru",
              "text": "Для небольших заказов транспортные расходы часто слишком высоки."
            },
            {
              "language": "sq",
              "text": "Për porositë e vogla, kostot e transportit shpesh janë shumë të larta."
            },
