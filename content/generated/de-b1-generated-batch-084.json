        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kreditkarte",
          "relationLabel": "related noun",
          "note": null
        },
        {
          "lemma": "kreditwürdig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قرض؛ ائتمان"
        },
        {
          "language": "ckb",
          "text": "قەرز؛ کرێدیت"
        },
        {
          "language": "en",
          "text": "loan; credit"
        },
        {
          "language": "fa",
          "text": "وام؛ اعتبار"
        },
        {
          "language": "kmr",
          "text": "deyn; kredî"
        },
        {
          "language": "pl",
          "text": "kredyt; pożyczka"
        },
        {
          "language": "ro",
          "text": "credit; împrumut"
        },
        {
          "language": "ru",
          "text": "кредит; заём"
        },
        {
          "language": "sq",
          "text": "kredi; hua"
        },
        {
          "language": "tr",
          "text": "kredi; borç"
        }
      ],
      "examples": [
        {
          "baseText": "Die Firma möchte einen Kredit aufnehmen, um neue Maschinen zu kaufen.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد الشركة الحصول على قرض لشراء آلات جديدة."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە دەیەوێت قەرز وەربگرێت بۆ کڕینی ئامێری نوێ."
            },
            {
              "language": "en",
              "text": "The company wants to take out a loan to buy new machines."
            },
            {
              "language": "fa",
              "text": "شرکت می‌خواهد برای خرید ماشین‌آلات جدید وام بگیرد."
            },
            {
              "language": "kmr",
              "text": "Şîrket dixwaze deynê bistîne da ku makîneyên nû bikire."
            },
            {
              "language": "pl",
              "text": "Firma chce wziąć kredyt, aby kupić nowe maszyny."
            },
            {
              "language": "ro",
              "text": "Firma dorește să ia un credit pentru a cumpăra utilaje noi."
            },
            {
              "language": "ru",
              "text": "Компания хочет взять кредит, чтобы купить новые станки."
            },
            {
              "language": "sq",
              "text": "Kompania dëshiron të marrë kredi për të blerë makineri të reja."
            },
            {
              "language": "tr",
              "text": "Firma yeni makineler almak için kredi çekmek istiyor."
            }
          ]
        },
        {
          "baseText": "Für die Wohnung prüfen sie, ob sie den Kredit monatlich bezahlen können.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل الشقة يتحققون مما إذا كانوا يستطيعون دفع القرض شهرياً."
            },
            {
              "language": "ckb",
              "text": "بۆ شوقەکە دەپشکنن ئایا دەتوانن قەرزەکە مانگانە بدەن."
            },
            {
              "language": "en",
              "text": "For the apartment, they check whether they can pay the loan monthly."
            },
            {
              "language": "fa",
              "text": "برای آپارتمان بررسی می‌کنند آیا می‌توانند وام را ماهانه پرداخت کنند."
            },
            {
              "language": "kmr",
              "text": "Ji bo apartmanê ew kontrol dikin ka dikarin deynê mehane bidin yan na."
            },
            {
              "language": "pl",
