  "entries": [
    {
      "word": "kreativ",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "kre-a-tiv",
      "topics": [
        "work-and-jobs",
        "culture-and-media",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes original or imaginative ideas and solutions"
      ],
      "collocations": [
        {
          "text": "eine kreative Lösung",
          "meaning": "a creative solution"
        },
        {
          "text": "kreativ arbeiten",
          "meaning": "to work creatively"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kreativität",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إبداعي؛ مبتكر"
        },
        {
          "language": "ckb",
          "text": "داهێنەرانە؛ خەیاڵدار"
        },
        {
          "language": "en",
          "text": "creative"
        },
        {
          "language": "fa",
          "text": "خلاق؛ ابتکاری"
        },
        {
          "language": "kmr",
          "text": "afirîner; kreatîf"
        },
        {
          "language": "pl",
          "text": "kreatywny; twórczy"
        },
        {
          "language": "ro",
          "text": "creativ"
        },
        {
          "language": "ru",
          "text": "креативный; творческий"
        },
        {
          "language": "sq",
          "text": "krijues; kreativ"
        },
        {
          "language": "tr",
          "text": "yaratıcı"
        }
      ],
      "examples": [
        {
          "baseText": "Für die neue Kampagne brauchen wir eine kreative Idee, die trotzdem zum Budget passt.",
          "translations": [
            {
              "language": "ar",
              "text": "للحملة الجديدة نحتاج إلى فكرة إبداعية تناسب الميزانية رغم ذلك."
            },
            {
              "language": "ckb",
              "text": "بۆ کەمپەینی نوێ پێویستمان بە بیرۆکەیەکی داهێنەرانە هەیە کە هەر لەگەڵ بودجەکەش بگونجێت."
            },
            {
              "language": "en",
              "text": "For the new campaign, we need a creative idea that still fits the budget."
            },
            {
              "language": "fa",
              "text": "برای کمپین جدید به یک ایده خلاق نیاز داریم که با بودجه هم هماهنگ باشد."
            },
            {
              "language": "kmr",
              "text": "Ji bo kampanyaya nû em hewceyê ramaneke afirîner in ku hîn jî bi budceyê re bigunce."
            },
            {
              "language": "pl",
              "text": "Do nowej kampanii potrzebujemy kreatywnego pomysłu, który mimo to pasuje do budżetu."
            },
            {
              "language": "ro",
              "text": "Pentru noua campanie avem nevoie de o idee creativă care să se potrivească totuși bugetului."
            },
            {
              "language": "ru",
              "text": "Для новой кампании нам нужна креативная идея, которая всё же вписывается в бюджет."
            },
            {
              "language": "sq",
              "text": "Për fushatën e re na duhet një ide krijuese që megjithatë i përshtatet buxhetit."
            },
            {
              "language": "tr",
              "text": "Yeni kampanya için bütçeye de uyan yaratıcı bir fikre ihtiyacımız var."
            }
          ]
        },
        {
          "baseText": "Die Kinder waren kreativ und haben aus alten Kartons ein Haus gebaut.",
          "translations": [
            {
              "language": "ar",
              "text": "كان الأطفال مبدعين وبنوا بيتاً من صناديق قديمة."
            },
            {
              "language": "ckb",
              "text": "منداڵەکان داهێنەر بوون و لە کارتۆنی کۆن خانوویەکیان دروست کرد."
            },
            {
              "language": "en",
              "text": "The children were creative and built a house out of old boxes."
            },
            {
              "language": "fa",
              "text": "بچه‌ها خلاق بودند و از کارتن‌های قدیمی یک خانه ساختند."
            },
            {
              "language": "kmr",
              "text": "Zarok afirîner bûn û ji qutiyên kevn xaniyek çêkirin."
            },
            {
              "language": "pl",
              "text": "Dzieci były kreatywne i zbudowały dom ze starych kartonów."
            },
            {
              "language": "ro",
              "text": "Copiii au fost creativi și au construit o casă din cutii vechi."
            },
            {
              "language": "ru",
              "text": "Дети были креативными и построили дом из старых коробок."
            },
            {
              "language": "sq",
              "text": "Fëmijët ishin krijues dhe ndërtuan një shtëpi nga kuti të vjetra."
            },
            {
              "language": "tr",
              "text": "Çocuklar yaratıcıydı ve eski kutulardan bir ev yaptılar."
            }
          ]
        }
      ]
    },
    {
      "word": "der Kredit",
      "language": "de",
      "cefrLevel": "B1",
