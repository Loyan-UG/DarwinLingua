      ],
      "collocations": [
        {
          "text": "für Sicherheit sorgen",
          "meaning": "to ensure safety"
        },
        {
          "text": "Sicherheit am Arbeitsplatz",
          "meaning": "safety at work"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sicher",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "sichern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أمان؛ سلامة؛ أمن"
        },
        {
          "language": "ckb",
          "text": "ئاسایش؛ سەلامەتی؛ پاراستن"
        },
        {
          "language": "en",
          "text": "safety; security"
        },
        {
          "language": "fa",
          "text": "ایمنی؛ امنیت"
        },
        {
          "language": "kmr",
          "text": "ewlehî; parastin"
        },
        {
          "language": "pl",
          "text": "bezpieczeństwo"
        },
        {
          "language": "ro",
          "text": "siguranță; securitate"
        },
        {
          "language": "ru",
          "text": "безопасность; защищённость"
        },
        {
          "language": "sq",
          "text": "siguri; mbrojtje"
        },
        {
          "language": "tr",
          "text": "güvenlik; emniyet"
        }
      ],
      "examples": [
        {
          "baseText": "Die Sicherheit der Mitarbeiter hat in der Produktion höchste Priorität.",
          "translations": [
            {
              "language": "ar",
              "text": "سلامة الموظفين لها الأولوية القصوى في الإنتاج."
            },
            {
              "language": "ckb",
              "text": "سەلامەتی کارمەندان لە بەرهەمهێناندا گرنگترین ئەولەویەتە."
            },
            {
              "language": "en",
              "text": "Employee safety has the highest priority in production."
            },
            {
              "language": "fa",
              "text": "ایمنی کارکنان در تولید بالاترین اولویت را دارد."
            },
            {
              "language": "kmr",
              "text": "Ewlehiya karmendan di hilberînê de pêşîniya herî bilind e."
            },
            {
              "language": "pl",
              "text": "Bezpieczeństwo pracowników ma w produkcji najwyższy priorytet."
            },
            {
              "language": "ro",
              "text": "Siguranța angajaților are cea mai mare prioritate în producție."
            },
            {
              "language": "ru",
              "text": "Безопасность сотрудников на производстве имеет высший приоритет."
            },
            {
              "language": "sq",
              "text": "Siguria e punonjësve ka përparësinë më të lartë në prodhim."
            },
            {
              "language": "tr",
              "text": "Üretimde çalışan güvenliği en yüksek önceliğe sahiptir."
            }
          ]
        },
        {
          "baseText": "Für mehr Sicherheit verwenden wir starke Passwörter.",
          "translations": [
            {
              "language": "ar",
              "text": "لمزيد من الأمان نستخدم كلمات مرور قوية."
            },
            {
              "language": "ckb",
              "text": "بۆ ئاسایشی زیاتر وشەی نهێنی بەهێز بەکاردەهێنین."
            },
            {
              "language": "en",
              "text": "For more security, we use strong passwords."
            },
            {
              "language": "fa",
              "text": "برای امنیت بیشتر از گذرواژه‌های قوی استفاده می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Ji bo ewlehiya zêdetir em şîfreyên bihêz bikar tînin."
            },
            {
              "language": "pl",
              "text": "Dla większego bezpieczeństwa używamy silnych haseł."
            },
            {
              "language": "ro",
              "text": "Pentru mai multă securitate folosim parole puternice."
            },
            {
              "language": "ru",
              "text": "Для большей безопасности мы используем надёжные пароли."
            },
            {
              "language": "sq",
              "text": "Për më shumë siguri përdorim fjalëkalime të forta."
            },
            {
              "language": "tr",
              "text": "Daha fazla güvenlik için güçlü parolalar kullanıyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "die Sicherheitsvorschrift",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Sicherheitsvorschriften",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Si-cher-heits-vor-schrift",
      "topics": [
        "quality-and-risk",
        "law-and-compliance",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "workplace",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; often used in plural"
      ],
      "collocations": [
        {
          "text": "Sicherheitsvorschriften beachten",
          "meaning": "to follow safety regulations"
        },
        {
          "text": "gegen Sicherheitsvorschriften verstoßen",
          "meaning": "to violate safety regulations"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Sicherheit",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Vorschrift",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تعليمات السلامة؛ لوائح الأمان"
        },
        {
          "language": "ckb",
          "text": "ڕێنماییەکانی سەلامەتی؛ یاساکانی پاراستن"
        },
        {
          "language": "en",
          "text": "safety regulation; safety instruction"
        },
        {
          "language": "fa",
          "text": "مقررات ایمنی؛ دستورالعمل ایمنی"
        },
        {
          "language": "kmr",
          "text": "rêziknameya ewlehiyê; rêbernameya ewlehiyê"
        },
        {
          "language": "pl",
          "text": "przepis bezpieczeństwa; instrukcja bezpieczeństwa"
        },
        {
          "language": "ro",
          "text": "regulă de siguranță; instrucțiune de securitate"
        },
        {
          "language": "ru",
          "text": "правило безопасности; инструкция по безопасности"
        },
        {
          "language": "sq",
          "text": "rregull sigurie; udhëzim sigurie"
        },
        {
          "language": "tr",
          "text": "güvenlik kuralı; güvenlik talimatı"
        }
      ],
      "examples": [
        {
          "baseText": "Vor dem Betreten der Halle müssen alle die Sicherheitsvorschriften lesen.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل دخول القاعة يجب على الجميع قراءة تعليمات السلامة."
            },
            {
              "language": "ckb",
              "text": "پێش چوونە ناو هۆڵەکە هەمووان دەبێت ڕێنماییەکانی سەلامەتی بخوێننەوە."
            },
            {
              "language": "en",
              "text": "Before entering the hall, everyone must read the safety regulations."
            },
            {
              "language": "fa",
              "text": "قبل از ورود به سالن، همه باید مقررات ایمنی را بخوانند."
            },
            {
              "language": "kmr",
              "text": "Berî ketina salonê divê hemû kes rêziknameyên ewlehiyê bixwînin."
            },
            {
              "language": "pl",
              "text": "Przed wejściem do hali wszyscy muszą przeczytać przepisy bezpieczeństwa."
            },
            {
              "language": "ro",
              "text": "Înainte de intrarea în hală, toți trebuie să citească regulile de siguranță."
            },
            {
              "language": "ru",
              "text": "Перед входом в цех все должны прочитать правила безопасности."
            },
            {
              "language": "sq",
              "text": "Para hyrjes në sallë, të gjithë duhet të lexojnë rregullat e sigurisë."
            },
            {
              "language": "tr",
              "text": "Salona girmeden önce herkes güvenlik talimatlarını okumalıdır."
            }
          ]
        },
        {
          "baseText": "Die neue Sicherheitsvorschrift gilt ab Montag für das ganze Team.",
          "translations": [
            {
              "language": "ar",
              "text": "تسري تعليمات السلامة الجديدة اعتبارًا من الاثنين على الفريق كله."
            },
            {
              "language": "ckb",
              "text": "ڕێنمایی نوێی سەلامەتی لە دووشەممەوە بۆ هەموو تیمەکە کاریگەر دەبێت."
            },
            {
              "language": "en",
              "text": "The new safety regulation applies to the whole team from Monday."
            },
            {
              "language": "fa",
              "text": "مقررات ایمنی جدید از دوشنبه برای کل تیم اجرا می‌شود."
            },
            {
              "language": "kmr",
              "text": "Rêziknameya nû ya ewlehiyê ji duşemê û pê ve ji bo tevahiya tîmê derbasdar e."
            },
            {
              "language": "pl",
              "text": "Nowy przepis bezpieczeństwa obowiązuje cały zespół od poniedziałku."
            },
            {
              "language": "ro",
              "text": "Noua regulă de siguranță se aplică întregii echipe de luni."
            },
            {
              "language": "ru",
              "text": "Новое правило безопасности действует для всей команды с понедельника."
            },
            {
              "language": "sq",
              "text": "Rregulli i ri i sigurisë vlen për të gjithë ekipin nga e hëna."
            },
            {
              "language": "tr",
              "text": "Yeni güvenlik kuralı pazartesiden itibaren tüm ekip için geçerlidir."
            }
          ]
        }
      ]
    },
    {
      "word": "sinken",
