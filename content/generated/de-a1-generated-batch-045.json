      "examples": [
        {
          "baseText": "Guten Abend, Frau Schneider.",
          "translations": [
            {
              "language": "ar",
              "text": "مساء الخير، سيدة شنايدر."
            },
            {
              "language": "ckb",
              "text": "ئێوارە باش، خانم شنایدەر."
            },
            {
              "language": "en",
              "text": "Good evening, Ms. Schneider."
            },
            {
              "language": "fa",
              "text": "عصر بخیر، خانم اشنایدر."
            },
            {
              "language": "kmr",
              "text": "Êvar baş, Xanim Schneider."
            },
            {
              "language": "pl",
              "text": "Dobry wieczór, pani Schneider."
            },
            {
              "language": "ro",
              "text": "Bună seara, doamnă Schneider."
            },
            {
              "language": "ru",
              "text": "Добрый вечер, госпожа Шнайдер."
            },
            {
              "language": "sq",
              "text": "Mirëmbrëma, zonja Schneider."
            },
            {
              "language": "tr",
              "text": "İyi akşamlar, Bayan Schneider."
            }
          ]
        },
        {
          "baseText": "Guten Abend, ich habe einen Tisch reserviert.",
          "translations": [
            {
              "language": "ar",
              "text": "مساء الخير، لقد حجزت طاولة."
            },
            {
              "language": "ckb",
              "text": "ئێوارە باش، من مێزێکم حجز کردووە."
            },
            {
              "language": "en",
              "text": "Good evening, I have reserved a table."
            },
            {
              "language": "fa",
              "text": "عصر بخیر، من یک میز رزرو کرده‌ام."
            },
            {
              "language": "kmr",
              "text": "Êvar baş, min maseyek rezerve kiriye."
            },
            {
              "language": "pl",
              "text": "Dobry wieczór, zarezerwowałem stolik."
            },
            {
              "language": "ro",
              "text": "Bună seara, am rezervat o masă."
            },
            {
              "language": "ru",
              "text": "Добрый вечер, я забронировал столик."
            },
            {
              "language": "sq",
              "text": "Mirëmbrëma, kam rezervuar një tavolinë."
            },
            {
              "language": "tr",
              "text": "İyi akşamlar, bir masa ayırttım."
