            },
            {
              "language": "tr",
              "text": "Günaydın, nasılsınız?"
            }
          ]
        },
        {
          "baseText": "Guten Morgen, ich habe um neun Uhr einen Termin.",
          "translations": [
            {
              "language": "ar",
              "text": "صباح الخير، لدي موعد الساعة التاسعة."
            },
            {
              "language": "ckb",
              "text": "بەیانی باش، کاتژمێر نۆ کاتم هەیە."
            },
            {
              "language": "en",
              "text": "Good morning, I have an appointment at nine o’clock."
            },
            {
              "language": "fa",
              "text": "صبح بخیر، من ساعت نه یک وقت دارم."
            },
            {
              "language": "kmr",
              "text": "Sibeh baş, min saet nehê demek heye."
            },
            {
              "language": "pl",
              "text": "Dzień dobry, mam termin o dziewiątej."
            },
            {
              "language": "ro",
              "text": "Bună dimineața, am o programare la ora nouă."
            },
            {
              "language": "ru",
              "text": "Доброе утро, у меня встреча в девять часов."
            },
            {
              "language": "sq",
              "text": "Mirëmëngjes, kam një takim në orën nëntë."
            },
            {
              "language": "tr",
              "text": "Günaydın, saat dokuzda randevum var."
            }
          ]
        }
      ]
