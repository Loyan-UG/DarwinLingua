      "meanings": [
        {
          "language": "ar",
          "text": "استقطاب"
        },
        {
          "language": "ckb",
          "text": "جیاوازیی توند؛ پۆلاریزەبوون"
        },
        {
          "language": "en",
          "text": "polarization"
        },
        {
          "language": "fa",
          "text": "قطبی‌شدن"
        },
        {
          "language": "kmr",
          "text": "polarîzasyon"
        },
        {
          "language": "pl",
          "text": "polaryzacja"
        },
        {
          "language": "ro",
          "text": "polarizare"
        },
        {
          "language": "ru",
          "text": "поляризация"
        },
        {
          "language": "sq",
          "text": "polarizim"
        },
        {
          "language": "tr",
          "text": "kutuplaşma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Polarisierung in der Debatte nahm zu, als persönliche Angriffe sachliche Argumente verdrängten.",
          "translations": [
            {
              "language": "ar",
              "text": "ازداد الاستقطاب في النقاش عندما أزاحت الهجمات الشخصية الحجج الموضوعية."
            },
            {
              "language": "ckb",
              "text": "پۆلاریزەبوون لە گفتوگۆکەدا زیاد بوو کاتێک هێرشە کەسییەکان ئارگومێنتی بابەتیان دوورخستەوە."
            },
            {
              "language": "en",
              "text": "Polarization in the debate increased when personal attacks displaced factual arguments."
            },
            {
              "language": "fa",
              "text": "قطبی‌شدن بحث زمانی افزایش یافت که حملات شخصی جای استدلال‌های محتوایی را گرفت."
            },
            {
              "language": "kmr",
              "text": "Polarîzasyon di nîqaşê de zêde bû dema êrişên kesane argumanên rastîn derxistin."
            },
            {
              "language": "pl",
              "text": "Polaryzacja debaty wzrosła, gdy ataki osobiste wyparły rzeczowe argumenty."
            },
            {
              "language": "ro",
              "text": "Polarizarea în dezbatere a crescut când atacurile personale au înlocuit argumentele factuale."
