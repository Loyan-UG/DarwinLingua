      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "die Plausibilität prüfen",
          "meaning": "to check plausibility"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "plausibel",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "المعقولية؛ قابلية التصديق"
        },
        {
          "language": "ckb",
          "text": "باوەڕپێکراوی؛ مەعقوولی"
        },
        {
          "language": "en",
          "text": "plausibility"
        },
        {
          "language": "fa",
          "text": "قابل‌قبول بودن؛ معقولیت"
        },
        {
          "language": "kmr",
          "text": "maqûlbûn; bawerbarî"
        },
        {
          "language": "pl",
          "text": "wiarygodność; prawdopodobieństwo"
        },
        {
          "language": "ro",
          "text": "plauzibilitate"
        },
        {
          "language": "ru",
          "text": "правдоподобие; убедительность"
        },
        {
          "language": "sq",
          "text": "besueshmëri; arsyeshmëri"
        },
        {
          "language": "tr",
          "text": "makullük; inandırıcılık"
        }
      ],
      "examples": [
        {
          "baseText": "Vor der Freigabe prüft das Controlling die Plausibilität der Umsatzprognose.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الموافقة يفحص قسم الرقابة المالية معقولية توقعات المبيعات."
            },
            {
              "language": "ckb",
              "text": "پێش ڕێگەپێدان، بەشی کۆنترۆڵی دارایی باوەڕپێکراوی پێشبینیی فرۆشتن دەپشکنێت."
            },
            {
              "language": "en",
              "text": "Before approval, controlling checks the plausibility of the sales forecast."
            },
            {
              "language": "fa",
              "text": "پیش از تأیید، واحد کنترل مالی معقول بودن پیش‌بینی فروش را بررسی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Berî erêkirinê beşa kontrolê maqûlbûna pêşbîniya firotanê kontrol dike."
            },
            {
              "language": "pl",
              "text": "Przed zatwierdzeniem controlling sprawdza wiarygodność prognozy sprzedaży."
            },
            {
              "language": "ro",
              "text": "Înainte de aprobare, controllingul verifică plauzibilitatea prognozei de vânzări."
            },
            {
              "language": "ru",
              "text": "Перед утверждением контроллинг проверяет правдоподобие прогноза продаж."
            },
            {
              "language": "sq",
              "text": "Para miratimit, kontrollingu verifikon besueshmërinë e parashikimit të shitjeve."
            },
            {
              "language": "tr",
              "text": "Onaydan önce kontrol birimi satış tahmininin makullüğünü kontrol eder."
            }
          ]
        },
        {
          "baseText": "Die Plausibilität der Erklärung leidet, weil mehrere zentrale Ereignisse unerwähnt bleiben.",
          "translations": [
            {
              "language": "ar",
              "text": "تتضرر معقولية التفسير لأن عدة أحداث مركزية تبقى غير مذكورة."
            },
            {
              "language": "ckb",
              "text": "باوەڕپێکراوی ڕوونکردنەوەکە زیان دەبینێت چونکە چەند ڕووداوی سەرەکی باس ناکرێن."
            },
            {
              "language": "en",
              "text": "The plausibility of the explanation suffers because several key events remain unmentioned."
            },
            {
              "language": "fa",
              "text": "قابل‌قبول بودن توضیح آسیب می‌بیند، چون چند رویداد اصلی ناگفته می‌مانند."
            },
            {
              "language": "kmr",
              "text": "Maqûlbûna ravekirinê zirar dibîne ji ber ku gelek bûyerên sereke nayên gotin."
            },
            {
              "language": "pl",
              "text": "Wiarygodność wyjaśnienia cierpi, ponieważ kilka kluczowych wydarzeń pozostaje pominiętych."
            },
            {
              "language": "ro",
              "text": "Plauzibilitatea explicației are de suferit deoarece mai multe evenimente centrale rămân nemenționate."
            },
            {
              "language": "ru",
              "text": "Убедительность объяснения страдает, потому что несколько ключевых событий остаются неупомянутыми."
            },
            {
              "language": "sq",
              "text": "Besueshmëria e shpjegimit dëmtohet sepse disa ngjarje kyçe mbeten të papërmendura."
            },
            {
              "language": "tr",
              "text": "Açıklamanın inandırıcılığı, birkaç temel olayın belirtilmemesi nedeniyle zarar görür."
            }
          ]
        }
      ]
    },
    {
      "word": "die Pluralität",
      "language": "de",
      "cefrLevel": "C1",
