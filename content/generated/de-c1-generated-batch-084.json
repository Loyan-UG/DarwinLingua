        "academic",
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "gesellschaftliche Pluralität anerkennen",
          "meaning": "to recognize social plurality"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "plural",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "der Pluralismus",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تعددية؛ تنوع"
        },
        {
          "language": "ckb",
          "text": "فرەیی؛ جۆراوجۆری"
        },
        {
          "language": "en",
          "text": "plurality; diversity"
        },
        {
          "language": "fa",
          "text": "تکثر؛ چندگانگی"
        },
        {
          "language": "kmr",
          "text": "pirrengî; cihêrengî"
        },
        {
          "language": "pl",
          "text": "pluralizm; wielość"
        },
        {
          "language": "ro",
          "text": "pluralitate; diversitate"
        },
        {
          "language": "ru",
          "text": "множественность; плюральность"
        },
        {
          "language": "sq",
          "text": "pluralitet; shumësi"
        },
        {
          "language": "tr",
          "text": "çoğulluk; çeşitlilik"
        }
      ],
      "examples": [
        {
          "baseText": "Die Pluralität der Perspektiven macht den Bericht anspruchsvoller, aber auch belastbarer.",
          "translations": [
            {
              "language": "ar",
              "text": "تجعل تعددية المنظورات التقرير أكثر تعقيداً، لكنها تجعله أيضاً أكثر قوة."
            },
            {
              "language": "ckb",
              "text": "فرەیی دیدگاکان ڕاپۆرتەکە قورستر دەکات، بەڵام هەروەها پشتپێبەستتریش دەکات."
            },
            {
              "language": "en",
              "text": "The plurality of perspectives makes the report more demanding, but also more robust."
            },
            {
              "language": "fa",
              "text": "تکثر دیدگاه‌ها گزارش را دشوارتر، اما قابل اتکاتر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pirrengiya perspektîfan raporê dijwartir dike, lê her wiha bihêztir jî dike."
            },
            {
              "language": "pl",
              "text": "Pluralizm perspektyw czyni raport bardziej wymagającym, ale też solidniejszym."
            },
            {
              "language": "ro",
              "text": "Pluralitatea perspectivelor face raportul mai complex, dar și mai solid."
            },
            {
              "language": "ru",
              "text": "Множественность перспектив делает отчет сложнее, но и надежнее."
            },
            {
              "language": "sq",
              "text": "Pluraliteti i perspektivave e bën raportin më kërkues, por edhe më të qëndrueshëm."
            },
            {
              "language": "tr",
              "text": "Perspektiflerin çoğulluğu raporu daha zorlu ama aynı zamanda daha sağlam kılar."
            }
          ]
        },
        {
          "baseText": "Eine demokratische Öffentlichkeit lebt von Pluralität, nicht von erzwungener Einigkeit.",
          "translations": [
            {
              "language": "ar",
              "text": "تعيش الساحة العامة الديمقراطية من التعددية لا من وحدة مفروضة."
            },
            {
              "language": "ckb",
              "text": "گشتییەتی دیموکراتیک بە فرەیی دەژی، نە بە یەکگرتوویی زۆرەملێ."
            },
            {
              "language": "en",
              "text": "A democratic public sphere lives from plurality, not from enforced unity."
            },
            {
              "language": "fa",
              "text": "عرصه عمومی دموکراتیک از تکثر زنده است، نه از وحدت تحمیلی."
            },
            {
              "language": "kmr",
              "text": "Qada giştî ya demokratîk bi pirrengiyê dijî, ne bi yekîtiya bi zorê."
            },
            {
              "language": "pl",
              "text": "Demokratyczna sfera publiczna żyje pluralizmem, a nie wymuszoną jednością."
            },
            {
              "language": "ro",
              "text": "O sferă publică democratică trăiește din pluralitate, nu din unitate impusă."
            },
            {
              "language": "ru",
              "text": "Демократическая публичная сфера живет множественностью, а не навязанным единством."
            },
            {
              "language": "sq",
              "text": "Sfera publike demokratike jeton nga pluraliteti, jo nga uniteti i detyruar."
            },
            {
              "language": "tr",
              "text": "Demokratik kamusal alan, zorlanmış birlikten değil çoğulluktan beslenir."
            }
          ]
        }
      ]
    },
