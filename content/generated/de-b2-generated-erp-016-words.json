      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; defined warehouse area or zone"
      ],
      "collocations": [
        {
          "text": "einen Lagerbereich sperren",
          "meaning": "to block a warehouse area"
        },
        {
          "text": "einen Lagerbereich zuweisen",
          "meaning": "to assign a warehouse area"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Lager",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Bereich",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "منطقة المستودع"
        },
        {
          "language": "ckb",
          "text": "بەشی کۆگا"
        },
        {
          "language": "en",
          "text": "warehouse area"
        },
        {
          "language": "fa",
          "text": "بخش انبار؛ محدوده انبار"
        },
        {
          "language": "kmr",
          "text": "qada embarê"
        },
        {
          "language": "pl",
          "text": "obszar magazynu"
        },
        {
          "language": "ro",
          "text": "zonă de depozit"
        },
        {
          "language": "ru",
          "text": "складская зона"
        },
        {
          "language": "sq",
          "text": "zonë magazine"
        },
        {
          "language": "tr",
          "text": "depo alanı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lagerbereich ist im ERP für Gefahrgut gesperrt.",
          "translations": [
            {
              "language": "ar",
              "text": "منطقة المستودع محظورة في ERP للبضائع الخطرة."
            },
            {
              "language": "ckb",
              "text": "بەشی کۆگا لە ERP دا بۆ کاڵای مەترسیدار قەدەغەکراوە."
            },
            {
              "language": "en",
              "text": "The warehouse area is blocked in the ERP for dangerous goods."
            },
            {
              "language": "fa",
              "text": "بخش انبار در ERP برای کالای خطرناک مسدود شده است."
            },
            {
              "language": "kmr",
              "text": "Qada embarê di ERP de ji bo malên metirsîdar hatiye astengkirin."
            },
            {
              "language": "pl",
              "text": "Obszar magazynu jest w ERP zablokowany dla towarów niebezpiecznych."
            },
            {
              "language": "ro",
              "text": "Zona de depozit este blocată în ERP pentru mărfuri periculoase."
            },
            {
              "language": "ru",
              "text": "Складская зона заблокирована в ERP для опасных грузов."
            },
            {
              "language": "sq",
              "text": "Zona e magazinës është e bllokuar në ERP për mallra të rrezikshme."
            },
            {
              "language": "tr",
              "text": "Depo alanı ERP’de tehlikeli maddeler için bloke edildi."
            }
          ]
        },
        {
          "baseText": "Bitte bringen Sie die Palette in den Lagerbereich für Retouren.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى نقل المنصة إلى منطقة المستودع الخاصة بالمرتجعات."
            },
            {
              "language": "ckb",
              "text": "تکایە پالێتەکە ببەنە بەشی کۆگای گەڕاوەکان."
            },
            {
              "language": "en",
              "text": "Please take the pallet to the warehouse area for returns."
            },
            {
              "language": "fa",
              "text": "لطفاً پالت را به بخش انبار مربوط به مرجوعی‌ها ببرید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe paletê bibin qada embarê ya vegerandinan."
            },
            {
              "language": "pl",
              "text": "Proszę przenieść paletę do obszaru magazynu dla zwrotów."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să duceți paletul în zona de depozit pentru retururi."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отнесите палету в складскую зону для возвратов."
            },
            {
              "language": "sq",
              "text": "Ju lutemi çojeni paletën në zonën e magazinës për kthime."
            },
            {
              "language": "tr",
              "text": "Lütfen paleti iadeler için ayrılan depo alanına götürün."
            }
          ]
        }
      ]
    },
    {
      "word": "Lagerort",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Lagerorte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "La-ger-ort",
      "topics": [
        "warehouse-and-logistics",
        "erp-and-business-systems",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; storage location or plant-level inventory location"
      ],
      "collocations": [
        {
          "text": "einen Lagerort anlegen",
          "meaning": "to create a storage location"
        },
        {
          "text": "den Lagerort ändern",
          "meaning": "to change the storage location"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Lager",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Ort",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موقع التخزين"
        },
        {
          "language": "ckb",
          "text": "شوێنی کۆگا"
        },
        {
          "language": "en",
          "text": "storage location"
        },
        {
          "language": "fa",
          "text": "محل انبار؛ مکان نگهداری"
        },
        {
          "language": "kmr",
          "text": "cihê embarê"
        },
        {
          "language": "pl",
          "text": "lokalizacja magazynowa"
        },
        {
          "language": "ro",
          "text": "locație de depozitare"
        },
        {
          "language": "ru",
          "text": "место хранения"
        },
        {
          "language": "sq",
          "text": "lokacion magazinimi"
        },
        {
          "language": "tr",
          "text": "depo yeri"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lagerort muss im ERP richtig gepflegt sein, sonst wird der Bestand falsch angezeigt.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب صيانة موقع التخزين بشكل صحيح في ERP، وإلا سيظهر المخزون بشكل خاطئ."
            },
            {
              "language": "ckb",
              "text": "شوێنی کۆگا پێویستە لە ERP دا بە دروستی ڕێکخرابێت، ئەگەر نا کۆگا بە هەڵە نیشان دەدرێت."
            },
            {
              "language": "en",
              "text": "The storage location must be maintained correctly in the ERP, otherwise the stock is displayed incorrectly."
            },
            {
              "language": "fa",
              "text": "محل انبار باید در ERP درست ثبت شود، وگرنه موجودی اشتباه نمایش داده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Cihê embarê divê di ERP de rast were parastin, wekî din stok şaş tê nîşandan."
            },
            {
              "language": "pl",
              "text": "Lokalizacja magazynowa musi być poprawnie utrzymana w ERP, inaczej stan będzie pokazany błędnie."
            },
            {
              "language": "ro",
              "text": "Locația de depozitare trebuie întreținută corect în ERP, altfel stocul este afișat greșit."
            },
            {
              "language": "ru",
              "text": "Место хранения должно быть правильно ведено в ERP, иначе запас отображается неверно."
            },
            {
              "language": "sq",
              "text": "Lokacioni i magazinimit duhet të mirëmbahet saktë në ERP, përndryshe stoku shfaqet gabim."
            },
            {
              "language": "tr",
              "text": "Depo yeri ERP’de doğru tutulmalıdır, aksi halde stok yanlış gösterilir."
            }
          ]
        },
        {
          "baseText": "Die Ware liegt am falschen Lagerort und muss umgebucht werden.",
          "translations": [
            {
              "language": "ar",
              "text": "البضاعة موجودة في موقع التخزين الخطأ ويجب إعادة ترحيلها."
            },
            {
              "language": "ckb",
              "text": "کاڵاکە لە شوێنی کۆگای هەڵەدایە و پێویستە دووبارە تۆمار بکرێت."
            },
            {
              "language": "en",
              "text": "The goods are in the wrong storage location and must be reposted."
            },
            {
              "language": "fa",
              "text": "کالا در محل انبار اشتباه است و باید جابه‌جایی ثبت شود."
            },
            {
              "language": "kmr",
              "text": "Mal li cihê embarê yê şaş e û divê ji nû ve were tomarkirin."
            },
            {
              "language": "pl",
              "text": "Towar znajduje się w niewłaściwej lokalizacji magazynowej i musi zostać przeksięgowany."
            },
            {
              "language": "ro",
              "text": "Marfa se află în locația de depozitare greșită și trebuie transferată contabil."
            },
            {
              "language": "ru",
              "text": "Товар находится в неправильном месте хранения и должен быть перепроведен."
            },
            {
              "language": "sq",
              "text": "Malli ndodhet në lokacionin e gabuar të magazinimit dhe duhet të regjistrohet sërish."
            },
            {
              "language": "tr",
              "text": "Mal yanlış depo yerinde ve yeniden kayıtla aktarılmalı."
            }
          ]
        }
      ]
    },
