        "planning-and-projects"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb; means to make a concept measurable or practically usable"
      ],
      "collocations": [
        {
          "text": "einen Begriff operationalisieren",
          "meaning": "to operationalize a concept"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Operationalisierung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "operational",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحوّل إلى مؤشرات قابلة للقياس؛ يجعل قابلاً للتطبيق"
        },
        {
          "language": "ckb",
          "text": "کردەیی دەکات؛ بە پێوەر دەگۆڕێت"
        },
        {
          "language": "en",
          "text": "to operationalize; to make measurable"
        },
        {
          "language": "fa",
          "text": "عملیاتی‌سازی کردن؛ قابل سنجش کردن"
        },
        {
          "language": "kmr",
          "text": "operationalîze kirin; pîvanbar kirin"
        },
        {
          "language": "pl",
          "text": "operacjonalizować"
        },
        {
          "language": "ro",
          "text": "a operaționaliza"
        },
        {
          "language": "ru",
          "text": "операционализировать"
        },
        {
          "language": "sq",
          "text": "të operacionalizosh"
        },
        {
          "language": "tr",
          "text": "operasyonelleştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bevor wir die Umfrage starten, müssen wir den Begriff Kundenzufriedenheit sauber operationalisieren.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل أن نبدأ الاستبيان، يجب أن نحوّل مفهوم رضا العملاء إلى مؤشرات قابلة للقياس بدقة."
            },
            {
              "language": "ckb",
              "text": "پێش ئەوەی پرسیارنامەکە دەست پێ بکەین، دەبێت چەمکی ڕەزامەندی کڕیار بە پاکی کردەیی بکەین."
            },
            {
              "language": "en",
              "text": "Before we start the survey, we need to operationalize the concept of customer satisfaction properly."
            },
            {
              "language": "fa",
              "text": "پیش از شروع نظرسنجی باید مفهوم رضایت مشتری را دقیق عملیاتی‌سازی کنیم."
            },
            {
              "language": "kmr",
              "text": "Berî ku em dest bi anketê bikin, divê têgeha razîbûna xerîdar bi paqijî operationalîze bikin."
            },
            {
              "language": "pl",
              "text": "Zanim rozpoczniemy ankietę, musimy poprawnie operacjonalizować pojęcie zadowolenia klienta."
            },
            {
              "language": "ro",
              "text": "Înainte să lansăm sondajul, trebuie să operaționalizăm corect conceptul de satisfacție a clienților."
            },
            {
              "language": "ru",
              "text": "Перед запуском опроса нужно корректно операционализировать понятие удовлетворенности клиентов."
            },
            {
              "language": "sq",
              "text": "Para se të nisim sondazhin, duhet ta operacionalizojmë saktë konceptin e kënaqësisë së klientit."
            },
            {
              "language": "tr",
              "text": "Anketi başlatmadan önce müşteri memnuniyeti kavramını düzgün biçimde operasyonelleştirmeliyiz."
            }
          ]
        },
        {
          "baseText": "Die Studie versucht, soziale Teilhabe nicht nur abstrakt zu beschreiben, sondern empirisch zu operationalisieren.",
          "translations": [
            {
              "language": "ar",
              "text": "تحاول الدراسة ألا تصف المشاركة الاجتماعية بشكل مجرد فقط، بل أن تجعلها قابلة للقياس تجريبياً."
            },
            {
              "language": "ckb",
              "text": "توێژینەوەکە هەوڵ دەدات بەشداری کۆمەڵایەتی تەنها بە شێوەیەکی ئەبستراکت وەسف نەکات، بەڵکو بە ئەزموونی کردەیی بکات."
            },
            {
              "language": "en",
              "text": "The study tries not only to describe social participation abstractly, but to operationalize it empirically."
            },
            {
              "language": "fa",
              "text": "این مطالعه تلاش می‌کند مشارکت اجتماعی را فقط انتزاعی توصیف نکند، بلکه آن را تجربی قابل سنجش کند."
            },
            {
              "language": "kmr",
              "text": "Lêkolîn hewl dide beşdariya civakî ne tenê abstrakt rave bike, lê bi empirîkî operationalîze bike."
            },
            {
              "language": "pl",
              "text": "Badanie próbuje nie tylko abstrakcyjnie opisać uczestnictwo społeczne, lecz także operacjonalizować je empirycznie."
            },
            {
              "language": "ro",
              "text": "Studiul încearcă nu doar să descrie abstract participarea socială, ci să o operaționalizeze empiric."
            },
            {
              "language": "ru",
              "text": "Исследование пытается не только абстрактно описать социальное участие, но и эмпирически операционализировать его."
            },
            {
              "language": "sq",
              "text": "Studimi përpiqet jo vetëm ta përshkruajë pjesëmarrjen shoqërore abstraktisht, por ta operacionalizojë empirikisht."
            },
            {
              "language": "tr",
              "text": "Çalışma sosyal katılımı yalnızca soyut biçimde tanımlamaya değil, ampirik olarak operasyonelleştirmeye çalışır."
            }
          ]
        }
      ]
    },
