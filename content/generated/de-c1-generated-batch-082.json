  "entries": [
    {
      "word": "operationalisieren",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "operationalisieren",
      "pronunciationIpa": null,
      "syllableBreak": "o-pe-ra-ti-o-na-li-sie-ren",
      "topics": [
