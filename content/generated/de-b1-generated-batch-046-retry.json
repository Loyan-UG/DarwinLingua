      "examples": [
        {
          "baseText": "Die Einleitung des Berichts sollte kurz und verständlich sein.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي أن تكون مقدمة التقرير قصيرة ومفهومة."
            },
            {
              "language": "ckb",
              "text": "پێشەکی ڕاپۆرتەکە دەبێت کورت و تێگەیشتوو بێت."
            },
            {
              "language": "en",
              "text": "The introduction of the report should be short and easy to understand."
            },
            {
              "language": "fa",
              "text": "مقدمه گزارش باید کوتاه و قابل فهم باشد."
            },
            {
              "language": "kmr",
              "text": "Pêşgotina raporê divê kurt û têgihiştî be."
            },
            {
              "language": "pl",
              "text": "Wstęp raportu powinien być krótki i zrozumiały."
            },
            {
              "language": "ro",
              "text": "Introducerea raportului ar trebui să fie scurtă și ușor de înțeles."
            },
            {
              "language": "ru",
              "text": "Введение отчета должно быть коротким и понятным."
            },
            {
              "language": "sq",
              "text": "Hyrja e raportit duhet të jetë e shkurtër dhe e kuptueshme."
            },
            {
              "language": "tr",
              "text": "Raporun girişi kısa ve anlaşılır olmalıdır."
            }
          ]
        },
        {
          "baseText": "Nach einer kurzen Einleitung beginnt die Trainerin mit den Übungen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد مقدمة قصيرة تبدأ المدربة بالتمارين."
            },
            {
              "language": "ckb",
              "text": "دوای پێشەکییەکی کورت ڕاهێنەرە ژنەکە دەست بە مەشقەکان دەکات."
            },
            {
              "language": "en",
              "text": "After a short introduction, the trainer starts with the exercises."
            },
            {
              "language": "fa",
              "text": "بعد از یک مقدمه کوتاه، مربی تمرین‌ها را شروع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Piştî pêşgotineke kurt, rahênera jin bi xebatan dest pê dike."
            },
            {
              "language": "pl",
              "text": "Po krótkim wprowadzeniu trenerka zaczyna ćwiczenia."
            },
            {
              "language": "ro",
              "text": "După o scurtă introducere, instructoarea începe exercițiile."
            },
            {
              "language": "ru",
              "text": "После короткого введения тренер начинает упражнения."
            },
            {
              "language": "sq",
              "text": "Pas një hyrjeje të shkurtër, trajnerja fillon ushtrimet."
            },
            {
              "language": "tr",
              "text": "Kısa bir girişten sonra eğitmen alıştırmalara başlar."
            }
          ]
        }
      ]
    }
