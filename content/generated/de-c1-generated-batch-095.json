      "word": "die Sekundäranalyse",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Sekundäranalysen",
      "infinitive": null,
      "syllableBreak": "Se-kun-där-a-na-ly-se",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun; research term"
      ],
      "collocations": [
        {
          "text": "eine Sekundäranalyse durchführen",
          "meaning": "to conduct a secondary analysis"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sekundär",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Analyse",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تحليل ثانوي لبيانات موجودة"
        },
        {
          "language": "ckb",
          "text": "شیکردنەوەی دووەم؛ شیکردنەوەی داتای ئامادە"
        },
        {
          "language": "en",
          "text": "secondary analysis"
        },
        {
          "language": "fa",
          "text": "تحلیل ثانویه؛ تحلیل داده‌های موجود"
        },
        {
          "language": "kmr",
          "text": "analîza duyemîn"
        },
        {
          "language": "pl",
          "text": "analiza wtórna"
        },
        {
          "language": "ro",
          "text": "analiză secundară"
        },
        {
          "language": "ru",
          "text": "вторичный анализ"
        },
        {
          "language": "sq",
          "text": "analizë dytësore"
        },
        {
          "language": "tr",
          "text": "ikincil analiz"
        }
      ],
      "examples": [
        {
          "baseText": "Die Sekundäranalyse nutzt vorhandene Umfragedaten, um neue Forschungsfragen zu beantworten.",
          "translations": [
            {
              "language": "ar",
              "text": "يستخدم التحليل الثانوي بيانات استطلاع موجودة للإجابة عن أسئلة بحثية جديدة."
            },
            {
              "language": "ckb",
              "text": "شیکردنەوەی دووەم داتای پرسیارنامەی ئامادە بەکاردەهێنێت بۆ وەڵامدانەوەی پرسیاری توێژینەوەی نوێ."
            },
            {
              "language": "en",
              "text": "The secondary analysis uses existing survey data to answer new research questions."
            },
            {
              "language": "fa",
              "text": "تحلیل ثانویه از داده‌های نظرسنجی موجود برای پاسخ به پرسش‌های پژوهشی جدید استفاده می‌کند."
            },
            {
              "language": "kmr",
              "text": "Analîza duyemîn daneyên anketê yên heyî bikar tîne da ku bersiva pirsên nû yên lêkolînê bide."
            },
            {
              "language": "pl",
              "text": "Analiza wtórna wykorzystuje istniejące dane ankietowe, aby odpowiedzieć na nowe pytania badawcze."
            },
            {
              "language": "ro",
              "text": "Analiza secundară folosește date de sondaj existente pentru a răspunde la noi întrebări de cercetare."
            },
            {
              "language": "ru",
              "text": "Вторичный анализ использует существующие данные опросов для ответа на новые исследовательские вопросы."
            },
            {
              "language": "sq",
              "text": "Analiza dytësore përdor të dhëna ekzistuese të sondazhit për t’iu përgjigjur pyetjeve të reja kërkimore."
            },
            {
              "language": "tr",
              "text": "İkincil analiz, yeni araştırma sorularını yanıtlamak için mevcut anket verilerini kullanır."
            }
          ]
        },
        {
          "baseText": "Für den Marktbericht reicht zunächst eine Sekundäranalyse öffentlich verfügbarer Quellen.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة إلى تقرير السوق يكفي في البداية تحليل ثانوي للمصادر المتاحة علناً."
            },
            {
              "language": "ckb",
              "text": "بۆ ڕاپۆرتی بازاڕ سەرەتا شیکردنەوەی دووەمی سەرچاوە ئاشکراکان بەسە."
            },
            {
              "language": "en",
              "text": "For the market report, a secondary analysis of publicly available sources is sufficient at first."
            },
            {
              "language": "fa",
              "text": "برای گزارش بازار، فعلاً تحلیل ثانویه منابع عمومی کافی است."
            },
            {
              "language": "kmr",
              "text": "Ji bo rapora bazarê di destpêkê de analîza duyemîn a çavkaniyên giştî bes e."
            },
            {
              "language": "pl",
              "text": "Do raportu rynkowego na początek wystarczy analiza wtórna publicznie dostępnych źródeł."
            },
            {
              "language": "ro",
              "text": "Pentru raportul de piață este suficientă inițial o analiză secundară a surselor publice."
            },
            {
              "language": "ru",
              "text": "Для рыночного отчета сначала достаточно вторичного анализа общедоступных источников."
            },
            {
              "language": "sq",
              "text": "Për raportin e tregut mjafton fillimisht një analizë dytësore e burimeve publike."
            },
            {
              "language": "tr",
              "text": "Pazar raporu için başlangıçta kamuya açık kaynakların ikincil analizi yeterlidir."
            }
          ]
        }
      ]
    },
