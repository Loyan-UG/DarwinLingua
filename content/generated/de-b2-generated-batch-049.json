      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بازکردن؛ آغاز کردن"
        },
        {
          "language": "ckb",
          "text": "کردنەوە؛ دەستپێکردن"
        },
        {
          "language": "en",
          "text": "break open; start"
        },
        {
          "language": "fa",
          "text": "باز کردن؛ آغاز کردن"
        },
        {
          "language": "kmr",
          "text": "veşartin; dest pê kirin"
        },
        {
          "language": "pl",
          "text": "otwierać; rozpoczynać"
        },
        {
          "language": "ro",
          "text": "a deschide; a începe"
        },
        {
          "language": "ru",
          "text": "вскрывать; начинать"
        },
        {
          "language": "sq",
          "text": "shkulur; filluar"
        },
        {
          "language": "tr",
          "text": "açmak; başlatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Sicherheitsfreigabe wurde der verschlossene Container aufgebrochen.",
          "translations": [
            {
              "language": "ar",
              "text": "پس از تایید ایمنی، کانتینر قفل‌شده باز شد."
            },
            {
              "language": "ckb",
              "text": "دوای ڕێگەپێدانی سەلەمی، کانتینەری داخراوەکە بانگێ کرایەوە."
            },
            {
              "language": "en",
              "text": "After the safety approval, the locked container was opened."
            },
            {
              "language": "fa",
              "text": "پس از تایید ایمنی، کانتینر قفل‌شده باز شد."
            },
            {
              "language": "kmr",
              "text": "Piştî destûra ewlehiyê, konteynêrê kilîdkirî hate vekirin."
            },
            {
              "language": "pl",
              "text": "Po zatwierdzeniu bezpieczeństwa zamknięty kontener został otwarty."
            },
            {
              "language": "ro",
              "text": "După aprobarea de siguranță, containerul încuiat a fost deschis."
            },
            {
              "language": "ru",
              "text": "После разрешения службы безопасности закрытый контейнер был вскрыт."
            },
            {
              "language": "sq",
              "text": "Pas miratimit të sigurisë, kontejneri i kyçur u hap."
            },
            {
              "language": "tr",
              "text": "Güvenlik onayı sonrası kilitli konteyner açıldı."
            }
          ]
        },
        {
          "baseText": "Das Team bricht um acht Uhr die Sprint-Planung auf.",
          "translations": [
            {
              "language": "ar",
              "text": "تیم در ساعت هشت برنامه‌ریزی اسپرینت را شروع می‌کند."
            },
            {
              "language": "ckb",
              "text": "تیمەکە کاتژمێر هەشت پلانى سپڕینت دەدەستێنێت."
            },
            {
              "language": "en",
              "text": "The team starts the sprint planning at eight o'clock."
            },
            {
              "language": "fa",
              "text": "تیم برنامه‌ریزی اسپرینت را ساعت هشت شروع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Kom têketina planên sprintê di saeta hêt de dest pê dike."
            },
            {
              "language": "pl",
              "text": "Zespół rozpoczyna planowanie sprintu o ósmej."
            },
            {
              "language": "ro",
              "text": "Echipa începe planificarea sprintului la opt ore."
            },
            {
              "language": "ru",
              "text": "Команда начинает планирование спринта в восемь часов."
            },
            {
              "language": "sq",
              "text": "Ekipi fillon planifikimin e sprintit në orën tetë."
            },
            {
              "language": "tr",
              "text": "Ekip saat sekizde sprint planlamasına başlar."
            }
          ]
        }
      ]
    },
