          "note": "3rd person singular present"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نفخ؛ مبالغه"
        },
        {
          "language": "ckb",
          "text": "فەراوانکردن؛ گەورەکردن"
        },
        {
          "language": "en",
          "text": "inflate; exaggerate"
        },
        {
          "language": "fa",
          "text": "تورم دادن؛ اغراق کردن"
        },
        {
          "language": "kmr",
          "text": "tijîtin; dirêjkirin"
        },
        {
          "language": "pl",
          "text": "nadmuchać; wyolbrzymiać"
        },
        {
          "language": "ro",
          "text": "a umfla; a exagera"
        },
        {
          "language": "ru",
          "text": "надуть; приукрашивать"
        },
        {
          "language": "sq",
          "text": "fryjshëm; ekzagjeruar"
        },
        {
          "language": "tr",
          "text": "şişirmek; abartmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Servicetechniker hat den Reifen vor der Abfahrt aufgeblasen.",
          "translations": [
            {
              "language": "ar",
              "text": "ضخّق تکنسین سرویس تایر را قبل از حرکت باد کرد."
            },
            {
              "language": "ckb",
              "text": "تەکنیکی سرویسەکە پێشەوە چەقەکەی خاو دەکەیت."
            },
            {
              "language": "en",
              "text": "The service technician inflated the tire before departure."
            },
            {
              "language": "fa",
              "text": "تکنسین سرویس، پیش از حرکت، لاستیک را باد کرد."
            },
            {
              "language": "kmr",
              "text": "Teknîsyena servîsê berî derxistinê berhevkariya çêkir."
            },
            {
              "language": "pl",
              "text": "Technik serwisowy napompował oponę przed wyjazdem."
            },
            {
              "language": "ro",
              "text": "Tehnicianul de service a umflat pneul înainte de plecare."
            },
            {
              "language": "ru",
              "text": "Техник обслуживания накачал шину перед выездом."
            },
            {
              "language": "sq",
              "text": "Tekniku i shërbimit mbushi gomën para nisjes."
            },
            {
              "language": "tr",
              "text": "Servis teknisyeni ayrılmadan önce lastiği şişirdi."
            }
          ]
        },
        {
          "baseText": "Bitte blasen Sie die Kosten nicht unnötig auf.",
          "translations": [
            {
              "language": "ar",
              "text": "لطفاً هزینه‌ها را بی‌دلیل بزرگ نکنید."
            },
            {
              "language": "ckb",
              "text": "تكایه خەرجیەکان بەبێ هۆکارە بێزار مەکە."
            },
            {
              "language": "en",
              "text": "Please do not overstate the costs without reason."
            },
            {
              "language": "fa",
              "text": "لطفاً هزینه‌ها را بدون دلیل بزرگ‌نمایی نکنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe derfetên xercanî bê hêvî mezin nekî."
            },
            {
              "language": "pl",
              "text": "Proszę nie wyolbrzymiać kosztów bez powodu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să nu exagerați costurile fără motiv."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не раздувайте расходы без необходимости."
            },
            {
              "language": "sq",
              "text": "Ju lutemi, mos i fryjsojini shpenzimet pa nevojë."
            },
            {
              "language": "tr",
              "text": "Lütfen giderleri gereksiz yere abartmayın."
            }
          ]
        }
      ]
    },
