        },
        {
          "language": "tr",
          "text": "özgürlük"
        }
      ],
      "examples": [
        {
          "baseText": "Für viele Menschen ist persönliche Freiheit sehr wichtig.",
          "translations": [
            {
              "language": "ar",
              "text": "الحرية الشخصية مهمة جدًا لكثير من الناس."
            },
            {
              "language": "ckb",
              "text": "بۆ زۆر کەس ئازادیی کەسی زۆر گرنگە."
            },
            {
              "language": "en",
              "text": "Personal freedom is very important to many people."
            },
            {
              "language": "fa",
              "text": "برای بسیاری از مردم آزادی شخصی بسیار مهم است."
            },
            {
              "language": "kmr",
              "text": "Ji bo gelek kesan azadiya kesane pir girîng e."
            },
            {
              "language": "pl",
              "text": "Dla wielu ludzi wolność osobista jest bardzo ważna."
            },
            {
              "language": "ro",
              "text": "Pentru mulți oameni libertatea personală este foarte importantă."
            },
            {
              "language": "ru",
              "text": "Для многих людей личная свобода очень важна."
            },
            {
              "language": "sq",
              "text": "Për shumë njerëz liria personale është shumë e rëndësishme."
            },
            {
              "language": "tr",
              "text": "Birçok insan için kişisel özgürlük çok önemlidir."
            }
          ]
        },
        {
          "baseText": "Flexible Arbeitszeiten geben den Mitarbeitenden mehr Freiheit im Alltag.",
          "translations": [
            {
              "language": "ar",
              "text": "تمنح ساعات العمل المرنة الموظفين حرية أكبر في الحياة اليومية."
            },
            {
              "language": "ckb",
              "text": "کاتی کاری نەرم ئازادیی زیاتر بە کارمەندان لە ژیانی ڕۆژانەدا دەدات."
            },
            {
              "language": "en",
              "text": "Flexible working hours give employees more freedom in everyday life."
            },
            {
              "language": "fa",
              "text": "ساعت‌های کاری انعطاف‌پذیر در زندگی روزمره آزادی بیشتری به کارکنان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Demên karê yên nerm azadiyeke zêdetir di jiyana rojane de didin karmendan."
            },
            {
              "language": "pl",
              "text": "Elastyczne godziny pracy dają pracownikom więcej wolności na co dzień."
            },
            {
              "language": "ro",
              "text": "Programul flexibil le oferă angajaților mai multă libertate în viața de zi cu zi."
            },
            {
              "language": "ru",
              "text": "Гибкий график дает сотрудникам больше свободы в повседневной жизни."
            },
            {
              "language": "sq",
              "text": "Orari fleksibël u jep punonjësve më shumë liri në përditshmëri."
            },
            {
              "language": "tr",
              "text": "Esnek çalışma saatleri çalışanlara günlük yaşamda daha fazla özgürlük sağlar."
            }
          ]
        }
      ]
    },
