      "meanings": [
        {
          "language": "ar",
          "text": "متابعة الرحلة؛ رحلة المتابعة"
        },
        {
          "language": "ckb",
          "text": "بەردەوامی گەشت"
        },
        {
          "language": "en",
          "text": "onward journey; continuation of travel"
        },
        {
          "language": "fa",
          "text": "ادامه سفر؛ ادامه مسیر"
        },
        {
          "language": "kmr",
          "text": "berdewamiya rêwîtiyê"
        },
        {
          "language": "pl",
          "text": "dalsza podróż"
        },
        {
          "language": "ro",
          "text": "continuarea călătoriei"
        },
        {
          "language": "ru",
          "text": "дальнейшая поездка"
        },
        {
          "language": "sq",
          "text": "vazhdimi i udhëtimit"
        },
        {
          "language": "tr",
          "text": "yolculuğun devamı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Weiterfahrt ist erst morgen möglich.",
          "translations": [
            {
              "language": "ar",
              "text": "متابعة الرحلة ممكنة فقط غداً."
            },
            {
              "language": "ckb",
              "text": "بەردەوامی گەشتەکە تەنها سبەی دەکرێت."
            },
            {
              "language": "en",
              "text": "The onward journey is only possible tomorrow."
            },
            {
              "language": "fa",
              "text": "ادامه سفر فقط فردا ممکن است."
            },
            {
              "language": "kmr",
              "text": "Berdewamiya rêwîtiyê tenê sibê gengaz e."
            },
            {
              "language": "pl",
              "text": "Dalsza podróż jest możliwa dopiero jutro."
            },
            {
              "language": "ro",
              "text": "Continuarea călătoriei este posibilă abia mâine."
            },
            {
              "language": "ru",
              "text": "Продолжение поездки возможно только завтра."
            },
            {
              "language": "sq",
              "text": "Vazhdimi i udhëtimit është i mundur vetëm nesër."
            },
            {
              "language": "tr",
              "text": "Yolculuğun devamı ancak yarın mümkün."
            }
          ]
        },
        {
          "baseText": "Bitte zeigen Sie Ihr Ticket für die Weiterfahrt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إظهار تذكرتكم لمتابعة الرحلة."
            },
            {
              "language": "ckb",
              "text": "تکایە بلیتەکەتان بۆ بەردەوامی گەشتەکە پیشان بدەن."
            },
            {
              "language": "en",
              "text": "Please show your ticket for the onward journey."
            },
            {
              "language": "fa",
              "text": "لطفاً بلیت ادامه مسیر را نشان دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe bilêta xwe ji bo berdewamiya rêwîtiyê nîşan bidin."
            },
            {
              "language": "pl",
              "text": "Proszę pokazać bilet na dalszą podróż."
            },
            {
              "language": "ro",
              "text": "Vă rog să arătați biletul pentru continuarea călătoriei."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, покажите билет для дальнейшей поездки."
            },
            {
              "language": "sq",
              "text": "Ju lutem tregoni biletën për vazhdimin e udhëtimit."
            },
            {
              "language": "tr",
              "text": "Lütfen devam yolculuğu için biletinizi gösterin."
            }
          ]
        }
      ]
    },
