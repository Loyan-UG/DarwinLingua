      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يواصل السير؛ يتابع الرحلة"
        },
        {
          "language": "ckb",
          "text": "بەردەوام دەبێت لە ڕۆیشتن"
        },
        {
          "language": "en",
          "text": "to continue driving/traveling"
        },
        {
          "language": "fa",
          "text": "به مسیر ادامه دادن"
        },
        {
          "language": "kmr",
          "text": "berdewam ajotin; berdewam çûn"
        },
        {
          "language": "pl",
          "text": "jechać dalej"
        },
        {
          "language": "ro",
          "text": "a continua drumul"
        },
        {
          "language": "ru",
          "text": "ехать дальше; продолжать путь"
        },
        {
          "language": "sq",
          "text": "të vazhdosh udhëtimin"
        },
        {
          "language": "tr",
          "text": "yola devam etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Pause fahren wir weiter.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الاستراحة نتابع الطريق."
            },
            {
              "language": "ckb",
              "text": "دوای پشوودانەکە بەردەوام دەبین لە ڕۆیشتن."
            },
            {
              "language": "en",
              "text": "After the break, we continue our trip."
            },
            {
              "language": "fa",
              "text": "بعد از استراحت به مسیر ادامه می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Piştî bêhnvedanê em berdewam diçin."
            },
            {
              "language": "pl",
              "text": "Po przerwie jedziemy dalej."
            },
            {
              "language": "ro",
              "text": "După pauză continuăm drumul."
            },
            {
              "language": "ru",
              "text": "После перерыва мы едем дальше."
            },
            {
              "language": "sq",
              "text": "Pas pushimit vazhdojmë udhëtimin."
            },
            {
              "language": "tr",
              "text": "Moladan sonra yola devam ediyoruz."
            }
          ]
        },
        {
          "baseText": "Der Zug kann wegen des Unfalls nicht weiterfahren.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يستطيع القطار متابعة السير بسبب الحادث."
            },
            {
              "language": "ckb",
              "text": "شەمەندەفەرەکە بەهۆی ڕووداوەکە ناتوانێت بەردەوام بێت."
            },
            {
              "language": "en",
              "text": "The train cannot continue because of the accident."
            },
            {
              "language": "fa",
              "text": "قطار به خاطر حادثه نمی‌تواند ادامه مسیر دهد."
            },
            {
              "language": "kmr",
              "text": "Trên ji ber qezayê nikare berdewam bike."
            },
            {
              "language": "pl",
              "text": "Pociąg nie może jechać dalej z powodu wypadku."
            },
            {
              "language": "ro",
              "text": "Trenul nu poate continua din cauza accidentului."
            },
            {
              "language": "ru",
              "text": "Поезд не может ехать дальше из-за аварии."
            },
            {
              "language": "sq",
              "text": "Treni nuk mund të vazhdojë për shkak të aksidentit."
            },
            {
              "language": "tr",
              "text": "Tren kaza nedeniyle devam edemiyor."
            }
          ]
        }
      ]
    },
