      "meanings": [
        {
          "language": "ar",
          "text": "يحوّل؛ يمرر"
        },
        {
          "language": "ckb",
          "text": "دەگوازێتەوە؛ فۆروارد دەکات"
        },
        {
          "language": "en",
          "text": "to forward; to pass on"
        },
        {
          "language": "fa",
          "text": "ارسال مجدد کردن؛ ارجاع دادن"
        },
        {
          "language": "kmr",
          "text": "pêşve şandin; veguhestin"
        },
        {
          "language": "pl",
          "text": "przekazywać; przekierować"
        },
        {
          "language": "ro",
          "text": "a redirecționa; a transmite mai departe"
        },
        {
          "language": "ru",
          "text": "пересылать; перенаправлять"
        },
        {
          "language": "sq",
          "text": "të përcjellësh; të ridërgosh"
        },
        {
          "language": "tr",
          "text": "iletmek; yönlendirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich leite Ihre E-Mail an den Service weiter.",
          "translations": [
            {
              "language": "ar",
              "text": "سأحول بريدكم الإلكتروني إلى قسم الخدمة."
            },
            {
              "language": "ckb",
              "text": "ئیمەیڵەکەتان بۆ بەشی خزمەتگوزاری دەگوازمەوە."
            },
            {
              "language": "en",
              "text": "I will forward your email to the service department."
            },
            {
              "language": "fa",
              "text": "ایمیل شما را به بخش خدمات ارجاع می‌دهم."
            },
            {
              "language": "kmr",
              "text": "Ez e-nameya we ji bo beşa xizmetê pêşve dişînim."
            },
            {
              "language": "pl",
              "text": "Przekażę państwa e-mail do serwisu."
            },
            {
              "language": "ro",
              "text": "Redirecționez e-mailul dumneavoastră către service."
            },
            {
              "language": "ru",
              "text": "Я перешлю ваше письмо в службу поддержки."
            },
            {
              "language": "sq",
              "text": "Do ta përcjell emailin tuaj te shërbimi."
            },
            {
              "language": "tr",
              "text": "E-postanızı servis bölümüne yönlendiriyorum."
            }
          ]
        },
        {
          "baseText": "Bitte leiten Sie die Nachricht an Frau Keller weiter.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تمرير الرسالة إلى السيدة كيلر."
            },
            {
              "language": "ckb",
              "text": "تکایە پەیامەکە بۆ خانمی کێلەر بنێرنەوە."
            },
            {
              "language": "en",
              "text": "Please forward the message to Ms. Keller."
            },
            {
              "language": "fa",
              "text": "لطفاً پیام را برای خانم کلر ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe peyamê ji bo xanim Keller pêşve bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przekazać wiadomość pani Keller."
            },
            {
              "language": "ro",
              "text": "Vă rog să transmiteți mesajul doamnei Keller."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, перешлите сообщение госпоже Келлер."
            },
            {
              "language": "sq",
              "text": "Ju lutem përcilljani mesazhin zonjës Keller."
            },
            {
              "language": "tr",
              "text": "Lütfen mesajı Bayan Keller’e iletin."
            }
          ]
        }
      ]
