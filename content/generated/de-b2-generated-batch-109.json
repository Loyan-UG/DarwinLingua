          "text": "uygunluk; oranlılık"
        }
      ],
      "examples": [
        {
          "baseText": "Die Angemessenheit des Preises wurde im Vertrag klar festgelegt.",
          "translations": [
            {
              "language": "ar",
              "text": "معقولیت قیمت در قرارداد به‌طور شفاف تعیین شده است."
            },
            {
              "language": "ckb",
              "text": "گونجاوی بەهاکە بەڕاستی لە قراردادەکەدا دیاری کراوە."
            },
            {
              "language": "en",
              "text": "The appropriateness of the price is clearly defined in the contract."
            },
            {
              "language": "fa",
              "text": "تناسب قیمت در قرارداد به‌طور واضح تعیین شده است."
            },
            {
              "language": "kmr",
              "text": "Güneyazîya bihayê bi hêvî di peymanê de diyar e."
