      "examples": [
        {
          "baseText": "Wir haben dem Großkunden gestern ein Angebot für das neue Logging-Modul geschickt.",
          "translations": [
            {
              "language": "ar",
              "text": "دیروز یک پیشنهاد برای ماژول جدید گزارش‌گیری برای مشتری بزرگ فرستادیم."
            },
            {
              "language": "ckb",
              "text": "دوێنێن پێشنیارێک بۆ ماژۆلی نوێی تۆمارەکان بۆ کڕیاری گەورە نێردووە."
            },
            {
              "language": "en",
              "text": "We sent an offer for the new logging module to the key customer yesterday."
            },
            {
              "language": "fa",
              "text": "دیروز یک پیشنهاد برای ماژول جدید گزارش‌گیری را برای مشتری بزرگ‌مان ارسال کردیم."
            },
            {
              "language": "kmr",
              "text": "Dîrokaşî em bo xerîdara mezin pêşniyarek ji bo navçeya nû ya logging şand."
            },
            {
              "language": "pl",
              "text": "Wczoraj wysłaliśmy kluczowemu klientowi ofertę na nowy moduł logowania."
            },
            {
              "language": "ro",
              "text": "Ieri am trimis clientului important o ofertă pentru noul modul de jurnalizare."
            },
            {
              "language": "ru",
              "text": "Вчера мы отправили ключевому клиенту предложение по новому модулю логирования."
            },
            {
              "language": "sq",
              "text": "Dje i dërguam klientit kryesor një ofertë për modulin e ri të regjistrimit."
            },
            {
              "language": "tr",
              "text": "Dün, ana müşteriye yeni günlüğe alma modülü için bir teklif gönderdik."
            }
          ]
        },
        {
          "baseText": "Bitte geben Sie dem Kunden ein konkretes Angebot und einen Liefertermin.",
          "translations": [
            {
              "language": "ar",
              "text": "لطفاً یک پیشنهاد مشخص و تاریخ تحویل به مشتری ارائه دهید."
            },
            {
              "language": "ckb",
              "text": "تکایە بۆ کڕیارەکە پێشنیاری دیاریکراو و ڕۆژێکی گەیاندن بنووسە."
            },
            {
              "language": "en",
              "text": "Please provide the customer with a concrete offer and a delivery date."
            },
            {
              "language": "fa",
              "text": "لطفاً برای مشتری یک پیشنهاد مشخص و تاریخ تحویل ارائه دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe re ji xerîdarê pêşniyarek rast û dîroka teslimê bikin."
            },
            {
              "language": "pl",
              "text": "Proszę przygotować klientowi konkretną ofertę i termin dostawy."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să oferiți clientului o ofertă clară și o dată de livrare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, предоставьте клиенту конкретное предложение и срок поставки."
            },
            {
              "language": "sq",
              "text": "Ju lutemi jepuni klientit një ofertë konkrete dhe një afat dorëzimi."
            },
            {
              "language": "tr",
              "text": "Lütfen müşteriye net bir teklif ve teslimat tarihi verin."
            }
          ]
        }
      ]
