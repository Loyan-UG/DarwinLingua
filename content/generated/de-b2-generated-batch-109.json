      "examples": [
        {
          "baseText": "Wir gehen das Sicherheitsproblem in der nächsten Sprint-Sitzung an.",
          "translations": [
            {
              "language": "ar",
              "text": "ما این مسئله امنیتی را در جلسه اسپرینت بعدی بررسی می‌کنیم."
            },
            {
              "language": "ckb",
              "text": "ئێمە کێشەی سەلامەتیەکە لە کۆبوونەوەی سِپرینتی داهاتوودا دەگرتوو دەچین."
            },
            {
              "language": "en",
              "text": "We will tackle the security issue in the next sprint meeting."
            },
            {
              "language": "fa",
              "text": "در جلسه اسپرینت بعدی، این موضوع امنیتی را بررسی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em ê pirsa ewlekarî di civîna sprint a paşîn de ber xwe bîne."
