          "translations": [
            {
              "language": "ar",
              "text": "لطفاً قبل از اطلاع‌رسانی به مشتری، ابتدا موضوع شکایت را بررسی کنید."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش ئەوەی کڕیار ئاگادار بکەیت، سوڕەکەی شکوە بەخۆی ناوخۆیی بکە."
            },
            {
              "language": "en",
              "text": "Please handle the complaint case internally first, then inform the customer."
