  "entries": [
    {
      "word": "anfahren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anfahren",
      "pronunciationIpa": null,
      "syllableBreak": "an-fah-ren",
      "topics": [
        "technology-and-it",
        "quality-and-risk",
        "work-and-jobs"
      ],
      "usageLabels": [
        "technical",
        "workplace",
        "written"
      ],
      "contextLabels": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الانطلاق؛ البدء"
        },
        {
          "language": "ckb",
          "text": "دەستپێکردن؛ ڕەوت کردن"
        },
        {
          "language": "en",
          "text": "to start up; to begin moving"
        },
        {
          "language": "fa",
          "text": "راه‌اندازی کردن؛ حرکت کردن"
        },
        {
          "language": "kmr",
          "text": "destpê kirin; dest bi kirin"
        },
        {
          "language": "pl",
          "text": "uruchamiać; ruszać"
        },
        {
          "language": "ro",
          "text": "a porni; a se pune în mișcare"
        },
        {
          "language": "ru",
          "text": "запускать; начинать движение"
        },
        {
          "language": "sq",
          "text": "të ndizet; të nisë lëvizjen"
        },
        {
          "language": "tr",
          "text": "başlatmak; harekete geçirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lieferwagen fährt langsam an, als die Ampel grün wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "وقفت الشاحنة الصغيرة ببطء عندما تحولت الإشارة إلى اللون الأخضر."
            },
            {
              "language": "ckb",
              "text": "فەراوی پارەوە بە خێرایی دەفڕێت کە تەختەسەرەنگە سەوز بوو."
            },
            {
              "language": "en",
              "text": "The delivery van started moving slowly when the light turned green."
            },
            {
              "language": "fa",
              "text": "وانت وقتی چراغ سبز شد، به‌آرامی به حرکت در آمد."
            },
            {
              "language": "kmr",
              "text": "Fira şandina hêdî dest pê kir ku ronahîyê sîyâh bû."
            },
            {
              "language": "pl",
              "text": "Furgonetka powoli ruszyła, gdy sygnalizacja zmieniła się na zielone."
            },
            {
              "language": "ro",
              "text": "Autoutilitara a pornit încet când semaforul a devenit verde."
            },
            {
              "language": "ru",
              "text": "Грузовик-\"ван\" плавно тронулся, когда светофор стал зелёным."
            },
            {
              "language": "sq",
              "text": "Furgoni nisi ngadalë të niset kur sinjali u bë i gjelbër."
            },
            {
              "language": "tr",
              "text": "Işık yeşile dönünce teslimat aracı yavaşça harekete geçti."
            }
          ]
        },
        {
          "baseText": "Nach dem Deployment fährt der neue Service automatisch an.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد النشر، تبدأ الخدمة الجديدة في التشغيل تلقائياً."
            },
            {
              "language": "ckb",
              "text": "دوای بەرزکردنەوە، خزمەتگوزاریەکی نوێ خۆکارانە دەستپێدەکات."
            },
            {
              "language": "en",
              "text": "After deployment, the new service starts automatically."
            },
            {
              "language": "fa",
              "text": "پس از استقرار، سرویس جدید به صورت خودکار راه‌اندازی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Piştî belavbûnê, karûbarê nû xweber dest pê dike."
            },
            {
              "language": "pl",
              "text": "Po wdrożeniu nowa usługa uruchamia się automatycznie."
            },
            {
              "language": "ro",
              "text": "După implementare, serviciul nou pornește automat."
            },
            {
              "language": "ru",
              "text": "После внедрения новый сервис автоматически запускается."
            },
            {
              "language": "sq",
              "text": "Pas vendosjes, shërbimi i ri fillon automatikisht."
            },
            {
              "language": "tr",
              "text": "Dağıtımdan sonra yeni hizmet otomatik olarak başlar."
            }
          ]
        }
      ]
    },
    {
      "word": "anfallen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anfallen",
      "pronunciationIpa": null,
      "syllableBreak": "an-fal-len",
      "topics": [
        "finance-and-accounting",
        "planning-and-projects",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "written",
        "analysis"
      ],
      "contextLabels": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحدث أو يقع؛ ينجم عن"
        },
        {
          "language": "ckb",
          "text": "دەرچووی داهات بۆ"
        },
        {
          "language": "en",
          "text": "to incur; to come as a result of"
        },
        {
          "language": "fa",
          "text": "تحمیل شدن؛ به‌دست آمدن"
        },
        {
          "language": "kmr",
          "text": "berdayîn; derbasbûn ji"
        },
        {
          "language": "pl",
          "text": "napotykać; powstawać"
        },
        {
          "language": "ro",
          "text": "a surveni; a apărea"
        },
        {
          "language": "ru",
          "text": "возникать; подвергаться"
        },
        {
          "language": "sq",
          "text": "të paraqiten; të shfaqen"
        },
        {
          "language": "tr",
          "text": "ortaya çıkmak; düşmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bei kurzfristiger Kündigung fallen dem Kunden zusätzliche Kosten an.",
          "translations": [
            {
              "language": "ar",
              "text": "عند الإلغاء في آخر لحظة، تتحمل الشركة تكاليف إضافية."
            },
            {
              "language": "ckb",
              "text": "لە ھەنگاوی هەڵبژاردنی کورتەوەی پێچەوانەیە، خەرجی زیاتر دەسەری کڕیار دێت."
            },
            {
              "language": "en",
              "text": "If the contract is canceled at short notice, additional costs fall to the customer."
            },
            {
              "language": "fa",
              "text": "در صورت لغو فوری، هزینه‌های اضافی به مشتری تحمیل می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ger peyman bi demekî kurt betal bû, lêdûrî li ser xerîdarê zêde dibin."
            },
            {
              "language": "pl",
              "text": "Przy nagłym wypowiedzeniu klientowi powstają dodatkowe koszty."
            },
            {
              "language": "ro",
              "text": "În cazul unei anulări la termen scurt, clientului îi revin costuri suplimentare."
            },
            {
              "language": "ru",
              "text": "При срочном расторжении договора у клиента возникнут дополнительные расходы."
            },
            {
              "language": "sq",
              "text": "Në rast anulimi afatshkurtër, klientit i bien kosto shtesë."
            },
            {
              "language": "tr",
              "text": "Son dakika iptallerde müşteriye ek maliyetler düşer."
            }
          ]
        },
        {
          "baseText": "Bei einem Projektstopp fällt oft ein hoher Mehraufwand an.",
          "translations": [
            {
              "language": "ar",
              "text": "عند إيقاف مشروع، غالبًا ما تنشأ أعباء إضافية كبيرة."
            },
            {
              "language": "ckb",
              "text": "لە کاتی وەستاندنی پڕۆژەدا، زۆرجار تێچوویی زیادە دەفڕێت."
            },
            {
              "language": "en",
              "text": "When a project is stopped, a high additional effort is often incurred."
            },
            {
              "language": "fa",
              "text": "وقتی یک پروژه متوقف می‌شود، معمولاً هزینه کاری اضافی سنگینی به آن افزوده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Dema projeyek sekin bibe, gelek hêza zêde pir caran pêk tê."
            },
            {
              "language": "pl",
              "text": "Kiedy projekt zostaje wstrzymany, zwykle pojawia się duży nakład dodatkowej pracy."
            },
            {
              "language": "ro",
              "text": "Atunci când un proiect este oprit, de multe ori apar costuri suplimentare mari de efort."
            },
            {
              "language": "ru",
              "text": "Когда проект останавливается, часто возникает значительная дополнительная нагрузка."
            },
            {
              "language": "sq",
              "text": "Kur një projekt ndalet, shpesh bie një përpjekje shtesë e madhe."
            },
            {
              "language": "tr",
              "text": "Bir proje durduğunda genellikle yüksek ek bir emek doğar."
            }
          ]
        }
      ]
    },
