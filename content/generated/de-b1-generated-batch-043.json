  "entries": [
    {
      "word": "diskutieren",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "diskutieren",
      "pronunciationIpa": null,
      "syllableBreak": "dis-ku-tie-ren",
      "topics": [
        "meetings-and-presentations",
        "business-communication",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "formal"
      ],
      "contextLabels": [
        "management",
        "administration"
      ],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "ein Thema diskutieren",
          "meaning": "to discuss a topic"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Diskussion",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يناقش؛ يتحاور"
        },
        {
          "language": "ckb",
          "text": "گفتوگۆ کردن؛ تاوتوێ کردن"
        },
        {
          "language": "en",
          "text": "to discuss; to debate"
        },
        {
          "language": "fa",
          "text": "بحث کردن؛ گفتگو کردن"
        },
        {
          "language": "kmr",
          "text": "nîqaş kirin; gotûbêj kirin"
        },
        {
          "language": "pl",
          "text": "dyskutować"
        },
        {
          "language": "ro",
          "text": "a discuta; a dezbate"
        },
        {
          "language": "ru",
          "text": "обсуждать; дискутировать"
        },
        {
          "language": "sq",
          "text": "të diskutosh; të debatosh"
        },
        {
          "language": "tr",
          "text": "tartışmak; görüşmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir diskutieren die offenen Punkte morgen im Teammeeting.",
          "translations": [
            {
              "language": "ar",
              "text": "سنناقش النقاط المفتوحة غدًا في اجتماع الفريق."
            },
            {
              "language": "ckb",
              "text": "سبەی خاڵە کراوەکان لە کۆبوونەوەی تیمدا تاوتوێ دەکەین."
            },
            {
              "language": "en",
              "text": "We will discuss the open points tomorrow in the team meeting."
            },
            {
              "language": "fa",
              "text": "فردا موارد باز را در جلسه تیمی بررسی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em ê sibê xalên vekirî di civîna tîmê de nîqaş bikin."
            },
            {
              "language": "pl",
              "text": "Omówimy otwarte punkty jutro na spotkaniu zespołu."
            },
            {
              "language": "ro",
              "text": "Vom discuta punctele deschise mâine în ședința echipei."
            },
            {
              "language": "ru",
              "text": "Мы обсудим открытые вопросы завтра на командном совещании."
            },
            {
              "language": "sq",
              "text": "Pikat e hapura do t’i diskutojmë nesër në takimin e ekipit."
            },
            {
              "language": "tr",
              "text": "Açık konuları yarın ekip toplantısında görüşeceğiz."
            }
          ]
        },
        {
          "baseText": "Zu Hause diskutieren wir oft, wer am Wochenende einkaufen geht.",
          "translations": [
            {
              "language": "ar",
              "text": "في البيت نناقش كثيرًا من سيذهب للتسوق في عطلة نهاية الأسبوع."
            },
            {
              "language": "ckb",
              "text": "لە ماڵەوە زۆرجار گفتوگۆ دەکەین کێ لە کۆتایی هەفتەدا دەچێت بازاڕ."
            },
            {
              "language": "en",
              "text": "At home, we often discuss who will go shopping at the weekend."
            },
            {
              "language": "fa",
              "text": "در خانه اغلب بحث می‌کنیم چه کسی آخر هفته خرید برود."
            },
            {
              "language": "kmr",
              "text": "Li malê em gelek caran nîqaş dikin ka dawiya hefteyê kî diçe kirînê."
            },
            {
              "language": "pl",
              "text": "W domu często dyskutujemy, kto pójdzie na zakupy w weekend."
            },
            {
              "language": "ro",
              "text": "Acasă discutăm adesea cine merge la cumpărături în weekend."
            },
            {
              "language": "ru",
              "text": "Дома мы часто обсуждаем, кто пойдет за покупками на выходных."
            },
            {
              "language": "sq",
              "text": "Në shtëpi shpesh diskutojmë kush do të shkojë për pazar në fundjavë."
            },
            {
              "language": "tr",
              "text": "Evde hafta sonu alışverişe kimin gideceğini sık sık tartışırız."
            }
          ]
        }
      ]
    },
