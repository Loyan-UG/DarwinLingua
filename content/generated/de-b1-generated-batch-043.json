        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "توثيق؛ وثائق شرح"
        },
        {
          "language": "ckb",
          "text": "بەڵگەکردن؛ دۆکیومێنتەیشن"
        },
        {
          "language": "en",
          "text": "documentation"
        },
        {
          "language": "fa",
          "text": "مستندسازی؛ مستندات"
        },
        {
          "language": "kmr",
          "text": "belgekirin; dokumentasyon"
        },
        {
          "language": "pl",
          "text": "dokumentacja"
        },
        {
          "language": "ro",
          "text": "documentație"
        },
        {
          "language": "ru",
          "text": "документация"
        },
        {
          "language": "sq",
          "text": "dokumentacion"
        },
        {
          "language": "tr",
          "text": "dokümantasyon; belgelendirme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Dokumentation erklärt, wie man die Schnittstelle benutzt.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح الوثائق كيف يمكن استخدام الواجهة البرمجية."
            },
            {
              "language": "ckb",
              "text": "دۆکیومێنتەیشنەکە ڕوون دەکاتەوە چۆن API بەکاربهێنرێت."
            },
            {
              "language": "en",
              "text": "The documentation explains how to use the interface."
            },
            {
              "language": "fa",
              "text": "مستندات توضیح می‌دهد چگونه از رابط استفاده کنیم."
            },
            {
              "language": "kmr",
              "text": "Dokumentasyon şirove dike ka çawa navberê bikar bînin."
            },
            {
              "language": "pl",
              "text": "Dokumentacja wyjaśnia, jak korzystać z interfejsu."
            },
            {
              "language": "ro",
              "text": "Documentația explică modul de utilizare a interfeței."
            },
            {
              "language": "ru",
              "text": "Документация объясняет, как пользоваться интерфейсом."
            },
            {
              "language": "sq",
              "text": "Dokumentacioni shpjegon si të përdoret ndërfaqja."
            },
            {
              "language": "tr",
              "text": "Dokümantasyon arayüzün nasıl kullanılacağını açıklar."
            }
          ]
        },
        {
          "baseText": "Für die Prüfung brauchen wir eine vollständige Dokumentation aller Änderungen.",
          "translations": [
            {
              "language": "ar",
              "text": "للمراجعة نحتاج إلى توثيق كامل لجميع التغييرات."
            },
            {
              "language": "ckb",
