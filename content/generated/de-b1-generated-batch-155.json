      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular: die Zukunft"
      ],
      "collocations": [
        {
          "text": "in der Zukunft",
          "meaning": "in the future"
        },
        {
          "text": "Pläne für die Zukunft",
          "meaning": "plans for the future"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zukünftig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "المستقبل"
        },
        {
          "language": "ckb",
          "text": "داهاتوو"
        },
        {
          "language": "en",
          "text": "future"
        },
        {
          "language": "fa",
          "text": "آینده"
        },
        {
          "language": "kmr",
          "text": "pêşeroj; dahatû"
        },
        {
          "language": "pl",
          "text": "przyszłość"
        },
        {
          "language": "ro",
          "text": "viitor"
        },
        {
          "language": "ru",
          "text": "будущее"
        },
        {
          "language": "sq",
          "text": "e ardhmja"
        },
        {
          "language": "tr",
          "text": "gelecek"
        }
      ],
      "examples": [
        {
          "baseText": "In Zukunft möchten wir mehr online verkaufen.",
          "translations": [
            {
              "language": "ar",
              "text": "في المستقبل نريد أن نبيع أكثر عبر الإنترنت."
            },
            {
              "language": "ckb",
              "text": "لە داهاتوودا دەمەوێت زیاتر لەسەر ئینتەرنێت بفرۆشین."
            },
            {
              "language": "en",
              "text": "In the future, we would like to sell more online."
            },
            {
              "language": "fa",
              "text": "در آینده می‌خواهیم بیشتر آنلاین بفروشیم."
            },
            {
              "language": "kmr",
              "text": "Di pêşerojê de em dixwazin zêdetir bi rêya înternetê bifroşin."
            },
            {
              "language": "pl",
              "text": "W przyszłości chcemy sprzedawać więcej online."
            },
            {
              "language": "ro",
              "text": "În viitor dorim să vindem mai mult online."
            },
            {
              "language": "ru",
              "text": "В будущем мы хотим больше продавать онлайн."
            },
            {
              "language": "sq",
              "text": "Në të ardhmen duam të shesim më shumë online."
            },
            {
              "language": "tr",
              "text": "Gelecekte internet üzerinden daha fazla satış yapmak istiyoruz."
            }
          ]
        },
        {
          "baseText": "Sie macht sich viele Gedanken über ihre Zukunft.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تفكر كثيراً في مستقبلها."
            },
            {
              "language": "ckb",
              "text": "ئەو زۆر بیر لە داهاتووی خۆی دەکاتەوە."
            },
            {
              "language": "en",
              "text": "She thinks a lot about her future."
            },
            {
              "language": "fa",
              "text": "او زیاد به آینده‌اش فکر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ew gelek li ser pêşeroja xwe difikire."
            },
            {
              "language": "pl",
              "text": "Ona dużo myśli o swojej przyszłości."
            },
            {
              "language": "ro",
              "text": "Ea se gândește mult la viitorul ei."
            },
            {
              "language": "ru",
              "text": "Она много думает о своем будущем."
            },
            {
              "language": "sq",
              "text": "Ajo mendon shumë për të ardhmen e saj."
            },
            {
              "language": "tr",
              "text": "Geleceği hakkında çok düşünüyor."
            }
          ]
        }
      ]
    },
    {
      "word": "zulassen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zulassen",
      "pronunciationIpa": null,
      "syllableBreak": "zu-las-sen",
      "topics": [
        "documents-and-administration",
        "public-services",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: ich lasse zu, ich ließ zu, ich habe zugelassen"
      ],
      "collocations": [
        {
          "text": "etwas nicht zulassen",
          "meaning": "not to allow something"
        },
        {
          "text": "zur Prüfung zugelassen werden",
          "meaning": "to be admitted to an exam"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zulassung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسمح؛ يجيز؛ يقبل رسمياً"
        },
        {
          "language": "ckb",
          "text": "ڕێگەدان؛ قبووڵکردنی فەرمی"
        },
        {
          "language": "en",
          "text": "to allow; to admit; to approve"
        },
        {
          "language": "fa",
          "text": "اجازه دادن؛ پذیرفتن رسمی"
        },
        {
          "language": "kmr",
          "text": "destûr dan; qebûl kirin; pejirandin"
        },
        {
          "language": "pl",
          "text": "dopuścić; zezwolić"
        },
        {
          "language": "ro",
          "text": "a permite; a admite"
        },
        {
          "language": "ru",
          "text": "допускать; разрешать"
        },
        {
          "language": "sq",
          "text": "të lejosh; të pranosh zyrtarisht"
        },
        {
          "language": "tr",
          "text": "izin vermek; kabul etmek; onaylamak"
        }
      ],
      "examples": [
        {
          "baseText": "Aus Sicherheitsgründen lassen wir keine Besucher ohne Ausweis zu.",
          "translations": [
            {
              "language": "ar",
              "text": "لأسباب أمنية لا نسمح بدخول الزوار من دون بطاقة هوية."
            },
            {
              "language": "ckb",
              "text": "بەهۆی هۆکاری ئاسایشی، میوان بەبێ ناسنامە ڕێگە پێ نادەین."
            },
            {
              "language": "en",
              "text": "For security reasons, we do not allow visitors without an ID."
            },
            {
              "language": "fa",
              "text": "به دلایل امنیتی، به بازدیدکنندگان بدون کارت شناسایی اجازه ورود نمی‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Ji ber sedemên ewlehiyê, em mêvanên bê nasname qebûl nakin."
            },
            {
              "language": "pl",
              "text": "Ze względów bezpieczeństwa nie wpuszczamy gości bez dokumentu."
            },
            {
              "language": "ro",
              "text": "Din motive de securitate, nu permitem vizitatori fără act de identitate."
            },
            {
              "language": "ru",
              "text": "По соображениям безопасности мы не допускаем посетителей без удостоверения."
            },
            {
              "language": "sq",
              "text": "Për arsye sigurie nuk lejojmë vizitorë pa dokument identifikimi."
            },
            {
              "language": "tr",
              "text": "Güvenlik nedeniyle kimliği olmayan ziyaretçilere izin vermiyoruz."
            }
          ]
        },
        {
          "baseText": "Er wurde zur Prüfung zugelassen, weil alle Unterlagen vollständig waren.",
          "translations": [
            {
              "language": "ar",
              "text": "تم قبوله للامتحان لأن جميع المستندات كانت كاملة."
            },
            {
              "language": "ckb",
              "text": "ئەو بۆ تاقیکردنەوەکە قبووڵ کرا، چونکە هەموو بەڵگەنامەکان تەواو بوون."
            },
            {
              "language": "en",
              "text": "He was admitted to the exam because all documents were complete."
            },
            {
              "language": "fa",
              "text": "او برای امتحان پذیرفته شد، چون همه مدارک کامل بود."
            },
            {
              "language": "kmr",
              "text": "Ew ji bo ezmûnê hate qebûlkirin, ji ber ku hemû belge temam bûn."
            },
            {
              "language": "pl",
              "text": "Został dopuszczony do egzaminu, bo wszystkie dokumenty były kompletne."
            },
            {
              "language": "ro",
              "text": "A fost admis la examen deoarece toate documentele erau complete."
            },
            {
              "language": "ru",
              "text": "Его допустили к экзамену, потому что все документы были полными."
            },
            {
              "language": "sq",
              "text": "Ai u pranua në provim sepse të gjitha dokumentet ishin të plota."
            },
            {
              "language": "tr",
              "text": "Tüm belgeler eksiksiz olduğu için sınava kabul edildi."
            }
          ]
        }
      ]
    },
