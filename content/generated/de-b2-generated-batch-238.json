      "meanings": [
        {
          "language": "ar",
          "text": "اتجاه؛ صيحة"
        },
        {
          "language": "ckb",
          "text": "ئاراستە؛ ترێند"
        },
        {
          "language": "en",
          "text": "trend; tendency"
        },
        {
          "language": "fa",
          "text": "روند؛ گرایش"
        },
        {
          "language": "kmr",
