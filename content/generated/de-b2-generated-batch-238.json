        }
      ],
      "examples": [
        {
          "baseText": "Der aktuelle Trend zeigt, dass Kunden mehr Self-Service-Angebote erwarten.",
          "translations": [
            {
              "language": "ar",
              "text": "يُظهر الاتجاه الحالي أن العملاء يتوقعون المزيد من خدمات الخدمة الذاتية."
            },
            {
              "language": "ckb",
              "text": "ترێندی ئێستا پیشان دەدات کە کڕیاران چاوەڕێی خزمەتگوزاری زیاتر بە شێوەی خۆخزمەتکردنن."
            },
            {
              "language": "en",
              "text": "The current trend shows that customers expect more self-service options."
            },
            {
              "language": "fa",
              "text": "روند فعلی نشان می‌دهد که مشتریان انتظار گزینه‌های سلف‌سرویس بیشتری دارند."
            },
            {
              "language": "kmr",
              "text": "Trenda niha nîşan dide ku xerîdar hêvîya zêdetir xizmetên xwe-xizmetiyê dikin."
            },
            {
              "language": "pl",
              "text": "Obecny trend pokazuje, że klienci oczekują więcej opcji samoobsługi."
            },
            {
              "language": "ro",
              "text": "Trendul actual arată că clienții așteaptă mai multe opțiuni de autoservire."
            },
            {
              "language": "ru",
              "text": "Текущий тренд показывает, что клиенты ожидают больше возможностей самообслуживания."
            },
            {
              "language": "sq",
              "text": "Trendi aktual tregon se klientët presin më shumë mundësi vetëshërbimi."
            },
            {
              "language": "tr",
              "text": "Güncel trend, müşterilerin daha fazla self servis seçeneği beklediğini gösteriyor."
            }
          ]
        },
        {
          "baseText": "In der Mode kommt dieser Trend jedes Frühjahr wieder zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "في الموضة يعود هذا الاتجاه كل ربيع."
            },
            {
              "language": "ckb",
              "text": "لە مۆدەدا ئەم ترێندە هەموو بەهارێک دەگەڕێتەوە."
            },
            {
              "language": "en",
