  "entries": [
    {
      "word": "mitschwingen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "mitschwingen",
      "pronunciationIpa": null,
      "syllableBreak": "mit-schwin-gen",
      "topics": [
        "business-communication",
        "culture-and-media",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong separable verb; often figurative: to resonate implicitly"
      ],
      "collocations": [
        {
          "text": "in einer Aussage mitschwingen",
          "meaning": "to resonate implicitly in a statement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schwingen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتردد ضمنياً؛ يكون حاضراً كإيحاء"
        },
        {
          "language": "ckb",
          "text": "بە ناڕاستەوخۆ هەست پێدەکرێت؛ هاودەنگ دەبێت"
        },
        {
          "language": "en",
          "text": "to resonate implicitly; to be implied"
        },
        {
          "language": "fa",
          "text": "ضمنی حضور داشتن؛ در پسِ چیزی طنین داشتن"
        },
        {
          "language": "kmr",
          "text": "bi neyekserî deng vedan"
        },
        {
          "language": "pl",
          "text": "pobrzmiewać; być obecnym pośrednio"
        },
        {
          "language": "ro",
          "text": "a reverbera implicit; a fi sugerat"
        },
        {
          "language": "ru",
          "text": "подспудно звучать; подразумеваться"
        },
        {
          "language": "sq",
          "text": "të nënkuptohet; të jehojë në sfond"
        },
        {
          "language": "tr",
          "text": "örtük biçimde yankılanmak; ima edilmek"
        }
      ],
      "examples": [
        {
          "baseText": "In der Rückmeldung schwang mit, dass das Team dem neuen Zeitplan nicht vertraut.",
          "translations": [
            {
              "language": "ar",
              "text": "في الملاحظة كان هناك إيحاء بأن الفريق لا يثق بالجدول الزمني الجديد."
            },
            {
              "language": "ckb",
              "text": "لە فیدباکەکەدا بە ناڕاستەوخۆ هەست دەکرا کە تیمەکە متمانەی بە خشتەی کاتی نوێ نییە."
            },
            {
              "language": "en",
              "text": "The feedback implicitly suggested that the team did not trust the new schedule."
            },
            {
              "language": "fa",
              "text": "در بازخورد این نکته به‌طور ضمنی وجود داشت که تیم به زمان‌بندی جدید اعتماد ندارد."
            },
            {
              "language": "kmr",
              "text": "Di vegerandina nerînê de bi neyekserî xuya bû ku tîm baweriya xwe bi plana demê ya nû nîne."
            },
            {
              "language": "pl",
              "text": "W informacji zwrotnej pobrzmiewało, że zespół nie ufa nowemu harmonogramowi."
            },
            {
              "language": "ro",
              "text": "În feedback se simțea implicit că echipa nu are încredere în noul calendar."
            },
            {
              "language": "ru",
              "text": "В отзыве подспудно звучало, что команда не доверяет новому графику."
            },
            {
              "language": "sq",
              "text": "Në reagim nënkuptohej se ekipi nuk i beson afatit të ri."
            },
            {
              "language": "tr",
              "text": "Geri bildirimde ekibin yeni zaman planına güvenmediği örtük biçimde hissediliyordu."
            }
          ]
        },
        {
          "baseText": "In der Szene schwingt eine leise Kritik an der bürgerlichen Ordnung mit.",
          "translations": [
            {
              "language": "ar",
              "text": "في المشهد يتردد نقد هادئ للنظام البرجوازي."
            },
            {
              "language": "ckb",
              "text": "لە دیمەنەکەدا ڕەخنەیەکی هێمنی ڕێکخستنی بۆرژوازی بە ناڕاستەوخۆ هەست پێدەکرێت."
            },
            {
              "language": "en",
              "text": "A quiet critique of bourgeois order resonates in the scene."
            },
            {
              "language": "fa",
              "text": "در این صحنه نقدی آرام به نظم بورژوایی به‌طور ضمنی طنین دارد."
            },
            {
              "language": "kmr",
              "text": "Di dîmenê de rexneyeke hêdî li ser rêza bûrjûwazî deng vedide."
            },
            {
              "language": "pl",
              "text": "W scenie pobrzmiewa cicha krytyka porządku mieszczańskiego."
            },
            {
              "language": "ro",
              "text": "În scenă reverberează o critică discretă a ordinii burgheze."
            },
            {
              "language": "ru",
              "text": "В сцене подспудно звучит тихая критика буржуазного порядка."
            },
            {
              "language": "sq",
              "text": "Në skenë jehohet një kritikë e qetë ndaj rendit borgjez."
            },
            {
              "language": "tr",
              "text": "Sahnede burjuva düzene yönelik sessiz bir eleştiri örtük biçimde yankılanır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Modellannahme",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Modellannahmen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Mo-dell-an-nah-me",
      "topics": [
        "data-and-reporting",
        "advanced-analysis",
        "planning-and-projects"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "eine Modellannahme prüfen",
          "meaning": "to check a model assumption"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Modell",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Annahme",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "افتراض النموذج"
        },
        {
          "language": "ckb",
          "text": "گریمانەی مۆدێل"
        },
        {
          "language": "en",
          "text": "model assumption"
        },
        {
          "language": "fa",
          "text": "فرض مدل"
        },
        {
          "language": "kmr",
          "text": "texmîna modelê"
        },
        {
          "language": "pl",
          "text": "założenie modelu"
        },
        {
          "language": "ro",
          "text": "ipoteză de model"
        },
        {
          "language": "ru",
          "text": "модельное предположение"
        },
        {
          "language": "sq",
          "text": "supozim modeli"
        },
        {
          "language": "tr",
          "text": "model varsayımı"
        }
      ],
      "examples": [
        {
          "baseText": "Die zentrale Modellannahme ist, dass die Nachfrage nicht abrupt einbricht.",
          "translations": [
            {
              "language": "ar",
              "text": "الافتراض المركزي في النموذج هو أن الطلب لا ينهار فجأة."
            },
            {
              "language": "ckb",
              "text": "گریمانەی سەرەکیی مۆدێلەکە ئەوەیە کە داواکاری لەناکاو ناڕووخێت."
            },
            {
              "language": "en",
              "text": "The central model assumption is that demand will not collapse abruptly."
            },
            {
              "language": "fa",
              "text": "فرض اصلی مدل این است که تقاضا به‌طور ناگهانی سقوط نمی‌کند."
            },
            {
              "language": "kmr",
              "text": "Texmîna sereke ya modelê ev e ku daxwaz ji nişkê ve narizê."
            },
            {
              "language": "pl",
              "text": "Centralnym założeniem modelu jest to, że popyt nie załamie się gwałtownie."
            },
            {
              "language": "ro",
              "text": "Ipoteza centrală a modelului este că cererea nu se va prăbuși brusc."
            },
            {
              "language": "ru",
              "text": "Центральное модельное предположение состоит в том, что спрос не обрушится внезапно."
            },
            {
              "language": "sq",
              "text": "Supozimi qendror i modelit është se kërkesa nuk bie papritur."
            },
            {
              "language": "tr",
              "text": "Modelin temel varsayımı, talebin aniden çökmeyeceğidir."
            }
          ]
        },
        {
          "baseText": "Wenn sich eine Modellannahme ändert, müssen auch die Ergebnisse neu interpretiert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا تغير افتراض في النموذج، فيجب أيضاً إعادة تفسير النتائج."
            },
            {
              "language": "ckb",
              "text": "ئەگەر گریمانەیەکی مۆدێل بگۆڕێت، دەبێت ئەنجامەکانیش نوێ لێکبدرێنەوە."
            },
            {
              "language": "en",
              "text": "If a model assumption changes, the results must also be reinterpreted."
            },
            {
              "language": "fa",
              "text": "اگر یکی از فرض‌های مدل تغییر کند، نتایج هم باید دوباره تفسیر شوند."
            },
            {
              "language": "kmr",
              "text": "Heke texmînek modelê biguhere, divê encam jî ji nû ve bên şîrovekirin."
            },
            {
              "language": "pl",
              "text": "Jeśli zmieni się założenie modelu, wyniki również trzeba zinterpretować na nowo."
            },
            {
              "language": "ro",
              "text": "Dacă o ipoteză a modelului se schimbă, și rezultatele trebuie reinterpretate."
            },
            {
              "language": "ru",
              "text": "Если модельное предположение меняется, результаты также нужно интерпретировать заново."
            },
            {
              "language": "sq",
              "text": "Nëse ndryshon një supozim modeli, edhe rezultatet duhet të interpretohen sërish."
            },
            {
              "language": "tr",
              "text": "Bir model varsayımı değişirse sonuçlar da yeniden yorumlanmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Modellgüte",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
