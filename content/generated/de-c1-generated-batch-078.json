      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; usually singular"
      ],
      "collocations": [
        {
          "text": "die Modellgüte bewerten",
          "meaning": "to assess model quality"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Modell",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Güte",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جودة النموذج؛ ملاءمة النموذج"
        },
        {
          "language": "ckb",
          "text": "کوالیتی مۆدێل؛ باشی مۆدێل"
        },
        {
          "language": "en",
          "text": "model quality; goodness of fit"
        },
        {
          "language": "fa",
          "text": "کیفیت مدل؛ برازش مدل"
        },
        {
          "language": "kmr",
          "text": "kalîteya modelê"
        },
        {
          "language": "pl",
          "text": "jakość modelu; dopasowanie modelu"
        },
        {
          "language": "ro",
          "text": "calitatea modelului; gradul de potrivire"
        },
        {
          "language": "ru",
          "text": "качество модели; степень соответствия"
        },
        {
          "language": "sq",
          "text": "cilësia e modelit; përshtatja e modelit"
        },
        {
          "language": "tr",
          "text": "model kalitesi; uyum iyiliği"
        }
      ],
      "examples": [
        {
          "baseText": "Die Modellgüte verbesserte sich deutlich, nachdem saisonale Effekte berücksichtigt wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "تحسنت جودة النموذج بوضوح بعد أخذ الآثار الموسمية في الاعتبار."
            },
            {
              "language": "ckb",
              "text": "کوالیتی مۆدێل بە ڕوونی باشتر بوو دوای ئەوەی کاریگەریی وەرزی لەبەرچاو گیرا."
            },
            {
              "language": "en",
              "text": "The model quality improved significantly after seasonal effects were taken into account."
            },
            {
              "language": "fa",
              "text": "کیفیت مدل پس از در نظر گرفتن اثرهای فصلی به‌طور محسوسی بهتر شد."
            },
            {
              "language": "kmr",
              "text": "Kalîteya modelê piştî ku bandorên demsalî hatin li ber çavan girtin bi zelalî baştir bû."
            },
            {
              "language": "pl",
              "text": "Jakość modelu wyraźnie się poprawiła po uwzględnieniu efektów sezonowych."
            },
            {
