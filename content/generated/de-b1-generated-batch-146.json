  "entries": [
    {
      "word": "vor allem",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "vor al-lem",
      "topics": [
        "business-communication",
        "everyday-life",
        "work-and-jobs"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "fixed adverbial phrase"
      ],
      "collocations": [
        {
          "text": "vor allem wichtig",
          "meaning": "especially important"
        },
        {
          "text": "vor allem im Alltag",
          "meaning": "especially in everyday life"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "allem",
          "relationLabel": "pronoun form",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خصوصًا؛ قبل كل شيء"
        },
        {
          "language": "ckb",
          "text": "بەتایبەتی؛ لە هەموو شتێک زیاتر"
        },
        {
          "language": "en",
          "text": "especially; above all"
        },
        {
          "language": "fa",
          "text": "به‌ویژه؛ قبل از همه"
        },
        {
          "language": "kmr",
          "text": "bi taybetî; berî her tiştî"
        },
        {
          "language": "pl",
          "text": "przede wszystkim; zwłaszcza"
        },
        {
          "language": "ro",
          "text": "mai ales; în primul rând"
        },
        {
          "language": "ru",
          "text": "прежде всего; особенно"
        },
        {
          "language": "sq",
          "text": "sidomos; mbi të gjitha"
        },
        {
          "language": "tr",
          "text": "özellikle; her şeyden önce"
        }
      ],
      "examples": [
        {
          "baseText": "Vor allem die neuen Kunden brauchen eine klare Erklärung.",
          "translations": [
            {
              "language": "ar",
              "text": "خصوصًا العملاء الجدد يحتاجون إلى شرح واضح."
            },
            {
              "language": "ckb",
              "text": "بەتایبەتی کڕیارە نوێیەکان پێویستیان بە ڕوونکردنەوەیەکی ڕوون هەیە."
            },
            {
              "language": "en",
              "text": "Especially the new customers need a clear explanation."
            },
            {
              "language": "fa",
              "text": "به‌ویژه مشتریان جدید به توضیح روشن نیاز دارند."
            },
            {
              "language": "kmr",
              "text": "Bi taybetî xerîdarên nû hewceyê ravekirineke zelal in."
            },
            {
              "language": "pl",
              "text": "Przede wszystkim nowi klienci potrzebują jasnego wyjaśnienia."
            },
            {
              "language": "ro",
              "text": "Mai ales clienții noi au nevoie de o explicație clară."
            },
            {
              "language": "ru",
              "text": "Прежде всего новым клиентам нужно понятное объяснение."
            },
            {
              "language": "sq",
              "text": "Sidomos klientët e rinj kanë nevojë për një shpjegim të qartë."
            },
            {
              "language": "tr",
              "text": "Özellikle yeni müşterilerin net bir açıklamaya ihtiyacı var."
            }
          ]
        },
        {
          "baseText": "Im Winter ist vor allem warme Kleidung wichtig.",
          "translations": [
            {
              "language": "ar",
              "text": "في الشتاء تكون الملابس الدافئة مهمة قبل كل شيء."
            },
            {
              "language": "ckb",
              "text": "لە زستاندا بەتایبەتی جل و بەرگی گەرم گرنگە."
            },
            {
              "language": "en",
              "text": "In winter, warm clothing is especially important."
            },
            {
              "language": "fa",
              "text": "در زمستان به‌ویژه لباس گرم مهم است."
            },
            {
              "language": "kmr",
              "text": "Di zivistanê de bi taybetî cilên germ girîng in."
            },
            {
              "language": "pl",
              "text": "Zimą szczególnie ważne jest ciepłe ubranie."
            },
            {
              "language": "ro",
              "text": "Iarna, hainele călduroase sunt mai ales importante."
            },
            {
              "language": "ru",
              "text": "Зимой особенно важна теплая одежда."
            },
            {
              "language": "sq",
              "text": "Në dimër janë sidomos të rëndësishme rrobat e ngrohta."
            },
            {
              "language": "tr",
              "text": "Kışın özellikle sıcak giysiler önemlidir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Voraussetzung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Voraussetzungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Vo-raus-set-zung",
      "topics": [
        "work-and-jobs",
        "education-and-training",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Voraussetzung erfüllen",
          "meaning": "to meet a requirement"
        },
        {
          "text": "wichtige Voraussetzung",
          "meaning": "important prerequisite"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "voraussetzen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شرط مسبق؛ متطلب"
        },
        {
          "language": "ckb",
          "text": "مەرج؛ پێداویستی پێشوەخت"
        },
        {
          "language": "en",
          "text": "prerequisite; requirement"
        },
        {
          "language": "fa",
          "text": "پیش‌شرط؛ شرط لازم"
        },
        {
          "language": "kmr",
          "text": "mercê pêşîn; pêdivî"
        },
        {
          "language": "pl",
          "text": "warunek; wymaganie"
        },
        {
          "language": "ro",
          "text": "condiție prealabilă; cerință"
        },
        {
          "language": "ru",
          "text": "предпосылка; требование"
        },
        {
          "language": "sq",
          "text": "parakusht; kërkesë"
        },
        {
          "language": "tr",
          "text": "ön koşul; şart"
        }
      ],
      "examples": [
        {
          "baseText": "Gute Deutschkenntnisse sind eine Voraussetzung für diese Stelle.",
          "translations": [
            {
              "language": "ar",
              "text": "المعرفة الجيدة بالألمانية شرط لهذه الوظيفة."
            },
            {
              "language": "ckb",
              "text": "زانیاریی باشی ئەڵمانی مەرجێکە بۆ ئەم پۆستە."
            },
            {
              "language": "en",
              "text": "Good German skills are a requirement for this position."
            },
            {
              "language": "fa",
              "text": "دانش خوب آلمانی شرط لازم برای این موقعیت است."
            },
            {
              "language": "kmr",
              "text": "Zanîna baş a almanî mercê vê karê ye."
            },
            {
              "language": "pl",
              "text": "Dobra znajomość niemieckiego jest warunkiem tego stanowiska."
            },
            {
              "language": "ro",
              "text": "Cunoștințele bune de germană sunt o cerință pentru acest post."
            },
            {
              "language": "ru",
              "text": "Хорошее знание немецкого является требованием для этой должности."
            },
            {
              "language": "sq",
              "text": "Njohuritë e mira të gjermanishtes janë kusht për këtë vend pune."
            },
            {
              "language": "tr",
              "text": "İyi Almanca bilgisi bu pozisyon için bir şarttır."
            }
          ]
        },
        {
          "baseText": "Für die Teilnahme am Kurs müssen Sie keine besonderen Voraussetzungen erfüllen.",
          "translations": [
            {
              "language": "ar",
              "text": "للمشاركة في الدورة لا يجب أن تستوفي شروطًا خاصة."
            },
            {
              "language": "ckb",
              "text": "بۆ بەژداربوون لە کۆرسەکەدا پێویست ناکات مەرجی تایبەت جێبەجێ بکەیت."
            },
            {
              "language": "en",
              "text": "To take part in the course, you do not have to meet any special requirements."
            },
            {
              "language": "fa",
              "text": "برای شرکت در دوره لازم نیست شرایط خاصی را داشته باشید."
            },
            {
              "language": "kmr",
              "text": "Ji bo beşdarbûna kursê pêwîst nîne hûn mercên taybet pêk bînin."
            },
            {
              "language": "pl",
              "text": "Do udziału w kursie nie trzeba spełniać żadnych szczególnych warunków."
            },
            {
              "language": "ro",
              "text": "Pentru participarea la curs nu trebuie să îndepliniți condiții speciale."
            },
            {
              "language": "ru",
              "text": "Для участия в курсе не нужно выполнять особые требования."
            },
            {
              "language": "sq",
              "text": "Për pjesëmarrje në kurs nuk duhet të plotësoni kushte të veçanta."
            },
            {
              "language": "tr",
              "text": "Kursa katılmak için özel şartları yerine getirmeniz gerekmez."
            }
          ]
        }
      ]
    },
    {
      "word": "voraussichtlich",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "vo-raus-sicht-lich",
      "topics": [
        "business-communication",
        "planning-and-projects",
        "transport-and-travel"
      ],
      "usageLabels": [
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb/adjective; used for expected dates or results"
      ],
      "collocations": [
        {
          "text": "voraussichtlich morgen",
          "meaning": "expected tomorrow"
        },
        {
          "text": "voraussichtlich dauern",
          "meaning": "to probably take"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Voraussicht",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "على الأرجح؛ من المتوقع"
        },
        {
          "language": "ckb",
          "text": "پێشبینی دەکرێت؛ بە گومانەوە"
        },
        {
          "language": "en",
          "text": "expected; probably"
        },
        {
          "language": "fa",
          "text": "احتمالاً؛ طبق پیش‌بینی"
        },
        {
          "language": "kmr",
          "text": "li gor pêşbînî; belkî"
        },
        {
          "language": "pl",
          "text": "prawdopodobnie; przewidywany"
        },
        {
          "language": "ro",
          "text": "probabil; estimat"
        },
        {
          "language": "ru",
          "text": "предположительно; вероятно"
        },
        {
          "language": "sq",
          "text": "me gjasë; pritet"
        },
        {
          "language": "tr",
          "text": "muhtemelen; tahminen"
        }
      ],
      "examples": [
        {
          "baseText": "Die Lieferung kommt voraussichtlich am Freitag an.",
          "translations": [
            {
              "language": "ar",
              "text": "من المتوقع أن تصل الشحنة يوم الجمعة."
            },
            {
              "language": "ckb",
              "text": "پێشبینی دەکرێت گەیاندنەکە ڕۆژی هەینی بگات."
            },
            {
              "language": "en",
              "text": "The delivery is expected to arrive on Friday."
            },
            {
              "language": "fa",
              "text": "تحویل احتمالاً روز جمعه می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Radestkirin li gor pêşbînî roja înê digihêje."
            },
            {
              "language": "pl",
              "text": "Dostawa prawdopodobnie dotrze w piątek."
            },
            {
              "language": "ro",
              "text": "Livrarea va ajunge probabil vineri."
            },
            {
              "language": "ru",
              "text": "Доставка предположительно прибудет в пятницу."
            },
            {
              "language": "sq",
              "text": "Dërgesa pritet të arrijë të premten."
            },
            {
              "language": "tr",
              "text": "Teslimat muhtemelen cuma günü ulaşacak."
            }
          ]
        },
        {
          "baseText": "Die Wartungsarbeiten dauern voraussichtlich zwei Stunden.",
          "translations": [
            {
              "language": "ar",
              "text": "من المتوقع أن تستغرق أعمال الصيانة ساعتين."
            },
            {
              "language": "ckb",
              "text": "پێشبینی دەکرێت کاری چاکسازی دوو کاتژمێر بخایەنێت."
            },
            {
              "language": "en",
              "text": "The maintenance work will probably take two hours."
            },
            {
              "language": "fa",
              "text": "کارهای نگهداری احتمالاً دو ساعت طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Karên lênêrînê li gor pêşbînî du saetan dikişînin."
            },
            {
              "language": "pl",
              "text": "Prace konserwacyjne potrwają prawdopodobnie dwie godziny."
            },
            {
              "language": "ro",
              "text": "Lucrările de mentenanță vor dura probabil două ore."
            },
            {
              "language": "ru",
              "text": "Технические работы, вероятно, продлятся два часа."
            },
            {
              "language": "sq",
              "text": "Punimet e mirëmbajtjes pritet të zgjasin dy orë."
            },
            {
              "language": "tr",
              "text": "Bakım çalışmaları muhtemelen iki saat sürecek."
            }
          ]
        }
      ]
    },
    {
      "word": "vorbeigehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
