      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; usually used in singular; loud and unpleasant noise"
      ],
      "collocations": [
        {
          "text": "viel Lärm machen",
          "meaning": "to make a lot of noise"
        },
        {
          "text": "sich über Lärm beschweren",
          "meaning": "to complain about noise"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "lärmen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "lärmbelastet",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ضجيج؛ إزعاج"
        },
        {
          "language": "ckb",
          "text": "ژاوەژاو؛ دەنگی زۆر"
        },
        {
          "language": "en",
          "text": "noise; loud disturbance"
        },
        {
          "language": "fa",
          "text": "سر و صدا؛ آلودگی صوتی"
        },
        {
          "language": "kmr",
          "text": "qerebalix; dengê bilind"
        },
        {
          "language": "pl",
          "text": "hałas"
        },
        {
          "language": "ro",
          "text": "zgomot; gălăgie"
        },
        {
          "language": "ru",
          "text": "шум"
        },
        {
          "language": "sq",
          "text": "zhurmë"
        },
        {
          "language": "tr",
          "text": "gürültü"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lärm von der Baustelle stört die Mitarbeiter im Büro.",
          "translations": [
            {
              "language": "ar",
              "text": "يزعج ضجيج موقع البناء الموظفين في المكتب."
            },
            {
              "language": "ckb",
              "text": "ژاوەژاوی شوێنی بیناسازی کارمەندانی ئۆفیسەکە بێزار دەکات."
            },
            {
              "language": "en",
              "text": "The noise from the construction site disturbs the employees in the office."
            },
            {
              "language": "fa",
              "text": "سر و صدای کارگاه ساختمانی کارکنان دفتر را اذیت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Qerebalixa ji cihê avahiyê karmendên nivîsgehê aciz dike."
            },
            {
              "language": "pl",
              "text": "Hałas z budowy przeszkadza pracownikom w biurze."
            },
            {
              "language": "ro",
              "text": "Zgomotul de pe șantier îi deranjează pe angajații din birou."
            },
            {
              "language": "ru",
              "text": "Шум со стройки мешает сотрудникам в офисе."
            },
            {
              "language": "sq",
              "text": "Zhurma nga kantieri i shqetëson punonjësit në zyrë."
            },
            {
              "language": "tr",
              "text": "İnşaat alanından gelen gürültü ofisteki çalışanları rahatsız ediyor."
            }
          ]
        },
        {
          "baseText": "Nach 22 Uhr sollte man im Haus keinen lauten Lärm mehr machen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الساعة العاشرة مساءً ينبغي ألا يصدر المرء ضجيجاً عالياً في المبنى."
            },
            {
              "language": "ckb",
              "text": "دوای کاتژمێر ٢٢ نابێت لە خانووەکەدا ژاوەژاوی بەرز بکرێت."
            },
            {
              "language": "en",
              "text": "After 10 p.m., people should not make loud noise in the building anymore."
            },
            {
              "language": "fa",
