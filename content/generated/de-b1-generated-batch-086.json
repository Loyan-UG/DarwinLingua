  "entries": [
    {
      "word": "die Kurzarbeit",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kurz-ar-beit",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "formal",
        "workplace",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually used in singular; reduced working hours due to economic reasons"
      ],
      "collocations": [
        {
          "text": "Kurzarbeit anmelden",
          "meaning": "to register short-time work"
        },
        {
          "text": "in Kurzarbeit gehen",
          "meaning": "to go on short-time work"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kurz",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Arbeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عمل بدوام مختصر؛ تقليل ساعات العمل"
        },
        {
          "language": "ckb",
          "text": "کارکردنی کورتکراوە؛ کەمکردنەوەی کاتژمێری کار"
        },
        {
          "language": "en",
          "text": "short-time work; reduced working hours"
        },
        {
          "language": "fa",
          "text": "کاهش ساعات کاری؛ کار کوتاه‌مدت"
        },
        {
          "language": "kmr",
          "text": "karê demkurt; kêmkirina demên kar"
        },
        {
          "language": "pl",
          "text": "skrócony czas pracy; Kurzarbeit"
        },
        {
          "language": "ro",
          "text": "program redus de lucru; Kurzarbeit"
        },
        {
          "language": "ru",
          "text": "сокращённое рабочее время; Kurzarbeit"
        },
        {
          "language": "sq",
          "text": "punë me orar të shkurtuar"
        },
        {
          "language": "tr",
          "text": "kısa çalışma; azaltılmış çalışma süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Wegen weniger Aufträge musste die Firma Kurzarbeit anmelden.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب قلة الطلبات اضطرت الشركة إلى تسجيل العمل بدوام مختصر."
            },
            {
              "language": "ckb",
              "text": "بەهۆی کەمی داواکارییەکان، کۆمپانیاکە ناچار بوو کارکردنی کورتکراوە تۆمار بکات."
            },
            {
              "language": "en",
              "text": "Because of fewer orders, the company had to register short-time work."
            },
            {
              "language": "fa",
              "text": "به دلیل کاهش سفارش‌ها، شرکت مجبور شد کاهش ساعات کاری را اعلام کند."
            },
            {
              "language": "kmr",
              "text": "Ji ber kêmbûna fermanan, şîrket neçar ma karê demkurt tomar bike."
            },
            {
              "language": "pl",
              "text": "Z powodu mniejszej liczby zleceń firma musiała zgłosić skrócony czas pracy."
            },
            {
              "language": "ro",
              "text": "Din cauza numărului mai mic de comenzi, firma a trebuit să declare program redus de lucru."
            },
            {
              "language": "ru",
              "text": "Из-за меньшего количества заказов компания была вынуждена оформить Kurzarbeit."
            },
            {
              "language": "sq",
              "text": "Për shkak të më pak porosive, kompania duhej të regjistronte punë me orar të shkurtuar."
            },
            {
              "language": "tr",
              "text": "Daha az sipariş nedeniyle firma kısa çalışma başvurusu yapmak zorunda kaldı."
            }
          ]
        },
        {
          "baseText": "Während der Kurzarbeit bekommen die Beschäftigten weniger Gehalt.",
          "translations": [
            {
              "language": "ar",
              "text": "خلال العمل بدوام مختصر يحصل الموظفون على راتب أقل."
            },
            {
              "language": "ckb",
              "text": "لە ماوەی کارکردنی کورتکراوەدا کارمەندان مووچەی کەمتر وەردەگرن."
            },
            {
              "language": "en",
              "text": "During short-time work, employees receive less salary."
            },
            {
              "language": "fa",
              "text": "در زمان کاهش ساعات کاری، کارکنان حقوق کمتری دریافت می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Di dema karê demkurt de karmend meaşê kêmtir werdigirin."
            },
            {
              "language": "pl",
              "text": "Podczas skróconego czasu pracy pracownicy otrzymują niższe wynagrodzenie."
            },
            {
              "language": "ro",
              "text": "În timpul programului redus, angajații primesc un salariu mai mic."
            },
            {
              "language": "ru",
              "text": "Во время Kurzarbeit сотрудники получают меньшую зарплату."
            },
            {
              "language": "sq",
              "text": "Gjatë punës me orar të shkurtuar, punonjësit marrin pagë më të ulët."
            },
            {
              "language": "tr",
              "text": "Kısa çalışma sırasında çalışanlar daha az maaş alır."
            }
          ]
        }
      ]
    },
    {
      "word": "der Lärm",
      "language": "de",
      "cefrLevel": "B1",
