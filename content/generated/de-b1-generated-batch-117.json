      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مادة تدريبية؛ مستند تدريب"
        },
        {
          "language": "ckb",
          "text": "بەڵگەنامەی ڕاهێنان؛ ماددەی فێرکاری"
        },
        {
          "language": "en",
          "text": "training material; training document"
        },
        {
          "language": "fa",
          "text": "جزوه آموزشی؛ مدارک آموزشی"
        },
        {
          "language": "kmr",
          "text": "belgeya perwerdeyê; materyala perwerdeyê"
        },
        {
          "language": "pl",
          "text": "materiał szkoleniowy; dokument szkoleniowy"
        },
        {
          "language": "ro",
          "text": "material de instruire; document de training"
        },
        {
          "language": "ru",
          "text": "учебный материал; материалы тренинга"
        },
        {
          "language": "sq",
          "text": "material trajnimi; dokument trajnimi"
        },
        {
          "language": "tr",
          "text": "eğitim materyali; eğitim dokümanı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Schulungsunterlagen stehen nach dem Kurs im Intranet bereit.",
          "translations": [
            {
              "language": "ar",
              "text": "ستكون مواد التدريب متاحة في الشبكة الداخلية بعد الدورة."
            },
            {
              "language": "ckb",
              "text": "دوای کۆرسەکە بەڵگەنامەکانی ڕاهێنان لە ئینترانێتدا ئامادەن."
            },
            {
              "language": "en",
              "text": "The training materials will be available on the intranet after the course."
            },
            {
              "language": "fa",
              "text": "جزوه‌های آموزشی بعد از دوره در اینترانت در دسترس هستند."
            },
            {
              "language": "kmr",
              "text": "Piştî kursê belgeyên perwerdeyê li intranetê amade ne."
            },
            {
              "language": "pl",
              "text": "Materiały szkoleniowe będą dostępne po kursie w intranecie."
            },
            {
              "language": "ro",
              "text": "Materialele de instruire vor fi disponibile pe intranet după curs."
            },
            {
              "language": "ru",
              "text": "Учебные материалы будут доступны в интранете после курса."
            },
            {
              "language": "sq",
              "text": "Materialet e trajnimit do të jenë të disponueshme në intranet pas kursit."
            },
            {
              "language": "tr",
              "text": "Eğitim materyalleri kurstan sonra intranette hazır olacak."
            }
          ]
        },
        {
          "baseText": "Bitte bringen Sie die Schulungsunterlage zum Termin mit.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إحضار مادة التدريب إلى الموعد."
            },
            {
              "language": "ckb",
              "text": "تکایە بەڵگەنامەی ڕاهێنانەکە بۆ کاتەکە لەگەڵ خۆتان بهێنن."
            },
            {
              "language": "en",
              "text": "Please bring the training document to the appointment."
            },
            {
              "language": "fa",
              "text": "لطفاً جزوه آموزشی را برای جلسه همراه داشته باشید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeya perwerdeyê ji bo hevdîtinê bi xwe re bînin."
            },
            {
              "language": "pl",
              "text": "Proszę przynieść materiał szkoleniowy na spotkanie."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să aduceți materialul de instruire la întâlnire."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, принесите учебный материал на встречу."
            },
            {
              "language": "sq",
              "text": "Ju lutem sillni materialin e trajnimit në takim."
            },
