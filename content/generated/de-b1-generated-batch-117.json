  "entries": [
    {
      "word": "die Schulpflicht",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Schul-pflicht",
      "topics": [
        "education-and-training",
        "law-and-compliance",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "die Schulpflicht erfüllen",
          "meaning": "to fulfill compulsory schooling"
        },
        {
          "text": "Beginn der Schulpflicht",
          "meaning": "start of compulsory schooling"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Schule",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Pflicht",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "التعليم الإلزامي؛ إلزامية المدرسة"
        },
        {
          "language": "ckb",
          "text": "خوێندنی ئیجباری؛ ئەرکی چوونە قوتابخانە"
        },
        {
          "language": "en",
          "text": "compulsory schooling; school attendance requirement"
        },
        {
          "language": "fa",
          "text": "تحصیل اجباری؛ الزام مدرسه"
        },
        {
          "language": "kmr",
          "text": "mecbûriyeta dibistanê"
        },
        {
          "language": "pl",
          "text": "obowiązek szkolny"
        },
        {
          "language": "ro",
          "text": "obligație școlară"
        },
        {
          "language": "ru",
          "text": "обязательное школьное обучение"
        },
        {
          "language": "sq",
          "text": "detyrim shkollor"
        },
        {
          "language": "tr",
          "text": "zorunlu eğitim; okula devam zorunluluğu"
        }
      ],
      "examples": [
        {
          "baseText": "In Deutschland beginnt die Schulpflicht je nach Bundesland unterschiedlich.",
          "translations": [
            {
              "language": "ar",
              "text": "في ألمانيا تبدأ إلزامية المدرسة بشكل مختلف حسب الولاية."
            },
            {
              "language": "ckb",
              "text": "لە ئەڵمانیا Schulpflicht بەپێی هەرێمەکە بە جیاوازی دەست پێ دەکات."
            },
            {
              "language": "en",
              "text": "In Germany, compulsory schooling starts differently depending on the federal state."
            },
            {
              "language": "fa",
              "text": "در آلمان تحصیل اجباری بسته به ایالت زمان متفاوتی شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Li Almanyayê mecbûriyeta dibistanê li gorî eyaletê cuda dest pê dike."
            },
            {
              "language": "pl",
              "text": "W Niemczech obowiązek szkolny zaczyna się różnie w zależności od kraju związkowego."
            },
            {
              "language": "ro",
              "text": "În Germania, obligația școlară începe diferit în funcție de land."
            },
            {
              "language": "ru",
              "text": "В Германии обязательное школьное обучение начинается по-разному в зависимости от федеральной земли."
            },
            {
              "language": "sq",
              "text": "Në Gjermani, detyrimi shkollor fillon ndryshe sipas landit."
            },
            {
              "language": "tr",
              "text": "Almanya’da zorunlu eğitim eyalete göre farklı zamanlarda başlar."
            }
          ]
        },
        {
          "baseText": "Bei einem Umzug müssen Eltern die Schulpflicht ihrer Kinder beachten.",
          "translations": [
            {
              "language": "ar",
              "text": "عند الانتقال يجب على الوالدين مراعاة التعليم الإلزامي لأطفالهم."
            },
            {
              "language": "ckb",
              "text": "لە کاتی گواستنەوەدا دایک و باوک دەبێت ئەرکی قوتابخانەی منداڵەکانیان لەبەرچاو بگرن."
            },
            {
              "language": "en",
              "text": "When moving, parents must observe their children’s compulsory schooling requirements."
            },
            {
              "language": "fa",
              "text": "هنگام اسباب‌کشی، والدین باید الزام مدرسه فرزندانشان را رعایت کنند."
            },
            {
              "language": "kmr",
              "text": "Dema bar kirinê dê û bav divê mecbûriyeta dibistana zarokên xwe binirxînin."
            },
            {
              "language": "pl",
              "text": "Przy przeprowadzce rodzice muszą uwzględnić obowiązek szkolny swoich dzieci."
            },
            {
              "language": "ro",
              "text": "La mutare, părinții trebuie să țină cont de obligația școlară a copiilor."
            },
            {
              "language": "ru",
              "text": "При переезде родители должны учитывать школьную обязанность своих детей."
            },
            {
              "language": "sq",
              "text": "Gjatë zhvendosjes, prindërit duhet të marrin parasysh detyrimin shkollor të fëmijëve."
            },
            {
              "language": "tr",
              "text": "Taşınırken ebeveynler çocuklarının okul zorunluluğunu dikkate almalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Schulungsunterlage",
