      "examples": [
        {
          "baseText": "Der Geschmack ist frisch und leicht.",
          "translations": [
            { "language": "ar", "text": "الطعم طازج وخفيف." },
            { "language": "ckb", "text": "تامەکە تازە و سووکە." },
            { "language": "en", "text": "The taste is fresh and light." },
            { "language": "fa", "text": "طعم آن تازه و سبک است." },
