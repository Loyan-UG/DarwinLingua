          "baseText": "Über Geschmack kann man lange diskutieren.",
          "translations": [
            { "language": "ar", "text": "يمكن النقاش طويلاً حول الذوق." },
            { "language": "ckb", "text": "دەکرێت ماوەیەکی زۆر لەسەر حەز گفتوگۆ بکرێت." },
            { "language": "en", "text": "People can discuss taste for a long time." },
            { "language": "fa", "text": "درباره سلیقه می‌توان مدت زیادی بحث کرد." },
            { "language": "kmr", "text": "Mirov dikare demeke dirêj li ser hezê nîqaş bike." },
            { "language": "pl", "text": "O gustach można długo dyskutować." },
            { "language": "ro", "text": "Despre gust se poate discuta mult." },
            { "language": "ru", "text": "О вкусе можно долго спорить." },
            { "language": "sq", "text": "Për shijen mund të diskutohet gjatë." },
            { "language": "tr", "text": "Zevk üzerine uzun süre tartışılabilir." }
          ]
        }
