      "meanings": [
        { "language": "ar", "text": "نقاش؛ مناظرة" },
        { "language": "ckb", "text": "مشتومڕ؛ گفتوگۆ" },
        { "language": "en", "text": "debate" },
        { "language": "fa", "text": "بحث؛ مناظره" },
        { "language": "kmr", "text": "nîqaş; debate" },
        { "language": "pl", "text": "debata" },
        { "language": "ro", "text": "dezbatere" },
        { "language": "ru", "text": "дебаты; обсуждение" },
        { "language": "sq", "text": "debat" },
        { "language": "tr", "text": "tartışma; münazara" }
      ],
      "examples": [
        {
          "baseText": "Die Debatte war sachlich und fair.",
          "translations": [
            { "language": "ar", "text": "كان النقاش موضوعياً وعادلاً." },
            { "language": "ckb", "text": "مشتومڕەکە بابەتی و دادپەروەرانە بوو." },
            { "language": "en", "text": "The debate was factual and fair." },
            { "language": "fa", "text": "بحث منطقی و منصفانه بود." },
            { "language": "kmr", "text": "Nîqaş rast û adil bû." },
            { "language": "pl", "text": "Debata była rzeczowa i uczciwa." },
            { "language": "ro", "text": "Dezbaterea a fost obiectivă și corectă." },
            { "language": "ru", "text": "Дебаты были предметными и честными." },
            { "language": "sq", "text": "Debati ishte faktik dhe i drejtë." },
            { "language": "tr", "text": "Tartışma nesnel ve adildi." }
          ]
        },
        {
          "baseText": "In der Gruppe entsteht schnell eine lebhafte Debatte.",
          "translations": [
            { "language": "ar", "text": "ينشأ في المجموعة نقاش حيوي بسرعة." },
            { "language": "ckb", "text": "لە گرووپەکەدا زوو مشتومڕێکی زیندوو دروست دەبێت." },
            { "language": "en", "text": "A lively debate quickly develops in the group." },
            { "language": "fa", "text": "در گروه خیلی زود بحثی پرجنب‌وجوش شکل می‌گیرد." },
            { "language": "kmr", "text": "Di komê de zû nîqaşeke zindî çêdibe." },
            { "language": "pl", "text": "W grupie szybko powstaje żywa debata." },
            { "language": "ro", "text": "În grup apare repede o dezbatere vie." },
            { "language": "ru", "text": "В группе быстро возникает оживленная дискуссия." },
            { "language": "sq", "text": "Në grup lind shpejt një debat i gjallë." },
            { "language": "tr", "text": "Grupta hızla canlı bir tartışma oluşur." }
          ]
        }
      ]
