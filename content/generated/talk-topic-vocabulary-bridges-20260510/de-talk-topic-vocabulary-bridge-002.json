      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "العمل من المنزل" },
        { "language": "ckb", "text": "کارکردن لە ماڵەوە" },
        { "language": "en", "text": "home office; working from home" },
        { "language": "fa", "text": "دورکاری؛ کار از خانه" },
        { "language": "kmr", "text": "kar ji malê" },
        { "language": "pl", "text": "praca z domu" },
        { "language": "ro", "text": "muncă de acasă" },
        { "language": "ru", "text": "удаленная работа; работа из дома" },
        { "language": "sq", "text": "punë nga shtëpia" },
        { "language": "tr", "text": "evden çalışma" }
      ],
      "examples": [
        {
          "baseText": "Viele Menschen arbeiten heute im Homeoffice.",
          "translations": [
            { "language": "ar", "text": "يعمل كثير من الناس اليوم من المنزل." },
            { "language": "ckb", "text": "زۆر کەس ئەمڕۆ لە ماڵەوە کار دەکەن." },
            { "language": "en", "text": "Many people work from home today." },
            { "language": "fa", "text": "امروزه افراد زیادی از خانه کار می‌کنند." },
            { "language": "kmr", "text": "Gelek kes îro ji malê dixebitin." },
            { "language": "pl", "text": "Wiele osób pracuje dziś z domu." },
            { "language": "ro", "text": "Mulți oameni lucrează astăzi de acasă." },
            { "language": "ru", "text": "Многие люди сегодня работают из дома." },
            { "language": "sq", "text": "Shumë njerëz sot punojnë nga shtëpia." },
            { "language": "tr", "text": "Bugün birçok insan evden çalışıyor." }
          ]
        },
        {
          "baseText": "Im Homeoffice braucht man klare Absprachen.",
          "translations": [
            { "language": "ar", "text": "في العمل من المنزل يحتاج المرء إلى اتفاقات واضحة." },
            { "language": "ckb", "text": "لە کارکردن لە ماڵەوە ڕێککەوتنی ڕوون پێویستە." },
            { "language": "en", "text": "When working from home, clear agreements are needed." },
            { "language": "fa", "text": "در دورکاری به توافق‌های روشن نیاز است." },
            { "language": "kmr", "text": "Di karê ji malê de lihevkirinên zelal pêwîst in." },
            { "language": "pl", "text": "W pracy z domu potrzebne są jasne ustalenia." },
            { "language": "ro", "text": "În munca de acasă sunt necesare acorduri clare." },
            { "language": "ru", "text": "При работе из дома нужны четкие договоренности." },
            { "language": "sq", "text": "Në punën nga shtëpia duhen marrëveshje të qarta." },
            { "language": "tr", "text": "Evden çalışırken net anlaşmalar gerekir." }
          ]
        }
      ]
