        { "language": "ru", "text": "тело" },
        { "language": "sq", "text": "trup" },
        { "language": "tr", "text": "vücut; beden" }
      ],
      "examples": [
        {
          "baseText": "Der Körper braucht Bewegung und Ruhe.",
          "translations": [
            { "language": "ar", "text": "يحتاج الجسم إلى الحركة والراحة." },
            { "language": "ckb", "text": "جەستە پێویستی بە جووڵە و پشوودان هەیە." },
            { "language": "en", "text": "The body needs movement and rest." },
            { "language": "fa", "text": "بدن به حرکت و استراحت نیاز دارد." },
            { "language": "kmr", "text": "Laş hewceyê liv û bêhnvedanê ye." },
            { "language": "pl", "text": "Ciało potrzebuje ruchu i odpoczynku." },
            { "language": "ro", "text": "Corpul are nevoie de mișcare și odihnă." },
            { "language": "ru", "text": "Телу нужны движение и отдых." },
            { "language": "sq", "text": "Trupi ka nevojë për lëvizje dhe pushim." },
            { "language": "tr", "text": "Vücudun harekete ve dinlenmeye ihtiyacı vardır." }
          ]
        },
        {
          "baseText": "Nach dem Sport fühlt sich mein Körper gut an.",
          "translations": [
            { "language": "ar", "text": "بعد الرياضة يشعر جسمي بأنه بخير." },
            { "language": "ckb", "text": "دوای وەرزش جەستەم هەستێکی باشی هەیە." },
            { "language": "en", "text": "After sport, my body feels good." },
            { "language": "fa", "text": "بعد از ورزش، بدنم حس خوبی دارد." },
            { "language": "kmr", "text": "Piştî werzîşê laşê min baş hîs dike." },
            { "language": "pl", "text": "Po sporcie moje ciało czuje się dobrze." },
            { "language": "ro", "text": "După sport, corpul meu se simte bine." },
            { "language": "ru", "text": "После спорта мое тело чувствует себя хорошо." },
            { "language": "sq", "text": "Pas sportit trupi im ndihet mirë." },
            { "language": "tr", "text": "Spordan sonra vücudum iyi hissediyor." }
          ]
        }
      ]
