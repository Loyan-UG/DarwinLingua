      "grammarNotes": ["feminine noun; plural: die Reisen"],
      "collocations": [
        { "text": "eine Reise planen", "meaning": "to plan a trip" },
        { "text": "auf Reise gehen", "meaning": "to go on a journey" }
      ],
      "wordFamilies": [
        { "lemma": "reisen", "relationLabel": "verb", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "رحلة؛ سفر" },
        { "language": "ckb", "text": "گەشت" },
        { "language": "en", "text": "trip; journey" },
        { "language": "fa", "text": "سفر؛ سفر کوتاه" },
        { "language": "kmr", "text": "rêwîtî; sefer" },
        { "language": "pl", "text": "podróż" },
        { "language": "ro", "text": "călătorie" },
        { "language": "ru", "text": "поездка; путешествие" },
        { "language": "sq", "text": "udhëtim" },
        { "language": "tr", "text": "seyahat; yolculuk" }
      ],
      "examples": [
        {
          "baseText": "Die Reise dauert drei Tage.",
          "translations": [
            { "language": "ar", "text": "تستغرق الرحلة ثلاثة أيام." },
            { "language": "ckb", "text": "گەشتەکە سێ ڕۆژ دەخایەنێت." },
            { "language": "en", "text": "The trip lasts three days." },
            { "language": "fa", "text": "این سفر سه روز طول می‌کشد." },
            { "language": "kmr", "text": "Rêwîtî sê roj dom dike." },
            { "language": "pl", "text": "Podróż trwa trzy dni." },
            { "language": "ro", "text": "Călătoria durează trei zile." },
            { "language": "ru", "text": "Поездка длится три дня." },
            { "language": "sq", "text": "Udhëtimi zgjat tri ditë." },
            { "language": "tr", "text": "Seyahat üç gün sürer." }
          ]
        },
        {
          "baseText": "Wir sprechen über die schönste Reise.",
          "translations": [
            { "language": "ar", "text": "نتحدث عن أجمل رحلة." },
            { "language": "ckb", "text": "دەربارەی جوانترین گەشت قسە دەکەین." },
            { "language": "en", "text": "We talk about the most beautiful trip." },
            { "language": "fa", "text": "ما درباره زیباترین سفر صحبت می‌کنیم." },
            { "language": "kmr", "text": "Em li ser rêwîtiya herî xweşik diaxivin." },
            { "language": "pl", "text": "Rozmawiamy o najpiękniejszej podróży." },
            { "language": "ro", "text": "Vorbim despre cea mai frumoasă călătorie." },
            { "language": "ru", "text": "Мы говорим о самой красивой поездке." },
            { "language": "sq", "text": "Flasim për udhëtimin më të bukur." },
            { "language": "tr", "text": "En güzel seyahat hakkında konuşuyoruz." }
          ]
        }
      ]
    },
    {
      "word": "zuhören",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zuhören",
      "lexicalForms": [
        { "partOfSpeech": "Verb", "article": null, "plural": null, "infinitive": "zuhören", "isPrimary": true }
      ],
      "syllableBreak": "zu-hö-ren",
      "topics": ["everyday-life", "work-and-jobs"],
      "usageLabels": [],
      "contextLabels": [],
      "grammarNotes": ["separable verb; often used with dative: jemandem zuhören"],
      "collocations": [
        { "text": "aufmerksam zuhören", "meaning": "to listen attentively" },
        { "text": "einander zuhören", "meaning": "to listen to each other" }
      ],
      "wordFamilies": [
        { "lemma": "das Zuhören", "relationLabel": "nominalized verb", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "يصغي؛ يستمع" },
        { "language": "ckb", "text": "گوێگرتن" },
        { "language": "en", "text": "to listen" },
        { "language": "fa", "text": "گوش دادن" },
        { "language": "kmr", "text": "guhdarî kirin" },
        { "language": "pl", "text": "słuchać" },
        { "language": "ro", "text": "a asculta" },
        { "language": "ru", "text": "слушать" },
        { "language": "sq", "text": "dëgjoj" },
        { "language": "tr", "text": "dinlemek" }
      ],
      "examples": [
        {
          "baseText": "Bitte hör mir kurz zu.",
          "translations": [
            { "language": "ar", "text": "من فضلك استمع إليّ للحظة." },
            { "language": "ckb", "text": "تکایە کەمێک گوێم لێ بگرە." },
            { "language": "en", "text": "Please listen to me briefly." },
            { "language": "fa", "text": "لطفاً کوتاه به من گوش بده." },
            { "language": "kmr", "text": "Ji kerema xwe demeke kurt guhdarî min bike." },
            { "language": "pl", "text": "Proszę, posłuchaj mnie przez chwilę." },
            { "language": "ro", "text": "Te rog să mă asculți puțin." },
            { "language": "ru", "text": "Пожалуйста, послушай меня немного." },
            { "language": "sq", "text": "Të lutem më dëgjo shkurt." },
            { "language": "tr", "text": "Lütfen beni kısa süre dinle." }
          ]
        },
        {
          "baseText": "In guten Gesprächen hören die Menschen einander zu.",
          "translations": [
            { "language": "ar", "text": "في المحادثات الجيدة يستمع الناس بعضهم إلى بعض." },
            { "language": "ckb", "text": "لە گفتوگۆی باشدا خەڵک گوێ لە یەکتر دەگرن." },
            { "language": "en", "text": "In good conversations, people listen to each other." },
            { "language": "fa", "text": "در گفت‌وگوهای خوب، افراد به هم گوش می‌دهند." },
            { "language": "kmr", "text": "Di axaftinên baş de mirov guhdarî hev dikin." },
            { "language": "pl", "text": "W dobrych rozmowach ludzie słuchają się nawzajem." },
            { "language": "ro", "text": "În conversațiile bune, oamenii se ascultă unii pe alții." },
            { "language": "ru", "text": "В хороших разговорах люди слушают друг друга." },
            { "language": "sq", "text": "Në biseda të mira njerëzit dëgjojnë njëri-tjetrin." },
            { "language": "tr", "text": "İyi konuşmalarda insanlar birbirini dinler." }
          ]
        }
      ]
    },
