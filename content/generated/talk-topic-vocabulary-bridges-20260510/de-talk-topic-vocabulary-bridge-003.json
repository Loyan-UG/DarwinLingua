    {
      "word": "der Alltag",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "lexicalForms": [
        { "partOfSpeech": "Noun", "article": "der", "plural": null, "infinitive": null, "isPrimary": true }
      ],
      "syllableBreak": "All-tag",
      "topics": ["everyday-life"],
      "usageLabels": [],
      "contextLabels": [],
      "grammarNotes": ["masculine noun; usually used in the singular"],
      "collocations": [
        { "text": "im Alltag", "meaning": "in everyday life" },
        { "text": "den Alltag organisieren", "meaning": "to organize everyday life" }
      ],
      "wordFamilies": [
        { "lemma": "alltäglich", "relationLabel": "adjective", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "الحياة اليومية" },
        { "language": "ckb", "text": "ژیانی ڕۆژانە" },
        { "language": "en", "text": "everyday life; daily routine" },
        { "language": "fa", "text": "زندگی روزمره" },
        { "language": "kmr", "text": "jiyana rojane" },
        { "language": "pl", "text": "codzienność" },
        { "language": "ro", "text": "viață de zi cu zi" },
        { "language": "ru", "text": "повседневная жизнь" },
        { "language": "sq", "text": "jeta e përditshme" },
        { "language": "tr", "text": "günlük hayat" }
      ],
      "examples": [
        {
          "baseText": "Im Alltag brauchen wir einfache Lösungen.",
          "translations": [
            { "language": "ar", "text": "في الحياة اليومية نحتاج إلى حلول بسيطة." },
            { "language": "ckb", "text": "لە ژیانی ڕۆژانەدا پێویستمان بە چارەسەری سادە هەیە." },
            { "language": "en", "text": "In everyday life, we need simple solutions." },
            { "language": "fa", "text": "در زندگی روزمره به راه‌حل‌های ساده نیاز داریم." },
            { "language": "kmr", "text": "Di jiyana rojane de em hewceyê çareseriyên hêsan in." },
            { "language": "pl", "text": "W codzienności potrzebujemy prostych rozwiązań." },
            { "language": "ro", "text": "În viața de zi cu zi avem nevoie de soluții simple." },
            { "language": "ru", "text": "В повседневной жизни нам нужны простые решения." },
            { "language": "sq", "text": "Në jetën e përditshme na duhen zgjidhje të thjeshta." },
            { "language": "tr", "text": "Günlük hayatta basit çözümlere ihtiyaç duyarız." }
          ]
        },
        {
          "baseText": "Der Alltag verändert sich durch neue Gewohnheiten.",
          "translations": [
            { "language": "ar", "text": "تتغير الحياة اليومية بسبب عادات جديدة." },
            { "language": "ckb", "text": "ژیانی ڕۆژانە بە خووی نوێ دەگۆڕێت." },
            { "language": "en", "text": "Everyday life changes through new habits." },
            { "language": "fa", "text": "زندگی روزمره با عادت‌های جدید تغییر می‌کند." },
            { "language": "kmr", "text": "Jiyana rojane bi adetên nû diguhere." },
            { "language": "pl", "text": "Codzienność zmienia się przez nowe nawyki." },
            { "language": "ro", "text": "Viața de zi cu zi se schimbă prin obiceiuri noi." },
            { "language": "ru", "text": "Повседневность меняется из-за новых привычек." },
            { "language": "sq", "text": "Jeta e përditshme ndryshon nga zakone të reja." },
            { "language": "tr", "text": "Günlük hayat yeni alışkanlıklarla değişir." }
          ]
        }
      ]
    },
    {
      "word": "der Streit",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Streite",
      "lexicalForms": [
        { "partOfSpeech": "Noun", "article": "der", "plural": "Streite", "infinitive": null, "isPrimary": true }
      ],
      "syllableBreak": "Streit",
      "topics": ["everyday-life", "work-and-jobs"],
      "usageLabels": [],
      "contextLabels": [],
      "grammarNotes": ["masculine noun; plural is possible but less frequent"],
      "collocations": [
        { "text": "einen Streit lösen", "meaning": "to resolve an argument" },
        { "text": "Streit vermeiden", "meaning": "to avoid conflict" }
      ],
      "wordFamilies": [
        { "lemma": "streiten", "relationLabel": "verb", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "خلاف؛ شجار" },
        { "language": "ckb", "text": "ناکۆکی؛ شەڕ" },
        { "language": "en", "text": "argument; conflict" },
        { "language": "fa", "text": "دعوا؛ اختلاف" },
        { "language": "kmr", "text": "nakokî; şer" },
        { "language": "pl", "text": "spór; kłótnia" },
        { "language": "ro", "text": "ceartă; conflict" },
        { "language": "ru", "text": "спор; ссора" },
        { "language": "sq", "text": "grindje; konflikt" },
        { "language": "tr", "text": "tartışma; anlaşmazlık" }
      ],
      "examples": [
        {
          "baseText": "Der Streit beginnt oft mit einem Missverständnis.",
          "translations": [
            { "language": "ar", "text": "يبدأ الخلاف غالباً بسوء فهم." },
            { "language": "ckb", "text": "ناکۆکی زۆرجار بە تێنەگەیشتن دەست پێدەکات." },
            { "language": "en", "text": "The argument often starts with a misunderstanding." },
            { "language": "fa", "text": "دعوا اغلب با یک سوءتفاهم شروع می‌شود." },
            { "language": "kmr", "text": "Nakokî pir caran bi şaşfêmkirinê dest pê dike." },
            { "language": "pl", "text": "Spór często zaczyna się od nieporozumienia." },
            { "language": "ro", "text": "Cearta începe adesea cu o neînțelegere." },
            { "language": "ru", "text": "Спор часто начинается с недоразумения." },
            { "language": "sq", "text": "Grindja shpesh fillon me një keqkuptim." },
            { "language": "tr", "text": "Tartışma çoğu zaman bir yanlış anlamayla başlar." }
          ]
        },
        {
          "baseText": "Nach dem Gespräch war der Streit kleiner.",
          "translations": [
            { "language": "ar", "text": "بعد الحديث أصبح الخلاف أصغر." },
            { "language": "ckb", "text": "دوای گفتوگۆکە ناکۆکییەکە کەمتر بوو." },
            { "language": "en", "text": "After the conversation, the conflict was smaller." },
            { "language": "fa", "text": "بعد از گفت‌وگو، اختلاف کمتر شد." },
            { "language": "kmr", "text": "Piştî axaftinê nakokî kêmtir bû." },
            { "language": "pl", "text": "Po rozmowie spór był mniejszy." },
            { "language": "ro", "text": "După conversație, conflictul a fost mai mic." },
            { "language": "ru", "text": "После разговора конфликт стал меньше." },
            { "language": "sq", "text": "Pas bisedës konflikti u zvogëlua." },
            { "language": "tr", "text": "Konuşmadan sonra anlaşmazlık azaldı." }
          ]
        }
      ]
    },
    {
      "word": "die Reise",
