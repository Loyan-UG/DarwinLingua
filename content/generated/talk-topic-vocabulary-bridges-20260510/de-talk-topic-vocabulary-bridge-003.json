      "plural": "Reisen",
      "lexicalForms": [
        { "partOfSpeech": "Noun", "article": "die", "plural": "Reisen", "infinitive": null, "isPrimary": true }
      ],
      "syllableBreak": "Rei-se",
      "topics": ["everyday-life", "shopping"],
      "usageLabels": [],
