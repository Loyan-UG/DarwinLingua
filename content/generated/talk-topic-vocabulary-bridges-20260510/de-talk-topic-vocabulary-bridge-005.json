        { "language": "kmr", "text": "konser" },
        { "language": "pl", "text": "koncert" },
        { "language": "ro", "text": "concert" },
        { "language": "ru", "text": "концерт" },
        { "language": "sq", "text": "koncert" },
        { "language": "tr", "text": "konser" }
      ],
      "examples": [
        {
          "baseText": "Das Konzert beginnt um acht Uhr.",
          "translations": [
            { "language": "ar", "text": "تبدأ الحفلة الموسيقية في الساعة الثامنة." },
            { "language": "ckb", "text": "کۆنسێرتەکە کاتژمێر هەشت دەست پێدەکات." },
            { "language": "en", "text": "The concert begins at eight o'clock." },
            { "language": "fa", "text": "کنسرت ساعت هشت شروع می‌شود." },
            { "language": "kmr", "text": "Konser saet heştê dest pê dike." },
            { "language": "pl", "text": "Koncert zaczyna się o ósmej." },
            { "language": "ro", "text": "Concertul începe la ora opt." },
            { "language": "ru", "text": "Концерт начинается в восемь часов." },
            { "language": "sq", "text": "Koncerti fillon në orën tetë." },
            { "language": "tr", "text": "Konser saat sekizde başlar." }
          ]
        },
        {
          "baseText": "Nach dem Konzert sprechen wir über die Musik.",
          "translations": [
            { "language": "ar", "text": "بعد الحفلة نتحدث عن الموسيقى." },
            { "language": "ckb", "text": "دوای کۆنسێرتەکە دەربارەی موزیک قسە دەکەین." },
            { "language": "en", "text": "After the concert, we talk about the music." },
            { "language": "fa", "text": "بعد از کنسرت درباره موسیقی صحبت می‌کنیم." },
            { "language": "kmr", "text": "Piştî konserê em li ser muzîkê diaxivin." },
            { "language": "pl", "text": "Po koncercie rozmawiamy o muzyce." },
            { "language": "ro", "text": "După concert vorbim despre muzică." },
            { "language": "ru", "text": "После концерта мы говорим о музыке." },
            { "language": "sq", "text": "Pas koncertit flasim për muzikën." },
            { "language": "tr", "text": "Konserden sonra müzik hakkında konuşuruz." }
          ]
        }
