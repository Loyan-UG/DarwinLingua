    {
      "word": "die Erde",
      "language": "de",
      "cefrLevel": "A1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "lexicalForms": [
        { "partOfSpeech": "Noun", "article": "die", "plural": null, "infinitive": null, "isPrimary": true }
      ],
      "syllableBreak": "Er-de",
      "topics": ["everyday-life"],
      "usageLabels": [],
      "contextLabels": [],
      "grammarNotes": ["feminine noun; usually used in the singular when it means the planet Earth"],
      "collocations": [
        { "text": "auf der Erde", "meaning": "on Earth" },
        { "text": "die Erde schützen", "meaning": "to protect Earth" }
      ],
      "wordFamilies": [
        { "lemma": "irdisch", "relationLabel": "adjective", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "الأرض" },
        { "language": "ckb", "text": "زەوی" },
        { "language": "en", "text": "Earth; ground" },
        { "language": "fa", "text": "زمین؛ خاک" },
        { "language": "kmr", "text": "erd; ax" },
        { "language": "pl", "text": "Ziemia; ziemia" },
        { "language": "ro", "text": "Pământ; pământ" },
        { "language": "ru", "text": "Земля; земля" },
        { "language": "sq", "text": "Toka; dheu" },
        { "language": "tr", "text": "Dünya; toprak" }
      ],
      "examples": [
        {
          "baseText": "Die Erde ist unser Planet.",
          "translations": [
            { "language": "ar", "text": "الأرض هي كوكبنا." },
            { "language": "ckb", "text": "زەوی هەسارەی ئێمەیە." },
            { "language": "en", "text": "Earth is our planet." },
            { "language": "fa", "text": "زمین سیاره ماست." },
            { "language": "kmr", "text": "Erd gerstêrka me ye." },
            { "language": "pl", "text": "Ziemia jest naszą planetą." },
            { "language": "ro", "text": "Pământul este planeta noastră." },
            { "language": "ru", "text": "Земля — наша планета." },
            { "language": "sq", "text": "Toka është planeti ynë." },
            { "language": "tr", "text": "Dünya bizim gezegenimizdir." }
          ]
        },
        {
          "baseText": "Viele Menschen sprechen über die Zukunft der Erde.",
          "translations": [
            { "language": "ar", "text": "يتحدث كثير من الناس عن مستقبل الأرض." },
            { "language": "ckb", "text": "زۆر کەس دەربارەی داهاتووی زەوی قسە دەکەن." },
            { "language": "en", "text": "Many people talk about the future of Earth." },
            { "language": "fa", "text": "افراد زیادی درباره آینده زمین صحبت می‌کنند." },
            { "language": "kmr", "text": "Gelek kes li ser pêşeroja erdê diaxivin." },
            { "language": "pl", "text": "Wiele osób mówi o przyszłości Ziemi." },
            { "language": "ro", "text": "Mulți oameni vorbesc despre viitorul Pământului." },
            { "language": "ru", "text": "Многие люди говорят о будущем Земли." },
            { "language": "sq", "text": "Shumë njerëz flasin për të ardhmen e Tokës." },
            { "language": "tr", "text": "Birçok insan Dünya'nın geleceği hakkında konuşuyor." }
          ]
        }
      ]
    },
    {
      "word": "das Glück",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": null,
      "lexicalForms": [
        { "partOfSpeech": "Noun", "article": "das", "plural": null, "infinitive": null, "isPrimary": true }
      ],
      "syllableBreak": "Glück",
      "topics": ["everyday-life"],
      "usageLabels": [],
      "contextLabels": [],
      "grammarNotes": ["neuter noun; usually used in the singular"],
      "collocations": [
        { "text": "Glück haben", "meaning": "to be lucky" },
        { "text": "persönliches Glück", "meaning": "personal happiness" }
      ],
      "wordFamilies": [
        { "lemma": "glücklich", "relationLabel": "adjective", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "سعادة؛ حظ" },
        { "language": "ckb", "text": "بەخت؛ دڵخۆشی" },
        { "language": "en", "text": "happiness; luck" },
        { "language": "fa", "text": "خوشبختی؛ شانس" },
        { "language": "kmr", "text": "bext; kêfxweşî" },
        { "language": "pl", "text": "szczęście" },
        { "language": "ro", "text": "fericire; noroc" },
        { "language": "ru", "text": "счастье; удача" },
        { "language": "sq", "text": "lumturi; fat" },
        { "language": "tr", "text": "mutluluk; şans" }
      ],
      "examples": [
        {
          "baseText": "Für viele Menschen bedeutet Glück etwas anderes.",
          "translations": [
            { "language": "ar", "text": "تعني السعادة شيئاً مختلفاً لكثير من الناس." },
            { "language": "ckb", "text": "بۆ زۆر کەس بەخت واتای جیاواز هەیە." },
            { "language": "en", "text": "For many people, happiness means something different." },
            { "language": "fa", "text": "برای بسیاری از مردم، خوشبختی معنای متفاوتی دارد." },
            { "language": "kmr", "text": "Ji bo gelek kesan kêfxweşî tiştekî cuda tê wate kirin." },
            { "language": "pl", "text": "Dla wielu ludzi szczęście znaczy coś innego." },
            { "language": "ro", "text": "Pentru mulți oameni, fericirea înseamnă altceva." },
            { "language": "ru", "text": "Для многих людей счастье означает разное." },
            { "language": "sq", "text": "Për shumë njerëz lumturia do të thotë diçka tjetër." },
            { "language": "tr", "text": "Birçok insan için mutluluk farklı bir şey ifade eder." }
          ]
        },
        {
          "baseText": "Wir hatten Glück mit dem Wetter.",
          "translations": [
            { "language": "ar", "text": "كان لدينا حظ جيد مع الطقس." },
            { "language": "ckb", "text": "لە بارودۆخی کەشدا بەختیار بووین." },
            { "language": "en", "text": "We were lucky with the weather." },
            { "language": "fa", "text": "ما از نظر هوا شانس آوردیم." },
            { "language": "kmr", "text": "Bi hewayê re me bext hebû." },
            { "language": "pl", "text": "Mieliśmy szczęście z pogodą." },
            { "language": "ro", "text": "Am avut noroc cu vremea." },
            { "language": "ru", "text": "Нам повезло с погодой." },
            { "language": "sq", "text": "Patëm fat me motin." },
            { "language": "tr", "text": "Hava konusunda şanslıydık." }
          ]
        }
      ]
    },
    {
