        { "language": "fa", "text": "موزه" },
        { "language": "kmr", "text": "muzexane" },
        { "language": "pl", "text": "muzeum" },
        { "language": "ro", "text": "muzeu" },
        { "language": "ru", "text": "музей" },
        { "language": "sq", "text": "muze" },
        { "language": "tr", "text": "müze" }
      ],
      "examples": [
        {
          "baseText": "Am Sonntag besuchen wir ein Museum.",
          "translations": [
            { "language": "ar", "text": "يوم الأحد نزور متحفاً." },
            { "language": "ckb", "text": "یەکشەممە سەردانی مۆزەخانەیەک دەکەین." },
            { "language": "en", "text": "On Sunday, we visit a museum." },
            { "language": "fa", "text": "یکشنبه از یک موزه بازدید می‌کنیم." },
            { "language": "kmr", "text": "Yekşemê em serdana muzexaneyekê dikin." },
            { "language": "pl", "text": "W niedzielę odwiedzamy muzeum." },
            { "language": "ro", "text": "Duminică vizităm un muzeu." },
            { "language": "ru", "text": "В воскресенье мы посещаем музей." },
            { "language": "sq", "text": "Të dielën vizitojmë një muze." },
            { "language": "tr", "text": "Pazar günü bir müzeyi ziyaret ediyoruz." }
          ]
        },
        {
          "baseText": "Im Museum sehen die Kinder alte Bilder.",
          "translations": [
            { "language": "ar", "text": "في المتحف يرى الأطفال صوراً قديمة." },
            { "language": "ckb", "text": "لە مۆزەخانەدا منداڵەکان وێنەی کۆن دەبینن." },
            { "language": "en", "text": "In the museum, the children see old pictures." },
            { "language": "fa", "text": "در موزه، کودکان عکس‌های قدیمی می‌بینند." },
            { "language": "kmr", "text": "Li muzexaneyê zarok wêneyên kevn dibînin." },
            { "language": "pl", "text": "W muzeum dzieci oglądają stare obrazy." },
            { "language": "ro", "text": "În muzeu, copiii văd imagini vechi." },
            { "language": "ru", "text": "В музее дети видят старые картины." },
            { "language": "sq", "text": "Në muze fëmijët shohin fotografi të vjetra." },
            { "language": "tr", "text": "Müzede çocuklar eski resimleri görür." }
          ]
        }
