      ],
      "wordFamilies": [
        { "lemma": "das Tier", "relationLabel": "base noun", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "حيوان أليف" },
        { "language": "ckb", "text": "ئاژەڵی ماڵی" },
        { "language": "en", "text": "pet" },
        { "language": "fa", "text": "حیوان خانگی" },
        { "language": "kmr", "text": "ajala malê" },
        { "language": "pl", "text": "zwierzę domowe" },
        { "language": "ro", "text": "animal de companie" },
        { "language": "ru", "text": "домашнее животное" },
        { "language": "sq", "text": "kafshë shtëpiake" },
        { "language": "tr", "text": "evcil hayvan" }
      ],
      "examples": [
        {
          "baseText": "Ein Haustier braucht Zeit und Pflege.",
          "translations": [
            { "language": "ar", "text": "يحتاج الحيوان الأليف إلى وقت ورعاية." },
            { "language": "ckb", "text": "ئاژەڵی ماڵی پێویستی بە کات و چاودێری هەیە." },
            { "language": "en", "text": "A pet needs time and care." },
            { "language": "fa", "text": "حیوان خانگی به زمان و مراقبت نیاز دارد." },
            { "language": "kmr", "text": "Ajala malê hewceyê dem û lênêrînê ye." },
            { "language": "pl", "text": "Zwierzę domowe potrzebuje czasu i opieki." },
            { "language": "ro", "text": "Un animal de companie are nevoie de timp și îngrijire." },
            { "language": "ru", "text": "Домашнему животному нужны время и уход." },
            { "language": "sq", "text": "Një kafshë shtëpiake ka nevojë për kohë dhe kujdes." },
            { "language": "tr", "text": "Evcil hayvan zaman ve bakım ister." }
          ]
        },
        {
          "baseText": "Viele Familien wünschen sich ein Haustier.",
          "translations": [
            { "language": "ar", "text": "تتمنى كثير من العائلات حيواناً أليفاً." },
            { "language": "ckb", "text": "زۆر خێزان ئارەزووی ئاژەڵێکی ماڵی دەکەن." },
            { "language": "en", "text": "Many families would like to have a pet." },
            { "language": "fa", "text": "بسیاری از خانواده‌ها دوست دارند حیوان خانگی داشته باشند." },
            { "language": "kmr", "text": "Gelek malbat dixwazin ajaleke malê hebin." },
            { "language": "pl", "text": "Wiele rodzin chciałoby mieć zwierzę domowe." },
            { "language": "ro", "text": "Multe familii își doresc un animal de companie." },
            { "language": "ru", "text": "Многие семьи хотят домашнее животное." },
            { "language": "sq", "text": "Shumë familje dëshirojnë një kafshë shtëpiake." },
            { "language": "tr", "text": "Birçok aile evcil hayvan ister." }
          ]
        }
      ]
    },
