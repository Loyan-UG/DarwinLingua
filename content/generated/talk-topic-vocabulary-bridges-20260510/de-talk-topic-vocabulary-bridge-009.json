      ],
      "examples": [
        {
          "baseText": "Fairness ist im Sport und im Alltag wichtig.",
          "translations": [
            { "language": "ar", "text": "الإنصاف مهم في الرياضة والحياة اليومية." },
            { "language": "ckb", "text": "دادپەروەری لە وەرزش و ژیانی ڕۆژانەدا گرنگە." },
            { "language": "en", "text": "Fairness is important in sport and everyday life." },
            { "language": "fa", "text": "انصاف در ورزش و زندگی روزمره مهم است." },
            { "language": "kmr", "text": "Dadperwerî di werzîşê û jiyana rojane de girîng e." },
            { "language": "pl", "text": "Fair play jest ważne w sporcie i codziennym życiu." },
            { "language": "ro", "text": "Corectitudinea este importantă în sport și în viața de zi cu zi." },
            { "language": "ru", "text": "Честность важна в спорте и повседневной жизни." },
            { "language": "sq", "text": "Drejtësia është e rëndësishme në sport dhe në jetën e përditshme." },
            { "language": "tr", "text": "Adil davranış sporda ve günlük hayatta önemlidir." }
          ]
        },
        {
          "baseText": "Die Mannschaft spricht nach dem Spiel über Fairness.",
          "translations": [
            { "language": "ar", "text": "يتحدث الفريق بعد المباراة عن الإنصاف." },
            { "language": "ckb", "text": "تیمەکە دوای یارییەکە دەربارەی دادپەروەری قسە دەکات." },
            { "language": "en", "text": "The team talks about fairness after the game." },
            { "language": "fa", "text": "تیم بعد از بازی درباره انصاف صحبت می‌کند." },
            { "language": "kmr", "text": "Tîm piştî lîstikê li ser dadperweriyê diaxive." },
            { "language": "pl", "text": "Drużyna po meczu rozmawia o fair play." },
            { "language": "ro", "text": "Echipa vorbește despre corectitudine după meci." },
            { "language": "ru", "text": "Команда после игры говорит о честности." },
            { "language": "sq", "text": "Ekipi flet për drejtësinë pas lojës." },
            { "language": "tr", "text": "Takım maçtan sonra adil davranış hakkında konuşur." }
