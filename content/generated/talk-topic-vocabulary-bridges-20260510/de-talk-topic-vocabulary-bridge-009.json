      "meanings": [
        { "language": "ar", "text": "لعبة؛ مباراة" },
        { "language": "ckb", "text": "یاری" },
        { "language": "en", "text": "game; match" },
        { "language": "fa", "text": "بازی؛ مسابقه" },
        { "language": "kmr", "text": "lîstik; maç" },
        { "language": "pl", "text": "gra; mecz" },
        { "language": "ro", "text": "joc; meci" },
        { "language": "ru", "text": "игра; матч" },
        { "language": "sq", "text": "lojë; ndeshje" },
        { "language": "tr", "text": "oyun; maç" }
      ],
      "examples": [
        {
          "baseText": "Das Spiel beginnt um drei Uhr.",
          "translations": [
            { "language": "ar", "text": "تبدأ المباراة في الساعة الثالثة." },
            { "language": "ckb", "text": "یارییەکە کاتژمێر سێ دەست پێدەکات." },
            { "language": "en", "text": "The game starts at three o'clock." },
            { "language": "fa", "text": "بازی ساعت سه شروع می‌شود." },
            { "language": "kmr", "text": "Lîstik saet sêyan dest pê dike." },
            { "language": "pl", "text": "Gra zaczyna się o trzeciej." },
            { "language": "ro", "text": "Jocul începe la ora trei." },
            { "language": "ru", "text": "Игра начинается в три часа." },
            { "language": "sq", "text": "Loja fillon në orën tre." },
            { "language": "tr", "text": "Oyun saat üçte başlar." }
          ]
        },
        {
          "baseText": "Nach dem Spiel sprechen die Kinder über Fairness.",
          "translations": [
            { "language": "ar", "text": "بعد اللعبة يتحدث الأطفال عن الإنصاف." },
            { "language": "ckb", "text": "دوای یارییەکە منداڵەکان دەربارەی دادپەروەری قسە دەکەن." },
            { "language": "en", "text": "After the game, the children talk about fairness." },
            { "language": "fa", "text": "بعد از بازی، کودکان درباره انصاف صحبت می‌کنند." },
            { "language": "kmr", "text": "Piştî lîstikê zarok li ser dadperweriyê diaxivin." },
            { "language": "pl", "text": "Po grze dzieci rozmawiają o fair play." },
            { "language": "ro", "text": "După joc, copiii vorbesc despre corectitudine." },
            { "language": "ru", "text": "После игры дети говорят о честности." },
            { "language": "sq", "text": "Pas lojës fëmijët flasin për drejtësinë." },
            { "language": "tr", "text": "Oyundan sonra çocuklar adil davranış hakkında konuşur." }
          ]
        }
      ]
    },
    {
      "word": "der Fußball",
