      ],
      "examples": [
        {
          "baseText": "Eine gute Freundschaft braucht Zeit und Vertrauen.",
          "translations": [
            { "language": "ar", "text": "تحتاج الصداقة الجيدة إلى وقت وثقة." },
            { "language": "ckb", "text": "هاوڕێیەتییەکی باش پێویستی بە کات و متمانە هەیە." },
            { "language": "en", "text": "A good friendship needs time and trust." },
            { "language": "fa", "text": "یک دوستی خوب به زمان و اعتماد نیاز دارد." },
            { "language": "kmr", "text": "Hevaltiyeke baş hewceyê dem û baweriyê ye." },
            { "language": "pl", "text": "Dobra przyjaźń potrzebuje czasu i zaufania." },
            { "language": "ro", "text": "O prietenie bună are nevoie de timp și încredere." },
            { "language": "ru", "text": "Хорошей дружбе нужны время и доверие." },
            { "language": "sq", "text": "Një miqësi e mirë ka nevojë për kohë dhe besim." },
            { "language": "tr", "text": "İyi bir arkadaşlık zaman ve güven ister." }
          ]
        },
        {
          "baseText": "Auch online kann eine Freundschaft entstehen.",
          "translations": [
            { "language": "ar", "text": "يمكن أن تنشأ صداقة أيضاً عبر الإنترنت." },
