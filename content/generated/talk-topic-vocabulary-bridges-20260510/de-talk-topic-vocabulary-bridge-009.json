        { "lemma": "der Fußballer", "relationLabel": "related noun", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "كرة القدم" },
        { "language": "ckb", "text": "تۆپی پێ" },
        { "language": "en", "text": "football; soccer" },
        { "language": "fa", "text": "فوتبال" },
        { "language": "kmr", "text": "futbol" },
        { "language": "pl", "text": "piłka nożna; futbol" },
        { "language": "ro", "text": "fotbal" },
        { "language": "ru", "text": "футбол" },
        { "language": "sq", "text": "futboll" },
        { "language": "tr", "text": "futbol" }
      ],
      "examples": [
        {
          "baseText": "Viele Kinder spielen gern Fußball.",
          "translations": [
            { "language": "ar", "text": "كثير من الأطفال يحبون لعب كرة القدم." },
            { "language": "ckb", "text": "زۆر منداڵ حەز دەکەن تۆپی پێ بکەن." },
            { "language": "en", "text": "Many children like playing football." },
            { "language": "fa", "text": "بسیاری از کودکان دوست دارند فوتبال بازی کنند." },
            { "language": "kmr", "text": "Gelek zarok hez dikin futbolê bilîzin." },
            { "language": "pl", "text": "Wiele dzieci lubi grać w piłkę nożną." },
            { "language": "ro", "text": "Mulți copii joacă fotbal cu plăcere." },
            { "language": "ru", "text": "Многие дети любят играть в футбол." },
            { "language": "sq", "text": "Shumë fëmijë duan të luajnë futboll." },
            { "language": "tr", "text": "Birçok çocuk futbol oynamayı sever." }
          ]
        },
        {
          "baseText": "Beim Fußball sind Teamgeist und Fairness wichtig.",
          "translations": [
            { "language": "ar", "text": "في كرة القدم روح الفريق والإنصاف مهمان." },
            { "language": "ckb", "text": "لە تۆپی پێدا ڕۆحی تیم و دادپەروەری گرنگن." },
            { "language": "en", "text": "In football, team spirit and fairness are important." },
            { "language": "fa", "text": "در فوتبال، روحیه تیمی و انصاف مهم هستند." },
            { "language": "kmr", "text": "Di futbolê de ruhê tîmê û dadperwerî girîng in." },
            { "language": "pl", "text": "W piłce nożnej ważne są duch zespołu i fair play." },
            { "language": "ro", "text": "În fotbal, spiritul de echipă și corectitudinea sunt importante." },
            { "language": "ru", "text": "В футболе важны командный дух и честность." },
            { "language": "sq", "text": "Në futboll janë të rëndësishme fryma e ekipit dhe drejtësia." },
            { "language": "tr", "text": "Futbolda takım ruhu ve adil oyun önemlidir." }
          ]
        }
      ]
    },
