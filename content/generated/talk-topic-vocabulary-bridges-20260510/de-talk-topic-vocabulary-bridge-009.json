        { "language": "ro", "text": "arbitru" },
        { "language": "ru", "text": "судья; арбитр" },
        { "language": "sq", "text": "gjyqtar; arbitër" },
        { "language": "tr", "text": "hakem" }
      ],
      "examples": [
        {
          "baseText": "Der Schiedsrichter erklärt seine Entscheidung.",
          "translations": [
            { "language": "ar", "text": "يشرح الحكم قراره." },
            { "language": "ckb", "text": "دادوەرەکە بڕیارەکەی ڕوون دەکاتەوە." },
            { "language": "en", "text": "The referee explains his decision." },
            { "language": "fa", "text": "داور تصمیم خود را توضیح می‌دهد." },
            { "language": "kmr", "text": "Hakem biryara xwe rave dike." },
            { "language": "pl", "text": "Sędzia wyjaśnia swoją decyzję." },
            { "language": "ro", "text": "Arbitrul își explică decizia." },
            { "language": "ru", "text": "Судья объясняет свое решение." },
            { "language": "sq", "text": "Arbitri shpjegon vendimin e tij." },
            { "language": "tr", "text": "Hakem kararını açıklar." }
          ]
        },
        {
          "baseText": "Ohne Schiedsrichter ist ein großes Spiel schwer zu leiten.",
          "translations": [
            { "language": "ar", "text": "من الصعب إدارة مباراة كبيرة دون حكم." },
            { "language": "ckb", "text": "بێ دادوەر بەڕێوەبردنی یارییەکی گەورە قورسە." },
            { "language": "en", "text": "Without a referee, a big game is hard to manage." },
            { "language": "fa", "text": "بدون داور، اداره یک بازی بزرگ دشوار است." },
            { "language": "kmr", "text": "Bê hakem rêvebirina lîstikeke mezin zehmet e." },
            { "language": "pl", "text": "Bez sędziego trudno prowadzić duży mecz." },
            { "language": "ro", "text": "Fără arbitru, un meci mare este greu de condus." },
            { "language": "ru", "text": "Без судьи большой матч трудно вести." },
            { "language": "sq", "text": "Pa arbitër është e vështirë të drejtosh një lojë të madhe." },
            { "language": "tr", "text": "Hakem olmadan büyük bir maçı yönetmek zordur." }
          ]
        }
      ]
    },
