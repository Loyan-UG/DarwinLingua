      "meanings": [
        { "language": "ar", "text": "الفضاء؛ الكون" },
        { "language": "ckb", "text": "گەردوون؛ ئاسمان" },
        { "language": "en", "text": "space; universe" },
        { "language": "fa", "text": "فضا؛ جهان" },
        { "language": "kmr", "text": "asman; gerdûn" },
