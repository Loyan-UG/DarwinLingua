        { "language": "ro", "text": "spațiu public; piață publică" },
        { "language": "ru", "text": "общественная площадь; общественное место" },
        { "language": "sq", "text": "shesh publik; vend publik" },
        { "language": "tr", "text": "kamusal meydan; kamusal alan" }
      ],
      "examples": [
        {
          "baseText": "Der öffentliche Platz ist ein Treffpunkt für viele Menschen.",
          "translations": [
            { "language": "ar", "text": "الساحة العامة مكان لقاء لكثير من الناس." },
            { "language": "ckb", "text": "شوێنە گشتییەکە خاڵی دیداری زۆر کەسە." },
            { "language": "en", "text": "The public square is a meeting place for many people." },
            { "language": "fa", "text": "میدان عمومی محل دیدار افراد زیادی است." },
            { "language": "kmr", "text": "Qada giştî cihê hevdîtina gelek kesan e." },
            { "language": "pl", "text": "Plac publiczny jest miejscem spotkań wielu osób." },
            { "language": "ro", "text": "Spațiul public este un loc de întâlnire pentru mulți oameni." },
            { "language": "ru", "text": "Общественная площадь является местом встречи для многих людей." },
            { "language": "sq", "text": "Sheshi publik është vendtakim për shumë njerëz." },
            { "language": "tr", "text": "Kamusal meydan birçok insan için buluşma yeridir." }
          ]
        },
        {
          "baseText": "In der Diskussion geht es um sichere öffentliche Plätze.",
          "translations": [
            { "language": "ar", "text": "يدور النقاش حول الأماكن العامة الآمنة." },
            { "language": "ckb", "text": "گفتوگۆکە دەربارەی شوێنە گشتییە پارێزراوەکانە." },
            { "language": "en", "text": "The discussion is about safe public places." },
            { "language": "fa", "text": "بحث درباره فضاهای عمومی امن است." },
            { "language": "kmr", "text": "Nîqaş li ser cihên giştî yên ewle ye." },
            { "language": "pl", "text": "Dyskusja dotyczy bezpiecznych miejsc publicznych." },
            { "language": "ro", "text": "Discuția este despre spații publice sigure." },
            { "language": "ru", "text": "Обсуждение касается безопасных общественных мест." },
            { "language": "sq", "text": "Diskutimi është për vende publike të sigurta." },
            { "language": "tr", "text": "Tartışma güvenli kamusal alanlarla ilgilidir." }
          ]
        }
      ]
