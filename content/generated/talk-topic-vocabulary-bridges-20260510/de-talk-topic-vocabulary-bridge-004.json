      ],
      "syllableBreak": "Be-we-gung",
      "topics": ["appointments-and-health", "everyday-life"],
      "usageLabels": [],
      "contextLabels": [],
      "grammarNotes": ["feminine noun; plural: die Bewegungen"],
      "collocations": [
        { "text": "regelmäßige Bewegung", "meaning": "regular movement or exercise" },
        { "text": "Bewegung im Alltag", "meaning": "movement in everyday life" }
      ],
      "wordFamilies": [
        { "lemma": "bewegen", "relationLabel": "verb", "note": null },
        { "lemma": "beweglich", "relationLabel": "adjective", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "حركة؛ نشاط بدني" },
        { "language": "ckb", "text": "جووڵە؛ چالاکی جەستەیی" },
        { "language": "en", "text": "movement; physical activity" },
        { "language": "fa", "text": "حرکت؛ فعالیت بدنی" },
        { "language": "kmr", "text": "liv; çalakiya laşî" },
        { "language": "pl", "text": "ruch; aktywność fizyczna" },
        { "language": "ro", "text": "mișcare; activitate fizică" },
        { "language": "ru", "text": "движение; физическая активность" },
        { "language": "sq", "text": "lëvizje; aktivitet fizik" },
        { "language": "tr", "text": "hareket; fiziksel aktivite" }
      ],
      "examples": [
        {
          "baseText": "Bewegung ist gut für die Gesundheit.",
          "translations": [
            { "language": "ar", "text": "الحركة مفيدة للصحة." },
            { "language": "ckb", "text": "جووڵە بۆ تەندروستی باشە." },
            { "language": "en", "text": "Movement is good for health." },
            { "language": "fa", "text": "حرکت برای سلامتی خوب است." },
            { "language": "kmr", "text": "Liv ji bo tenduristiyê baş e." },
            { "language": "pl", "text": "Ruch jest dobry dla zdrowia." },
            { "language": "ro", "text": "Mișcarea este bună pentru sănătate." },
            { "language": "ru", "text": "Движение полезно для здоровья." },
            { "language": "sq", "text": "Lëvizja është e mirë për shëndetin." },
            { "language": "tr", "text": "Hareket sağlık için iyidir." }
          ]
        },
        {
          "baseText": "Mehr Bewegung kann den Alltag leichter machen.",
          "translations": [
            { "language": "ar", "text": "يمكن أن تجعل الحركة أكثر الحياة اليومية أسهل." },
            { "language": "ckb", "text": "جووڵەی زیاتر دەتوانێت ژیانی ڕۆژانە ئاسانتر بکات." },
            { "language": "en", "text": "More movement can make everyday life easier." },
            { "language": "fa", "text": "حرکت بیشتر می‌تواند زندگی روزمره را آسان‌تر کند." },
            { "language": "kmr", "text": "Livê zêdetir dikare jiyana rojane hêsantir bike." },
            { "language": "pl", "text": "Więcej ruchu może ułatwić codzienność." },
            { "language": "ro", "text": "Mai multă mișcare poate face viața de zi cu zi mai ușoară." },
            { "language": "ru", "text": "Больше движения может облегчить повседневную жизнь." },
            { "language": "sq", "text": "Më shumë lëvizje mund ta bëjë jetën e përditshme më të lehtë." },
            { "language": "tr", "text": "Daha fazla hareket günlük hayatı kolaylaştırabilir." }
          ]
        }
      ]
    },
