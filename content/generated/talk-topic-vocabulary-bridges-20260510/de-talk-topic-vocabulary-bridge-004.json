        { "language": "ru", "text": "космос; вселенная" },
        { "language": "sq", "text": "hapësirë; univers" },
        { "language": "tr", "text": "uzay; evren" }
      ],
      "examples": [
        {
          "baseText": "Viele Kinder interessieren sich für das Weltall.",
          "translations": [
            { "language": "ar", "text": "يهتم كثير من الأطفال بالفضاء." },
            { "language": "ckb", "text": "زۆر منداڵ بە گەردوون دڵخوازن." },
            { "language": "en", "text": "Many children are interested in space." },
            { "language": "fa", "text": "بسیاری از کودکان به فضا علاقه دارند." },
            { "language": "kmr", "text": "Gelek zarok bi asmanê re eleqedar in." },
            { "language": "pl", "text": "Wiele dzieci interesuje się kosmosem." },
            { "language": "ro", "text": "Mulți copii sunt interesați de spațiu." },
            { "language": "ru", "text": "Многие дети интересуются космосом." },
            { "language": "sq", "text": "Shumë fëmijë interesohen për hapësirën." },
            { "language": "tr", "text": "Birçok çocuk uzayla ilgilenir." }
          ]
        },
        {
          "baseText": "Im Weltall gibt es viele offene Fragen.",
          "translations": [
            { "language": "ar", "text": "في الفضاء توجد أسئلة كثيرة مفتوحة." },
            { "language": "ckb", "text": "لە گەردووندا پرسیاری زۆری کراوە هەیە." },
            { "language": "en", "text": "There are many open questions in space." },
            { "language": "fa", "text": "در فضا پرسش‌های باز زیادی وجود دارد." },
            { "language": "kmr", "text": "Di asmanê de gelek pirsên vekirî hene." },
            { "language": "pl", "text": "W kosmosie jest wiele otwartych pytań." },
            { "language": "ro", "text": "În spațiu există multe întrebări deschise." },
            { "language": "ru", "text": "В космосе есть много открытых вопросов." },
            { "language": "sq", "text": "Në hapësirë ka shumë pyetje të hapura." },
            { "language": "tr", "text": "Uzayda birçok açık soru vardır." }
          ]
        }
      ]
    },
