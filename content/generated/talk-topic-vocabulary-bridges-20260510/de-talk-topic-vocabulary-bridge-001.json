    {
      "word": "die Frage",
      "language": "de",
      "cefrLevel": "A1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Fragen",
      "lexicalForms": [
        { "partOfSpeech": "Noun", "article": "die", "plural": "Fragen", "infinitive": null, "isPrimary": true }
      ],
      "pronunciationIpa": null,
      "syllableBreak": "Fra-ge",
      "topics": [ "everyday-life", "work-and-jobs" ],
      "usageLabels": [ "spoken", "written", "high-frequency" ],
      "contextLabels": [ "discussion" ],
      "grammarNotes": [ "feminine noun; plural: die Fragen" ],
      "collocations": [
        { "text": "eine Frage stellen", "meaning": "to ask a question" },
        { "text": "eine offene Frage", "meaning": "an open question" }
      ],
      "wordFamilies": [
        { "lemma": "fragen", "relationLabel": "verb", "note": null },
        { "lemma": "die Nachfrage", "relationLabel": "related noun", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "سؤال" },
        { "language": "ckb", "text": "پرسیار" },
        { "language": "en", "text": "question" },
        { "language": "fa", "text": "سؤال؛ پرسش" },
        { "language": "kmr", "text": "pirs" },
        { "language": "pl", "text": "pytanie" },
        { "language": "ro", "text": "întrebare" },
        { "language": "ru", "text": "вопрос" },
        { "language": "sq", "text": "pyetje" },
        { "language": "tr", "text": "soru" }
      ],
      "examples": [
        {
          "baseText": "Ich habe eine Frage.",
          "translations": [
            { "language": "ar", "text": "لدي سؤال." },
            { "language": "ckb", "text": "پرسیارێکم هەیە." },
            { "language": "en", "text": "I have a question." },
            { "language": "fa", "text": "من یک سؤال دارم." },
            { "language": "kmr", "text": "Pirsek min heye." },
            { "language": "pl", "text": "Mam pytanie." },
            { "language": "ro", "text": "Am o întrebare." },
            { "language": "ru", "text": "У меня есть вопрос." },
            { "language": "sq", "text": "Kam një pyetje." },
            { "language": "tr", "text": "Bir sorum var." }
          ]
        },
        {
          "baseText": "Diese Frage ist wichtig für die Diskussion.",
          "translations": [
            { "language": "ar", "text": "هذا السؤال مهم للنقاش." },
            { "language": "ckb", "text": "ئەم پرسیارە بۆ گفتوگۆکە گرنگە." },
            { "language": "en", "text": "This question is important for the discussion." },
            { "language": "fa", "text": "این سؤال برای بحث مهم است." },
            { "language": "kmr", "text": "Ev pirs ji bo nîqaşê girîng e." },
            { "language": "pl", "text": "To pytanie jest ważne dla dyskusji." },
            { "language": "ro", "text": "Această întrebare este importantă pentru discuție." },
            { "language": "ru", "text": "Этот вопрос важен для обсуждения." },
            { "language": "sq", "text": "Kjo pyetje është e rëndësishme për diskutimin." },
            { "language": "tr", "text": "Bu soru tartışma için önemlidir." }
          ]
        }
      ]
    },
    {
      "word": "vorstellen",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "infinitive": "vorstellen",
      "lexicalForms": [
        { "partOfSpeech": "Verb", "article": null, "plural": null, "infinitive": "vorstellen", "isPrimary": true }
      ],
      "pronunciationIpa": null,
      "syllableBreak": "vor-stel-len",
      "topics": [ "everyday-life", "work-and-jobs" ],
      "usageLabels": [ "spoken", "written", "high-frequency" ],
      "contextLabels": [ "discussion" ],
      "grammarNotes": [ "separable verb in the sense of introducing someone or imagining something" ],
      "collocations": [
        { "text": "sich kurz vorstellen", "meaning": "to introduce oneself briefly" },
        { "text": "sich etwas vorstellen", "meaning": "to imagine something" }
      ],
      "wordFamilies": [
        { "lemma": "die Vorstellung", "relationLabel": "noun", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "يقدّم؛ يتخيّل" },
        { "language": "ckb", "text": "ناساندن؛ وێناکردن" },
        { "language": "en", "text": "to introduce; to imagine" },
        { "language": "fa", "text": "معرفی کردن؛ تصور کردن" },
        { "language": "kmr", "text": "nasandin; xeyal kirin" },
        { "language": "pl", "text": "przedstawiać; wyobrażać sobie" },
        { "language": "ro", "text": "a prezenta; a-și imagina" },
        { "language": "ru", "text": "представлять; воображать" },
        { "language": "sq", "text": "prezantoj; imagjinoj" },
        { "language": "tr", "text": "tanıtmak; hayal etmek" }
      ],
      "examples": [
        {
          "baseText": "Kannst du dich kurz vorstellen?",
          "translations": [
            { "language": "ar", "text": "هل يمكنك أن تقدم نفسك باختصار؟" },
            { "language": "ckb", "text": "دەتوانیت بە کورتی خۆت بناسێنیت؟" },
            { "language": "en", "text": "Can you briefly introduce yourself?" },
            { "language": "fa", "text": "می‌توانی کوتاه خودت را معرفی کنی؟" },
            { "language": "kmr", "text": "Tu dikarî xwe bi kurtî bidî nasîn?" },
            { "language": "pl", "text": "Czy możesz się krótko przedstawić?" },
            { "language": "ro", "text": "Poți să te prezinți pe scurt?" },
            { "language": "ru", "text": "Можешь кратко представиться?" },
            { "language": "sq", "text": "A mund të prezantohesh shkurt?" },
            { "language": "tr", "text": "Kendini kısaca tanıtabilir misin?" }
          ]
        },
        {
          "baseText": "Ich kann mir diese Lösung gut vorstellen.",
          "translations": [
            { "language": "ar", "text": "أستطيع أن أتخيل هذا الحل جيداً." },
            { "language": "ckb", "text": "دەتوانم ئەم چارەسەرە باش وێنا بکەم." },
            { "language": "en", "text": "I can easily imagine this solution." },
            { "language": "fa", "text": "می‌توانم این راه‌حل را خوب تصور کنم." },
            { "language": "kmr", "text": "Ez dikarim vê çareseriyê baş xeyal bikim." },
            { "language": "pl", "text": "Mogę sobie dobrze wyobrazić to rozwiązanie." },
            { "language": "ro", "text": "Îmi pot imagina bine această soluție." },
            { "language": "ru", "text": "Я хорошо могу представить себе это решение." },
            { "language": "sq", "text": "Mund ta imagjinoj mirë këtë zgjidhje." },
            { "language": "tr", "text": "Bu çözümü iyi hayal edebiliyorum." }
          ]
        }
      ]
    },
    {
      "word": "verändern",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "infinitive": "verändern",
      "lexicalForms": [
        { "partOfSpeech": "Verb", "article": null, "plural": null, "infinitive": "verändern", "isPrimary": true }
      ],
      "pronunciationIpa": null,
      "syllableBreak": "ver-än-dern",
      "topics": [ "everyday-life", "work-and-jobs" ],
      "usageLabels": [ "spoken", "written", "high-frequency" ],
      "contextLabels": [ "discussion" ],
      "grammarNotes": [ "regular verb; often used with etwas or sich" ],
      "collocations": [
        { "text": "etwas stark verändern", "meaning": "to change something strongly" },
        { "text": "sich langsam verändern", "meaning": "to change slowly" }
      ],
      "wordFamilies": [
        { "lemma": "die Veränderung", "relationLabel": "noun", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "يغيّر؛ يتغير" },
        { "language": "ckb", "text": "گۆڕین؛ گۆڕان" },
        { "language": "en", "text": "to change; to alter" },
        { "language": "fa", "text": "تغییر دادن؛ تغییر کردن" },
        { "language": "kmr", "text": "guhertin; guherîn" },
        { "language": "pl", "text": "zmieniać" },
        { "language": "ro", "text": "a schimba; a modifica" },
        { "language": "ru", "text": "изменять; меняться" },
        { "language": "sq", "text": "ndryshoj" },
        { "language": "tr", "text": "değiştirmek; değişmek" }
      ],
      "examples": [
        {
          "baseText": "Neue Technik verändert den Alltag.",
          "translations": [
            { "language": "ar", "text": "تغيّر التكنولوجيا الجديدة الحياة اليومية." },
            { "language": "ckb", "text": "تەکنەلۆژیای نوێ ژیانی ڕۆژانە دەگۆڕێت." },
            { "language": "en", "text": "New technology changes everyday life." },
            { "language": "fa", "text": "فناوری جدید زندگی روزمره را تغییر می‌دهد." },
            { "language": "kmr", "text": "Teknolojiya nû jiyana rojane diguherîne." },
            { "language": "pl", "text": "Nowa technologia zmienia codzienność." },
            { "language": "ro", "text": "Tehnologia nouă schimbă viața de zi cu zi." },
            { "language": "ru", "text": "Новая технология меняет повседневную жизнь." },
            { "language": "sq", "text": "Teknologjia e re ndryshon jetën e përditshme." },
            { "language": "tr", "text": "Yeni teknoloji günlük hayatı değiştirir." }
          ]
        },
        {
          "baseText": "Was würdest du an der Schule verändern?",
          "translations": [
            { "language": "ar", "text": "ماذا كنت ستغيّر في المدرسة؟" },
            { "language": "ckb", "text": "چی لە قوتابخانەدا دەگۆڕیت؟" },
            { "language": "en", "text": "What would you change at school?" },
            { "language": "fa", "text": "در مدرسه چه چیزی را تغییر می‌دادی؟" },
            { "language": "kmr", "text": "Tu dê li dibistanê çi biguherînî?" },
            { "language": "pl", "text": "Co zmieniłbyś w szkole?" },
            { "language": "ro", "text": "Ce ai schimba la școală?" },
            { "language": "ru", "text": "Что бы ты изменил в школе?" },
            { "language": "sq", "text": "Çfarë do të ndryshoje në shkollë?" },
            { "language": "tr", "text": "Okulda neyi değiştirirdin?" }
          ]
        }
      ]
    },
