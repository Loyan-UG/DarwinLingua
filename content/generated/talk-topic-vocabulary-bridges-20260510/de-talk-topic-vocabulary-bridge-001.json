        { "text": "gegenseitiger Respekt", "meaning": "mutual respect" }
      ],
      "wordFamilies": [
        { "lemma": "respektieren", "relationLabel": "verb", "note": null },
        { "lemma": "respektvoll", "relationLabel": "adjective", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "احترام" },
        { "language": "ckb", "text": "ڕێز" },
        { "language": "en", "text": "respect" },
        { "language": "fa", "text": "احترام" },
        { "language": "kmr", "text": "rêz" },
        { "language": "pl", "text": "szacunek" },
        { "language": "ro", "text": "respect" },
        { "language": "ru", "text": "уважение" },
        { "language": "sq", "text": "respekt" },
        { "language": "tr", "text": "saygı" }
      ],
      "examples": [
        {
          "baseText": "In einer Diskussion ist Respekt wichtig.",
          "translations": [
            { "language": "ar", "text": "الاحترام مهم في النقاش." },
            { "language": "ckb", "text": "لە گفتوگۆدا ڕێز گرنگە." },
            { "language": "en", "text": "Respect is important in a discussion." },
            { "language": "fa", "text": "در یک بحث، احترام مهم است." },
            { "language": "kmr", "text": "Di nîqaşê de rêz girîng e." },
            { "language": "pl", "text": "W dyskusji szacunek jest ważny." },
            { "language": "ro", "text": "Într-o discuție, respectul este important." },
            { "language": "ru", "text": "В обсуждении важно уважение." },
            { "language": "sq", "text": "Në një diskutim respekti është i rëndësishëm." },
            { "language": "tr", "text": "Bir tartışmada saygı önemlidir." }
          ]
        },
        {
          "baseText": "Die Gruppe spricht mit Respekt über verschiedene Meinungen.",
          "translations": [
            { "language": "ar", "text": "تتحدث المجموعة باحترام عن آراء مختلفة." },
            { "language": "ckb", "text": "گرووپەکە بە ڕێزەوە دەربارەی بۆچوونی جیاواز قسە دەکات." },
            { "language": "en", "text": "The group talks respectfully about different opinions." },
            { "language": "fa", "text": "گروه با احترام درباره نظرهای مختلف صحبت می‌کند." },
            { "language": "kmr", "text": "Kom bi rêz li ser ramanên cuda diaxive." },
            { "language": "pl", "text": "Grupa rozmawia z szacunkiem o różnych opiniach." },
            { "language": "ro", "text": "Grupul vorbește cu respect despre opinii diferite." },
            { "language": "ru", "text": "Группа уважительно говорит о разных мнениях." },
            { "language": "sq", "text": "Grupi flet me respekt për mendime të ndryshme." },
            { "language": "tr", "text": "Grup farklı görüşler hakkında saygıyla konuşur." }
          ]
        }
      ]
    },
    {
      "word": "das Risiko",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Risiken",
      "lexicalForms": [
        { "partOfSpeech": "Noun", "article": "das", "plural": "Risiken", "infinitive": null, "isPrimary": true }
      ],
      "pronunciationIpa": null,
      "syllableBreak": "Ri-si-ko",
      "topics": [ "everyday-life", "work-and-jobs" ],
      "usageLabels": [ "spoken", "written", "high-frequency" ],
      "contextLabels": [ "discussion", "risk" ],
      "grammarNotes": [ "neuter noun; plural: die Risiken" ],
      "collocations": [
        { "text": "ein Risiko eingehen", "meaning": "to take a risk" },
        { "text": "Risiken abwägen", "meaning": "to weigh risks" }
      ],
      "wordFamilies": [
        { "lemma": "riskant", "relationLabel": "adjective", "note": null },
        { "lemma": "die Risikobewertung", "relationLabel": "related noun", "note": null }
      ],
      "relations": [],
      "meanings": [
        { "language": "ar", "text": "خطر؛ مخاطرة" },
        { "language": "ckb", "text": "مەترسی" },
        { "language": "en", "text": "risk" },
        { "language": "fa", "text": "ریسک؛ خطر" },
        { "language": "kmr", "text": "metirsî; rîsk" },
        { "language": "pl", "text": "ryzyko" },
        { "language": "ro", "text": "risc" },
        { "language": "ru", "text": "риск" },
        { "language": "sq", "text": "rrezik" },
        { "language": "tr", "text": "risk" }
      ],
      "examples": [
        {
          "baseText": "Jede Entscheidung hat Chancen und Risiken.",
          "translations": [
            { "language": "ar", "text": "لكل قرار فرص ومخاطر." },
            { "language": "ckb", "text": "هەر بڕیارێک دەرفەت و مەترسی هەیە." },
            { "language": "en", "text": "Every decision has opportunities and risks." },
            { "language": "fa", "text": "هر تصمیمی فرصت‌ها و ریسک‌هایی دارد." },
            { "language": "kmr", "text": "Her biryar şans û metirsiyan heye." },
            { "language": "pl", "text": "Każda decyzja ma szanse i ryzyka." },
            { "language": "ro", "text": "Fiecare decizie are șanse și riscuri." },
            { "language": "ru", "text": "У каждого решения есть возможности и риски." },
            { "language": "sq", "text": "Çdo vendim ka mundësi dhe rreziqe." },
            { "language": "tr", "text": "Her kararın fırsatları ve riskleri vardır." }
          ]
        },
        {
          "baseText": "Wir müssen das Risiko realistisch einschätzen.",
          "translations": [
            { "language": "ar", "text": "يجب أن نقيّم الخطر بشكل واقعي." },
            { "language": "ckb", "text": "دەبێت مەترسییەکە بە ڕاست‌بینانە هەڵبسەنگێنین." },
            { "language": "en", "text": "We must assess the risk realistically." },
            { "language": "fa", "text": "باید ریسک را واقع‌بینانه ارزیابی کنیم." },
            { "language": "kmr", "text": "Em divê metirsiyê bi rastînî binirxînin." },
            { "language": "pl", "text": "Musimy realistycznie ocenić ryzyko." },
            { "language": "ro", "text": "Trebuie să evaluăm riscul în mod realist." },
            { "language": "ru", "text": "Мы должны реалистично оценить риск." },
