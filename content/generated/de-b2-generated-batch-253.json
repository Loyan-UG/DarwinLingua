  "entries": [
    {
      "word": "der Verlust",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Verluste",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-lust",
      "topics": [
        "finance-and-accounting",
        "quality-and-risk",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "finance",
        "risk",
        "management"
      ],
      "grammarNotes": [
        "masculine noun; plural: Verluste"
      ],
      "collocations": [
        {
          "text": "einen Verlust ausgleichen",
          "meaning": "to offset a loss"
        },
        {
          "text": "Verlust machen",
          "meaning": "to make a loss"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verlieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "verlustreich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خسارة؛ فقدان"
        },
        {
          "language": "ckb",
          "text": "لەدەستدان؛ زیان"
        },
        {
          "language": "en",
          "text": "loss"
        },
        {
          "language": "fa",
          "text": "زیان؛ از دست دادن"
        },
        {
          "language": "kmr",
          "text": "windakirin; ziyan"
        },
        {
          "language": "pl",
          "text": "strata; utrata"
        },
        {
          "language": "ro",
          "text": "pierdere"
        },
        {
          "language": "ru",
          "text": "потеря; убыток"
        },
        {
          "language": "sq",
          "text": "humbje"
        },
        {
          "language": "tr",
          "text": "kayıp; zarar"
        }
      ],
      "examples": [
        {
          "baseText": "Der Verlust eines wichtigen Kunden hat den Umsatz im Quartal deutlich reduziert.",
          "translations": [
            {
              "language": "ar",
              "text": "أدى فقدان عميل مهم إلى خفض الإيرادات في الربع بشكل واضح."
            },
            {
              "language": "ckb",
              "text": "لەدەستدانی کڕیارێکی گرنگ داهاتی چارەکەکەی بە ڕوونی کەم کردەوە."
            },
            {
              "language": "en",
              "text": "The loss of an important customer significantly reduced revenue in the quarter."
            },
            {
              "language": "fa",
              "text": "از دست دادن یک مشتری مهم، درآمد فصل را به‌طور قابل توجهی کاهش داد."
            },
            {
              "language": "kmr",
              "text": "Windakirina xerîdarekî girîng dahata çaryekê bi eşkere kêm kir."
            },
            {
              "language": "pl",
              "text": "Utrata ważnego klienta wyraźnie obniżyła przychód w kwartale."
            },
            {
              "language": "ro",
              "text": "Pierderea unui client important a redus semnificativ veniturile trimestrului."
            },
            {
              "language": "ru",
              "text": "Потеря важного клиента заметно снизила выручку за квартал."
            },
            {
              "language": "sq",
              "text": "Humbja e një klienti të rëndësishëm uli ndjeshëm të ardhurat në tremujor."
            },
            {
              "language": "tr",
              "text": "Önemli bir müşterinin kaybı çeyrek gelirini belirgin şekilde azalttı."
            }
          ]
        },
        {
          "baseText": "Durch regelmäßige Backups vermeiden wir den Verlust wichtiger Projektdaten.",
          "translations": [
            {
              "language": "ar",
              "text": "من خلال النسخ الاحتياطية المنتظمة نتجنب فقدان بيانات المشروع المهمة."
            },
            {
              "language": "ckb",
              "text": "بە پاشەکەوتی بەردەوام ڕێگری لە لەدەستدانی داتای گرنگی پڕۆژە دەکەین."
            },
            {
              "language": "en",
              "text": "With regular backups, we avoid losing important project data."
            },
            {
              "language": "fa",
              "text": "با پشتیبان‌گیری منظم از از دست رفتن داده‌های مهم پروژه جلوگیری می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Bi backupên rêkûpêk em rê li windakirina daneyên girîng ên projeyê digirin."
            },
            {
              "language": "pl",
              "text": "Dzięki regularnym kopiom zapasowym unikamy utraty ważnych danych projektu."
            },
            {
              "language": "ro",
              "text": "Prin backupuri regulate evităm pierderea datelor importante ale proiectului."
            },
            {
              "language": "ru",
              "text": "Благодаря регулярным резервным копиям мы избегаем потери важных проектных данных."
            },
            {
              "language": "sq",
              "text": "Me kopje rezervë të rregullta shmangim humbjen e të dhënave të rëndësishme të projektit."
            },
            {
              "language": "tr",
              "text": "Düzenli yedeklerle önemli proje verilerinin kaybını önlüyoruz."
            }
          ]
        }
      ]
    },
