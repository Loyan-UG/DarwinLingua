        "polite",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; opposite of möglich"
      ],
      "collocations": [
        {
          "text": "leider unmöglich",
          "meaning": "unfortunately impossible"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "möglich",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Möglichkeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مستحيل؛ غير ممكن"
        },
        {
          "language": "ckb",
          "text": "نەکرێت؛ نامومکین"
        },
        {
          "language": "en",
          "text": "impossible; not possible"
        },
        {
          "language": "fa",
          "text": "غیرممکن؛ نشدنی"
        },
        {
          "language": "kmr",
          "text": "ne mumkin; ne gengaz"
        },
        {
          "language": "pl",
          "text": "niemożliwy"
        },
        {
          "language": "ro",
          "text": "imposibil"
        },
        {
          "language": "ru",
          "text": "невозможный"
        },
        {
          "language": "sq",
          "text": "i pamundur"
        },
        {
          "language": "tr",
          "text": "imkansız; mümkün değil"
        }
      ],
      "examples": [
        {
          "baseText": "Eine Rückgabe ohne Rechnung ist leider unmöglich.",
          "translations": [
            {
              "language": "ar",
              "text": "للأسف إرجاع المنتج من دون فاتورة غير ممكن."
            },
            {
              "language": "ckb",
              "text": "بەداخەوە گەڕاندنەوە بەبێ فاکتور ناکرێت."
            },
            {
              "language": "en",
              "text": "Unfortunately, a return without an invoice is impossible."
            },
            {
              "language": "fa",
              "text": "متأسفانه مرجوعی بدون فاکتور امکان‌پذیر نیست."
            },
            {
              "language": "kmr",
              "text": "Mixabin vegerandin bê fatûre ne gengaz e."
            },
            {
              "language": "pl",
              "text": "Zwrot bez faktury jest niestety niemożliwy."
            },
            {
              "language": "ro",
              "text": "Din păcate, returnarea fără factură este imposibilă."
            },
            {
              "language": "ru",
              "text": "К сожалению, возврат без счета невозможен."
            },
            {
              "language": "sq",
              "text": "Fatkeqësisht kthimi pa faturë është i pamundur."
            },
            {
              "language": "tr",
              "text": "Faturasız iade maalesef mümkün değil."
            }
          ]
        },
        {
          "baseText": "Heute ist ein Termin unmöglich, aber morgen geht es.",
          "translations": [
            {
              "language": "ar",
              "text": "اليوم الموعد غير ممكن، لكن غداً يمكن."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ کاتێک نامومکینە، بەڵام سبەی دەکرێت."
            },
            {
              "language": "en",
              "text": "An appointment today is impossible, but tomorrow works."
            },
            {
              "language": "fa",
              "text": "امروز وقت گرفتن ممکن نیست، اما فردا می‌شود."
            },
            {
              "language": "kmr",
              "text": "Îro demek ne mumkin e, lê sibê dibe."
            },
            {
              "language": "pl",
              "text": "Termin dzisiaj jest niemożliwy, ale jutro się da."
            },
            {
              "language": "ro",
              "text": "O programare astăzi este imposibilă, dar mâine se poate."
            },
            {
              "language": "ru",
              "text": "Сегодня запись невозможна, но завтра можно."
            },
            {
              "language": "sq",
              "text": "Sot takimi është i pamundur, por nesër bëhet."
            },
            {
              "language": "tr",
              "text": "Bugün randevu imkansız, ama yarın olur."
            }
          ]
        }
      ]
    },
    {
      "word": "die Unterkunft",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Unterkünfte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Un-ter-kunft",
      "topics": [
        "transport-and-travel",
        "housing-and-real-estate",
        "customer-service"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written",
        "customer-facing",
        "polite",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Unterkunft buchen",
          "meaning": "to book accommodation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "unterkommen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "سكن؛ مكان إقامة"
        },
        {
          "language": "ckb",
          "text": "شوێنی مانەوە"
        },
        {
          "language": "en",
          "text": "accommodation; lodging"
        },
        {
          "language": "fa",
          "text": "اقامتگاه؛ محل اقامت"
        },
        {
          "language": "kmr",
          "text": "cihê mayînê"
        },
        {
          "language": "pl",
          "text": "zakwaterowanie; nocleg"
        },
        {
          "language": "ro",
          "text": "cazare"
        },
        {
          "language": "ru",
          "text": "жилье; размещение"
        },
        {
          "language": "sq",
          "text": "akomodim; strehim"
        },
        {
          "language": "tr",
          "text": "konaklama; kalacak yer"
        }
      ],
      "examples": [
        {
          "baseText": "Wir suchen eine günstige Unterkunft in der Nähe vom Bahnhof.",
          "translations": [
            {
              "language": "ar",
              "text": "نبحث عن سكن رخيص بالقرب من محطة القطار."
            },
            {
              "language": "ckb",
              "text": "ئێمە دەگەڕێین بەدوای شوێنی مانەوەیەکی هەرزان لە نزیک وێستگە."
            },
            {
              "language": "en",
              "text": "We are looking for cheap accommodation near the train station."
            },
            {
              "language": "fa",
              "text": "دنبال یک اقامتگاه ارزان نزدیک ایستگاه قطار هستیم."
            },
            {
              "language": "kmr",
              "text": "Em li nêzîkî stasyonê li cihê mayînê yê erzan digerin."
            },
            {
              "language": "pl",
              "text": "Szukamy taniego noclegu blisko dworca."
            },
            {
              "language": "ro",
              "text": "Căutăm o cazare ieftină aproape de gară."
            },
            {
              "language": "ru",
              "text": "Мы ищем недорогое жилье рядом с вокзалом."
            },
            {
              "language": "sq",
              "text": "Po kërkojmë një akomodim të lirë pranë stacionit të trenit."
            },
            {
              "language": "tr",
              "text": "Tren istasyonuna yakın ucuz bir konaklama arıyoruz."
            }
          ]
        },
        {
          "baseText": "Ist die Unterkunft für drei Nächte frei?",
          "translations": [
            {
              "language": "ar",
              "text": "هل السكن متاح لثلاث ليال؟"
            },
            {
              "language": "ckb",
              "text": "ئایا شوێنی مانەوەکە بۆ سێ شەو بەتاڵە؟"
            },
            {
              "language": "en",
              "text": "Is the accommodation available for three nights?"
            },
            {
              "language": "fa",
              "text": "آیا اقامتگاه برای سه شب خالی است؟"
            },
            {
              "language": "kmr",
              "text": "Ma cihê mayînê ji bo sê şevan vala ye?"
            },
            {
              "language": "pl",
              "text": "Czy nocleg jest dostępny na trzy noce?"
            },
            {
              "language": "ro",
              "text": "Cazarea este disponibilă pentru trei nopți?"
            },
            {
              "language": "ru",
              "text": "Жилье свободно на три ночи?"
            },
            {
              "language": "sq",
              "text": "A është akomodimi i lirë për tri net?"
            },
            {
              "language": "tr",
              "text": "Konaklama üç gece için müsait mi?"
            }
          ]
        }
      ]
    },
