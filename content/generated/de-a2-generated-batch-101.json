      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يوقّع"
        },
        {
          "language": "ckb",
          "text": "واژۆ دەکات"
        },
        {
          "language": "en",
          "text": "to sign"
        },
        {
          "language": "fa",
          "text": "امضا کردن"
        },
        {
          "language": "kmr",
          "text": "îmze kirin"
        },
        {
          "language": "pl",
          "text": "podpisać"
        },
        {
          "language": "ro",
          "text": "a semna"
        },
        {
          "language": "ru",
          "text": "подписывать"
        },
        {
          "language": "sq",
          "text": "të nënshkruash"
        },
        {
          "language": "tr",
          "text": "imzalamak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte unterschreiben Sie das Formular hier.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى توقيع الاستمارة هنا."
            },
            {
              "language": "ckb",
              "text": "تکایە فۆرمەکە لێرە واژۆ بکەن."
            },
            {
              "language": "en",
              "text": "Please sign the form here."
            },
            {
              "language": "fa",
              "text": "لطفاً فرم را اینجا امضا کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe formê li vir îmze bikin."
            },
            {
              "language": "pl",
              "text": "Proszę podpisać formularz tutaj."
            },
            {
              "language": "ro",
              "text": "Vă rog să semnați formularul aici."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, подпишите форму здесь."
            },
            {
              "language": "sq",
              "text": "Ju lutem nënshkruani formularin këtu."
            },
            {
              "language": "tr",
              "text": "Lütfen formu burada imzalayın."
            }
          ]
        },
        {
          "baseText": "Ich muss den Vertrag vor Freitag unterschreiben.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن أوقّع العقد قبل الجمعة."
            },
            {
              "language": "ckb",
              "text": "دەبێت پێش هەینی گرێبەستەکە واژۆ بکەم."
            },
            {
              "language": "en",
              "text": "I have to sign the contract before Friday."
            },
            {
              "language": "fa",
              "text": "باید قرارداد را قبل از جمعه امضا کنم."
            },
            {
              "language": "kmr",
              "text": "Divê ez berî înê peymanê îmze bikim."
            },
            {
              "language": "pl",
              "text": "Muszę podpisać umowę przed piątkiem."
            },
            {
              "language": "ro",
              "text": "Trebuie să semnez contractul înainte de vineri."
            },
            {
              "language": "ru",
              "text": "Мне нужно подписать договор до пятницы."
            },
            {
              "language": "sq",
              "text": "Duhet ta nënshkruaj kontratën para së premtes."
            },
            {
              "language": "tr",
              "text": "Sözleşmeyi cumadan önce imzalamam gerekiyor."
            }
          ]
        }
      ]
    },
