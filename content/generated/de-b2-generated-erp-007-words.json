  "entries": [
    {
      "word": "Bestellvorschlag",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Bestellvorschläge",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-stell-vor-schlag",
      "topics": [
        "procurement-and-suppliers",
        "erp-and-business-systems",
        "warehouse-and-logistics"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; system-generated proposal to create a purchase order"
      ],
      "collocations": [
        {
          "text": "einen Bestellvorschlag prüfen",
          "meaning": "to check a purchase proposal"
        },
        {
          "text": "einen Bestellvorschlag übernehmen",
          "meaning": "to convert a purchase proposal into an order"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bestellen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Vorschlag",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اقتراح طلب شراء"
        },
        {
          "language": "ckb",
          "text": "پێشنیاری داواکاریی کڕین"
        },
        {
          "language": "en",
          "text": "purchase proposal; order proposal"
        },
        {
          "language": "fa",
          "text": "پیشنهاد سفارش خرید"
        },
        {
          "language": "kmr",
          "text": "pêşniyara fermana kirînê"
        },
        {
          "language": "pl",
          "text": "propozycja zamówienia"
        },
        {
          "language": "ro",
          "text": "propunere de comandă"
        },
        {
          "language": "ru",
          "text": "предложение заказа"
        },
        {
          "language": "sq",
          "text": "propozim porosie"
        },
        {
          "language": "tr",
          "text": "sipariş önerisi"
        }
      ],
      "examples": [
        {
          "baseText": "Das ERP erstellt einen Bestellvorschlag, wenn der Lagerbestand unter den Mindestbestand fällt.",
          "translations": [
            {
              "language": "ar",
              "text": "ينشئ ERP اقتراح طلب شراء عندما ينخفض المخزون عن الحد الأدنى."
            },
            {
              "language": "ckb",
              "text": "ERP پێشنیاری داواکاریی کڕین دروست دەکات کاتێک کۆگا لە خوار کەمترین ئاست دادەبەزێت."
            },
            {
              "language": "en",
              "text": "The ERP creates a purchase proposal when stock falls below the minimum level."
            },
            {
              "language": "fa",
              "text": "وقتی موجودی انبار از حداقل موجودی کمتر شود، ERP یک پیشنهاد سفارش خرید ایجاد می‌کند."
            },
            {
              "language": "kmr",
              "text": "ERP dema stok ji asta herî kêm kêmtir dibe pêşniyara fermana kirînê çêdike."
            },
            {
              "language": "pl",
              "text": "ERP tworzy propozycję zamówienia, gdy stan magazynowy spada poniżej minimum."
            },
            {
              "language": "ro",
              "text": "ERP creează o propunere de comandă când stocul scade sub nivelul minim."
            },
            {
              "language": "ru",
              "text": "ERP создает предложение заказа, когда складской запас падает ниже минимального уровня."
            },
            {
              "language": "sq",
              "text": "ERP krijon një propozim porosie kur stoku bie nën nivelin minimal."
            },
            {
              "language": "tr",
              "text": "Stok minimum seviyenin altına düştüğünde ERP bir sipariş önerisi oluşturur."
            }
          ]
        },
        {
          "baseText": "Der Einkauf prüft den Bestellvorschlag, bevor daraus eine verbindliche Bestellung wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يفحص قسم المشتريات اقتراح الطلب قبل أن يتحول إلى طلب شراء ملزم."
            },
            {
              "language": "ckb",
              "text": "بەشی کڕین پێشنیاری داواکاریی کڕین دەپشکنێت پێش ئەوەی ببێتە داواکارییەکی پابەند."
            },
            {
              "language": "en",
              "text": "Purchasing checks the purchase proposal before it becomes a binding order."
            },
            {
              "language": "fa",
              "text": "واحد خرید قبل از تبدیل شدن پیشنهاد سفارش به سفارش قطعی، آن را بررسی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Beşa kirînê pêşniyara fermana kirînê kontrol dike berî ku bibe fermaneke girêdayî."
            },
            {
              "language": "pl",
              "text": "Dział zakupów sprawdza propozycję zamówienia, zanim stanie się ona wiążącym zamówieniem."
            },
            {
              "language": "ro",
              "text": "Departamentul de achiziții verifică propunerea de comandă înainte ca aceasta să devină o comandă fermă."
            },
            {
              "language": "ru",
              "text": "Отдел закупок проверяет предложение заказа, прежде чем оно станет обязательным заказом."
            },
            {
              "language": "sq",
              "text": "Blerja e kontrollon propozimin e porosisë para se të bëhet porosi detyruese."
            },
            {
              "language": "tr",
              "text": "Satın alma, sipariş önerisi bağlayıcı bir siparişe dönüşmeden önce onu kontrol eder."
            }
          ]
        }
      ]
    },
    {
      "word": "Betreffbaustein",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Betreffbausteine",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-treff-bau-stein",
      "topics": [
        "business-communication",
        "erp-and-business-systems",
        "customer-service"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; reusable subject-line text block in communication templates"
      ],
      "collocations": [
        {
          "text": "einen Betreffbaustein auswählen",
          "meaning": "to select a subject text block"
        },
        {
          "text": "einen Betreffbaustein pflegen",
          "meaning": "to maintain a subject text block"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Betreff",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Baustein",
          "relationLabel": "component noun",
          "note": "reusable text block"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قالب جزء من سطر الموضوع"
        },
        {
          "language": "ckb",
          "text": "بەشی ئامادەی بابەتی نامە"
        },
        {
          "language": "en",
          "text": "subject text block"
        },
        {
          "language": "fa",
          "text": "قطعه آماده موضوع ایمیل"
        },
        {
          "language": "kmr",
          "text": "perçeya amade ya mijarê"
        },
        {
          "language": "pl",
          "text": "blok tematu wiadomości"
        },
        {
          "language": "ro",
          "text": "bloc de text pentru subiect"
        },
        {
          "language": "ru",
          "text": "шаблон темы сообщения"
        },
        {
          "language": "sq",
          "text": "bllok teksti për subjektin"
        },
        {
          "language": "tr",
          "text": "konu metni bloğu"
        }
      ],
      "examples": [
        {
          "baseText": "Im ERP wählen wir den Betreffbaustein „Lieferverzug“, damit die E-Mail eindeutig ist.",
          "translations": [
            {
              "language": "ar",
              "text": "في ERP نختار قالب الموضوع \"تأخر التسليم\" حتى تكون الرسالة واضحة."
            },
            {
              "language": "ckb",
              "text": "لە ERP دا بەشی ئامادەی بابەتی \"دواکەوتنی گەیاندن\" هەڵدەبژێرین بۆ ئەوەی ئیمەیڵەکە ڕوون بێت."
            },
            {
              "language": "en",
              "text": "In the ERP, we select the subject text block “delivery delay” so the email is clear."
            },
            {
              "language": "fa",
              "text": "در ERP قطعه آماده موضوع «تأخیر در تحویل» را انتخاب می‌کنیم تا ایمیل واضح باشد."
            },
            {
              "language": "kmr",
              "text": "Di ERP de em perçeya mijarê \"derengmayîna radestkirinê\" hilbijêrin da ku e-name zelal be."
            },
            {
              "language": "pl",
              "text": "W ERP wybieramy blok tematu „opóźnienie dostawy”, aby e-mail był jednoznaczny."
            },
            {
              "language": "ro",
              "text": "În ERP alegem blocul de subiect „întârziere livrare” pentru ca e-mailul să fie clar."
            },
            {
              "language": "ru",
              "text": "В ERP мы выбираем шаблон темы «задержка поставки», чтобы письмо было понятным."
            },
            {
              "language": "sq",
              "text": "Në ERP zgjedhim bllokun e subjektit “vonesë dorëzimi” që emaili të jetë i qartë."
            },
            {
              "language": "tr",
              "text": "ERP’de e-postanın açık olması için “teslimat gecikmesi” konu metni bloğunu seçiyoruz."
            }
          ]
        },
        {
          "baseText": "Der neue Betreffbaustein spart Zeit, weil das Supportteam ihn täglich verwendet.",
          "translations": [
            {
              "language": "ar",
              "text": "يوفر قالب الموضوع الجديد الوقت لأن فريق الدعم يستخدمه يوميًا."
            },
            {
              "language": "ckb",
              "text": "بەشی ئامادەی بابەتی نوێ کات دەگەڕێنێتەوە، چونکە تیمی پشتگیری ڕۆژانە بەکاری دەهێنێت."
            },
            {
              "language": "en",
              "text": "The new subject text block saves time because the support team uses it every day."
            },
            {
              "language": "fa",
              "text": "قطعه آماده موضوع جدید زمان را صرفه‌جویی می‌کند، چون تیم پشتیبانی هر روز از آن استفاده می‌کند."
            },
            {
              "language": "kmr",
              "text": "Perçeya nû ya mijarê demê xilas dike, ji ber ku tîma piştgiriyê her roj wê bi kar tîne."
            },
            {
              "language": "pl",
              "text": "Nowy blok tematu oszczędza czas, ponieważ zespół wsparcia używa go codziennie."
            },
            {
              "language": "ro",
              "text": "Noul bloc de subiect economisește timp, deoarece echipa de suport îl folosește zilnic."
            },
            {
              "language": "ru",
              "text": "Новый шаблон темы экономит время, потому что служба поддержки использует его ежедневно."
            },
            {
              "language": "sq",
              "text": "Blloku i ri i subjektit kursen kohë sepse ekipi i mbështetjes e përdor çdo ditë."
            },
            {
              "language": "tr",
              "text": "Yeni konu metni bloğu zaman kazandırıyor, çünkü destek ekibi onu her gün kullanıyor."
            }
          ]
        }
      ]
    },
