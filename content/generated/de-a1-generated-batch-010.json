      ],
      "wordFamilies": [
        {
          "lemma": "die Ruhe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يستريح"
        },
        {
          "language": "ckb",
          "text": "پشوودان؛ حەسانەوە"
        },
        {
          "language": "en",
          "text": "to rest"
        },
        {
          "language": "fa",
          "text": "استراحت کردن"
        },
        {
          "language": "kmr",
          "text": "bêhnvedan; rehet kirin"
        },
        {
          "language": "pl",
          "text": "odpoczywać"
        },
        {
          "language": "ro",
          "text": "a se odihni"
        },
        {
          "language": "ru",
          "text": "отдыхать"
        },
        {
          "language": "sq",
          "text": "të pushosh"
        },
        {
          "language": "tr",
          "text": "dinlenmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich ruhe mich nach der Arbeit aus.",
          "translations": [
            {
              "language": "ar",
              "text": "أستريح بعد العمل."
            },
            {
              "language": "ckb",
              "text": "دوای کار پشوودەدەم."
            },
            {
              "language": "en",
              "text": "I rest after work."
            },
            {
              "language": "fa",
              "text": "بعد از کار استراحت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez piştî kar bêhnvedanê dikim."
            },
            {
              "language": "pl",
              "text": "Odpoczywam po pracy."
            },
            {
              "language": "ro",
              "text": "Mă odihnesc după muncă."
            },
            {
              "language": "ru",
              "text": "Я отдыхаю после работы."
            },
            {
              "language": "sq",
              "text": "Pushoj pas punës."
            },
            {
              "language": "tr",
              "text": "İşten sonra dinleniyorum."
            }
          ]
        },
        {
          "baseText": "Du bist müde, ruh dich bitte aus.",
          "translations": [
            {
              "language": "ar",
              "text": "أنت متعب، استرح من فضلك."
            },
            {
              "language": "ckb",
              "text": "تۆ ماندوویت، تکایە پشووبدە."
            },
            {
              "language": "en",
              "text": "You are tired; please rest."
            },
            {
              "language": "fa",
              "text": "خسته‌ای، لطفاً استراحت کن."
            },
            {
              "language": "kmr",
              "text": "Tu westiyayî, ji kerema xwe bêhna xwe vede."
            },
            {
              "language": "pl",
              "text": "Jesteś zmęczony, odpocznij proszę."
            },
            {
              "language": "ro",
              "text": "Ești obosit, te rog odihnește-te."
            },
            {
              "language": "ru",
              "text": "Ты устал, пожалуйста, отдохни."
            },
            {
              "language": "sq",
              "text": "Je i lodhur, të lutem pusho."
            },
            {
              "language": "tr",
              "text": "Yorgunsun, lütfen dinlen."
            }
          ]
        }
      ]
    },
