        },
        {
          "language": "ru",
          "text": "удостоверение личности"
        },
        {
          "language": "sq",
          "text": "kartë identiteti"
        },
        {
          "language": "tr",
          "text": "kimlik; kimlik kartı"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte zeigen Sie Ihren Ausweis.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إظهار بطاقة هويتكم."
            },
            {
              "language": "ckb",
              "text": "تکایە ناسنامەکەتان پیشان بدەن."
            },
            {
              "language": "en",
              "text": "Please show your ID."
            },
            {
              "language": "fa",
              "text": "لطفاً کارت شناسایی خود را نشان دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe nasnameya xwe nîşan bidin."
            },
            {
              "language": "pl",
              "text": "Proszę pokazać dowód."
            },
            {
              "language": "ro",
              "text": "Vă rog să arătați actul de identitate."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, покажите удостоверение личности."
            },
            {
              "language": "sq",
              "text": "Ju lutem tregoni kartën tuaj të identitetit."
            },
            {
              "language": "tr",
              "text": "Lütfen kimliğinizi gösterin."
            }
          ]
        },
        {
          "baseText": "Ich habe meinen Ausweis zu Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "بطاقة هويتي في البيت."
            },
            {
              "language": "ckb",
              "text": "ناسنامەکەم لە ماڵەوەیە."
            },
            {
              "language": "en",
              "text": "My ID is at home."
            },
            {
              "language": "fa",
              "text": "کارت شناسایی‌ام در خانه است."
            },
            {
              "language": "kmr",
              "text": "Nasnameya min li malê ye."
            },
            {
              "language": "pl",
              "text": "Mam dowód w domu."
            },
            {
              "language": "ro",
              "text": "Am actul de identitate acasă."
            },
            {
              "language": "ru",
              "text": "Мое удостоверение дома."
            },
            {
              "language": "sq",
              "text": "Kartën e identitetit e kam në shtëpi."
            },
            {
              "language": "tr",
              "text": "Kimliğim evde."
            }
          ]
        }
      ]
