          "text": "eine qualitative Forschungslogik",
          "meaning": "a qualitative research logic"
        },
        {
          "text": "der Forschungslogik folgen",
          "meaning": "to follow the logic of inquiry"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "forschen",
