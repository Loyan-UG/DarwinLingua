      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; bank account number"
      ],
      "collocations": [
        {
          "text": "die Kontonummer angeben",
          "meaning": "to provide the account number"
        },
        {
          "text": "eine Kontonummer prüfen",
          "meaning": "to check an account number"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Konto",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Nummer",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "رقم الحساب"
        },
        {
          "language": "ckb",
          "text": "ژمارەی هەژمار"
        },
        {
          "language": "en",
          "text": "account number"
        },
        {
          "language": "fa",
          "text": "شماره حساب"
        },
        {
          "language": "kmr",
          "text": "hejmara hesabê"
        },
        {
          "language": "pl",
          "text": "numer konta"
        },
        {
          "language": "ro",
          "text": "număr de cont"
        },
        {
          "language": "ru",
          "text": "номер счёта"
        },
        {
          "language": "sq",
          "text": "numër llogarie"
        },
        {
          "language": "tr",
          "text": "hesap numarası"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte geben Sie die Kontonummer nur ein, wenn keine IBAN vorhanden ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إدخال رقم الحساب فقط إذا لم يكن رقم IBAN موجوداً."
            },
            {
              "language": "ckb",
              "text": "تکایە تەنها کاتێک ژمارەی هەژمار بنووسن کە IBAN بوونی نەبێت."
            },
            {
              "language": "en",
              "text": "Please enter the account number only if no IBAN is available."
            },
            {
              "language": "fa",
              "text": "لطفاً فقط زمانی شماره حساب را وارد کنید که IBAN وجود ندارد."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe tenê heke IBAN tune be hejmara hesabê binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę wpisać numer konta tylko wtedy, gdy nie ma IBAN-u."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să introduceți numărul de cont doar dacă nu există IBAN."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, укажите номер счёта только если нет IBAN."
            },
            {
              "language": "sq",
              "text": "Ju lutemi shkruani numrin e llogarisë vetëm nëse nuk ka IBAN."
            },
            {
              "language": "tr",
              "text": "Lütfen hesap numarasını yalnızca IBAN yoksa girin."
            }
          ]
        },
        {
          "baseText": "Die Kontonummer auf dem alten Formular ist nicht mehr gültig.",
          "translations": [
            {
              "language": "ar",
              "text": "رقم الحساب الموجود في النموذج القديم لم يعد صالحاً."
            },
            {
              "language": "ckb",
              "text": "ژمارەی هەژمار لە فۆرمی کۆنەکەدا چیتر دروست نییە."
            },
            {
              "language": "en",
              "text": "The account number on the old form is no longer valid."
            },
            {
              "language": "fa",
              "text": "شماره حساب روی فرم قدیمی دیگر معتبر نیست."
            },
            {
              "language": "kmr",
              "text": "Hejmara hesabê li ser forma kevn êdî derbasdar nîne."
            },
            {
              "language": "pl",
              "text": "Numer konta na starym formularzu nie jest już ważny."
            },
            {
              "language": "ro",
              "text": "Numărul de cont de pe formularul vechi nu mai este valabil."
            },
            {
              "language": "ru",
              "text": "Номер счёта в старой форме больше не действителен."
            },
            {
              "language": "sq",
              "text": "Numri i llogarisë në formularin e vjetër nuk është më i vlefshëm."
            },
            {
              "language": "tr",
              "text": "Eski formdaki hesap numarası artık geçerli değil."
            }
          ]
        }
      ]
    },
    {
      "word": "der Kontostand",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Kontostände",
      "infinitive": null,
