      ],
      "usageLabels": [
        "spoken",
        "workplace"
      ],
      "contextLabels": [
        "customer-service",
        "documents"
      ],
      "grammarNotes": [
        "separable verb"
      ],
      "collocations": [
        {
          "text": "den Kunden antreffen",
          "meaning": "to meet the customer"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يلتقي"
        },
        {
          "language": "ckb",
          "text": "دیدارکردن"
        },
        {
          "language": "en",
          "text": "to meet"
        },
        {
          "language": "fa",
          "text": "ملاقات کردن"
        },
        {
          "language": "kmr",
          "text": "ditingeh kirin"
        },
        {
          "language": "pl",
          "text": "spotykać"
        },
        {
          "language": "ro",
          "text": "a întâlni"
        },
        {
          "language": "ru",
          "text": "встретить"
        },
        {
          "language": "sq",
          "text": "të takosh"
        },
        {
          "language": "tr",
          "text": "karşılaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir haben den Kunden im Servicecenter angetroffen und seine Anfrage direkt ins Ticket übernommen.",
          "translations": [
            {
              "language": "ar",
              "text": "ما مشتری را در مرکز خدمات ملاقات کردیم و درخواست او را بلافاصله در تیکت ثبت کردیم."
            },
            {
              "language": "ckb",
              "text": "ئێمە کڕیارەکەمان لە ناوەکی خزمەتگوزاری دیدرا و داواکارییەکەی بە شێوەیەکی ڕاستەوخۆ تۆماری تیکەت کرد."
            },
            {
              "language": "en",
              "text": "We met the customer at the service desk and logged the request directly into a ticket."
            },
            {
              "language": "fa",
              "text": "در مرکز خدمات مشتری را دیدیم و درخواست او را مستقیم در تیکت ثبت کردیم."
            },
            {
              "language": "kmr",
              "text": "Kîrkerê xerîdarê di navçava xizmetê de temasa kirin û daxwaza wî têketandina tiketê kir."
            },
            {
              "language": "pl",
              "text": "Spotkaliśmy klienta przy stanowisku serwisu i od razu przenieśliśmy zgłoszenie do ticketa."
            },
            {
              "language": "ro",
              "text": "L-am întâlnit pe client la centrul de servicii și am trecut direct cererea lui într-un tichet."
            },
            {
              "language": "ru",
              "text": "Мы встретили клиента в сервис-центре и сразу передали заявку в тикет."
            },
            {
              "language": "sq",
              "text": "E takuam klientin në qendrën e shërbimit dhe e shënuam menjëherë kërkesën në bilet."
            },
            {
              "language": "tr",
              "text": "Müşteriyi servis merkezinde bulduk ve talebini direkt bilet içine işledik."
            }
          ]
        },
        {
          "baseText": "Bitte in der Übergabe antreffen Sie den Support-Verantwortlichen direkt an der Desk-Station.",
          "translations": [
            {
              "language": "ar",
              "text": "در زمان تحویل، لطفاً مسئول پشتیبانی را به صورت مستقیم در ایستگاه میز ملاقات کنید."
            },
            {
              "language": "ckb",
              "text": "تکایە لە کاتی گواستنەوەی کارەکان بە ڕاستەوخۆیەوە لە شارەزای پشتگیری ببەستەوە."
            },
            {
              "language": "en",
              "text": "During handover, please meet the support owner directly at the desk station."
            },
            {
              "language": "fa",
              "text": "در زمان تحویل، لطفاً مسئول پشتیبانی را مستقیماً در ایستگاه پذیرش ملاقات کنید."
            },
            {
              "language": "kmr",
              "text": "Di dema guherînê de bi rasterast li stasyonê de bi kesê berpirsiyarîyê ya alîkariyê re bibin."
            },
            {
              "language": "pl",
              "text": "Podczas przekazania proszę od razu spotkać właściciela wsparcia przy stanowisku stoiska."
            },
            {
              "language": "ro",
