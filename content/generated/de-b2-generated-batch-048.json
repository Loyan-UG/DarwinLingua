        {
          "text": "die Oberfläche anstreichen",
          "meaning": "to paint a surface"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يطلي"
        },
        {
          "language": "ckb",
          "text": "ڕەنگکردن"
        },
        {
          "language": "en",
          "text": "to paint"
        },
        {
          "language": "fa",
          "text": "رنگ زدن"
        },
        {
          "language": "kmr",
          "text": "renk kirin"
        },
        {
          "language": "pl",
          "text": "malować"
        },
        {
          "language": "ro",
          "text": "a vopsi"
        },
        {
          "language": "ru",
          "text": "красить"
        },
        {
          "language": "sq",
          "text": "pikturoj"
        },
        {
          "language": "tr",
          "text": "boyamak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir haben die neue API-Doku neu anstreichen lassen und damit den Fehler im Layout behoben.",
          "translations": [
            {
              "language": "ar",
              "text": "ما مستندات API جدید را دوباره رنگ زدیم تا خطای چیدمان برطرف شود."
            },
            {
              "language": "ckb",
              "text": "ئێمە بەڵگەنامەی نوێی API بەدووبارە درووست کرد و هەڵەی شێوەیەکە چارەسەری کرد."
            },
            {
              "language": "en",
              "text": "We repainted the new API documentation to fix a layout issue."
            },
            {
              "language": "fa",
              "text": "اسناد API جدید را دوباره بازنویسی/بازطراحی کردیم تا خطای چیدمان برطرف شود."
            },
            {
              "language": "kmr",
              "text": "Em belgeya nû ya API bi nû ve kişandin da ku xerabiya çêkirinê çareser bibe."
            },
            {
              "language": "pl",
              "text": "Przemalowaliśmy dokumentację nowego API, aby naprawić błąd układu."
            },
            {
              "language": "ro",
              "text": "Am revopsit documentația noului API pentru a corecta o eroare de layout."
            },
            {
              "language": "ru",
              "text": "Мы перекрасили новую документацию API, чтобы исправить ошибку вёрстки."
            },
            {
              "language": "sq",
              "text": "Ne e mbuluam sërish dokumentimin e ri të API dhe kështu rregulluam një gabim të paraqitjes."
            },
            {
              "language": "tr",
              "text": "Duzen hatasını düzeltmek için yeni API dokümantasyonunu tekrar işaretledik."
            }
          ]
        },
        {
          "baseText": "Bitte anstreichen Sie die aktive Warnung im Dashboard rot, damit jeder sie sieht.",
          "translations": [
            {
              "language": "ar",
              "text": "لطفا هشدار فعال را در داشبورد قرمز کنید تا همه آن را ببینند."
            },
            {
              "language": "ckb",
              "text": "تکایە ئاگادارکردنەوەی چالاکەکە لە داشبۆردەکە سوورەوە نیشان بدە تا هەموو ببینن."
            },
            {
              "language": "en",
              "text": "Please highlight the active warning in the dashboard in red so everyone sees it."
            },
            {
              "language": "fa",
              "text": "هشدار فعال را در داشبورد با قرمز برجسته کنید تا همه آن را ببینند."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe hişyariya çalak di dashboardê de bi sor nîşan bide da ku hertişt bibînin."
            },
            {
              "language": "pl",
              "text": "Proszę oznaczyć aktywne ostrzeżenie na dashboardzie na czerwono, by wszyscy je zobaczyli."
            },
            {
              "language": "ro",
              "text": "Te rog evidențiază alertul activ în panoul de monitorizare cu roșu ca toți să-l vadă."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, выделите красным активное предупреждение на панели, чтобы все его увидели."
            },
            {
              "language": "sq",
              "text": "Ju lutemi theksoni paralajmërimin aktiv në panelin e kontrollit me të kuqe, që të gjithë ta shohin."
            },
            {
              "language": "tr",
              "text": "Lütfen aktif uyarıyı panodaki kırmızı renkle işaretleyin, herkes görsün."
            }
          ]
        }
      ]
    },
    {
      "word": "antreffen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "antreffen",
      "pronunciationIpa": null,
      "syllableBreak": "an-tref-fen",
      "topics": [
        "customer-service",
