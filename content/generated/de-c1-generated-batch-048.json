        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دراسة حالة"
        },
        {
          "language": "ckb",
          "text": "توێژینەوەی کەیس"
        },
        {
          "language": "en",
          "text": "case study"
        },
        {
          "language": "fa",
          "text": "مطالعه موردی"
        },
        {
          "language": "kmr",
          "text": "lêkolîna dozê"
        },
        {
          "language": "pl",
          "text": "studium przypadku"
        },
        {
          "language": "ro",
          "text": "studiu de caz"
        },
        {
          "language": "ru",
          "text": "кейс-исследование; исследование случая"
        },
        {
          "language": "sq",
          "text": "studim rasti"
        },
        {
          "language": "tr",
          "text": "vaka çalışması"
        }
      ],
      "examples": [
        {
          "baseText": "Die Fallstudie zeigt, wie ein mittelständisches Unternehmen seine Lieferkette digitalisiert hat.",
          "translations": [
            {
              "language": "ar",
              "text": "تُظهر دراسة الحالة كيف رقمنت شركة متوسطة سلسلة التوريد الخاصة بها."
            },
            {
              "language": "ckb",
              "text": "توێژینەوەی کەیسەکە پیشان دەدات کۆمپانیایەکی مامناوەند چۆن زنجیرەی دابینکردنی دیجیتاڵی کردووە."
            },
            {
              "language": "en",
              "text": "The case study shows how a medium-sized company digitized its supply chain."
