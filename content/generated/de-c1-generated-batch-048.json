  "entries": [
    {
      "word": "die Expertise",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Expertisen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ex-per-ti-se",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "business",
        "academic",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; can mean expert knowledge or an expert report"
      ],
      "collocations": [
        {
          "text": "fachliche Expertise einbringen",
          "meaning": "to contribute subject-matter expertise"
        },
        {
          "text": "externe Expertise einholen",
          "meaning": "to obtain external expert advice"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Experte",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "expertengestützt",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خبرة متخصصة؛ تقرير خبير"
        },
        {
          "language": "ckb",
          "text": "شارەزایی پسپۆڕی؛ ڕاپۆرتی پسپۆڕ"
        },
        {
          "language": "en",
          "text": "expertise; expert report"
        },
        {
          "language": "fa",
          "text": "تخصص؛ نظر کارشناسی؛ گزارش کارشناسی"
        },
        {
          "language": "kmr",
          "text": "pisporî; raporta pispor"
        },
        {
          "language": "pl",
          "text": "ekspertyza; wiedza ekspercka"
        },
        {
          "language": "ro",
          "text": "expertiză; competență de specialitate"
        },
        {
          "language": "ru",
          "text": "экспертиза; экспертное заключение"
        },
        {
          "language": "sq",
          "text": "ekspertizë; njohuri profesionale"
        },
        {
          "language": "tr",
          "text": "uzmanlık; uzman raporu"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Bewertung der Sicherheitsarchitektur holen wir externe Expertise ein.",
          "translations": [
            {
              "language": "ar",
              "text": "نستعين بخبرة خارجية لتقييم بنية الأمان."
            },
            {
              "language": "ckb",
              "text": "بۆ هەڵسەنگاندنی پێکهاتەی ئاسایش، شارەزایی دەرەکی وەردەگرین."
            },
            {
              "language": "en",
              "text": "We are obtaining external expertise to assess the security architecture."
            },
            {
              "language": "fa",
              "text": "برای ارزیابی معماری امنیتی از تخصص بیرونی کمک می‌گیریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo nirxandina avahiya ewlehiyê em pisporiya derveyî werdigirin."
            },
            {
              "language": "pl",
              "text": "Do oceny architektury bezpieczeństwa pozyskujemy zewnętrzną ekspertyzę."
            },
            {
              "language": "ro",
              "text": "Pentru evaluarea arhitecturii de securitate apelăm la expertiză externă."
            },
            {
              "language": "ru",
              "text": "Для оценки архитектуры безопасности мы привлекаем внешнюю экспертизу."
            },
            {
              "language": "sq",
              "text": "Për vlerësimin e arkitekturës së sigurisë po marrim ekspertizë të jashtme."
            },
            {
              "language": "tr",
              "text": "Güvenlik mimarisini değerlendirmek için dış uzmanlık alıyoruz."
            }
          ]
        },
        {
          "baseText": "Ihre Expertise im Vergaberecht war entscheidend für die saubere Dokumentation des Verfahrens.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت خبرتها في قانون المناقصات حاسمة للتوثيق السليم للإجراء."
            },
            {
              "language": "ckb",
              "text": "شارەزاییەکەی لە یاسای پێدانی گرێبەستدا بڕیاریدەر بوو بۆ بەڵگەنامەسازیی پاکی پرۆسەکە."
            },
            {
              "language": "en",
              "text": "Her expertise in procurement law was decisive for the clean documentation of the procedure."
            },
            {
              "language": "fa",
              "text": "تخصص او در حقوق مناقصات برای مستندسازی درست فرایند تعیین‌کننده بود."
            },
            {
              "language": "kmr",
              "text": "Pisporiya wê di qanûna peymanpêdanê de ji bo belgekirina rast a pêvajoyê girîng bû."
            },
            {
              "language": "pl",
              "text": "Jej ekspertyza w prawie zamówień była kluczowa dla poprawnej dokumentacji procedury."
            },
            {
              "language": "ro",
              "text": "Expertiza ei în dreptul achizițiilor a fost decisivă pentru documentarea corectă a procedurii."
            },
            {
              "language": "ru",
              "text": "Ее экспертиза в праве закупок была решающей для корректной документации процедуры."
            },
            {
              "language": "sq",
              "text": "Ekspertiza e saj në të drejtën e prokurimit ishte vendimtare për dokumentimin e saktë të procedurës."
            },
            {
              "language": "tr",
              "text": "İhale hukukundaki uzmanlığı sürecin düzgün belgelenmesi için belirleyici oldu."
            }
          ]
        }
      ]
    },
    {
      "word": "explizit",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ex-pli-zit",
      "topics": [
        "business-communication",
        "documents-and-administration",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective/adverb; means explicitly, clearly stated"
      ],
      "collocations": [
        {
          "text": "explizit darauf hinweisen",
          "meaning": "to explicitly point out"
        },
        {
          "text": "explizit geregelt sein",
          "meaning": "to be explicitly regulated"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Explizitheit",
          "relationLabel": "noun",
          "note": "rare noun"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "صريح؛ بشكل واضح ومباشر"
        },
        {
          "language": "ckb",
          "text": "بە ڕوونی؛ ڕاستەوخۆ؛ ئاشکرا"
        },
        {
          "language": "en",
          "text": "explicit; explicitly stated"
        },
        {
          "language": "fa",
          "text": "صریح؛ آشکار؛ به‌طور روشن بیان‌شده"
        },
        {
          "language": "kmr",
          "text": "eşkere; bi zelalî gotî"
        },
        {
          "language": "pl",
          "text": "wyraźny; jednoznaczny; explicite"
        },
        {
          "language": "ro",
          "text": "explicit; formulat clar"
        },
        {
          "language": "ru",
          "text": "явный; прямо указанный"
        },
        {
          "language": "sq",
          "text": "eksplicit; i shprehur qartë"
        },
        {
          "language": "tr",
          "text": "açık; açıkça belirtilmiş"
        }
      ],
      "examples": [
        {
          "baseText": "Der Vertrag regelt explizit, welche Daten nach Vertragsende gelöscht werden müssen.",
          "translations": [
            {
              "language": "ar",
              "text": "ينظم العقد صراحةً أي بيانات يجب حذفها بعد انتهاء العقد."
            },
            {
              "language": "ckb",
              "text": "گرێبەستەکە بە ڕوونی ڕێکدەخات کام داتا دوای کۆتایی گرێبەست دەبێت بسڕدرێتەوە."
            },
            {
              "language": "en",
              "text": "The contract explicitly regulates which data must be deleted after the contract ends."
            },
            {
              "language": "fa",
              "text": "قرارداد صریحاً مشخص می‌کند کدام داده‌ها پس از پایان قرارداد باید حذف شوند."
            },
            {
              "language": "kmr",
              "text": "Peyman bi zelalî rêk dixe ka kîjan dane piştî dawîbûna peymanê divê bên jêbirin."
            },
            {
              "language": "pl",
              "text": "Umowa wyraźnie reguluje, które dane należy usunąć po zakończeniu umowy."
            },
            {
              "language": "ro",
              "text": "Contractul reglementează explicit ce date trebuie șterse după încheierea contractului."
            },
            {
              "language": "ru",
              "text": "Договор прямо регулирует, какие данные должны быть удалены после окончания договора."
            },
            {
              "language": "sq",
              "text": "Kontrata rregullon qartë cilat të dhëna duhet të fshihen pas përfundimit të kontratës."
            },
            {
              "language": "tr",
              "text": "Sözleşme, sözleşme bitiminden sonra hangi verilerin silinmesi gerektiğini açıkça düzenler."
            }
          ]
        },
        {
          "baseText": "Bitte weisen Sie im Angebot explizit auf die zusätzlichen Wartungskosten hin.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الإشارة صراحة في العرض إلى تكاليف الصيانة الإضافية."
            },
            {
              "language": "ckb",
              "text": "تکایە لە پێشنیارەکەدا بە ڕوونی ئاماژە بە تێچووی زیادەی چاکسازی بکەن."
            },
            {
              "language": "en",
              "text": "Please explicitly point out the additional maintenance costs in the offer."
            },
            {
              "language": "fa",
              "text": "لطفاً در پیشنهاد به‌طور صریح به هزینه‌های نگهداری اضافی اشاره کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe di pêşniyarê de bi zelalî amaje bi lêçûnên zêde yên lênêrînê bikin."
            },
            {
              "language": "pl",
              "text": "Proszę wyraźnie wskazać w ofercie dodatkowe koszty utrzymania."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să menționați explicit în ofertă costurile suplimentare de mentenanță."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, прямо укажите в предложении дополнительные расходы на обслуживание."
            },
            {
              "language": "sq",
              "text": "Ju lutemi, tregoni qartë në ofertë kostot shtesë të mirëmbajtjes."
            },
            {
              "language": "tr",
              "text": "Lütfen teklifte ek bakım maliyetlerini açıkça belirtin."
            }
          ]
        }
      ]
    },
    {
      "word": "die Fallstudie",
      "language": "de",
