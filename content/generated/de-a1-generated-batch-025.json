      "examples": [
        {
          "baseText": "Im Dezember ist es kalt.",
          "translations": [
            {
              "language": "ar",
              "text": "في ديسمبر يكون الجو بارداً."
            },
            {
              "language": "ckb",
              "text": "لە دیسەمبەردا کەشەکە ساردە."
            },
            {
              "language": "en",
              "text": "It is cold in December."
            },
            {
              "language": "fa",
              "text": "در دسامبر هوا سرد است."
            },
            {
              "language": "kmr",
              "text": "Di Kanûnê de hewa sar e."
            },
            {
              "language": "pl",
              "text": "W grudniu jest zimno."
            },
            {
              "language": "ro",
              "text": "În decembrie este frig."
            },
            {
              "language": "ru",
              "text": "В декабре холодно."
            },
            {
              "language": "sq",
              "text": "Në dhjetor është ftohtë."
            },
            {
              "language": "tr",
              "text": "Aralık ayında hava soğuktur."
            }
          ]
        },
        {
          "baseText": "Mein Geburtstag ist im Dezember.",
          "translations": [
            {
              "language": "ar",
              "text": "عيد ميلادي في ديسمبر."
            },
            {
              "language": "ckb",
              "text": "ڕۆژی لەدایکبوونم لە دیسەمبەرە."
            },
            {
              "language": "en",
              "text": "My birthday is in December."
            },
            {
              "language": "fa",
              "text": "تولد من در دسامبر است."
            },
            {
              "language": "kmr",
              "text": "Roja jidayikbûna min di Kanûnê de ye."
            },
            {
              "language": "pl",
              "text": "Moje urodziny są w grudniu."
            },
            {
              "language": "ro",
              "text": "Ziua mea de naștere este în decembrie."
            },
            {
              "language": "ru",
              "text": "Мой день рождения в декабре."
            },
            {
              "language": "sq",
              "text": "Ditëlindja ime është në dhjetor."
            },
            {
              "language": "tr",
              "text": "Doğum günüm Aralık ayında."
            }
          ]
        }
      ]
