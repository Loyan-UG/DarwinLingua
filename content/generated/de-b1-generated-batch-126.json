  "entries": [
    {
      "word": "die Strategie",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Strategien",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Stra-te-gie",
      "topics": [
        "planning-and-projects",
        "management-and-leadership",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Strategie entwickeln",
          "meaning": "to develop a strategy"
        },
        {
          "text": "die Strategie ändern",
          "meaning": "to change the strategy"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "strategisch",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استراتيجية؛ خطة"
        },
        {
          "language": "ckb",
          "text": "ستراتیژی؛ پلان"
        },
        {
          "language": "en",
          "text": "strategy; plan"
        },
        {
          "language": "fa",
          "text": "استراتژی؛ راهبرد"
        },
        {
          "language": "kmr",
          "text": "stratejî; plan"
        },
        {
          "language": "pl",
          "text": "strategia; plan działania"
        },
        {
          "language": "ro",
          "text": "strategie; plan"
        },
        {
          "language": "ru",
          "text": "стратегия; план"
        },
        {
          "language": "sq",
          "text": "strategji; plan"
        },
        {
          "language": "tr",
          "text": "strateji; plan"
        }
      ],
      "examples": [
        {
          "baseText": "Im Teammeeting haben wir eine neue Strategie für den Kundenservice besprochen.",
          "translations": [
            {
              "language": "ar",
              "text": "ناقشنا في اجتماع الفريق استراتيجية جديدة لخدمة العملاء."
            },
            {
              "language": "ckb",
              "text": "لە کۆبوونەوەی تیمەکەدا ستراتیژییەکی نوێمان بۆ خزمەتگوزاری کڕیاران باس کرد."
            },
            {
              "language": "en",
              "text": "In the team meeting, we discussed a new strategy for customer service."
            },
            {
              "language": "fa",
              "text": "در جلسه تیم، یک استراتژی جدید برای خدمات مشتریان را بررسی کردیم."
            },
            {
              "language": "kmr",
              "text": "Di civîna tîmê de me stratejiyeke nû ji bo xizmeta xerîdaran gotûbêj kir."
            },
            {
              "language": "pl",
              "text": "Na spotkaniu zespołu omówiliśmy nową strategię obsługi klienta."
            },
            {
              "language": "ro",
              "text": "La ședința echipei am discutat o nouă strategie pentru serviciul clienți."
            },
            {
              "language": "ru",
              "text": "На командной встрече мы обсудили новую стратегию обслуживания клиентов."
            },
            {
              "language": "sq",
              "text": "Në takimin e ekipit diskutuam një strategji të re për shërbimin ndaj klientit."
            },
            {
              "language": "tr",
              "text": "Ekip toplantısında müşteri hizmetleri için yeni bir strateji konuştuk."
            }
          ]
        },
        {
          "baseText": "Ohne klare Strategie geben wir zu viel Geld für Werbung aus.",
          "translations": [
            {
              "language": "ar",
              "text": "بدون استراتيجية واضحة ننفق مالًا كثيرًا على الإعلانات."
            },
            {
              "language": "ckb",
              "text": "بێ ستراتیژییەکی ڕوون، پارەی زۆر بۆ ڕیکلام خەرج دەکەین."
            },
            {
              "language": "en",
              "text": "Without a clear strategy, we spend too much money on advertising."
            },
            {
              "language": "fa",
              "text": "بدون یک استراتژی روشن، پول زیادی برای تبلیغات خرج می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Bê stratejiyeke zelal em pir pere ji bo reklaman xerc dikin."
            },
            {
              "language": "pl",
              "text": "Bez jasnej strategii wydajemy za dużo pieniędzy na reklamę."
            },
            {
              "language": "ro",
              "text": "Fără o strategie clară cheltuim prea mulți bani pe publicitate."
            },
            {
              "language": "ru",
              "text": "Без четкой стратегии мы тратим слишком много денег на рекламу."
            },
            {
              "language": "sq",
              "text": "Pa një strategji të qartë shpenzojmë shumë para për reklama."
            },
            {
              "language": "tr",
              "text": "Net bir strateji olmadan reklama çok fazla para harcıyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "streiten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "streiten",
      "pronunciationIpa": null,
      "syllableBreak": "strei-ten",
      "topics": [
        "social-and-relationships",
        "work-and-jobs",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: streitet, stritt, hat gestritten"
      ],
      "collocations": [
        {
          "text": "sich mit jemandem streiten",
          "meaning": "to argue with someone"
        },
        {
          "text": "über Geld streiten",
          "meaning": "to argue about money"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Streit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتجادل؛ يتشاجر"
        },
        {
          "language": "ckb",
          "text": "ناکۆکی کردن؛ شەڕکردن"
        },
        {
          "language": "en",
          "text": "to argue; to quarrel"
        },
        {
          "language": "fa",
          "text": "بحث کردن؛ دعوا کردن"
        },
        {
          "language": "kmr",
          "text": "gengeşe kirin; şer kirin"
        },
        {
          "language": "pl",
          "text": "kłócić się; spierać się"
        },
        {
          "language": "ro",
          "text": "a se certa; a se contrazice"
        },
        {
          "language": "ru",
          "text": "спорить; ссориться"
        },
        {
          "language": "sq",
          "text": "të grindesh; të debatosh"
        },
        {
          "language": "tr",
          "text": "tartışmak; kavga etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kollegen streiten nicht mehr über die Aufgaben, seit alles klar verteilt ist.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يعد الزملاء يتجادلون حول المهام منذ أن تم توزيع كل شيء بوضوح."
            },
            {
              "language": "ckb",
              "text": "هاوکاران چیتر لەسەر ئەرکەکان ناکۆکی ناکەن، چونکە هەموو شتێک بە ڕوونی دابەش کراوە."
            },
            {
              "language": "en",
              "text": "The colleagues no longer argue about the tasks since everything is clearly assigned."
            },
            {
              "language": "fa",
              "text": "همکاران دیگر درباره وظایف بحث نمی‌کنند، چون همه چیز واضح تقسیم شده است."
            },
            {
              "language": "kmr",
              "text": "Hevkar êdî li ser erkê nagengeşin, ji ber ku her tişt bi zelalî hatiye dabeşkirin."
            },
            {
              "language": "pl",
              "text": "Koledzy nie kłócą się już o zadania, odkąd wszystko jest jasno podzielone."
            },
            {
              "language": "ro",
              "text": "Colegii nu se mai ceartă pe sarcini de când totul este împărțit clar."
            },
            {
              "language": "ru",
              "text": "Коллеги больше не спорят о задачах, с тех пор как все четко распределено."
            },
            {
              "language": "sq",
              "text": "Kolegët nuk debatojnë më për detyrat, që kur gjithçka është ndarë qartë."
            },
            {
              "language": "tr",
              "text": "Her şey net şekilde paylaştırıldığından beri çalışanlar görevler hakkında tartışmıyor."
            }
          ]
        },
        {
          "baseText": "Die Nachbarn streiten oft wegen der lauten Musik am Abend.",
          "translations": [
            {
              "language": "ar",
              "text": "يتشاجر الجيران كثيرًا بسبب الموسيقى العالية في المساء."
            },
            {
              "language": "ckb",
              "text": "دراوسێکان زۆرجار بەهۆی مۆسیقای بەرزی ئێوارانەوە شەڕ دەکەن."
            },
            {
              "language": "en",
              "text": "The neighbors often argue because of the loud music in the evening."
            },
            {
              "language": "fa",
              "text": "همسایه‌ها اغلب به خاطر موسیقی بلند شب‌ها دعوا می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Cîran gelek caran ji ber muzîka bilind a êvarê şer dikin."
            },
            {
              "language": "pl",
              "text": "Sąsiedzi często kłócą się z powodu głośnej muzyki wieczorem."
            },
            {
              "language": "ro",
              "text": "Vecinii se ceartă des din cauza muzicii puternice seara."
            },
            {
              "language": "ru",
              "text": "Соседи часто ссорятся из-за громкой музыки по вечерам."
            },
            {
              "language": "sq",
              "text": "Fqinjët shpesh grinden për shkak të muzikës së lartë në mbrëmje."
            },
            {
              "language": "tr",
              "text": "Komşular akşamları yüksek müzik yüzünden sık sık tartışıyor."
            }
          ]
        }
      ]
    },
