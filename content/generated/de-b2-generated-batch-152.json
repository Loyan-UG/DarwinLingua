  "entries": [
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "die Diskussionsgrundlage",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Diskussionsgrundlagen",
      "infinitive": null,
      "syllableBreak": "Dis-kus-si-ons-grund-la-ge",
      "topics": [
        "meetings-and-presentations",
        "business-communication",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "meeting",
        "documents"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "als Diskussionsgrundlage dienen",
          "meaning": "to serve as a basis for discussion"
        },
        {
          "text": "eine Diskussionsgrundlage vorbereiten",
          "meaning": "to prepare a basis for discussion"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Diskussion",
          "relationLabel": "compound part",
          "note": null
        },
        {
          "lemma": "die Grundlage",
          "relationLabel": "compound part",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "أساس للنقاش"
        },
        {
          "language": "ckb",
          "text": "بنەمای گفتوگۆ"
        },
        {
          "language": "en",
          "text": "basis for discussion"
        },
        {
          "language": "fa",
          "text": "مبنای بحث"
        },
        {
          "language": "kmr",
          "text": "bingeh ji bo nîqaşê"
        },
        {
          "language": "pl",
          "text": "podstawa do dyskusji"
        },
        {
          "language": "ro",
          "text": "bază de discuție"
        },
        {
          "language": "ru",
          "text": "основа для обсуждения"
        },
        {
          "language": "sq",
          "text": "bazë për diskutim"
        },
        {
          "language": "tr",
          "text": "tartışma zemini"
        }
      ],
      "examples": [
        {
          "baseText": "Ich schicke euch den Entwurf als Diskussionsgrundlage für das Meeting am Donnerstag.",
          "translations": [
            {
              "language": "ar",
              "text": "سأرسل لكم المسودة كأساس للنقاش في اجتماع يوم الخميس."
            },
            {
              "language": "ckb",
              "text": "ڕەشنووسەکە وەک بنەمای گفتوگۆ بۆ کۆبوونەوەی پێنجشەممە بۆتان دەنێرم."
            },
            {
              "language": "en",
              "text": "I will send you the draft as a basis for discussion for Thursday’s meeting."
            },
            {
              "language": "fa",
              "text": "پیش‌نویس را به‌عنوان مبنای بحث برای جلسه پنجشنبه برایتان می‌فرستم."
            },
            {
              "language": "kmr",
              "text": "Ez ê pêşnivîsê wek bingeh ji bo nîqaşa civîna roja pêncşemê ji we re bişînim."
            },
            {
              "language": "pl",
              "text": "Wyślę wam projekt jako podstawę do dyskusji na czwartkowe spotkanie."
            },
            {
              "language": "ro",
              "text": "Vă trimit proiectul ca bază de discuție pentru ședința de joi."
            },
            {
              "language": "ru",
              "text": "Я отправлю вам черновик как основу для обсуждения на встрече в четверг."
            },
            {
              "language": "sq",
              "text": "Do t’jua dërgoj draftin si bazë për diskutim për takimin e së enjtes."
            },
            {
              "language": "tr",
              "text": "Taslağı perşembe günkü toplantı için tartışma zemini olarak size göndereceğim."
            }
          ]
        },
        {
          "baseText": "Die Zahlen aus der Umfrage sind noch nicht endgültig, aber sie bieten eine gute Diskussionsgrundlage.",
          "translations": [
            {
              "language": "ar",
              "text": "أرقام الاستبيان ليست نهائية بعد، لكنها توفر أساسًا جيدًا للنقاش."
            },
            {
              "language": "ckb",
              "text": "ژمارەکانی ڕاپرسییەکە هێشتا کۆتایی نین، بەڵام بنەمایەکی باش بۆ گفتوگۆ دابین دەکەن."
            },
            {
              "language": "en",
              "text": "The survey figures are not final yet, but they provide a good basis for discussion."
            },
            {
              "language": "fa",
              "text": "اعداد نظرسنجی هنوز نهایی نیستند، اما مبنای خوبی برای بحث فراهم می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Hejmarên ankêtê hîn dawî nînin, lê bingehê baş ji bo nîqaşê pêşkêş dikin."
            },
            {
              "language": "pl",
              "text": "Dane z ankiety nie są jeszcze ostateczne, ale stanowią dobrą podstawę do dyskusji."
            },
            {
              "language": "ro",
              "text": "Cifrele din sondaj nu sunt încă finale, dar oferă o bază bună de discuție."
            },
            {
              "language": "ru",
              "text": "Данные опроса еще не окончательные, но они дают хорошую основу для обсуждения."
            },
            {
              "language": "sq",
              "text": "Shifrat nga anketa nuk janë ende përfundimtare, por ofrojnë një bazë të mirë për diskutim."
            },
            {
              "language": "tr",
              "text": "Anket rakamları henüz kesin değil, ancak iyi bir tartışma zemini sunuyor."
            }
          ]
        }
      ]
    },
