      "meanings": [
        {
          "language": "ar",
          "text": "يمرر؛ ينجح في إقرار؛ يساعد على تجاوز"
        },
        {
          "language": "ckb",
          "text": "تێدەپەڕێنێت؛ پەسەند دەکات؛ لە قەیران دەرباز دەکات"
        },
        {
          "language": "en",
          "text": "to get approved; to get through; to carry someone through"
        },
        {
          "language": "fa",
          "text": "به تصویب رساندن؛ از چیزی عبور دادن"
        },
        {
          "language": "kmr",
          "text": "pejirandin; derbas kirin; ji rewşek derxistin"
        },
        {
          "language": "pl",
          "text": "przeforsować; przeprowadzić przez coś"
        },
        {
          "language": "ro",
          "text": "a face să treacă; a ajuta să treacă peste ceva"
        },
        {
          "language": "ru",
          "text": "провести; добиться принятия; помочь пережить"
        },
        {
          "language": "sq",
          "text": "të kalosh; të bësh të miratohet; të ndihmosh të përballojë"
        },
        {
          "language": "tr",
          "text": "kabul ettirmek; birini/süreci atlatmak"
