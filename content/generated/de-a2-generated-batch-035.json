      "examples": [
        {
          "baseText": "Die Fachfrau erklärt uns die Maschine.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح لنا الخبيرة الآلة."
            },
            {
              "language": "ckb",
              "text": "پسپۆڕە ژنەکە ئامێرەکەمان بۆ ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The specialist explains the machine to us."
            },
            {
              "language": "fa",
              "text": "متخصص دستگاه را برای ما توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Pispor amûrê ji me re rave dike."
