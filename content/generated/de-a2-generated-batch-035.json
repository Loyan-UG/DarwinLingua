      "examples": [
        {
          "baseText": "Viele Länder in Europa benutzen den Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "تستخدم دول كثيرة في أوروبا اليورو."
            },
            {
              "language": "ckb",
              "text": "زۆر وڵات لە ئەورووپا یۆرۆ بەکاردەهێنن."
            },
            {
              "language": "en",
              "text": "Many countries in Europe use the euro."
            },
            {
              "language": "fa",
              "text": "بسیاری از کشورها در اروپا از یورو استفاده می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Gelek welatên Ewropayê euro bi kar tînin."
            },
            {
              "language": "pl",
              "text": "Wiele krajów w Europie używa euro."
            },
            {
              "language": "ro",
              "text": "Multe țări din Europa folosesc euro."
            },
            {
              "language": "ru",
              "text": "Многие страны в Европе используют евро."
            },
            {
              "language": "sq",
              "text": "Shumë vende në Evropë përdorin euron."
            },
            {
              "language": "tr",
              "text": "Avrupa’daki birçok ülke avro kullanır."
            }
          ]
        },
        {
          "baseText": "Wir möchten im Sommer durch Europa reisen.",
          "translations": [
            {
              "language": "ar",
              "text": "نريد أن نسافر في الصيف عبر أوروبا."
            },
            {
              "language": "ckb",
              "text": "دەمانەوێت لە هاویندا بە ئەورووپا بگەڕێین."
            },
            {
              "language": "en",
              "text": "We would like to travel through Europe in the summer."
            },
            {
              "language": "fa",
              "text": "می‌خواهیم تابستان در اروپا سفر کنیم."
            },
            {
              "language": "kmr",
              "text": "Em dixwazin havînê li Ewropayê bigerin."
            },
            {
              "language": "pl",
              "text": "Latem chcemy podróżować po Europie."
            },
            {
              "language": "ro",
              "text": "Vrem să călătorim prin Europa vara."
            },
            {
              "language": "ru",
              "text": "Летом мы хотим путешествовать по Европе."
            },
            {
              "language": "sq",
              "text": "Duam të udhëtojmë nëpër Evropë në verë."
            },
            {
              "language": "tr",
              "text": "Yazın Avrupa’da seyahat etmek istiyoruz."
            }
          ]
        }
      ]
    },
