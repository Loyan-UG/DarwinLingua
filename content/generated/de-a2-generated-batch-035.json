      "examples": [
        {
          "baseText": "Sie arbeitet für eine europäische Firma.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تعمل لدى شركة أوروبية."
            },
            {
              "language": "ckb",
              "text": "ئەو بۆ کۆمپانیایەکی ئەورووپی کار دەکات."
            },
            {
              "language": "en",
              "text": "She works for a European company."
            },
            {
              "language": "fa",
              "text": "او برای یک شرکت اروپایی کار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ew ji bo şîrketek ewropî dixebite."
            },
            {
              "language": "pl",
              "text": "Ona pracuje dla europejskiej firmy."
            },
            {
              "language": "ro",
              "text": "Ea lucrează pentru o firmă europeană."
            },
            {
              "language": "ru",
              "text": "Она работает в европейской компании."
            },
            {
              "language": "sq",
              "text": "Ajo punon për një kompani evropiane."
            },
            {
              "language": "tr",
              "text": "Avrupalı bir şirket için çalışıyor."
            }
          ]
        },
        {
          "baseText": "Im Kurs sprechen wir über europäische Länder.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدورة نتحدث عن دول أوروبية."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسەکەدا باس لە وڵاتانی ئەورووپی دەکەین."
            },
            {
              "language": "en",
              "text": "In the course, we talk about European countries."
            },
            {
              "language": "fa",
              "text": "در کلاس درباره کشورهای اروپایی صحبت می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di kursê de em li ser welatên ewropî diaxivin."
            },
            {
              "language": "pl",
              "text": "Na kursie rozmawiamy o krajach europejskich."
            },
            {
              "language": "ro",
              "text": "La curs vorbim despre țări europene."
            },
            {
              "language": "ru",
              "text": "На курсе мы говорим о европейских странах."
            },
            {
              "language": "sq",
              "text": "Në kurs flasim për vendet evropiane."
            },
            {
              "language": "tr",
              "text": "Kursta Avrupa ülkeleri hakkında konuşuyoruz."
            }
