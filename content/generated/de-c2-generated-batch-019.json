      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يهين بفظاظة؛ يصدّ بشكل جارح"
        },
        {
          "language": "ckb",
          "text": "بە توندی سووکایەتی بکات؛ بە شێوەیەکی بریندارکەر ڕەت بکاتەوە"
        },
        {
          "language": "en",
          "text": "to offend; to snub; to affront abruptly"
        },
        {
          "language": "fa",
          "text": "رنجاندن با رفتار تند؛ بی‌اعتنایی توهین‌آمیز کردن"
        },
        {
          "language": "kmr",
          "text": "bi tûjî xemgîn kirin; bêhurmet kirin"
        },
        {
          "language": "pl",
          "text": "urazić; zlekceważyć obcesowo"
        },
        {
          "language": "ro",
          "text": "a brusca; a ofensa prin respingere bruscă"
        },
