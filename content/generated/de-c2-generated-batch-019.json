  "entries": [
    {
      "word": "brüchig",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "brü-chig",
      "topics": [
        "quality-and-risk",
        "social-and-relationships",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; can describe physical fragility or figurative instability"
      ],
      "collocations": [
        {
          "text": "brüchiges Vertrauen",
          "meaning": "fragile trust"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Bruch",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "brechen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "هش؛ قابل للكسر؛ غير مستقر"
        },
        {
          "language": "ckb",
          "text": "شکاوە؛ لاواز؛ ناجێگیر"
        },
        {
          "language": "en",
          "text": "fragile; brittle; unstable"
        },
        {
          "language": "fa",
          "text": "شکننده؛ ترد؛ ناپایدار"
        },
        {
          "language": "kmr",
          "text": "şikebar; nazik; ne sekinbar"
        },
        {
          "language": "pl",
          "text": "kruchy; łamliwy; niestabilny"
        },
        {
          "language": "ro",
          "text": "fragil; casant; instabil"
        },
        {
          "language": "ru",
          "text": "хрупкий; ломкий; непрочный"
        },
        {
          "language": "sq",
          "text": "i brishtë; i thyeshëm; i paqëndrueshëm"
        },
        {
          "language": "tr",
          "text": "kırılgan; gevrek; istikrarsız"
        }
      ],
      "examples": [
        {
          "baseText": "Das Vertrauen zwischen den Teams blieb brüchig, obwohl der Konflikt offiziell beigelegt war.",
          "translations": [
            {
              "language": "ar",
              "text": "بقيت الثقة بين الفرق هشة، رغم أن النزاع سُوي رسمياً."
            },
            {
              "language": "ckb",
              "text": "متمانەی نێوان تیمەکان لاواز مایەوە، هەرچەندە ناکۆکییەکە بە فەرمی چارەسەر کرابوو."
            },
            {
              "language": "en",
              "text": "Trust between the teams remained fragile, although the conflict had officially been settled."
            },
            {
              "language": "fa",
              "text": "اعتماد میان تیم‌ها شکننده ماند، هرچند تعارض به‌طور رسمی حل شده بود."
            },
            {
              "language": "kmr",
              "text": "Baweriya di navbera tîman de nazik ma, herçend nakokî bi fermî çareser bûbû."
            },
            {
              "language": "pl",
              "text": "Zaufanie między zespołami pozostało kruche, choć konflikt oficjalnie zażegnano."
            },
            {
              "language": "ro",
              "text": "Încrederea dintre echipe a rămas fragilă, deși conflictul fusese rezolvat oficial."
            },
            {
              "language": "ru",
              "text": "Доверие между командами оставалось хрупким, хотя конфликт официально был урегулирован."
            },
            {
              "language": "sq",
              "text": "Besimi midis ekipeve mbeti i brishtë, megjithëse konflikti ishte zgjidhur zyrtarisht."
            },
            {
              "language": "tr",
              "text": "Ekipler arasındaki güven, çatışma resmen çözülmüş olsa da kırılgan kaldı."
            }
          ]
        },
        {
          "baseText": "Die alten Leitungen waren so brüchig, dass jede Reparatur ein neues Risiko erzeugte.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت الأنابيب القديمة هشة جداً لدرجة أن كل إصلاح كان يخلق خطراً جديداً."
            },
            {
              "language": "ckb",
              "text": "هێڵە کۆنەکان هێندە شکاوە بوون کە هەر چاککردنەوەیەک مەترسییەکی نوێی دروست دەکرد."
            },
            {
              "language": "en",
              "text": "The old pipes were so brittle that every repair created a new risk."
            },
            {
              "language": "fa",
              "text": "لوله‌های قدیمی آن‌قدر شکننده بودند که هر تعمیر ریسک تازه‌ای ایجاد می‌کرد."
            },
            {
              "language": "kmr",
              "text": "Lûleyên kevn ewqas şikebar bûn ku her tamîrek xetereyeke nû çêdikir."
            },
            {
              "language": "pl",
              "text": "Stare przewody były tak kruche, że każda naprawa tworzyła nowe ryzyko."
            },
            {
              "language": "ro",
              "text": "Conductele vechi erau atât de fragile încât fiecare reparație crea un nou risc."
            },
            {
              "language": "ru",
              "text": "Старые трубы были настолько хрупкими, что каждый ремонт создавал новый риск."
            },
            {
              "language": "sq",
              "text": "Tubacionet e vjetra ishin aq të brishta sa çdo riparim krijonte një rrezik të ri."
            },
            {
              "language": "tr",
              "text": "Eski borular o kadar kırılgandı ki her onarım yeni bir risk yaratıyordu."
            }
          ]
        }
      ]
    },
    {
      "word": "brüsk",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "brüsk",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes abrupt, curt, or harsh behavior"
      ],
      "collocations": [
        {
          "text": "brüsk reagieren",
          "meaning": "to react curtly or abruptly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "brüskieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فظ؛ مفاجئ وحاد"
        },
        {
          "language": "ckb",
          "text": "تووند و کورت؛ بە توندی لەناکاو"
        },
        {
          "language": "en",
          "text": "abrupt; curt; brusque"
        },
        {
          "language": "fa",
          "text": "تند و ناگهانی؛ سرد و بی‌ملاحظه"
        },
        {
          "language": "kmr",
          "text": "tûj û nişka ve; kurt û sar"
        },
        {
          "language": "pl",
          "text": "obcesowy; opryskliwy; gwałtowny"
        },
        {
          "language": "ro",
          "text": "brusc; tăios; nepoliticos"
        },
        {
          "language": "ru",
          "text": "резкий; грубовато-краткий"
        },
        {
          "language": "sq",
          "text": "i prerë; i ashpër; i beftë"
        },
        {
          "language": "tr",
          "text": "kaba kısa; ani ve sert"
        }
      ],
      "examples": [
        {
          "baseText": "Die brüske Antwort des Supports verschärfte die Beschwerde, statt sie zu klären.",
          "translations": [
            {
              "language": "ar",
              "text": "زاد رد الدعم الفظ الشكوى حدة بدلاً من توضيحها."
            },
            {
              "language": "ckb",
              "text": "وەڵامی توندی پشتگیری سکاڵاکەی توندتر کرد، نەک ڕوونی بکاتەوە."
            },
            {
              "language": "en",
              "text": "The support team’s brusque reply escalated the complaint instead of clarifying it."
            },
            {
              "language": "fa",
              "text": "پاسخ تند پشتیبانی شکایت را تشدید کرد، نه اینکه آن را روشن کند."
            },
            {
              "language": "kmr",
              "text": "Bersiva tûj a piştgiriyê gilî zêdetir aloztir kir, ne ku zelal bike."
            },
            {
              "language": "pl",
              "text": "Obcesowa odpowiedź wsparcia zaostrzyła reklamację zamiast ją wyjaśnić."
            },
            {
              "language": "ro",
              "text": "Răspunsul brusc al suportului a agravat reclamația în loc să o clarifice."
            },
            {
              "language": "ru",
              "text": "Резкий ответ поддержки обострил жалобу вместо того, чтобы её прояснить."
            },
            {
              "language": "sq",
              "text": "Përgjigjja e prerë e mbështetjes e përshkallëzoi ankesën në vend që ta sqaronte."
            },
            {
              "language": "tr",
              "text": "Destek ekibinin kaba kısa yanıtı şikâyeti açıklığa kavuşturmak yerine tırmandırdı."
            }
          ]
        },
        {
          "baseText": "Er brach das Gespräch brüsk ab, als die Frage nach seiner Verantwortung gestellt wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "أنهى الحديث بحدة عندما طُرح سؤال مسؤوليته."
            },
            {
              "language": "ckb",
              "text": "کاتێک پرسیاری بەرپرسیارێتییەکەی کرا، گفتوگۆکەی بە توندی پچڕاند."
            },
            {
              "language": "en",
              "text": "He abruptly broke off the conversation when the question of his responsibility was raised."
            },
            {
              "language": "fa",
              "text": "وقتی پرسش درباره مسئولیت او مطرح شد، گفت‌وگو را ناگهان و تند قطع کرد."
            },
            {
              "language": "kmr",
              "text": "Dema pirs li ser berpirsiyariya wî hat kirin, wî axaftin bi tûjî qut kir."
            },
            {
              "language": "pl",
              "text": "Gwałtownie przerwał rozmowę, gdy padło pytanie o jego odpowiedzialność."
            },
            {
              "language": "ro",
              "text": "A întrerupt brusc conversația când a fost pusă întrebarea despre responsabilitatea lui."
            },
            {
              "language": "ru",
              "text": "Он резко прервал разговор, когда был задан вопрос о его ответственности."
            },
            {
              "language": "sq",
              "text": "Ai e ndërpreu bisedën ashpër kur u bë pyetja për përgjegjësinë e tij."
            },
            {
              "language": "tr",
              "text": "Sorumluluğuyla ilgili soru sorulunca konuşmayı sertçe kesti."
            }
          ]
        }
      ]
    },
    {
