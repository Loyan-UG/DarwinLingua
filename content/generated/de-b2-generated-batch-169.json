      "word": "entscheidend",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "syllableBreak": "ent-schei-dend",
      "topics": [
        "management-and-leadership",
        "advanced-analysis",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "formal",
        "analysis"
      ],
      "contextLabels": [
        "management",
        "risk"
      ],
      "grammarNotes": [
        "adjective/adverb; means decisive or crucial"
      ],
      "collocations": [
        {
          "text": "entscheidend sein",
          "meaning": "to be decisive"
        },
        {
          "text": "ein entscheidender Faktor",
          "meaning": "a decisive factor"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "entscheiden",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Entscheidung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "حاسم؛ مهم للغاية"
        },
        {
          "language": "ckb",
          "text": "یەکلاکەرەوە؛ زۆر گرنگ"
        },
        {
          "language": "en",
          "text": "decisive; crucial"
        },
        {
          "language": "fa",
          "text": "تعیین‌کننده؛ حیاتی"
        },
        {
          "language": "kmr",
          "text": "biryarder; girîng"
        },
        {
          "language": "pl",
          "text": "decydujący; kluczowy"
        },
        {
          "language": "ro",
          "text": "decisiv; crucial"
        },
        {
          "language": "ru",
          "text": "решающий; ключевой"
        },
        {
          "language": "sq",
          "text": "vendimtar; thelbësor"
        },
        {
          "language": "tr",
          "text": "belirleyici; kritik"
        }
      ],
      "examples": [
        {
          "baseText": "Für den Erfolg des Projekts ist eine klare Kommunikation mit dem Kunden entscheidend.",
          "translations": [
            {
              "language": "ar",
              "text": "التواصل الواضح مع العميل حاسم لنجاح المشروع."
            },
            {
              "language": "ckb",
              "text": "بۆ سەرکەوتنی پرۆژەکە پەیوەندیی ڕوون لەگەڵ کڕیار یەکلاکەرەوەیە."
            },
            {
              "language": "en",
              "text": "Clear communication with the customer is crucial for the project’s success."
            },
            {
              "language": "fa",
              "text": "ارتباط شفاف با مشتری برای موفقیت پروژه تعیین‌کننده است."
            },
            {
              "language": "kmr",
              "text": "Ji bo serkeftina projeyê, peywendiya zelal bi xerîdar re girîng û biryarder e."
            },
            {
              "language": "pl",
              "text": "Dla sukcesu projektu kluczowa jest jasna komunikacja z klientem."
            },
            {
              "language": "ro",
              "text": "Pentru succesul proiectului, comunicarea clară cu clientul este decisivă."
            },
            {
              "language": "ru",
              "text": "Для успеха проекта решающее значение имеет четкая коммуникация с клиентом."
            },
            {
              "language": "sq",
              "text": "Për suksesin e projektit, komunikimi i qartë me klientin është vendimtar."
            },
            {
              "language": "tr",
              "text": "Projenin başarısı için müşteriyle net iletişim belirleyicidir."
            }
          ]
        },
        {
          "baseText": "Bei der Wohnungssuche war die Nähe zur Schule entscheidend.",
          "translations": [
            {
              "language": "ar",
              "text": "عند البحث عن شقة كان القرب من المدرسة هو العامل الحاسم."
            },
            {
              "language": "ckb",
              "text": "لە گەڕان بەدوای خانوودا نزیکی لە قوتابخانە یەکلاکەرەوە بوو."
            },
            {
              "language": "en",
              "text": "When looking for an apartment, proximity to the school was decisive."
            },
            {
              "language": "fa",
              "text": "در جست‌وجوی خانه، نزدیکی به مدرسه تعیین‌کننده بود."
            },
            {
              "language": "kmr",
              "text": "Di lêgerîna xanî de nêzîkbûna dibistanê biryarder bû."
            },
            {
              "language": "pl",
              "text": "Przy szukaniu mieszkania decydująca była bliskość szkoły."
            },
            {
              "language": "ro",
              "text": "La căutarea locuinței, apropierea de școală a fost decisivă."
            },
            {
              "language": "ru",
              "text": "При поиске квартиры решающим фактором была близость к школе."
            },
            {
              "language": "sq",
              "text": "Gjatë kërkimit të banesës, afërsia me shkollën ishte vendimtare."
            },
            {
              "language": "tr",
              "text": "Ev ararken okula yakınlık belirleyici oldu."
            }
          ]
        }
      ]
    },
