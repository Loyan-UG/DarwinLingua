      ],
      "collocations": [
        {
          "text": "ein Restaurant empfehlen",
          "meaning": "to recommend a restaurant"
        },
        {
          "text": "etwas weiterempfehlen",
          "meaning": "to recommend something to others"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Empfehlung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يوصي؛ ينصح"
        },
        {
          "language": "ckb",
          "text": "پێشنیارکردن؛ ڕاسپاردن"
        },
        {
          "language": "en",
          "text": "to recommend"
        },
        {
          "language": "fa",
          "text": "توصیه کردن؛ پیشنهاد دادن"
        },
        {
          "language": "kmr",
          "text": "pêşniyar kirin; şîret kirin"
        },
        {
          "language": "pl",
          "text": "polecić; rekomendować"
        },
        {
          "language": "ro",
          "text": "a recomanda"
        },
        {
          "language": "ru",
          "text": "рекомендовать"
        },
        {
          "language": "sq",
          "text": "të rekomandosh"
        },
        {
          "language": "tr",
          "text": "tavsiye etmek; önermek"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie mir ein gutes Restaurant empfehlen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم أن توصوا لي بمطعم جيد؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن چێشتخانەیەکی باشم پێشنیار بکەن؟"
            },
            {
              "language": "en",
              "text": "Can you recommend a good restaurant to me?"
            },
            {
              "language": "fa",
              "text": "می‌توانید یک رستوران خوب به من پیشنهاد کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin restoranek baş ji min re pêşniyar bikin?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan/Pani polecić mi dobrą restaurację?"
            },
            {
              "language": "ro",
              "text": "Îmi puteți recomanda un restaurant bun?"
            },
            {
              "language": "ru",
              "text": "Можете порекомендовать мне хороший ресторан?"
            },
            {
              "language": "sq",
              "text": "A mund të më rekomandoni një restorant të mirë?"
            },
            {
              "language": "tr",
              "text": "Bana iyi bir restoran önerebilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Ich empfehle diese App für Anfänger.",
          "translations": [
            {
              "language": "ar",
              "text": "أوصي بهذا التطبيق للمبتدئين."
            },
            {
              "language": "ckb",
              "text": "ئەم ئەپە بۆ دەستپێکەران پێشنیار دەکەم."
            },
            {
              "language": "en",
              "text": "I recommend this app for beginners."
            },
            {
              "language": "fa",
              "text": "این اپلیکیشن را برای مبتدی‌ها توصیه می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez vê sepanê ji bo destpêkeran pêşniyar dikim."
            },
            {
              "language": "pl",
              "text": "Polecam tę aplikację początkującym."
            },
            {
              "language": "ro",
              "text": "Recomand această aplicație pentru începători."
            },
            {
              "language": "ru",
              "text": "Я рекомендую это приложение начинающим."
            },
            {
              "language": "sq",
              "text": "E rekomandoj këtë aplikacion për fillestarët."
            },
            {
              "language": "tr",
              "text": "Bu uygulamayı yeni başlayanlara tavsiye ederim."
            }
          ]
        }
      ]
    },
