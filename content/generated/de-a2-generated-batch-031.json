      "examples": [
        {
          "baseText": "Der Bus ist endlich da.",
          "translations": [
            {
              "language": "ar",
              "text": "الحافلة وصلت أخيراً."
            },
            {
              "language": "ckb",
              "text": "پاسەکە لە کۆتاییدا گەیشت."
            },
            {
              "language": "en",
              "text": "The bus is finally here."
            },
            {
              "language": "fa",
              "text": "اتوبوس بالاخره آمد."
            },
            {
              "language": "kmr",
              "text": "Otobus dawî hat."
            },
            {
              "language": "pl",
              "text": "Autobus wreszcie jest."
            },
            {
              "language": "ro",
              "text": "Autobuzul este în sfârșit aici."
            },
            {
              "language": "ru",
              "text": "Автобус наконец приехал."
            },
            {
              "language": "sq",
              "text": "Autobusi më në fund erdhi."
            },
            {
              "language": "tr",
              "text": "Otobüs sonunda geldi."
            }
          ]
        },
        {
          "baseText": "Nach der Arbeit bin ich endlich zu Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد العمل أنا أخيراً في البيت."
            },
            {
              "language": "ckb",
              "text": "دوای کار لە کۆتاییدا لە ماڵەوەم."
            },
            {
              "language": "en",
              "text": "After work, I am finally at home."
            },
            {
              "language": "fa",
              "text": "بعد از کار بالاخره در خانه هستم."
            },
            {
              "language": "kmr",
              "text": "Piştî karê ez dawî li malê me."
            },
            {
              "language": "pl",
              "text": "Po pracy jestem wreszcie w domu."
            },
            {
              "language": "ro",
              "text": "După muncă sunt în sfârșit acasă."
            },
            {
              "language": "ru",
              "text": "После работы я наконец дома."
            },
            {
              "language": "sq",
              "text": "Pas punës jam më në fund në shtëpi."
            },
            {
              "language": "tr",
              "text": "İşten sonra sonunda evdeyim."
            }
          ]
        }
      ]
