      ],
      "collocations": [
        {
          "text": "eine Empfangsbestätigung bekommen",
          "meaning": "to receive an acknowledgement of receipt"
        },
        {
          "text": "mit Empfangsbestätigung senden",
          "meaning": "to send with confirmation of receipt"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "empfangen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Bestätigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تأكيد الاستلام"
        },
        {
          "language": "ckb",
          "text": "پشتڕاستکردنەوەی وەرگرتن"
        },
        {
          "language": "en",
          "text": "confirmation of receipt; acknowledgement"
        },
        {
          "language": "fa",
          "text": "تأیید دریافت"
        },
        {
          "language": "kmr",
          "text": "piştrastkirina wergirtinê"
        },
        {
          "language": "pl",
          "text": "potwierdzenie odbioru"
        },
        {
          "language": "ro",
          "text": "confirmare de primire"
        },
        {
          "language": "ru",
          "text": "подтверждение получения"
        },
        {
          "language": "sq",
          "text": "konfirmim pranimi"
        },
        {
          "language": "tr",
          "text": "alındı onayı; teslim alındı belgesi"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schicken Sie mir eine Empfangsbestätigung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى أن ترسلوا لي تأكيد الاستلام."
            },
            {
              "language": "ckb",
              "text": "تکایە پشتڕاستکردنەوەی وەرگرتن بۆم بنێرن."
            },
            {
              "language": "en",
              "text": "Please send me a confirmation of receipt."
            },
            {
              "language": "fa",
              "text": "لطفاً تأیید دریافت را برای من بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe piştrastkirina wergirtinê ji min re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę wysłać mi potwierdzenie odbioru."
            },
            {
              "language": "ro",
              "text": "Vă rog să îmi trimiteți o confirmare de primire."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте мне подтверждение получения."
            },
            {
              "language": "sq",
              "text": "Ju lutem më dërgoni një konfirmim pranimi."
            },
            {
              "language": "tr",
              "text": "Lütfen bana alındı onayı gönderin."
            }
          ]
        },
        {
          "baseText": "Die Empfangsbestätigung kommt automatisch per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "يأتي تأكيد الاستلام تلقائياً عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "پشتڕاستکردنەوەی وەرگرتنەکە ئۆتۆماتیکی بە ئیمەیڵ دێت."
            },
            {
              "language": "en",
              "text": "The confirmation of receipt comes automatically by email."
            },
            {
              "language": "fa",
              "text": "تأیید دریافت به‌صورت خودکار با ایمیل می‌آید."
            },
            {
              "language": "kmr",
              "text": "Piştrastkirina wergirtinê bixweber bi e-nameyê tê."
            },
            {
              "language": "pl",
              "text": "Potwierdzenie odbioru przychodzi automatycznie e-mailem."
            },
            {
              "language": "ro",
              "text": "Confirmarea de primire vine automat prin e-mail."
            },
            {
              "language": "ru",
              "text": "Подтверждение получения автоматически приходит по электронной почте."
            },
            {
              "language": "sq",
              "text": "Konfirmimi i pranimit vjen automatikisht me email."
            },
            {
              "language": "tr",
              "text": "Alındı onayı otomatik olarak e-posta ile gelir."
            }
          ]
        }
      ]
    },
    {
      "word": "empfehlen",
