      ],
      "collocations": [
        {
          "text": "einen Verdächtigen festnehmen",
          "meaning": "to arrest a suspect"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Festnahme",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعتقل؛ يوقف"
        },
        {
          "language": "ckb",
          "text": "دەستگیرکردن"
        },
        {
          "language": "en",
          "text": "to arrest"
        },
        {
          "language": "fa",
          "text": "دستگیر کردن"
        },
        {
          "language": "kmr",
          "text": "girtin; destgîr kirin"
        },
        {
          "language": "pl",
          "text": "aresztować; zatrzymać"
        },
        {
          "language": "ro",
          "text": "a aresta; a reține"
        },
        {
          "language": "ru",
          "text": "арестовывать; задерживать"
        },
        {
          "language": "sq",
          "text": "të arrestosh; të ndalosh"
        },
        {
          "language": "tr",
          "text": "tutuklamak; gözaltına almak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Polizei konnte den Verdächtigen am Bahnhof festnehmen.",
          "translations": [
            {
              "language": "ar",
              "text": "تمكنت الشرطة من اعتقال المشتبه به في محطة القطار."
            },
            {
              "language": "ckb",
              "text": "پۆلیس توانێ گومانلێکراوەکە لە وێستگەی شەمەندەفەر دەستگیر بکات."
            },
            {
              "language": "en",
              "text": "The police were able to arrest the suspect at the train station."
            },
            {
              "language": "fa",
              "text": "پلیس توانست مظنون را در ایستگاه قطار دستگیر کند."
            },
            {
              "language": "kmr",
              "text": "Polîs karî gumanbar li stasyona trênê bigire."
            },
            {
              "language": "pl",
              "text": "Policja zdołała zatrzymać podejrzanego na dworcu."
            },
            {
              "language": "ro",
              "text": "Poliția a putut aresta suspectul la gară."
            },
