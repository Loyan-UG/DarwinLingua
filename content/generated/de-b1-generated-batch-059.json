  "entries": [
    {
      "word": "festlegen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "festlegen",
      "pronunciationIpa": null,
      "syllableBreak": "fest-le-gen",
      "topics": [
        "planning-and-projects",
        "business-communication",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "formal",
        "written"
      ],
      "contextLabels": [
        "documents",
        "administration",
        "management"
      ],
      "grammarNotes": [
        "separable regular verb: legt fest, legte fest, hat festgelegt"
      ],
      "collocations": [
        {
          "text": "einen Termin festlegen",
          "meaning": "to set a date"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fest",
          "relationLabel": "adjective/adverb",
          "note": null
        },
        {
          "lemma": "legen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحدد؛ يقرر"
        },
        {
          "language": "ckb",
          "text": "دیاریکردن؛ بڕیاردان"
        },
        {
          "language": "en",
          "text": "to set; to define; to determine"
        },
        {
          "language": "fa",
          "text": "تعیین کردن؛ مشخص کردن"
        },
        {
          "language": "kmr",
          "text": "diyar kirin; biryar dan"
        },
        {
          "language": "pl",
          "text": "ustalić; określić"
        },
        {
          "language": "ro",
          "text": "a stabili; a defini"
        },
        {
          "language": "ru",
          "text": "устанавливать; определять"
        },
        {
          "language": "sq",
          "text": "të përcaktosh; të vendosësh"
        },
        {
          "language": "tr",
          "text": "belirlemek; kararlaştırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir müssen heute den Termin für die Besprechung festlegen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن نحدد اليوم موعد الاجتماع."
            },
            {
              "language": "ckb",
              "text": "دەبێت ئەمڕۆ کاتی کۆبوونەوەکە دیاری بکەین."
            },
            {
              "language": "en",
              "text": "We need to set the date for the meeting today."
            },
            {
              "language": "fa",
              "text": "باید امروز زمان جلسه را تعیین کنیم."
            },
            {
              "language": "kmr",
              "text": "Divê em îro wextê civînê diyar bikin."
            },
            {
              "language": "pl",
              "text": "Musimy dziś ustalić termin spotkania."
            },
            {
              "language": "ro",
              "text": "Trebuie să stabilim astăzi data ședinței."
            },
            {
              "language": "ru",
              "text": "Сегодня нам нужно назначить дату совещания."
            },
            {
              "language": "sq",
              "text": "Duhet ta caktojmë sot datën e takimit."
            },
            {
              "language": "tr",
              "text": "Toplantı tarihini bugün belirlememiz gerekiyor."
            }
          ]
        },
        {
          "baseText": "Die Regeln für die Nutzung der Küche werden schriftlich festgelegt.",
          "translations": [
            {
              "language": "ar",
              "text": "سيتم تحديد قواعد استخدام المطبخ كتابةً."
            },
            {
              "language": "ckb",
              "text": "یاساکانی بەکارهێنانی چێشتخانەکە بە نووسراوی دیاری دەکرێن."
            },
            {
              "language": "en",
              "text": "The rules for using the kitchen are set down in writing."
            },
            {
              "language": "fa",
              "text": "قوانین استفاده از آشپزخانه به صورت کتبی تعیین می‌شود."
            },
            {
              "language": "kmr",
              "text": "Rêzikên bikaranîna metbexê bi nivîskî tên diyarkirin."
            },
            {
              "language": "pl",
              "text": "Zasady korzystania z kuchni zostaną ustalone na piśmie."
            },
            {
              "language": "ro",
              "text": "Regulile de utilizare a bucătăriei sunt stabilite în scris."
            },
            {
              "language": "ru",
              "text": "Правила пользования кухней будут установлены письменно."
            },
            {
              "language": "sq",
              "text": "Rregullat për përdorimin e kuzhinës përcaktohen me shkrim."
            },
            {
              "language": "tr",
              "text": "Mutfağın kullanım kuralları yazılı olarak belirlenir."
            }
          ]
        }
      ]
    },
    {
      "word": "festnehmen",
