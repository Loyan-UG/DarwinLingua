  "entries": [
    {
      "word": "Auslagerung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Auslagerungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Aus-la-ge-rung",
      "topics": [
        "warehouse-and-logistics",
        "erp-and-business-systems",
        "sales-and-customers"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; in logistics it means removing goods from storage for shipment or use"
      ],
      "collocations": [
        {
          "text": "eine Auslagerung starten",
          "meaning": "to start a stock removal process"
        },
        {
          "text": "die Auslagerung buchen",
          "meaning": "to post the removal from storage"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "auslagern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إخراج من المخزون؛ سحب من المستودع"
        },
        {
          "language": "ckb",
          "text": "دەرکردنی کاڵا لە کۆگا"
        },
        {
          "language": "en",
          "text": "removal from storage; stock withdrawal"
        },
        {
          "language": "fa",
          "text": "خروج از انبار؛ برداشت از موجودی"
        },
        {
          "language": "kmr",
          "text": "derxistina ji embarê"
        },
        {
          "language": "pl",
          "text": "wydanie z magazynu"
        },
        {
          "language": "ro",
          "text": "scoatere din depozit"
        },
        {
          "language": "ru",
          "text": "выдача со склада; снятие с хранения"
        },
        {
          "language": "sq",
          "text": "nxjerrje nga magazina"
        },
        {
          "language": "tr",
          "text": "depodan çıkarma; stoktan çekme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Auslagerung wird im ERP erst gestartet, wenn der Kundenauftrag freigegeben ist.",
          "translations": [
            {
              "language": "ar",
              "text": "لا تبدأ عملية إخراج البضاعة من المستودع في ERP إلا بعد تحرير طلب العميل."
            },
            {
              "language": "ckb",
              "text": "دەرکردنی کاڵا لە کۆگا لە ERP دا تەنها کاتێک دەست پێدەکات کە داواکاریی کڕیار ئازاد کرابێت."
            },
            {
              "language": "en",
              "text": "The stock withdrawal is started in the ERP only when the customer order has been released."
            },
            {
              "language": "fa",
              "text": "خروج کالا از انبار در ERP فقط وقتی شروع می‌شود که سفارش مشتری آزاد شده باشد."
            },
            {
              "language": "kmr",
              "text": "Derxistina ji embarê di ERP de tenê dema fermana mişterî hatibe berdan dest pê dike."
            },
            {
              "language": "pl",
              "text": "Wydanie z magazynu jest uruchamiane w ERP dopiero po zwolnieniu zamówienia klienta."
            },
            {
              "language": "ro",
              "text": "Scoaterea din depozit este pornită în ERP doar după aprobarea comenzii clientului."
            },
            {
              "language": "ru",
              "text": "Выдача со склада запускается в ERP только после разблокировки заказа клиента."
            },
            {
              "language": "sq",
              "text": "Nxjerrja nga magazina nis në ERP vetëm pasi porosia e klientit të jetë liruar."
            },
            {
              "language": "tr",
              "text": "Depodan çıkarma ERP’de ancak müşteri siparişi serbest bırakıldıktan sonra başlatılır."
            }
          ]
        },
        {
          "baseText": "Bei der Auslagerung stellte der Mitarbeiter fest, dass zwei Kartons beschädigt waren.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء إخراج البضاعة من المستودع لاحظ الموظف أن صندوقين كانا تالفين."
            },
            {
              "language": "ckb",
              "text": "لە کاتی دەرکردنی کاڵا لە کۆگا، کارمەندەکە تێبینی کرد دوو کارتۆن زیانیان پێگەیشتووە."
            },
            {
              "language": "en",
              "text": "During the stock withdrawal, the employee noticed that two boxes were damaged."
            },
            {
              "language": "fa",
              "text": "هنگام خروج کالا از انبار، کارمند متوجه شد که دو کارتن آسیب دیده‌اند."
            },
            {
              "language": "kmr",
              "text": "Di dema derxistina ji embarê de karmend dît ku du karton zirar dîtine."
            },
            {
              "language": "pl",
              "text": "Podczas wydania z magazynu pracownik zauważył, że dwa kartony były uszkodzone."
            },
            {
              "language": "ro",
              "text": "La scoaterea din depozit, angajatul a observat că două cutii erau deteriorate."
            },
            {
              "language": "ru",
              "text": "При выдаче со склада сотрудник заметил, что две коробки были повреждены."
            },
            {
              "language": "sq",
              "text": "Gjatë nxjerrjes nga magazina, punonjësi vuri re se dy kuti ishin të dëmtuara."
            },
            {
              "language": "tr",
              "text": "Depodan çıkarma sırasında çalışan iki kolinin hasarlı olduğunu fark etti."
            }
          ]
        }
      ]
    },
    {
      "word": "Avis",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Avise",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "A-vis",
      "topics": [
        "warehouse-and-logistics",
        "procurement-and-suppliers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; in logistics an advance notice of delivery or shipment"
      ],
      "collocations": [
        {
          "text": "ein Avis erfassen",
          "meaning": "to record an advance notice"
        },
        {
          "text": "ein Avis erhalten",
          "meaning": "to receive an advance notice"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "avisieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إشعار مسبق بالشحنة أو التسليم"
        },
        {
          "language": "ckb",
          "text": "ئاگاداریی پێشوەختەی گەیاندن"
        },
        {
          "language": "en",
          "text": "advance delivery notice; shipping notice"
        },
        {
          "language": "fa",
          "text": "اعلامیه پیشاپیش ارسال یا تحویل"
        },
        {
          "language": "kmr",
          "text": "agahdariya pêşwext a radestkirinê"
        },
        {
          "language": "pl",
          "text": "awizo dostawy"
        },
        {
          "language": "ro",
          "text": "aviz de livrare"
        },
        {
          "language": "ru",
          "text": "предварительное уведомление о поставке"
        },
        {
          "language": "sq",
          "text": "njoftim paraprak për dorëzim"
        },
        {
          "language": "tr",
          "text": "ön teslimat bildirimi; sevkiyat bildirimi"
        }
      ],
      "examples": [
        {
          "baseText": "Das Avis vom Lieferanten ist im ERP eingegangen, aber die Ware ist noch nicht angekommen.",
          "translations": [
            {
              "language": "ar",
              "text": "وصل إشعار التسليم من المورد إلى ERP، لكن البضاعة لم تصل بعد."
            },
            {
              "language": "ckb",
              "text": "ئاگاداریی پێشوەختەی دابینکەر لە ERP دا گەیشتووە، بەڵام کاڵاکە هێشتا نەگەیشتووە."
            },
            {
              "language": "en",
              "text": "The supplier’s advance delivery notice has arrived in the ERP, but the goods have not arrived yet."
            },
            {
              "language": "fa",
              "text": "اعلامیه تحویل تأمین‌کننده در ERP ثبت شده، اما کالا هنوز نرسیده است."
            },
            {
              "language": "kmr",
              "text": "Agahdariya pêşwext a dabînker di ERP de hatiye, lê mal hîn negihîştiye."
            },
            {
              "language": "pl",
              "text": "Awizo od dostawcy wpłynęło do ERP, ale towar jeszcze nie dotarł."
            },
            {
              "language": "ro",
              "text": "Avizul de la furnizor a intrat în ERP, dar marfa nu a sosit încă."
            },
            {
              "language": "ru",
              "text": "Уведомление от поставщика поступило в ERP, но товар еще не прибыл."
            },
            {
              "language": "sq",
              "text": "Njoftimi paraprak nga furnitori ka hyrë në ERP, por malli ende nuk ka mbërritur."
            },
            {
              "language": "tr",
              "text": "Tedarikçiden gelen ön teslimat bildirimi ERP’ye ulaştı, ancak mal henüz gelmedi."
            }
          ]
        },
        {
          "baseText": "Ohne Avis kann die Spedition heute keinen festen Entladetermin bestätigen.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون إشعار مسبق لا تستطيع شركة النقل اليوم تأكيد موعد تفريغ ثابت."
            },
            {
              "language": "ckb",
              "text": "بەبێ ئاگاداریی پێشوەختە، کۆمپانیای گواستنەوە ئەمڕۆ ناتوانێت کاتی دابەزاندنی جێگیر پشتڕاست بکاتەوە."
            },
            {
              "language": "en",
              "text": "Without an advance notice, the carrier cannot confirm a fixed unloading appointment today."
            },
            {
              "language": "fa",
              "text": "بدون اعلامیه قبلی، شرکت حمل‌ونقل امروز نمی‌تواند زمان قطعی تخلیه را تأیید کند."
            },
            {
              "language": "kmr",
              "text": "Bê agahdariya pêşwext, şirketa barkirinê îro nikare demeke sabît a daxistinê piştrast bike."
            },
            {
              "language": "pl",
              "text": "Bez awiza spedytor nie może dziś potwierdzić stałego terminu rozładunku."
            },
            {
              "language": "ro",
              "text": "Fără aviz, firma de transport nu poate confirma astăzi o oră fixă de descărcare."
            },
            {
              "language": "ru",
              "text": "Без предварительного уведомления перевозчик сегодня не может подтвердить точное время разгрузки."
            },
            {
              "language": "sq",
              "text": "Pa njoftim paraprak, kompania e transportit nuk mund të konfirmojë sot një orar të saktë shkarkimi."
            },
            {
              "language": "tr",
              "text": "Ön bildirim olmadan nakliye firması bugün kesin bir boşaltma randevusu onaylayamaz."
            }
          ]
        }
      ]
    },
    {
