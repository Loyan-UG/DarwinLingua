      "examples": [
        {
          "baseText": "Der Bearbeitungsbeginn wird im ERP automatisch gesetzt, sobald der Auftrag geöffnet wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تعيين بداية المعالجة في ERP تلقائيًا بمجرد فتح الطلب."
            },
            {
              "language": "ckb",
              "text": "دەستپێکی چارەسەرکردن لە ERP دا خۆکارانە دادەنرێت هەر کات داواکارییەکە بکرێتەوە."
            },
            {
              "language": "en",
              "text": "The start of processing is set automatically in the ERP as soon as the order is opened."
            },
            {
              "language": "fa",
              "text": "شروع پردازش در ERP به‌محض باز شدن سفارش به‌صورت خودکار ثبت می‌شود."
            },
            {
              "language": "kmr",
              "text": "Destpêka xebitandinê di ERP de xweber tê danîn dema ferman were vekirin."
            },
            {
              "language": "pl",
              "text": "Początek przetwarzania jest ustawiany w ERP automatycznie, gdy tylko zamówienie zostanie otwarte."
            },
            {
              "language": "ro",
              "text": "Începutul procesării este setat automat în ERP imediat ce comanda este deschisă."
