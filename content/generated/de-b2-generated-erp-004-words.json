      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بند إشعار التسليم المسبق"
        },
        {
          "language": "ckb",
          "text": "بڕگەی ئاگاداریی پێشوەختەی گەیاندن"
        },
        {
          "language": "en",
          "text": "advance notice line item"
        },
        {
          "language": "fa",
          "text": "ردیف اعلامیه تحویل؛ آیتم avis"
        },
        {
          "language": "kmr",
          "text": "hêla agahdariya pêşwext"
        },
        {
          "language": "pl",
          "text": "pozycja awiza"
        },
        {
          "language": "ro",
          "text": "poziție din avizul de livrare"
        },
        {
          "language": "ru",
          "text": "позиция предварительного уведомления"
        },
        {
          "language": "sq",
          "text": "pozicion i njoftimit paraprak"
        },
        {
          "language": "tr",
          "text": "ön bildirim kalemi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Avisposition passt im ERP nicht zur Bestellposition, deshalb muss der Einkauf sie prüfen.",
          "translations": [
            {
              "language": "ar",
              "text": "بند إشعار التسليم في ERP لا يطابق بند طلب الشراء، لذلك يجب على قسم المشتريات فحصه."
            },
            {
              "language": "ckb",
              "text": "بڕگەی ئاگاداریی پێشوەختە لە ERP دا لەگەڵ بڕگەی داواکاریی کڕین ناگونجێت، بۆیە بەشی کڕین پێویستە بیپشکنێت."
            },
            {
              "language": "en",
              "text": "The advance notice line item does not match the purchase order line in the ERP, so purchasing has to check it."
            },
            {
              "language": "fa",
              "text": "ردیف اعلامیه تحویل در ERP با ردیف سفارش خرید تطبیق ندارد، بنابراین خرید باید آن را بررسی کند."
            },
            {
              "language": "kmr",
              "text": "Hêla agahdariya pêşwext di ERP de bi hêla fermana kirînê re nagunce, ji ber vê yekê kirîn divê wê kontrol bike."
            },
            {
              "language": "pl",
              "text": "Pozycja awiza nie pasuje w ERP do pozycji zamówienia, dlatego dział zakupów musi ją sprawdzić."
            },
            {
              "language": "ro",
              "text": "Poziția din aviz nu corespunde în ERP poziției din comanda de achiziție, de aceea achizițiile trebuie să o verifice."
            },
            {
              "language": "ru",
              "text": "Позиция уведомления в ERP не соответствует позиции заказа на закупку, поэтому отдел закупок должен ее проверить."
            },
            {
              "language": "sq",
              "text": "Pozicioni i njoftimit paraprak nuk përputhet në ERP me pozicionin e porosisë së blerjes, prandaj blerja duhet ta kontrollojë."
            },
            {
              "language": "tr",
              "text": "Ön bildirim kalemi ERP’de satın alma siparişi kalemiyle eşleşmiyor, bu yüzden satın alma ekibi bunu kontrol etmeli."
            }
          ]
        },
        {
          "baseText": "Der Lagermitarbeiter scannte jede Avisposition, bevor er die Palette annahm.",
          "translations": [
            {
              "language": "ar",
              "text": "قام موظف المستودع بمسح كل بند من إشعار التسليم قبل قبول المنصة."
            },
            {
              "language": "ckb",
              "text": "کارمەندی کۆگا هەر بڕگەیەکی ئاگاداریی پێشوەختەی سکان کرد پێش ئەوەی پالێتەکە وەربگرێت."
            },
            {
              "language": "en",
              "text": "The warehouse employee scanned each advance notice line item before accepting the pallet."
            },
            {
              "language": "fa",
              "text": "کارمند انبار قبل از پذیرش پالت، هر ردیف اعلامیه تحویل را اسکن کرد."
            },
            {
              "language": "kmr",
              "text": "Karmendê embarê berî ku paletê qebûl bike her hêla agahdariya pêşwext sken kir."
            },
            {
              "language": "pl",
              "text": "Pracownik magazynu zeskanował każdą pozycję awiza, zanim przyjął paletę."
            },
            {
              "language": "ro",
              "text": "Angajatul depozitului a scanat fiecare poziție din aviz înainte să accepte paletul."
            },
            {
              "language": "ru",
              "text": "Сотрудник склада отсканировал каждую позицию уведомления перед приемкой палеты."
            },
            {
              "language": "sq",
              "text": "Punonjësi i magazinës skanoi çdo pozicion të njoftimit paraprak para se të pranonte paletën."
            },
            {
              "language": "tr",
              "text": "Depo çalışanı paleti kabul etmeden önce her ön bildirim kalemini taradı."
            }
          ]
        }
