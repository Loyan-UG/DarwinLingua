            {
              "language": "kmr",
              "text": "Berî girtina mehê, hesabdarî tomarên nû di daneyên bingehîn ên bankan de kontrol dike."
            },
            {
              "language": "pl",
              "text": "Przed zamknięciem miesiąca księgowość sprawdza nowe wpisy w danych podstawowych banków."
            },
            {
              "language": "ro",
              "text": "Înainte de închiderea lunii, contabilitatea verifică noile înregistrări din datele master ale băncilor."
            },
            {
              "language": "ru",
              "text": "Перед закрытием месяца бухгалтерия проверяет новые записи в основных банковских данных."
            },
            {
              "language": "sq",
              "text": "Para mbylljes mujore, kontabiliteti kontrollon regjistrimet e reja në të dhënat bazë të bankave."
            },
            {
              "language": "tr",
              "text": "Ay kapanışından önce muhasebe banka ana verilerindeki yeni kayıtları kontrol eder."
            }
          ]
