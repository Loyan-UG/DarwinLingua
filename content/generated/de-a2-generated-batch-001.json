        "polite",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: ich bestelle ab, ich habe abbestellt"
      ],
      "collocations": [
        {
          "text": "ein Abo abbestellen",
          "meaning": "to cancel a subscription"
        },
        {
          "text": "eine Zeitung abbestellen",
          "meaning": "to cancel a newspaper order"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bestellen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Bestellung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يلغي طلباً أو اشتراكاً"
        },
        {
          "language": "ckb",
          "text": "هەڵوەشاندنەوەی داواکاری یان ئابوونە"
        },
        {
          "language": "en",
          "text": "to cancel an order or subscription"
        },
        {
          "language": "fa",
          "text": "لغو کردن سفارش یا اشتراک"
        },
        {
          "language": "kmr",
          "text": "siparîşek an abonelîkek betal kirin"
        },
        {
          "language": "pl",
          "text": "odwołać zamówienie lub prenumeratę"
        },
        {
          "language": "ro",
          "text": "a anula o comandă sau un abonament"
        },
        {
          "language": "ru",
          "text": "отменять заказ или подписку"
        },
        {
          "language": "sq",
          "text": "të anulosh një porosi ose abonim"
        },
        {
          "language": "tr",
          "text": "siparişi veya aboneliği iptal etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte den Newsletter abbestellen.",
          "translations": [
            {
              "language": "ar",
              "text": "أريد إلغاء الاشتراك في النشرة البريدية."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت نیوزلەتەرەکە هەڵبوەشێنمەوە."
            },
            {
              "language": "en",
              "text": "I would like to unsubscribe from the newsletter."
            },
            {
              "language": "fa",
              "text": "می‌خواهم خبرنامه را لغو کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim ji nûçenameyê derkevim."
            },
            {
              "language": "pl",
              "text": "Chcę zrezygnować z newslettera."
            },
            {
              "language": "ro",
              "text": "Aș dori să mă dezabonez de la newsletter."
            },
            {
              "language": "ru",
              "text": "Я хочу отписаться от рассылки."
            },
            {
              "language": "sq",
              "text": "Dua ta anuloj abonimin në buletinin informativ."
            },
            {
              "language": "tr",
              "text": "Bülten aboneliğini iptal etmek istiyorum."
            }
          ]
        },
        {
          "baseText": "Können Sie die Zeitung ab nächster Woche abbestellen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم إلغاء الجريدة ابتداءً من الأسبوع القادم؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن ڕۆژنامەکە لە هەفتەی داهاتووەوە هەڵبوەشێننەوە؟"
            },
            {
              "language": "en",
              "text": "Can you cancel the newspaper from next week?"
            },
            {
              "language": "fa",
              "text": "می‌توانید روزنامه را از هفته آینده لغو کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji hefteya bê ve rojnameyê betal bikin?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan/Pani anulować gazetę od przyszłego tygodnia?"
            },
            {
              "language": "ro",
              "text": "Puteți anula ziarul începând de săptămâna viitoare?"
            },
            {
              "language": "ru",
              "text": "Можете отменить газету со следующей недели?"
            },
            {
              "language": "sq",
              "text": "A mund ta anuloni gazetën nga java tjetër?"
            },
            {
              "language": "tr",
              "text": "Gazeteyi gelecek haftadan itibaren iptal edebilir misiniz?"
            }
          ]
        }
      ]
    },
