    {
      "word": "ab und zu",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ab und zu",
      "topics": [
        "everyday-life",
        "social-and-relationships"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "fixed adverbial phrase meaning sometimes"
      ],
      "collocations": [
        {
          "text": "ab und zu kommen",
          "meaning": "to come now and then"
        },
        {
          "text": "ab und zu Kaffee trinken",
          "meaning": "to drink coffee sometimes"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أحياناً؛ من وقت لآخر"
        },
        {
          "language": "ckb",
          "text": "جاروبار؛ هەندێک جار"
        },
        {
          "language": "en",
          "text": "now and then; sometimes"
        },
        {
          "language": "fa",
          "text": "گاهی؛ هر از گاهی"
        },
        {
          "language": "kmr",
          "text": "carinan; car bi car"
        },
        {
          "language": "pl",
          "text": "od czasu do czasu; czasami"
        },
        {
          "language": "ro",
          "text": "din când în când; uneori"
        },
        {
          "language": "ru",
          "text": "время от времени; иногда"
        },
        {
          "language": "sq",
          "text": "herë pas here; nganjëherë"
        },
        {
          "language": "tr",
          "text": "ara sıra; bazen"
        }
      ],
      "examples": [
        {
          "baseText": "Ich trinke ab und zu Kaffee.",
          "translations": [
            {
              "language": "ar",
              "text": "أشرب القهوة أحياناً."
            },
            {
              "language": "ckb",
              "text": "من جاروبار قاوە دەخۆمەوە."
            },
            {
              "language": "en",
              "text": "I drink coffee now and then."
            },
            {
              "language": "fa",
              "text": "من گاهی قهوه می‌نوشم."
            },
            {
              "language": "kmr",
              "text": "Ez carinan qehwe vedixwim."
            },
            {
              "language": "pl",
              "text": "Od czasu do czasu piję kawę."
            },
            {
              "language": "ro",
              "text": "Beau cafea din când în când."
            },
            {
              "language": "ru",
              "text": "Я время от времени пью кофе."
            },
            {
              "language": "sq",
              "text": "Unë pi kafe herë pas here."
            },
            {
              "language": "tr",
              "text": "Ara sıra kahve içerim."
            }
          ]
        },
        {
          "baseText": "Ab und zu besucht sie ihre Eltern am Wochenende.",
          "translations": [
            {
              "language": "ar",
              "text": "تزور والديها أحياناً في عطلة نهاية الأسبوع."
            },
            {
              "language": "ckb",
              "text": "ئەو جاروبار لە کۆتایی هەفتە سەردانی دایک و باوکی دەکات."
            },
            {
              "language": "en",
              "text": "Now and then she visits her parents on the weekend."
            },
            {
              "language": "fa",
              "text": "او گاهی آخر هفته به دیدن پدر و مادرش می‌رود."
            },
            {
              "language": "kmr",
              "text": "Ew carinan dawiya hefteyê serdana dê û bavê xwe dike."
            },
            {
              "language": "pl",
              "text": "Od czasu do czasu odwiedza rodziców w weekend."
            },
            {
              "language": "ro",
              "text": "Din când în când își vizitează părinții în weekend."
            },
            {
              "language": "ru",
              "text": "Иногда она навещает родителей на выходных."
            },
            {
              "language": "sq",
              "text": "Herë pas here ajo viziton prindërit në fundjavë."
            },
            {
              "language": "tr",
              "text": "Ara sıra hafta sonu anne babasını ziyaret eder."
            }
          ]
        }
      ]
    },
