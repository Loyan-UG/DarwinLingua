      "meanings": [
        { "language": "ar", "text": "تحديد رقمياً؛ تقدير مبلغ" },
        { "language": "ckb", "text": "بە ژمارە دیاریکردن؛ خەملاندنی بڕ" },
        { "language": "en", "text": "to quantify; to state as an amount" },
        { "language": "fa", "text": "رقمی تعیین کردن؛ مبلغ را برآورد کردن" },
        { "language": "kmr", "text": "bi hejmar diyarkirin; nirxek gotin" },
        { "language": "pl", "text": "oszacować kwotowo; określić liczbowo" },
        { "language": "ro", "text": "a cuantifica; a exprima ca sumă" },
        { "language": "ru", "text": "оценивать в цифрах; указывать сумму" },
        { "language": "sq", "text": "të përcaktojë me shifra; të vlerësojë shumën" },
        { "language": "tr", "text": "rakamla belirtmek; tutarı belirlemek" }
      ],
      "examples": [
        {
          "baseText": "Der Schaden lässt sich erst beziffern, wenn alle Rechnungen vorliegen.",
          "translations": [
            { "language": "ar", "text": "لا يمكن تحديد قيمة الضرر إلا بعد توفر جميع الفواتير." },
            { "language": "ckb", "text": "زیانەکە تەنها کاتێک بە ژمارە دیاری دەکرێت کە هەموو پسوولەکان ئامادە بن." },
            { "language": "en", "text": "The damage can only be quantified once all invoices are available." },
            { "language": "fa", "text": "میزان خسارت فقط وقتی قابل برآورد است که همه فاکتورها موجود باشند." },
            { "language": "kmr", "text": "Ziyan tenê dema hemû faturayên amade bin dikare bi hejmar were diyarkirin." },
            { "language": "pl", "text": "Szkodę można oszacować dopiero wtedy, gdy dostępne są wszystkie faktury." },
            { "language": "ro", "text": "Dauna poate fi cuantificată abia după ce sunt disponibile toate facturile." },
            { "language": "ru", "text": "Ущерб можно оценить только после получения всех счетов." },
            { "language": "sq", "text": "Dëmi mund të përcaktohet me shifra vetëm pasi të jenë në dispozicion të gjitha faturat." },
            { "language": "tr", "text": "Zarar ancak tüm faturalar mevcut olduğunda rakamla belirlenebilir." }
          ]
        },
        {
          "baseText": "Im Quartalsbericht beziffern wir die Einsparung durch die neue Automatisierung auf 18 Prozent.",
          "translations": [
            { "language": "ar", "text": "في تقرير الربع نحدد التوفير الناتج عن الأتمتة الجديدة بنسبة 18 في المئة." },
            { "language": "ckb", "text": "لە ڕاپۆرتی چارەکدا پاشەکەوتی ئۆتۆماتیککردنی نوێ بە ١٨ لەسەد دیاری دەکەین." },
            { "language": "en", "text": "In the quarterly report, we quantify the savings from the new automation at 18 percent." },
            { "language": "fa", "text": "در گزارش فصلی، صرفه‌جویی ناشی از اتوماسیون جدید را ۱۸ درصد اعلام می‌کنیم." },
            { "language": "kmr", "text": "Di rapora çaryekê de em spartina ji otomatîkkirina nû bi 18 sedî diyarkirin." },
            { "language": "pl", "text": "W raporcie kwartalnym określamy oszczędność z nowej automatyzacji na 18 procent." },
            { "language": "ro", "text": "În raportul trimestrial cuantificăm economia adusă de noua automatizare la 18 procente." },
            { "language": "ru", "text": "В квартальном отчете мы оцениваем экономию от новой автоматизации в 18 процентов." },
            { "language": "sq", "text": "Në raportin tremujor e vlerësojmë kursimin nga automatizimi i ri në 18 për qind." },
            { "language": "tr", "text": "Çeyrek raporunda yeni otomasyondan gelen tasarrufu yüzde 18 olarak belirtiyoruz." }
          ]
        }
      ]
