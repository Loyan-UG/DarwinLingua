  "entries": [
    {
      "word": "die Kostenübernahme",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kostenübernahmen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kos-ten-über-nah-me",
      "topics": [
        "healthcare-and-appointments",
        "finance-and-accounting",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "medical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; approval that another party pays the costs"
      ],
      "collocations": [
        {
          "text": "eine Kostenübernahme beantragen",
          "meaning": "to apply for coverage of costs"
        },
        {
          "text": "die Kostenübernahme bestätigen",
          "meaning": "to confirm coverage of costs"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kosten",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "übernehmen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تحمّل التكاليف؛ تغطية التكاليف"
        },
        {
          "language": "ckb",
          "text": "وەرگرتنی تێچوو؛ داپۆشینی تێچوو"
        },
        {
          "language": "en",
          "text": "coverage of costs; assumption of costs"
        },
        {
          "language": "fa",
          "text": "پوشش هزینه؛ تقبل هزینه"
        },
        {
          "language": "kmr",
          "text": "girtina lêçûnan; dagirtina lêçûnan"
        },
        {
          "language": "pl",
          "text": "pokrycie kosztów; przejęcie kosztów"
        },
        {
          "language": "ro",
          "text": "preluarea costurilor; acoperirea costurilor"
        },
        {
          "language": "ru",
          "text": "покрытие расходов; принятие расходов"
        },
        {
          "language": "sq",
          "text": "mbulim i kostove; marrje përsipër e kostove"
        },
        {
          "language": "tr",
          "text": "masraf üstlenme; giderlerin karşılanması"
        }
      ],
      "examples": [
        {
          "baseText": "Vor der Behandlung müssen wir die Kostenübernahme der Krankenkasse abwarten.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل العلاج يجب أن ننتظر موافقة شركة التأمين الصحي على تحمّل التكاليف."
            },
            {
              "language": "ckb",
              "text": "پێش چارەسەرەکە دەبێت چاوەڕێی وەرگرتنی تێچوو لەلایەن بیمەی تەندروستی بکەین."
            },
            {
              "language": "en",
              "text": "Before the treatment, we have to wait for the health insurer to approve cost coverage."
            },
            {
              "language": "fa",
              "text": "قبل از درمان باید منتظر تأیید پوشش هزینه از طرف بیمه درمانی بمانیم."
            },
            {
              "language": "kmr",
              "text": "Berî dermankirinê divê em li benda pejirandina girtina lêçûnan ji aliyê sîgorteya tenduristiyê bin."
            },
            {
              "language": "pl",
              "text": "Przed leczeniem musimy poczekać na potwierdzenie pokrycia kosztów przez kasę chorych."
            },
            {
              "language": "ro",
              "text": "Înainte de tratament trebuie să așteptăm aprobarea acoperirii costurilor de către asigurarea medicală."
            },
            {
              "language": "ru",
              "text": "Перед лечением мы должны дождаться подтверждения покрытия расходов от медицинской страховки."
            },
            {
              "language": "sq",
              "text": "Para trajtimit duhet të presim miratimin e mbulimit të kostove nga sigurimi shëndetësor."
            },
            {
              "language": "tr",
              "text": "Tedaviden önce sağlık sigortasının masraf karşılamasını onaylamasını beklemeliyiz."
            }
          ]
        },
        {
          "baseText": "Der Kunde fragt, ob eine Kostenübernahme durch den Hersteller möglich ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يسأل العميل عما إذا كان من الممكن أن يتحمل المصنّع التكاليف."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە دەپرسێت ئایا وەرگرتنی تێچوو لەلایەن بەرهەمهێنەرەوە دەکرێت."
            },
            {
              "language": "en",
              "text": "The customer asks whether cost coverage by the manufacturer is possible."
            },
            {
              "language": "fa",
              "text": "مشتری می‌پرسد آیا پوشش هزینه توسط تولیدکننده ممکن است یا نه."
            },
            {
              "language": "kmr",
              "text": "Xerîdar dipirse gelo girtina lêçûnan ji aliyê hilberîner ve mimkun e."
            },
            {
              "language": "pl",
              "text": "Klient pyta, czy możliwe jest pokrycie kosztów przez producenta."
            },
            {
              "language": "ro",
              "text": "Clientul întreabă dacă este posibilă acoperirea costurilor de către producător."
            },
            {
              "language": "ru",
              "text": "Клиент спрашивает, возможно ли покрытие расходов производителем."
            },
            {
              "language": "sq",
              "text": "Klienti pyet nëse është i mundur mbulimi i kostove nga prodhuesi."
            },
            {
              "language": "tr",
              "text": "Müşteri, masrafların üretici tarafından karşılanıp karşılanamayacağını soruyor."
            }
          ]
        }
      ]
    },
    {
      "word": "der Kostenvoranschlag",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Kostenvoranschläge",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kos-ten-vor-an-schlag",
      "topics": [
        "shopping-and-services",
        "customer-service",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "formal",
        "business",
        "customer-facing"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; estimated cost quote before work starts"
      ],
      "collocations": [
        {
          "text": "einen Kostenvoranschlag erstellen",
          "meaning": "to prepare a cost estimate"
        },
        {
          "text": "einen Kostenvoranschlag anfordern",
          "meaning": "to request a cost estimate"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kosten",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "veranschlagen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تقدير تكلفة؛ عرض تكلفة مبدئي"
        },
        {
          "language": "ckb",
          "text": "پێشبینی تێچوو؛ خەملاندنی تێچوو"
        },
        {
          "language": "en",
          "text": "cost estimate; quotation"
        },
        {
          "language": "fa",
          "text": "برآورد هزینه؛ پیش‌فاکتور خدمات"
        },
        {
          "language": "kmr",
          "text": "texmîna lêçûnan; pêşniyara nirxê"
        },
        {
          "language": "pl",
          "text": "kosztorys; wycena"
        },
        {
          "language": "ro",
          "text": "deviz estimativ; estimare de cost"
        },
        {
          "language": "ru",
          "text": "смета; предварительная оценка стоимости"
        },
        {
          "language": "sq",
          "text": "parallogaritje kostoje; ofertë kostoje"
        },
        {
          "language": "tr",
          "text": "maliyet tahmini; fiyat teklifi"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schicken Sie uns vor der Reparatur einen Kostenvoranschlag.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال تقدير تكلفة إلينا قبل الإصلاح."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش چاککردنەوەکە پێشبینی تێچووێک بۆمان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us a cost estimate before the repair."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از تعمیر یک برآورد هزینه برای ما بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî tamîrê texmîneke lêçûnan ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać nam kosztorys przed naprawą."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți un deviz estimativ înainte de reparație."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам смету до ремонта."
            },
            {
              "language": "sq",
              "text": "Ju lutemi na dërgoni një parallogaritje kostoje para riparimit."
            },
            {
              "language": "tr",
              "text": "Lütfen tamirden önce bize bir maliyet tahmini gönderin."
            }
          ]
        },
        {
          "baseText": "Der Kostenvoranschlag für die neue Webseite liegt bei 3.000 Euro.",
          "translations": [
