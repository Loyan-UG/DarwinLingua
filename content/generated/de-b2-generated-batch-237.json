  "entries": [
    {
      "word": "totschlagen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "totschlagen",
      "pronunciationIpa": null,
      "syllableBreak": "tot-schla-gen",
      "topics": [
        "everyday-life",
        "business-communication",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "management",
        "customer-service"
      ],
      "grammarNotes": [
        "separable irregular verb: schlägt tot, schlug tot, hat totgeschlagen; often used figuratively in business contexts"
      ],
      "collocations": [
        {
          "text": "die Zeit totschlagen",
          "meaning": "to kill time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "tot",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "schlagen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقتل؛ يقتل الوقت"
        },
        {
          "language": "ckb",
          "text": "دەکوژێت؛ کات بەسەر دەبات"
        },
        {
          "language": "en",
          "text": "to kill; to kill time; to suppress a topic with empty phrases"
        },
        {
          "language": "fa",
          "text": "کشتن؛ وقت‌گذرانی کردن؛ با حرف‌های کلی موضوعی را خنثی کردن"
        },
        {
          "language": "kmr",
          "text": "kuştin; dem derbas kirin"
        },
        {
          "language": "pl",
          "text": "zabić; zabić czas"
        },
        {
          "language": "ro",
          "text": "a omorî; a omorî timpul"
        },
        {
          "language": "ru",
          "text": "убить; убить время"
        },
        {
          "language": "sq",
          "text": "të vrasësh; të kalosh kohën kot"
        },
        {
          "language": "tr",
          "text": "öldürmek; zaman öldürmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir mussten am Bahnhof fast eine Stunde totschlagen, weil der Zug Verspätung hatte.",
          "translations": [
            {
              "language": "ar",
              "text": "اضطررنا إلى قتل ما يقرب من ساعة في المحطة لأن القطار كان متأخرًا."
            },
            {
              "language": "ckb",
              "text": "لە وێستگەدا نزیکەی کاتژمێرێکمان بەسەر برد، چونکە شەمەندەفەرەکە دوا کەوتبوو."
            },
            {
              "language": "en",
              "text": "We had to kill almost an hour at the station because the train was delayed."
            },
            {
              "language": "fa",
              "text": "مجبور شدیم در ایستگاه تقریباً یک ساعت وقت بگذرانیم چون قطار تأخیر داشت."
            },
            {
              "language": "kmr",
              "text": "Li stasyona trênê me neçar bû nêzî saetek dem derbas bikin, ji ber ku trên dereng bû."
            },
            {
              "language": "pl",
              "text": "Musieliśmy zabić prawie godzinę na dworcu, bo pociąg był opóźniony."
            },
            {
              "language": "ro",
              "text": "A trebuit să omorâm aproape o oră în gară, deoarece trenul avea întârziere."
            },
            {
              "language": "ru",
              "text": "Нам пришлось убить почти час на вокзале, потому что поезд опаздывал."
            },
            {
              "language": "sq",
              "text": "Na u desh të kalonim gati një orë kot në stacion, sepse treni ishte me vonesë."
            },
            {
              "language": "tr",
              "text": "Tren geciktiği için istasyonda neredeyse bir saat zaman öldürmek zorunda kaldık."
            }
          ]
        },
        {
          "baseText": "Die Kritik der Kunden lässt sich nicht mit allgemeinen Antworten totschlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يمكن إسكات انتقادات العملاء بإجابات عامة."
            },
            {
              "language": "ckb",
              "text": "ڕەخنەی کڕیاران ناکرێت بە وەڵامی گشتی بێ کاریگەر بکرێت."
            },
            {
              "language": "en",
              "text": "The customers’ criticism cannot be brushed aside with generic answers."
            },
            {
              "language": "fa",
              "text": "نمی‌توان انتقاد مشتریان را با پاسخ‌های کلی خنثی کرد."
            },
            {
              "language": "kmr",
              "text": "Rexneyên xerîdaran bi bersivên giştî nayên bêbandor kirin."
            },
            {
              "language": "pl",
              "text": "Krytyki klientów nie da się zbyć ogólnymi odpowiedziami."
            },
            {
              "language": "ro",
              "text": "Critica clienților nu poate fi înlăturată cu răspunsuri generale."
            },
            {
              "language": "ru",
              "text": "Критику клиентов нельзя заглушить общими ответами."
            },
            {
              "language": "sq",
              "text": "Kritikat e klientëve nuk mund të shmangen me përgjigje të përgjithshme."
            },
            {
              "language": "tr",
              "text": "Müşterilerin eleştirileri genel cevaplarla geçiştirilemez."
            }
          ]
        }
      ]
    },
    {
      "word": "totschweigen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "totschweigen",
      "pronunciationIpa": null,
      "syllableBreak": "tot-schwei-gen",
      "topics": [
        "business-communication",
        "law-and-compliance",
        "management-and-leadership"
      ],
      "usageLabels": [
        "written",
        "business"
      ],
      "contextLabels": [
        "compliance",
        "management",
        "customer-service"
      ],
      "grammarNotes": [
        "separable verb: schweigt tot, schwieg tot, hat totgeschwiegen; means deliberately not discussing something"
      ],
      "collocations": [
        {
          "text": "ein Problem totschweigen",
          "meaning": "to keep silent about a problem until it is ignored"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schweigen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتجاهل بالصمت؛ يتعمد عدم ذكره"
        },
        {
          "language": "ckb",
          "text": "بە بێدەنگی پشتگوێی دەخات"
        },
        {
          "language": "en",
          "text": "to suppress by silence; to deliberately ignore"
        },
        {
          "language": "fa",
          "text": "با سکوت نادیده گرفتن؛ عمداً مطرح نکردن"
        },
        {
          "language": "kmr",
          "text": "bi bêdengiyê veşartin"
        },
        {
          "language": "pl",
          "text": "przemilczeć; celowo ignorować"
        },
        {
          "language": "ro",
          "text": "a trece sub tăcere"
        },
        {
          "language": "ru",
          "text": "замалчивать"
        },
        {
          "language": "sq",
          "text": "ta heshtësh qëllimisht"
        },
        {
          "language": "tr",
          "text": "sessiz kalarak görmezden gelmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Vorstand kann die Sicherheitsprobleme nicht länger totschweigen.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يعد بإمكان مجلس الإدارة تجاهل مشكلات الأمان بالصمت."
            },
            {
              "language": "ckb",
              "text": "دەستەی بەڕێوەبردن ناتوانێت چیتر کێشەکانی ئاسایش بە بێدەنگی پشتگوێ بخات."
            },
            {
              "language": "en",
              "text": "The board can no longer keep silent about the security issues."
            },
            {
              "language": "fa",
              "text": "هیئت‌مدیره دیگر نمی‌تواند مشکلات امنیتی را با سکوت نادیده بگیرد."
            },
            {
              "language": "kmr",
              "text": "Desteya rêveberiyê êdî nikare pirsgirêkên ewlehiyê bi bêdengiyê veşêre."
            },
            {
              "language": "pl",
              "text": "Zarząd nie może dłużej przemilczać problemów z bezpieczeństwem."
            },
            {
              "language": "ro",
              "text": "Consiliul de conducere nu mai poate trece sub tăcere problemele de securitate."
            },
            {
              "language": "ru",
              "text": "Правление больше не может замалчивать проблемы безопасности."
            },
            {
              "language": "sq",
              "text": "Bordi nuk mund t’i heshtë më gjatë problemet e sigurisë."
            },
            {
              "language": "tr",
              "text": "Yönetim kurulu güvenlik sorunlarını artık sessizce geçiştiremez."
            }
          ]
        },
        {
          "baseText": "Viele Kunden hatten das Gefühl, dass ihre Beschwerden wochenlang totgeschwiegen wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "شعر كثير من العملاء بأن شكاواهم تم تجاهلها بالصمت لأسابيع."
            },
            {
              "language": "ckb",
              "text": "زۆر کڕیار هەستیان کرد کە سکاڵاکانیان بۆ چەند هەفتە بە بێدەنگی پشتگوێ خراون."
            },
            {
              "language": "en",
              "text": "Many customers felt that their complaints had been ignored for weeks."
            },
            {
              "language": "fa",
              "text": "بسیاری از مشتریان احساس کردند شکایت‌هایشان هفته‌ها با سکوت نادیده گرفته شده است."
            },
            {
              "language": "kmr",
              "text": "Gelek xerîdar hîs kirin ku gilîyên wan bi hefteyan hatine bêdeng kirin."
            },
            {
              "language": "pl",
              "text": "Wielu klientów miało poczucie, że ich reklamacje przez tygodnie były przemilczane."
            },
            {
              "language": "ro",
              "text": "Mulți clienți au simțit că reclamațiile lor au fost trecute sub tăcere săptămâni întregi."
            },
            {
              "language": "ru",
              "text": "Многие клиенты чувствовали, что их жалобы неделями замалчивали."
            },
            {
              "language": "sq",
              "text": "Shumë klientë patën ndjesinë se ankesat e tyre u heshtën për javë të tëra."
            },
            {
              "language": "tr",
