          "translations": [
            {
              "language": "ar",
              "text": "عندما يكون النظام بطيئًا، يصل كثير من المستخدمين في الوقت نفسه إلى قاعدة البيانات نفسها."
            },
            {
              "language": "ckb",
              "text": "کاتێک سیستەمەکە خاوە، زۆر بەکارهێنەر بە هاوکات دەست دەگەن بە هەمان داتابەیس."
            },
            {
