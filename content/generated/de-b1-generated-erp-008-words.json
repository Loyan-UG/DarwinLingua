      "examples": [
        {
          "baseText": "Der Tourplan ist im ERP-System für alle Fahrer sichtbar.",
          "translations": [
            {
              "language": "ar",
              "text": "خطة المسار ظاهرة في نظام تخطيط موارد المؤسسة لكل السائقين."
            },
            {
              "language": "ckb",
              "text": "پلانی گەشت لە سیستەمی ERPدا بۆ هەموو شۆفێرەکان دیارە."
            },
            {
              "language": "en",
              "text": "The route plan is visible to all drivers in the ERP system."
            },
            {
              "language": "fa",
              "text": "برنامه مسیر در سیستم ERP برای همه رانندگان قابل مشاهده است."
            },
