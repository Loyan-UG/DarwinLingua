      "word": "die Suchkennung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Suchkennungen",
      "infinitive": null,
      "syllableBreak": "Such-ken-nung",
      "topics": [
        "erp-and-business-systems",
        "data-and-reporting",
        "technology-and-it"
      ],
      "usageLabels": [
        "business",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Suchkennung eingeben",
          "meaning": "to enter a search key"
        },
        {
          "text": "nach Suchkennung suchen",
          "meaning": "to search by search key"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "suchen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Kennung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "معرّف بحث"
        },
        {
          "language": "ckb",
          "text": "ناسنامەی گەڕان"
        },
        {
          "language": "en",
          "text": "search key; search identifier"
        },
        {
          "language": "fa",
          "text": "شناسه جستجو"
        },
        {
          "language": "kmr",
          "text": "nasnameya lêgerînê"
        },
        {
          "language": "pl",
          "text": "identyfikator wyszukiwania"
        },
        {
          "language": "ro",
          "text": "identificator de căutare"
        },
        {
          "language": "ru",
          "text": "поисковый идентификатор"
        },
        {
          "language": "sq",
          "text": "identifikues kërkimi"
        },
        {
          "language": "tr",
          "text": "arama kodu"
        }
      ],
      "examples": [
        {
          "baseText": "Geben Sie die Suchkennung im ERP-System ein, um den Artikel zu finden.",
          "translations": [
            {
              "language": "ar",
              "text": "أدخل معرّف البحث في نظام تخطيط موارد المؤسسة للعثور على الصنف."
            },
            {
              "language": "ckb",
              "text": "ناسنامەی گەڕان لە سیستەمی ERPدا بنووسە بۆ دۆزینەوەی کاڵاکە."
            },
            {
              "language": "en",
              "text": "Enter the search key in the ERP system to find the item."
            },
            {
              "language": "fa",
              "text": "برای پیدا کردن کالا، شناسه جستجو را در سیستم ERP وارد کنید."
            },
            {
              "language": "kmr",
              "text": "Ji bo dîtina tiştê, nasnameya lêgerînê di pergala ERP de binivîse."
            },
            {
              "language": "pl",
              "text": "Wprowadź identyfikator wyszukiwania w systemie ERP, aby znaleźć artykuł."
            },
            {
              "language": "ro",
              "text": "Introduceți identificatorul de căutare în sistemul ERP pentru a găsi articolul."
            },
            {
              "language": "ru",
              "text": "Введите поисковый идентификатор в ERP-системе, чтобы найти товар."
            },
            {
              "language": "sq",
              "text": "Shkruani identifikuesin e kërkimit në sistemin ERP për të gjetur artikullin."
            },
            {
              "language": "tr",
              "text": "Ürünü bulmak için ERP sistemine arama kodunu girin."
            }
          ]
        },
        {
          "baseText": "Ich kenne die Kundennummer nicht, aber ich habe die Suchkennung.",
          "translations": [
            {
              "language": "ar",
              "text": "لا أعرف رقم العميل، لكن لدي معرّف البحث."
            },
            {
              "language": "ckb",
              "text": "ژمارەی کڕیارەکە نازانم، بەڵام ناسنامەی گەڕانم هەیە."
            },
            {
              "language": "en",
              "text": "I do not know the customer number, but I have the search key."
            },
            {
              "language": "fa",
              "text": "شماره مشتری را نمی‌دانم، اما شناسه جستجو را دارم."
            },
            {
              "language": "kmr",
              "text": "Ez jimareya xerîdar nizanim, lê nasnameya lêgerînê heye."
            },
            {
              "language": "pl",
              "text": "Nie znam numeru klienta, ale mam identyfikator wyszukiwania."
            },
            {
              "language": "ro",
              "text": "Nu cunosc numărul clientului, dar am identificatorul de căutare."
            },
            {
              "language": "ru",
              "text": "Я не знаю номер клиента, но у меня есть поисковый идентификатор."
            },
            {
              "language": "sq",
              "text": "Nuk e di numrin e klientit, por kam identifikuesin e kërkimit."
            },
            {
              "language": "tr",
              "text": "Müşteri numarasını bilmiyorum ama arama kodu bende var."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Tätigkeit",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Tätigkeiten",
      "infinitive": null,
      "syllableBreak": "Tä-tig-keit",
      "topics": [
        "work-and-jobs",
        "documents-and-administration",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "workplace"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Tätigkeit erfassen",
          "meaning": "to record an activity"
        },
        {
          "text": "berufliche Tätigkeit",
          "meaning": "professional activity"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "tätig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "نشاط؛ عمل"
        },
        {
          "language": "ckb",
          "text": "چالاکی؛ کار"
        },
        {
          "language": "en",
          "text": "activity; work"
        },
        {
          "language": "fa",
          "text": "فعالیت؛ کار"
        },
        {
          "language": "kmr",
          "text": "çalakî; kar"
        },
        {
          "language": "pl",
          "text": "czynność; działalność"
        },
        {
          "language": "ro",
          "text": "activitate"
        },
        {
          "language": "ru",
          "text": "деятельность; работа"
        },
        {
          "language": "sq",
          "text": "aktivitet; punë"
        },
        {
          "language": "tr",
          "text": "faaliyet; iş"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte erfassen Sie jede Tätigkeit im ERP-System unter dem richtigen Projekt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تسجيل كل نشاط في نظام تخطيط موارد المؤسسة تحت المشروع الصحيح."
            },
            {
              "language": "ckb",
              "text": "تکایە هەر چالاکییەک لە سیستەمی ERPدا لە ژێر پڕۆژەی دروست تۆمار بکەن."
            },
            {
              "language": "en",
              "text": "Please record each activity in the ERP system under the correct project."
            },
            {
              "language": "fa",
              "text": "لطفاً هر فعالیت را در سیستم ERP زیر پروژه درست ثبت کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe her çalakiyekê di pergala ERP de li bin projeya rast tomar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę rejestrować każdą czynność w systemie ERP pod właściwym projektem."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să înregistrați fiecare activitate în sistemul ERP la proiectul corect."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, заносите каждую деятельность в ERP-систему под правильным проектом."
            },
            {
              "language": "sq",
              "text": "Ju lutemi regjistroni çdo aktivitet në sistemin ERP nën projektin e duhur."
            },
            {
              "language": "tr",
              "text": "Lütfen her faaliyeti ERP sisteminde doğru proje altında kaydedin."
            }
          ]
        },
        {
          "baseText": "Meine neue Tätigkeit beginnt nächsten Monat.",
          "translations": [
            {
              "language": "ar",
              "text": "نشاطي/عملي الجديد يبدأ الشهر القادم."
            },
            {
              "language": "ckb",
              "text": "کاری نوێم مانگی داهاتوو دەست پێدەکات."
            },
            {
              "language": "en",
              "text": "My new job starts next month."
            },
            {
              "language": "fa",
              "text": "کار جدید من ماه آینده شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kara min a nû meha bê dest pê dike."
            },
            {
              "language": "pl",
              "text": "Moja nowa praca zaczyna się w przyszłym miesiącu."
            },
            {
              "language": "ro",
              "text": "Noua mea activitate începe luna viitoare."
            },
            {
              "language": "ru",
              "text": "Моя новая работа начинается в следующем месяце."
            },
            {
              "language": "sq",
              "text": "Puna ime e re fillon muajin tjetër."
            },
            {
              "language": "tr",
              "text": "Yeni işim gelecek ay başlıyor."
            }
          ]
        }
      ]
    },
