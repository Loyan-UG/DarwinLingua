        },
        {
          "text": "auf Tour gehen",
          "meaning": "to go on a route/tour"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جولة؛ مسار توصيل"
        },
        {
          "language": "ckb",
          "text": "گەشت؛ ڕێڕەوی گەیاندن"
        },
        {
          "language": "en",
          "text": "tour; delivery route"
        },
        {
          "language": "fa",
          "text": "مسیر؛ تور تحویل"
        },
        {
          "language": "kmr",
          "text": "rêwîtiya radestkirinê; ger"
        },
        {
          "language": "pl",
          "text": "trasa; kurs"
        },
        {
          "language": "ro",
          "text": "tură; rută de livrare"
        },
        {
          "language": "ru",
          "text": "маршрут; рейс"
        },
        {
          "language": "sq",
          "text": "tur; rrugë shpërndarjeje"
        },
        {
          "language": "tr",
          "text": "tur; teslimat rotası"
        }
      ],
      "examples": [
        {
          "baseText": "Die Tour für den Fahrer wurde im ERP-System neu geplant.",
          "translations": [
            {
              "language": "ar",
              "text": "تمت إعادة تخطيط جولة السائق في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "گەشتی شۆفێرەکە لە سیستەمی ERPدا دووبارە پلاندانرا."
            },
            {
              "language": "en",
              "text": "The route for the driver was replanned in the ERP system."
            },
            {
              "language": "fa",
              "text": "مسیر راننده در سیستم ERP دوباره برنامه‌ریزی شد."
            },
            {
              "language": "kmr",
              "text": "Rêya ajokar di pergala ERP de ji nû ve hate plansazkirin."
            },
            {
              "language": "pl",
              "text": "Trasa kierowcy została ponownie zaplanowana w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Ruta șoferului a fost replanificată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Маршрут водителя был заново спланирован в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Rruga e shoferit u planifikua përsëri në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Şoförün rotası ERP sisteminde yeniden planlandı."
            }
          ]
        },
        {
          "baseText": "Morgen macht unser Team eine Tour durch die Stadt.",
          "translations": [
            {
              "language": "ar",
              "text": "غدًا يقوم فريقنا بجولة في المدينة."
            },
            {
              "language": "ckb",
              "text": "سبەی تیمەکەمان گەشتێک بە ناو شاردا دەکات."
            },
            {
              "language": "en",
              "text": "Tomorrow our team is taking a tour through the city."
            },
            {
              "language": "fa",
              "text": "فردا تیم ما یک تور در شهر دارد."
            },
            {
              "language": "kmr",
              "text": "Sibê tîma me di nav bajêr de gereke dike."
            },
            {
              "language": "pl",
              "text": "Jutro nasz zespół robi wycieczkę po mieście."
            },
            {
              "language": "ro",
              "text": "Mâine echipa noastră face un tur prin oraș."
            },
            {
              "language": "ru",
              "text": "Завтра наша команда совершит тур по городу."
            },
            {
              "language": "sq",
              "text": "Nesër ekipi ynë bën një tur nëpër qytet."
            },
            {
              "language": "tr",
              "text": "Yarın ekibimiz şehirde bir tur yapıyor."
            }
          ]
        }
      ]
    },
