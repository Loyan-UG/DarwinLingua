            },
            {
              "language": "ckb",
              "text": "من حەزم لە چا خواردنەوەیە."
            },
            {
              "language": "en",
              "text": "I like drinking tea."
            },
            {
              "language": "fa",
              "text": "من چای نوشیدن را دوست دارم."
