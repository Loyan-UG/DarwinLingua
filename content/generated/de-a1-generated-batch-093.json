      "examples": [
        {
          "baseText": "Ich rufe ein Taxi.",
          "translations": [
            {
              "language": "ar",
              "text": "سأتصل بسيارة أجرة."
            },
            {
              "language": "ckb",
              "text": "من تەکسییەک بانگ دەکەم."
            },
            {
              "language": "en",
              "text": "I am calling a taxi."
            },
            {
              "language": "fa",
              "text": "من یک تاکسی می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez taksiyekê bang dikim."
            },
            {
              "language": "pl",
              "text": "Dzwonię po taksówkę."
            },
            {
              "language": "ro",
              "text": "Chem un taxi."
            },
            {
              "language": "ru",
              "text": "Я вызываю такси."
            },
            {
              "language": "sq",
              "text": "Po thërras një taksi."
            },
            {
              "language": "tr",
              "text": "Taksi çağırıyorum."
            }
          ]
        },
        {
          "baseText": "Das Taxi steht vor dem Hotel.",
          "translations": [
            {
              "language": "ar",
              "text": "سيارة الأجرة أمام الفندق."
            },
            {
              "language": "ckb",
              "text": "تەکسییەکە لە پێش هۆتێلەکەیە."
            },
            {
              "language": "en",
              "text": "The taxi is in front of the hotel."
            },
            {
              "language": "fa",
              "text": "تاکسی جلوی هتل است."
            },
            {
              "language": "kmr",
              "text": "Taksî li ber otêlê ye."
            },
            {
              "language": "pl",
              "text": "Taksówka stoi przed hotelem."
            },
            {
              "language": "ro",
              "text": "Taxiul este în fața hotelului."
            },
            {
              "language": "ru",
              "text": "Такси стоит перед отелем."
            },
            {
              "language": "sq",
              "text": "Taksia është para hotelit."
            },
            {
              "language": "tr",
              "text": "Taksi otelin önünde."
