        {
          "language": "tr",
          "text": "telefonla konuşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich telefoniere mit meiner Mutter.",
          "translations": [
            {
              "language": "ar",
              "text": "أتحدث بالهاتف مع أمي."
            },
            {
              "language": "ckb",
              "text": "لەگەڵ دایکم تەلەفۆن دەکەم."
            },
            {
              "language": "en",
              "text": "I am talking on the phone with my mother."
            },
            {
              "language": "fa",
              "text": "من با مادرم تلفنی صحبت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez bi dayika xwe re telefon dikim."
            },
            {
              "language": "pl",
              "text": "Rozmawiam przez telefon z mamą."
            },
            {
              "language": "ro",
              "text": "Vorbesc la telefon cu mama mea."
            },
            {
              "language": "ru",
              "text": "Я разговариваю по телефону с мамой."
            },
            {
              "language": "sq",
              "text": "Po flas në telefon me nënën time."
            },
            {
              "language": "tr",
              "text": "Annemle telefonda konuşuyorum."
            }
          ]
        },
        {
          "baseText": "Wir telefonieren morgen mit dem Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "سنتحدث غدًا بالهاتف مع العميل."
            },
            {
              "language": "ckb",
              "text": "سبەی لەگەڵ کڕیارەکە تەلەفۆن دەکەین."
            },
            {
              "language": "en",
              "text": "We will call the customer tomorrow."
            },
            {
              "language": "fa",
              "text": "ما فردا با مشتری تلفنی صحبت می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em sibê bi xerîdar re telefon dikin."
            },
            {
              "language": "pl",
              "text": "Jutro rozmawiamy telefonicznie z klientem."
            },
            {
              "language": "ro",
              "text": "Mâine vorbim la telefon cu clientul."
            },
            {
              "language": "ru",
              "text": "Завтра мы поговорим с клиентом по телефону."
            },
            {
              "language": "sq",
              "text": "Nesër flasim në telefon me klientin."
            },
            {
              "language": "tr",
              "text": "Yarın müşteriyle telefonda konuşacağız."
