            },
            {
              "language": "en",
              "text": "Would you like tea or coffee?"
            },
            {
              "language": "fa",
              "text": "چای می‌خواهید یا قهوه؟"
            },
            {
              "language": "kmr",
              "text": "Hûn çay dixwazin an qehwe?"
            },
            {
              "language": "pl",
              "text": "Chce pan/pani herbatę czy kawę?"
            },
            {
              "language": "ro",
              "text": "Doriți ceai sau cafea?"
            },
            {
              "language": "ru",
              "text": "Вы хотите чай или кофе?"
