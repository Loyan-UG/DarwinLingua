            },
            {
              "language": "ru",
              "text": "Я пью кофе без сахара."
            },
            {
              "language": "sq",
              "text": "Unë pi kafe pa sheqer."
            },
            {
              "language": "tr",
              "text": "Kahveyi şekersiz içerim."
            }
          ]
        },
        {
          "baseText": "Bitte ohne Milch.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك بدون حليب."
            },
            {
              "language": "ckb",
              "text": "تکایە بێ شیر."
            },
            {
              "language": "en",
              "text": "Without milk, please."
            },
            {
              "language": "fa",
              "text": "لطفاً بدون شیر."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe bê şîr."
            },
            {
              "language": "pl",
              "text": "Proszę bez mleka."
            },
            {
              "language": "ro",
              "text": "Fără lapte, vă rog."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, без молока."
            },
            {
              "language": "sq",
              "text": "Pa qumësht, ju lutem."
