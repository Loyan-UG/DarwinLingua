      "examples": [
        {
          "baseText": "Ich trinke Kaffee ohne Zucker.",
          "translations": [
            {
              "language": "ar",
              "text": "أشرب القهوة بدون سكر."
            },
            {
              "language": "ckb",
              "text": "من قاوە بێ شەکر دەخۆمەوە."
            },
            {
              "language": "en",
              "text": "I drink coffee without sugar."
            },
            {
              "language": "fa",
              "text": "من قهوه را بدون شکر می‌نوشم."
            },
            {
              "language": "kmr",
              "text": "Ez qehweyê bê şekir vedixwim."
            },
            {
              "language": "pl",
