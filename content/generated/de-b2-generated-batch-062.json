  "entries": [
    {
      "word": "die Behandlungsqualität",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "die Behandlungsqualitäten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-han-tlungs-qual-ität",
      "topics": [
        "quality-and-risk",
        "healthcare-and-appointments",
        "documents-and-administration"
      ],
      "usageLabels": [
        "written",
        "workplace",
        "business"
      ],
      "contextLabels": [
        "documents"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "جودة العلاج"
        },
        {
          "language": "ckb",
          "text": "جۆرەتی چارەسەری"
        },
        {
          "language": "en",
          "text": "quality of treatment"
        },
        {
          "language": "fa",
          "text": "کیفیت درمان"
        },
        {
          "language": "kmr",
          "text": "kalîteya çêkirinê"
        },
        {
          "language": "pl",
          "text": "jakość opieki"
        },
        {
          "language": "ro",
          "text": "calitatea tratamentului"
        },
        {
          "language": "ru",
          "text": "качество лечения"
        },
        {
          "language": "sq",
          "text": "cilësia e trajtimit"
        },
        {
          "language": "tr",
          "text": "tedavi kalitesi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Behandlungsqualität wurde im Team aus Auswertungen und Feedback der Kunden gemessen.",
          "translations": [
            {
              "language": "ar",
              "text": "کیفیت درمان از طریق تحلیل و بازخورد مشتریان در تیم اندازه‌گیری شد."
            },
            {
              "language": "ckb",
              "text": "جۆرەتی چارەسەری لەلایەن ڕاپۆرت و فیدبەکی کڕیارەکان لە تیمەوە پەیمانگکرا."
            },
            {
              "language": "en",
              "text": "Treatment quality was measured by team analysis and customer feedback."
            },
            {
              "language": "fa",
              "text": "کیفیت درمان با تحلیل تیم و بازخورد مشتریان سنجیده شد."
            },
            {
              "language": "kmr",
              "text": "Kalîteya çêkirinê bi analîza tîmê û feedbackê xerîdaran pîvan kirin."
            },
            {
              "language": "pl",
              "text": "Jakość obsługi została zmierzona przez analizę zespołu i opinie klientów."
            },
            {
              "language": "ro",
              "text": "Calitatea tratamentului a fost măsurată prin analiza echipei și feedback-ul clienților."
            },
            {
              "language": "ru",
              "text": "Качество обработки оценили по анализу команды и отзывам клиентов."
            },
            {
              "language": "sq",
              "text": "Cilësia e trajtimit u mat nga analiza e ekipit dhe reagimet e klientëve."
            },
            {
              "language": "tr",
              "text": "Tedavi kalitesi, ekip analizi ve müşteri geri bildirimiyle ölçüldü."
            }
          ]
        },
        {
          "baseText": "In den monatlichen Berichten verfolgen wir die Behandlungsqualität je Bereich.",
          "translations": [
            {
              "language": "ar",
              "text": "در گزارش‌های ماهانه کیفیت درمان را برای هر بخش پیگیری می‌کنیم."
            },
            {
              "language": "ckb",
              "text": "لە ڕاپۆرتە مانگانەکانەوە گۆڕانکاری جۆرەتی چارەسەری لە هەموو بەشەکاندا چاودێریکردوە."
            },
            {
              "language": "en",
              "text": "In monthly reports we track treatment quality per department."
            },
            {
              "language": "fa",
              "text": "در گزارش‌های ماهانه، کیفیت درمان را در هر بخش پیگیری می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di raporên mehane de em kalîteya çêkirinê li gorî beşan şop dikin."
            },
            {
              "language": "pl",
              "text": "W raportach miesięcznych monitorujemy jakość opieki w każdym dziale."
            },
            {
              "language": "ro",
              "text": "În rapoartele lunare urmărim calitatea tratamentului pe fiecare departament."
            },
            {
              "language": "ru",
              "text": "В месячных отчетах мы отслеживаем качество обслуживания по каждому отделу."
            },
            {
              "language": "sq",
              "text": "Në raportet mujore ndjekim cilësinë e trajtimit për çdo departament."
            },
            {
              "language": "tr",
              "text": "Aylık raporlarda birim bazında tedavi kalitesini takip ediyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "beheben",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beheben",
      "pronunciationIpa": null,
      "syllableBreak": "be-he-ben",
      "topics": [
        "support-and-resolution",
        "it",
        "work-and-jobs"
      ],
      "usageLabels": [
        "workplace",
        "written",
        "formal"
      ],
      "contextLabels": [
        "it"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "حل/رفع"
        },
        {
          "language": "ckb",
          "text": "چارەسەرکردن"
        },
        {
          "language": "en",
          "text": "to fix; to resolve"
        },
        {
          "language": "fa",
          "text": "رفع کردن"
        },
        {
          "language": "kmr",
          "text": "rastkirin"
        },
        {
          "language": "pl",
          "text": "naprawić"
        },
        {
          "language": "ro",
          "text": "a remedia"
        },
        {
          "language": "ru",
          "text": "исправить; устранить"
        },
        {
          "language": "sq",
          "text": "zgjidh"
        },
        {
          "language": "tr",
          "text": "gidermek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir beheben den kritischen Bug im Datenimport direkt im nächsten Sprint.",
          "translations": [
            {
              "language": "ar",
              "text": "باگ بحرانی واردات داده را در اسپرینت بعدی به‌طور مستقیم رفع می‌کنیم."
            },
            {
              "language": "ckb",
              "text": "هەڵەی گرنگ لە هاوردنی زانیاریەکان لە سپڕینتی دواتر ڕاستدەکەین."
            },
            {
              "language": "en",
              "text": "We will fix the critical data import bug in the next sprint."
            },
            {
              "language": "fa",
              "text": "باگ بحرانی واردسازی داده را در اسپرینت بعدی رفع می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em çewtiya giran a importê ya daneyan di sprinta paş de rast dikin."
            },
            {
              "language": "pl",
              "text": "Usuniemy krytyczny błąd importu danych w następnym sprincie."
            },
            {
              "language": "ro",
              "text": "Vom remedia bugul critic din importul de date în sprintul următor."
            },
            {
              "language": "ru",
              "text": "Критический баг импорта данных мы исправим в следующем спринте."
            },
            {
              "language": "sq",
              "text": "Ne do ta rregullojmë gabimin kritik në importin e të dhënave në sprintin e ardhshëm."
            },
            {
              "language": "tr",
              "text": "Kritik veri aktarımdaki hatayı bir sonraki sprintte düzelteceğiz."
            }
          ]
        },
        {
          "baseText": "Der Incident wurde im Ticketsystem dokumentiert und bis morgen behoben.",
          "translations": [
            {
              "language": "ar",
              "text": "حادث ثبت شد و تا فردا حل خواهد شد."
            },
            {
              "language": "ckb",
              "text": "ڕووداوەکە لە سیستەمی تیکت تۆمارکرا و تا سبەیانە چارەسەر دەکرێت."
            },
            {
              "language": "en",
              "text": "The incident was logged in the ticket system and will be fixed by tomorrow."
            },
            {
              "language": "fa",
              "text": "این رخداد در سیستم تیکت ثبت شد و تا فردا رفع خواهد شد."
            },
            {
              "language": "kmr",
              "text": "Rebaza çewtiyê di pergala tiketê da tomarkir û heta sibê rast bê."
            },
            {
              "language": "pl",
              "text": "Incydent został odnotowany w systemie ticketów i zostanie naprawiony do jutra."
            },
            {
              "language": "ro",
              "text": "Incidentul a fost înregistrat în sistemul de tichete și va fi remediat până mâine."
            },
            {
              "language": "ru",
              "text": "Инцидент был зарегистрирован в тикет-системе и будет устранен к завтрашнему дню."
            },
            {
              "language": "sq",
              "text": "Incidenti u regjistrua në sistemin e tiketave dhe do të zgjidhet deri nesër."
            },
            {
              "language": "tr",
              "text": "Olay bilet sistemine kaydedildi ve yarına kadar giderilecek."
            }
          ]
        }
      ]
    },
    {
      "word": "beibehalten",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beibehalten",
      "pronunciationIpa": null,
      "syllableBreak": "be-ibe-hal-ten",
      "topics": [
        "management-and-leadership",
        "work-and-jobs",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "documents"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "حفظ/ادامه دادن"
        },
        {
          "language": "ckb",
          "text": "پاراستن"
        },
        {
          "language": "en",
          "text": "to maintain"
        },
        {
          "language": "fa",
          "text": "حفظ کردن"
        },
        {
          "language": "kmr",
          "text": "bihêle bûn"
        },
        {
          "language": "pl",
          "text": "utrzymywać"
        },
        {
          "language": "ro",
          "text": "a menține"
        },
        {
          "language": "ru",
          "text": "сохранять"
        },
        {
          "language": "sq",
          "text": "të mbash"
        },
        {
          "language": "tr",
          "text": "korumak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir beibehalten die aktuelle Architektur, bis die neue Lösung getestet ist.",
          "translations": [
            {
              "language": "ar",
              "text": "تا زمانی که راه‌حل جدید تست شود، معماری فعلی حفظ می‌شود."
            },
            {
              "language": "ckb",
              "text": "تا کە چارەکارێکی نوێ پشکنین بکەین، بناغەی ئێستا پاراستووە."
            },
            {
              "language": "en",
              "text": "We keep the current architecture until the new solution is tested."
            },
            {
              "language": "fa",
              "text": "تا زمانی که راه‌حل جدید تست شود، معماری فعلی را حفظ می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em avabûna heyvê dixwazin heta ku çareya nû tê testkirin bihêlan."
            },
            {
              "language": "pl",
              "text": "Utrzymujemy obecną architekturę, dopóki nowa wersja nie zostanie przetestowana."
            },
            {
              "language": "ro",
              "text": "Menținem arhitectura actuală până când noua soluție este testată."
            },
            {
              "language": "ru",
              "text": "Мы сохраняем текущую архитектуру, пока новая схема не будет протестирована."
            },
            {
              "language": "sq",
              "text": "E mbajmë arkitekturën aktuale derisa zgjidhja e re të testohet."
            },
            {
              "language": "tr",
              "text": "Yeni çözüm test edilene kadar mevcut mimariyi koruyacağız."
            }
          ]
        },
        {
          "baseText": "Bitte beibehalten Sie die alte Regel für bestehende Kunden bis Ende des Quartals.",
          "translations": [
            {
              "language": "ar",
              "text": "لطفا تا پایان فصل قاعده قدیمی را برای مشتریان فعلی حفظ کنید."
            },
            {
              "language": "ckb",
