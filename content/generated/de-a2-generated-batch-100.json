      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable regular verb: tauscht um, hat umgetauscht"
      ],
      "collocations": [
        {
          "text": "einen Artikel umtauschen",
          "meaning": "to exchange an item"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Umtausch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يستبدل؛ يبدّل"
        },
        {
          "language": "ckb",
          "text": "دەگۆڕێتەوە"
        },
        {
          "language": "en",
          "text": "to exchange; to return for another item"
        },
        {
          "language": "fa",
          "text": "تعویض کردن"
        },
        {
          "language": "kmr",
          "text": "guhertin; veguhertin"
        },
        {
          "language": "pl",
          "text": "wymieniać"
        },
        {
          "language": "ro",
          "text": "a schimba"
        },
        {
          "language": "ru",
          "text": "обменивать"
        },
        {
          "language": "sq",
          "text": "të ndërrosh"
        },
        {
          "language": "tr",
          "text": "değiştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Kann ich diese Jacke umtauschen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني استبدال هذه السترة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم ئەم چاکەتە بگۆڕمەوە؟"
            },
            {
              "language": "en",
              "text": "Can I exchange this jacket?"
            },
            {
              "language": "fa",
              "text": "می‌توانم این کاپشن را تعویض کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim vê çaketê biguherînim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę wymienić tę kurtkę?"
            },
            {
              "language": "ro",
              "text": "Pot schimba această jachetă?"
            },
            {
              "language": "ru",
              "text": "Могу я обменять эту куртку?"
            },
            {
              "language": "sq",
              "text": "A mund ta ndërroj këtë xhaketë?"
            },
            {
              "language": "tr",
              "text": "Bu ceketi değiştirebilir miyim?"
            }
          ]
        },
        {
          "baseText": "Sie können die Schuhe innerhalb von 14 Tagen umtauschen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم استبدال الحذاء خلال 14 يوماً."
            },
            {
              "language": "ckb",
              "text": "دەتوانن پێڵاوەکان لە ماوەی ١٤ ڕۆژدا بگۆڕنەوە."
            },
            {
              "language": "en",
              "text": "You can exchange the shoes within 14 days."
            },
            {
              "language": "fa",
              "text": "می‌توانید کفش‌ها را ظرف ۱۴ روز تعویض کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin pêlavan di nav 14 rojan de biguherînin."
            },
            {
              "language": "pl",
              "text": "Mogą państwo wymienić buty w ciągu 14 dni."
            },
            {
              "language": "ro",
              "text": "Puteți schimba pantofii în termen de 14 zile."
            },
            {
              "language": "ru",
              "text": "Вы можете обменять обувь в течение 14 дней."
            },
            {
              "language": "sq",
              "text": "Mund t’i ndërroni këpucët brenda 14 ditëve."
            },
            {
              "language": "tr",
              "text": "Ayakkabıları 14 gün içinde değiştirebilirsiniz."
            }
          ]
        }
      ]
    },
    {
      "word": "umziehen",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "umziehen",
      "pronunciationIpa": null,
      "syllableBreak": "um-zie-hen",
      "topics": [
        "housing-and-real-estate",
        "everyday-life",
        "work-and-jobs"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable irregular verb: zieht um, zog um, ist umgezogen; can also mean to change clothes"
      ],
      "collocations": [
        {
          "text": "in eine neue Wohnung umziehen",
          "meaning": "to move to a new apartment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Umzug",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينتقل إلى سكن جديد؛ يغيّر ملابسه"
        },
        {
          "language": "ckb",
          "text": "دەگوازرێتەوە؛ جل دەگۆڕێت"
        },
        {
          "language": "en",
          "text": "to move house; to change clothes"
        },
        {
          "language": "fa",
          "text": "اسباب‌کشی کردن؛ لباس عوض کردن"
        },
        {
          "language": "kmr",
          "text": "bar kirin; cil guhertin"
        },
        {
          "language": "pl",
          "text": "przeprowadzać się; przebierać się"
        },
        {
          "language": "ro",
          "text": "a se muta; a se schimba"
        },
        {
          "language": "ru",
          "text": "переезжать; переодеваться"
        },
        {
          "language": "sq",
          "text": "të shpërngulesh; të ndërrohesh"
        },
        {
          "language": "tr",
          "text": "taşınmak; üstünü değiştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir ziehen nächste Woche in eine größere Wohnung um.",
          "translations": [
            {
              "language": "ar",
              "text": "سننتقل الأسبوع القادم إلى شقة أكبر."
            },
            {
              "language": "ckb",
              "text": "هەفتەی داهاتوو دەچینە خانوویەکی گەورەتر."
            },
            {
              "language": "en",
              "text": "We are moving to a bigger apartment next week."
            },
            {
              "language": "fa",
              "text": "ما هفته آینده به یک آپارتمان بزرگ‌تر نقل مکان می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em hefteya bê diçin apartmaneke mezintir."
            },
            {
              "language": "pl",
              "text": "W przyszłym tygodniu przeprowadzamy się do większego mieszkania."
            },
            {
              "language": "ro",
              "text": "Săptămâna viitoare ne mutăm într-un apartament mai mare."
            },
            {
              "language": "ru",
              "text": "На следующей неделе мы переезжаем в большую квартиру."
            },
            {
              "language": "sq",
              "text": "Javën tjetër shpërngulemi në një apartament më të madh."
            },
            {
              "language": "tr",
              "text": "Gelecek hafta daha büyük bir daireye taşınıyoruz."
            }
          ]
        },
        {
          "baseText": "Nach dem Sport muss ich mich schnell umziehen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الرياضة يجب أن أغير ملابسي بسرعة."
            },
            {
              "language": "ckb",
              "text": "دوای وەرزش دەبێت بە خێرایی جلەکانم بگۆڕم."
            },
            {
              "language": "en",
              "text": "After sports, I have to change clothes quickly."
            },
            {
              "language": "fa",
              "text": "بعد از ورزش باید سریع لباس عوض کنم."
            },
            {
              "language": "kmr",
              "text": "Piştî werzîşê divê ez zû cilên xwe biguherînim."
            },
            {
              "language": "pl",
              "text": "Po sporcie muszę szybko się przebrać."
            },
            {
              "language": "ro",
              "text": "După sport trebuie să mă schimb repede."
            },
            {
              "language": "ru",
              "text": "После спорта мне нужно быстро переодеться."
            },
            {
              "language": "sq",
              "text": "Pas sportit duhet të ndërrohem shpejt."
            },
            {
              "language": "tr",
              "text": "Spordan sonra hızlıca üstümü değiştirmem gerekiyor."
            }
          ]
        }
      ]
    },
