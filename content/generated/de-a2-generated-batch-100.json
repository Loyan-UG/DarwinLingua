      "meanings": [
        {
          "language": "ar",
          "text": "حادث"
        },
        {
          "language": "ckb",
          "text": "ڕووداو؛ حادسە"
        },
        {
          "language": "en",
          "text": "accident"
        },
        {
          "language": "fa",
          "text": "تصادف؛ حادثه"
        },
        {
          "language": "kmr",
          "text": "qezayê; bûyer"
        },
        {
          "language": "pl",
          "text": "wypadek"
        },
        {
          "language": "ro",
          "text": "accident"
        },
        {
          "language": "ru",
          "text": "авария; несчастный случай"
        },
        {
          "language": "sq",
          "text": "aksident"
        },
        {
          "language": "tr",
          "text": "kaza"
        }
      ],
      "examples": [
        {
          "baseText": "Auf der Straße gab es einen Unfall.",
          "translations": [
            {
              "language": "ar",
              "text": "كان هناك حادث في الشارع."
            },
            {
              "language": "ckb",
              "text": "لەسەر شەقامەکە ڕووداوێک هەبوو."
            },
            {
              "language": "en",
              "text": "There was an accident on the street."
            },
            {
              "language": "fa",
              "text": "در خیابان یک تصادف رخ داد."
            },
            {
              "language": "kmr",
              "text": "Li ser kolanê qezayek hebû."
            },
            {
              "language": "pl",
              "text": "Na ulicy był wypadek."
            },
            {
              "language": "ro",
              "text": "Pe stradă a avut loc un accident."
            },
            {
              "language": "ru",
              "text": "На улице произошла авария."
            },
            {
              "language": "sq",
              "text": "Në rrugë pati një aksident."
            },
            {
              "language": "tr",
              "text": "Yolda bir kaza oldu."
            }
          ]
        },
        {
          "baseText": "Bitte rufen Sie nach dem Unfall die Polizei.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الاتصال بالشرطة بعد الحادث."
            },
            {
              "language": "ckb",
              "text": "تکایە دوای ڕووداوەکە پۆلیس بانگ بکەن."
            },
            {
              "language": "en",
              "text": "Please call the police after the accident."
            },
            {
              "language": "fa",
              "text": "لطفاً بعد از حادثه با پلیس تماس بگیرید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe piştî qezayê polîsê bang bikin."
            },
            {
              "language": "pl",
              "text": "Po wypadku proszę zadzwonić na policję."
            },
            {
              "language": "ro",
              "text": "Vă rog să sunați la poliție după accident."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, после аварии вызовите полицию."
            },
            {
              "language": "sq",
              "text": "Ju lutem telefononi policinë pas aksidentit."
            },
            {
              "language": "tr",
              "text": "Kazadan sonra lütfen polisi arayın."
            }
          ]
        }
      ]
    },
