      "meanings": [
        {
          "language": "ar",
          "text": "معتمد على الدخل"
        },
        {
          "language": "ckb",
          "text": "پەیوەست بە داهات"
        },
        {
          "language": "en",
          "text": "income-dependent; based on income"
        },
        {
          "language": "fa",
          "text": "وابسته به درآمد"
        },
        {
          "language": "kmr",
          "text": "girêdayî dahatê"
        },
        {
          "language": "pl",
          "text": "zależny od dochodu"
        },
        {
          "language": "ro",
          "text": "dependent de venit"
        },
        {
          "language": "ru",
          "text": "зависящий от дохода"
        },
        {
          "language": "sq",
          "text": "i varur nga të ardhurat"
        },
        {
          "language": "tr",
          "text": "gelire bağlı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kita-Gebühren sind in vielen Städten einkommensabhängig.",
          "translations": [
            {
              "language": "ar",
              "text": "رسوم الحضانة في كثير من المدن تعتمد على الدخل."
            },
            {
              "language": "ckb",
              "text": "کرێی باخچەی ساوایان لە زۆر شاردا پەیوەستە بە داهات."
            },
            {
              "language": "en",
              "text": "Daycare fees are income-dependent in many cities."
            },
            {
              "language": "fa",
              "text": "هزینه مهدکودک در بسیاری از شهرها وابسته به درآمد است."
            },
            {
              "language": "kmr",
              "text": "Xercên baxçeyê zarokan li gelek bajaran girêdayî dahatê ne."
            },
            {
              "language": "pl",
              "text": "Opłaty za przedszkole w wielu miastach zależą od dochodu."
            },
            {
              "language": "ro",
              "text": "Taxele pentru grădiniță sunt dependente de venit în multe orașe."
            },
            {
              "language": "ru",
              "text": "Плата за детский сад во многих городах зависит от дохода."
            },
            {
              "language": "sq",
              "text": "Tarifat e kopshtit në shumë qytete varen nga të ardhurat."
            },
            {
              "language": "tr",
              "text": "Birçok şehirde kreş ücretleri gelire bağlıdır."
            }
          ]
        },
        {
          "baseText": "Das Unternehmen prüft, ob ein einkommensabhängiger Zuschuss für das Jobticket möglich ist.",
          "translations": [
            {
              "language": "ar",
              "text": "تدرس الشركة ما إذا كان دعم تذكرة العمل المعتمد على الدخل ممكنًا."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە دەپشکنێت ئایا یارمەتییەکی پەیوەست بە داهات بۆ بلیتی کارکردن دەکرێت یان نا."
            },
            {
              "language": "en",
              "text": "The company is checking whether an income-dependent subsidy for the job ticket is possible."
            },
            {
              "language": "fa",
              "text": "شرکت بررسی می‌کند آیا کمک‌هزینه وابسته به درآمد برای بلیت کاری ممکن است یا نه."
            },
            {
              "language": "kmr",
              "text": "Pargîdanî kontrol dike ka piştgiriyeke girêdayî dahatê ji bo bilêta karê gengaz e an na."
            },
            {
              "language": "pl",
              "text": "Firma sprawdza, czy możliwa jest zależna od dochodu dopłata do biletu pracowniczego."
            },
            {
              "language": "ro",
              "text": "Compania verifică dacă este posibilă o subvenție dependentă de venit pentru abonamentul de transport al angajaților."
            },
            {
              "language": "ru",
              "text": "Компания проверяет, возможна ли зависящая от дохода субсидия на рабочий проездной."
            },
            {
              "language": "sq",
              "text": "Kompania po shqyrton nëse është i mundur një subvencion i varur nga të ardhurat për biletën e punës."
            },
            {
              "language": "tr",
              "text": "Şirket, iş bileti için gelire bağlı bir destek mümkün mü diye inceliyor."
            }
          ]
        }
      ]
    }
