      ],
      "examples": [
        {
          "baseText": "Meine Freundin kommt heute.",
          "translations": [
            {
              "language": "ar",
              "text": "صديقتي تأتي اليوم."
            },
            {
              "language": "ckb",
              "text": "هاوڕێیەکەم ئەمڕۆ دێت."
            },
            {
              "language": "en",
              "text": "My friend is coming today."
            },
            {
              "language": "fa",
              "text": "دوستم امروز می‌آید."
            },
            {
              "language": "kmr",
              "text": "Hevala min îro tê."
            },
            {
              "language": "pl",
              "text": "Moja przyjaciółka przychodzi dzisiaj."
            },
            {
              "language": "ro",
              "text": "Prietena mea vine astăzi."
            },
            {
              "language": "ru",
              "text": "Моя подруга придет сегодня."
            },
            {
              "language": "sq",
              "text": "Shoqja ime vjen sot."
            },
            {
              "language": "tr",
              "text": "Kız arkadaşım bugün geliyor."
            }
          ]
        },
        {
          "baseText": "Ich besuche meine Freundin.",
          "translations": [
            {
              "language": "ar",
              "text": "أزور صديقتي."
            },
            {
              "language": "ckb",
              "text": "من سەردانی هاوڕێیەکەم دەکەم."
            },
            {
              "language": "en",
              "text": "I am visiting my friend."
            },
            {
              "language": "fa",
              "text": "من به دیدن دوستم می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez serdana hevala xwe dikim."
            },
            {
              "language": "pl",
              "text": "Odwiedzam moją przyjaciółkę."
            },
            {
              "language": "ro",
              "text": "O vizitez pe prietena mea."
            },
            {
              "language": "ru",
              "text": "Я навещаю подругу."
            },
            {
              "language": "sq",
              "text": "Po vizitoj shoqen time."
            },
            {
              "language": "tr",
              "text": "Kız arkadaşımı ziyaret ediyorum."
            }
          ]
        }
      ]
