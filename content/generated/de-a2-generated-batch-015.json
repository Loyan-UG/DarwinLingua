      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقدّم طلباً؛ يطلب رسمياً"
        },
        {
          "language": "ckb",
          "text": "داواکاری پێشکەشکردن"
        },
        {
          "language": "en",
          "text": "to apply for; to request officially"
        },
        {
          "language": "fa",
          "text": "درخواست دادن؛ تقاضا کردن"
        },
        {
          "language": "kmr",
          "text": "daxwaz kirin; serlêdan kirin"
        },
        {
          "language": "pl",
          "text": "złożyć wniosek; ubiegać się"
        },
        {
          "language": "ro",
          "text": "a solicita; a depune cerere"
        },
        {
          "language": "ru",
          "text": "подавать заявление; запрашивать"
        },
        {
          "language": "sq",
          "text": "të aplikosh; të kërkosh zyrtarisht"
        },
        {
          "language": "tr",
          "text": "başvurmak; talep etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte einen neuen Pass beantragen.",
          "translations": [
            {
              "language": "ar",
              "text": "أريد أن أقدم طلباً لجواز سفر جديد."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت داوای پاسپۆرتێکی نوێ بکەم."
            },
            {
              "language": "en",
              "text": "I would like to apply for a new passport."
            },
            {
              "language": "fa",
              "text": "می‌خواهم برای پاسپورت جدید درخواست بدهم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim ji bo pasaportek nû serlêdan bikim."
            },
            {
              "language": "pl",
              "text": "Chcę złożyć wniosek o nowy paszport."
            },
            {
              "language": "ro",
              "text": "Aș dori să solicit un pașaport nou."
            },
            {
              "language": "ru",
              "text": "Я хочу подать заявление на новый паспорт."
            },
            {
              "language": "sq",
              "text": "Dua të aplikoj për një pasaportë të re."
            },
            {
              "language": "tr",
              "text": "Yeni bir pasaport için başvurmak istiyorum."
            }
          ]
        },
        {
          "baseText": "Sie können den Zuschuss online beantragen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم تقديم طلب الدعم المالي عبر الإنترنت."
            },
            {
              "language": "ckb",
              "text": "دەتوانن یارمەتی داراییەکە ئۆنلاین داوا بکەن."
            },
            {
              "language": "en",
              "text": "You can apply for the grant online."
            },
            {
              "language": "fa",
              "text": "می‌توانید کمک‌هزینه را آنلاین درخواست کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin alîkariya pereyî online daxwaz bikin."
            },
            {
              "language": "pl",
              "text": "Można złożyć wniosek o dotację online."
            },
            {
              "language": "ro",
              "text": "Puteți solicita subvenția online."
            },
            {
              "language": "ru",
              "text": "Вы можете подать заявку на субсидию онлайн."
            },
            {
              "language": "sq",
              "text": "Mund të aplikoni online për grantin."
            },
            {
              "language": "tr",
              "text": "Desteğe çevrim içi başvurabilirsiniz."
            }
          ]
        }
      ]
    },
