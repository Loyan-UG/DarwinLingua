      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; means accessible without barriers"
      ],
      "collocations": [
        {
          "text": "ein barrierefreier Eingang",
          "meaning": "an accessible entrance"
        },
        {
          "text": "barrierefrei wohnen",
          "meaning": "to live in an accessible home"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Barriere",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "frei",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خالٍ من العوائق؛ مناسب لذوي الإعاقة"
        },
        {
          "language": "ckb",
          "text": "بێ بەربەست؛ گونجاو بۆ کەسانی کەمئەندام"
        },
        {
          "language": "en",
          "text": "accessible; barrier-free"
        },
        {
          "language": "fa",
          "text": "بدون مانع؛ قابل دسترس برای معلولان"
        },
        {
          "language": "kmr",
          "text": "bê asteng; gihîştinbar"
        },
        {
          "language": "pl",
          "text": "bez barier; dostępny"
        },
        {
          "language": "ro",
          "text": "accesibil; fără bariere"
        },
        {
          "language": "ru",
          "text": "безбарьерный; доступный"
        },
        {
          "language": "sq",
          "text": "pa barriera; i aksesueshëm"
        },
        {
          "language": "tr",
          "text": "engelsiz; erişilebilir"
        }
      ],
      "examples": [
        {
          "baseText": "Der Eingang ist barrierefrei.",
          "translations": [
            {
              "language": "ar",
              "text": "المدخل خالٍ من العوائق."
            },
            {
              "language": "ckb",
              "text": "دەروازەکە بێ بەربەستە."
            },
            {
              "language": "en",
              "text": "The entrance is accessible."
            },
            {
              "language": "fa",
              "text": "ورودی بدون مانع است."
            },
            {
              "language": "kmr",
              "text": "Derketin bê asteng e."
            },
            {
              "language": "pl",
              "text": "Wejście jest bez barier."
            },
            {
              "language": "ro",
              "text": "Intrarea este accesibilă."
            },
            {
              "language": "ru",
              "text": "Вход безбарьерный."
            },
            {
              "language": "sq",
              "text": "Hyrja është pa barriera."
            },
            {
              "language": "tr",
              "text": "Giriş engelsizdir."
            }
          ]
        },
        {
          "baseText": "Gibt es im Hotel barrierefreie Zimmer?",
          "translations": [
            {
              "language": "ar",
              "text": "هل توجد في الفندق غرف مناسبة لذوي الإعاقة؟"
            },
            {
              "language": "ckb",
              "text": "لە هۆتێلەکە ژووری بێ بەربەست هەیە؟"
            },
            {
              "language": "en",
              "text": "Are there accessible rooms in the hotel?"
            },
            {
              "language": "fa",
              "text": "آیا در هتل اتاق‌های قابل دسترس وجود دارد؟"
            },
            {
              "language": "kmr",
              "text": "Di otêlê de odeyên bê asteng hene?"
            },
            {
              "language": "pl",
              "text": "Czy w hotelu są pokoje bez barier?"
            },
            {
              "language": "ro",
              "text": "Există camere accesibile în hotel?"
            },
            {
              "language": "ru",
              "text": "В отеле есть доступные номера?"
            },
            {
              "language": "sq",
              "text": "A ka dhoma të aksesueshme në hotel?"
            },
            {
              "language": "tr",
              "text": "Otelde engelsiz odalar var mı?"
            }
          ]
        }
      ]
    },
