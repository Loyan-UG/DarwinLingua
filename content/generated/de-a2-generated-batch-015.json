          "text": "einen Pass beantragen",
          "meaning": "to apply for a passport"
        },
        {
          "text": "Hilfe beantragen",
          "meaning": "to apply for assistance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Antrag",
          "relationLabel": "noun",
          "note": null
