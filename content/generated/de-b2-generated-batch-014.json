      ],
      "grammarNotes": [
        "separable verb"
      ],
      "collocations": [
        {
          "text": "ein Projekt anfahren",
          "meaning": "to start a project"
        },
        {
          "text": "einen Prozess anfahren",
          "meaning": "to start a process"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Ablauf",
          "relationLabel": "noun",
          "note": "process flow"
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "الانطلاق أو البدء (في عملية أو جهاز)"
        },
        {
          "language": "ckb",
          "text": "دەستپێکردن و دەستەواژەکردن"
        },
        {
          "language": "en",
          "text": "to start (a system, process, or vehicle)"
        },
        {
          "language": "fa",
          "text": "راه‌اندازی کردن؛ آغاز کردن"
        },
        {
          "language": "kmr",
          "text": "destpêkirin"
        },
        {
          "language": "pl",
          "text": "rozpoczynać; uruchamiać"
        },
        {
          "language": "ro",
          "text": "a porni; a începe"
        },
        {
          "language": "ru",
          "text": "запускать; начинать"
        },
        {
          "language": "sq",
          "text": "të nisë; të fillojë"
        },
        {
          "language": "tr",
          "text": "başlatmak; harekete geçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Linienbus in der Zentrale fährt um 7:10 Uhr an.",
          "translations": [
            {
              "language": "ar",
              "text": "حافلة النقل في المبنى الرئيسي تنطلق الساعة 7:10 صباحًا."
            },
            {
              "language": "ckb",
              "text": "باتەری پاساژەی ناوەندی لە کاتژماری 7:10ی بەیانی دەدەیەوێت."
            },
            {
              "language": "en",
              "text": "The employee shuttle in the office building starts at 7:10 AM."
            },
            {
              "language": "fa",
              "text": "اتوبوس سرویس داخل شرکت ساعت 7:10 صبح حرکت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Busa karî li navê amadekirine, di saet 7:10 ê de dest pê dike."
            },
            {
              "language": "pl",
              "text": "Autobus zakładowy w centrum uruchamia się o 7:10."
            },
            {
              "language": "ro",
              "text": "Autobuzul de serviciu din clădire pornește la ora 7:10."
            },
            {
              "language": "ru",
              "text": "Автобус на предприятии выезжает в 7:10."
            },
            {
              "language": "sq",
              "text": "Autobusi i kompanisë në ndërtesë niset në orën 7:10."
            },
            {
              "language": "tr",
              "text": "Merkezdeki servis otobüsü saat 7:10'da kalkar."
            }
          ]
        },
        {
          "baseText": "Wir fahren heute den neuen Monitoring-Flow in Staging an.",
          "translations": [
            {
              "language": "ar",
              "text": "امسح اليوم عملية المراقبة الجديدة في بيئة Staging."
            },
            {
              "language": "ckb",
              "text": "ئێمە ئەمڕۆ پڕۆسەی ئۆتۆماتیکی چاودێری نوێ لە محیطی Staging دەدەستپێنین."
            },
            {
              "language": "en",
              "text": "Today we start the new monitoring flow in staging."
            },
            {
              "language": "fa",
              "text": "امروز جریان جدید مانیتورینگ را در محیط Staging راه‌اندازی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Îro me rêza nû ya şopandinê di Staging de destpê dikin."
            },
            {
              "language": "pl",
              "text": "Dzisiaj uruchamiamy nowy przepływ monitorowania w środowisku staging."
            },
            {
              "language": "ro",
              "text": "Astăzi pornim noul flux de monitorizare în mediul de testare."
            },
            {
              "language": "ru",
              "text": "Сегодня мы запускаем новый поток мониторинга в staging."
            },
            {
              "language": "sq",
              "text": "Sot po nisim rrjedhën e re të monitorimit në mjedisin e Staging-ut."
            },
            {
              "language": "tr",
              "text": "Bugün staging ortamında yeni izleme akışını başlatıyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "das Angebot",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "die Angebote",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-ge-bot",
      "topics": [
        "sales-and-customers",
        "documents-and-administration",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "customer-service"
      ],
      "grammarNotes": [
        "neutral noun",
        "singular and plural forms"
      ],
      "collocations": [
        {
          "text": "ein Angebot einreichen",
          "meaning": "to submit an offer"
        },
        {
          "text": "das Angebot annehmen",
          "meaning": "to accept an offer"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "anbieten",
          "relationLabel": "verb",
          "note": "related verb"
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "عرض؛ پیشنهاد"
        },
        {
          "language": "ckb",
          "text": "پێشنیار"
        },
        {
          "language": "en",
          "text": "offer; proposal"
        },
        {
          "language": "fa",
          "text": "پیشنهاد"
        },
        {
          "language": "kmr",
          "text": "pêşniyaz"
        },
        {
          "language": "pl",
          "text": "oferta"
        },
        {
          "language": "ro",
          "text": "ofertă"
        },
        {
          "language": "ru",
          "text": "предложение; оферта"
        },
        {
          "language": "sq",
          "text": "ofertë"
        },
        {
          "language": "tr",
          "text": "teklif"
        }
      ],
      "examples": [
        {
          "baseText": "Das Angebot für die API-Lizenz haben wir heute an den Kunden geschickt.",
          "translations": [
            {
              "language": "ar",
              "text": "لقد أرسلنا عرض ترخيص الـAPI للعميل اليوم."
            },
            {
              "language": "ckb",
              "text": "پێشنیاری مۆڵەتی API ئێمە ئەمڕۆ ناردین بۆ کڕیار."
            },
            {
              "language": "en",
              "text": "We sent the API license offer to the client today."
            },
            {
              "language": "fa",
              "text": "پیشنهاد مجوز API را امروز برای مشتری ارسال کردیم."
            },
            {
              "language": "kmr",
              "text": "Pêşniyaza lîsansê API-em îro ji xerîdarê re şandin."
            },
            {
              "language": "pl",
              "text": "Dziś wysłaliśmy ofertę licencji API do klienta."
            },
            {
              "language": "ro",
              "text": "Am trimis astăzi oferta pentru licența API clientului."
            },
            {
              "language": "ru",
              "text": "Мы сегодня отправили клиенту предложение по лицензии API."
            },
            {
              "language": "sq",
              "text": "Oferta për licencën e API-së e dërguam sot klientit."
            },
            {
              "language": "tr",
              "text": "API lisansına yönelik teklifi bugün müşteriye gönderdik."
            }
          ]
        },
        {
          "baseText": "Wir warten auf die Rückmeldung zum Angebot, bevor wir mit der Implementierung starten.",
          "translations": [
            {
              "language": "ar",
              "text": "منتظر پاسخ مربوط به العرض نَحن قبل بدء التنفيذ."
            },
            {
              "language": "ckb",
              "text": "مانەکەمان وەک پەاساوبەری پێشنیارەکە دەچێت پێش لە دەستپێکردنی جێبەجێکردن."
            },
            {
              "language": "en",
              "text": "We are waiting for feedback on the offer before starting the implementation."
            },
            {
              "language": "fa",
              "text": "قبل از شروع پیاده‌سازی منتظر بازخورد دربارهٔ پیشنهاد هستیم."
            },
            {
              "language": "kmr",
              "text": "Em berî destpêkirina bişkojkê bersiv ji pêşniyazê li benda me ne."
            },
            {
              "language": "pl",
              "text": "Czekamy na odpowiedź na ofertę, zanim rozpoczniemy wdrożenie."
            },
            {
              "language": "ro",
              "text": "Așteptăm confirmarea ofertei înainte de a începe implementarea."
            },
            {
              "language": "ru",
              "text": "Мы ждём ответа на предложение, прежде чем начинать внедрение."
            },
            {
              "language": "sq",
              "text": "Përpara se të fillojmë zbatimin, presim përshtypjen për ofertën."
            },
            {
              "language": "tr",
              "text": "Uygulamaya başlamadan önce teklif hakkındaki geri bildirimi bekliyoruz."
            }
          ]
        }
      ]
    },
