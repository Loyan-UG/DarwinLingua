      "meanings": [
        {
          "language": "ar",
          "text": "شكوى؛ مطالبة بسبب عيب"
        },
        {
          "language": "ckb",
          "text": "سکاڵا؛ داواکاری چاککردنەوە"
        },
        {
          "language": "en",
          "text": "complaint; claim"
        },
        {
          "language": "fa",
          "text": "شکایت؛ اعتراض به کالا/خدمت"
        },
        {
          "language": "kmr",
          "text": "şikayet; gilî"
        },
        {
          "language": "pl",
          "text": "reklamacja"
        },
        {
          "language": "ro",
          "text": "reclamație"
        },
        {
          "language": "ru",
          "text": "рекламация; жалоба"
        },
        {
          "language": "sq",
          "text": "reklamim; ankesë"
        },
        {
          "language": "tr",
          "text": "şikayet; ürün iadesi/itiraz"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe eine Reklamation zu meiner Bestellung.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي شكوى بخصوص طلبي."
            },
            {
              "language": "ckb",
              "text": "سکاڵایەکم دەربارەی داواکارییەکەم هەیە."
            },
            {
              "language": "en",
              "text": "I have a complaint about my order."
            },
            {
              "language": "fa",
              "text": "درباره سفارش خود شکایت دارم."
            },
            {
              "language": "kmr",
              "text": "Min şikayetek li ser fermana xwe heye."
            },
            {
              "language": "pl",
              "text": "Mam reklamację dotyczącą mojego zamówienia."
            },
            {
              "language": "ro",
              "text": "Am o reclamație despre comanda mea."
            },
            {
              "language": "ru",
              "text": "У меня претензия по моему заказу."
            },
            {
              "language": "sq",
              "text": "Kam një ankesë për porosinë time."
            },
            {
              "language": "tr",
              "text": "Siparişimle ilgili bir şikayetim var."
            }
          ]
        },
        {
          "baseText": "Die Reklamation wird heute bearbeitet.",
          "translations": [
            {
              "language": "ar",
              "text": "سيتم معالجة الشكوى اليوم."
            },
            {
              "language": "ckb",
              "text": "سکاڵاکە ئەمڕۆ چارەسەر دەکرێت."
            },
            {
              "language": "en",
              "text": "The complaint will be processed today."
            },
            {
              "language": "fa",
              "text": "شکایت امروز رسیدگی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Şikayet îro tê çareserkirin."
            },
            {
              "language": "pl",
              "text": "Reklamacja będzie dziś rozpatrzona."
            },
            {
              "language": "ro",
              "text": "Reclamația este procesată astăzi."
            },
            {
              "language": "ru",
              "text": "Рекламация будет обработана сегодня."
            },
            {
              "language": "sq",
              "text": "Ankesa do të përpunohet sot."
            },
            {
              "language": "tr",
              "text": "Şikayet bugün işleme alınacak."
            }
          ]
        }
      ]
    },
