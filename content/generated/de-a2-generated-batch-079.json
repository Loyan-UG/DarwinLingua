            },
            {
              "language": "ru",
              "text": "Я хотел бы предъявить претензию по сломанной лампе."
            },
            {
              "language": "sq",
              "text": "Dua të reklamoj llambën e prishur."
            },
            {
              "language": "tr",
              "text": "Bozuk lambayı şikayet etmek istiyorum."
            }
          ]
        },
        {
          "baseText": "Sie können den Artikel an der Kasse reklamieren.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنك تقديم الشكوى عن المنتج عند الصندوق."
            },
            {
              "language": "ckb",
              "text": "دەتوانن شتەكە لە کاشێر ڕیکلام بکەن."
            },
            {
              "language": "en",
              "text": "You can make a complaint about the item at the checkout."
            },
            {
              "language": "fa",
              "text": "می‌توانید کالا را در صندوق مرجوع/اعتراض کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin tiştê li kasê şikayet bikin."
