      ],
      "examples": [
        {
          "baseText": "Ich möchte die kaputte Lampe reklamieren.",
          "translations": [
            {
              "language": "ar",
              "text": "أريد أن أشتكي من المصباح المكسور."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت سکاڵا لە چرای تێکچوو بکەم."
            },
            {
              "language": "en",
              "text": "I would like to complain about the broken lamp."
            },
            {
              "language": "fa",
              "text": "می‌خواهم بابت چراغ خراب شکایت کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim li ser çiraya xerab şikayet bikim."
