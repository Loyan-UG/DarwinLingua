      ],
      "collocations": [
        {
          "text": "eine Reiseversicherung abschließen",
          "meaning": "to take out travel insurance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Reise",
          "relationLabel": "noun",
          "note": "trip"
        },
        {
          "lemma": "die Versicherung",
          "relationLabel": "noun",
          "note": "insurance"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تأمين سفر"
        },
        {
          "language": "ckb",
          "text": "بیمەی گەشت"
        },
        {
          "language": "en",
          "text": "travel insurance"
        },
        {
          "language": "fa",
          "text": "بیمه سفر"
        },
        {
          "language": "kmr",
          "text": "sîgorteya rêwîtiyê"
        },
        {
          "language": "pl",
          "text": "ubezpieczenie podróżne"
        },
        {
          "language": "ro",
          "text": "asigurare de călătorie"
        },
        {
          "language": "ru",
          "text": "туристическая страховка"
        },
        {
          "language": "sq",
          "text": "sigurim udhëtimi"
        },
        {
          "language": "tr",
          "text": "seyahat sigortası"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Reise nach Spanien brauche ich eine Reiseversicherung.",
          "translations": [
            {
              "language": "ar",
              "text": "للسفر إلى إسبانيا أحتاج إلى تأمين سفر."
            },
            {
              "language": "ckb",
              "text": "بۆ گەشت بۆ ئیسپانیا پێویستم بە بیمەی گەشت هەیە."
            },
            {
              "language": "en",
              "text": "For the trip to Spain, I need travel insurance."
            },
            {
              "language": "fa",
              "text": "برای سفر به اسپانیا به بیمه سفر نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ji bo rêwîtiya Spanyayê sîgorteya rêwîtiyê divê min be."
            },
            {
              "language": "pl",
              "text": "Na podróż do Hiszpanii potrzebuję ubezpieczenia podróżnego."
            },
            {
              "language": "ro",
              "text": "Pentru călătoria în Spania am nevoie de asigurare de călătorie."
            },
            {
              "language": "ru",
              "text": "Для поездки в Испанию мне нужна туристическая страховка."
            },
            {
              "language": "sq",
              "text": "Për udhëtimin në Spanjë më duhet sigurim udhëtimi."
            },
            {
              "language": "tr",
              "text": "İspanya seyahati için seyahat sigortasına ihtiyacım var."
            }
          ]
        },
        {
          "baseText": "Die Reiseversicherung kostet 25 Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "تأمين السفر يكلف 25 يورو."
            },
            {
              "language": "ckb",
              "text": "بیمەی گەشتەکە ٢٥ یۆرۆیە."
            },
            {
              "language": "en",
              "text": "The travel insurance costs 25 euros."
            },
            {
              "language": "fa",
              "text": "بیمه سفر ۲۵ یورو هزینه دارد."
            },
            {
              "language": "kmr",
              "text": "Sîgorteya rêwîtiyê 25 euro ye."
            },
            {
              "language": "pl",
              "text": "Ubezpieczenie podróżne kosztuje 25 euro."
            },
            {
              "language": "ro",
              "text": "Asigurarea de călătorie costă 25 de euro."
            },
            {
              "language": "ru",
              "text": "Туристическая страховка стоит 25 евро."
            },
            {
              "language": "sq",
              "text": "Sigurimi i udhëtimit kushton 25 euro."
            },
            {
              "language": "tr",
              "text": "Seyahat sigortası 25 avro tutuyor."
            }
          ]
        }
      ]
    },
