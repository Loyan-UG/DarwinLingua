  "entries": [
    {
      "word": "vergehen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vergehen",
      "pronunciationIpa": null,
      "syllableBreak": "ver-ge-hen",
      "topics": [
        "everyday-life",
        "law-and-compliance",
        "business-communication"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "legal",
        "administration",
        "management"
      ],
      "grammarNotes": [
        "irregular verb: vergeht, verging, ist vergangen; can mean time passes or someone commits an offense"
      ],
      "collocations": [
        {
          "text": "die Zeit vergeht",
          "meaning": "time passes"
        },
        {
          "text": "sich an einer Regel vergehen",
          "meaning": "to violate a rule"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vergangen",
          "relationLabel": "participle/adjective",
          "note": null
        },
        {
          "lemma": "das Vergehen",
          "relationLabel": "noun",
          "note": "minor offense"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يمر؛ يرتكب مخالفة"
        },
        {
          "language": "ckb",
          "text": "تێدەپەڕێت؛ سەرپێچی دەکات"
        },
        {
          "language": "en",
          "text": "to pass; to commit an offense"
        },
        {
          "language": "fa",
          "text": "گذشتن؛ مرتکب تخلف شدن"
        },
        {
          "language": "kmr",
          "text": "derbas bûn; binpêkirin kirin"
        },
        {
          "language": "pl",
          "text": "mijać; popełnić wykroczenie"
        },
        {
          "language": "ro",
          "text": "a trece; a comite o abatere"
        },
        {
          "language": "ru",
          "text": "проходить; совершить проступок"
        },
        {
          "language": "sq",
          "text": "të kalojë; të kryesh shkelje"
        },
        {
          "language": "tr",
          "text": "geçmek; kabahat işlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Zwischen der Anfrage und der Antwort dürfen nicht mehr als zwei Werktage vergehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب ألا يمر أكثر من يومي عمل بين الطلب والرد."
            },
            {
              "language": "ckb",
              "text": "لە نێوان داواکاری و وەڵامدا نابێت زیاتر لە دوو ڕۆژی کاری تێپەڕێت."
            },
            {
              "language": "en",
              "text": "No more than two working days should pass between the request and the response."
            },
            {
              "language": "fa",
              "text": "بین درخواست و پاسخ نباید بیش از دو روز کاری بگذرد."
            },
            {
              "language": "kmr",
              "text": "Di navbera daxwaz û bersivê de nabe zêdetir ji du rojên kar derbas bibin."
            },
            {
              "language": "pl",
              "text": "Między zapytaniem a odpowiedzią nie powinny minąć więcej niż dwa dni robocze."
            },
            {
              "language": "ro",
              "text": "Între solicitare și răspuns nu trebuie să treacă mai mult de două zile lucrătoare."
            },
            {
              "language": "ru",
              "text": "Между запросом и ответом должно пройти не более двух рабочих дней."
            },
            {
              "language": "sq",
              "text": "Mes kërkesës dhe përgjigjes nuk duhet të kalojnë më shumë se dy ditë pune."
            },
            {
              "language": "tr",
              "text": "Talep ile yanıt arasında iki iş gününden fazla geçmemelidir."
            }
          ]
        },
        {
          "baseText": "Wer sich wiederholt gegen interne Regeln vergeht, muss mit Konsequenzen rechnen.",
          "translations": [
            {
              "language": "ar",
              "text": "من يخالف القواعد الداخلية مرارًا يجب أن يتوقع عواقب."
            },
            {
              "language": "ckb",
              "text": "ئەوەی دووبارە و دووبارە دژی ڕێسای ناوخۆ سەرپێچی بکات، دەبێت چاوەڕێی ئاکام بێت."
            },
            {
              "language": "en",
              "text": "Anyone who repeatedly violates internal rules must expect consequences."
            },
            {
              "language": "fa",
              "text": "کسی که مکرراً از قوانین داخلی تخلف کند، باید انتظار پیامد داشته باشد."
            },
            {
              "language": "kmr",
              "text": "Kesê ku dubare li dijî rêzikên navxweyî binpê bike, divê li bendê encaman be."
            },
            {
              "language": "pl",
              "text": "Kto wielokrotnie narusza wewnętrzne zasady, musi liczyć się z konsekwencjami."
            },
            {
              "language": "ro",
              "text": "Cine încalcă repetat regulile interne trebuie să se aștepte la consecințe."
            },
            {
              "language": "ru",
              "text": "Тот, кто неоднократно нарушает внутренние правила, должен ожидать последствий."
            },
            {
              "language": "sq",
              "text": "Kush shkel vazhdimisht rregullat e brendshme duhet të presë pasoja."
            },
            {
              "language": "tr",
              "text": "İç kuralları tekrar tekrar ihlal eden kişi sonuçlara katlanmalıdır."
            }
          ]
        }
      ]
    },
