          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موظف؛ عامل"
        },
        {
          "language": "ckb",
          "text": "کارمەند؛ هاوکار"
        },
        {
          "language": "en",
          "text": "employee; staff member"
        },
        {
          "language": "fa",
          "text": "کارمند؛ نیروی کار"
        },
        {
          "language": "kmr",
          "text": "karmend; endamê xebatê"
        },
        {
          "language": "pl",
          "text": "pracownik"
        },
        {
          "language": "ro",
          "text": "angajat; membru al personalului"
        },
        {
          "language": "ru",
          "text": "сотрудник; работник"
        },
        {
          "language": "sq",
          "text": "punonjës; anëtar i stafit"
        },
        {
          "language": "tr",
          "text": "çalışan; personel"
        }
      ],
      "examples": [
        {
          "baseText": "Der neue Mitarbeiter bekommt heute seinen Laptop.",
          "translations": [
            {
              "language": "ar",
              "text": "يحصل الموظف الجديد اليوم على حاسوبه المحمول."
            },
            {
              "language": "ckb",
              "text": "کارمەندی نوێ ئەمڕۆ لاپتۆپەکەی وەردەگرێت."
            },
            {
              "language": "en",
              "text": "The new employee gets his laptop today."
            },
            {
              "language": "fa",
              "text": "کارمند جدید امروز لپ‌تاپش را دریافت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Karmendê nû îro laptopa xwe werdigire."
            },
            {
              "language": "pl",
              "text": "Nowy pracownik dostaje dziś laptopa."
            },
            {
              "language": "ro",
              "text": "Noul angajat primește astăzi laptopul."
            },
            {
              "language": "ru",
              "text": "Новый сотрудник сегодня получает свой ноутбук."
            },
            {
              "language": "sq",
              "text": "Punonjësi i ri merr sot laptopin e tij."
            },
            {
              "language": "tr",
              "text": "Yeni çalışan bugün dizüstü bilgisayarını alıyor."
            }
          ]
        },
        {
          "baseText": "Ein Mitarbeiter aus dem Service ruft Sie am Nachmittag zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "سيتصل بك موظف من قسم الخدمة بعد الظهر."
            },
            {
              "language": "ckb",
              "text": "کارمەندێک لە بەشی خزمەتگوزاری نیوەڕۆ پەیوەندیت پێوە دەکاتەوە."
            },
            {
              "language": "en",
              "text": "An employee from service will call you back in the afternoon."
            },
            {
              "language": "fa",
              "text": "یکی از کارکنان بخش خدمات بعدازظهر با شما تماس می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Karmendek ji beşa servîsê piştî nîvro vegere telefonê we."
            },
            {
              "language": "pl",
              "text": "Pracownik z działu obsługi oddzwoni do pana/pani po południu."
            },
            {
              "language": "ro",
              "text": "Un angajat de la service vă va suna înapoi după-amiază."
            },
            {
              "language": "ru",
              "text": "Сотрудник службы поддержки перезвонит вам после обеда."
            },
            {
              "language": "sq",
              "text": "Një punonjës nga shërbimi do t’ju telefonojë pasdite."
            },
            {
              "language": "tr",
              "text": "Servisten bir çalışan öğleden sonra sizi geri arayacak."
            }
          ]
        }
      ]
    },
