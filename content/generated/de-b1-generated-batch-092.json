  "entries": [
    {
      "word": "misslingen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "misslingen",
      "pronunciationIpa": null,
      "syllableBreak": "miss-lin-gen",
      "topics": [
        "work-and-jobs",
        "planning-and-projects",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "written",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: misslingt, misslang, misslungen; often used with dative"
      ],
      "collocations": [
        {
          "text": "der Versuch misslingt",
          "meaning": "the attempt fails"
        },
        {
          "text": "das Projekt misslingt",
          "meaning": "the project fails"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Misslingen",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "gelingen",
          "relationLabel": "opposite verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفشل؛ لا ينجح"
        },
        {
          "language": "ckb",
          "text": "سەرناکەوێت؛ شک دەهێنێت"
        },
        {
          "language": "en",
          "text": "to fail; not to succeed"
        },
        {
          "language": "fa",
          "text": "ناموفق شدن؛ شکست خوردن"
        },
        {
          "language": "kmr",
          "text": "serneketin; bi ser neketin"
        },
        {
          "language": "pl",
          "text": "nie udać się; zakończyć się niepowodzeniem"
        },
        {
          "language": "ro",
          "text": "a eșua; a nu reuși"
        },
        {
          "language": "ru",
          "text": "не удаваться; провалиться"
        },
        {
          "language": "sq",
          "text": "të dështojë; të mos ketë sukses"
        },
        {
          "language": "tr",
          "text": "başarısız olmak; sonuç vermemek"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn der Test misslingt, müssen wir den Fehler zuerst finden.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا فشل الاختبار، يجب أن نجد الخطأ أولًا."
            },
            {
              "language": "ckb",
              "text": "ئەگەر تاقیکردنەوەکە سەرنەکەوێت، پێویستە سەرەتا هەڵەکە بدۆزینەوە."
            },
            {
              "language": "en",
              "text": "If the test fails, we have to find the error first."
            },
            {
              "language": "fa",
              "text": "اگر تست ناموفق شود، باید اول خطا را پیدا کنیم."
            },
            {
              "language": "kmr",
              "text": "Heke test sernekeve, divê em pêşî xeletiyê bibînin."
            },
            {
              "language": "pl",
              "text": "Jeśli test się nie uda, musimy najpierw znaleźć błąd."
            },
            {
              "language": "ro",
              "text": "Dacă testul eșuează, trebuie mai întâi să găsim eroarea."
            },
            {
              "language": "ru",
              "text": "Если тест не удастся, сначала нужно найти ошибку."
            },
            {
              "language": "sq",
              "text": "Nëse testi dështon, duhet të gjejmë fillimisht gabimin."
            },
            {
              "language": "tr",
              "text": "Test başarısız olursa önce hatayı bulmamız gerekir."
            }
          ]
        },
        {
          "baseText": "Der Kuchen kann misslingen, wenn der Ofen zu heiß ist.",
          "translations": [
            {
              "language": "ar",
              "text": "قد لا تنجح الكعكة إذا كان الفرن ساخنًا جدًا."
            },
            {
              "language": "ckb",
              "text": "کێکەکە دەتوانێت سەرنەکەوێت ئەگەر فڕنەکە زۆر گەرم بێت."
            },
            {
              "language": "en",
              "text": "The cake can fail if the oven is too hot."
            },
            {
              "language": "fa",
              "text": "اگر فر خیلی داغ باشد، ممکن است کیک خراب شود."
            },
            {
              "language": "kmr",
              "text": "Heke firin pir germ be, kek dikare xerab bibe."
            },
            {
              "language": "pl",
              "text": "Ciasto może się nie udać, jeśli piekarnik jest za gorący."
            },
            {
              "language": "ro",
              "text": "Prăjitura poate să nu iasă bine dacă cuptorul este prea fierbinte."
            },
            {
              "language": "ru",
              "text": "Пирог может не получиться, если духовка слишком горячая."
            },
            {
              "language": "sq",
              "text": "Ëmbëlsira mund të mos dalë mirë nëse furra është shumë e nxehtë."
            },
            {
              "language": "tr",
              "text": "Fırın çok sıcaksa kek başarısız olabilir."
            }
          ]
        }
      ]
    },
    {
