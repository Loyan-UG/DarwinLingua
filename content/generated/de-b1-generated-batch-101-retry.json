      "meanings": [
        {
          "language": "ar",
          "text": "عملية جراحية"
        },
        {
          "language": "ckb",
          "text": "نەشتەرگەری؛ ئۆپەراسیۆن"
        },
        {
          "language": "en",
          "text": "operation; surgery"
        },
        {
          "language": "fa",
          "text": "عمل جراحی"
        },
        {
          "language": "kmr",
          "text": "emeliyat; niştêrgerî"
        },
        {
          "language": "pl",
          "text": "operacja; zabieg chirurgiczny"
        },
        {
          "language": "ro",
          "text": "operație; intervenție chirurgicală"
        },
        {
          "language": "ru",
          "text": "операция; хирургическое вмешательство"
        },
        {
          "language": "sq",
          "text": "operacion; ndërhyrje kirurgjikale"
        },
        {
          "language": "tr",
          "text": "ameliyat; operasyon"
        }
      ],
      "examples": [
        {
          "baseText": "Die Operation findet morgen früh im Krankenhaus statt.",
          "translations": [
            {
              "language": "ar",
              "text": "ستُجرى العملية غدًا صباحًا في المستشفى."
            },
            {
              "language": "ckb",
              "text": "نەشتەرگەرییەکە سبەی بەیانی لە نەخۆشخانە ئەنجام دەدرێت."
            },
            {
              "language": "en",
              "text": "The operation will take place tomorrow morning at the hospital."
            },
            {
              "language": "fa",
              "text": "عمل جراحی فردا صبح در بیمارستان انجام می‌شود."
            },
            {
              "language": "kmr",
              "text": "Emeliyat sibê serê sibê li nexweşxaneyê pêk tê."
            },
            {
              "language": "pl",
              "text": "Operacja odbędzie się jutro rano w szpitalu."
            },
            {
              "language": "ro",
              "text": "Operația are loc mâine dimineață la spital."
            },
            {
              "language": "ru",
              "text": "Операция состоится завтра утром в больнице."
            },
            {
              "language": "sq",
              "text": "Operacioni do të bëhet nesër në mëngjes në spital."
            },
            {
              "language": "tr",
              "text": "Ameliyat yarın sabah hastanede yapılacak."
            }
          ]
        },
        {
          "baseText": "Vor der Operation erklärt die Ärztin dem Patienten den Ablauf.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل العملية تشرح الطبيبة للمريض سير الإجراء."
            },
            {
              "language": "ckb",
              "text": "پێش نەشتەرگەرییەکە پزیشکە ژنەکە ڕێڕەوی کارەکە بۆ نەخۆشەکە ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "Before the operation, the doctor explains the procedure to the patient."
            },
            {
              "language": "fa",
              "text": "قبل از عمل، پزشک روند کار را برای بیمار توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Berî emeliyatê bijîşk pêvajoyê ji nexweş re rave dike."
            },
            {
              "language": "pl",
              "text": "Przed operacją lekarka wyjaśnia pacjentowi przebieg zabiegu."
            },
            {
              "language": "ro",
              "text": "Înainte de operație, doctorița îi explică pacientului procedura."
            },
            {
              "language": "ru",
              "text": "Перед операцией врач объясняет пациенту ход процедуры."
            },
            {
              "language": "sq",
              "text": "Para operacionit, mjekja ia shpjegon pacientit procedurën."
            },
            {
              "language": "tr",
              "text": "Ameliyattan önce doktor hastaya süreci açıklar."
            }
          ]
        }
      ]
    }
  ],
