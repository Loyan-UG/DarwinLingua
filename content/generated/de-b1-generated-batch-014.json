  "entries": [
    {
      "word": "die Arbeitszeit",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Arbeitszeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ar-beits-zeit",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "formal",
        "business",
        "spoken"
      ],
      "contextLabels": [
        "hr",
        "contracts",
        "management"
      ],
      "grammarNotes": [
        "feminine noun",
        "often used in plural when talking about schedules"
      ],
      "collocations": [
        {
          "text": "flexible Arbeitszeiten",
          "meaning": "flexible working hours"
        },
        {
          "text": "die Arbeitszeit erfassen",
          "meaning": "to record working time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "arbeiten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Zeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ساعات العمل؛ وقت العمل"
        },
        {
          "language": "ckb",
          "text": "کاتی کار؛ کاتەکانی کار"
        },
        {
          "language": "en",
          "text": "working time; working hours"
        },
        {
          "language": "fa",
          "text": "ساعت کاری؛ زمان کار"
        },
        {
          "language": "kmr",
          "text": "dema karê; demên karê"
        },
        {
          "language": "pl",
          "text": "czas pracy; godziny pracy"
        },
        {
          "language": "ro",
          "text": "program de lucru; timp de lucru"
        },
        {
          "language": "ru",
          "text": "рабочее время; часы работы"
        },
        {
          "language": "sq",
          "text": "orari i punës; kohë pune"
        },
        {
          "language": "tr",
          "text": "çalışma süresi; mesai saatleri"
        }
      ],
      "examples": [
        {
          "baseText": "Die Arbeitszeit muss jeden Tag im System erfasst werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب تسجيل وقت العمل يوميًا في النظام."
            },
            {
              "language": "ckb",
              "text": "کاتی کار دەبێت هەموو ڕۆژێک لە سیستەمدا تۆمار بکرێت."
            },
            {
              "language": "en",
              "text": "Working time must be recorded in the system every day."
            },
            {
              "language": "fa",
              "text": "ساعت کاری باید هر روز در سیستم ثبت شود."
            },
            {
              "language": "kmr",
              "text": "Divê dema karê her roj di pergalê de were tomar kirin."
            },
            {
              "language": "pl",
              "text": "Czas pracy musi być codziennie rejestrowany w systemie."
            },
            {
              "language": "ro",
              "text": "Timpul de lucru trebuie înregistrat zilnic în sistem."
            },
            {
              "language": "ru",
              "text": "Рабочее время нужно каждый день фиксировать в системе."
            },
            {
              "language": "sq",
              "text": "Koha e punës duhet të regjistrohet çdo ditë në sistem."
            },
            {
              "language": "tr",
              "text": "Çalışma süresi her gün sisteme kaydedilmelidir."
            }
          ]
        },
        {
          "baseText": "Wegen der Kinderbetreuung braucht sie flexible Arbeitszeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب رعاية الأطفال تحتاج إلى ساعات عمل مرنة."
            },
            {
              "language": "ckb",
              "text": "بەهۆی چاودێری منداڵانەوە پێویستی بە کاتی کاری نەرم هەیە."
            },
            {
              "language": "en",
              "text": "Because of childcare, she needs flexible working hours."
            },
            {
              "language": "fa",
              "text": "به خاطر مراقبت از بچه‌ها به ساعت کاری منعطف نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Ji ber lênêrîna zarokan, ew hewceyê demên karê yên nerm e."
            },
            {
              "language": "pl",
              "text": "Z powodu opieki nad dziećmi potrzebuje elastycznych godzin pracy."
            },
            {
              "language": "ro",
              "text": "Din cauza îngrijirii copiilor, are nevoie de program de lucru flexibil."
            },
            {
              "language": "ru",
              "text": "Из-за ухода за детьми ей нужен гибкий график работы."
            },
            {
              "language": "sq",
              "text": "Për shkak të kujdesit për fëmijët, asaj i duhen orare pune fleksibël."
            },
            {
              "language": "tr",
