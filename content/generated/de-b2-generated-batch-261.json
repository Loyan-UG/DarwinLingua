  "entries": [
    {
      "word": "währenddessen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "wäh-rend-des-sen",
      "topics": [
        "business-communication",
        "planning-and-projects",
        "everyday-life"
      ],
      "usageLabels": [
        "written",
        "spoken"
      ],
      "contextLabels": [
        "management",
        "administration"
      ],
      "grammarNotes": [
        "adverb meaning meanwhile or during that time"
      ],
      "collocations": [
        {
          "text": "währenddessen weiterarbeiten",
          "meaning": "to keep working meanwhile"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "während",
          "relationLabel": "preposition/conjunction",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "في أثناء ذلك؛ في الوقت نفسه"
        },
        {
          "language": "ckb",
          "text": "لەو کاتەدا؛ هەمان کات"
        },
        {
          "language": "en",
          "text": "meanwhile; during that time"
        },
        {
          "language": "fa",
          "text": "در همین حین؛ در آن زمان"
        },
        {
          "language": "kmr",
          "text": "di wê demê de"
        },
        {
          "language": "pl",
          "text": "w międzyczasie"
        },
        {
          "language": "ro",
          "text": "între timp"
        },
        {
          "language": "ru",
          "text": "тем временем"
        },
        {
          "language": "sq",
          "text": "ndërkohë"
        },
        {
          "language": "tr",
          "text": "bu sırada; o esnada"
        }
      ],
      "examples": [
        {
          "baseText": "Der Server wird aktualisiert; währenddessen können sich Nutzer nicht anmelden.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تحديث الخادم؛ في أثناء ذلك لا يمكن للمستخدمين تسجيل الدخول."
            },
            {
              "language": "ckb",
              "text": "سێرڤەرەکە نوێ دەکرێتەوە؛ لەو کاتەدا بەکارهێنەران ناتوانن بچنە ژوورەوە."
            },
            {
              "language": "en",
              "text": "The server is being updated; meanwhile, users cannot log in."
            },
            {
              "language": "fa",
              "text": "سرور در حال به‌روزرسانی است؛ در این مدت کاربران نمی‌توانند وارد شوند."
            },
            {
              "language": "kmr",
              "text": "Server tê nûkirin; di wê demê de bikarhêner nikarin têkevin."
            },
            {
              "language": "pl",
              "text": "Serwer jest aktualizowany; w tym czasie użytkownicy nie mogą się logować."
            },
            {
              "language": "ro",
              "text": "Serverul este actualizat; între timp, utilizatorii nu se pot autentifica."
            },
            {
              "language": "ru",
              "text": "Сервер обновляется; тем временем пользователи не могут войти."
            },
            {
              "language": "sq",
              "text": "Serveri po përditësohet; ndërkohë përdoruesit nuk mund të hyjnë."
            },
            {
              "language": "tr",
              "text": "Sunucu güncelleniyor; bu sırada kullanıcılar giriş yapamaz."
            }
          ]
        },
        {
          "baseText": "Ich bereite die Präsentation vor, und währenddessen sammelt Lea die offenen Fragen.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا أجهز العرض، وفي الوقت نفسه تجمع ليا الأسئلة المفتوحة."
            },
            {
              "language": "ckb",
              "text": "من پێشکەشکردنەکە ئامادە دەکەم، لەو کاتەدا لیا پرسیارە کراوەکان کۆدەکاتەوە."
            },
            {
              "language": "en",
              "text": "I am preparing the presentation, and meanwhile Lea is collecting the open questions."
            },
            {
              "language": "fa",
              "text": "من ارائه را آماده می‌کنم و در همین حین لیا سؤال‌های باز را جمع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ez pêşkêşiyê amade dikim, û di wê demê de Lea pirsên vekirî kom dike."
            },
            {
              "language": "pl",
              "text": "Przygotowuję prezentację, a w międzyczasie Lea zbiera otwarte pytania."
            },
            {
              "language": "ro",
