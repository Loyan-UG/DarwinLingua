      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "Fortschritte machen",
          "meaning": "to make progress"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fortschreiten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تقدم؛ تطور"
        },
        {
          "language": "ckb",
          "text": "پێشکەوتن"
        },
        {
          "language": "en",
          "text": "progress"
        },
        {
          "language": "fa",
          "text": "پیشرفت"
        },
        {
          "language": "kmr",
          "text": "pêşketin"
        },
        {
          "language": "pl",
          "text": "postęp"
        },
        {
          "language": "ro",
          "text": "progres; progresie"
        },
        {
          "language": "ru",
          "text": "прогресс"
        },
        {
          "language": "sq",
          "text": "përparim"
        },
        {
          "language": "tr",
          "text": "ilerleme; gelişme"
        }
      ],
      "examples": [
        {
          "baseText": "Im Projekt sehen wir jede Woche deutliche Fortschritte.",
          "translations": [
            {
              "language": "ar",
              "text": "نرى في المشروع تقدمًا واضحًا كل أسبوع."
            },
            {
              "language": "ckb",
              "text": "لە پرۆژەکەدا هەموو هەفتە پێشکەوتنی ڕوون دەبینین."
            },
            {
              "language": "en",
              "text": "In the project, we see clear progress every week."
            },
            {
              "language": "fa",
              "text": "در پروژه هر هفته پیشرفت روشنی می‌بینیم."
            },
            {
              "language": "kmr",
              "text": "Di projeyê de em her hefte pêşketineke diyar dibînin."
            },
            {
              "language": "pl",
              "text": "W projekcie co tydzień widzimy wyraźne postępy."
            },
            {
              "language": "ro",
              "text": "În proiect vedem progrese clare în fiecare săptămână."
            },
            {
              "language": "ru",
              "text": "В проекте мы каждую неделю видим явный прогресс."
            },
            {
              "language": "sq",
              "text": "Në projekt shohim përparim të qartë çdo javë."
            },
            {
              "language": "tr",
              "text": "Projede her hafta belirgin ilerleme görüyoruz."
            }
          ]
        },
        {
          "baseText": "Durch regelmäßiges Üben macht sie große Fortschritte im Deutschen.",
          "translations": [
            {
              "language": "ar",
              "text": "من خلال التدريب المنتظم تحقق تقدمًا كبيرًا في الألمانية."
            },
            {
              "language": "ckb",
              "text": "بە مەشقکردنی بەردەوام پێشکەوتنی گەورە لە ئەڵمانیدا دەکات."
            },
            {
              "language": "en",
              "text": "Through regular practice, she is making great progress in German."
            },
