  "entries": [
    {
      "word": "fortfahren",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "fortfahren",
      "pronunciationIpa": null,
      "syllableBreak": "fort-fah-ren",
      "topics": [
        "business-communication",
        "planning-and-projects",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "written"
      ],
      "contextLabels": [
        "management",
        "administration"
      ],
      "grammarNotes": [
        "separable strong verb: fährt fort, fuhr fort, ist fortgefahren; often with mit + dative"
      ],
      "collocations": [
        {
          "text": "mit der Arbeit fortfahren",
          "meaning": "to continue with the work"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fahren",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "fort",
          "relationLabel": "prefix/adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يواصل؛ يستمر"
        },
        {
          "language": "ckb",
          "text": "بەردەوامبوون؛ درێژەدان"
        },
        {
          "language": "en",
          "text": "to continue; to proceed"
        },
        {
          "language": "fa",
          "text": "ادامه دادن؛ از سر گرفتن"
        },
        {
          "language": "kmr",
          "text": "berdewam kirin"
        },
        {
          "language": "pl",
          "text": "kontynuować"
        },
        {
          "language": "ro",
          "text": "a continua"
        },
        {
          "language": "ru",
          "text": "продолжать"
        },
        {
          "language": "sq",
          "text": "të vazhdosh"
        },
        {
          "language": "tr",
          "text": "devam etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der kurzen Pause fahren wir mit der Besprechung fort.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الاستراحة القصيرة نواصل الاجتماع."
            },
            {
              "language": "ckb",
              "text": "دوای پشوویەکی کورت درێژە بە کۆبوونەوەکە دەدەین."
            },
            {
              "language": "en",
              "text": "After the short break, we continue with the meeting."
            },
            {
              "language": "fa",
              "text": "بعد از استراحت کوتاه، جلسه را ادامه می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Piştî bêhnvedana kurt em bi civînê berdewam dikin."
            },
            {
              "language": "pl",
              "text": "Po krótkiej przerwie kontynuujemy spotkanie."
            },
            {
              "language": "ro",
              "text": "După pauza scurtă continuăm ședința."
            },
            {
              "language": "ru",
              "text": "После короткого перерыва мы продолжим совещание."
            },
            {
              "language": "sq",
              "text": "Pas pushimit të shkurtër vazhdojmë takimin."
            },
            {
              "language": "tr",
              "text": "Kısa aradan sonra toplantıya devam ediyoruz."
            }
          ]
        },
        {
          "baseText": "Bitte fahren Sie mit der Installation erst fort, wenn das Backup fertig ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى متابعة التثبيت فقط بعد انتهاء النسخة الاحتياطية."
            },
            {
              "language": "ckb",
              "text": "تکایە تەنها کاتێک درێژە بە دامەزراندن بدەن کە بەرگریکۆپییەکە تەواو بوو."
            },
            {
              "language": "en",
              "text": "Please continue with the installation only when the backup is finished."
            },
            {
              "language": "fa",
              "text": "لطفاً نصب را فقط وقتی ادامه دهید که پشتیبان‌گیری تمام شده است."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe tenê dema kopiya paşve amade bû bi sazkirinê berdewam bikin."
            },
            {
              "language": "pl",
              "text": "Proszę kontynuować instalację dopiero po zakończeniu kopii zapasowej."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să continuați instalarea doar după ce backupul este gata."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, продолжайте установку только после завершения резервного копирования."
            },
            {
              "language": "sq",
              "text": "Ju lutemi vazhdoni instalimin vetëm kur kopja rezervë të ketë përfunduar."
            },
            {
              "language": "tr",
              "text": "Lütfen kuruluma yalnızca yedekleme tamamlandıktan sonra devam edin."
            }
          ]
        }
      ]
    },
    {
      "word": "der Fortschritt",
