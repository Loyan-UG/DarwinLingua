      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "die Müllabfuhr kommt",
          "meaning": "the garbage collection comes"
        },
        {
          "text": "den Termin der Müllabfuhr prüfen",
          "meaning": "to check the garbage collection date"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Müll",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "abfahren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جمع القمامة؛ خدمة النظافة"
        },
        {
          "language": "ckb",
          "text": "کۆکردنەوەی خاشاک؛ خزمەتی خاشاک"
        },
        {
          "language": "en",
          "text": "garbage collection; waste collection service"
        },
        {
          "language": "fa",
          "text": "جمع‌آوری زباله؛ خدمات زباله‌برداری"
        },
        {
          "language": "kmr",
          "text": "komkirina gemarê; xizmeta avêtinê"
        },
        {
          "language": "pl",
          "text": "wywóz śmieci"
        },
        {
          "language": "ro",
          "text": "colectarea gunoiului; serviciul de salubritate"
        },
        {
          "language": "ru",
          "text": "вывоз мусора; служба вывоза мусора"
        },
        {
          "language": "sq",
          "text": "mbledhja e mbeturinave; shërbimi i pastrimit"
        },
        {
          "language": "tr",
          "text": "çöp toplama; temizlik hizmeti"
        }
      ],
      "examples": [
        {
          "baseText": "Die Müllabfuhr kommt morgen früh, also stellen wir die Tonnen heute Abend raus.",
          "translations": [
            {
              "language": "ar",
              "text": "تأتي سيارة جمع القمامة غدًا صباحًا، لذلك نضع الحاويات في الخارج هذا المساء."
            },
            {
              "language": "ckb",
              "text": "خزمەتی خاشاک سبەی بەیانی دێت، بۆیە ئەمشەو سەتڵەکان دەخەینە دەرەوە."
            },
            {
              "language": "en",
              "text": "The garbage collection comes tomorrow morning, so we put the bins out this evening."
            },
            {
              "language": "fa",
              "text": "زباله‌برداری فردا صبح می‌آید، پس امشب سطل‌ها را بیرون می‌گذاریم."
            },
            {
              "language": "kmr",
              "text": "Xizmeta gemarê sibê serê sibê tê, ji ber vê em îşev qutiyan derdixin derve."
            },
            {
              "language": "pl",
              "text": "Wywóz śmieci przyjeżdża jutro rano, więc dziś wieczorem wystawimy pojemniki."
            },
            {
              "language": "ro",
              "text": "Colectarea gunoiului vine mâine dimineață, așa că scoatem pubelele în seara asta."
            },
            {
              "language": "ru",
              "text": "Вывоз мусора будет завтра утром, поэтому сегодня вечером мы вынесем контейнеры."
            },
            {
              "language": "sq",
              "text": "Mbledhja e mbeturinave vjen nesër në mëngjes, prandaj sonte nxjerrim kazanët jashtë."
            },
            {
              "language": "tr",
              "text": "Çöp toplama yarın sabah geliyor, bu yüzden kutuları bu akşam dışarı çıkarıyoruz."
            }
          ]
        },
        {
          "baseText": "Bei der Stadt kann man den Plan der Müllabfuhr online ansehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن الاطلاع على جدول جمع القمامة عبر موقع البلدية."
            },
            {
              "language": "ckb",
              "text": "لە شارەوانی دەتوانرێت پلانی خزمەتی خاشاک بە ئۆنلاین ببینرێت."
            },
            {
              "language": "en",
              "text": "You can view the garbage collection schedule online on the city website."
            },
            {
              "language": "fa",
              "text": "می‌توان برنامه زباله‌برداری را در سایت شهر به‌صورت آنلاین دید."
            },
            {
              "language": "kmr",
              "text": "Li malpera bajêr mirov dikare plana komkirina gemarê online bibîne."
            },
            {
              "language": "pl",
              "text": "Na stronie miasta można sprawdzić online harmonogram wywozu śmieci."
            },
            {
              "language": "ro",
              "text": "Pe site-ul orașului se poate vedea online programul de colectare a gunoiului."
            },
            {
              "language": "ru",
              "text": "На сайте города можно посмотреть график вывоза мусора онлайн."
            },
            {
              "language": "sq",
              "text": "Në faqen e qytetit mund të shihet online orari i mbledhjes së mbeturinave."
            },
            {
              "language": "tr",
              "text": "Belediyenin sitesinde çöp toplama planı çevrim içi görülebilir."
            }
          ]
        }
      ]
    },
