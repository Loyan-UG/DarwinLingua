          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فرز النفايات"
        },
        {
          "language": "ckb",
          "text": "جیاکردنەوەی خاشاک"
        },
        {
          "language": "en",
          "text": "waste separation; sorting rubbish"
        },
        {
          "language": "fa",
          "text": "تفکیک زباله"
        },
        {
          "language": "kmr",
          "text": "veqetandina gemarê"
        },
        {
          "language": "pl",
          "text": "segregacja śmieci"
        },
        {
          "language": "ro",
          "text": "separarea deșeurilor"
        },
        {
          "language": "ru",
          "text": "сортировка мусора"
        },
        {
          "language": "sq",
          "text": "ndarja e mbeturinave"
        },
        {
          "language": "tr",
          "text": "çöp ayrıştırma"
        }
      ],
      "examples": [
        {
          "baseText": "In unserem Haus gibt es klare Regeln für die Mülltrennung.",
          "translations": [
            {
              "language": "ar",
              "text": "في بنايتنا توجد قواعد واضحة لفرز النفايات."
            },
            {
              "language": "ckb",
              "text": "لە بیناکەماندا یاسای ڕوون بۆ جیاکردنەوەی خاشاک هەیە."
            },
            {
              "language": "en",
              "text": "In our building there are clear rules for waste separation."
            },
            {
              "language": "fa",
              "text": "در ساختمان ما قوانین روشنی برای تفکیک زباله وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Li avahiya me qaîdeyên zelal ji bo veqetandina gemarê hene."
            },
            {
              "language": "pl",
              "text": "W naszym budynku są jasne zasady segregacji śmieci."
            },
            {
              "language": "ro",
              "text": "În blocul nostru există reguli clare pentru separarea deșeurilor."
            },
            {
              "language": "ru",
              "text": "В нашем доме есть чёткие правила сортировки мусора."
            },
            {
              "language": "sq",
              "text": "Në ndërtesën tonë ka rregulla të qarta për ndarjen e mbeturinave."
            },
            {
              "language": "tr",
              "text": "Binamızda çöp ayrıştırma için net kurallar var."
            }
          ]
        },
        {
          "baseText": "Die Firma erklärt neuen Mitarbeitern die Mülltrennung in der Küche.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح الشركة للموظفين الجدد فرز النفايات في المطبخ."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە جیاکردنەوەی خاشاک لە چێشتخانەدا بۆ کارمەندانی نوێ ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The company explains waste separation in the kitchen to new employees."
            },
            {
              "language": "fa",
              "text": "شرکت تفکیک زباله در آشپزخانه را برای کارکنان جدید توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Şîrket veqetandina gemarê li metbexê ji karmendên nû re rave dike."
            },
            {
              "language": "pl",
              "text": "Firma wyjaśnia nowym pracownikom segregację śmieci w kuchni."
            },
            {
              "language": "ro",
              "text": "Firma le explică noilor angajați separarea deșeurilor în bucătărie."
            },
            {
              "language": "ru",
              "text": "Компания объясняет новым сотрудникам сортировку мусора на кухне."
            },
            {
              "language": "sq",
              "text": "Kompania ua shpjegon punonjësve të rinj ndarjen e mbeturinave në kuzhinë."
            },
            {
              "language": "tr",
