        "technology-and-it"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb; regular or irregular past forms are possible: sendete/sandte, gesendet/gesandt"
      ],
      "collocations": [
        {
          "text": "eine E-Mail senden",
          "meaning": "to send an email"
        },
        {
          "text": "Unterlagen senden",
          "meaning": "to send documents"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Sendung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "absenden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يرسل؛ يبث"
        },
        {
          "language": "ckb",
          "text": "دەنێرێت؛ پەخش دەکات"
        },
        {
          "language": "en",
          "text": "to send; to broadcast"
        },
        {
          "language": "fa",
          "text": "فرستادن؛ ارسال کردن؛ پخش کردن"
        },
        {
          "language": "kmr",
          "text": "şandin; weşandin"
        },
        {
          "language": "pl",
          "text": "wysyłać; nadawać"
        },
        {
          "language": "ro",
          "text": "a trimite; a difuza"
        },
        {
          "language": "ru",
          "text": "отправлять; передавать"
        },
        {
          "language": "sq",
          "text": "të dërgosh; të transmetosh"
        },
        {
          "language": "tr",
          "text": "göndermek; yayınlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte senden Sie uns die fehlenden Unterlagen per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال المستندات الناقصة إلينا عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "تکایە بەڵگەنامە کەمەکان بە ئیمەیڵ بۆمان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us the missing documents by email."
            },
            {
              "language": "fa",
              "text": "لطفاً مدارک ناقص را از طریق ایمیل برای ما ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeyên kêm bi e-nameyê ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać nam brakujące dokumenty e-mailem."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți documentele lipsă prin e-mail."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам недостающие документы по электронной почте."
            },
            {
              "language": "sq",
              "text": "Ju lutem na dërgoni dokumentet që mungojnë me email."
            },
            {
              "language": "tr",
              "text": "Lütfen eksik belgeleri bize e-posta ile gönderin."
            }
          ]
        },
        {
          "baseText": "Das System sendet automatisch eine Bestätigung an den Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "يرسل النظام تلقائيًا تأكيدًا إلى العميل."
            },
            {
              "language": "ckb",
              "text": "سیستەمەکە بە شێوەیەکی ئۆتۆماتیکی پشتڕاستکردنەوە بۆ کڕیار دەنێرێت."
            },
            {
              "language": "en",
              "text": "The system automatically sends a confirmation to the customer."
            },
            {
              "language": "fa",
              "text": "سیستم به‌صورت خودکار یک تأییدیه برای مشتری ارسال می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pergal bixweber pejirandinek ji mişterî re dişîne."
            },
            {
              "language": "pl",
              "text": "System automatycznie wysyła potwierdzenie do klienta."
            },
            {
              "language": "ro",
              "text": "Sistemul trimite automat o confirmare către client."
            },
            {
              "language": "ru",
              "text": "Система автоматически отправляет клиенту подтверждение."
            },
            {
              "language": "sq",
              "text": "Sistemi i dërgon automatikisht një konfirmim klientit."
            },
            {
              "language": "tr",
              "text": "Sistem müşteriye otomatik olarak bir onay gönderir."
            }
          ]
        }
      ]
    },
