  "entries": [
    {
      "word": "selbstbewusst",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "selbst-be-wusst",
      "topics": [
        "work-and-jobs",
        "social-and-relationships",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "workplace",
        "formal",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; can describe a person or behavior"
      ],
      "collocations": [
        {
          "text": "selbstbewusst auftreten",
          "meaning": "to appear confident"
        },
        {
          "text": "eine selbstbewusste Antwort",
          "meaning": "a confident answer"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Selbstbewusstsein",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "bewusst",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "واثق من نفسه"
        },
        {
          "language": "ckb",
          "text": "بەخۆباوەڕ؛ دڵنیا لە خۆی"
        },
        {
          "language": "en",
          "text": "self-confident; confident"
        },
        {
          "language": "fa",
          "text": "بااعتمادبه‌نفس؛ مطمئن به خود"
        },
        {
          "language": "kmr",
          "text": "bi xwe bawer; xwebawer"
        },
        {
          "language": "pl",
          "text": "pewny siebie"
        },
        {
          "language": "ro",
          "text": "încrezător în sine"
        },
        {
          "language": "ru",
          "text": "уверенный в себе"
        },
        {
          "language": "sq",
          "text": "me vetëbesim"
        },
        {
          "language": "tr",
          "text": "özgüvenli"
        }
      ],
      "examples": [
        {
          "baseText": "Im Vorstellungsgespräch wirkte sie ruhig und selbstbewusst.",
          "translations": [
            {
              "language": "ar",
              "text": "في مقابلة العمل بدت هادئة وواثقة من نفسها."
            },
            {
              "language": "ckb",
              "text": "لە چاوپێکەوتنی کاردا ئارام و بەخۆباوەڕ دیار بوو."
            },
            {
              "language": "en",
              "text": "In the job interview, she seemed calm and confident."
            },
            {
              "language": "fa",
              "text": "در مصاحبه کاری آرام و بااعتمادبه‌نفس به نظر می‌رسید."
            },
            {
              "language": "kmr",
              "text": "Di hevpeyvîna kar de ew aram û xwebawer xuya dikir."
            },
            {
              "language": "pl",
              "text": "Na rozmowie kwalifikacyjnej wydawała się spokojna i pewna siebie."
            },
            {
              "language": "ro",
              "text": "La interviul de angajare părea calmă și încrezătoare în sine."
            },
            {
              "language": "ru",
              "text": "На собеседовании она выглядела спокойной и уверенной в себе."
            },
            {
              "language": "sq",
              "text": "Në intervistën e punës ajo dukej e qetë dhe me vetëbesim."
            },
            {
              "language": "tr",
              "text": "İş görüşmesinde sakin ve özgüvenli görünüyordu."
            }
          ]
        },
        {
          "baseText": "Der neue Kollege stellt seine Ideen selbstbewusst im Team vor.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض الزميل الجديد أفكاره بثقة أمام الفريق."
            },
            {
              "language": "ckb",
              "text": "هاوکارە نوێیەکە بیرۆکەکانی بەخۆباوەڕی لە تیمەکەدا پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "The new colleague presents his ideas confidently to the team."
            },
            {
              "language": "fa",
              "text": "همکار جدید ایده‌هایش را با اعتمادبه‌نفس در تیم مطرح می‌کند."
            },
            {
              "language": "kmr",
              "text": "Hevkarê nû ramanên xwe bi xwebawerî di tîmê de pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Nowy kolega pewnie przedstawia swoje pomysły zespołowi."
            },
            {
              "language": "ro",
              "text": "Noul coleg își prezintă ideile cu încredere în echipă."
            },
            {
              "language": "ru",
              "text": "Новый коллега уверенно представляет свои идеи команде."
            },
            {
              "language": "sq",
              "text": "Kolegu i ri i prezanton idetë e tij me vetëbesim në ekip."
            },
            {
              "language": "tr",
              "text": "Yeni meslektaş fikirlerini ekipte özgüvenle sunuyor."
            }
          ]
        }
      ]
    },
    {
      "word": "senden",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
