      "examples": [
        {
          "baseText": "Die Fernsehsendung erklärt komplizierte Themen sehr einfach.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح البرنامج التلفزيوني موضوعات معقدة بطريقة بسيطة جدًا."
            },
            {
              "language": "ckb",
              "text": "بەرنامەی تەلەفزیۆنەکە بابەتە ئاڵۆزەکان زۆر بە سادەیی ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The TV program explains complicated topics very simply."
            },
            {
              "language": "fa",
              "text": "برنامه تلویزیونی موضوعات پیچیده را خیلی ساده توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Bernameya televîzyonê mijarên aloz pir hêsan şirove dike."
            },
            {
              "language": "pl",
              "text": "Program telewizyjny wyjaśnia skomplikowane tematy bardzo prosto."
            },
            {
              "language": "ro",
              "text": "Emisiunea TV explică subiecte complicate foarte simplu."
            },
            {
              "language": "ru",
              "text": "Телепередача очень просто объясняет сложные темы."
            },
            {
              "language": "sq",
              "text": "Emisioni televiziv shpjegon tema të ndërlikuara shumë thjesht."
            },
            {
              "language": "tr",
              "text": "Televizyon programı karmaşık konuları çok basit açıklar."
            }
          ]
        },
        {
          "baseText": "Am Abend schauen wir oft eine kurze Fernsehsendung über Reisen.",
          "translations": [
            {
              "language": "ar",
              "text": "في المساء نشاهد غالبًا برنامجًا تلفزيونيًا قصيرًا عن السفر."
            },
            {
              "language": "ckb",
              "text": "ئێواران زۆرجار بەرنامەیەکی کورتی تەلەفزیۆن دەربارەی گەشت دەبینین."
            },
            {
              "language": "en",
              "text": "In the evening, we often watch a short TV program about travel."
            },
            {
              "language": "fa",
              "text": "عصرها اغلب یک برنامه تلویزیونی کوتاه درباره سفر می‌بینیم."
            },
            {
              "language": "kmr",
              "text": "Êvaran em gelek caran bernameyeke kurt a televîzyonê li ser rêwîtî temaşe dikin."
            },
            {
              "language": "pl",
              "text": "Wieczorem często oglądamy krótki program telewizyjny o podróżach."
            },
            {
              "language": "ro",
              "text": "Seara ne uităm adesea la o scurtă emisiune TV despre călătorii."
            },
            {
              "language": "ru",
              "text": "По вечерам мы часто смотрим короткую телепередачу о путешествиях."
            },
            {
              "language": "sq",
              "text": "Në mbrëmje shpesh shohim një emision të shkurtër televiziv për udhëtimet."
            },
            {
              "language": "tr",
              "text": "Akşamları sık sık seyahat hakkında kısa bir televizyon programı izleriz."
            }
          ]
        }
      ]
    }
