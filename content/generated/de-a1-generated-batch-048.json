      "collocations": [
        {
          "text": "um den Tisch herum",
          "meaning": "around the table"
        },
        {
          "text": "hier herum",
          "meaning": "around here"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "حول؛ في الجوار"
        },
        {
          "language": "ckb",
          "text": "دەوروبەر؛ لە دەوری"
        },
        {
          "language": "en",
          "text": "around; about"
        },
        {
          "language": "fa",
          "text": "دور؛ اطراف"
        },
        {
          "language": "kmr",
          "text": "li dor; derdor"
        },
        {
          "language": "pl",
          "text": "wokół; dookoła"
        },
        {
          "language": "ro",
          "text": "în jur; pe aici"
        },
        {
          "language": "ru",
          "text": "вокруг; поблизости"
        },
        {
          "language": "sq",
          "text": "rreth; përreth"
        },
        {
          "language": "tr",
          "text": "etrafında; buralarda"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kinder laufen um den Tisch herum.",
          "translations": [
            {
              "language": "ar",
              "text": "الأطفال يركضون حول الطاولة."
            },
            {
              "language": "ckb",
              "text": "منداڵەکان لە دەوری مێزەکە ڕادەکەن."
            },
            {
              "language": "en",
              "text": "The children run around the table."
            },
            {
              "language": "fa",
              "text": "بچه‌ها دور میز می‌دوند."
            },
            {
              "language": "kmr",
              "text": "Zarok li dor maseyê direvin."
            },
            {
              "language": "pl",
              "text": "Dzieci biegają wokół stołu."
            },
            {
              "language": "ro",
              "text": "Copiii aleargă în jurul mesei."
            },
            {
              "language": "ru",
              "text": "Дети бегают вокруг стола."
            },
            {
              "language": "sq",
              "text": "Fëmijët vrapojnë rreth tavolinës."
            },
            {
              "language": "tr",
              "text": "Çocuklar masanın etrafında koşuyor."
            }
          ]
        },
        {
          "baseText": "Gibt es hier herum ein Café?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يوجد مقهى هنا في الجوار؟"
            },
            {
              "language": "ckb",
              "text": "لەم دەوروبەرە کافێ هەیە؟"
            },
            {
              "language": "en",
              "text": "Is there a café around here?"
            },
            {
              "language": "fa",
              "text": "اینجا اطرافش کافه‌ای هست؟"
            },
            {
              "language": "kmr",
              "text": "Li derdora vir kafeyek heye?"
            },
            {
              "language": "pl",
              "text": "Czy jest tu gdzieś w pobliżu kawiarnia?"
            },
            {
              "language": "ro",
              "text": "Este vreo cafenea pe aici?"
            },
            {
              "language": "ru",
              "text": "Здесь поблизости есть кафе?"
            },
            {
              "language": "sq",
              "text": "A ka ndonjë kafene këtu përreth?"
            },
            {
              "language": "tr",
              "text": "Buralarda bir kafe var mı?"
            }
          ]
        }
      ]
    },
