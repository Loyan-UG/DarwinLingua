        {
          "language": "ar",
          "text": "يطبخ؛ يغلي"
        },
        {
          "language": "ckb",
          "text": "چێشت لێنان؛ کوڵاندن"
        },
        {
          "language": "en",
          "text": "to cook; to boil"
        },
        {
          "language": "fa",
          "text": "پختن؛ جوشاندن"
        },
        {
          "language": "kmr",
          "text": "xwarin çêkirin; kelandin"
        },
        {
          "language": "pl",
          "text": "gotować"
        },
        {
          "language": "ro",
          "text": "a găti; a fierbe"
        },
        {
          "language": "ru",
          "text": "готовить; варить"
        },
        {
          "language": "sq",
          "text": "gatuaj; ziej"
        },
        {
          "language": "tr",
          "text": "pişirmek; kaynatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich koche heute Suppe.",
          "translations": [
            {
              "language": "ar",
              "text": "أطبخ اليوم حساءً."
            },
            {
              "language": "ckb",
              "text": "من ئەمڕۆ شۆربا لێدەنێم."
            },
            {
              "language": "en",
              "text": "I am cooking soup today."
            },
            {
              "language": "fa",
              "text": "من امروز سوپ می‌پزم."
            },
            {
              "language": "kmr",
              "text": "Ez îro şorbe çêdikim."
            },
            {
              "language": "pl",
              "text": "Dzisiaj gotuję zupę."
            },
            {
              "language": "ro",
              "text": "Astăzi gătesc supă."
            },
            {
              "language": "ru",
              "text": "Сегодня я готовлю суп."
            },
            {
              "language": "sq",
              "text": "Sot po gatuaj supë."
            },
            {
              "language": "tr",
              "text": "Bugün çorba pişiriyorum."
            }
          ]
        },
        {
          "baseText": "Die Kartoffeln kochen zehn Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "تُطهى البطاطا عشر دقائق."
            },
            {
              "language": "ckb",
              "text": "پەتاتەکان دە خولەک دەکوڵێن."
            },
            {
              "language": "en",
              "text": "The potatoes cook for ten minutes."
            },
            {
              "language": "fa",
              "text": "سیب‌زمینی‌ها ده دقیقه می‌پزند."
            },
            {
              "language": "kmr",
              "text": "Kartol deh xulekê dikeline."
            },
            {
              "language": "pl",
              "text": "Ziemniaki gotują się dziesięć minut."
            },
            {
              "language": "ro",
              "text": "Cartofii fierb zece minute."
            },
            {
              "language": "ru",
              "text": "Картошка варится десять минут."
            },
            {
              "language": "sq",
              "text": "Patatet ziejnë dhjetë minuta."
            },
            {
              "language": "tr",
              "text": "Patatesler on dakika pişiyor."
            }
          ]
        }
      ]
