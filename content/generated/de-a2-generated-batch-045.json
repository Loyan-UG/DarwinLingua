      ],
      "examples": [
        {
          "baseText": "Ich gratuliere dir zum Geburtstag.",
          "translations": [
            {
              "language": "ar",
              "text": "أهنئك بعيد ميلادك."
            },
            {
              "language": "ckb",
              "text": "پیرۆزبایی ڕۆژی لەدایکبوونت لێ دەکەم."
            },
            {
              "language": "en",
              "text": "I congratulate you on your birthday."
            },
            {
              "language": "fa",
              "text": "تولدت را به تو تبریک می‌گویم."
            },
            {
              "language": "kmr",
              "text": "Ez rojbûna te pîroz dikim."
            },
            {
              "language": "pl",
              "text": "Gratuluję ci urodzin."
            },
            {
              "language": "ro",
              "text": "Te felicit de ziua ta."
            },
            {
              "language": "ru",
              "text": "Я поздравляю тебя с днём рождения."
            },
            {
              "language": "sq",
              "text": "Të uroj për ditëlindjen."
            },
            {
              "language": "tr",
              "text": "Doğum gününü kutlarım."
            }
          ]
        },
        {
          "baseText": "Wir gratulieren unserer Kollegin zur Prüfung.",
          "translations": [
            {
              "language": "ar",
              "text": "نهنئ زميلتنا بالامتحان."
            },
            {
              "language": "ckb",
              "text": "پیرۆزبایی تاقیکردنەوەکە لە هاوکارەکەمان دەکەین."
            },
            {
              "language": "en",
              "text": "We congratulate our colleague on the exam."
            },
            {
              "language": "fa",
              "text": "ما به همکارمان برای امتحان تبریک می‌گوییم."
            },
            {
              "language": "kmr",
              "text": "Em ji hevkariya xwe re ji bo ezmûnê pîrozbahî dikin."
            },
            {
              "language": "pl",
              "text": "Gratulujemy naszej koleżance egzaminu."
            },
            {
              "language": "ro",
              "text": "O felicităm pe colega noastră pentru examen."
            },
            {
              "language": "ru",
              "text": "Мы поздравляем нашу коллегу с экзаменом."
            },
            {
              "language": "sq",
              "text": "E urojmë kolegen tonë për provimin."
            },
            {
              "language": "tr",
              "text": "İş arkadaşımızı sınav için tebrik ediyoruz."
            }
          ]
        }
      ]
