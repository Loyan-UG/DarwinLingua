      "examples": [
        {
          "baseText": "Die Grammatik ist heute nicht schwer.",
          "translations": [
            {
              "language": "ar",
              "text": "القواعد اليوم ليست صعبة."
            },
            {
              "language": "ckb",
              "text": "ڕێزمانەکە ئەمڕۆ قورس نییە."
            },
            {
              "language": "en",
              "text": "The grammar is not difficult today."
            },
            {
              "language": "fa",
              "text": "گرامر امروز سخت نیست."
            },
            {
              "language": "kmr",
              "text": "Rêziman îro ne dijwar e."
            },
            {
              "language": "pl",
              "text": "Gramatyka nie jest dziś trudna."
            },
            {
              "language": "ro",
              "text": "Gramatica nu este grea astăzi."
            },
            {
              "language": "ru",
              "text": "Грамматика сегодня не трудная."
            },
            {
              "language": "sq",
              "text": "Gramatika sot nuk është e vështirë."
            },
            {
              "language": "tr",
              "text": "Bugünkü dil bilgisi zor değil."
            }
          ]
        },
        {
          "baseText": "Ich übe die Grammatik mit kurzen Sätzen.",
          "translations": [
            {
              "language": "ar",
              "text": "أتدرب على القواعد بجمل قصيرة."
            },
            {
              "language": "ckb",
              "text": "ڕێزمان بە ڕستەی کورت ڕاهێنان دەکەم."
            },
            {
              "language": "en",
              "text": "I practice grammar with short sentences."
            },
            {
              "language": "fa",
              "text": "گرامر را با جمله‌های کوتاه تمرین می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez rêzimanê bi hevokên kurt fêr dibim."
            },
            {
              "language": "pl",
              "text": "Ćwiczę gramatykę krótkimi zdaniami."
            },
            {
              "language": "ro",
              "text": "Exersez gramatica cu propoziții scurte."
            },
            {
              "language": "ru",
              "text": "Я тренирую грамматику короткими предложениями."
            },
            {
              "language": "sq",
              "text": "E ushtroj gramatikën me fjali të shkurtra."
            },
            {
              "language": "tr",
              "text": "Dil bilgisini kısa cümlelerle çalışıyorum."
            }
          ]
        }
