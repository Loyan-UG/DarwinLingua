  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "durchschießen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "durchschießen",
      "syllableBreak": "durch-schie-ßen",
      "topics": [
        "quality-and-risk",
        "production-and-maintenance",
        "technology-and-it"
      ],
      "usageLabels": [
        "technical",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; literal shooting through or figurative sudden surge"
      ],
      "collocations": [
        {
          "text": "durch die Decke schießen",
          "meaning": "to shoot through the roof"
        },
        {
          "text": "ein Schmerz schießt durch den Arm",
          "meaning": "a pain shoots through the arm"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schießen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يندفع عبر؛ يرتفع فجأة"
        },
        {
          "language": "ckb",
          "text": "بە خێرایی تێدەپەڕێت؛ لەناکاو بەرز دەبێت"
        },
        {
          "language": "en",
          "text": "to shoot through; to surge suddenly"
        },
        {
          "language": "fa",
          "text": "با سرعت عبور کردن؛ ناگهان جهش کردن"
        },
        {
          "language": "kmr",
          "text": "bi lez derbas bûn; ji nişka ve zêde bûn"
        },
        {
          "language": "pl",
          "text": "przestrzelić; gwałtownie wzrosnąć"
        },
        {
          "language": "ro",
          "text": "a străbate brusc; a crește brusc"
        },
        {
          "language": "ru",
          "text": "простреливать; резко подскакивать"
        },
        {
          "language": "sq",
          "text": "të kalojë vrullshëm; të rritet papritur"
        },
        {
          "language": "tr",
          "text": "hızla geçmek; aniden fırlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Preisänderung schossen die Supportanfragen innerhalb weniger Stunden durch die Decke.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تغيير السعر قفزت طلبات الدعم خلال ساعات قليلة إلى مستوى عالٍ جدًا."
            },
            {
              "language": "ckb",
              "text": "دوای گۆڕانی نرخەکە، داواکارییەکانی پاڵپشتی لە ماوەی چەند کاتژمێرێکدا بە توندی بەرز بوونەوە."
            },
            {
              "language": "en",
              "text": "After the price change, support requests shot through the roof within a few hours."
            },
            {
              "language": "fa",
              "text": "پس از تغییر قیمت، درخواست‌های پشتیبانی ظرف چند ساعت به‌شدت جهش کردند."
            },
            {
              "language": "kmr",
              "text": "Piştî guherîna bihayê, daxwazên piştgiriyê di çend saetan de gelek zêde bûn."
            },
            {
              "language": "pl",
              "text": "Po zmianie ceny liczba zgłoszeń do supportu w ciągu kilku godzin gwałtownie wzrosła."
            },
            {
              "language": "ro",
              "text": "După schimbarea prețului, solicitările de suport au explodat în câteva ore."
            },
            {
              "language": "ru",
              "text": "После изменения цены запросы в поддержку за несколько часов резко взлетели."
            },
            {
              "language": "sq",
              "text": "Pas ndryshimit të çmimit, kërkesat për suport u rritën shumë brenda pak orësh."
            },
            {
              "language": "tr",
              "text": "Fiyat değişikliğinden sonra destek talepleri birkaç saat içinde tavana fırladı."
            }
          ]
        },
        {
          "baseText": "Beim Anheben der Kiste schoss ihm ein stechender Schmerz durch den Rücken.",
          "translations": [
            {
              "language": "ar",
              "text": "عند رفع الصندوق اندفع ألم حاد في ظهره."
            },
            {
              "language": "ckb",
              "text": "لە کاتی هەڵگرتنی سندووقەکەدا ئازارێکی تیز بە پشتی دا تێپەڕی."
            },
            {
              "language": "en",
              "text": "When lifting the box, a sharp pain shot through his back."
            },
            {
              "language": "fa",
              "text": "هنگام بلند کردن جعبه، درد تیزی در کمرش تیر کشید."
            },
            {
              "language": "kmr",
              "text": "Dema qutiyê hilda, êşeke tûj ji pişta wî derbas bû."
            },
            {
              "language": "pl",
              "text": "Podczas podnoszenia skrzyni przeszył go ostry ból pleców."
            },
            {
              "language": "ro",
              "text": "Când a ridicat cutia, o durere ascuțită i-a străbătut spatele."
            },
            {
              "language": "ru",
              "text": "Когда он поднимал коробку, резкая боль прострелила спину."
            },
            {
              "language": "sq",
              "text": "Kur ngriti kutinë, një dhimbje e mprehtë i përshkoi shpinën."
            },
            {
              "language": "tr",
              "text": "Kutuyu kaldırırken sırtına keskin bir ağrı saplandı."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "durchschlagen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "durchschlagen",
      "syllableBreak": "durch-schla-gen",
      "topics": [
        "finance-and-accounting",
        "quality-and-risk",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; often sich auf etwas durchschlagen means to have an effect on something"
      ],
      "collocations": [
        {
          "text": "auf die Kosten durchschlagen",
          "meaning": "to impact costs"
        },
        {
          "text": "sich bis zum Kunden durchschlagen",
          "meaning": "to affect the customer eventually"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schlagen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يؤثر في النهاية؛ يخترق بضربة"
        },
        {
          "language": "ckb",
          "text": "لە کۆتاییدا کاریگەری دەکات؛ بە لێدان تێدەپەڕێت"
        },
        {
          "language": "en",
          "text": "to have an eventual impact; to punch through"
        },
        {
          "language": "fa",
          "text": "اثر گذاشتن در نهایت؛ با ضربه سوراخ کردن"
        },
        {
          "language": "kmr",
          "text": "di dawiyê de bandor kirin; bi lêdan derbas kirin"
        },
        {
          "language": "pl",
          "text": "odbić się na; przebić"
        },
        {
          "language": "ro",
          "text": "a se repercuta; a străpunge"
        },
        {
          "language": "ru",
          "text": "сказываться; пробивать"
        },
        {
          "language": "sq",
          "text": "të ndikojë më në fund; të shpërthejë"
        },
        {
          "language": "tr",
          "text": "etkisini göstermek; delip geçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die höheren Energiekosten schlagen inzwischen deutlich auf die Produktionspreise durch.",
          "translations": [
            {
              "language": "ar",
              "text": "أصبحت تكاليف الطاقة الأعلى تؤثر الآن بوضوح في أسعار الإنتاج."
            },
            {
              "language": "ckb",
              "text": "تێچووی بەرزی وزە ئێستا بە ڕوونی کاریگەری لەسەر نرخی بەرهەمهێنان دەکات."
            },
            {
              "language": "en",
              "text": "The higher energy costs are now clearly feeding through to production prices."
            },
            {
              "language": "fa",
              "text": "هزینه‌های بالاتر انرژی اکنون به‌وضوح بر قیمت‌های تولید اثر گذاشته است."
            },
            {
              "language": "kmr",
              "text": "Lêçûnên bilind ên enerjiyê niha bi eşkere li ser bihayên hilberînê bandor dikin."
            },
            {
              "language": "pl",
              "text": "Wyższe koszty energii wyraźnie odbijają się już na cenach produkcji."
            },
            {
              "language": "ro",
              "text": "Costurile mai mari ale energiei se repercutează acum clar asupra prețurilor de producție."
            },
            {
              "language": "ru",
              "text": "Более высокие энергозатраты теперь явно сказываются на производственных ценах."
            },
            {
              "language": "sq",
              "text": "Kostot më të larta të energjisë tani po ndikojnë qartë te çmimet e prodhimit."
            },
            {
              "language": "tr",
              "text": "Yüksek enerji maliyetleri artık üretim fiyatlarına açıkça yansıyor."
            }
          ]
        },
        {
          "baseText": "Beim Bohren schlug der Bohrer unerwartet durch die dünne Rückwand durch.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء الثقب اخترق المثقاب الجدار الخلفي الرقيق بشكل غير متوقع."
            },
            {
              "language": "ckb",
              "text": "لە کاتی کونکردندا، بڕینەکەرەکە بە نەچاوەڕوانی لە دیواری پاشەوەی باریک تێپەڕی."
            },
            {
              "language": "en",
              "text": "While drilling, the drill unexpectedly went through the thin back panel."
            },
            {
              "language": "fa",
              "text": "هنگام سوراخ‌کاری، مته به‌طور غیرمنتظره از دیواره نازک پشت عبور کرد."
            },
            {
              "language": "kmr",
              "text": "Dema qul dikir, bor bi neçaverêkirî ji dîwarê paşê yê tenik derbas bû."
            },
            {
              "language": "pl",
              "text": "Podczas wiercenia wiertło niespodziewanie przebiło cienką tylną ściankę."
            },
            {
              "language": "ro",
              "text": "În timpul găuririi, burghiul a străpuns neașteptat peretele subțire din spate."
            },
            {
              "language": "ru",
              "text": "При сверлении сверло неожиданно пробило тонкую заднюю стенку."
            },
            {
              "language": "sq",
              "text": "Gjatë shpimit, burgia papritur e shpoi panelin e hollë të pasmë."
            },
            {
              "language": "tr",
              "text": "Delme sırasında matkap ince arka paneli beklenmedik şekilde delip geçti."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "durchstoßen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "durchstoßen",
      "syllableBreak": "durch-sto-ßen",
      "topics": [
        "production-and-maintenance",
        "advanced-analysis",
        "quality-and-risk"
      ],
      "usageLabels": [
        "technical",
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; means to pierce/break through or exceed a limit"
      ],
      "collocations": [
        {
          "text": "eine Grenze durchstoßen",
          "meaning": "to break through a limit"
        },
        {
          "text": "eine Wand durchstoßen",
          "meaning": "to break through a wall"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "stoßen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يخترق؛ يتجاوز حدًا"
        },
        {
          "language": "ckb",
          "text": "تێدەپەڕێت؛ سنوورێک دەشکێنێت"
        },
        {
          "language": "en",
          "text": "to break through; to pierce; to exceed"
        },
        {
          "language": "fa",
          "text": "عبور کردن از سد؛ سوراخ کردن؛ از حد گذشتن"
        },
        {
          "language": "kmr",
          "text": "têperîn; sînor şikandin"
        },
        {
          "language": "pl",
          "text": "przebić; przekroczyć"
        },
        {
          "language": "ro",
          "text": "a străpunge; a depăși"
        },
        {
          "language": "ru",
          "text": "пробивать; преодолевать предел"
        },
        {
          "language": "sq",
          "text": "të çash; të tejkalosh"
        },
        {
          "language": "tr",
          "text": "delip geçmek; sınırı aşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Umsatz hat erstmals die Marke von zehn Millionen Euro durchstoßen.",
          "translations": [
            {
              "language": "ar",
              "text": "تجاوزت الإيرادات لأول مرة حاجز عشرة ملايين يورو."
            },
            {
              "language": "ckb",
              "text": "داهات بۆ یەکەم جار سنووری دە ملیۆن یۆرۆی تێپەڕاند."
            },
            {
              "language": "en",
              "text": "Revenue has broken through the ten-million-euro mark for the first time."
            },
            {
              "language": "fa",
