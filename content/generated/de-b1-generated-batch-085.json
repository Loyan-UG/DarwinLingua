  "entries": [
    {
      "word": "die Kündigung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kündigungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kün-di-gung",
      "topics": [
        "contracts-and-negotiation",
        "work-and-jobs",
        "housing-and-real-estate"
      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; termination notice for a contract, job, or rental agreement"
      ],
      "collocations": [
        {
          "text": "eine Kündigung schreiben",
          "meaning": "to write a notice of termination"
        },
        {
          "text": "die Kündigung erhalten",
          "meaning": "to receive a termination notice"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kündigen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Kündigungsfrist",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إنهاء؛ إشعار إنهاء"
        },
        {
          "language": "ckb",
          "text": "هەڵوەشاندنەوە؛ ئاگاداری کۆتایی"
        },
        {
          "language": "en",
          "text": "termination; notice of termination"
        },
        {
          "language": "fa",
          "text": "فسخ؛ اعلام پایان قرارداد"
        },
        {
          "language": "kmr",
          "text": "betalkirin; agahdariya dawî"
        },
        {
          "language": "pl",
          "text": "wypowiedzenie"
        },
        {
          "language": "ro",
          "text": "reziliere; notificare de încetare"
        },
        {
          "language": "ru",
          "text": "расторжение; уведомление об увольнении/расторжении"
        },
        {
          "language": "sq",
          "text": "ndërprerje; njoftim për përfundim"
        },
        {
          "language": "tr",
          "text": "fesih; işten ayrılma bildirimi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kündigung des Mietvertrags muss schriftlich erfolgen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن يتم إنهاء عقد الإيجار كتابةً."
            },
            {
              "language": "ckb",
              "text": "هەڵوەشاندنەوەی گرێبەستی کرێ دەبێت بە نووسراوەیی بێت."
            },
            {
              "language": "en",
              "text": "The termination of the rental contract must be made in writing."
            },
            {
              "language": "fa",
              "text": "فسخ قرارداد اجاره باید به صورت کتبی انجام شود."
            },
            {
              "language": "kmr",
              "text": "Betalkirina peymana kirê divê bi nivîskî bê kirin."
            },
            {
              "language": "pl",
              "text": "Wypowiedzenie umowy najmu musi nastąpić na piśmie."
            },
            {
              "language": "ro",
              "text": "Rezilierea contractului de închiriere trebuie făcută în scris."
            },
            {
              "language": "ru",
              "text": "Расторжение договора аренды должно быть оформлено письменно."
            },
            {
              "language": "sq",
              "text": "Ndërprerja e kontratës së qirasë duhet të bëhet me shkrim."
            },
            {
              "language": "tr",
              "text": "Kira sözleşmesinin feshi yazılı olarak yapılmalıdır."
            }
          ]
        },
        {
          "baseText": "Nach der Kündigung ihres alten Jobs sucht sie eine neue Stelle im Support.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد ترك وظيفتها القديمة تبحث عن وظيفة جديدة في الدعم."
            },
            {
              "language": "ckb",
              "text": "دوای کۆتاییهێنان بە کاری کۆنی، بەدوای شوێنی کارێکی نوێ لە پشتگیری دەگەڕێت."
            },
            {
              "language": "en",
              "text": "After leaving her old job, she is looking for a new position in support."
            },
            {
              "language": "fa",
              "text": "بعد از پایان کار قبلی‌اش، دنبال موقعیت جدیدی در پشتیبانی است."
            },
            {
              "language": "kmr",
              "text": "Piştî devberdana ji karê xwe yê kevn, ew li cihê karekî nû di piştgiriyê de digere."
            },
            {
              "language": "pl",
              "text": "Po wypowiedzeniu starej pracy szuka nowego stanowiska w dziale wsparcia."
            },
            {
              "language": "ro",
              "text": "După încetarea vechiului loc de muncă, caută un post nou în suport."
            },
            {
              "language": "ru",
              "text": "После ухода со старой работы она ищет новую должность в поддержке."
            },
            {
              "language": "sq",
              "text": "Pas largimit nga puna e vjetër, ajo kërkon një pozicion të ri në mbështetje."
            },
            {
              "language": "tr",
              "text": "Eski işinden ayrıldıktan sonra destek bölümünde yeni bir pozisyon arıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Kündigungsfrist",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kündigungsfristen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kün-di-gungs-frist",
      "topics": [
        "contracts-and-negotiation",
        "work-and-jobs",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; required notice period before ending a contract"
      ],
      "collocations": [
        {
          "text": "die Kündigungsfrist einhalten",
          "meaning": "to observe the notice period"
        },
        {
          "text": "eine Kündigungsfrist von drei Monaten",
          "meaning": "a notice period of three months"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kündigung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Frist",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مهلة الإشعار؛ فترة الإنهاء"
        },
        {
          "language": "ckb",
          "text": "ماوەی ئاگادارکردنەوەی کۆتایی"
        },
        {
          "language": "en",
          "text": "notice period"
        },
        {
          "language": "fa",
          "text": "مهلت فسخ؛ دوره اعلام پایان قرارداد"
        },
        {
          "language": "kmr",
          "text": "dema agahdarkirina dawî"
        },
        {
          "language": "pl",
          "text": "okres wypowiedzenia"
        },
        {
          "language": "ro",
          "text": "perioadă de preaviz"
        },
        {
          "language": "ru",
          "text": "срок уведомления; срок расторжения"
        },
        {
          "language": "sq",
          "text": "afat njoftimi për ndërprerje"
        },
        {
          "language": "tr",
          "text": "fesih bildirim süresi; ihbar süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Im Vertrag steht eine Kündigungsfrist von vier Wochen.",
          "translations": [
            {
              "language": "ar",
              "text": "ينص العقد على مهلة إشعار مدتها أربعة أسابيع."
            },
            {
              "language": "ckb",
              "text": "لە گرێبەستەکەدا ماوەی ئاگادارکردنەوەی چوار هەفتە نووسراوە."
            },
            {
              "language": "en",
              "text": "The contract states a notice period of four weeks."
            },
            {
              "language": "fa",
              "text": "در قرارداد مهلت فسخ چهار هفته ذکر شده است."
            },
            {
              "language": "kmr",
              "text": "Di peymanê de dema agahdarkirinê ya çar hefteyan hatiye nivîsandin."
            },
            {
              "language": "pl",
              "text": "W umowie jest zapisany czterotygodniowy okres wypowiedzenia."
            },
            {
              "language": "ro",
              "text": "În contract este prevăzută o perioadă de preaviz de patru săptămâni."
            },
            {
              "language": "ru",
              "text": "В договоре указан срок уведомления четыре недели."
            },
            {
              "language": "sq",
              "text": "Në kontratë është shkruar një afat njoftimi prej katër javësh."
            },
            {
              "language": "tr",
              "text": "Sözleşmede dört haftalık ihbar süresi yazıyor."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie die Kündigungsfrist, bevor Sie das Abo beenden.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق من مهلة الإشعار قبل إنهاء الاشتراك."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش کۆتاییهێنان بە ئەبۆنەکە ماوەی ئاگادارکردنەوە بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the notice period before you cancel the subscription."
            },
            {
              "language": "fa",
