      "collocations": [
        {
          "text": "fünf Minuten warten",
          "meaning": "to wait five minutes"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دقيقة"
        },
        {
          "language": "ckb",
          "text": "خولەک"
        },
        {
          "language": "en",
          "text": "minute"
        },
        {
          "language": "fa",
          "text": "دقیقه"
        },
        {
          "language": "kmr",
          "text": "xulek"
        },
        {
          "language": "pl",
          "text": "minuta"
        },
        {
          "language": "ro",
          "text": "minut"
        },
        {
          "language": "ru",
          "text": "минута"
        },
        {
          "language": "sq",
          "text": "minutë"
        },
        {
          "language": "tr",
          "text": "dakika"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte warten Sie fünf Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك انتظر خمس دقائق."
            },
            {
              "language": "ckb",
              "text": "تکایە پێنج خولەک چاوەڕێ بکە."
            },
            {
              "language": "en",
              "text": "Please wait five minutes."
            },
            {
              "language": "fa",
              "text": "لطفاً پنج دقیقه صبر کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pênc xulek bisekinin."
            },
            {
              "language": "pl",
              "text": "Proszę poczekać pięć minut."
            },
            {
              "language": "ro",
              "text": "Vă rog să așteptați cinci minute."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, подождите пять минут."
            },
            {
              "language": "sq",
              "text": "Ju lutem prisni pesë minuta."
            },
            {
              "language": "tr",
              "text": "Lütfen beş dakika bekleyin."
            }
          ]
        },
        {
          "baseText": "Der Termin dauert zehn Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "يستغرق الموعد عشر دقائق."
            },
            {
              "language": "ckb",
              "text": "چاوپێکەوتنەکە دە خولەک دەخایەنێت."
            },
            {
              "language": "en",
              "text": "The appointment takes ten minutes."
            },
            {
              "language": "fa",
              "text": "قرار ده دقیقه طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Hevdîtin deh xulek didome."
            },
            {
              "language": "pl",
              "text": "Spotkanie trwa dziesięć minut."
            },
            {
              "language": "ro",
              "text": "Programarea durează zece minute."
            },
            {
              "language": "ru",
              "text": "Встреча длится десять минут."
            },
            {
              "language": "sq",
              "text": "Takimi zgjat dhjetë minuta."
            },
            {
              "language": "tr",
              "text": "Randevu on dakika sürer."
            }
          ]
        }
      ]
    },
