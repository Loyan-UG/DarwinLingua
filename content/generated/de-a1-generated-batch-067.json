      "examples": [
        {
          "baseText": "Kannst du mir helfen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك مساعدتي؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت یارمەتیم بدەیت؟"
            },
            {
              "language": "en",
              "text": "Can you help me?"
            },
            {
              "language": "fa",
              "text": "می‌توانی به من کمک کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî alîkariya min bikî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz mi pomóc?"
            },
            {
              "language": "ro",
              "text": "Poți să mă ajuți?"
            },
            {
              "language": "ru",
              "text": "Ты можешь мне помочь?"
            },
            {
              "language": "sq",
              "text": "A mund të më ndihmosh?"
            },
            {
              "language": "tr",
              "text": "Bana yardım edebilir misin?"
            }
          ]
        },
        {
          "baseText": "Bitte geben Sie mir das Formular.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك أعطني الاستمارة."
            },
            {
              "language": "ckb",
              "text": "تکایە فۆرمەکە بدە بە من."
            },
            {
              "language": "en",
              "text": "Please give me the form."
            },
            {
              "language": "fa",
              "text": "لطفاً فرم را به من بدهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe formê bidin min."
            },
            {
              "language": "pl",
              "text": "Proszę dać mi formularz."
            },
            {
              "language": "ro",
              "text": "Vă rog să-mi dați formularul."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, дайте мне форму."
            },
            {
              "language": "sq",
              "text": "Ju lutem ma jepni formularin."
            },
            {
              "language": "tr",
              "text": "Lütfen formu bana verin."
            }
          ]
        }
      ]
