        "customer-service",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "polite",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine weak noun: den/dem/des Patienten; female form: die Patientin"
      ],
      "collocations": [
        {
          "text": "den Patienten untersuchen",
          "meaning": "to examine the patient"
        },
        {
          "text": "ein neuer Patient",
          "meaning": "a new patient"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Patientin",
