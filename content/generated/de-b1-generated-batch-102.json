  "entries": [
    {
      "word": "die Parkgebühr",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Parkgebühren",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Park-ge-bühr",
      "topics": [
        "transport-and-travel",
        "shopping-and-services",
        "public-services"
      ],
      "usageLabels": [
        "everyday",
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "Parkgebühren bezahlen",
          "meaning": "to pay parking fees"
        },
        {
          "text": "hohe Parkgebühren",
          "meaning": "high parking fees"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "parken",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Gebühr",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "رسوم الوقوف؛ أجرة parking"
        },
        {
          "language": "ckb",
          "text": "پارەی وەستاندنی ئۆتۆمبێل"
        },
        {
          "language": "en",
          "text": "parking fee"
        },
        {
          "language": "fa",
          "text": "هزینه پارک؛ عوارض پارکینگ"
        },
        {
          "language": "kmr",
          "text": "heqê park kirinê"
        },
        {
          "language": "pl",
          "text": "opłata parkingowa"
        },
        {
          "language": "ro",
          "text": "taxă de parcare"
        },
        {
          "language": "ru",
          "text": "плата за парковку"
        },
        {
          "language": "sq",
          "text": "tarifë parkimi"
        },
        {
          "language": "tr",
          "text": "park ücreti"
        }
      ],
      "examples": [
        {
          "baseText": "Die Parkgebühr kann man direkt am Automaten bezahlen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن دفع رسوم الوقوف مباشرة عند الجهاز."
            },
            {
              "language": "ckb",
              "text": "دەتوانرێت پارەی وەستاندن ڕاستەوخۆ لە ئامێرەکە بدرێت."
            },
            {
              "language": "en",
              "text": "You can pay the parking fee directly at the machine."
            },
            {
              "language": "fa",
              "text": "می‌توان هزینه پارک را مستقیم در دستگاه پرداخت کرد."
            },
            {
              "language": "kmr",
              "text": "Mirov dikare heqê park kirinê rasterast li makîneyê bide."
            },
            {
              "language": "pl",
              "text": "Opłatę parkingową można zapłacić bezpośrednio w automacie."
            },
            {
              "language": "ro",
              "text": "Taxa de parcare se poate plăti direct la automat."
            },
            {
              "language": "ru",
              "text": "Плату за парковку можно оплатить прямо в автомате."
            },
            {
              "language": "sq",
              "text": "Tarifa e parkimit mund të paguhet direkt te automati."
            },
            {
              "language": "tr",
              "text": "Park ücreti doğrudan makinede ödenebilir."
            }
          ]
        },
        {
          "baseText": "Für Kunden erstatten wir die Parkgebühr bis zu zwei Stunden.",
          "translations": [
            {
              "language": "ar",
              "text": "نعوّض للعملاء رسوم الوقوف لمدة تصل إلى ساعتين."
            },
            {
              "language": "ckb",
              "text": "بۆ کڕیاران پارەی وەستاندن تا دوو کاتژمێر دەگەڕێنینەوە."
            },
            {
              "language": "en",
              "text": "For customers, we reimburse the parking fee for up to two hours."
            },
            {
              "language": "fa",
              "text": "برای مشتریان، هزینه پارک را تا دو ساعت بازپرداخت می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Ji bo mişteriyan em heqê park kirinê heta du saetan vedigerînin."
            },
            {
              "language": "pl",
              "text": "Klientom zwracamy opłatę parkingową do dwóch godzin."
            },
            {
              "language": "ro",
              "text": "Pentru clienți rambursăm taxa de parcare până la două ore."
            },
            {
              "language": "ru",
              "text": "Клиентам мы возмещаем плату за парковку до двух часов."
            },
            {
              "language": "sq",
              "text": "Për klientët rimbursojmë tarifën e parkimit deri në dy orë."
            },
            {
              "language": "tr",
              "text": "Müşteriler için park ücretini iki saate kadar geri ödüyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "der Patient",
      "language": "de",
