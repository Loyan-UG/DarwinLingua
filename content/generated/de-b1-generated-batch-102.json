        },
        {
          "lemma": "die Patientenverfügung",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مريض"
        },
        {
          "language": "ckb",
          "text": "نەخۆش؛ پەیشنێت"
        },
        {
          "language": "en",
          "text": "patient; male patient"
        },
        {
          "language": "fa",
          "text": "بیمار؛ بیمار مرد"
        },
        {
          "language": "kmr",
          "text": "nexweş; nexweşê mêr"
        },
        {
          "language": "pl",
          "text": "pacjent"
        },
        {
          "language": "ro",
          "text": "pacient"
        },
        {
          "language": "ru",
          "text": "пациент"
        },
        {
          "language": "sq",
          "text": "pacient"
        },
        {
          "language": "tr",
          "text": "hasta; erkek hasta"
        }
      ],
      "examples": [
        {
          "baseText": "Der Patient wartet seit zehn Minuten im Behandlungszimmer.",
          "translations": [
            {
              "language": "ar",
              "text": "ينتظر المريض منذ عشر دقائق في غرفة العلاج."
            },
            {
              "language": "ckb",
              "text": "نەخۆشەکە لە ژووری چارەسەردا دە خولەکە چاوەڕێیە."
            },
            {
              "language": "en",
              "text": "The patient has been waiting in the treatment room for ten minutes."
            },
            {
              "language": "fa",
              "text": "بیمار ده دقیقه است در اتاق معاینه منتظر است."
            },
            {
              "language": "kmr",
              "text": "Nexweş deh deqîqeyan e li odeya dermankirinê li bendê ye."
            },
            {
              "language": "pl",
              "text": "Pacjent czeka od dziesięciu minut w gabinecie zabiegowym."
            },
            {
              "language": "ro",
              "text": "Pacientul așteaptă de zece minute în sala de tratament."
            },
            {
              "language": "ru",
              "text": "Пациент уже десять минут ждёт в процедурном кабинете."
            },
            {
              "language": "sq",
              "text": "Pacienti po pret prej dhjetë minutash në dhomën e trajtimit."
            },
            {
              "language": "tr",
              "text": "Hasta on dakikadır tedavi odasında bekliyor."
            }
          ]
        },
        {
          "baseText": "Bitte geben Sie dem Patienten den nächsten Termin mit.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إعطاء المريض الموعد القادم."
            },
            {
              "language": "ckb",
              "text": "تکایە کاتی داهاتوو بدەن بە نەخۆشەکە."
            },
            {
              "language": "en",
              "text": "Please give the patient the next appointment."
            },
            {
              "language": "fa",
              "text": "لطفاً وقت بعدی را به بیمار بدهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe hevdîtina bê bidin nexweş."
            },
            {
              "language": "pl",
              "text": "Proszę dać pacjentowi następny termin."
            },
            {
              "language": "ro",
              "text": "Vă rog să îi dați pacientului următoarea programare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, дайте пациенту следующий приём."
            },
            {
              "language": "sq",
              "text": "Ju lutem jepini pacientit takimin e ardhshëm."
            },
            {
              "language": "tr",
              "text": "Lütfen hastaya bir sonraki randevuyu verin."
            }
          ]
        }
      ]
    },
