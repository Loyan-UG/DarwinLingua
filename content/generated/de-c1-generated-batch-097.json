      "word": "die Spannbreite",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Spannbreiten",
      "infinitive": null,
      "syllableBreak": "Spann-brei-te",
      "topics": [
        "data-and-reporting",
        "advanced-analysis",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "business",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine große Spannbreite aufweisen",
          "meaning": "to show a wide range"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "spannen",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "breit",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "نطاق؛ مدى"
        },
        {
          "language": "ckb",
          "text": "مەودا؛ بازنەی جیاوازی"
        },
        {
          "language": "en",
          "text": "range; span"
        },
        {
          "language": "fa",
          "text": "دامنه؛ بازه"
        },
        {
          "language": "kmr",
          "text": "navber; firehiya qadê"
        },
        {
          "language": "pl",
          "text": "rozpiętość; zakres"
        },
        {
          "language": "ro",
          "text": "interval; amplitudine"
        },
        {
          "language": "ru",
          "text": "диапазон; разброс"
        },
        {
          "language": "sq",
          "text": "shtrirje; diapazon"
        },
        {
          "language": "tr",
          "text": "aralık; genişlik"
        }
      ],
      "examples": [
        {
          "baseText": "Die Spannbreite der Angebote reicht von einfachen Supportpaketen bis zu vollständig betreuten Lösungen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمتد نطاق العروض من حزم دعم بسيطة إلى حلول مُدارة بالكامل."
            },
            {
              "language": "ckb",
              "text": "مەودای پێشکەشکارییەکان لە پاکێجی پشتگیری سادەوە تا چارەسەری تەواو بەڕێوەبردراو دەگات."
            },
            {
              "language": "en",
              "text": "The range of offers extends from simple support packages to fully managed solutions."
            },
            {
              "language": "fa",
              "text": "دامنه پیشنهادها از بسته‌های ساده پشتیبانی تا راه‌حل‌های کاملاً مدیریت‌شده را در بر می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Firehiya pêşniyaran ji pakêtên piştgiriyê yên hêsan heta çareseriyên bi tevahî rêvebirî digihîje."
            },
            {
              "language": "pl",
              "text": "Rozpiętość ofert sięga od prostych pakietów wsparcia po w pełni zarządzane rozwiązania."
            },
            {
              "language": "ro",
              "text": "Gama ofertelor merge de la pachete simple de suport până la soluții complet gestionate."
            },
            {
              "language": "ru",
              "text": "Диапазон предложений простирается от простых пакетов поддержки до полностью управляемых решений."
            },
            {
              "language": "sq",
              "text": "Shtrirja e ofertave varion nga paketat e thjeshta të suportit deri te zgjidhjet plotësisht të menaxhuara."
            },
            {
              "language": "tr",
              "text": "Tekliflerin aralığı basit destek paketlerinden tamamen yönetilen çözümlere kadar uzanır."
            }
          ]
        },
        {
          "baseText": "Die Spannbreite der gemessenen Werte war größer als im Vorjahr.",
          "translations": [
            {
              "language": "ar",
              "text": "كان نطاق القيم المقاسة أكبر مما كان عليه في العام السابق."
            },
            {
              "language": "ckb",
              "text": "مەودای نرخە پێوانەکراوەکان گەورەتر بوو لە ساڵی پێشوو."
            },
            {
              "language": "en",
              "text": "The range of measured values was larger than in the previous year."
            },
            {
              "language": "fa",
              "text": "دامنه مقادیر اندازه‌گیری‌شده از سال قبل بیشتر بود."
            },
            {
              "language": "kmr",
              "text": "Navbera nirxên pîvandî ji sala berê mezintir bû."
            },
            {
              "language": "pl",
              "text": "Rozpiętość zmierzonych wartości była większa niż w poprzednim roku."
            },
            {
              "language": "ro",
              "text": "Intervalul valorilor măsurate a fost mai mare decât anul trecut."
            },
            {
              "language": "ru",
              "text": "Разброс измеренных значений был больше, чем в прошлом году."
            },
            {
              "language": "sq",
              "text": "Diapazoni i vlerave të matura ishte më i madh se vitin e kaluar."
            },
            {
              "language": "tr",
              "text": "Ölçülen değerlerin aralığı önceki yıla göre daha genişti."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
