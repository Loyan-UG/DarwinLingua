  "entries": [
    {
      "word": "begeben",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "begeben",
      "pronunciationIpa": null,
      "syllableBreak": "be-ge-ben",
      "topics": [
        "business-communication",
        "management-and-leadership",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "written",
        "workplace"
      ],
      "contextLabels": [
        "documents"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يتحمل/يخوض"
        },
        {
          "language": "ckb",
          "text": "چوون/بەرەوهێنان"
        },
        {
          "language": "en",
          "text": "to undertake; to enter"
        },
        {
          "language": "fa",
          "text": "به عهده گرفتن"
        },
        {
          "language": "kmr",
          "text": "çûn / berdan"
        },
        {
          "language": "pl",
          "text": "podejmować"
        },
        {
          "language": "ro",
          "text": "a se îndeplini"
        },
        {
          "language": "ru",
          "text": "взяться"
        },
        {
          "language": "sq",
          "text": "të angazhohesh"
        },
        {
          "language": "tr",
          "text": "üstlenmek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Team hat sich bereit erklärt, die Migration auf das neue ERP-System zu begeben.",
          "translations": [
            {
              "language": "ar",
              "text": "فريق العمل وافق على تنفيذ ترحيل نظام ERP الجديد."
            },
            {
              "language": "ckb",
              "text": "تیم داوی کرد بە گواستنەوەی سیستەمی ERP نوێ."
            },
            {
              "language": "en",
              "text": "The team agreed to undertake the migration to the new ERP system."
            },
            {
              "language": "fa",
              "text": "تیم با انجام مهاجرت به سیستم ERP جدید موافقت کرد."
            },
            {
              "language": "kmr",
              "text": "Tîm bi migrationa bo pergala nû ya ERP ket."
            },
            {
              "language": "pl",
              "text": "Zespół zgodził się podjąć migrację na nowy system ERP."
            },
            {
              "language": "ro",
              "text": "Echipa a acceptat să preia migrarea către noul sistem ERP."
            },
            {
              "language": "ru",
              "text": "Команда согласилась заняться миграцией на новую ERP-систему."
            },
            {
              "language": "sq",
              "text": "Ekipi pranoi të marrë përsipër migrimin në sistemin e ri ERP."
            },
            {
              "language": "tr",
              "text": "Ekip yeni ERP sistemine geçişi üstlenmeyi kabul etti."
            }
          ]
        },
        {
          "baseText": "Bitte begeben Sie sich zur Service-Front, falls der Zugriff erneut fehlschlägt.",
          "translations": [
            {
              "language": "ar",
              "text": "در صورت تکرار خطای دسترسی، لطفاً به تیم خدمات مراجعه کنید."
            },
            {
              "language": "ckb",
              "text": "لە کاتێکدا گەڕانەوەی دەستپێگەشتن شکستی هێنا، تکایە بڕۆ بۆ بخشەی خزمەتگوزارییەکان."
            },
            {
              "language": "en",
              "text": "Please go to the service desk if access fails again."
            },
            {
              "language": "fa",
              "text": "اگر دوباره دسترسی شکست خورد، لطفاً به میز پشتیبانی مراجعه کنید."
            },
            {
              "language": "kmr",
              "text": "Ger gihîştin dîsa têkçû, ji kerema xwe re here pêşkeftina karûbarê."
            },
            {
              "language": "pl",
              "text": "Jeśli dostęp ponownie zawiedzie, proszę udać się do działu obsługi."
            },
            {
              "language": "ro",
              "text": "Dacă accesul eșuează din nou, vă rugăm să mergeți la serviciul de suport."
            },
            {
              "language": "ru",
              "text": "Если доступ снова не сработает, пожалуйста, обратитесь в службу поддержки."
            },
            {
              "language": "sq",
              "text": "Nëse aksesimi dështon sërish, ju lutemi shkoni te shërbimi i mbështetjes."
            },
            {
              "language": "tr",
              "text": "Erişim tekrar başarısız olursa lütfen destek hattına gidin."
            }
          ]
        }
      ]
    },
    {
      "word": "begehen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "begehen",
      "pronunciationIpa": null,
      "syllableBreak": "be-ge-hen",
      "topics": [
        "meetings-and-presentations",
        "work-and-jobs",
        "documents-and-administration"
      ],
      "usageLabels": [
        "workplace",
        "formal",
        "written"
      ],
      "contextLabels": [
        "documents"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تنظیم/انجام دادن"
        },
        {
          "language": "ckb",
          "text": "دەستبردان"
        },
        {
          "language": "en",
          "text": "to conduct"
        },
        {
          "language": "fa",
          "text": "انجام دادن"
        },
        {
          "language": "kmr",
          "text": "çalakî kirin"
        },
        {
          "language": "pl",
          "text": "przeprowadzać"
        },
        {
          "language": "ro",
          "text": "a conduce"
        },
        {
          "language": "ru",
          "text": "проводить"
        },
        {
          "language": "sq",
          "text": "të kryesh"
        },
        {
          "language": "tr",
          "text": "gerçekleştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir begehen vor dem Rollout ein Sicherheitsmeeting mit allen Teamleitern.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الإطلاق رسمی، یک جلسه امنیتی با همه سرپرستان تیم برگزار می‌کنیم."
            },
            {
              "language": "ckb",
              "text": "پێش ڕاگەیاندنێکی تەواو کۆبوونەوەی ئاسایش لەگەڵ هەموو سەرپەرشتیاری تیمەکان دەکەین."
            },
            {
              "language": "en",
              "text": "We hold a security meeting with all team leads before rollout."
            },
            {
              "language": "fa",
              "text": "قبل از استقرار، جلسه‌ای امنیتی با همه سرپرستان تیم برگزار می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Piştî amadehiya rolloutê em civînê ewlehiyê bi hemû serokên tîmê dikin."
            },
            {
              "language": "pl",
              "text": "Przeprowadzamy spotkanie bezpieczeństwa ze wszystkimi liderami zespołów przed wdrożeniem."
            },
            {
              "language": "ro",
              "text": "Trecem la o ședință de securitate cu toți liderii de echipă înainte de lansare."
            },
            {
              "language": "ru",
              "text": "Перед релизом проводим встречу по безопасности со всеми руководителями команд."
            },
            {
              "language": "sq",
              "text": "Para ndezjes bëjmë një takim sigurie me të gjithë drejtuesit e ekipeve."
            },
            {
              "language": "tr",
              "text": "Yayına geçmeden önce tüm ekip liderleriyle bir güvenlik toplantısı yapıyoruz."
            }
          ]
        },
        {
          "baseText": "Das Team beging eine Retrospektive, nachdem der Sprint fertig wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "تیم پس از تکمیل اسپرینت یک بازنگری انجام داد."
            },
            {
              "language": "ckb",
              "text": "تیم دواتر لە تەواوبوونی سپڕنتەکە یەک بازگەڕەوەیەکی بازاندەری کرد."
            },
            {
              "language": "en",
              "text": "The team held a retrospective after the sprint was completed."
            },
            {
              "language": "fa",
              "text": "تیم پس از پایان اسپرینت یک بازبینی انجام داد."
            },
            {
              "language": "kmr",
              "text": "Tîm pa dawîbûna sprintê retrospektivê vekir."
            },
            {
              "language": "pl",
              "text": "Zespół przeprowadził retrospektywę po zakończeniu sprintu."
            },
            {
              "language": "ro",
              "text": "Echipa a organizat o retrospectivă după ce sprintul a fost finalizat."
            },
            {
              "language": "ru",
              "text": "Команда провела ретроспективу после завершения спринта."
            },
            {
              "language": "sq",
              "text": "Ekipi mbajti një retrospektivë pasi sprinti u përfundua."
            },
            {
              "language": "tr",
              "text": "Takım sprint tamamlandıktan sonra bir geribildirim toplantısı yaptı."
            }
          ]
        }
      ]
    },
    {
      "word": "begießen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "begießen",
      "pronunciationIpa": null,
      "syllableBreak": "be-gie-ßen",
      "topics": [
        "technology-and-it",
        "work-and-jobs",
        "everyday-life"
      ],
      "usageLabels": [
        "workplace",
        "technical"
      ],
      "contextLabels": [
        "it"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "پاشیدن/اسپرینگ کردن"
        },
        {
          "language": "ckb",
          "text": "بەهەژمەنەوە"
        },
        {
          "language": "en",
          "text": "to spray"
        },
        {
          "language": "fa",
          "text": "پاشیدن"
        },
        {
          "language": "kmr",
          "text": "fîrkirin"
        },
        {
          "language": "pl",
          "text": "zraszać"
        },
        {
          "language": "ro",
          "text": "a stropi"
        },
        {
          "language": "ru",
          "text": "распылять"
        },
        {
          "language": "sq",
          "text": "të spërkatësh"
        },
        {
          "language": "tr",
          "text": "püskürtmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir begießen die Testserver regelmäßig mit Testdaten für Performance-Checks.",
          "translations": [
            {
              "language": "ar",
              "text": "برای بررسی عملکرد، داده‌های آزمایشی را به‌طور منظم بر روی سرورهای تست پاشش می‌کنیم."
            },
            {
              "language": "ckb",
              "text": "ئێمە بەردەوام بەخۆمان داتای تاقیکردنەوە لە سێرڤەری تاقیکردنەوە دەتەکەین بۆ پشکنینی کارایی."
            },
            {
              "language": "en",
              "text": "We regularly seed test servers with test data for performance checks."
            },
            {
              "language": "fa",
              "text": "به‌طور منظم سرورهای تست را با داده‌های آزمایشی برای کنترل عملکرد تغذیه می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em serverên ceribandinê bi daneyên ceribandinê her dem pêçûn dikin bo kontrola performansê."
            },
            {
              "language": "pl",
              "text": "Regularnie zasilamy serwery testowe danymi testowymi do kontroli wydajności."
            },
            {
              "language": "ro",
              "text": "Hrănim regulat serverele de test cu date de test pentru verificări de performanță."
            },
            {
              "language": "ru",
              "text": "Мы регулярно наполняем тестовые серверы тестовыми данными для проверки производительности."
            },
            {
              "language": "sq",
              "text": "Ne rregullisht mbjellim serverët testues me të dhëna testuese për kontrollet e performancës."
            },
            {
              "language": "tr",
              "text": "Performans kontrolleri için test sunucularını düzenli olarak test verisi ile besliyoruz."
            }
          ]
        },
        {
          "baseText": "Die Wartungscrew begießt die Kühlkammer nur mit zugelassenen Mitteln.",
          "translations": [
            {
              "language": "ar",
              "text": "تیم نگهداشت فقط با مواد مجاز، محفظه خنک‌کننده را پاشش می‌کند."
            },
            {
              "language": "ckb",
