        "housing-and-real-estate"
      ],
      "usageLabels": [
        "spoken",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable irregular verb: ich ziehe aus, ich bin/habe ausgezogen depending on meaning"
      ],
      "collocations": [
        {
          "text": "die Schuhe ausziehen",
          "meaning": "to take off the shoes"
        },
        {
          "text": "aus der Wohnung ausziehen",
          "meaning": "to move out of the apartment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "ziehen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "einziehen",
          "relationLabel": "verb",
          "note": "opposite for moving in"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يخلع؛ ينتقل من السكن"
        },
        {
          "language": "ckb",
          "text": "دەرکردن؛ کۆچکردن لە ماڵ"
        },
        {
          "language": "en",
          "text": "to take off; to move out"
        },
        {
          "language": "fa",
          "text": "درآوردن؛ از خانه نقل مکان کردن"
        },
        {
          "language": "kmr",
          "text": "ji xwe derxistin; ji malê derketin"
        },
        {
          "language": "pl",
          "text": "zdjąć; wyprowadzić się"
        },
        {
          "language": "ro",
          "text": "a scoate; a se muta din locuință"
        },
        {
          "language": "ru",
          "text": "снимать; съезжать"
        },
        {
          "language": "sq",
          "text": "të heqësh; të largohesh nga banesa"
        },
        {
          "language": "tr",
          "text": "çıkarmak; taşınmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte ziehen Sie die Schuhe aus.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى خلع الحذاء."
            },
            {
              "language": "ckb",
              "text": "تکایە پێڵاوەکانت دەر بکە."
            },
            {
              "language": "en",
              "text": "Please take off your shoes."
            },
            {
              "language": "fa",
              "text": "لطفاً کفش‌هایتان را دربیاورید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pêlavên xwe ji xwe derxin."
            },
            {
              "language": "pl",
              "text": "Proszę zdjąć buty."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să vă scoateți pantofii."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, снимите обувь."
            },
            {
              "language": "sq",
              "text": "Ju lutem hiqni këpucët."
            },
            {
              "language": "tr",
              "text": "Lütfen ayakkabılarınızı çıkarın."
            }
          ]
        },
        {
          "baseText": "Wir ziehen Ende des Monats aus.",
          "translations": [
            {
              "language": "ar",
              "text": "سننتقل من السكن في نهاية الشهر."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی مانگ لە ماڵەکە دەچینە دەرەوە."
            },
            {
              "language": "en",
              "text": "We are moving out at the end of the month."
            },
            {
              "language": "fa",
              "text": "ما آخر ماه از خانه نقل مکان می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em dawiya mehê ji malê derdikevin."
            },
            {
              "language": "pl",
              "text": "Wyprowadzamy się pod koniec miesiąca."
            },
            {
              "language": "ro",
              "text": "Ne mutăm din locuință la sfârșitul lunii."
            },
            {
              "language": "ru",
              "text": "Мы съезжаем в конце месяца."
            },
            {
              "language": "sq",
              "text": "Ne largohemi nga banesa në fund të muajit."
            },
            {
              "language": "tr",
              "text": "Ay sonunda taşınıyoruz."
            }
          ]
        }
      ]
    },
