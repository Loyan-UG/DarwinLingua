            {
              "language": "fa",
              "text": "نویسنده این مقاله را می‌شناسی؟"
            },
            {
              "language": "kmr",
              "text": "Tu nivîskarê vê gotarê nas dikî?"
            },
            {
              "language": "pl",
              "text": "Znasz autora tego artykułu?"
            },
            {
              "language": "ro",
              "text": "Îl cunoști pe autorul acestui articol?"
