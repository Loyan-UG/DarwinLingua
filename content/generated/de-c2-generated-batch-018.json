        "culture-and-media",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; literally biting, figuratively sharp or cutting in tone"
      ],
      "collocations": [
        {
          "text": "eine bissige Bemerkung",
          "meaning": "a biting remark"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "beißen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Biss",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "لاذع؛ جارح؛ عضّاض"
        },
        {
          "language": "ckb",
          "text": "توند و تیژ؛ بریندارکەر؛ گازگرتوو"
        },
        {
          "language": "en",
          "text": "biting; sharp; cutting"
        },
        {
          "language": "fa",
          "text": "نیش‌دار؛ تند و گزنده"
        },
        {
          "language": "kmr",
          "text": "tûj; birîndar; gezker"
        },
        {
          "language": "pl",
          "text": "kąśliwy; zjadliwy"
        },
        {
          "language": "ro",
          "text": "mușcător; tăios"
        },
        {
          "language": "ru",
          "text": "язвительный; резкий; кусачий"
        },
        {
          "language": "sq",
          "text": "thumbues; i mprehtë"
        },
        {
          "language": "tr",
          "text": "iğneleyici; keskin; ısırgan"
        }
      ],
      "examples": [
        {
          "baseText": "Seine bissige Kritik traf einen wunden Punkt, machte eine sachliche Diskussion aber fast unmöglich.",
          "translations": [
            {
              "language": "ar",
              "text": "أصابت نقده اللاذع نقطة حساسة، لكنه جعل النقاش الموضوعي شبه مستحيل."
            },
            {
              "language": "ckb",
              "text": "ڕەخنە توندەکەی خاڵێکی هەستیار پێکا، بەڵام گفتوگۆی بابەتی نزیکەی نەگونجاو کرد."
            },
            {
              "language": "en",
              "text": "His biting criticism hit a sore point, but made a factual discussion almost impossible."
            },
            {
              "language": "fa",
              "text": "انتقاد نیش‌دار او نقطه حساسی را هدف گرفت، اما بحث منطقی را تقریباً ناممکن کرد."
            },
            {
              "language": "kmr",
              "text": "Rexneya wî ya tûj cihê hesas girt, lê nîqaşeke rastîn hema hema ne gengaz kir."
            },
            {
              "language": "pl",
              "text": "Jego kąśliwa krytyka trafiła w czuły punkt, ale niemal uniemożliwiła rzeczową dyskusję."
            },
            {
              "language": "ro",
              "text": "Critica lui tăioasă a atins un punct sensibil, dar a făcut aproape imposibilă o discuție obiectivă."
            },
            {
              "language": "ru",
              "text": "Его язвительная критика попала в больное место, но почти сделала невозможной предметную дискуссию."
            },
            {
              "language": "sq",
              "text": "Kritika e tij thumbuese preku një pikë të ndjeshme, por e bëri pothuajse të pamundur një diskutim faktik."
            },
            {
              "language": "tr",
              "text": "İğneleyici eleştirisi hassas bir noktaya dokundu, ancak nesnel bir tartışmayı neredeyse imkânsız kıldı."
            }
          ]
        },
        {
          "baseText": "Die Kolumne ist bissig, ohne in bloße Häme abzugleiten.",
          "translations": [
            {
              "language": "ar",
              "text": "المقالة لاذعة من دون أن تنزلق إلى مجرد شماتة."
            },
            {
              "language": "ckb",
              "text": "کۆڵۆمەکە تیژە، بەبێ ئەوەی ببێتە تەنها گاڵتەی خراپەکارانە."
            },
            {
              "language": "en",
              "text": "The column is sharp without sliding into mere malice."
            },
            {
              "language": "fa",
              "text": "ستون روزنامه نیش‌دار است، بدون اینکه به بدخواهی صرف بلغزد."
            },
            {
              "language": "kmr",
              "text": "Stûn tûj e bê ku bikeve tenê qerebalixiya xirab."
            },
            {
              "language": "pl",
              "text": "Felieton jest kąśliwy, nie osuwając się w zwykłą złośliwość."
            },
            {
              "language": "ro",
              "text": "Coloana este tăioasă fără să alunece în simplă răutate."
            },
            {
              "language": "ru",
              "text": "Колонка язвительна, но не скатывается в простую злорадность."
            },
            {
              "language": "sq",
              "text": "Kolumna është thumbuese pa rrëshqitur në ligësi të thjeshtë."
            },
            {
              "language": "tr",
              "text": "Köşe yazısı keskindir, salt kötücüllüğe kaymadan."
            }
          ]
        }
      ]
    },
