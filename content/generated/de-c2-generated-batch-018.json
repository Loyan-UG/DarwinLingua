  "entries": [
    {
      "word": "der Binnenreim",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Binnenreime",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Bin-nen-reim",
      "topics": [
        "culture-and-media",
        "education-and-training",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "academic",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; poetic term for a rhyme within a line"
      ],
      "collocations": [
        {
          "text": "einen Binnenreim verwenden",
          "meaning": "to use an internal rhyme"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Reim",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قافية داخلية"
        },
        {
          "language": "ckb",
          "text": "هاوشێوەدەنگی ناو دێڕ"
        },
        {
          "language": "en",
          "text": "internal rhyme"
        },
        {
          "language": "fa",
          "text": "قافیه درونی"
        },
        {
          "language": "kmr",
          "text": "qafiyeya hundirîn"
        },
        {
          "language": "pl",
          "text": "rym wewnętrzny"
        },
        {
          "language": "ro",
          "text": "rimă internă"
        },
        {
          "language": "ru",
          "text": "внутренняя рифма"
        },
        {
          "language": "sq",
          "text": "rimë e brendshme"
        },
        {
          "language": "tr",
          "text": "iç uyak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Binnenreim verdichtet den Rhythmus der Zeile, ohne den Satz künstlich wirken zu lassen.",
          "translations": [
            {
              "language": "ar",
              "text": "تكثّف القافية الداخلية إيقاع السطر من دون أن تجعل الجملة تبدو مصطنعة."
            },
            {
              "language": "ckb",
              "text": "هاوشێوەدەنگی ناو دێڕ ڕیتمی دێڕەکە چڕتر دەکات، بەبێ ئەوەی ڕستەکە دەستکرد دیار بێت."
            },
            {
              "language": "en",
              "text": "The internal rhyme tightens the rhythm of the line without making the sentence sound artificial."
            },
            {
              "language": "fa",
              "text": "قافیه درونی ریتم مصرع را فشرده‌تر می‌کند، بدون اینکه جمله مصنوعی به نظر برسد."
            },
            {
              "language": "kmr",
              "text": "Qafiyeya hundirîn rîtma rêzê tîr dike bê ku hevok çêkirî xuya bike."
            },
            {
              "language": "pl",
              "text": "Rym wewnętrzny zagęszcza rytm wersu, nie sprawiając, że zdanie brzmi sztucznie."
            },
            {
              "language": "ro",
              "text": "Rima internă concentrează ritmul versului fără să facă propoziția să pară artificială."
            },
            {
              "language": "ru",
              "text": "Внутренняя рифма уплотняет ритм строки, не делая фразу искусственной."
            },
            {
              "language": "sq",
              "text": "Rima e brendshme e dendëson ritmin e vargut pa e bërë fjalinë të duket artificiale."
            },
            {
              "language": "tr",
              "text": "İç uyak dizenin ritmini sıkılaştırır, cümlenin yapay duyulmasına yol açmadan."
            }
          ]
        },
        {
          "baseText": "Im Seminar zeigte die Dozentin, wie Binnenreime in Rap-Texten Bedeutung und Klang verbinden.",
          "translations": [
            {
              "language": "ar",
              "text": "في الندوة أوضحت المحاضِرة كيف تربط القوافي الداخلية في نصوص الراب المعنى بالصوت."
            },
            {
              "language": "ckb",
              "text": "لە سیمینارەکەدا مامۆستاکە نیشانی دا کە هاوشێوەدەنگی ناو دێڕ لە دەقەکانی ڕاپدا چۆن مانا و دەنگ پێکەوە دەبەستێت."
            },
            {
              "language": "en",
              "text": "In the seminar, the lecturer showed how internal rhymes in rap lyrics connect meaning and sound."
            },
            {
              "language": "fa",
              "text": "در سمینار، مدرس نشان داد که قافیه‌های درونی در متن‌های رپ چگونه معنا و صدا را به هم وصل می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Di semînerê de mamoste nîşan da ka qafiyeyên hundirîn di tekstên rapê de çawa wate û deng girê didin."
            },
            {
              "language": "pl",
              "text": "Na seminarium prowadząca pokazała, jak rymy wewnętrzne w tekstach rapowych łączą znaczenie i brzmienie."
            },
            {
              "language": "ro",
              "text": "La seminar, profesoara a arătat cum rimele interne din textele rap leagă sensul de sunet."
            },
            {
              "language": "ru",
              "text": "На семинаре преподавательница показала, как внутренние рифмы в рэп-текстах связывают смысл и звучание."
            },
            {
              "language": "sq",
              "text": "Në seminar, pedagogia tregoi si rimat e brendshme në tekstet rap lidhin kuptimin me tingullin."
            },
            {
              "language": "tr",
              "text": "Seminerde öğretim görevlisi rap metinlerinde iç uyakların anlam ile sesi nasıl bağladığını gösterdi."
            }
          ]
        }
      ]
    },
    {
      "word": "bissig",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "bis-sig",
      "topics": [
