      "examples": [
        {
          "baseText": "Das ERP weist der Palette automatisch einen freien Stellplatz zu.",
          "translations": [
            {
              "language": "ar",
              "text": "يخصص ERP للمنصة تلقائيًا مكانًا شاغرًا."
            },
            {
              "language": "ckb",
              "text": "ERP خۆکارانە شوێنێکی بەتاڵ بۆ پالێتەکە دیاری دەکات."
            },
            {
              "language": "en",
              "text": "The ERP automatically assigns a free staging spot to the pallet."
            },
            {
              "language": "fa",
              "text": "ERP به‌صورت خودکار یک محل خالی به پالت اختصاص می‌دهد."
            },
            {
              "language": "kmr",
              "text": "ERP xweber cihê vala ji paletê re diyar dike."
            },
            {
              "language": "pl",
              "text": "ERP automatycznie przypisuje palecie wolne miejsce odstawcze."
            },
            {
              "language": "ro",
              "text": "ERP alocă automat paletului un loc liber de staționare."
            },
            {
              "language": "ru",
