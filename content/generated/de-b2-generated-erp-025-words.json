  "entries": [
    {
      "word": "Status aktualisieren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "Status aktualisieren",
      "pronunciationIpa": null,
      "syllableBreak": "Sta-tus ak-tu-a-li-sie-ren",
      "topics": [
        "erp-and-business-systems",
        "warehouse-and-logistics",
        "technology-and-it"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb phrase used in ERP workflows; means to update a document, order, or process status"
      ],
      "collocations": [
        {
          "text": "den Status automatisch aktualisieren",
          "meaning": "to update the status automatically"
        },
        {
          "text": "den Lieferstatus aktualisieren",
          "meaning": "to update the delivery status"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Status",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "aktualisieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تحديث الحالة"
        },
        {
          "language": "ckb",
          "text": "نوێکردنەوەی دۆخ"
        },
        {
          "language": "en",
          "text": "to update the status"
        },
        {
          "language": "fa",
          "text": "به‌روزرسانی وضعیت"
        },
        {
          "language": "kmr",
          "text": "rewşê nûkirin"
        },
        {
          "language": "pl",
          "text": "zaktualizować status"
        },
        {
          "language": "ro",
          "text": "a actualiza statusul"
        },
        {
          "language": "ru",
          "text": "обновить статус"
        },
        {
          "language": "sq",
          "text": "të përditësosh statusin"
        },
        {
          "language": "tr",
          "text": "durumu güncellemek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Mitarbeiter muss den Status im ERP aktualisieren, sobald die Ware verladen ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على الموظف تحديث الحالة في ERP بمجرد تحميل البضاعة."
            },
            {
              "language": "ckb",
              "text": "کارمەندەکە پێویستە دۆخەکە لە ERP دا نوێ بکاتەوە هەر کات کاڵاکە بارکرا."
            },
            {
              "language": "en",
              "text": "The employee has to update the status in the ERP as soon as the goods are loaded."
            },
            {
              "language": "fa",
              "text": "کارمند باید به‌محض بارگیری کالا، وضعیت را در ERP به‌روزرسانی کند."
            },
            {
              "language": "kmr",
              "text": "Karmend divê dema mal hate barkirin rewşê di ERP de nû bike."
            },
            {
              "language": "pl",
              "text": "Pracownik musi zaktualizować status w ERP, gdy tylko towar zostanie załadowany."
            },
            {
              "language": "ro",
              "text": "Angajatul trebuie să actualizeze statusul în ERP imediat ce marfa este încărcată."
            },
            {
              "language": "ru",
              "text": "Сотрудник должен обновить статус в ERP, как только товар загружен."
            },
            {
              "language": "sq",
              "text": "Punonjësi duhet ta përditësojë statusin në ERP sapo malli të ngarkohet."
            },
            {
              "language": "tr",
              "text": "Çalışan mal yüklenir yüklenmez ERP’de durumu güncellemelidir."
            }
          ]
        },
        {
          "baseText": "Bitte aktualisieren Sie den Status erst nach der Rückmeldung aus dem Lager.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تحديث الحالة فقط بعد وصول الرد من المستودع."
            },
            {
              "language": "ckb",
              "text": "تکایە دۆخەکە تەنها دوای وەڵامی کۆگا نوێ بکەنەوە."
            },
            {
              "language": "en",
              "text": "Please update the status only after feedback from the warehouse."
            },
            {
              "language": "fa",
              "text": "لطفاً وضعیت را فقط پس از بازخورد انبار به‌روزرسانی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe rewşê tenê piştî bersiva ji embarê nû bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zaktualizować status dopiero po informacji zwrotnej z magazynu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să actualizați statusul doar după feedbackul din depozit."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, обновляйте статус только после ответа со склада."
            },
            {
              "language": "sq",
              "text": "Ju lutemi përditësoni statusin vetëm pas përgjigjes nga magazina."
            },
            {
              "language": "tr",
              "text": "Lütfen durumu ancak depodan geri bildirim geldikten sonra güncelleyin."
            }
          ]
        }
      ]
    },
    {
      "word": "Status prüfen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "Status prüfen",
      "pronunciationIpa": null,
      "syllableBreak": "Sta-tus prü-fen",
      "topics": [
        "erp-and-business-systems",
        "customer-service",
        "warehouse-and-logistics"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb phrase; to check the status of an order, invoice, delivery, or task"
      ],
      "collocations": [
        {
          "text": "den Auftragsstatus prüfen",
          "meaning": "to check the order status"
        },
        {
          "text": "den Status im ERP prüfen",
          "meaning": "to check the status in the ERP"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Status",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "prüfen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "التحقق من الحالة"
        },
        {
          "language": "ckb",
          "text": "پشکنینی دۆخ"
        },
        {
          "language": "en",
          "text": "to check the status"
        },
        {
          "language": "fa",
          "text": "بررسی وضعیت"
        },
        {
          "language": "kmr",
          "text": "rewşê kontrol kirin"
        },
        {
          "language": "pl",
          "text": "sprawdzić status"
        },
        {
          "language": "ro",
          "text": "a verifica statusul"
        },
        {
          "language": "ru",
          "text": "проверить статус"
        },
        {
          "language": "sq",
          "text": "të kontrollosh statusin"
        },
        {
          "language": "tr",
          "text": "durumu kontrol etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kundenservice prüft den Status der Lieferung direkt im ERP.",
          "translations": [
            {
              "language": "ar",
              "text": "تتحقق خدمة العملاء من حالة التسليم مباشرة في ERP."
            },
            {
              "language": "ckb",
              "text": "خزمەتگوزاریی کڕیار دۆخی گەیاندنەکە ڕاستەوخۆ لە ERP دا دەپشکنێت."
            },
            {
              "language": "en",
              "text": "Customer service checks the delivery status directly in the ERP."
            },
            {
              "language": "fa",
              "text": "خدمات مشتری وضعیت تحویل را مستقیم در ERP بررسی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Xizmeta mişterî rewşa radestkirinê rasterast di ERP de kontrol dike."
            },
            {
              "language": "pl",
              "text": "Obsługa klienta sprawdza status dostawy bezpośrednio w ERP."
            },
            {
              "language": "ro",
              "text": "Serviciul clienți verifică statusul livrării direct în ERP."
            },
            {
              "language": "ru",
              "text": "Служба поддержки клиентов проверяет статус поставки прямо в ERP."
            },
            {
              "language": "sq",
              "text": "Shërbimi ndaj klientit kontrollon statusin e dorëzimit direkt në ERP."
            },
            {
              "language": "tr",
              "text": "Müşteri hizmetleri teslimat durumunu doğrudan ERP’de kontrol eder."
            }
          ]
        },
        {
          "baseText": "Bevor Sie den Kunden anrufen, prüfen Sie bitte den Status der offenen Rechnung.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الاتصال بالعميل، يرجى التحقق من حالة الفاتورة المفتوحة."
            },
            {
              "language": "ckb",
              "text": "پێش پەیوەندیکردن بە کڕیار، تکایە دۆخی فاکتورەی کراوە بپشکنن."
            },
            {
              "language": "en",
              "text": "Before calling the customer, please check the status of the open invoice."
            },
            {
              "language": "fa",
              "text": "قبل از تماس با مشتری، لطفاً وضعیت فاکتور باز را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Berî ku hûn bi mişterî re telefon bikin, ji kerema xwe rewşa fatûreya vekirî kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Przed telefonem do klienta proszę sprawdzić status otwartej faktury."
            },
            {
              "language": "ro",
              "text": "Înainte să sunați clientul, vă rugăm să verificați statusul facturii deschise."
            },
            {
              "language": "ru",
              "text": "Перед звонком клиенту проверьте, пожалуйста, статус открытого счета."
            },
            {
              "language": "sq",
              "text": "Para se ta telefononi klientin, ju lutemi kontrolloni statusin e faturës së hapur."
            },
            {
              "language": "tr",
              "text": "Müşteriyi aramadan önce lütfen açık faturanın durumunu kontrol edin."
            }
          ]
        }
      ]
    },
