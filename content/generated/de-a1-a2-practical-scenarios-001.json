          "prompt": "Warum kommt die Person nicht ins Büro?",
          "translations": [
            {
              "language": "en",
              "text": "Why is the person not coming to the office?"
            },
            {
              "language": "fa",
              "text": "چرا آن شخص به دفتر نمی‌آید؟"
            }
          ],
          "answers": [
