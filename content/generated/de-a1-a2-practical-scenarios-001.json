    {
      "slug": "a2-call-in-sick-at-work",
      "title": "Call in Sick at Work",
      "description": "An A2 workplace call for saying you are sick and asking what to send.",
      "learnerGoal": "Inform a colleague or manager that you are sick and ask about the next step.",
      "cefrLevel": "A2",
      "category": "workplace-communication",
      "topics": [
        "work-and-jobs",
        "appointments-and-health"
      ],
      "sortOrder": 30,
      "dialogueTurns": [
        {
          "speakerRole": "learner",
          "baseText": "Guten Morgen. Ich bin heute krank und kann nicht ins Büro kommen.",
          "translations": [
            {
              "language": "en",
              "text": "Good morning. I am sick today and cannot come to the office."
            },
            {
              "language": "fa",
              "text": "صبح به خیر. امروز مریض هستم و نمی‌توانم به دفتر بیایم."
            }
          ]
        },
        {
          "speakerRole": "manager",
          "baseText": "Danke für die Information. Schicken Sie bitte eine kurze Nachricht an das Team.",
          "translations": [
            {
              "language": "en",
              "text": "Thanks for the information. Please send a short message to the team."
            },
            {
              "language": "fa",
              "text": "ممنون از اطلاع‌رسانی. لطفاً یک پیام کوتاه برای تیم بفرستید."
            }
          ]
        },
        {
          "speakerRole": "learner",
          "baseText": "Muss ich eine Bescheinigung senden?",
          "translations": [
            {
              "language": "en",
              "text": "Do I need to send a certificate?"
            },
            {
              "language": "fa",
              "text": "آیا باید گواهی ارسال کنم؟"
            }
          ]
        }
      ],
      "usefulPhrases": [
        {
          "baseText": "Ich bin heute krank.",
          "usageNote": "Use this short sentence when informing work or school.",
          "translations": [
            {
              "language": "en",
              "text": "I am sick today."
            },
            {
              "language": "fa",
              "text": "امروز مریض هستم."
            }
          ]
        },
        {
          "baseText": "Muss ich eine Bescheinigung senden?",
          "usageNote": "Use when asking about a required document.",
          "translations": [
            {
              "language": "en",
              "text": "Do I need to send a certificate?"
            },
            {
              "language": "fa",
              "text": "آیا باید گواهی ارسال کنم؟"
            }
          ]
        }
      ],
      "questions": [
