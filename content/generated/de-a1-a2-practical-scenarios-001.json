    {
      "slug": "a2-reschedule-delivery-time",
      "title": "Reschedule a Delivery Time",
      "description": "An A2 logistics call for changing a pickup or delivery appointment.",
      "learnerGoal": "Explain that a time does not work and suggest a new time.",
      "cefrLevel": "A2",
      "category": "workplace-logistics",
      "topics": [
        "work-and-jobs"
      ],
      "sortOrder": 40,
      "dialogueTurns": [
        {
          "speakerRole": "service-agent",
          "baseText": "Der Abholtermin ist morgen um acht Uhr.",
          "translations": [
            {
              "language": "en",
              "text": "The pickup appointment is tomorrow at eight."
            },
            {
              "language": "fa",
              "text": "زمان تحویل گرفتن فردا ساعت هشت است."
            }
          ]
        },
        {
          "speakerRole": "learner",
          "baseText": "Um acht Uhr passt es leider nicht. Geht es um zehn Uhr?",
          "translations": [
            {
              "language": "en",
              "text": "Eight o'clock unfortunately does not work. Is ten o'clock possible?"
            },
            {
              "language": "fa",
              "text": "ساعت هشت متأسفانه مناسب نیست. ساعت ده ممکن است؟"
            }
          ]
        },
        {
          "speakerRole": "service-agent",
          "baseText": "Ja, ich ändere den Termin auf zehn Uhr.",
          "translations": [
            {
              "language": "en",
              "text": "Yes, I will change the appointment to ten o'clock."
            },
            {
              "language": "fa",
              "text": "بله، زمان را به ساعت ده تغییر می‌دهم."
            }
          ]
        }
      ],
      "usefulPhrases": [
        {
          "baseText": "Das passt leider nicht.",
          "usageNote": "Use this polite sentence when a proposed time does not work.",
          "translations": [
            {
              "language": "en",
              "text": "That unfortunately does not work."
            },
            {
              "language": "fa",
              "text": "این متأسفانه مناسب نیست."
            }
          ]
        },
        {
          "baseText": "Geht es um zehn Uhr?",
          "usageNote": "Use to suggest another time.",
          "translations": [
            {
              "language": "en",
              "text": "Is ten o'clock possible?"
            },
            {
              "language": "fa",
              "text": "ساعت ده ممکن است؟"
            }
          ]
        }
      ],
      "questions": [
        {
          "prompt": "Welche neue Zeit schlägt die Person vor?",
          "translations": [
            {
              "language": "en",
              "text": "Which new time does the person suggest?"
            },
            {
              "language": "fa",
              "text": "آن شخص چه زمان جدیدی پیشنهاد می‌دهد؟"
            }
          ],
          "answers": [
            {
              "text": "Zehn Uhr.",
              "isCorrect": true,
              "feedback": "Correct.",
              "translations": [
                {
                  "language": "en",
                  "text": "Ten o'clock."
                },
                {
                  "language": "fa",
                  "text": "ساعت ده."
                }
              ]
            },
            {
              "text": "Acht Uhr.",
              "isCorrect": false,
              "feedback": "Eight o'clock was the original time.",
              "translations": [
                {
                  "language": "en",
                  "text": "Eight o'clock."
                },
                {
                  "language": "fa",
                  "text": "ساعت هشت."
                }
              ]
            }
          ]
        }
      ]
    }
