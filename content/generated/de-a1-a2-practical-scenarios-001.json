    {
      "slug": "a1-buy-bread-at-bakery",
      "title": "Buy Bread at a Bakery",
      "description": "A short A1 exchange for buying bread and paying politely.",
      "learnerGoal": "Ask for one item, understand the price, and say thank you.",
      "cefrLevel": "A1",
      "category": "shopping-and-food",
      "topics": [
        "shopping",
        "everyday-life"
      ],
      "sortOrder": 10,
      "dialogueTurns": [
        {
          "speakerRole": "seller",
          "baseText": "Guten Morgen. Was möchten Sie?",
          "translations": [
            {
              "language": "en",
              "text": "Good morning. What would you like?"
            },
            {
              "language": "fa",
              "text": "صبح به خیر. چه چیزی میل دارید؟"
            }
          ]
        },
        {
          "speakerRole": "learner",
          "baseText": "Ich möchte ein Brot, bitte.",
          "translations": [
            {
              "language": "en",
              "text": "I would like one bread, please."
            },
            {
              "language": "fa",
              "text": "یک نان می‌خواهم، لطفاً."
            }
          ]
        },
        {
          "speakerRole": "seller",
          "baseText": "Das macht drei Euro.",
          "translations": [
            {
              "language": "en",
              "text": "That is three euros."
            },
            {
              "language": "fa",
              "text": "می‌شود سه یورو."
            }
          ]
        },
        {
          "speakerRole": "learner",
          "baseText": "Danke schön. Auf Wiedersehen.",
          "translations": [
            {
              "language": "en",
              "text": "Thank you. Goodbye."
            },
            {
              "language": "fa",
              "text": "خیلی ممنون. خداحافظ."
            }
          ]
        }
      ],
      "usefulPhrases": [
        {
          "baseText": "Ich möchte ... bitte.",
          "usageNote": "Use this polite pattern when ordering one item.",
          "translations": [
            {
              "language": "en",
              "text": "I would like ... please."
            },
            {
              "language": "fa",
              "text": "... می‌خواهم، لطفاً."
            }
          ]
        },
        {
          "baseText": "Was kostet das?",
          "usageNote": "Use this when you need the price.",
          "translations": [
            {
              "language": "en",
              "text": "How much does that cost?"
            },
            {
              "language": "fa",
              "text": "قیمتش چقدر است؟"
            }
          ]
        }
      ],
      "questions": [
        {
          "prompt": "Was kauft die Person?",
          "translations": [
            {
              "language": "en",
              "text": "What does the person buy?"
            },
            {
              "language": "fa",
              "text": "آن شخص چه چیزی می‌خرد؟"
            }
          ],
          "answers": [
            {
              "text": "Ein Brot.",
              "isCorrect": true,
              "feedback": "Correct.",
              "translations": [
                {
                  "language": "en",
                  "text": "One bread."
                },
                {
                  "language": "fa",
                  "text": "یک نان."
                }
              ]
            },
            {
              "text": "Eine Fahrkarte.",
              "isCorrect": false,
              "feedback": "That belongs to transport.",
              "translations": [
                {
                  "language": "en",
                  "text": "A ticket."
                },
                {
                  "language": "fa",
                  "text": "یک بلیت."
                }
              ]
            }
          ]
        }
      ]
    },
