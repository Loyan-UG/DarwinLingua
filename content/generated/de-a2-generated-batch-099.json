      "examples": [
        {
          "baseText": "Meine Kollegin spricht Türkisch und Deutsch.",
          "translations": [
            {
              "language": "ar",
              "text": "زميلتي تتكلم التركية والألمانية."
            },
            {
              "language": "ckb",
              "text": "هاوکارەکەم تورکی و ئەڵمانی دەزانێت."
            },
            {
              "language": "en",
              "text": "My colleague speaks Turkish and German."
            },
            {
              "language": "fa",
              "text": "همکارم ترکی و آلمانی صحبت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Hevkariya min tirkî û almanî diaxive."
            },
            {
              "language": "pl",
              "text": "Moja koleżanka mówi po turecku i po niemiecku."
            },
            {
              "language": "ro",
              "text": "Colega mea vorbește turcă și germană."
            },
            {
              "language": "ru",
              "text": "Моя коллега говорит по-турецки и по-немецки."
            },
            {
              "language": "sq",
              "text": "Kolegia ime flet turqisht dhe gjermanisht."
            },
            {
              "language": "tr",
              "text": "İş arkadaşım Türkçe ve Almanca konuşuyor."
            }
          ]
        },
        {
          "baseText": "In der Nähe gibt es ein türkisches Restaurant.",
          "translations": [
            {
              "language": "ar",
              "text": "يوجد مطعم تركي قريب."
            },
            {
              "language": "ckb",
              "text": "لە نزیکەوە چێشتخانەیەکی تورکی هەیە."
            },
            {
              "language": "en",
              "text": "There is a Turkish restaurant nearby."
            },
            {
              "language": "fa",
              "text": "در نزدیکی یک رستوران ترکی هست."
            },
            {
              "language": "kmr",
              "text": "Li nêzîkê restoranteke tirkî heye."
            },
            {
              "language": "pl",
              "text": "W pobliżu jest turecka restauracja."
            },
            {
              "language": "ro",
              "text": "În apropiere este un restaurant turcesc."
            },
            {
              "language": "ru",
              "text": "Рядом есть турецкий ресторан."
            },
            {
              "language": "sq",
              "text": "Afër ka një restorant turk."
            },
            {
              "language": "tr",
              "text": "Yakında bir Türk restoranı var."
            }
