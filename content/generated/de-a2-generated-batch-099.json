              "language": "ru",
              "text": "Ночевка стоит 80 евро."
            },
            {
              "language": "sq",
              "text": "Qëndrimi gjatë natës kushton 80 euro."
            },
            {
              "language": "tr",
              "text": "Geceleme 80 avro tutuyor."
            }
          ]
        },
        {
          "baseText": "Ist das Frühstück bei der Übernachtung dabei?",
          "translations": [
