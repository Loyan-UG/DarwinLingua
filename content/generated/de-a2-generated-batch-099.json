            },
            {
              "language": "en",
              "text": "Is breakfast included with the overnight stay?"
            },
            {
              "language": "fa",
              "text": "آیا صبحانه با اقامت شبانه شامل است؟"
            },
            {
              "language": "kmr",
              "text": "Ma taştê di şevmayînê de heye?"
            },
            {
              "language": "pl",
              "text": "Czy śniadanie jest w cenie noclegu?"
            },
            {
              "language": "ro",
              "text": "Micul dejun este inclus în cazare?"
            },
            {
              "language": "ru",
              "text": "Завтрак входит в стоимость проживания?"
