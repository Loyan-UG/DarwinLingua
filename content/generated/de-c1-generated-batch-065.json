  "entries": [
    {
      "word": "die Kapitalrendite",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kapitalrenditen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ka-pi-tal-ren-di-te",
      "topics": [
        "finance-and-accounting",
        "data-and-reporting",
        "advanced-analysis"
      ],
      "usageLabels": [
        "business",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine stabile Kapitalrendite erzielen",
          "meaning": "to achieve a stable return on capital"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Kapital",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Rendite",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "العائد على رأس المال؛ مردودية رأس المال"
        },
        {
          "language": "ckb",
          "text": "گەڕانەوەی سەرمایە؛ قازانجی سەرمایە"
        },
        {
          "language": "en",
          "text": "return on capital; capital yield"
        },
        {
          "language": "fa",
          "text": "بازده سرمایه؛ سودآوری سرمایه"
        },
        {
          "language": "kmr",
          "text": "vegera sermayê; qazanca sermayê"
        },
        {
          "language": "pl",
          "text": "rentowność kapitału; zwrot z kapitału"
        },
        {
          "language": "ro",
          "text": "randament al capitalului; rentabilitatea capitalului"
        },
        {
          "language": "ru",
          "text": "рентабельность капитала; доходность капитала"
        },
        {
          "language": "sq",
          "text": "kthim mbi kapitalin; rendiment i kapitalit"
        },
        {
          "language": "tr",
          "text": "sermaye getirisi; sermaye karlılığı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kapitalrendite sank, obwohl der Umsatz deutlich gestiegen ist.",
          "translations": [
            {
              "language": "ar",
              "text": "انخفض العائد على رأس المال رغم أن الإيرادات ارتفعت بشكل واضح."
            },
            {
              "language": "ckb",
              "text": "گەڕانەوەی سەرمایە دابەزی، هەرچەندە داهات بە ڕوونی زیادی کرد."
            },
            {
              "language": "en",
              "text": "The return on capital fell even though revenue increased significantly."
            },
            {
              "language": "fa",
              "text": "بازده سرمایه کاهش یافت، هرچند درآمد به‌طور قابل توجهی افزایش پیدا کرده است."
            },
            {
              "language": "kmr",
              "text": "Vegerê sermayê kêm bû, her çend dahat bi awayekî berbiçav zêde bû."
            },
            {
              "language": "pl",
              "text": "Rentowność kapitału spadła, chociaż przychody wyraźnie wzrosły."
            },
            {
              "language": "ro",
              "text": "Randamentul capitalului a scăzut, deși veniturile au crescut semnificativ."
            },
            {
              "language": "ru",
              "text": "Рентабельность капитала снизилась, хотя выручка заметно выросла."
            },
            {
              "language": "sq",
              "text": "Kthimi mbi kapitalin ra, megjithëse të ardhurat u rritën ndjeshëm."
            },
            {
              "language": "tr",
              "text": "Gelir belirgin şekilde artmış olsa da sermaye getirisi düştü."
            }
          ]
        },
        {
          "baseText": "Für die Investoren zählt nicht nur Wachstum, sondern auch eine stabile Kapitalrendite.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة إلى المستثمرين لا يهم النمو فقط، بل أيضاً عائد مستقر على رأس المال."
            },
            {
              "language": "ckb",
              "text": "بۆ وەبەرهێنەران تەنها گەشە گرنگ نییە، بەڵکو گەڕانەوەیەکی جێگیری سەرمایەش گرنگە."
            },
            {
              "language": "en",
              "text": "For investors, not only growth matters, but also a stable return on capital."
            },
            {
              "language": "fa",
              "text": "برای سرمایه‌گذاران فقط رشد مهم نیست، بلکه بازده پایدار سرمایه هم اهمیت دارد."
            },
            {
              "language": "kmr",
              "text": "Ji bo veberhêneran ne tenê mezinbûn girîng e, lê vegera sermayê ya biîstîqrar jî girîng e."
            },
            {
              "language": "pl",
              "text": "Dla inwestorów liczy się nie tylko wzrost, lecz także stabilna rentowność kapitału."
            },
            {
              "language": "ro",
              "text": "Pentru investitori contează nu doar creșterea, ci și un randament stabil al capitalului."
            },
            {
              "language": "ru",
              "text": "Для инвесторов важен не только рост, но и стабильная рентабельность капитала."
            },
            {
              "language": "sq",
              "text": "Për investitorët nuk ka rëndësi vetëm rritja, por edhe një kthim i qëndrueshëm mbi kapitalin."
            },
            {
              "language": "tr",
              "text": "Yatırımcılar için sadece büyüme değil, istikrarlı sermaye getirisi de önemlidir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Kategorisierung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kategorisierungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ka-te-go-ri-sie-rung",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Kategorisierung vornehmen",
          "meaning": "to carry out a categorization"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kategorisieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Kategorie",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تصنيف؛ تبويب"
        },
        {
          "language": "ckb",
          "text": "پۆلێنکردن؛ دابەشکردن بۆ هاوپۆل"
        },
        {
          "language": "en",
          "text": "categorization; classification"
        },
        {
          "language": "fa",
          "text": "دسته‌بندی؛ طبقه‌بندی"
        },
        {
          "language": "kmr",
          "text": "kategorîkirin; polkirin"
        },
        {
          "language": "pl",
          "text": "kategoryzacja; klasyfikacja"
        },
        {
          "language": "ro",
          "text": "categorisire; clasificare"
        },
        {
          "language": "ru",
          "text": "категоризация; классификация"
        },
        {
          "language": "sq",
          "text": "kategorizim; klasifikim"
        },
        {
          "language": "tr",
          "text": "kategorilendirme; sınıflandırma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kategorisierung der Supportfälle hilft, wiederkehrende Fehler schneller zu erkennen.",
          "translations": [
            {
              "language": "ar",
              "text": "تساعد تصنيفات حالات الدعم في اكتشاف الأخطاء المتكررة بسرعة أكبر."
            },
            {
              "language": "ckb",
              "text": "پۆلێنکردنی کەیسەکانی پشتگیری یارمەتی دەدات هەڵە دووبارەکان خێراتر بناسرێن."
            },
            {
              "language": "en",
              "text": "Categorizing support cases helps identify recurring errors more quickly."
            },
            {
              "language": "fa",
              "text": "دسته‌بندی درخواست‌های پشتیبانی کمک می‌کند خطاهای تکراری سریع‌تر شناسایی شوند."
            },
            {
              "language": "kmr",
              "text": "Kategorîkirina rewşên piştgiriyê alîkar e ku şaşiyên dubare zûtir bêne nasîn."
            },
            {
              "language": "pl",
              "text": "Kategoryzacja zgłoszeń do wsparcia pomaga szybciej rozpoznawać powtarzające się błędy."
            },
            {
              "language": "ro",
              "text": "Categorisirea cazurilor de suport ajută la identificarea mai rapidă a erorilor recurente."
            },
            {
              "language": "ru",
              "text": "Категоризация обращений в поддержку помогает быстрее выявлять повторяющиеся ошибки."
            },
            {
              "language": "sq",
              "text": "Kategorizimi i rasteve të suportit ndihmon të njihen më shpejt gabimet që përsëriten."
            },
            {
              "language": "tr",
              "text": "Destek vakalarının kategorilendirilmesi, tekrarlayan hataların daha hızlı fark edilmesine yardımcı olur."
            }
          ]
        },
        {
          "baseText": "In der Studie wurde die Kategorisierung der Antworten vorab transparent dokumentiert.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدراسة وُثّق تصنيف الإجابات مسبقاً بطريقة شفافة."
            },
            {
              "language": "ckb",
              "text": "لە توێژینەوەکەدا پۆلێنکردنی وەڵامەکان پێشتر بە شێوەی ڕوون تۆمار کرابوو."
            },
            {
              "language": "en",
              "text": "In the study, the categorization of the responses was documented transparently in advance."
            },
            {
              "language": "fa",
              "text": "در این مطالعه، دسته‌بندی پاسخ‌ها از قبل به‌صورت شفاف مستند شده بود."
            },
            {
              "language": "kmr",
              "text": "Di lêkolînê de kategorîkirina bersivan ji berê ve bi zelalî hatibû belgekirin."
            },
            {
              "language": "pl",
              "text": "W badaniu kategoryzację odpowiedzi udokumentowano wcześniej w przejrzysty sposób."
            },
            {
              "language": "ro",
              "text": "În studiu, categorisirea răspunsurilor a fost documentată transparent în prealabil."
            },
            {
              "language": "ru",
              "text": "В исследовании категоризация ответов была заранее прозрачно задокументирована."
            },
            {
              "language": "sq",
              "text": "Në studim, kategorizimi i përgjigjeve u dokumentua paraprakisht në mënyrë transparente."
            },
            {
              "language": "tr",
              "text": "Çalışmada cevapların kategorilendirilmesi önceden şeffaf biçimde belgelenmişti."
            }
          ]
        }
      ]
    },
    {
      "word": "kausal",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "kau-sal",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; often used with Zusammenhang, Wirkung, Erklärung"
      ],
      "collocations": [
        {
          "text": "ein kausaler Zusammenhang",
          "meaning": "a causal connection"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kausalität",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "سببي؛ متعلق بالسبب والنتيجة"
        },
        {
          "language": "ckb",
          "text": "هۆکاری؛ پەیوەندیدار بە هۆ و ئەنجام"
        },
        {
          "language": "en",
          "text": "causal; cause-and-effect"
        },
        {
          "language": "fa",
          "text": "علّی؛ مربوط به علت و معلول"
        },
        {
          "language": "kmr",
          "text": "sedemî; girêdayî sedem û encamê"
        },
        {
          "language": "pl",
          "text": "przyczynowy; związany z przyczyną i skutkiem"
        },
        {
          "language": "ro",
          "text": "cauzal; legat de cauză și efect"
        },
        {
          "language": "ru",
          "text": "каузальный; причинно-следственный"
        },
        {
          "language": "sq",
          "text": "shkakor; i lidhur me shkakun dhe pasojën"
        },
        {
          "language": "tr",
          "text": "nedensel; sebep-sonuçla ilgili"
        }
      ],
      "examples": [
        {
          "baseText": "Aus der Korrelation allein lässt sich kein kausaler Zusammenhang ableiten.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يمكن استنتاج علاقة سببية من الارتباط وحده."
            },
            {
              "language": "ckb",
              "text": "تەنها لە پەیوەندی ئامارییەوە ناتوانرێت پەیوەندییەکی هۆکاری دەربهێنرێت."
            },
            {
              "language": "en",
              "text": "A causal connection cannot be inferred from correlation alone."
            },
            {
              "language": "fa",
              "text": "از همبستگی به‌تنهایی نمی‌توان یک رابطه علّی نتیجه گرفت."
            },
            {
              "language": "kmr",
              "text": "Tenê ji têkiliya amaran nayê derxistin ku girêdanek sedemî heye."
            },
            {
              "language": "pl",
              "text": "Z samej korelacji nie można wyprowadzić związku przyczynowego."
            },
            {
              "language": "ro",
              "text": "Din simpla corelație nu se poate deduce o legătură cauzală."
            },
            {
              "language": "ru",
              "text": "Из одной лишь корреляции нельзя вывести причинно-следственную связь."
            },
            {
              "language": "sq",
              "text": "Vetëm nga korrelacioni nuk mund të nxirret një lidhje shkakore."
            },
            {
              "language": "tr",
