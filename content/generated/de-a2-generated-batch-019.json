      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتقدم بطلب؛ يتقدم لوظيفة"
        },
        {
          "language": "ckb",
          "text": "داواکاری پێشکەشکردن؛ خۆپاڵاوتن بۆ کار"
        },
        {
          "language": "en",
          "text": "to apply; to apply for a job"
        },
        {
          "language": "fa",
          "text": "درخواست دادن؛ برای کار اقدام کردن"
        },
        {
          "language": "kmr",
          "text": "serlêdan kirin; ji bo kar xwe pêşkêş kirin"
        },
        {
          "language": "pl",
          "text": "ubiegać się; aplikować"
        },
        {
          "language": "ro",
          "text": "a candida; a aplica"
        },
        {
          "language": "ru",
          "text": "подавать заявление; устраиваться"
        },
        {
          "language": "sq",
          "text": "të aplikosh"
        },
        {
          "language": "tr",
          "text": "başvurmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte mich um diese Stelle bewerben.",
          "translations": [
            {
              "language": "ar",
              "text": "أريد أن أتقدم لهذه الوظيفة."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت بۆ ئەم کارە خۆم پاڵێو بکەم."
            },
            {
              "language": "en",
              "text": "I would like to apply for this job."
            },
            {
              "language": "fa",
              "text": "می‌خواهم برای این شغل درخواست بدهم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim ji bo vê karê serlêdan bikim."
            },
            {
              "language": "pl",
              "text": "Chcę ubiegać się o to stanowisko."
            },
            {
              "language": "ro",
              "text": "Aș dori să candidez pentru acest post."
            },
            {
              "language": "ru",
              "text": "Я хочу подать заявку на эту должность."
            },
            {
              "language": "sq",
              "text": "Dua të aplikoj për këtë vend pune."
            },
            {
              "language": "tr",
              "text": "Bu işe başvurmak istiyorum."
            }
          ]
        },
        {
          "baseText": "Sie bewirbt sich online für eine Ausbildung.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تتقدم عبر الإنترنت لتدريب مهني."
            },
            {
              "language": "ckb",
              "text": "ئەو ئۆنلاین بۆ ڕاهێنانی پیشەیی خۆی پاڵێو دەکات."
            },
            {
              "language": "en",
              "text": "She applies online for vocational training."
            },
            {
              "language": "fa",
              "text": "او برای یک دوره آموزش حرفه‌ای آنلاین درخواست می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Ew online ji bo perwerdeya pîşeyî serlêdan dike."
            },
            {
              "language": "pl",
              "text": "Ona aplikuje online na szkolenie zawodowe."
            },
            {
              "language": "ro",
              "text": "Ea aplică online pentru o formare profesională."
            },
            {
              "language": "ru",
              "text": "Она подает онлайн-заявку на профессиональное обучение."
            },
            {
              "language": "sq",
              "text": "Ajo aplikon online për trajnim profesional."
            },
            {
              "language": "tr",
              "text": "Mesleki eğitim için çevrim içi başvuruyor."
            }
          ]
        }
      ]
    },
