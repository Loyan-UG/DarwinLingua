      ],
      "examples": [
        {
          "baseText": "Meine Mutter wohnt in Berlin.",
          "translations": [
            {
              "language": "ar",
              "text": "أمي تسكن في برلين."
            },
            {
              "language": "ckb",
              "text": "دایکم لە بەرلین دەژیت."
            },
            {
              "language": "en",
              "text": "My mother lives in Berlin."
            },
            {
              "language": "fa",
              "text": "مادرم در برلین زندگی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Dayika min li Berlînê dijî."
            },
            {
              "language": "pl",
              "text": "Moja mama mieszka w Berlinie."
            },
            {
              "language": "ro",
              "text": "Mama mea locuiește în Berlin."
            },
            {
              "language": "ru",
              "text": "Моя мама живёт в Берлине."
            },
            {
              "language": "sq",
              "text": "Nëna ime jeton në Berlin."
            },
            {
              "language": "tr",
              "text": "Annem Berlin’de yaşıyor."
            }
          ]
        },
        {
          "baseText": "Die Mutter kommt mit dem Kind.",
          "translations": [
            {
              "language": "ar",
              "text": "الأم تأتي مع الطفل."
            },
            {
              "language": "ckb",
              "text": "دایکەکە لەگەڵ منداڵەکە دێت."
            },
            {
              "language": "en",
              "text": "The mother comes with the child."
            },
            {
              "language": "fa",
              "text": "مادر با بچه می‌آید."
            },
            {
              "language": "kmr",
              "text": "Dayik ligel zarokê tê."
            },
            {
              "language": "pl",
              "text": "Matka przychodzi z dzieckiem."
            },
            {
              "language": "ro",
              "text": "Mama vine cu copilul."
            },
            {
              "language": "ru",
              "text": "Мать приходит с ребёнком."
            },
            {
              "language": "sq",
              "text": "Nëna vjen me fëmijën."
            },
            {
              "language": "tr",
              "text": "Anne çocukla geliyor."
            }
          ]
        }
      ]
    },
