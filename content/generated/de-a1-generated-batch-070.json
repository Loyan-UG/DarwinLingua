      "examples": [
        {
          "baseText": "Ich fahre nach Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا ذاهب إلى البيت."
            },
            {
              "language": "ckb",
              "text": "من دەچم بۆ ماڵەوە."
            },
            {
              "language": "en",
              "text": "I am going home."
            },
            {
              "language": "fa",
              "text": "من به خانه می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez diçim malê."
            },
            {
              "language": "pl",
              "text": "Jadę do domu."
            },
            {
              "language": "ro",
              "text": "Merg acasă."
            },
            {
              "language": "ru",
              "text": "Я еду домой."
            },
            {
              "language": "sq",
              "text": "Po shkoj në shtëpi."
            },
            {
              "language": "tr",
              "text": "Eve gidiyorum."
            }
          ]
        },
        {
          "baseText": "Nach dem Kurs gehe ich einkaufen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الدرس أذهب للتسوق."
            },
            {
              "language": "ckb",
              "text": "دوای کۆرسەکە دەچم بازاڕ."
            },
            {
              "language": "en",
              "text": "After the course I go shopping."
            },
            {
              "language": "fa",
              "text": "بعد از کلاس خرید می‌روم."
            },
            {
              "language": "kmr",
              "text": "Piştî kursê ez diçim kirînê."
            },
            {
              "language": "pl",
              "text": "Po kursie idę na zakupy."
            },
            {
              "language": "ro",
              "text": "După curs merg la cumpărături."
            },
            {
              "language": "ru",
              "text": "После курса я иду за покупками."
            },
            {
              "language": "sq",
              "text": "Pas kursit shkoj për pazar."
            },
            {
              "language": "tr",
              "text": "Kurstan sonra alışverişe gidiyorum."
            }
          ]
        }
      ]
