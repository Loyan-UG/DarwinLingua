            {
              "language": "tr",
              "text": "Usta kapıyı tamir ediyor."
            }
          ]
        },
        {
          "baseText": "Wir brauchen morgen einen Handwerker.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج غداً إلى عامل صيانة."
            },
            {
              "language": "ckb",
              "text": "سبەی پێویستمان بە پیشەوەرێکە."
            },
            {
              "language": "en",
              "text": "We need a tradesman tomorrow."
            },
            {
              "language": "fa",
              "text": "ما فردا به یک تعمیرکار نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Em sibê hewceyê hostayekî ne."
            },
            {
              "language": "pl",
              "text": "Jutro potrzebujemy fachowca."
            },
            {
              "language": "ro",
              "text": "Mâine avem nevoie de un meșter."
            },
            {
              "language": "ru",
              "text": "Завтра нам нужен мастер."
            },
            {
              "language": "sq",
              "text": "Nesër na duhet një mjeshtër."
