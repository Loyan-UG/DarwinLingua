          "text": "pulë"
        },
        {
          "language": "tr",
          "text": "tavuk"
        }
      ],
      "examples": [
        {
          "baseText": "Ich nehme das Hähnchen mit Reis.",
          "translations": [
            {
              "language": "ar",
              "text": "سآخذ الدجاج مع الأرز."
            },
            {
              "language": "ckb",
              "text": "مریشکەکە لەگەڵ برنج وەردەگرم."
            },
            {
              "language": "en",
              "text": "I’ll have the chicken with rice."
            },
            {
              "language": "fa",
              "text": "مرغ را با برنج می‌خواهم."
            },
            {
              "language": "kmr",
              "text": "Ez mirîşkê bi birincê dixwazim."
            },
            {
              "language": "pl",
              "text": "Wezmę kurczaka z ryżem."
            },
            {
              "language": "ro",
              "text": "Iau puiul cu orez."
            },
            {
              "language": "ru",
              "text": "Я возьму курицу с рисом."
            },
            {
              "language": "sq",
              "text": "Do të marr pulën me oriz."
            },
            {
              "language": "tr",
              "text": "Pilavlı tavuk alayım."
            }
          ]
        },
        {
          "baseText": "Das Hähnchen ist noch warm.",
          "translations": [
            {
              "language": "ar",
              "text": "الدجاج لا يزال دافئاً."
            },
            {
              "language": "ckb",
              "text": "مریشکەکە هێشتا گەرمە."
            },
            {
              "language": "en",
              "text": "The chicken is still warm."
            },
            {
              "language": "fa",
              "text": "مرغ هنوز گرم است."
            },
            {
              "language": "kmr",
              "text": "Mirîşk hêj germ e."
            },
            {
              "language": "pl",
              "text": "Kurczak jest jeszcze ciepły."
            },
            {
              "language": "ro",
              "text": "Puiul este încă cald."
            },
            {
              "language": "ru",
              "text": "Курица ещё тёплая."
            },
            {
              "language": "sq",
              "text": "Pula është ende e ngrohtë."
            },
            {
              "language": "tr",
              "text": "Tavuk hâlâ sıcak."
            }
          ]
        }
