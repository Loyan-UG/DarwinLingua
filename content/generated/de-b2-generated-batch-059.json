  "entries": [
    {
      "word": "die Bauprojekt",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "die Bauprojekte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Bau-pro-jekt",
      "topics": [
        "housing-and-real-estate",
        "planning-and-projects",
        "work-and-jobs"
      ],
      "usageLabels": [
        "workplace",
        "business",
        "written"
      ],
      "contextLabels": [
        "documents"
      ],
      "meanings": [
        {
          "text": "مشروع بناء",
          "language": "ar"
        },
        {
          "text": "پرۆژەی چەندیناسازە",
          "language": "ckb"
        },
        {
          "text": "construction project",
          "language": "en"
        },
        {
          "text": "پروژه ساختمانی",
          "language": "fa"
        },
        {
          "text": "projeya avahiyan",
          "language": "kmr"
        },
        {
          "text": "projekt budowlany",
          "language": "pl"
        },
        {
          "text": "proiect de construcție",
          "language": "ro"
        },
        {
          "text": "строительный проект",
          "language": "ru"
        },
        {
          "text": "projekt ndërtimi",
          "language": "sq"
        },
        {
          "text": "inşaat projesi",
          "language": "tr"
        }
      ],
      "examples": [
        {
          "translations": [
            {
              "text": "بقي مشروع بناء مرکز داده جدید در چارچوب بودجه مصوب.",
              "language": "ar"
            },
            {
              "text": "پرۆژەی چەندیناسازی ناوەڕاستە بۆ کۆمپیوتەرە نوێکە لە هەژمارەی بودجه‌ی ڕێگەپێدراودا مانەوە.",
              "language": "ckb"
            },
            {
              "text": "The construction project for the new data center remained within the approved budget.",
              "language": "en"
            },
            {
              "text": "پروژه ساختمانی مرکز داده‌ی جدید در چارچوب بودجه‌ی تایید شده باقی ماند.",
              "language": "fa"
            },
            {
              "text": "Projeya avahiyê bo merkezê datayan nû di nav çarçoveya bugeta erêkirî de maye.",
              "language": "kmr"
            },
            {
              "text": "Projekt budowlany nowego centrum danych pozostał w zatwierdzonym budżecie.",
              "language": "pl"
            },
            {
              "text": "Proiectul de construcție pentru noul centru de date a rămas în bugetul aprobat.",
              "language": "ro"
            },
            {
              "text": "Строительный проект нового центра обработки данных остался в пределах одобренного бюджета.",
              "language": "ru"
            },
            {
              "text": "Projekti i ndërtimit për qendrën e re të të dhënave mbeti brenda buxhetit të miratuar.",
              "language": "sq"
            },
            {
              "text": "Yeni veri merkezi için inşaat projesi onaylanan bütçe kapsamı içinde kaldı.",
              "language": "tr"
            }
          ],
          "baseText": "Das Bauprojekt für das neue Rechenzentrum ist im genehmigten Budgetrahmen geblieben."
        },
        {
          "translations": [
            {
              "text": "ما ننسق بين فرق المشروع مع فرق تكنولوجيا المعلومات وحماية البيانات وسلامة العمل.",
              "language": "ar"
            },
            {
              "text": "ئێمە لە پرۆژەی چەندیناسازیەکەدا لەگەڵ تیمەکانی IT و پاراستنی زانیاری و ئاسایشی کاردا هاوکاری دەکەین.",
              "language": "ckb"
            },
            {
              "text": "We coordinate the construction project trades with IT, data-protection, and workplace safety teams.",
              "language": "en"
            },
            {
              "text": "در پروژه ساخت، بخش‌های کارگاهی را با تیم‌های IT، حفاظت از داده‌ها و ایمنی محیط کار هماهنگ می‌کنیم.",
              "language": "fa"
            },
            {
              "text": "Di projeya avahiyê de em bi tîmên IT, parastina daneyan û ewlehiyê li cîhê karê re hevkariya wekeşînin.",
              "language": "kmr"
            },
            {
              "text": "Koordynujemy branże w projekcie budowlanym z zespołami IT, ochrony danych i bezpieczeństwa pracy.",
              "language": "pl"
            },
            {
              "text": "Coordinăm meseriile din proiectul de construcție cu echipele IT, protecția datelor și siguranța muncii.",
              "language": "ro"
            },
            {
              "text": "Мы координируем работы в строительном проекте с IT-, службой защиты данных и охраной труда.",
              "language": "ru"
            },
            {
              "text": "Koordinojmë pjesët e projektit të ndërtimit me ekipet e IT-së, mbrojtjes së të dhënave dhe sigurisë në punë.",
              "language": "sq"
            },
            {
              "text": "İnşaat projesinde IT, veri koruma ve iş güvenliği ekipleriyle çalışmaları koordine ediyoruz.",
              "language": "tr"
            }
          ],
          "baseText": "Wir koordinieren die Gewerke im Bauprojekt mit IT-, Datenschutz- und Arbeitssicherheitsteams."
        }
      ]
    },
    {
      "word": "die Bebauung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "die Bebauungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-bau-ung",
      "topics": [
        "housing-and-real-estate",
        "work-and-jobs",
        "housing-and-real-estate"
      ],
      "usageLabels": [
        "business",
        "written",
        "workplace"
      ],
      "contextLabels": [
        "documents"
      ],
      "meanings": [
        {
          "text": "توسعه ساخت‌وساز; بافت مسکونی",
          "language": "ar"
        },
        {
          "text": "بوونیەکی دانراوە؛ دروستکردن",
          "language": "ckb"
        },
        {
          "text": "development; building density",
          "language": "en"
        },
        {
          "text": "ساخت و ساز؛ تراکم ساخت",
          "language": "fa"
        },
        {
          "text": "avahî; serbestiya avahin",
          "language": "kmr"
        },
        {
          "text": "zabudowa",
          "language": "pl"
        },
        {
          "text": "zonă construită",
          "language": "ro"
        },
        {
          "text": "застройка",
          "language": "ru"
        },
        {
          "text": "ndërtim; lagje",
          "language": "sq"
        },
        {
          "text": "imar",
          "language": "tr"
        }
      ],
      "examples": [
        {
          "translations": [
            {
              "text": "باید توسعه ساختمانی در حاشیه با مفاهیم معماری سازگار شود.",
              "language": "ar"
            },
            {
              "text": "بەشداری کردنی باڤەکان لەسەر دەوری باجگە باید لە پلانە فێڵانەی ئاراخوەتدا جێگیر بکرێت.",
              "language": "ckb"
            },
            {
              "text": "The development on the edge of the site must be adjusted in the architecture concept.",
              "language": "en"
            },
            {
              "text": "بافت ساخت و ساز اطراف سایت باید در چارچوب مفهومی معماری اصلاح شود.",
              "language": "fa"
            },
            {
              "text": "Bebauung li gilî herêmê divê di plana arhîtêktûrê de hate guheztin.",
              "language": "kmr"
            },
            {
              "text": "Zabudowa na obrzeżu terenu musi zostać dostosowana w koncepcji architektonicznej.",
              "language": "pl"
            },
            {
              "text": "Dezvoltarea din marginea amplasamentului trebuie ajustată în conceptul arhitectural.",
              "language": "ro"
            },
            {
              "text": "Застройку на краю участка нужно учесть в архитектурной концепции.",
              "language": "ru"
            },
            {
              "text": "Zhvillimi në skajin e truallit duhet të përshtatet në konceptin arkitekturor.",
              "language": "sq"
            },
            {
              "text": "Sahanın kenarındaki imar planı mimari konseptte güncellenmelidir.",
              "language": "tr"
            }
          ],
          "baseText": "Die Bebauung im Randbereich muss im Architekturkonzept angepasst werden."
        },
        {
          "translations": [
            {
              "text": "پیش از ارسال مناقصه به دفاتر خارجی، توسعه محوطه را در محل عکس‌برداری کردیم.",
              "language": "ar"
            },
            {
              "text": "پێش ئەوەی ئینگازی بیرکاری بۆ نێو ئێمەکان بچێت، باجگەی نزمەکە ئاماژەیان دەینەوە.",
              "language": "ckb"
            },
            {
              "text": "We documented the site development on location before sending the tender to external offices.",
              "language": "en"
            },
            {
              "text": "ما قبل از ارسال فراخوان به دفاتر بیرونی، تراکم ساخت را در محل ثبت کردیم.",
              "language": "fa"
            },
            {
              "text": "Em biçûkîyên bebauingê li deverê şopandin berî şandinê bo ofîsên derve.",
              "language": "kmr"
            },
            {
              "text": "Udokumentowaliśmy zabudowę na miejscu, zanim przetarg został wysłany do zewnętrznych biur.",
              "language": "pl"
            },
            {
              "text": "Am documentat dezvoltarea amplasamentului pe teren înainte de a trimite oferta către birourile externe.",
              "language": "ro"
            },
            {
              "text": "Мы зафиксировали застройку на месте до отправки тендера во внешние бюро.",
              "language": "ru"
            },
            {
              "text": "Ne dokumentuam zhvillimin e truallit në vendngjarje para se tenderi të dërgohej te zyrat e jashtme.",
              "language": "sq"
            },
            {
              "text": "Dış ofislere ihale göndermeden önce arazi imarını sahada belgelemiştik.",
              "language": "tr"
            }
          ],
          "baseText": "Wir haben die Bebauung vor Ort fotografiert, bevor die Ausschreibung an externe Büros ging."
        }
      ]
    },
