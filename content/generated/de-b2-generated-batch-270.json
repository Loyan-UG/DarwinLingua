  "entries": [
    {
      "word": "zusammenschieben",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zusammenschieben",
      "pronunciationIpa": null,
      "syllableBreak": "zu-sam-men-schie-ben",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "meetings-and-presentations"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "administration",
        "management"
      ],
      "grammarNotes": [
        "separable verb",
        "means to push things closer together"
      ],
      "collocations": [
        {
          "text": "Tische zusammenschieben",
          "meaning": "to push tables together"
        },
        {
          "text": "Termine zusammenschieben",
          "meaning": "to squeeze appointments closer together"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schieben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدفع الأشياء معًا؛ يقرّبها من بعضها"
        },
        {
          "language": "ckb",
          "text": "شتەکان بەیەکەوە پاڵ پێوەنان؛ نزیککردنەوە"
        },
        {
          "language": "en",
          "text": "to push together; to move closer together"
        },
        {
          "language": "fa",
          "text": "به هم نزدیک کردن؛ کنار هم هل دادن"
        },
        {
          "language": "kmr",
          "text": "li hev dehfandin; nêzî hev kirin"
        },
        {
          "language": "pl",
          "text": "zsunąć; przesunąć razem"
        },
        {
          "language": "ro",
          "text": "a împinge împreună; a apropia"
        },
        {
          "language": "ru",
          "text": "сдвинуть вместе; придвинуть друг к другу"
        },
        {
          "language": "sq",
          "text": "t’i shtysh bashkë; t’i afroni"
        },
        {
          "language": "tr",
          "text": "birbirine doğru itmek; yan yana getirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir schieben die Tische zusammen, damit alle Projektgruppen im selben Raum arbeiten können.",
          "translations": [
            {
              "language": "ar",
              "text": "سنقرب الطاولات من بعضها حتى تتمكن كل مجموعات المشروع من العمل في الغرفة نفسها."
            },
            {
              "language": "ckb",
              "text": "مێزەکان بەیەکەوە نزیک دەکەینەوە، بۆ ئەوەی هەموو گرووپەکانی پڕۆژە لە هەمان ژووردا کار بکەن."
            },
            {
              "language": "en",
              "text": "We are pushing the tables together so all project groups can work in the same room."
            },
            {
              "language": "fa",
              "text": "میزها را کنار هم می‌گذاریم تا همه گروه‌های پروژه بتوانند در یک اتاق کار کنند."
            },
            {
              "language": "kmr",
              "text": "Em maseyan li hev dixin da ku hemû komên projeyê di heman odeyê de bixebitin."
            },
            {
              "language": "pl",
              "text": "Zsuwamy stoły, aby wszystkie grupy projektowe mogły pracować w tej samej sali."
            },
            {
              "language": "ro",
              "text": "Împingem mesele una lângă alta, ca toate grupurile de proiect să poată lucra în aceeași sală."
            },
            {
              "language": "ru",
              "text": "Мы сдвигаем столы вместе, чтобы все проектные группы могли работать в одной комнате."
            },
            {
              "language": "sq",
              "text": "Po i afrojmë tavolinat që të gjitha grupet e projektit të punojnë në të njëjtën dhomë."
            },
            {
              "language": "tr",
              "text": "Tüm proje grupları aynı odada çalışabilsin diye masaları birleştiriyoruz."
            }
          ]
        },
        {
          "baseText": "Wenn wir die Termine zu stark zusammenschieben, bleibt den Patienten kaum Zeit für Fragen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا ضغطنا المواعيد كثيرًا، فلن يبقى للمرضى وقت كافٍ للأسئلة."
            },
            {
              "language": "ckb",
              "text": "ئەگەر کاتەکان زۆر نزیک بکەینەوە، نەخۆشەکان کاتی پێویستیان بۆ پرسیار نامێنێت."
            },
            {
              "language": "en",
              "text": "If we squeeze the appointments too closely together, patients will hardly have time for questions."
            },
            {
              "language": "fa",
              "text": "اگر وقت‌ها را بیش از حد فشرده کنیم، بیماران تقریباً زمانی برای سؤال نخواهند داشت."
            },
            {
              "language": "kmr",
              "text": "Heke em randevûyan pir nêzî hev bikin, ji nexweşan re zêde dem ji bo pirsan namîne."
            },
            {
              "language": "pl",
              "text": "Jeśli zbyt mocno ściśniemy terminy, pacjentom prawie nie zostanie czasu na pytania."
            },
            {
              "language": "ro",
              "text": "Dacă înghesuim prea mult programările, pacienților le rămâne foarte puțin timp pentru întrebări."
            },
            {
              "language": "ru",
              "text": "Если мы слишком сильно сдвинем записи, у пациентов почти не останется времени на вопросы."
            },
            {
              "language": "sq",
              "text": "Nëse i ngjeshim shumë takimet, pacientëve u mbetet shumë pak kohë për pyetje."
            },
            {
              "language": "tr",
              "text": "Randevuları çok sıkıştırırsak hastalara soru sormak için neredeyse hiç zaman kalmaz."
            }
          ]
        }
      ]
    },
    {
      "word": "zusammenschlagen",
