          "text": "e mërkurë"
        },
        {
          "language": "tr",
          "text": "çarşamba"
        }
      ],
      "examples": [
        {
          "baseText": "Am Mittwoch habe ich frei.",
          "translations": [
            {
              "language": "ar",
              "text": "يوم الأربعاء لديّ إجازة."
            },
            {
              "language": "ckb",
              "text": "چوارشەممە پشووەم هەیە."
            },
            {
              "language": "en",
              "text": "I have the day off on Wednesday."
            },
            {
              "language": "fa",
              "text": "چهارشنبه آزاد هستم."
            },
            {
              "language": "kmr",
              "text": "Çarşemê ez azad im."
            },
            {
              "language": "pl",
              "text": "W środę mam wolne."
            },
            {
              "language": "ro",
              "text": "Miercuri sunt liber."
            },
            {
              "language": "ru",
              "text": "В среду у меня выходной."
            },
            {
              "language": "sq",
              "text": "Të mërkurën jam pushim."
            },
            {
              "language": "tr",
              "text": "Çarşamba günü izinliyim."
            }
          ]
        },
        {
          "baseText": "Der Kurs ist am Mittwoch.",
          "translations": [
            {
              "language": "ar",
              "text": "الدورة يوم الأربعاء."
            },
            {
              "language": "ckb",
              "text": "کۆرسەکە چوارشەممەیە."
            },
            {
              "language": "en",
              "text": "The course is on Wednesday."
            },
            {
              "language": "fa",
              "text": "کلاس روز چهارشنبه است."
            },
            {
              "language": "kmr",
              "text": "Kurs roja çarşemê ye."
            },
            {
              "language": "pl",
              "text": "Kurs jest w środę."
            },
            {
              "language": "ro",
              "text": "Cursul este miercuri."
            },
            {
              "language": "ru",
              "text": "Курс в среду."
            },
            {
              "language": "sq",
              "text": "Kursi është të mërkurën."
            },
            {
              "language": "tr",
              "text": "Kurs çarşamba günü."
            }
          ]
        }
      ]
