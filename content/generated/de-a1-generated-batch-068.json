            {
              "language": "ru",
              "text": "Возможна ли встреча сегодня?"
            },
            {
              "language": "sq",
              "text": "A është i mundur një takim sot?"
            },
            {
              "language": "tr",
              "text": "Bugün randevu mümkün mü?"
            }
          ]
        },
        {
          "baseText": "Bitte kommen Sie, wenn möglich, früher.",
