      "examples": [
        {
          "baseText": "Ist ein Termin heute möglich?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكن تحديد موعد اليوم؟"
            },
            {
              "language": "ckb",
              "text": "ئایا ئەمڕۆ کاتێک مومکینە؟"
            },
            {
              "language": "en",
              "text": "Is an appointment possible today?"
            },
            {
              "language": "fa",
              "text": "آیا امروز وقت ملاقات ممکن است؟"
            },
            {
              "language": "kmr",
              "text": "Ma îro hevdîtinek gengaz e?"
            },
            {
              "language": "pl",
