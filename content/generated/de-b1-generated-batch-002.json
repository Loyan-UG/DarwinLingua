      "grammarNotes": [
        "masculine noun",
        "means process, sequence, or course of events"
      ],
      "collocations": [
        {
          "text": "der genaue Ablauf",
          "meaning": "the exact procedure"
        },
        {
          "text": "einen Ablauf erklären",
          "meaning": "to explain a process"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "ablaufen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "سير العملية؛ تسلسل؛ إجراء"
        },
        {
          "language": "ckb",
          "text": "ڕەوت؛ زنجیرەی هەنگاوەکان؛ شێوازی بەڕێوەچوون"
        },
        {
          "language": "en",
          "text": "process; sequence; procedure"
        },
        {
          "language": "fa",
          "text": "روند؛ ترتیب کار؛ فرایند"
        },
        {
          "language": "kmr",
          "text": "pêvajo; rêz; awayê meşandinê"
        },
        {
          "language": "pl",
          "text": "przebieg; procedura; kolejność"
        },
        {
          "language": "ro",
          "text": "desfășurare; procedură; succesiune"
        },
        {
          "language": "ru",
          "text": "ход; процесс; порядок действий"
        },
        {
          "language": "sq",
          "text": "rrjedhë; procedurë; rend veprimesh"
        },
        {
          "language": "tr",
          "text": "süreç; akış; prosedür"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie mir den Ablauf der Anmeldung kurz erklären?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم أن تشرحوا لي باختصار سير عملية التسجيل؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن بە کورتی ڕەوتی تۆمارکردنم بۆ روون بکەنەوە؟"
            },
            {
              "language": "en",
              "text": "Can you briefly explain the registration process to me?"
            },
            {
              "language": "fa",
              "text": "می‌توانید روند ثبت‌نام را کوتاه برایم توضیح دهید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin bi kurtî pêvajoya tomarê ji min re şirove bikin?"
            },
            {
              "language": "pl",
              "text": "Czy może mi Pan/Pani krótko wyjaśnić przebieg rejestracji?"
            },
            {
              "language": "ro",
              "text": "Îmi puteți explica pe scurt procedura de înregistrare?"
            },
            {
              "language": "ru",
              "text": "Можете кратко объяснить мне процесс регистрации?"
            },
            {
              "language": "sq",
              "text": "A mund të ma shpjegoni shkurt procesin e regjistrimit?"
            },
            {
              "language": "tr",
              "text": "Kayıt sürecini bana kısaca açıklayabilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Im Teammeeting besprechen wir morgen den Ablauf der nächsten zwei Wochen.",
          "translations": [
            {
              "language": "ar",
              "text": "في اجتماع الفريق سنناقش غدًا خطة سير العمل للأسبوعين القادمين."
            },
            {
              "language": "ckb",
              "text": "لە کۆبوونەوەی تیمدا سبەی ڕەوتی دوو هەفتەی داهاتوو باس دەکەین."
            },
            {
              "language": "en",
              "text": "In the team meeting tomorrow, we will discuss the schedule for the next two weeks."
            },
            {
              "language": "fa",
              "text": "در جلسه تیمی فردا روند دو هفته آینده را بررسی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di civîna tîmê ya sibê de em ê pêvajoya du hefteyên bê gotûbêj bikin."
            },
            {
              "language": "pl",
              "text": "Na jutrzejszym spotkaniu zespołu omówimy przebieg najbliższych dwóch tygodni."
            },
            {
              "language": "ro",
              "text": "La ședința de echipă de mâine discutăm desfășurarea următoarelor două săptămâni."
            },
            {
              "language": "ru",
              "text": "На завтрашней встрече команды мы обсудим план на следующие две недели."
            },
            {
              "language": "sq",
              "text": "Në takimin e ekipit nesër do të diskutojmë rrjedhën e dy javëve të ardhshme."
            },
            {
              "language": "tr",
              "text": "Yarınki ekip toplantısında önümüzdeki iki haftanın akışını konuşacağız."
            }
          ]
        }
      ]
    },
