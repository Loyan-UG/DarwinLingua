      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb phrase; separable in sentence structure as gehen ... essen"
      ],
      "collocations": [
        {
          "text": "heute essen gehen",
          "meaning": "to go out to eat today"
        },
        {
          "text": "mit Freunden essen gehen",
          "meaning": "to go out to eat with friends"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "essen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "gehen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يخرج لتناول الطعام"
        },
        {
          "language": "ckb",
          "text": "چوون بۆ خواردن لە دەرەوە"
        },
        {
          "language": "en",
          "text": "to go out to eat"
        },
        {
          "language": "fa",
          "text": "برای غذا خوردن بیرون رفتن"
        },
        {
          "language": "kmr",
          "text": "ji bo xwarinê derketin"
        },
        {
          "language": "pl",
          "text": "iść coś zjeść; iść do restauracji"
        },
        {
          "language": "ro",
          "text": "a ieși să mănânci"
        },
        {
          "language": "ru",
          "text": "пойти поесть вне дома"
        },
        {
          "language": "sq",
          "text": "dal për të ngrënë"
        },
        {
          "language": "tr",
          "text": "dışarıda yemek yemeye gitmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir gehen heute essen.",
          "translations": [
            {
              "language": "ar",
              "text": "سنخرج اليوم لتناول الطعام."
            },
            {
              "language": "ckb",
              "text": "ئێمە ئەمڕۆ دەچین بۆ خواردن."
            },
            {
              "language": "en",
              "text": "We are going out to eat today."
            },
            {
              "language": "fa",
              "text": "ما امروز برای غذا خوردن بیرون می‌رویم."
            },
            {
              "language": "kmr",
              "text": "Em îro ji bo xwarinê derdikevin."
            },
            {
              "language": "pl",
              "text": "Dzisiaj idziemy coś zjeść."
            },
            {
              "language": "ro",
              "text": "Astăzi ieșim să mâncăm."
            },
            {
              "language": "ru",
              "text": "Сегодня мы идем поесть вне дома."
            },
            {
              "language": "sq",
              "text": "Sot dalim për të ngrënë."
            },
            {
              "language": "tr",
              "text": "Bugün dışarıda yemek yemeye gidiyoruz."
            }
          ]
        },
        {
          "baseText": "Möchtest du mit uns essen gehen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل تريد أن تخرج معنا لتناول الطعام؟"
            },
            {
              "language": "ckb",
              "text": "دەتەوێ لەگەڵمان بچیت بۆ خواردن؟"
            },
            {
              "language": "en",
              "text": "Would you like to go out to eat with us?"
            },
            {
              "language": "fa",
              "text": "می‌خواهی با ما برای غذا خوردن بیرون بیایی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dixwazî bi me re biçî xwarinê?"
            },
            {
              "language": "pl",
              "text": "Czy chcesz pójść z nami coś zjeść?"
            },
            {
              "language": "ro",
              "text": "Vrei să ieși să mănânci cu noi?"
            },
            {
              "language": "ru",
              "text": "Хочешь пойти с нами поесть?"
            },
            {
              "language": "sq",
              "text": "A do të dalësh me ne për të ngrënë?"
            },
            {
              "language": "tr",
              "text": "Bizimle yemeğe gitmek ister misin?"
            }
          ]
        }
      ]
    },
