  "entries": [
    {
      "word": "anstreichen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anstreichen",
      "pronunciationIpa": null,
      "syllableBreak": "an-strei-chen",
      "topics": [
        "work-and-jobs",
        "documents-and-administration",
        "technology-and-it"
      ],
      "usageLabels": [
        "workplace",
        "technical",
        "written"
      ],
      "contextLabels": [
        "it",
        "support"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تلوين أو طلاء"
        },
        {
          "language": "ckb",
          "text": "ڕەنگکردن/لاو لێهێنان"
        },
        {
          "language": "en",
          "text": "to paint; to coat"
        },
        {
          "language": "fa",
          "text": "رنگ کردن؛ پوشاندن"
        },
        {
          "language": "kmr",
          "text": "rengkirin; şûndeqandin"
        },
        {
          "language": "pl",
          "text": "malować; szacować (wynik)"
        },
        {
          "language": "ro",
          "text": "a vopsi; a estima"
        },
        {
          "language": "ru",
          "text": "красить; предполагать (о цене)"
        },
        {
          "language": "sq",
          "text": "të lyë; të mbështjellë"
        },
        {
          "language": "tr",
          "text": "boyamak; kaplamak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Server-Rack wird in der Werkhalle vor der Wartung nicht mit Farbe, sondern nur mit Schutzfolie angebracht und angehängt.",
          "translations": [
            {
              "language": "ar",
              "text": "قایسای سرور پیش از تعمیر با رنگ پوشانده نمی‌شود، بلکه با پوشش حفاظتی و برچسب پوشانده می‌شود."
            },
            {
              "language": "ckb",
              "text": "ڕەفەکەی سێرڤەر پێش هەمواریکردن بە ڕەنگ نەکرێت، تەنها بە شیتە پاراستنی تێپەڕدرێت."
            },
            {
              "language": "en",
              "text": "Before maintenance, the server rack is not painted but only marked with protective coating and labels."
            },
            {
              "language": "fa",
              "text": "قبل از نگهداری، رک قفسه سرور با رنگ پوشش داده نمی‌شود و فقط با لایه محافظ و برچسب علامت‌گذاری می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ber dewsandinê racka serverê bi reng nayê anîn, tenê bi qopkirina parastin û etîkêtan qeyd dibe."
            },
            {
              "language": "pl",
              "text": "Przed serwisem szafę serwerową nie maluje się, a jedynie nakłada na nią osłonę ochronną i etykiety."
            },
            {
              "language": "ro",
              "text": "Înainte de mentenanță, rack-ul serverelor nu este vopsit, ci etichetat și acoperit cu protecție."
            },
            {
              "language": "ru",
              "text": "Перед техобслуживанием стойка сервера не красится, а лишь покрывается защитной плёнкой и маркируется."
            },
            {
              "language": "sq",
              "text": "Para mirëmbajtjes, rack-u i serverit nuk lyhet me ngjyrë, por vetëm mbulohet me film mbrojtës dhe etiketëzohet."
            },
            {
              "language": "tr",
              "text": "Bakım öncesinde sunucu rafı boyanmaz; sadece koruyucu kaplama ve etiket ile işaretlenir."
            }
          ]
        },
        {
          "baseText": "Im Projektplan wurde der Anteil für Reservekosten vorsichtig überschätzt, nicht angehoben.",
          "translations": [
            {
              "language": "ar",
              "text": "در طرح پروژه، سهم هزینه ذخیره را با احتیاط کمی بیش‌برآوردی شد، بدون افزایش ناگهانی."
            },
            {
              "language": "ckb",
              "text": "لە پلانی پڕۆژەدا بەهێزی خەرجیەکە بە تەنەختی بەرزتر کرایەوە، بەبێ قەڵە."
            },
            {
              "language": "en",
              "text": "In the project plan, reserve costs were estimated slightly higher, not overinflated."
            },
            {
              "language": "fa",
              "text": "در برنامه پروژه، سهم هزینه ذخیره کمی بیشتر پیش‌بینی شد، نه بیش‌برآوردی."
            },
            {
              "language": "kmr",
              "text": "Di plani projesê de xercên rezervayê piçuk mezelkirin, ne bi qetayî."
            },
            {
              "language": "pl",
              "text": "W planie projektu rezerwa kosztów została oszacowana nieco wyżej, ale nie przesadzono."
            },
            {
              "language": "ro",
              "text": "În planul proiectului, costul de rezervă a fost estimat ușor mai sus, nu exagerat."
            },
            {
              "language": "ru",
              "text": "В плане проекта резервные расходы были слегка завышены, но без чрезмерного завышения."
            },
            {
              "language": "sq",
              "text": "Në planin e projektit, kostoja rezervë u vlerësua paksa më lart, pa e fryrëte."
            },
            {
              "language": "tr",
              "text": "Proje planında yedek maliyetler biraz daha yüksek öngörüldü, aşırı abartılmadan."
            }
          ]
        }
      ]
    },
    {
      "word": "antreffen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "antreffen",
      "pronunciationIpa": null,
      "syllableBreak": "an-tref-fen",
      "topics": [
        "work-and-jobs",
        "business-communication",
        "documents-and-administration"
      ],
      "usageLabels": [
        "workplace",
        "meeting",
        "formal"
      ],
      "contextLabels": [
        "administration",
        "customer-service"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "مواجهه کردن/ملاقات کردن"
        },
        {
          "language": "ckb",
          "text": "ڕێکچووە لەگەڵ"
        },
        {
          "language": "en",
          "text": "to meet; to come across"
        },
        {
          "language": "fa",
          "text": "با کسی روبه‌رو شدن؛ ملاقات کردن"
        },
        {
          "language": "kmr",
          "text": "rasthatin; civiya"
        },
        {
          "language": "pl",
          "text": "spotykać; napotkać"
        },
        {
          "language": "ro",
          "text": "a întâlni; a se întâlni cu"
        },
        {
          "language": "ru",
          "text": "встречать; случайно встретить"
        },
        {
          "language": "sq",
          "text": "të takosh; të hasësh"
        },
        {
          "language": "tr",
          "text": "karşılaşmak; birini görmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir sollten den Datenschutzbeauftragten früh treffen, bevor die Unterlagen verteilt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "باید قبل از توزیع اسناد، با مسئول حفاظت داده‌ها ملاقات کنیم."
            },
            {
              "language": "ckb",
              "text": "پێش ئەوەی داهاتوویەکان پەخش بکەین، پیرۆزەی پاراستنی داتاکان لە سەرەتادا بیستین."
            },
            {
              "language": "en",
              "text": "We should meet the data protection officer before distributing the documents."
            },
            {
              "language": "fa",
              "text": "باید قبل از توزیع مدارک با مسئول حفاظت داده‌ها ملاقات کنیم."
            },
            {
              "language": "kmr",
              "text": "Pêwîst e ber belavkirina belgeyan bi pisîkê xwe re bi DPOyê civiya bikin."
            },
            {
              "language": "pl",
              "text": "Powinniśmy spotkać się z inspektorem ochrony danych przed dystrybucją dokumentów."
            },
            {
              "language": "ro",
              "text": "Ar trebui să îl întâlnim pe responsabilul cu protecția datelor înainte de distribuirea documentelor."
            },
            {
              "language": "ru",
              "text": "Мы должны встретиться с офицером по защите данных до распространения документов."
            },
            {
              "language": "sq",
              "text": "Duhet ta takohemi me mbrojtjen e të dhënave para shpërndarjes së dokumenteve."
            },
            {
              "language": "tr",
