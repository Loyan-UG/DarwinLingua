      "meanings": [
        {
          "language": "ar",
          "text": "السعر الموصى به"
        },
        {
          "language": "ckb",
          "text": "نرخی پێشنیارکراو"
        },
        {
          "language": "en",
          "text": "recommended price"
        },
        {
          "language": "fa",
          "text": "قیمت پیشنهادی"
        },
        {
          "language": "kmr",
          "text": "bihayê pêşniyarkirî"
        },
        {
          "language": "pl",
          "text": "cena rekomendowana"
        },
        {
          "language": "ro",
          "text": "preț recomandat"
        },
        {
          "language": "ru",
          "text": "рекомендованная цена"
        },
        {
          "language": "sq",
          "text": "çmim i rekomanduar"
        },
        {
          "language": "tr",
          "text": "önerilen fiyat"
        }
      ],
      "examples": [
        {
          "baseText": "Der empfohlene Preis wird im ERP aus Einkaufskosten, Zielmarge und aktuellen Marktbedingungen berechnet.",
          "translations": [
            {
              "language": "ar",
              "text": "يُحسب السعر الموصى به في نظام ERP من تكاليف الشراء والهامش المستهدف وظروف السوق الحالية."
            },
            {
              "language": "ckb",
              "text": "نرخی پێشنیارکراو لە ERPدا لە تێچووی کڕین و بارودۆخی بازاڕ حیساب دەکرێت."
            },
            {
              "language": "en",
              "text": "The recommended price is calculated in the ERP system from purchasing costs, target margin, and current market conditions."
            },
            {
              "language": "fa",
              "text": "قیمت پیشنهادی در ERP از هزینه خرید، حاشیه سود هدف و شرایط بازار محاسبه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Bihayê pêşniyarkirî di ERP de ji lêçûn, marj û mercên bazarê tê hesabkirin."
            },
            {
              "language": "pl",
              "text": "Cena rekomendowana jest obliczana w ERP z kosztów zakupu, marży i warunków rynku."
            },
            {
              "language": "ro",
              "text": "Prețul recomandat este calculat în ERP din costuri, marjă și condițiile pieței."
            },
            {
              "language": "ru",
              "text": "Рекомендованная цена рассчитывается в ERP из затрат, маржи и рыночных условий."
            },
            {
              "language": "sq",
              "text": "Çmimi i rekomanduar llogaritet në ERP nga kostot, marzhi dhe kushtet e tregut."
            },
            {
              "language": "tr",
              "text": "Önerilen fiyat ERP içinde maliyet, marj ve piyasa koşullarından hesaplanır."
            }
          ]
        },
        {
          "baseText": "Im Kundengespräch wich der Vertrieb bewusst vom empfohlenen Preis ab, weil der Auftrag strategisch wichtig war.",
          "translations": [
            {
              "language": "ar",
              "text": "في حديث العميل ابتعدت المبيعات عمدًا عن السعر الموصى به لأن الطلب كان مهمًا استراتيجيًا."
            },
            {
              "language": "ckb",
              "text": "لە گفتوگۆی کڕیاردا فرۆشتن بە مەبەست لە نرخی پێشنیارکراو لایدا."
            },
            {
              "language": "en",
              "text": "In the customer conversation, sales deliberately deviated from the recommended price because the order was strategically important."
            },
            {
              "language": "fa",
              "text": "در گفت‌وگو با مشتری، فروش آگاهانه از قیمت پیشنهادی فاصله گرفت چون سفارش راهبردی بود."
            },
            {
              "language": "kmr",
              "text": "Di axaftina bi xerîdar re firotan ji bihayê pêşniyarkirî dûr ket."
            },
            {
              "language": "pl",
              "text": "W rozmowie z klientem sprzedaż świadomie odstąpiła od ceny rekomendowanej."
            },
            {
              "language": "ro",
              "text": "În discuția cu clientul, vânzările s-au abătut intenționat de la prețul recomandat."
            },
            {
              "language": "ru",
              "text": "В разговоре с клиентом отдел продаж сознательно отклонился от рекомендованной цены."
            },
            {
              "language": "sq",
              "text": "Në bisedën me klientin, shitjet devijuan qëllimisht nga çmimi i rekomanduar."
            },
            {
              "language": "tr",
              "text": "Müşteri görüşmesinde satış ekibi önerilen fiyattan bilinçli şekilde saptı."
            }
          ]
        }
      ]
    }
