  "entries": [
    {
      "word": "die Stelle",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Stellen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Stel-le",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Stelle suchen",
          "meaning": "to look for a job"
        },
        {
          "text": "eine freie Stelle",
          "meaning": "a vacant position"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "stellen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وظيفة؛ منصب؛ مكان"
        },
        {
          "language": "ckb",
          "text": "کار؛ پۆست؛ شوێن"
        },
        {
          "language": "en",
          "text": "job; position; place"
        },
        {
          "language": "fa",
          "text": "موقعیت شغلی؛ جایگاه؛ محل"
        },
        {
          "language": "kmr",
          "text": "kar; post; cih"
        },
        {
          "language": "pl",
          "text": "stanowisko; praca; miejsce"
        },
        {
          "language": "ro",
          "text": "post; loc; poziție"
        },
        {
          "language": "ru",
          "text": "место; должность; позиция"
        },
        {
          "language": "sq",
          "text": "vend pune; pozicion; vend"
        },
        {
          "language": "tr",
          "text": "iş pozisyonu; yer; mevki"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe eine interessante Stelle in einer Softwarefirma gefunden.",
          "translations": [
            {
              "language": "ar",
              "text": "وجدت وظيفة مثيرة للاهتمام في شركة برمجيات."
            },
            {
              "language": "ckb",
              "text": "کارێکی سەرنجڕاکێشم لە کۆمپانیایەکی نەرمەکاڵادا دۆزییەوە."
            },
            {
              "language": "en",
              "text": "I found an interesting job at a software company."
            },
            {
              "language": "fa",
              "text": "یک موقعیت شغلی جالب در یک شرکت نرم‌افزاری پیدا کردم."
            },
            {
              "language": "kmr",
              "text": "Min karekî balkêş li şirketeke nermalavê dît."
            },
            {
              "language": "pl",
              "text": "Znalazłem interesującą posadę w firmie programistycznej."
            },
            {
              "language": "ro",
              "text": "Am găsit un post interesant într-o firmă de software."
            },
            {
              "language": "ru",
              "text": "Я нашел интересную должность в софтверной компании."
            },
            {
              "language": "sq",
              "text": "Gjeta një vend pune interesant në një kompani softuerësh."
            },
            {
              "language": "tr",
              "text": "Bir yazılım şirketinde ilginç bir iş pozisyonu buldum."
            }
          ]
        },
        {
          "baseText": "An dieser Stelle im Formular müssen Sie Ihre Adresse eintragen.",
          "translations": [
            {
              "language": "ar",
              "text": "في هذا الموضع من الاستمارة يجب أن تكتب عنوانك."
            },
            {
              "language": "ckb",
              "text": "لەم شوێنەی فۆرمەکەدا دەبێت ناونیشانەکەت بنووسیت."
            },
            {
              "language": "en",
              "text": "At this place in the form, you have to enter your address."
            },
            {
              "language": "fa",
              "text": "در این قسمت فرم باید آدرس خود را وارد کنید."
            },
            {
              "language": "kmr",
              "text": "Li vê cihê formê divê hûn navnîşana xwe binivîsin."
            },
            {
              "language": "pl",
              "text": "W tym miejscu formularza trzeba wpisać swój adres."
            },
            {
              "language": "ro",
              "text": "În acest loc din formular trebuie să introduceți adresa."
            },
            {
              "language": "ru",
              "text": "В этом месте формы нужно указать свой адрес."
            },
            {
              "language": "sq",
              "text": "Në këtë vend të formularit duhet të shkruani adresën tuaj."
            },
            {
              "language": "tr",
              "text": "Formun bu yerine adresinizi yazmanız gerekiyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Stellenausschreibung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Stellenausschreibungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Stel-len-aus-schrei-bung",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "written",
        "workplace"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Stellenausschreibung veröffentlichen",
          "meaning": "to publish a job posting"
        },
        {
          "text": "auf eine Stellenausschreibung reagieren",
          "meaning": "to respond to a job posting"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "ausschreiben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إعلان وظيفة؛ إعلان شاغر"
        },
        {
          "language": "ckb",
          "text": "ڕاگەیاندنی کار؛ ئاگاداری پۆستی بەتاڵ"
        },
        {
          "language": "en",
          "text": "job posting; job advertisement"
        },
        {
          "language": "fa",
          "text": "آگهی استخدام؛ اعلام موقعیت شغلی"
        },
        {
          "language": "kmr",
          "text": "ragihandina kar; îlana karê vala"
        },
        {
          "language": "pl",
          "text": "ogłoszenie o pracę"
        },
        {
          "language": "ro",
          "text": "anunț de angajare; post vacant publicat"
        },
        {
          "language": "ru",
          "text": "объявление о вакансии"
        },
        {
          "language": "sq",
          "text": "shpallje pune"
        },
        {
          "language": "tr",
          "text": "iş ilanı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Stellenausschreibung beschreibt genau, welche Erfahrungen erwartet werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يوضح إعلان الوظيفة بدقة ما الخبرات المتوقعة."
            },
            {
              "language": "ckb",
              "text": "ڕاگەیاندنی کارەکە بە وردی باس دەکات چ ئەزموونێک چاوەڕوان دەکرێت."
            },
            {
              "language": "en",
              "text": "The job posting describes exactly what experience is expected."
            },
            {
              "language": "fa",
              "text": "آگهی استخدام دقیقاً توضیح می‌دهد چه تجربه‌هایی انتظار می‌رود."
            },
            {
              "language": "kmr",
              "text": "Îlana karê bi rastî diyar dike kîjan ezmûn tê hêvîkirin."
            },
            {
              "language": "pl",
              "text": "Ogłoszenie o pracę dokładnie opisuje, jakiego doświadczenia się oczekuje."
            },
            {
              "language": "ro",
              "text": "Anunțul de angajare descrie exact ce experiență este așteptată."
            },
            {
              "language": "ru",
              "text": "Объявление о вакансии точно описывает, какой опыт ожидается."
            },
            {
              "language": "sq",
              "text": "Shpallja e punës përshkruan saktë çfarë përvoje pritet."
            },
            {
              "language": "tr",
              "text": "İş ilanı hangi deneyimlerin beklendiğini tam olarak açıklıyor."
            }
          ]
        },
        {
          "baseText": "Ich habe die Stellenausschreibung an einen Freund weitergeleitet.",
          "translations": [
            {
              "language": "ar",
              "text": "أرسلت إعلان الوظيفة إلى صديق."
            },
            {
              "language": "ckb",
              "text": "ڕاگەیاندنی کارەکەم بۆ هاوڕێیەک نارد."
            },
            {
              "language": "en",
              "text": "I forwarded the job posting to a friend."
            },
            {
              "language": "fa",
              "text": "آگهی استخدام را برای یک دوست فرستادم."
            },
            {
              "language": "kmr",
              "text": "Min îlana karê ji hevalekî re şand."
            },
            {
              "language": "pl",
              "text": "Przekazałem ogłoszenie o pracę znajomemu."
            },
            {
              "language": "ro",
              "text": "Am trimis anunțul de angajare unui prieten."
            },
            {
              "language": "ru",
              "text": "Я переслал объявление о вакансии другу."
            },
            {
              "language": "sq",
              "text": "Ia përcolla shpalljen e punës një shoku."
            },
            {
              "language": "tr",
              "text": "İş ilanını bir arkadaşıma ilettim."
            }
          ]
        }
      ]
    },
