      ],
      "examples": [
        {
          "baseText": "Auf der Rechnung steht, wie viel Steuer im Preis enthalten ist.",
          "translations": [
            {
              "language": "ar",
              "text": "توضح الفاتورة مقدار الضريبة المشمولة في السعر."
            },
            {
              "language": "ckb",
              "text": "لە پسووڵەکەدا نووسراوە چەند باج لە نرخەکەدا هەیە."
            },
            {
              "language": "en",
              "text": "The invoice shows how much tax is included in the price."
            },
            {
              "language": "fa",
              "text": "در فاکتور نوشته شده چه مقدار مالیات در قیمت لحاظ شده است."
            },
            {
              "language": "kmr",
              "text": "Li ser fatûreyê nivîsandî ye ka çiqas bac di bihayê de heye."
            },
            {
              "language": "pl",
              "text": "Na fakturze jest napisane, ile podatku zawiera cena."
            },
            {
              "language": "ro",
              "text": "Pe factură scrie cât impozit este inclus în preț."
            },
            {
              "language": "ru",
              "text": "В счете указано, сколько налога включено в цену."
            },
