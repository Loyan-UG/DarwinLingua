      ],
      "collocations": [
        {
          "text": "ein wichtiger Grundsatz",
          "meaning": "an important principle"
        },
        {
          "text": "gegen einen Grundsatz verstoßen",
          "meaning": "to violate a principle"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "grundsätzlich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مبدأ؛ قاعدة أساسية"
        },
        {
          "language": "ckb",
          "text": "بنەما؛ یاسای بنەڕەتی"
        },
        {
          "language": "en",
          "text": "principle; fundamental rule"
        },
        {
          "language": "fa",
          "text": "اصل؛ قاعده اساسی"
        },
        {
          "language": "kmr",
          "text": "bingeh; rêgeza bingehîn"
        },
        {
          "language": "pl",
          "text": "zasada; reguła podstawowa"
        },
        {
          "language": "ro",
          "text": "principiu; regulă fundamentală"
        },
        {
          "language": "ru",
          "text": "принцип; основное правило"
        },
        {
          "language": "sq",
          "text": "parim; rregull themelor"
        },
        {
          "language": "tr",
          "text": "ilke; temel kural"
        }
      ],
      "examples": [
        {
          "baseText": "Der Grundsatz der Transparenz muss auch bei kurzfristigen Entscheidungen gelten.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن يسري مبدأ الشفافية أيضًا على القرارات قصيرة الأجل."
            },
            {
              "language": "ckb",
              "text": "بنەمای ڕوونی دەبێت لە بڕیارە کورتخایەنەکانیشدا کاریگەر بێت."
            },
            {
              "language": "en",
              "text": "The principle of transparency must also apply to short-term decisions."
            },
            {
              "language": "fa",
              "text": "اصل شفافیت باید در تصمیم‌های کوتاه‌مدت هم رعایت شود."
            },
            {
              "language": "kmr",
              "text": "Bingehê zelaliyê divê di biryarên demkurt de jî derbasdar be."
            },
            {
              "language": "pl",
              "text": "Zasada przejrzystości musi obowiązywać także przy decyzjach krótkoterminowych."
            },
            {
              "language": "ro",
              "text": "Principiul transparenței trebuie să se aplice și deciziilor pe termen scurt."
            },
            {
              "language": "ru",
              "text": "Принцип прозрачности должен действовать и при краткосрочных решениях."
            },
            {
              "language": "sq",
              "text": "Parimi i transparencës duhet të vlejë edhe për vendimet afatshkurtra."
            },
            {
              "language": "tr",
              "text": "Şeffaflık ilkesi kısa vadeli kararlarda da geçerli olmalıdır."
            }
          ]
        },
        {
          "baseText": "Im Grundsatz sind alle Anträge gleich zu behandeln, Ausnahmen müssen begründet werden.",
          "translations": [
            {
              "language": "ar",
              "text": "من حيث المبدأ يجب معاملة جميع الطلبات بالتساوي، ويجب تبرير الاستثناءات."
            },
            {
              "language": "ckb",
              "text": "لە بنەڕەتدا دەبێت هەموو داواکارییەکان وەک یەک مامەڵەیان لەگەڵ بکرێت، دەرچوونەکان دەبێت پاساو بدرێن."
            },
            {
              "language": "en",
              "text": "In principle, all applications must be treated equally, and exceptions must be justified."
            },
            {
              "language": "fa",
              "text": "در اصل باید با همه درخواست‌ها یکسان برخورد شود و استثناها باید توجیه شوند."
            },
            {
              "language": "kmr",
              "text": "Di bingehê de divê hemû daxwaz wek hev bên meşandin û îstîsna bên sedemkirin."
            },
            {
              "language": "pl",
              "text": "Co do zasady wszystkie wnioski należy traktować równo, a wyjątki trzeba uzasadnić."
            },
            {
              "language": "ro",
              "text": "În principiu, toate cererile trebuie tratate egal, iar excepțiile trebuie motivate."
            },
            {
              "language": "ru",
              "text": "В принципе все заявления должны рассматриваться одинаково, а исключения нужно обосновывать."
            },
            {
              "language": "sq",
              "text": "Në parim, të gjitha kërkesat duhet të trajtohen njësoj, ndërsa përjashtimet duhet të arsyetohen."
            },
            {
              "language": "tr",
              "text": "İlke olarak tüm başvurular eşit ele alınmalı, istisnalar gerekçelendirilmelidir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Güterabwägung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Güterabwägungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Gü-ter-ab-wä-gung",
      "topics": [
        "law-and-compliance",
        "quality-and-risk",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Güterabwägungen"
      ],
      "collocations": [
        {
          "text": "eine Güterabwägung vornehmen",
          "meaning": "to balance competing interests or values"
        },
        {
          "text": "sorgfältige Güterabwägung",
          "meaning": "careful balancing of interests"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "abwägen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "das Gut",
          "relationLabel": "noun",
          "note": "value or legally protected interest"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موازنة المصالح أو القيم"
        },
        {
          "language": "ckb",
          "text": "هاوسەنگکردنی بەرژەوەندی یان بەهاکان"
        },
        {
          "language": "en",
          "text": "balancing of interests or values"
        },
        {
          "language": "fa",
          "text": "سنجش و موازنه منافع یا ارزش‌ها"
        },
        {
          "language": "kmr",
          "text": "hevsengkirina berjewendî an nirxan"
        },
        {
          "language": "pl",
          "text": "ważenie dóbr; wyważanie interesów"
        },
        {
          "language": "ro",
          "text": "punere în balanță a intereselor sau valorilor"
        },
        {
          "language": "ru",
          "text": "взвешивание благ или интересов"
        },
        {
          "language": "sq",
          "text": "balancim i interesave ose vlerave"
        },
        {
          "language": "tr",
          "text": "menfaatlerin veya değerlerin dengelenmesi"
        }
      ],
      "examples": [
        {
          "baseText": "Bei der Veröffentlichung sensibler Daten ist eine Güterabwägung zwingend erforderlich.",
          "translations": [
            {
              "language": "ar",
              "text": "عند نشر بيانات حساسة يكون إجراء موازنة للمصالح ضروريًا حتمًا."
            },
            {
              "language": "ckb",
              "text": "لە بڵاوکردنەوەی داتای هەستیاردا هاوسەنگکردنی بەرژەوەندییەکان بە ناچاری پێویستە."
            },
            {
              "language": "en",
              "text": "When sensitive data is published, a balancing of interests is absolutely required."
            },
            {
              "language": "fa",
              "text": "در انتشار داده‌های حساس، موازنه منافع الزاماً لازم است."
            },
            {
              "language": "kmr",
              "text": "Dema daneyên hestiyar têne weşandin, hevsengkirina berjewendiyan bi teqezî pêwîst e."
            },
            {
              "language": "pl",
              "text": "Przy publikacji danych wrażliwych konieczne jest wyważenie dóbr."
            },
            {
              "language": "ro",
              "text": "La publicarea datelor sensibile este obligatorie o punere în balanță a intereselor."
            },
            {
              "language": "ru",
              "text": "При публикации чувствительных данных обязательно требуется взвешивание интересов."
            },
            {
              "language": "sq",
              "text": "Në publikimin e të dhënave të ndjeshme kërkohet domosdoshmërisht balancim i interesave."
            },
            {
              "language": "tr",
              "text": "Hassas verilerin yayımlanmasında menfaatlerin dengelenmesi zorunludur."
            }
          ]
        },
        {
          "baseText": "Die Entscheidung zeigt, wie schwierig eine Güterabwägung zwischen Sicherheit und Freiheit sein kann.",
          "translations": [
            {
              "language": "ar",
              "text": "يُظهر القرار مدى صعوبة موازنة الأمن والحرية."
            },
            {
              "language": "ckb",
              "text": "بڕیارەکە پیشان دەدات هاوسەنگکردنی نێوان ئاسایش و ئازادی چەندە دژوار دەبێت."
            },
            {
              "language": "en",
              "text": "The decision shows how difficult it can be to balance security and freedom."
            },
            {
              "language": "fa",
              "text": "این تصمیم نشان می‌دهد موازنه میان امنیت و آزادی چقدر می‌تواند دشوار باشد."
            },
            {
              "language": "kmr",
              "text": "Biryara nîşan dide ku hevsengkirina di navbera ewlehî û azadiyê de çiqas dijwar dikare be."
            },
            {
              "language": "pl",
              "text": "Decyzja pokazuje, jak trudne może być wyważenie bezpieczeństwa i wolności."
            },
            {
              "language": "ro",
              "text": "Decizia arată cât de dificilă poate fi punerea în balanță a securității și libertății."
            },
            {
              "language": "ru",
              "text": "Решение показывает, насколько сложным может быть взвешивание безопасности и свободы."
            },
            {
              "language": "sq",
              "text": "Vendimi tregon sa i vështirë mund të jetë balancimi mes sigurisë dhe lirisë."
            },
            {
              "language": "tr",
              "text": "Karar, güvenlik ile özgürlük arasında denge kurmanın ne kadar zor olabileceğini gösteriyor."
            }
          ]
        }
      ]
    },
    {
