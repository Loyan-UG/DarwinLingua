      "meanings": [
        {
          "language": "ar",
          "text": "تقرير خبير؛ رأي فني"
        },
        {
          "language": "ckb",
          "text": "ڕاپۆرتی پسپۆڕ؛ هەڵسەنگاندنی شارەزا"
        },
        {
          "language": "en",
          "text": "expert report; expert opinion"
        },
        {
          "language": "fa",
          "text": "گزارش کارشناسی؛ نظر تخصصی"
        },
        {
          "language": "kmr",
          "text": "raporta pispor; nêrîna pisporî"
        },
        {
          "language": "pl",
          "text": "opinia biegłego; ekspertyza"
        },
        {
          "language": "ro",
          "text": "raport de expertiză; opinie de expert"
        },
        {
          "language": "ru",
          "text": "экспертное заключение; экспертиза"
        },
        {
          "language": "sq",
          "text": "raport ekspertize; opinion eksperti"
        },
        {
          "language": "tr",
          "text": "bilirkişi raporu; uzman görüşü"
        }
      ],
      "examples": [
        {
          "baseText": "Vor dem Kauf der Immobilie ließ die Firma ein technisches Gutachten erstellen.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل شراء العقار كلفت الشركة بإعداد تقرير فني متخصص."
            },
            {
              "language": "ckb",
              "text": "پێش کڕینی خانووبەرەکە کۆمپانیاکە داوای ئامادەکردنی ڕاپۆرتی تەکنیکیی پسپۆڕی کرد."
            },
            {
              "language": "en",
              "text": "Before buying the property, the company had a technical expert report prepared."
            },
            {
              "language": "fa",
              "text": "پیش از خرید ملک، شرکت یک گزارش کارشناسی فنی تهیه کرد."
            },
            {
              "language": "kmr",
              "text": "Berî kirîna xanî, şîrketê da ku raporta pisporî ya teknîkî were amadekirin."
            },
            {
              "language": "pl",
              "text": "Przed zakupem nieruchomości firma zleciła sporządzenie technicznej ekspertyzy."
            },
            {
              "language": "ro",
              "text": "Înainte de cumpărarea imobilului, firma a comandat un raport tehnic de expertiză."
            },
            {
              "language": "ru",
