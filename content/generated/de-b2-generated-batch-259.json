  "entries": [
    {
      "word": "vorfahren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vorfahren",
      "pronunciationIpa": null,
      "syllableBreak": "vor-fah-ren",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "customer-service"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "transport",
        "logistics",
        "customer-service"
      ],
      "grammarNotes": [
        "separable irregular verb: fährt vor, fuhr vor, ist vorgefahren; means to drive up or demonstrate driving"
      ],
      "collocations": [
        {
          "text": "am Eingang vorfahren",
          "meaning": "to drive up to the entrance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fahren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتقدم بالسيارة؛ يصل بالسيارة إلى الأمام"
        },
        {
          "language": "ckb",
          "text": "بە ئۆتۆمبێل دەگاتە پێشەوە"
        },
        {
          "language": "en",
          "text": "to drive up; to pull up by vehicle"
        },
        {
          "language": "fa",
          "text": "با خودرو جلو آمدن؛ خودرو را جلوی جایی آوردن"
        },
        {
          "language": "kmr",
          "text": "bi otomobîl hatin pêş"
        },
        {
          "language": "pl",
          "text": "podjechać"
        },
        {
          "language": "ro",
          "text": "a trage cu mașina în față; a opri în față"
        },
        {
          "language": "ru",
          "text": "подъехать"
        },
        {
          "language": "sq",
          "text": "të afrohesh me makinë"
        },
        {
          "language": "tr",
          "text": "araçla yanaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lieferwagen fährt direkt am Wareneingang vor.",
          "translations": [
            {
              "language": "ar",
              "text": "تتقدم شاحنة التوصيل مباشرة إلى مدخل البضائع."
            },
            {
              "language": "ckb",
              "text": "ئۆتۆمبێلی گەیاندن ڕاستەوخۆ لە بەرامبەر دەروازەی کاڵادا دەوەستێت."
            },
            {
              "language": "en",
              "text": "The delivery van pulls up directly at goods receiving."
            },
            {
              "language": "fa",
              "text": "ون تحویل مستقیم جلوی بخش دریافت کالا می‌ایستد."
            },
            {
              "language": "kmr",
              "text": "Kamyoneta radestkirinê rasterast li ber deriyê wergirtina malan radiweste."
            },
            {
              "language": "pl",
              "text": "Samochód dostawczy podjeżdża bezpośrednio pod przyjęcie towaru."
            },
            {
              "language": "ro",
              "text": "Duba de livrare oprește direct la recepția mărfurilor."
            },
            {
              "language": "ru",
              "text": "Фургон доставки подъезжает прямо к зоне приемки товара."
            },
            {
              "language": "sq",
              "text": "Furgoni i dorëzimit afrohet direkt te hyrja e mallrave."
            },
            {
              "language": "tr",
              "text": "Teslimat aracı doğrudan mal kabul noktasına yanaşır."
            }
          ]
        },
        {
          "baseText": "Bitte fahren Sie mit dem Kunden nicht vor dem Haupteingang vor, dort ist Halteverbot.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى ألا تتوقف بالسيارة مع العميل أمام المدخل الرئيسي، فهناك منع للتوقف."
            },
            {
              "language": "ckb",
              "text": "تکایە لەگەڵ کڕیارەکە لە بەردەم دەروازەی سەرەکی مەوەستن، لەوێ وەستان قەدەغەیە."
            },
            {
              "language": "en",
              "text": "Please do not pull up with the customer in front of the main entrance; stopping is prohibited there."
            },
            {
              "language": "fa",
              "text": "لطفاً با مشتری جلوی ورودی اصلی توقف نکنید؛ آنجا توقف ممنوع است."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe bi xerîdar re li ber deriyê sereke ranewestin; li wir rawestan qedexe ye."
            },
            {
              "language": "pl",
              "text": "Proszę nie podjeżdżać z klientem pod główne wejście, tam obowiązuje zakaz zatrzymywania."
            },
            {
              "language": "ro",
              "text": "Vă rog să nu opriți cu clientul în fața intrării principale; acolo oprirea este interzisă."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не подъезжайте с клиентом к главному входу, там остановка запрещена."
            },
            {
              "language": "sq",
              "text": "Ju lutem mos u afroni me klientin para hyrjes kryesore; aty ndalimi është i ndaluar."
            },
            {
              "language": "tr",
              "text": "Lütfen müşteriyle ana girişin önüne yanaşmayın; orada durmak yasak."
            }
          ]
        }
      ]
    },
