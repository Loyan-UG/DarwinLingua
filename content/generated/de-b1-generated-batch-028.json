      "meanings": [
        {
          "language": "ar",
          "text": "إشعار؛ إخطار"
        },
        {
          "language": "ckb",
          "text": "ئاگادارکردنەوە؛ پەیامی ئاگاداری"
        },
        {
          "language": "en",
          "text": "notification; notice"
        },
        {
          "language": "fa",
          "text": "اعلان؛ اطلاعیه"
        },
        {
          "language": "kmr",
          "text": "agahdarî; peyama agahdarî"
        },
        {
          "language": "pl",
          "text": "powiadomienie"
        },
        {
          "language": "ro",
          "text": "notificare; înștiințare"
        },
        {
          "language": "ru",
          "text": "уведомление"
        },
        {
          "language": "sq",
          "text": "njoftim"
        },
        {
          "language": "tr",
          "text": "bildirim; tebligat"
        }
      ],
      "examples": [
        {
          "baseText": "Sie erhalten eine Benachrichtigung, wenn Ihr Antrag bearbeitet wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "ستتلقون إشعارًا عندما تتم معالجة طلبكم."
            },
            {
              "language": "ckb",
              "text": "ئاگادارکردنەوەیەک وەردەگرن کاتێک داواکارییەکەتان چارەسەر کرا."
            },
            {
              "language": "en",
              "text": "You will receive a notification when your application has been processed."
            },
            {
              "language": "fa",
              "text": "وقتی درخواست شما بررسی شد، یک اعلان دریافت می‌کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn ê agahdariyekê wergirin dema daxwaznameya we hate pêvajoyê kirin."
            },
            {
              "language": "pl",
              "text": "Otrzymają Państwo powiadomienie, gdy wniosek zostanie przetworzony."
            },
            {
              "language": "ro",
              "text": "Veți primi o notificare când cererea dumneavoastră a fost procesată."
            },
            {
              "language": "ru",
              "text": "Вы получите уведомление, когда ваше заявление будет обработано."
            },
            {
              "language": "sq",
              "text": "Do të merrni një njoftim kur kërkesa juaj të jetë përpunuar."
            },
            {
              "language": "tr",
              "text": "Başvurunuz işlendiğinde bir bildirim alacaksınız."
            }
          ]
        },
        {
          "baseText": "Die Benachrichtigung auf dem Handy kam erst nach dem Meeting.",
          "translations": [
            {
              "language": "ar",
              "text": "وصل الإشعار على الهاتف بعد الاجتماع فقط."
            },
            {
              "language": "ckb",
              "text": "ئاگادارکردنەوەکە لە مۆبایلەکە تەنها دوای کۆبوونەوەکە هات."
            },
            {
              "language": "en",
              "text": "The notification on the phone arrived only after the meeting."
            },
            {
              "language": "fa",
              "text": "اعلان روی گوشی فقط بعد از جلسه رسید."
            },
            {
              "language": "kmr",
              "text": "Agahdariya li telefonê tenê piştî civînê hat."
            },
            {
              "language": "pl",
              "text": "Powiadomienie na telefonie przyszło dopiero po spotkaniu."
            },
            {
              "language": "ro",
              "text": "Notificarea de pe telefon a venit abia după ședință."
            },
            {
              "language": "ru",
              "text": "Уведомление на телефоне пришло только после встречи."
