      ],
      "contextLabels": [
        "customer-service",
        "support",
        "it"
      ],
      "grammarNotes": [
        "regular verb",
        "means to notify or inform someone"
      ],
      "collocations": [
        {
          "text": "den Kunden benachrichtigen",
          "meaning": "to notify the customer"
        },
        {
          "text": "per E-Mail benachrichtigen",
          "meaning": "to notify by email"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Benachrichtigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يُخطر؛ يُبلغ"
        },
        {
          "language": "ckb",
          "text": "ئاگادارکردنەوە؛ پێڕاگەیاندن"
        },
        {
          "language": "en",
          "text": "to notify; to inform"
        },
        {
          "language": "fa",
          "text": "مطلع کردن؛ اطلاع دادن"
        },
        {
          "language": "kmr",
          "text": "agahdar kirin"
        },
        {
          "language": "pl",
          "text": "powiadomić; poinformować"
        },
        {
          "language": "ro",
          "text": "a notifica; a informa"
        },
        {
          "language": "ru",
          "text": "уведомить; сообщить"
        },
        {
          "language": "sq",
          "text": "të njoftosh; të informosh"
        },
        {
          "language": "tr",
          "text": "bildirmek; haberdar etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte benachrichtigen Sie den Kunden, sobald die Lieferung versendet wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إبلاغ العميل بمجرد إرسال الشحنة."
            },
            {
              "language": "ckb",
              "text": "تکایە هەر کات گەیاندنەکە نێردرا، کڕیارەکە ئاگادار بکەنەوە."
            },
            {
              "language": "en",
              "text": "Please notify the customer as soon as the delivery has been shipped."
            },
            {
              "language": "fa",
              "text": "لطفاً به محض ارسال سفارش، مشتری را مطلع کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe gava radestkirin hate şandin, xerîdar agahdar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę powiadomić klienta, gdy tylko dostawa zostanie wysłana."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să anunțați clientul imediat ce livrarea a fost expediată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, уведомите клиента, как только доставка будет отправлена."
            },
            {
              "language": "sq",
              "text": "Ju lutem njoftoni klientin sapo dërgesa të jetë nisur."
            },
            {
              "language": "tr",
              "text": "Teslimat gönderilir gönderilmez lütfen müşteriyi bilgilendirin."
            }
          ]
        },
        {
          "baseText": "Die App benachrichtigt mich, wenn der Arzttermin verschoben wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يُعلمني التطبيق إذا تم تأجيل موعد الطبيب."
            },
            {
              "language": "ckb",
              "text": "ئەپەکە ئاگادارم دەکاتەوە ئەگەر کاتی پزیشکەکە بگوازرێتەوە."
            },
            {
              "language": "en",
              "text": "The app notifies me if the doctor’s appointment is moved."
            },
            {
              "language": "fa",
              "text": "اگر وقت دکتر جابه‌جا شود، اپلیکیشن به من اطلاع می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Heke randevûya bijîşkî were guherandin, app min agahdar dike."
            },
            {
              "language": "pl",
              "text": "Aplikacja powiadamia mnie, jeśli termin u lekarza zostanie przesunięty."
            },
            {
              "language": "ro",
              "text": "Aplicația mă notifică dacă programarea la medic este mutată."
            },
            {
              "language": "ru",
              "text": "Приложение уведомляет меня, если приём у врача переносится."
            },
            {
              "language": "sq",
              "text": "Aplikacioni më njofton nëse takimi te mjeku shtyhet."
            },
            {
              "language": "tr",
              "text": "Doktor randevusu değiştirilirse uygulama beni bilgilendirir."
            }
          ]
        }
      ]
    },
