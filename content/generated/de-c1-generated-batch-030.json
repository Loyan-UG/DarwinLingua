      "word": "die Differenzierung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Differenzierungen",
      "infinitive": null,
      "syllableBreak": "Dif-fe-ren-zie-rung",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "formal",
        "analysis",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine klare Differenzierung vornehmen",
          "meaning": "to make a clear differentiation"
        },
        {
          "text": "fehlende Differenzierung",
          "meaning": "lack of differentiation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "differenzieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "differenziert",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تمييز؛ تفريق دقيق"
        },
        {
          "language": "ckb",
          "text": "جیاکردنەوە؛ وردکردنەوەی جیاوازی"
        },
        {
          "language": "en",
          "text": "differentiation; precise distinction"
        },
        {
          "language": "fa",
          "text": "تفکیک؛ تمایزگذاری دقیق"
        },
        {
          "language": "kmr",
          "text": "cudakirin; veqetandina hûrgulî"
        },
        {
          "language": "pl",
          "text": "różnicowanie; rozróżnienie"
        },
        {
          "language": "ro",
          "text": "diferențiere; distincție precisă"
        },
        {
          "language": "ru",
          "text": "дифференциация; различение"
        },
        {
          "language": "sq",
          "text": "diferencim; dallim i saktë"
        },
        {
          "language": "tr",
          "text": "farklılaştırma; ayrım yapma"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Auswertung ist eine Differenzierung nach Kundensegmenten und Vertragslaufzeiten erforderlich.",
          "translations": [
            {
              "language": "ar",
              "text": "لأجل التحليل يلزم التمييز بين شرائح العملاء ومدد العقود."
            },
            {
              "language": "ckb",
              "text": "بۆ شیکردنەوەکە پێویستە جیاکردنەوە بەپێی بەشەکانی کڕیار و ماوەی گرێبەست بکرێت."
            },
            {
              "language": "en",
              "text": "For the analysis, differentiation by customer segments and contract terms is required."
            },
            {
              "language": "fa",
              "text": "برای تحلیل، تفکیک بر اساس بخش‌های مشتری و مدت قرارداد لازم است."
            },
            {
              "language": "kmr",
              "text": "Ji bo analîzê, cudakirin li gorî segmentên xerîdar û demdirêjiya peymanan pêwîst e."
            },
            {
              "language": "pl",
              "text": "Do analizy konieczne jest rozróżnienie według segmentów klientów i okresów umów."
            },
            {
              "language": "ro",
              "text": "Pentru analiză este necesară diferențierea după segmente de clienți și durate contractuale."
            },
            {
              "language": "ru",
              "text": "Для анализа необходима дифференциация по сегментам клиентов и срокам договоров."
            },
            {
              "language": "sq",
              "text": "Për analizën nevojitet diferencim sipas segmenteve të klientëve dhe afateve të kontratave."
            },
            {
              "language": "tr",
              "text": "Analiz için müşteri segmentlerine ve sözleşme sürelerine göre ayrım yapılması gerekir."
            }
          ]
        },
        {
          "baseText": "Die Lehrerin forderte mehr Differenzierung, damit starke und schwächere Lernende angemessen gefördert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "طالبت المعلمة بمزيد من التفريق كي يُدعم الطلاب الأقوياء والأضعف بشكل مناسب."
            },
            {
              "language": "ckb",
              "text": "مامۆستاکە داوای جیاکردنەوەی زیاتر کرد بۆ ئەوەی فێرخوازە بەهێز و لاوازترەکان بە گونجاوی پشتگیری بکرێن."
            },
            {
              "language": "en",
              "text": "The teacher called for more differentiation so stronger and weaker learners are supported appropriately."
            },
            {
              "language": "fa",
              "text": "معلم خواستار تفکیک بیشتر شد تا زبان‌آموزان قوی‌تر و ضعیف‌تر مناسب حمایت شوند."
            },
            {
              "language": "kmr",
              "text": "Mamoste daxwaza cudakirina zêdetir kir da ku fêrkarên xurt û lawaztir bi guncawî werin piştgirîkirin."
            },
            {
              "language": "pl",
              "text": "Nauczycielka zażądała większego różnicowania, aby mocniejsi i słabsi uczniowie byli odpowiednio wspierani."
            },
            {
              "language": "ro",
              "text": "Profesoara a cerut mai multă diferențiere, astfel încât elevii mai puternici și cei mai slabi să fie sprijiniți adecvat."
            },
            {
              "language": "ru",
              "text": "Учительница потребовала большей дифференциации, чтобы сильные и более слабые ученики получали соответствующую поддержку."
            },
            {
              "language": "sq",
              "text": "Mësuesja kërkoi më shumë diferencim që nxënësit më të fortë dhe më të dobët të mbështeten siç duhet."
            },
            {
              "language": "tr",
              "text": "Öğretmen güçlü ve daha zayıf öğrencilerin uygun destek alması için daha fazla farklılaştırma istedi."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
