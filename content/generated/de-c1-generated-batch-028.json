      "word": "dessen ungeachtet",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "syllableBreak": "des-sen un-ge-ach-tet",
      "topics": [
        "business-communication",
        "documents-and-administration",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "fixed concessive connector meaning nevertheless or notwithstanding that"
      ],
      "collocations": [
        {
          "text": "dessen ungeachtet bleibt festzuhalten",
          "meaning": "nevertheless it should be noted"
        },
        {
          "text": "dessen ungeachtet fortfahren",
          "meaning": "to continue despite that"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "ungeachtet",
          "relationLabel": "preposition",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ومع ذلك؛ رغم ذلك"
        },
        {
          "language": "ckb",
          "text": "سەرەڕای ئەوە؛ بەو حالەش"
        },
        {
          "language": "en",
          "text": "nevertheless; notwithstanding that"
        },
        {
          "language": "fa",
          "text": "با وجود آن؛ با این حال"
        },
        {
          "language": "kmr",
          "text": "tevî wê; herwiha"
        },
        {
          "language": "pl",
          "text": "mimo to; niezależnie od tego"
        },
        {
          "language": "ro",
          "text": "cu toate acestea; în pofida acestui fapt"
        },
        {
          "language": "ru",
          "text": "тем не менее; несмотря на это"
        },
        {
          "language": "sq",
          "text": "megjithatë; pavarësisht kësaj"
        },
        {
          "language": "tr",
          "text": "buna rağmen; yine de"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kosten sind gestiegen; dessen ungeachtet hält die Geschäftsführung am Zeitplan fest.",
          "translations": [
            {
              "language": "ar",
              "text": "ارتفعت التكاليف؛ ومع ذلك تتمسك الإدارة بالجدول الزمني."
            },
            {
              "language": "ckb",
              "text": "تێچووەکان زیاد بوون؛ سەرەڕای ئەوە بەڕێوەبردنەکە پەیوەستە بە خشتەی کات."
            },
            {
              "language": "en",
              "text": "Costs have increased; nevertheless, management is sticking to the schedule."
            },
            {
              "language": "fa",
              "text": "هزینه‌ها افزایش یافته‌اند؛ با وجود آن مدیریت به زمان‌بندی پایبند است."
            },
            {
              "language": "kmr",
              "text": "Lêçûn zêde bûne; tevî wê rêveberî li demjimêrê dimîne."
            },
            {
              "language": "pl",
              "text": "Koszty wzrosły; mimo to kierownictwo trzyma się harmonogramu."
            },
            {
              "language": "ro",
              "text": "Costurile au crescut; cu toate acestea, conducerea menține calendarul."
            },
            {
              "language": "ru",
              "text": "Затраты выросли; тем не менее руководство придерживается графика."
            },
            {
              "language": "sq",
              "text": "Kostot janë rritur; megjithatë, menaxhmenti i përmbahet afatit."
            },
            {
              "language": "tr",
              "text": "Maliyetler arttı; buna rağmen yönetim takvime bağlı kalıyor."
            }
          ]
        },
        {
          "baseText": "Die Kritik war berechtigt; dessen ungeachtet wurde der Bericht fristgerecht veröffentlicht.",
          "translations": [
            {
              "language": "ar",
              "text": "كان النقد مبررًا؛ ومع ذلك نُشر التقرير في الموعد المحدد."
