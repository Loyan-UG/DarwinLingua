      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقارن"
        },
        {
          "language": "ckb",
          "text": "بەراورد دەکات"
        },
        {
          "language": "en",
          "text": "to compare"
        },
        {
          "language": "fa",
          "text": "مقایسه کردن"
        },
        {
          "language": "kmr",
          "text": "berawird kirin"
        },
        {
          "language": "pl",
          "text": "porównywać"
        },
        {
          "language": "ro",
          "text": "a compara"
        },
        {
          "language": "ru",
          "text": "сравнивать"
        },
        {
          "language": "sq",
          "text": "të krahasosh"
        },
        {
          "language": "tr",
          "text": "karşılaştırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir vergleichen die Preise im Internet.",
          "translations": [
            {
              "language": "ar",
              "text": "نقارن الأسعار على الإنترنت."
            },
            {
              "language": "ckb",
              "text": "ئێمە نرخەکان لە ئینتەرنێتدا بەراورد دەکەین."
            },
            {
              "language": "en",
              "text": "We compare the prices online."
            },
            {
              "language": "fa",
              "text": "ما قیمت‌ها را در اینترنت مقایسه می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em bihayan li înternetê berawird dikin."
            },
            {
              "language": "pl",
              "text": "Porównujemy ceny w internecie."
            },
            {
              "language": "ro",
              "text": "Comparăm prețurile pe internet."
            },
            {
              "language": "ru",
              "text": "Мы сравниваем цены в интернете."
            },
            {
              "language": "sq",
              "text": "I krahasojmë çmimet në internet."
            },
            {
              "language": "tr",
              "text": "Fiyatları internette karşılaştırıyoruz."
            }
          ]
        },
        {
          "baseText": "Kannst du bitte die zwei Angebote vergleichen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك من فضلك مقارنة العرضين؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت تکایە ئەو دوو پێشنیارە بەراورد بکەیت؟"
            },
            {
              "language": "en",
              "text": "Can you please compare the two offers?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً دو پیشنهاد را مقایسه کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî ji kerema xwe her du pêşniyaran berawird bikî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz porównać te dwie oferty?"
            },
            {
              "language": "ro",
              "text": "Poți să compari, te rog, cele două oferte?"
            },
            {
              "language": "ru",
              "text": "Можешь, пожалуйста, сравнить два предложения?"
            },
            {
              "language": "sq",
              "text": "A mund t’i krahasosh dy ofertat, të lutem?"
            },
            {
              "language": "tr",
              "text": "Lütfen iki teklifi karşılaştırabilir misin?"
            }
          ]
        }
      ]
    },
