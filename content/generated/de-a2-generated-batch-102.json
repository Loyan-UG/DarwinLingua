      "collocations": [
        {
          "text": "einen Termin vergessen",
          "meaning": "to forget an appointment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vergesslich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينسى"
        },
        {
          "language": "ckb",
          "text": "لەبیر دەکات"
        },
        {
          "language": "en",
          "text": "to forget"
        },
        {
          "language": "fa",
          "text": "فراموش کردن"
        },
        {
          "language": "kmr",
          "text": "ji bîr kirin"
        },
        {
          "language": "pl",
          "text": "zapominać"
        },
        {
          "language": "ro",
          "text": "a uita"
        },
        {
          "language": "ru",
          "text": "забывать"
        },
        {
          "language": "sq",
          "text": "të harrosh"
        },
        {
          "language": "tr",
          "text": "unutmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe den Termin leider vergessen.",
          "translations": [
            {
              "language": "ar",
              "text": "للأسف نسيت الموعد."
            },
            {
              "language": "ckb",
              "text": "بەداخەوە کاتەکەم لەبیر کرد."
            },
            {
              "language": "en",
              "text": "Unfortunately, I forgot the appointment."
            },
            {
              "language": "fa",
              "text": "متأسفانه وقت را فراموش کردم."
            },
            {
              "language": "kmr",
              "text": "Mixabin min dem ji bîr kir."
            },
            {
              "language": "pl",
              "text": "Niestety zapomniałem o terminie."
            },
            {
              "language": "ro",
              "text": "Din păcate, am uitat programarea."
            },
            {
              "language": "ru",
              "text": "К сожалению, я забыл о встрече."
            },
            {
              "language": "sq",
              "text": "Fatkeqësisht e harrova takimin."
            },
            {
              "language": "tr",
              "text": "Maalesef randevuyu unuttum."
            }
          ]
        },
        {
          "baseText": "Bitte vergessen Sie Ihren Ausweis nicht.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلكم لا تنسوا هويتكم."
            },
            {
              "language": "ckb",
              "text": "تکایە ناسنامەکەتان لەبیر مەکەن."
            },
            {
              "language": "en",
              "text": "Please do not forget your ID."
            },
            {
              "language": "fa",
              "text": "لطفاً کارت شناسایی خود را فراموش نکنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe nasnameya xwe ji bîr nekin."
            },
            {
              "language": "pl",
              "text": "Proszę nie zapomnieć dowodu."
            },
            {
              "language": "ro",
              "text": "Vă rog să nu uitați actul de identitate."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не забудьте удостоверение личности."
            },
            {
              "language": "sq",
              "text": "Ju lutem mos harroni dokumentin tuaj të identitetit."
            },
            {
              "language": "tr",
              "text": "Lütfen kimliğinizi unutmayın."
            }
          ]
        }
      ]
    },
