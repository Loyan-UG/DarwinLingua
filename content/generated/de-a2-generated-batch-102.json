      ],
      "examples": [
        {
          "baseText": "Sind Sie verheiratet oder ledig?",
          "translations": [
            {
              "language": "ar",
              "text": "هل أنت متزوج أم أعزب؟"
            },
            {
              "language": "ckb",
              "text": "ئایا هاوسەرگیری کردووتە یان سەڵتیت؟"
            },
            {
              "language": "en",
              "text": "Are you married or single?"
            },
            {
              "language": "fa",
              "text": "آیا متأهل هستید یا مجرد؟"
            },
            {
              "language": "kmr",
              "text": "Ma hûn zewicî ne an tenê ne?"
            },
            {
              "language": "pl",
              "text": "Czy jest pan/pani żonaty/zamężna czy stanu wolnego?"
            },
            {
              "language": "ro",
              "text": "Sunteți căsătorit sau necăsătorit?"
            },
            {
              "language": "ru",
              "text": "Вы женаты/замужем или холосты?"
            },
            {
              "language": "sq",
              "text": "Jeni i/e martuar apo beqar/e?"
            },
            {
              "language": "tr",
              "text": "Evli misiniz yoksa bekar mı?"
            }
          ]
        },
        {
          "baseText": "Meine Schwester ist seit Mai verheiratet.",
          "translations": [
            {
              "language": "ar",
              "text": "أختي متزوجة منذ مايو."
            },
            {
              "language": "ckb",
              "text": "خوشکەکەم لە مانگی ئایارەوە هاوسەرگیری کردووە."
            },
            {
              "language": "en",
              "text": "My sister has been married since May."
            },
            {
              "language": "fa",
              "text": "خواهرم از ماه مه متأهل است."
            },
            {
              "language": "kmr",
              "text": "Xwişka min ji gulanê ve zewicî ye."
            },
            {
              "language": "pl",
              "text": "Moja siostra jest zamężna od maja."
            },
            {
              "language": "ro",
              "text": "Sora mea este căsătorită din mai."
            },
            {
              "language": "ru",
              "text": "Моя сестра замужем с мая."
            },
            {
              "language": "sq",
              "text": "Motra ime është e martuar që nga maji."
            },
            {
              "language": "tr",
              "text": "Kız kardeşim mayıstan beri evli."
            }
          ]
        }
      ]
    },
