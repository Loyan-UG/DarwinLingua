      "contextLabels": [],
      "grammarNotes": [
        "verb phrase with lassen; means to have something checked by someone else"
      ],
      "collocations": [
        {
          "text": "die Unterlagen prüfen lassen",
          "meaning": "to have the documents checked"
        },
        {
          "text": "das Auto prüfen lassen",
          "meaning": "to have the car inspected"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "prüfen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Prüfung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يجعل شخصًا يفحص؛ يطلب فحص شيء"
        },
        {
          "language": "ckb",
          "text": "دەدات بە کەسێک بۆ پشکنین؛ داوای پشکنین دەکات"
        },
        {
          "language": "en",
          "text": "to have something checked; to get something inspected"
        },
        {
          "language": "fa",
          "text": "دادن چیزی برای بررسی؛ درخواست بررسی کردن"
        },
        {
          "language": "kmr",
          "text": "tiştekî dayîn kontrolkirin; lêkolîn lê kirin"
        },
        {
          "language": "pl",
          "text": "zlecić sprawdzenie; dać do kontroli"
        },
        {
          "language": "ro",
          "text": "a da ceva la verificat; a solicita verificarea"
        },
        {
          "language": "ru",
          "text": "дать проверить; заказать проверку"
        },
        {
          "language": "sq",
          "text": "ta lësh diçka për kontroll; të kërkosh verifikim"
        },
        {
          "language": "tr",
          "text": "kontrol ettirmek; inceletmek"
        }
      ],
      "examples": [
        {
          "baseText": "Vor dem Termin sollten Sie die Unterlagen prüfen lassen.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الموعد ينبغي أن تجعلوا المستندات تُفحص."
            },
            {
              "language": "ckb",
              "text": "پێش کاتەکە پێویستە بەڵگەنامەکان بدەن بپشکنرێن."
            },
            {
              "language": "en",
              "text": "Before the appointment, you should have the documents checked."
            },
            {
              "language": "fa",
              "text": "قبل از وقت ملاقات بهتر است مدارک را برای بررسی بدهید."
            },
            {
              "language": "kmr",
              "text": "Berî hevdîtinê divê hûn belgeyan bidin kontrolkirin."
            },
            {
              "language": "pl",
              "text": "Przed terminem warto zlecić sprawdzenie dokumentów."
            },
            {
              "language": "ro",
              "text": "Înainte de programare ar trebui să dați documentele la verificat."
            },
            {
              "language": "ru",
              "text": "Перед встречей вам следует дать документы на проверку."
            },
            {
              "language": "sq",
              "text": "Para takimit duhet t’i lini dokumentet për kontroll."
            },
            {
              "language": "tr",
              "text": "Randevudan önce belgeleri kontrol ettirmelisiniz."
            }
          ]
        },
        {
          "baseText": "Ich lasse das Auto morgen in der Werkstatt prüfen.",
          "translations": [
            {
              "language": "ar",
              "text": "سأجعل السيارة تُفحص غدًا في الورشة."
            },
            {
              "language": "ckb",
              "text": "سبەی ئۆتۆمبێلەکە لە وەرکشۆپ دەدەم بپشکنرێت."
            },
            {
              "language": "en",
              "text": "I will have the car checked at the repair shop tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا ماشین را در تعمیرگاه برای بررسی می‌دهم."
            },
            {
              "language": "kmr",
              "text": "Ez ê sibê otomobîlê li tamîrxaneyê bidim kontrolkirin."
            },
            {
              "language": "pl",
              "text": "Jutro oddam samochód do sprawdzenia w warsztacie."
            },
            {
              "language": "ro",
              "text": "Mâine duc mașina la verificat la service."
            },
            {
              "language": "ru",
              "text": "Завтра я отдам машину на проверку в мастерскую."
            },
            {
              "language": "sq",
              "text": "Nesër do ta çoj makinën për kontroll në servis."
            },
            {
              "language": "tr",
              "text": "Arabayı yarın serviste kontrol ettireceğim."
            }
          ]
        }
      ]
    }
