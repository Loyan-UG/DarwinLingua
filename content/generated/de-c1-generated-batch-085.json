  "entries": [
    {
      "word": "präzise",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "prä-zi-se",
      "topics": [
        "business-communication",
        "data-and-reporting",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; means exact and clearly defined"
      ],
      "collocations": [
        {
          "text": "präzise formulieren",
          "meaning": "to formulate precisely"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Präzision",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Präzisierung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دقيق؛ محدد بوضوح"
        },
        {
          "language": "ckb",
          "text": "ورد؛ بە ڕوونی دیاریکراو"
        },
        {
          "language": "en",
          "text": "precise; exact"
        },
        {
          "language": "fa",
          "text": "دقیق؛ روشن و مشخص"
        },
        {
          "language": "kmr",
          "text": "rast û hûr; zelal"
        },
        {
          "language": "pl",
          "text": "precyzyjny; dokładny"
        },
        {
          "language": "ro",
          "text": "precis; exact"
        },
        {
          "language": "ru",
          "text": "точный; четкий"
        },
        {
          "language": "sq",
          "text": "i saktë; preciz"
        },
        {
          "language": "tr",
          "text": "kesin; net"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte beschreiben Sie den Fehler so präzise wie möglich, damit wir ihn reproduzieren können.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى وصف الخطأ بأكبر قدر ممكن من الدقة حتى نتمكن من إعادة إنتاجه."
            },
            {
              "language": "ckb",
              "text": "تکایە هەڵەکە بە وردترین شێوە باس بکەن بۆ ئەوەی بتوانین دووبارەی بکەینەوە."
            },
            {
              "language": "en",
              "text": "Please describe the error as precisely as possible so we can reproduce it."
            },
            {
              "language": "fa",
              "text": "لطفاً خطا را تا حد امکان دقیق توضیح دهید تا بتوانیم آن را بازتولید کنیم."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe şaşiyê bi qasî gengaz hûr rave bikin da ku em bikarin wê dubare bikin."
            },
            {
              "language": "pl",
              "text": "Proszę opisać błąd możliwie precyzyjnie, abyśmy mogli go odtworzyć."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să descrieți eroarea cât mai precis posibil, ca să o putem reproduce."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, опишите ошибку как можно точнее, чтобы мы могли ее воспроизвести."
            },
            {
              "language": "sq",
              "text": "Ju lutem përshkruajeni gabimin sa më saktë që të mund ta riprodhojmë."
            },
            {
              "language": "tr",
              "text": "Hatayı yeniden üretebilmemiz için lütfen mümkün olduğunca kesin açıklayın."
            }
          ]
        },
        {
          "baseText": "Die Diagnose war präzise, aber für die Patientin zunächst schwer verständlich.",
          "translations": [
            {
              "language": "ar",
              "text": "كان التشخيص دقيقاً، لكنه كان في البداية صعب الفهم على المريضة."
            },
            {
              "language": "ckb",
              "text": "دەستنیشانکردنی نەخۆشییەکە ورد بوو، بەڵام سەرەتا بۆ نەخۆشەکە زەحمەت بوو تێبگات."
            },
            {
              "language": "en",
              "text": "The diagnosis was precise, but initially difficult for the patient to understand."
            },
            {
              "language": "fa",
              "text": "تشخیص دقیق بود، اما در ابتدا برای بیمار دشوار فهمیده می‌شد."
            },
            {
              "language": "kmr",
              "text": "Teşhîs hûr bû, lê di destpêkê de ji bo nexweşê zehmet bû ku fêm bike."
            },
            {
              "language": "pl",
              "text": "Diagnoza była precyzyjna, ale początkowo trudna do zrozumienia dla pacjentki."
            },
            {
              "language": "ro",
              "text": "Diagnosticul a fost precis, dar la început greu de înțeles pentru pacientă."
            },
            {
              "language": "ru",
              "text": "Диагноз был точным, но сначала трудным для понимания пациентки."
            },
            {
              "language": "sq",
              "text": "Diagnoza ishte e saktë, por fillimisht e vështirë për t’u kuptuar nga pacientja."
            },
            {
              "language": "tr",
              "text": "Tanı kesindi, ancak hasta için başlangıçta anlaşılması zordu."
            }
          ]
        }
      ]
    },
    {
      "word": "die Präzisierung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Präzisierungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Prä-zi-sie-rung",
      "topics": [
        "documents-and-administration",
        "business-communication",
        "planning-and-projects"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Präzisierung der Anforderungen",
          "meaning": "a clarification or more precise definition of requirements"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "präzisieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "präzise",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "توضيح أدق؛ تحديد أكثر دقة"
        },
        {
          "language": "ckb",
          "text": "وردکردنەوە؛ دیاریکردنی وردتر"
        },
        {
          "language": "en",
          "text": "clarification; more precise specification"
        },
        {
          "language": "fa",
          "text": "دقیق‌سازی؛ توضیح روشن‌تر"
        },
        {
          "language": "kmr",
          "text": "zelalkirina hûrtir"
        },
        {
          "language": "pl",
          "text": "doprecyzowanie; uściślenie"
        },
        {
          "language": "ro",
          "text": "precizare; clarificare"
        },
        {
          "language": "ru",
          "text": "уточнение; конкретизация"
        },
        {
          "language": "sq",
          "text": "saktësim; qartësim"
        },
        {
          "language": "tr",
          "text": "netleştirme; kesinleştirme"
        }
      ],
      "examples": [
        {
          "baseText": "Ohne Präzisierung der Schnittstelle kann das Entwicklungsteam keinen belastbaren Aufwand schätzen.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون تحديد أدق للواجهة لا يستطيع فريق التطوير تقدير الجهد بشكل موثوق."
            },
            {
              "language": "ckb",
              "text": "بەبێ وردکردنەوەی ڕووکاری پەیوەندی، تیمی پەرەپێدان ناتوانێت هەوڵی پێویست بە پشتپێبەست خەمڵێنێت."
            },
            {
              "language": "en",
              "text": "Without a more precise specification of the interface, the development team cannot estimate effort reliably."
            },
            {
              "language": "fa",
              "text": "بدون دقیق‌سازی رابط، تیم توسعه نمی‌تواند برآورد قابل اتکایی از هزینه کار بدهد."
            },
            {
              "language": "kmr",
              "text": "Bê zelalkirina hûrtir a navrûyê, tîma pêşxistinê nikare hewldanê bi bawerbarî texmîn bike."
            },
            {
              "language": "pl",
              "text": "Bez doprecyzowania interfejsu zespół deweloperski nie może wiarygodnie oszacować nakładu pracy."
            },
            {
              "language": "ro",
              "text": "Fără precizarea interfeței, echipa de dezvoltare nu poate estima efortul în mod solid."
            },
            {
              "language": "ru",
              "text": "Без уточнения интерфейса команда разработки не может надежно оценить трудозатраты."
            },
            {
              "language": "sq",
              "text": "Pa saktësimin e ndërfaqes, ekipi i zhvillimit nuk mund të vlerësojë besueshëm përpjekjen."
            },
            {
              "language": "tr",
              "text": "Arayüz netleştirilmeden geliştirme ekibi eforu güvenilir biçimde tahmin edemez."
            }
          ]
        },
        {
          "baseText": "Die Präzisierung der Frage führte in der Diskussion zu deutlich besseren Antworten.",
          "translations": [
            {
              "language": "ar",
              "text": "أدى توضيح السؤال بشكل أدق إلى إجابات أفضل بكثير في النقاش."
            },
            {
              "language": "ckb",
              "text": "وردکردنەوەی پرسیارەکە لە گفتوگۆکەدا بووە هۆی وەڵامی زۆر باشتر."
            },
            {
              "language": "en",
              "text": "Clarifying the question led to significantly better answers in the discussion."
            },
            {
              "language": "fa",
              "text": "دقیق‌تر کردن سؤال در بحث به پاسخ‌های بسیار بهتری منجر شد."
            },
            {
              "language": "kmr",
              "text": "Zelalkirina hûrtir a pirsê di nîqaşê de bû sedema bersivên gelek baştir."
            },
            {
              "language": "pl",
              "text": "Doprecyzowanie pytania doprowadziło w dyskusji do znacznie lepszych odpowiedzi."
            },
            {
              "language": "ro",
              "text": "Precizarea întrebării a dus în discuție la răspunsuri mult mai bune."
            },
            {
              "language": "ru",
              "text": "Уточнение вопроса привело в дискуссии к гораздо лучшим ответам."
            },
            {
              "language": "sq",
              "text": "Saktësimi i pyetjes çoi në përgjigje dukshëm më të mira në diskutim."
            },
            {
              "language": "tr",
              "text": "Sorunun netleştirilmesi tartışmada çok daha iyi yanıtlara yol açtı."
            }
          ]
        }
      ]
    },
    {
      "word": "die Preisbildung",
