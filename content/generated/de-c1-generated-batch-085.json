      "meanings": [
        {
          "language": "ar",
          "text": "تكوين الأسعار؛ آلية التسعير"
        },
        {
          "language": "ckb",
          "text": "دروستبوونی نرخ؛ میکانیزمی نرخدانان"
        },
        {
          "language": "en",
          "text": "price formation; pricing mechanism"
        },
        {
          "language": "fa",
          "text": "شکل‌گیری قیمت؛ سازوکار قیمت‌گذاری"
        },
        {
          "language": "kmr",
          "text": "çêbûna bihayê"
        },
        {
          "language": "pl",
          "text": "kształtowanie cen"
        },
        {
          "language": "ro",
          "text": "formarea prețurilor"
        },
        {
          "language": "ru",
          "text": "ценообразование"
        },
        {
          "language": "sq",
          "text": "formim çmimi"
        },
        {
          "language": "tr",
          "text": "fiyat oluşumu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Preisbildung hängt stark davon ab, wie transparent die verfügbaren Marktdaten sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يعتمد تكوين الأسعار بشدة على مدى شفافية بيانات السوق المتاحة."
            },
            {
              "language": "ckb",
              "text": "دروستبوونی نرخ زۆر پەیوەستە بەوەی داتای بازاڕی بەردەست چەند ڕوونە."
            },
            {
              "language": "en",
              "text": "Price formation depends heavily on how transparent the available market data are."
            },
            {
              "language": "fa",
