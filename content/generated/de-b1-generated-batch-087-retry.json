      "examples": [
        {
          "baseText": "Viele Mitarbeiter leiden unter Stress, wenn mehrere Projekte gleichzeitig laufen.",
          "translations": [
            {
              "language": "ar",
              "text": "يعاني كثير من الموظفين من الضغط عندما تجري عدة مشاريع في الوقت نفسه."
            },
            {
              "language": "ckb",
              "text": "زۆر کارمەند بەهۆی سترێس ئازار دەچێژن کاتێک چەند پڕۆژە پێکەوە بەڕێوە دەچن."
            },
            {
              "language": "en",
              "text": "Many employees suffer from stress when several projects run at the same time."
            },
            {
              "language": "fa",
              "text": "بسیاری از کارکنان وقتی چند پروژه همزمان اجرا می‌شود دچار استرس می‌شوند."
            },
            {
              "language": "kmr",
              "text": "Gelek karmend ji stresê êş dikişînin dema çend proje bi hev re dimeşin."
            },
            {
              "language": "pl",
              "text": "Wielu pracowników cierpi na stres, gdy kilka projektów trwa jednocześnie."
            },
            {
              "language": "ro",
              "text": "Mulți angajați suferă de stres când mai multe proiecte se desfășoară simultan."
            },
            {
              "language": "ru",
              "text": "Многие сотрудники страдают от стресса, когда несколько проектов идут одновременно."
            },
            {
              "language": "sq",
              "text": "Shumë punonjës vuajnë nga stresi kur disa projekte zhvillohen njëkohësisht."
            },
            {
              "language": "tr",
              "text": "Birden fazla proje aynı anda yürüdüğünde birçok çalışan stresten muzdarip olur."
            }
          ]
        },
        {
          "baseText": "Sie leidet seit einigen Tagen unter starken Kopfschmerzen.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تعاني منذ عدة أيام من صداع شديد."
            },
            {
              "language": "ckb",
              "text": "ئەو چەند ڕۆژە بە ئازاری سەری توندەوە دەناڵێنێت."
            },
            {
              "language": "en",
              "text": "She has been suffering from severe headaches for several days."
            },
            {
              "language": "fa",
              "text": "او چند روز است از سردرد شدید رنج می‌برد."
            },
            {
              "language": "kmr",
              "text": "Ew ji çend rojan ve ji serêşiyên tund êş dikişîne."
            },
            {
              "language": "pl",
              "text": "Od kilku dni cierpi na silne bóle głowy."
            },
            {
              "language": "ro",
              "text": "De câteva zile suferă de dureri puternice de cap."
            },
            {
              "language": "ru",
              "text": "Она уже несколько дней страдает от сильных головных болей."
            },
            {
              "language": "sq",
              "text": "Ajo prej disa ditësh vuan nga dhimbje të forta koke."
            },
            {
              "language": "tr",
              "text": "Birkaç gündür şiddetli baş ağrısı çekiyor."
            }
          ]
        }
      ]
    }
