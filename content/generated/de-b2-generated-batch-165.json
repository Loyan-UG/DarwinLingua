  "entries": [
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "einsenden",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "einsenden",
      "syllableBreak": "ein-sen-den",
      "topics": [
        "documents-and-administration",
        "customer-service",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "documents",
        "customer-service"
      ],
      "grammarNotes": [
        "separable verb; means to submit or send in documents or material"
      ],
      "collocations": [
        {
          "text": "Unterlagen einsenden",
          "meaning": "to submit documents"
        },
        {
          "text": "eine Bewerbung einsenden",
          "meaning": "to send in an application"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "senden",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يرسل؛ يقدم مستندات"
        },
        {
          "language": "ckb",
          "text": "دەنێرێت؛ بەڵگەنامە پێشکەش دەکات"
        },
        {
          "language": "en",
          "text": "to send in; to submit"
        },
        {
          "language": "fa",
          "text": "ارسال کردن؛ ارائه دادن"
        },
        {
          "language": "kmr",
          "text": "şandin; belge pêşkêş kirin"
        },
        {
          "language": "pl",
          "text": "nadesłać; przesłać"
        },
        {
          "language": "ro",
          "text": "a trimite; a depune"
        },
        {
          "language": "ru",
          "text": "отправить; подать"
        },
        {
          "language": "sq",
          "text": "të dërgosh; të dorëzosh"
        },
        {
          "language": "tr",
          "text": "göndermek; teslim etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte senden Sie die unterschriebenen Unterlagen bis Freitag per E-Mail ein.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال المستندات الموقعة عبر البريد الإلكتروني بحلول يوم الجمعة."
            },
            {
              "language": "ckb",
              "text": "تکایە بەڵگەنامە واژۆکراوەکان تا هەینی بە ئیمەیڵ بنێرن."
            },
            {
              "language": "en",
              "text": "Please send in the signed documents by email by Friday."
            },
            {
              "language": "fa",
              "text": "لطفاً مدارک امضاشده را تا جمعه از طریق ایمیل ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeyên îmzekirî heta înê bi e-nameyê bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać podpisane dokumenty e-mailem do piątku."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să trimiteți documentele semnate prin e-mail până vineri."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте подписанные документы по электронной почте до пятницы."
            },
            {
              "language": "sq",
              "text": "Ju lutemi dërgoni dokumentet e nënshkruara me email deri të premten."
            },
            {
              "language": "tr",
              "text": "Lütfen imzalı belgeleri cumaya kadar e-posta ile gönderin."
            }
          ]
        },
        {
          "baseText": "Für den Fotowettbewerb können Jugendliche ihre Bilder online einsenden.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن للشباب إرسال صورهم عبر الإنترنت للمسابقة الفوتوغرافية."
            },
            {
              "language": "ckb",
              "text": "گەنجان دەتوانن وێنەکانیان بۆ پێشبڕکێی وێنەگرتن ئۆنلاین بنێرن."
            },
            {
              "language": "en",
              "text": "Young people can submit their photos online for the photo competition."
            },
            {
              "language": "fa",
              "text": "نوجوانان می‌توانند عکس‌هایشان را برای مسابقه عکاسی آنلاین ارسال کنند."
            },
            {
              "language": "kmr",
              "text": "Ciwan dikarin wêneyên xwe ji bo pêşbaziya wênegirtinê online bişînin."
            },
            {
              "language": "pl",
              "text": "Młodzież może przesyłać swoje zdjęcia online na konkurs fotograficzny."
            },
            {
              "language": "ro",
              "text": "Tinerii își pot trimite fotografiile online pentru concursul foto."
            },
            {
              "language": "ru",
              "text": "Молодые люди могут отправить свои фотографии на фотоконкурс онлайн."
            },
            {
              "language": "sq",
              "text": "Të rinjtë mund t’i dërgojnë fotografitë online për konkursin fotografik."
            },
            {
              "language": "tr",
              "text": "Gençler fotoğraf yarışması için fotoğraflarını çevrimiçi gönderebilir."
            }
          ]
        }
      ]
    },
