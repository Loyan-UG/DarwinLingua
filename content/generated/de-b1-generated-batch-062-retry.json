      "meanings": [
        {
          "language": "ar",
          "text": "ينتقل بعيدًا؛ يغادر للعيش في مكان آخر"
        },
        {
          "language": "ckb",
          "text": "کۆچکردن؛ لە شوێنێک ڕۆیشتن"
        },
        {
          "language": "en",
          "text": "to move away"
        },
        {
          "language": "fa",
          "text": "نقل مکان کردن؛ از جایی رفتن"
        },
        {
          "language": "kmr",
          "text": "bar kirin; ji cihêkê çûn"
        },
        {
          "language": "pl",
          "text": "wyprowadzić się"
        },
        {
          "language": "ro",
          "text": "a se muta departe"
        },
        {
          "language": "ru",
          "text": "переезжать; уезжать"
        },
        {
          "language": "sq",
          "text": "të shpërngulesh"
        },
        {
          "language": "tr",
          "text": "taşınıp gitmek"
        }
      ],
      "examples": [
        {
          "baseText": "Viele junge Leute ziehen nach der Ausbildung aus dem Dorf fort.",
          "translations": [
            {
              "language": "ar",
              "text": "ينتقل كثير من الشباب من القرية بعد التدريب المهني."
            },
            {
              "language": "ckb",
              "text": "زۆر گەنج دوای فێربوونی پیشەیی لە گوندەکە کۆچ دەکەن."
            },
            {
              "language": "en",
              "text": "Many young people move away from the village after vocational training."
            },
            {
              "language": "fa",
              "text": "بسیاری از جوانان بعد از آموزش حرفه‌ای از روستا می‌روند."
            },
            {
              "language": "kmr",
              "text": "Gelek ciwan piştî perwerdeya pîşeyî ji gundê bar dikin."
            },
            {
              "language": "pl",
              "text": "Wielu młodych ludzi wyprowadza się ze wsi po szkoleniu zawodowym."
            },
            {
              "language": "ro",
              "text": "Mulți tineri se mută din sat după formarea profesională."
            },
            {
              "language": "ru",
              "text": "Многие молодые люди после обучения уезжают из деревни."
            },
            {
              "language": "sq",
              "text": "Shumë të rinj shpërngulen nga fshati pas trajnimit profesional."
            },
            {
              "language": "tr",
              "text": "Birçok genç mesleki eğitimden sonra köyden taşınıp gidiyor."
            }
          ]
        },
        {
          "baseText": "Wenn die Miete weiter steigt, müssen wir vielleicht fortziehen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا استمر الإيجار في الارتفاع، فقد نضطر إلى الانتقال."
            },
            {
              "language": "ckb",
              "text": "ئەگەر کرێ بەردەوام بەرز ببێتەوە، ڕەنگە ناچار بین کۆچ بکەین."
            },
            {
              "language": "en",
              "text": "If the rent keeps rising, we may have to move away."
            },
            {
              "language": "fa",
              "text": "اگر اجاره همچنان بالا برود، شاید مجبور شویم نقل مکان کنیم."
            },
            {
              "language": "kmr",
              "text": "Heke kirê berdewam bilind bibe, belkî em neçar bibin bar bikin."
            },
            {
              "language": "pl",
              "text": "Jeśli czynsz dalej będzie rosnąć, może będziemy musieli się wyprowadzić."
            },
            {
              "language": "ro",
              "text": "Dacă chiria continuă să crească, poate va trebui să ne mutăm."
            },
            {
              "language": "ru",
              "text": "Если аренда продолжит расти, нам, возможно, придется переехать."
            },
            {
              "language": "sq",
              "text": "Nëse qiraja vazhdon të rritet, ndoshta duhet të shpërngulemi."
            },
            {
              "language": "tr",
              "text": "Kira artmaya devam ederse belki taşınmak zorunda kalacağız."
            }
          ]
        }
      ]
    }
