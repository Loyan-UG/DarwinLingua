  "entries": [
    {
      "word": "betreten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "betreten",
      "pronunciationIpa": null,
      "syllableBreak": "be-tre-ten",
      "topics": [
        "public-services",
        "work-and-jobs",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "written",
        "spoken"
      ],
      "contextLabels": [
        "administration",
        "documents"
      ],
      "grammarNotes": [
        "strong verb: betritt, betrat, hat betreten"
      ],
      "collocations": [
        {
          "text": "einen Raum betreten",
          "meaning": "to enter a room"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Eintritt",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدخل؛ يطأ"
        },
        {
          "language": "ckb",
          "text": "چوونە ژوورەوە؛ پێ نانە ناو"
        },
        {
          "language": "en",
          "text": "to enter; to step into"
        },
        {
          "language": "fa",
          "text": "وارد شدن؛ قدم گذاشتن به"
        },
        {
          "language": "kmr",
          "text": "ketin hundir; gav avêtin nav"
        },
        {
          "language": "pl",
          "text": "wejść; wkroczyć"
        },
        {
          "language": "ro",
          "text": "a intra; a păși în"
        },
        {
          "language": "ru",
          "text": "входить; вступать"
        },
        {
          "language": "sq",
          "text": "të hysh; të shkelësh në"
        },
        {
          "language": "tr",
          "text": "girmek; adım atmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte betreten Sie den Serverraum nur mit einer berechtigten Person.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى دخول غرفة الخوادم فقط مع شخص مخوّل."
            },
            {
              "language": "ckb",
              "text": "تکایە تەنها لەگەڵ کەسێکی ڕێپێدراو بچنە ژووری سێرڤەرەکان."
            },
            {
              "language": "en",
              "text": "Please enter the server room only with an authorized person."
            },
            {
              "language": "fa",
              "text": "لطفاً فقط همراه یک فرد مجاز وارد اتاق سرور شوید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe tenê bi kesekî destûrdar bikevin odeya serveran."
            },
            {
              "language": "pl",
              "text": "Proszę wchodzić do serwerowni tylko z upoważnioną osobą."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să intrați în camera serverelor doar cu o persoană autorizată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, входите в серверную только с уполномоченным лицом."
            },
            {
              "language": "sq",
              "text": "Ju lutemi hyni në dhomën e serverëve vetëm me një person të autorizuar."
            },
            {
              "language": "tr",
              "text": "Lütfen sunucu odasına yalnızca yetkili bir kişiyle girin."
            }
          ]
        },
        {
          "baseText": "Nach 18 Uhr darf niemand das Gebäude ohne Ausweis betreten.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الساعة السادسة مساءً لا يجوز لأحد دخول المبنى بدون بطاقة هوية."
            },
            {
              "language": "ckb",
              "text": "دوای کاتژمێر شەش ئێوارە هیچ کەس نابێت بێ ناسنامە بچێتە ناو بیناکە."
            },
            {
              "language": "en",
              "text": "After 6 p.m., no one may enter the building without an ID card."
            },
            {
              "language": "fa",
              "text": "بعد از ساعت ۱۸ هیچ‌کس اجازه ندارد بدون کارت شناسایی وارد ساختمان شود."
            },
            {
              "language": "kmr",
              "text": "Piştî saet 18:00 tu kes bê nasname nikare bikeve avahiyê."
            },
            {
              "language": "pl",
              "text": "Po godzinie 18 nikt nie może wejść do budynku bez identyfikatora."
            },
            {
              "language": "ro",
              "text": "După ora 18, nimeni nu are voie să intre în clădire fără legitimație."
            },
            {
              "language": "ru",
              "text": "После 18:00 никто не может входить в здание без удостоверения."
            },
            {
              "language": "sq",
              "text": "Pas orës 18:00 askush nuk mund të hyjë në ndërtesë pa kartë identiteti."
            },
            {
              "language": "tr",
              "text": "Saat 18’den sonra kimse kimlik kartı olmadan binaya giremez."
            }
          ]
        }
      ]
    },
    {
      "word": "der Betrieb",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Betriebe",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-trieb",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "production-and-maintenance"
      ],
      "usageLabels": [
        "business",
        "formal",
        "spoken"
      ],
      "contextLabels": [
        "management",
        "manufacturing",
        "administration"
      ],
      "grammarNotes": [
        "masculine noun; can mean company, operation, or workplace"
      ],
      "collocations": [
        {
          "text": "in einem Betrieb arbeiten",
          "meaning": "to work in a company or workplace"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "betrieblich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شركة؛ منشأة؛ تشغيل"
        },
        {
          "language": "ckb",
          "text": "کارگە؛ دامەزراوە؛ کارپێکردن"
        },
        {
          "language": "en",
          "text": "company; workplace; operation"
        },
        {
          "language": "fa",
          "text": "شرکت؛ محل کار؛ بهره‌برداری"
        },
        {
          "language": "kmr",
          "text": "kargeh; sazgeh; xebitandin"
        },
        {
          "language": "pl",
          "text": "zakład; firma; działanie"
        },
        {
          "language": "ro",
          "text": "întreprindere; firmă; funcționare"
        },
        {
          "language": "ru",
          "text": "предприятие; работа; эксплуатация"
        },
        {
          "language": "sq",
          "text": "ndërmarrje; vend pune; funksionim"
        },
        {
          "language": "tr",
          "text": "işletme; iş yeri; çalışma"
        }
      ],
      "examples": [
        {
          "baseText": "Der Betrieb bildet jedes Jahr neue Azubis aus.",
          "translations": [
            {
              "language": "ar",
              "text": "تقوم الشركة كل عام بتدريب متدربين مهنيين جدد."
            },
            {
              "language": "ckb",
              "text": "دامەزراوەکە هەموو ساڵێک فێرخوازانی پیشەیی نوێ پەروەردە دەکات."
            },
            {
              "language": "en",
              "text": "The company trains new apprentices every year."
            },
            {
              "language": "fa",
              "text": "این شرکت هر سال کارآموزان جدید تربیت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Kargeh her sal şagirtên pîşeyî yên nû perwerde dike."
            },
            {
              "language": "pl",
              "text": "Zakład co roku szkoli nowych uczniów zawodu."
            },
            {
              "language": "ro",
              "text": "Întreprinderea formează în fiecare an ucenici noi."
            },
            {
              "language": "ru",
              "text": "Предприятие каждый год обучает новых практикантов."
            },
            {
              "language": "sq",
              "text": "Ndërmarrja trajnon çdo vit praktikantë të rinj."
            },
            {
              "language": "tr",
              "text": "İşletme her yıl yeni çıraklar yetiştiriyor."
            }
          ]
        },
        {
          "baseText": "Während der Wartung ist der Betrieb der Anlage kurz unterbrochen.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء الصيانة يتوقف تشغيل النظام لفترة قصيرة."
            },
            {
              "language": "ckb",
