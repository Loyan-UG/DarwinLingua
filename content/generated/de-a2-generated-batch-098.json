      "examples": [
        {
          "baseText": "Sind die Transportkosten im Preis enthalten?",
          "translations": [
            {
              "language": "ar",
              "text": "هل تكاليف النقل مشمولة في السعر؟"
            },
            {
              "language": "ckb",
              "text": "ئایا تێچووی گواستنەوە لە نرخەکەدا هەیە؟"
            },
            {
              "language": "en",
              "text": "Are the transport costs included in the price?"
            },
            {
              "language": "fa",
              "text": "آیا هزینه حمل‌ونقل در قیمت شامل شده است؟"
            },
            {
              "language": "kmr",
              "text": "Ma mesrefên veguhestinê di bihayê de hene?"
            },
            {
              "language": "pl",
              "text": "Czy koszty transportu są wliczone w cenę?"
            },
            {
              "language": "ro",
              "text": "Costurile de transport sunt incluse în preț?"
            },
            {
              "language": "ru",
              "text": "Транспортные расходы включены в цену?"
            },
            {
              "language": "sq",
              "text": "A përfshihen kostot e transportit në çmim?"
            },
            {
              "language": "tr",
              "text": "Nakliye masrafları fiyata dahil mi?"
            }
          ]
        },
        {
          "baseText": "Die Transportkosten stehen auf der Rechnung.",
          "translations": [
            {
              "language": "ar",
              "text": "تكاليف النقل موجودة على الفاتورة."
            },
            {
              "language": "ckb",
              "text": "تێچووی گواستنەوە لەسەر فاکتورەکە نووسراوە."
            },
            {
              "language": "en",
              "text": "The transport costs are on the invoice."
            },
            {
              "language": "fa",
              "text": "هزینه حمل‌ونقل روی فاکتور نوشته شده است."
            },
            {
              "language": "kmr",
              "text": "Mesrefên veguhestinê li ser fatûreyê ne."
            },
            {
              "language": "pl",
              "text": "Koszty transportu są na fakturze."
            },
            {
              "language": "ro",
              "text": "Costurile de transport sunt pe factură."
            },
            {
              "language": "ru",
              "text": "Транспортные расходы указаны в счете."
            },
            {
              "language": "sq",
              "text": "Kostot e transportit janë në faturë."
            },
            {
              "language": "tr",
