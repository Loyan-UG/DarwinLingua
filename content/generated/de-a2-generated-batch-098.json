              "text": "Kompania transporton mobiliet nesër."
            },
            {
              "language": "tr",
              "text": "Şirket mobilyaları yarın taşıyor."
            }
          ]
        },
        {
          "baseText": "Wir transportieren die Kisten mit dem Aufzug.",
          "translations": [
