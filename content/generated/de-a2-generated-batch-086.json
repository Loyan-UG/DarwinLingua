      ],
      "collocations": [
        {
          "text": "eine Sehenswürdigkeit besuchen",
          "meaning": "to visit a sight"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sehenswert",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "معلم سياحي؛ مكان جدير بالزيارة"
        },
        {
          "language": "ckb",
          "text": "شوێنی دیدنی"
        },
        {
          "language": "en",
          "text": "sight; tourist attraction"
        },
        {
          "language": "fa",
          "text": "جاذبه دیدنی؛ جای دیدنی"
        },
        {
          "language": "kmr",
          "text": "cihê dîtinê; cihê geştî"
        },
        {
          "language": "pl",
          "text": "atrakcja turystyczna; zabytek"
        },
        {
          "language": "ro",
          "text": "obiectiv turistic"
        },
        {
          "language": "ru",
          "text": "достопримечательность"
        },
        {
          "language": "sq",
          "text": "vend turistik; atraksion"
        },
        {
          "language": "tr",
          "text": "gezilecek yer; turistik yer"
        }
      ],
      "examples": [
        {
          "baseText": "Welche Sehenswürdigkeit möchten Sie zuerst besuchen?",
          "translations": [
            {
              "language": "ar",
              "text": "أي معلم سياحي تريدون زيارته أولاً؟"
            },
            {
              "language": "ckb",
              "text": "دەتانەوێت سەرەتا کام شوێنی دیدنی ببینن؟"
            },
            {
              "language": "en",
              "text": "Which sight would you like to visit first?"
            },
            {
              "language": "fa",
              "text": "اول می‌خواهید کدام جاذبه دیدنی را ببینید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dixwazin pêşî kîjan cihê dîtinê ziyaret bikin?"
            },
            {
              "language": "pl",
              "text": "Którą atrakcję chcą państwo zwiedzić najpierw?"
            },
            {
              "language": "ro",
              "text": "Ce obiectiv turistic doriți să vizitați mai întâi?"
            },
            {
              "language": "ru",
              "text": "Какую достопримечательность вы хотите посетить сначала?"
            },
            {
              "language": "sq",
              "text": "Cilin vend turistik dëshironi të vizitoni së pari?"
            },
            {
              "language": "tr",
              "text": "Önce hangi turistik yeri ziyaret etmek istersiniz?"
            }
          ]
        },
        {
          "baseText": "Der Dom ist die bekannteste Sehenswürdigkeit der Stadt.",
          "translations": [
            {
              "language": "ar",
              "text": "الكاتدرائية هي أشهر معلم في المدينة."
            },
            {
              "language": "ckb",
              "text": "کەنیسە گەورەکە ناسراوترین شوێنی دیدنی شارەکەیە."
            },
            {
              "language": "en",
              "text": "The cathedral is the city’s best-known sight."
            },
            {
              "language": "fa",
              "text": "کلیسای جامع معروف‌ترین جاذبه شهر است."
            },
            {
              "language": "kmr",
              "text": "Katedral cihê dîtinê yê herî navdar ê bajêr e."
            },
            {
              "language": "pl",
              "text": "Katedra jest najbardziej znaną atrakcją miasta."
            },
            {
              "language": "ro",
              "text": "Catedrala este cel mai cunoscut obiectiv al orașului."
            },
            {
              "language": "ru",
              "text": "Собор — самая известная достопримечательность города."
            },
            {
              "language": "sq",
              "text": "Katedralja është atraksioni më i njohur i qytetit."
            },
            {
              "language": "tr",
              "text": "Katedral şehrin en bilinen turistik yeridir."
            }
          ]
        }
      ]
    },
