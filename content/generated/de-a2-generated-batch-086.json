      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الأمانة؛ مكتب الإدارة"
        },
        {
          "language": "ckb",
          "text": "سکرتاریا؛ نووسینگەی بەڕێوەبردن"
        },
        {
          "language": "en",
          "text": "secretariat; office"
        },
        {
          "language": "fa",
          "text": "دبیرخانه؛ دفتر اداری"
        },
        {
          "language": "kmr",
          "text": "sekreterî; nivîsgeha rêveberiyê"
        },
        {
          "language": "pl",
          "text": "sekretariat"
        },
        {
          "language": "ro",
          "text": "secretariat"
        },
        {
          "language": "ru",
          "text": "секретариат; канцелярия"
        },
        {
          "language": "sq",
          "text": "sekretari; zyrë administrate"
        },
        {
          "language": "tr",
          "text": "sekreterlik; idari ofis"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte melden Sie sich im Sekretariat.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تسجيل حضوركم في الأمانة."
            },
            {
              "language": "ckb",
              "text": "تکایە لە سکرتاریا خۆتان تۆمار بکەن."
            },
            {
              "language": "en",
              "text": "Please report to the office."
            },
            {
              "language": "fa",
              "text": "لطفاً به دفتر اداری مراجعه کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li sekreteriyê xwe qeyd bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zgłosić się w sekretariacie."
            },
            {
              "language": "ro",
              "text": "Vă rog să vă anunțați la secretariat."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, обратитесь в секретариат."
            },
            {
              "language": "sq",
              "text": "Ju lutem paraqituni në sekretari."
            },
            {
              "language": "tr",
              "text": "Lütfen sekreterliğe başvurun."
            }
          ]
        },
        {
          "baseText": "Das Sekretariat ist heute bis 15 Uhr geöffnet.",
          "translations": [
            {
              "language": "ar",
              "text": "الأمانة مفتوحة اليوم حتى الساعة الثالثة."
            },
            {
              "language": "ckb",
              "text": "سکرتاریا ئەمڕۆ تا کاتژمێر ١٥ کراوەیە."
            },
            {
              "language": "en",
              "text": "The office is open today until 3 p.m."
            },
            {
              "language": "fa",
              "text": "دفتر امروز تا ساعت ۱۵ باز است."
            },
            {
              "language": "kmr",
              "text": "Sekreterî îro heta saet 15 vekirî ye."
            },
            {
              "language": "pl",
              "text": "Sekretariat jest dziś otwarty do godziny 15."
            },
            {
              "language": "ro",
              "text": "Secretariatul este deschis astăzi până la ora 15."
            },
            {
              "language": "ru",
              "text": "Секретариат сегодня открыт до 15 часов."
            },
            {
              "language": "sq",
              "text": "Sekretaria sot është e hapur deri në orën 15."
            },
            {
              "language": "tr",
              "text": "Sekreterlik bugün saat 15’e kadar açık."
            }
          ]
        }
      ]
    },
