      ],
      "examples": [
        {
          "baseText": "Der Bahnhof ist in der Nähe.",
          "translations": [
            {
              "language": "ar",
              "text": "محطة القطار قريبة."
            },
            {
              "language": "ckb",
              "text": "وێستگەی شەمەندەفەر لە نزیکە."
            },
            {
              "language": "en",
              "text": "The train station is nearby."
            },
            {
              "language": "fa",
              "text": "ایستگاه قطار نزدیک است."
            },
            {
              "language": "kmr",
              "text": "Stasyona trênê li nêzîk e."
            },
            {
              "language": "pl",
              "text": "Dworzec jest blisko."
            },
            {
              "language": "ro",
              "text": "Gara este aproape."
            },
            {
              "language": "ru",
              "text": "Вокзал рядом."
            },
            {
              "language": "sq",
              "text": "Stacioni i trenit është afër."
            },
            {
              "language": "tr",
              "text": "Tren istasyonu yakında."
            }
          ]
        },
        {
          "baseText": "Ich warte am Bahnhof.",
          "translations": [
            {
              "language": "ar",
              "text": "أنتظر في محطة القطار."
            },
            {
              "language": "ckb",
              "text": "لە وێستگەی شەمەندەفەر چاوەڕێ دەکەم."
            },
            {
              "language": "en",
              "text": "I am waiting at the train station."
            },
            {
              "language": "fa",
              "text": "در ایستگاه قطار منتظر هستم."
            },
            {
              "language": "kmr",
              "text": "Ez li stasyona trênê disekinim."
            },
            {
              "language": "pl",
              "text": "Czekam na dworcu."
            },
            {
              "language": "ro",
              "text": "Aștept la gară."
            },
            {
              "language": "ru",
              "text": "Я жду на вокзале."
            },
            {
              "language": "sq",
              "text": "Po pres në stacionin e trenit."
            },
            {
              "language": "tr",
              "text": "Tren istasyonunda bekliyorum."
            }
          ]
        }
      ]
