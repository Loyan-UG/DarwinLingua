      ],
      "examples": [
        {
          "baseText": "Wir gehen heute ins Kino.",
          "translations": [
            {
              "language": "ar",
              "text": "نذهب اليوم إلى السينما."
            },
            {
              "language": "ckb",
              "text": "ئێمە ئەمڕۆ دەچینە سینەما."
            },
            {
              "language": "en",
              "text": "We are going to the cinema today."
            },
            {
              "language": "fa",
              "text": "ما امروز به سینما می‌رویم."
            },
            {
              "language": "kmr",
              "text": "Em îro diçin sînemayê."
            },
            {
              "language": "pl",
              "text": "Dzisiaj idziemy do kina."
            },
            {
              "language": "ro",
              "text": "Astăzi mergem la cinema."
            },
            {
              "language": "ru",
              "text": "Сегодня мы идем в кино."
            },
            {
              "language": "sq",
              "text": "Sot shkojmë në kinema."
            },
            {
              "language": "tr",
              "text": "Bugün sinemaya gidiyoruz."
            }
          ]
        },
        {
          "baseText": "Das Kino ist neben dem Café.",
          "translations": [
            {
              "language": "ar",
              "text": "السينما بجانب المقهى."
            },
            {
              "language": "ckb",
              "text": "سینەماکە لە تەنیشت کافێکەیە."
            },
            {
              "language": "en",
              "text": "The cinema is next to the café."
            },
            {
              "language": "fa",
              "text": "سینما کنار کافه است."
            },
            {
              "language": "kmr",
              "text": "Sînema li kêleka kafeyê ye."
            },
            {
              "language": "pl",
              "text": "Kino jest obok kawiarni."
            },
            {
              "language": "ro",
              "text": "Cinemaul este lângă cafenea."
            },
            {
              "language": "ru",
              "text": "Кинотеатр рядом с кафе."
            },
            {
              "language": "sq",
              "text": "Kinemaja është pranë kafenesë."
            },
            {
              "language": "tr",
              "text": "Sinema kafenin yanında."
            }
          ]
        }
