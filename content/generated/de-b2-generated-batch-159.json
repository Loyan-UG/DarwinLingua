      "examples": [
        {
          "baseText": "Biegen Sie nach der Ampel links in die Seitenstraße ein.",
          "translations": [
            {
              "language": "ar",
              "text": "انعطف يسارًا بعد الإشارة إلى الشارع الجانبي."
            },
            {
              "language": "ckb",
              "text": "دوای ترافیک لایتەکە بە چەپدا بۆ شەقامی لاوەکی بسووڕێنەوە."
            },
            {
              "language": "en",
              "text": "After the traffic light, turn left into the side street."
            },
            {
              "language": "fa",
              "text": "بعد از چراغ راهنمایی به چپ و داخل خیابان فرعی بپیچید."
            },
            {
              "language": "kmr",
              "text": "Piştî çiraya trafîkê çepê bizivire nav kolana alî."
            },
            {
              "language": "pl",
              "text": "Za światłami proszę skręcić w lewo w boczną ulicę."
            },
            {
              "language": "ro",
              "text": "După semafor, virați la stânga pe strada laterală."
            },
            {
              "language": "ru",
              "text": "После светофора поверните налево на боковую улицу."
            },
            {
              "language": "sq",
              "text": "Pas semaforit, kthehuni majtas në rrugën anësore."
            },
            {
              "language": "tr",
              "text": "Trafik ışığından sonra sola, yan sokağa dönün."
            }
          ]
        },
        {
          "baseText": "Der Fahrer ist zu früh auf das Werksgelände eingebogen und stand dann vor dem falschen Tor.",
          "translations": [
            {
              "language": "ar",
              "text": "انعطف السائق إلى موقع المصنع مبكرًا جدًا ثم وقف أمام البوابة الخطأ."
            },
            {
              "language": "ckb",
              "text": "شۆفێرەکە زۆر زوو چووە ناو محەوطەی کارگەکە و پاشان لەبەردەم دەروازەی هەڵە وەستا."
            },
            {
              "language": "en",
              "text": "The driver turned into the factory site too early and then ended up at the wrong gate."
            },
            {
              "language": "fa",
              "text": "راننده خیلی زود وارد محوطه کارخانه شد و بعد جلوی درِ اشتباه ایستاد."
            },
            {
              "language": "kmr",
              "text": "Şofêr zû pir ket nav qada fabrîkayê û paşê li ber deriyê şaş rawesta."
            },
            {
              "language": "pl",
              "text": "Kierowca za wcześnie skręcił na teren zakładu i stanął potem przy złej bramie."
            },
            {
              "language": "ro",
              "text": "Șoferul a intrat prea devreme pe terenul fabricii și apoi a ajuns la poarta greșită."
            },
            {
              "language": "ru",
              "text": "Водитель слишком рано свернул на территорию завода и оказался у неправильных ворот."
            },
            {
              "language": "sq",
              "text": "Shoferi hyri shumë herët në territorin e fabrikës dhe pastaj u ndal te porta e gabuar."
            },
            {
              "language": "tr",
              "text": "Sürücü fabrika sahasına çok erken saptı ve sonra yanlış kapının önünde kaldı."
            }
          ]
        }
      ]
    }
