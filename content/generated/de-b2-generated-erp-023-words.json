      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; reason for accepting a returned item"
      ],
      "collocations": [
        {
          "text": "einen Rücknahmegrund auswählen",
          "meaning": "to select a return reason"
        },
        {
          "text": "den Rücknahmegrund dokumentieren",
          "meaning": "to document the return reason"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Rücknahme",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Grund",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "سبب الإرجاع"
        },
        {
          "language": "ckb",
          "text": "هۆکاری وەرگرتنەوە"
        },
        {
          "language": "en",
          "text": "return reason"
        },
        {
          "language": "fa",
          "text": "دلیل مرجوعی؛ علت پس‌گیری"
        },
        {
          "language": "kmr",
          "text": "sedema vegerandinê"
        },
        {
          "language": "pl",
          "text": "powód zwrotu"
        },
        {
          "language": "ro",
          "text": "motiv de retur"
        },
        {
          "language": "ru",
          "text": "причина возврата"
        },
        {
          "language": "sq",
          "text": "arsye kthimi"
        },
        {
          "language": "tr",
          "text": "iade nedeni"
        }
      ],
      "examples": [
        {
          "baseText": "Der Rücknahmegrund muss im ERP angegeben werden, bevor die Gutschrift erstellt wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب إدخال سبب الإرجاع في ERP قبل إنشاء الإشعار الدائن."
            },
            {
              "language": "ckb",
              "text": "پێویستە هۆکاری وەرگرتنەوە لە ERP دا بنووسرێت پێش دروستکردنی قەرزنامە."
            },
            {
              "language": "en",
              "text": "The return reason must be entered in the ERP before the credit note is created."
            },
            {
              "language": "fa",
              "text": "دلیل مرجوعی باید قبل از ایجاد بستانکارنامه در ERP وارد شود."
            },
            {
              "language": "kmr",
              "text": "Sedema vegerandinê divê di ERP de were têketin berî ku nota krediyê were çêkirin."
            },
            {
              "language": "pl",
              "text": "Powód zwrotu musi zostać podany w ERP przed utworzeniem noty kredytowej."
            },
            {
              "language": "ro",
              "text": "Motivul de retur trebuie introdus în ERP înainte de crearea notei de credit."
            },
            {
