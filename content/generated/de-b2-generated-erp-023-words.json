  "entries": [
    {
      "word": "Rückholung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Rückholungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Rück-ho-lung",
      "topics": [
        "warehouse-and-logistics",
        "transport-and-travel",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; pickup or collection of goods from a customer or location"
      ],
      "collocations": [
        {
          "text": "eine Rückholung planen",
          "meaning": "to plan a pickup"
        },
        {
          "text": "eine Rückholung beauftragen",
          "meaning": "to order a pickup"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zurückholen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استرجاع؛ استلام عكسي"
        },
        {
          "language": "ckb",
          "text": "گەڕاندنەوە؛ هێنانەوە"
        },
        {
          "language": "en",
          "text": "pickup; collection; retrieval"
        },
        {
          "language": "fa",
          "text": "بازپس‌گیری؛ جمع‌آوری برگشتی"
        },
        {
          "language": "kmr",
          "text": "vegerandin; anîn-vegerandin"
        },
        {
          "language": "pl",
          "text": "odbiór zwrotny"
        },
        {
          "language": "ro",
          "text": "ridicare retur; recuperare"
        },
        {
          "language": "ru",
          "text": "обратный забор; возвратный вывоз"
        },
        {
          "language": "sq",
          "text": "marrje kthimi"
        },
        {
          "language": "tr",
          "text": "geri alma; iade toplama"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rückholung wird im ERP als eigene Tour für den Spediteur geplant.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تخطيط الاسترجاع في ERP كجولة مستقلة لشركة النقل."
            },
            {
              "language": "ckb",
              "text": "گەڕاندنەوەکە لە ERP دا وەک گەشتێکی جیاواز بۆ کۆمپانیای گواستنەوە پلاندانراوە."
            },
            {
              "language": "en",
              "text": "The pickup is planned in the ERP as a separate route for the carrier."
            },
            {
              "language": "fa",
              "text": "بازپس‌گیری در ERP به عنوان یک مسیر جداگانه برای شرکت حمل‌ونقل برنامه‌ریزی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Vegera malê di ERP de wekî rêyeke cuda ji bo barkêş tê plansazkirin."
            },
            {
              "language": "pl",
              "text": "Odbiór zwrotny jest planowany w ERP jako osobna trasa dla spedytora."
            },
            {
              "language": "ro",
              "text": "Ridicarea returului este planificată în ERP ca rută separată pentru transportator."
            },
            {
              "language": "ru",
              "text": "Обратный забор планируется в ERP как отдельный маршрут для перевозчика."
            },
            {
              "language": "sq",
              "text": "Marrja e kthimit planifikohet në ERP si tur i veçantë për transportuesin."
            },
            {
              "language": "tr",
              "text": "Geri alma ERP’de nakliyeci için ayrı bir tur olarak planlanır."
            }
          ]
        },
        {
          "baseText": "Der Kunde bittet um Rückholung der defekten Ware am Freitag.",
          "translations": [
            {
              "language": "ar",
              "text": "يطلب العميل استرجاع البضاعة المعيبة يوم الجمعة."
            },
            {
              "language": "ckb",
              "text": "کڕیار داوای گەڕاندنەوەی کاڵای تێکشکاو دەکات بۆ ڕۆژی هەینی."
            },
            {
              "language": "en",
              "text": "The customer asks for the defective goods to be picked up on Friday."
            },
            {
              "language": "fa",
              "text": "مشتری درخواست دارد کالای معیوب روز جمعه جمع‌آوری شود."
            },
            {
              "language": "kmr",
              "text": "Mişterî daxwaz dike ku mala xerab roja înê were vegerandin."
            },
            {
              "language": "pl",
              "text": "Klient prosi o odbiór wadliwego towaru w piątek."
            },
            {
              "language": "ro",
              "text": "Clientul solicită ridicarea mărfii defecte vineri."
            },
            {
              "language": "ru",
              "text": "Клиент просит забрать дефектный товар в пятницу."
            },
            {
              "language": "sq",
              "text": "Klienti kërkon marrjen e mallit të dëmtuar të premten."
            },
            {
              "language": "tr",
              "text": "Müşteri arızalı malın cuma günü geri alınmasını istiyor."
            }
          ]
        }
      ]
    },
    {
      "word": "Rücknahme",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Rücknahmen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Rück-nah-me",
      "topics": [
        "sales-and-customers",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; taking back returned goods or accepting a return"
      ],
      "collocations": [
        {
          "text": "eine Rücknahme buchen",
          "meaning": "to post a return acceptance"
        },
        {
          "text": "die Rücknahme verweigern",
          "meaning": "to refuse a return"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zurücknehmen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استلام المرتجع؛ قبول الإرجاع"
        },
        {
          "language": "ckb",
          "text": "وەرگرتنەوە"
        },
        {
          "language": "en",
          "text": "return acceptance; taking back"
        },
        {
          "language": "fa",
          "text": "پذیرش مرجوعی؛ پس‌گرفتن"
        },
        {
          "language": "kmr",
          "text": "qebûlkirina vegerandinê"
        },
        {
          "language": "pl",
          "text": "przyjęcie zwrotu"
        },
        {
          "language": "ro",
          "text": "acceptare retur"
        },
        {
          "language": "ru",
          "text": "прием возврата"
        },
        {
          "language": "sq",
          "text": "pranim kthimi"
        },
        {
          "language": "tr",
          "text": "iade kabulü"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rücknahme wird im ERP erst gebucht, wenn das Lager die Ware geprüft hat.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يتم ترحيل استلام المرتجع في ERP إلا بعد أن يفحص المستودع البضاعة."
            },
            {
              "language": "ckb",
              "text": "وەرگرتنەوە لە ERP دا تەنها کاتێک تۆمار دەکرێت کە کۆگا کاڵاکەی پشکنێت."
            },
            {
              "language": "en",
              "text": "The return acceptance is posted in the ERP only after the warehouse has checked the goods."
            },
            {
              "language": "fa",
              "text": "پذیرش مرجوعی در ERP فقط پس از بررسی کالا توسط انبار ثبت می‌شود."
            },
            {
              "language": "kmr",
              "text": "Qebûlkirina vegerandinê di ERP de tenê piştî kontrolkirina malê ji aliyê embarê ve tê tomarkirin."
            },
            {
              "language": "pl",
              "text": "Przyjęcie zwrotu jest księgowane w ERP dopiero po sprawdzeniu towaru przez magazyn."
            },
            {
              "language": "ro",
              "text": "Acceptarea returului este înregistrată în ERP doar după ce depozitul a verificat marfa."
            },
            {
              "language": "ru",
              "text": "Прием возврата проводится в ERP только после проверки товара складом."
            },
            {
              "language": "sq",
              "text": "Pranimi i kthimit regjistrohet në ERP vetëm pasi magazina ta ketë kontrolluar mallin."
            },
            {
              "language": "tr",
              "text": "İade kabulü ERP’de ancak depo malı kontrol ettikten sonra kaydedilir."
            }
          ]
        },
        {
          "baseText": "Ohne Originalverpackung ist die Rücknahme in diesem Fall schwierig.",
          "translations": [
            {
              "language": "ar",
              "text": "بدون التغليف الأصلي يكون قبول الإرجاع في هذه الحالة صعبًا."
            },
            {
              "language": "ckb",
              "text": "بەبێ پاکەتکردنی ئەسڵی، وەرگرتنەوە لەم حاڵەتەدا قورسە."
            },
            {
              "language": "en",
              "text": "Without the original packaging, accepting the return is difficult in this case."
            },
            {
              "language": "fa",
              "text": "بدون بسته‌بندی اصلی، پذیرش مرجوعی در این مورد دشوار است."
            },
            {
              "language": "kmr",
              "text": "Bê pakêtkirina orîjînal, qebûlkirina vegerandinê di vê rewşê de dijwar e."
            },
            {
              "language": "pl",
              "text": "Bez oryginalnego opakowania przyjęcie zwrotu jest w tym przypadku trudne."
            },
            {
              "language": "ro",
              "text": "Fără ambalajul original, acceptarea returului este dificilă în acest caz."
            },
            {
              "language": "ru",
              "text": "Без оригинальной упаковки прием возврата в этом случае затруднен."
            },
            {
              "language": "sq",
              "text": "Pa paketimin origjinal, pranimi i kthimit në këtë rast është i vështirë."
            },
            {
              "language": "tr",
              "text": "Orijinal ambalaj olmadan bu durumda iade kabulü zor."
            }
          ]
        }
      ]
    },
    {
      "word": "Rücknahmegrund",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Rücknahmegründe",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Rück-nah-me-grund",
      "topics": [
        "sales-and-customers",
        "customer-service",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
