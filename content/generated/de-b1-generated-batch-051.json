  "entries": [
    {
      "word": "entstehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entstehen",
      "pronunciationIpa": null,
      "syllableBreak": "ent-ste-hen",
      "topics": [
        "business-communication",
        "planning-and-projects",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "written",
        "spoken"
      ],
      "contextLabels": [
        "administration",
        "management"
      ],
      "grammarNotes": [
        "irregular verb: entsteht, entstand, ist entstanden"
      ],
      "collocations": [
        {
          "text": "ein Problem entsteht",
          "meaning": "a problem arises"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Entstehung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينشأ؛ يظهر"
        },
        {
          "language": "ckb",
          "text": "دروستبوون؛ سەرهەڵدان"
        },
        {
          "language": "en",
          "text": "to arise; to develop; to come into being"
        },
        {
          "language": "fa",
          "text": "به وجود آمدن؛ ایجاد شدن"
        },
        {
          "language": "kmr",
          "text": "çêbûn; derketin holê"
        },
        {
          "language": "pl",
          "text": "powstać; pojawić się"
        },
        {
          "language": "ro",
          "text": "a apărea; a se forma"
        },
        {
          "language": "ru",
          "text": "возникать; появляться"
        },
        {
          "language": "sq",
          "text": "të lindë; të krijohet"
        },
        {
          "language": "tr",
          "text": "ortaya çıkmak; oluşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bei der Umstellung können kurzfristig technische Probleme entstehen.",
          "translations": [
            {
              "language": "ar",
              "text": "قد تنشأ مشكلات تقنية مؤقتة أثناء التغيير."
            },
            {
              "language": "ckb",
              "text": "لە کاتی گۆڕانکارییەکەدا دەتوانێت کێشەی تەکنیکی کورتخایەن دروست ببێت."
            },
            {
              "language": "en",
              "text": "During the changeover, short-term technical problems may arise."
            },
            {
              "language": "fa",
              "text": "هنگام تغییر سیستم ممکن است مشکلات فنی کوتاه‌مدت ایجاد شود."
            },
            {
              "language": "kmr",
              "text": "Di dema guhertinê de dikarin pirsgirêkên teknîkî yên demkurt çêbibin."
            },
            {
              "language": "pl",
              "text": "Podczas zmiany mogą pojawić się krótkotrwałe problemy techniczne."
            },
            {
              "language": "ro",
              "text": "În timpul tranziției pot apărea probleme tehnice pe termen scurt."
            },
            {
              "language": "ru",
              "text": "Во время перехода могут возникнуть кратковременные технические проблемы."
            },
            {
              "language": "sq",
              "text": "Gjatë kalimit mund të lindin probleme teknike afatshkurtra."
            },
            {
              "language": "tr",
              "text": "Geçiş sırasında kısa süreli teknik sorunlar ortaya çıkabilir."
            }
          ]
        },
        {
          "baseText": "Aus einem kleinen Missverständnis ist ein langer Streit entstanden.",
          "translations": [
            {
              "language": "ar",
              "text": "نشأ خلاف طويل من سوء فهم صغير."
            },
            {
              "language": "ckb",
              "text": "لە تێنەگەیشتنێکی بچووکەوە ناکۆکییەکی درێژ دروست بوو."
            },
            {
              "language": "en",
              "text": "A long argument arose from a small misunderstanding."
            },
            {
              "language": "fa",
              "text": "از یک سوءتفاهم کوچک، یک بحث طولانی به وجود آمد."
            },
            {
              "language": "kmr",
              "text": "Ji şaşgihiştineke biçûk nîqaşeke dirêj çêbû."
            },
            {
              "language": "pl",
              "text": "Z małego nieporozumienia powstał długi spór."
            },
            {
              "language": "ro",
              "text": "Dintr-o mică neînțelegere a apărut o ceartă lungă."
            },
            {
              "language": "ru",
              "text": "Из небольшого недоразумения возник долгий спор."
            },
            {
              "language": "sq",
              "text": "Nga një keqkuptim i vogël lindi një debat i gjatë."
            },
            {
              "language": "tr",
              "text": "Küçük bir yanlış anlaşılmadan uzun bir tartışma çıktı."
            }
          ]
        }
      ]
    },
    {
      "word": "enttäuscht",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ent-täuscht",
      "topics": [
        "social-and-relationships",
        "customer-service",
        "business-communication"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "customer-service",
        "support"
      ],
      "grammarNotes": [
        "adjective; often used with von + dative or über + accusative"
      ],
      "collocations": [
        {
          "text": "von einem Ergebnis enttäuscht sein",
          "meaning": "to be disappointed with a result"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "enttäuschen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Enttäuschung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "محبط؛ خائب الأمل"
        },
        {
          "language": "ckb",
          "text": "نائومێد؛ دڵشکاو"
        },
        {
          "language": "en",
          "text": "disappointed"
        },
        {
          "language": "fa",
          "text": "ناامید؛ مأیوس"
        },
        {
          "language": "kmr",
          "text": "dilşikestî; bêhêvî"
        },
        {
          "language": "pl",
          "text": "rozczarowany"
        },
        {
          "language": "ro",
          "text": "dezamăgit"
        },
        {
          "language": "ru",
          "text": "разочарованный"
        },
        {
          "language": "sq",
          "text": "i zhgënjyer"
        },
        {
          "language": "tr",
          "text": "hayal kırıklığına uğramış"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kunde war enttäuscht, weil die Lieferung wieder zu spät kam.",
          "translations": [
            {
              "language": "ar",
              "text": "كان العميل خائب الأمل لأن التسليم تأخر مرة أخرى."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە نائومێد بوو چونکە گەیاندنەکە جارێکی تر درەنگ هات."
            },
            {
              "language": "en",
              "text": "The customer was disappointed because the delivery was late again."
            },
            {
              "language": "fa",
              "text": "مشتری ناامید شد چون تحویل دوباره دیر رسید."
            },
            {
              "language": "kmr",
              "text": "Xerîdar dilşikestî bû ji ber ku radestkirin dîsa dereng hat."
            },
            {
              "language": "pl",
              "text": "Klient był rozczarowany, ponieważ dostawa znowu się spóźniła."
            },
            {
              "language": "ro",
              "text": "Clientul a fost dezamăgit deoarece livrarea a întârziat din nou."
            },
