  "entries": [
    {
      "word": "Tourzeitfenster",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Tourzeitfenster",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Tour-zeit-fens-ter",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "das noun; specialized ERP/business term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نافذة زمنية للجولة"
        },
        {
          "language": "ckb",
          "text": "کاتی دیاریکراوی گەشت"
        },
        {
          "language": "en",
          "text": "route time window"
        },
        {
          "language": "fa",
          "text": "بازه زمانی مسیر"
        },
        {
          "language": "kmr",
          "text": "pencereya demê ya gerê"
        },
        {
          "language": "pl",
          "text": "okno czasowe trasy"
        },
        {
          "language": "ro",
          "text": "fereastră de timp tură"
        },
        {
          "language": "ru",
          "text": "временное окно маршрута"
        },
        {
          "language": "sq",
          "text": "dritare kohore e turit"
        },
        {
          "language": "tr",
          "text": "tur zaman penceresi"
        }
      ],
      "examples": [
        {
          "baseText": "Das Tourzeitfenster definiert im ERP, wann ein Kunde innerhalb einer geplanten Route beliefert werden darf.",
          "translations": [
            {
              "language": "ar",
              "text": "تحدد نافذة الجولة في ERP متى يمكن تسليم العميل ضمن مسار مخطط."
            },
            {
              "language": "ckb",
              "text": "کاتی دیاریکراوی گەشت لە ERPدا دیاری دەکات کڕیار لە نێوان ڕێڕەوی پلاندانراودا کەی دابین دەکرێت."
            },
            {
              "language": "en",
              "text": "The route time window defines in ERP when a customer may be delivered within a planned route."
            },
            {
              "language": "fa",
              "text": "بازه زمانی مسیر در ERP مشخص می‌کند مشتری در مسیر برنامه‌ریزی‌شده چه زمانی تحویل می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Pencereya demê di ERP de diyar dike xerîdar kengî di gerê de tê dabînkirin."
            },
            {
              "language": "pl",
              "text": "Okno czasowe trasy określa w ERP, kiedy klient może być obsłużony."
            },
            {
              "language": "ro",
              "text": "Fereastra de timp stabilește în ERP când clientul poate fi livrat."
            },
            {
              "language": "ru",
              "text": "Временное окно маршрута определяет в ERP, когда клиент может быть обслужен."
            },
            {
              "language": "sq",
              "text": "Dritarja përcakton në ERP kur klienti mund të furnizohet."
            },
            {
              "language": "tr",
              "text": "Tur zaman penceresi ERP içinde müşterinin rotada ne zaman teslim alacağını belirler."
            }
          ]
        },
        {
          "baseText": "Die Disposition verschob das Tourzeitfenster, weil der Kunde die Rampe erst ab 14 Uhr freigeben konnte.",
          "translations": [
            {
              "language": "ar",
              "text": "نقلت الديسبتش نافذة الجولة لأن العميل لم يستطع فتح الرصيف إلا بعد الثانية."
            },
            {
              "language": "ckb",
              "text": "پلاندانان کاتی گەشتی گواستەوە چونکە کڕیار تەنها دوای کاتژمێر ١٤ ڕامپەکەی ئازاد دەکرد."
            },
            {
              "language": "en",
              "text": "Dispatch moved the route time window because the customer could release the dock only after 2 p.m."
            },
            {
              "language": "fa",
              "text": "برنامه‌ریزی بازه زمانی مسیر را جابه‌جا کرد چون مشتری فقط از ساعت ۱۴ سکو را آزاد می‌کرد."
            },
            {
              "language": "kmr",
              "text": "Plansazî demê guherand ji ber ku xerîdar piştî 14 rampê berdida."
            },
            {
              "language": "pl",
              "text": "Dyspozycja przesunęła okno, bo klient udostępniał rampę dopiero od 14."
            },
            {
              "language": "ro",
              "text": "Dispeceratul a mutat fereastra deoarece clientul elibera rampa doar după ora 14."
            },
            {
              "language": "ru",
              "text": "Диспозиция перенесла окно, потому что клиент освобождал рампу только после 14:00."
            },
            {
              "language": "sq",
              "text": "Dispeçeria e zhvendosi dritaren sepse klienti e lironte rampën pas orës 14."
            },
            {
              "language": "tr",
              "text": "Planlama zaman penceresini kaydırdı, çünkü müşteri rampayı ancak 14:00 sonrası açıyordu."
            }
          ]
        }
      ]
    },
    {
      "word": "TSE",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "TSEs",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "T-S-E",
      "topics": [
        "finance-and-accounting",
        "erp-and-business-systems",
        "law-and-compliance"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "formal",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP/business term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وحدة أمان تقنية"
        },
        {
          "language": "ckb",
          "text": "یەکەی ئاسایشی تەکنیکی"
        },
        {
          "language": "en",
          "text": "technical security device"
        },
        {
          "language": "fa",
          "text": "دستگاه امنیت فنی"
        },
        {
          "language": "kmr",
          "text": "amûra ewlehiyê ya teknîkî"
        },
        {
          "language": "pl",
          "text": "techniczne urządzenie zabezpieczające"
        },
        {
          "language": "ro",
          "text": "dispozitiv tehnic de securitate"
        },
        {
          "language": "ru",
          "text": "техническое средство защиты"
        },
        {
          "language": "sq",
          "text": "pajisje teknike sigurie"
        },
        {
          "language": "tr",
          "text": "teknik güvenlik cihazı"
        }
      ],
      "examples": [
        {
          "baseText": "Die TSE signiert im Kassensystem jede Transaktion, bevor sie an das ERP und die Finanzbuchhaltung übertragen wird.",
          "translations": [
            {
              "language": "ar",
              "text": "توقّع وحدة الأمان التقنية في نظام الصندوق كل معاملة قبل نقلها إلى ERP والمحاسبة."
            },
            {
              "language": "ckb",
              "text": "TSE لە سیستەمی قاسەدا هەر مامەڵەیەک واژۆ دەکات پێش ناردن بۆ ERP و ژمێریاری دارایی."
            },
            {
              "language": "en",
              "text": "The TSE signs every transaction in the POS system before it is transferred to ERP and financial accounting."
            },
            {
              "language": "fa",
              "text": "TSE در سیستم صندوق هر تراکنش را قبل از انتقال به ERP و حسابداری مالی امضا می‌کند."
            },
            {
              "language": "kmr",
              "text": "TSE di pergala kasê de her danûstandinê îmze dike berî şandina bo ERP."
            },
            {
              "language": "pl",
              "text": "TSE podpisuje każdą transakcję w kasie przed przekazaniem do ERP i księgowości."
            },
            {
              "language": "ro",
              "text": "TSE semnează fiecare tranzacție înainte de transferul în ERP și contabilitate."
            },
            {
              "language": "ru",
              "text": "TSE подписывает каждую транзакцию в кассовой системе перед передачей в ERP."
            },
            {
              "language": "sq",
              "text": "TSE nënshkruan çdo transaksion para transferimit në ERP."
            },
            {
              "language": "tr",
              "text": "TSE kasa sisteminde her işlemi ERP ve muhasebeye aktarılmadan imzalar."
            }
          ]
        },
        {
          "baseText": "Nach dem Zertifikatswechsel prüfte die IT, ob die TSE weiterhin fehlerfrei mit dem ERP verbunden war.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تغيير الشهادة فحصت تقنية المعلومات ما إذا كانت وحدة الأمان ما زالت متصلة بـ ERP دون أخطاء."
            },
            {
              "language": "ckb",
              "text": "دوای گۆڕینی بڕوانامە، IT پشکنینی کرد ئایا TSE هێشتا بەبێ هەڵە لەگەڵ ERP پەیوەستە."
            },
            {
              "language": "en",
              "text": "After the certificate change, IT checked whether the TSE was still connected to ERP without errors."
            },
            {
              "language": "fa",
              "text": "بعد از تغییر گواهی، IT بررسی کرد آیا TSE هنوز بدون خطا به ERP وصل است."
            },
            {
              "language": "kmr",
              "text": "Piştî guherandina sertîfîkayê, IT kontrol kir ka TSE hîn bê şaşî bi ERP ve girêdayî ye."
            },
            {
              "language": "pl",
              "text": "Po zmianie certyfikatu IT sprawdziło, czy TSE nadal działa z ERP bez błędów."
            },
            {
              "language": "ro",
              "text": "După schimbarea certificatului, IT a verificat conexiunea TSE cu ERP."
            },
            {
              "language": "ru",
              "text": "После смены сертификата IT проверил, работает ли TSE с ERP без ошибок."
            },
            {
              "language": "sq",
              "text": "Pas ndryshimit të certifikatës, IT kontrolloi lidhjen TSE me ERP."
            },
            {
              "language": "tr",
              "text": "Sertifika değişiminden sonra BT, TSE’nin ERP ile hatasız bağlı olup olmadığını kontrol etti."
            }
          ]
        }
      ]
    },
    {
      "word": "Versandartikelposition",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Versandartikelpositionen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-sand-ar-ti-kel-po-si-ti-on",
      "topics": [
        "warehouse-and-logistics",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP/business term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بند صنف الشحن"
        },
        {
          "language": "ckb",
          "text": "بڕگەی کاڵای ناردن"
        },
        {
          "language": "en",
          "text": "shipping item line item"
        },
        {
          "language": "fa",
          "text": "ردیف کالای ارسال"
        },
        {
          "language": "kmr",
          "text": "hêmana gotara şandinê"
        },
        {
          "language": "pl",
          "text": "pozycja artykułu wysyłkowego"
        },
        {
          "language": "ro",
          "text": "poziție articol expediere"
        },
        {
          "language": "ru",
          "text": "позиция отгрузочного товара"
        },
        {
          "language": "sq",
          "text": "pozicion artikulli dërgese"
        },
        {
          "language": "tr",
          "text": "sevkiyat ürün kalemi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Versandartikelposition enthält im ERP Artikelnummer, Packstück und den zugehörigen Kundenauftrag.",
          "translations": [
            {
              "language": "ar",
              "text": "يتضمن بند صنف الشحن في ERP رقم الصنف والطرد وطلب العميل المرتبط."
            },
            {
              "language": "ckb",
              "text": "بڕگەی کاڵای ناردن لە ERPدا ژمارەی کاڵا، پاکەت و داواکاری کڕیاری پەیوەندیدار لەخۆ دەگرێت."
            },
            {
              "language": "en",
              "text": "The shipping item line item contains item number, package, and related customer order in ERP."
            },
            {
              "language": "fa",
              "text": "ردیف کالای ارسال در ERP شامل شماره کالا، بسته و سفارش مشتری مربوطه است."
            },
            {
              "language": "kmr",
              "text": "Hêmana şandinê di ERP de hejmara gotar, pakêt û fermanê xerîdar dihewîne."
            },
            {
              "language": "pl",
              "text": "Pozycja artykułu wysyłkowego zawiera w ERP numer, paczkę i zamówienie klienta."
            },
            {
              "language": "ro",
              "text": "Poziția conține în ERP numărul articolului, coletul și comanda clientului."
            },
            {
              "language": "ru",
              "text": "Позиция отгрузочного товара содержит номер, грузовое место и заказ клиента."
            },
            {
              "language": "sq",
              "text": "Pozicioni përmban numrin, paketën dhe porosinë e klientit në ERP."
            },
            {
              "language": "tr",
              "text": "Sevkiyat ürün kalemi ERP içinde ürün numarası, paket ve müşteri siparişini içerir."
            }
          ]
        },
        {
          "baseText": "Der Versand sperrte die Versandartikelposition, weil das Etikett nicht mit der Seriennummer übereinstimmte.",
          "translations": [
            {
              "language": "ar",
              "text": "حظر الشحن بند الصنف لأن الملصق لم يطابق الرقم التسلسلي."
            },
            {
              "language": "ckb",
              "text": "ناردن بڕگەی کاڵاکەی قفڵ کرد چونکە لیبڵەکە لەگەڵ ژمارەی زنجیرەیی نەدەگونجا."
            },
            {
              "language": "en",
