  "entries": [
    {
      "word": "austrinken",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "austrinken",
      "pronunciationIpa": null,
      "syllableBreak": "aus-trin-ken",
      "topics": [
        "everyday-life",
        "shopping-and-services",
        "healthcare-and-appointments"
      ],
      "usageLabels": [
        "spoken"
      ],
      "contextLabels": [
        "customer-service",
        "healthcare"
      ],
      "grammarNotes": [
        "separable verb",
        "means to finish drinking something"
      ],
      "collocations": [
        {
          "text": "den Kaffee austrinken",
          "meaning": "to finish drinking the coffee"
        },
        {
          "text": "ein Glas Wasser austrinken",
          "meaning": "to drink a glass of water completely"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "trinken",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يشرب حتى النهاية؛ ينهي الشراب"
        },
        {
          "language": "ckb",
          "text": "خواردنەوە تەواوکردن"
        },
        {
          "language": "en",
          "text": "to finish drinking"
        },
        {
          "language": "fa",
          "text": "نوشیدن تا آخر؛ تمام کردن نوشیدنی"
        },
        {
          "language": "kmr",
          "text": "vexwarinê qedandin"
        },
        {
          "language": "pl",
          "text": "wypić do końca"
        },
        {
          "language": "ro",
          "text": "a bea până la capăt"
        },
        {
          "language": "ru",
          "text": "допить"
        },
        {
          "language": "sq",
          "text": "ta pish deri në fund"
        },
        {
          "language": "tr",
          "text": "içip bitirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Trinken Sie bitte Ihren Kaffee aus, bevor wir in den Besprechungsraum gehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إنهاء قهوتكم قبل أن نذهب إلى غرفة الاجتماعات."
            },
            {
              "language": "ckb",
              "text": "تکایە قاوەکەتان تەواو بخۆنەوە پێش ئەوەی بچینە ژووری کۆبوونەوە."
            },
            {
              "language": "en",
              "text": "Please finish your coffee before we go to the meeting room."
            },
            {
              "language": "fa",
              "text": "لطفاً قهوه‌تان را تمام کنید قبل از اینکه به اتاق جلسه برویم."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe qehweya xwe biqedînin berî ku em biçin odeya civînê."
            },
            {
              "language": "pl",
              "text": "Proszę dopić kawę, zanim pójdziemy do sali konferencyjnej."
            },
            {
              "language": "ro",
              "text": "Vă rog să vă terminați cafeaua înainte să mergem în sala de ședințe."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, допейте кофе, прежде чем мы пойдём в переговорную."
            },
            {
              "language": "sq",
              "text": "Ju lutem përfundoni kafenë para se të shkojmë në dhomën e takimeve."
            },
            {
              "language": "tr",
              "text": "Toplantı odasına gitmeden önce lütfen kahvenizi bitirin."
            }
          ]
        },
        {
          "baseText": "Nach dem Sport sollte sie die Flasche Wasser langsam austrinken.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الرياضة ينبغي أن تشرب زجاجة الماء ببطء حتى النهاية."
            },
            {
              "language": "ckb",
              "text": "دوای وەرزش باشە بوتڵی ئاوەکە بە هێواشی تەواو بخواتەوە."
            },
            {
              "language": "en",
              "text": "After exercising, she should slowly finish the bottle of water."
            },
            {
              "language": "fa",
              "text": "بعد از ورزش بهتر است بطری آب را آرام تا آخر بنوشد."
            },
            {
              "language": "kmr",
              "text": "Piştî werzîşê divê ew şûşeya avê hêdî hêdî biqedîne."
            },
            {
              "language": "pl",
              "text": "Po sporcie powinna powoli wypić butelkę wody do końca."
            },
            {
              "language": "ro",
              "text": "După sport, ar trebui să termine încet sticla de apă."
            },
            {
              "language": "ru",
              "text": "После спорта ей следует медленно допить бутылку воды."
            },
            {
              "language": "sq",
              "text": "Pas sportit, ajo duhet ta pijë ngadalë deri në fund shishen e ujit."
            },
            {
              "language": "tr",
              "text": "Spordan sonra su şişesini yavaşça bitirmeli."
            }
          ]
        }
      ]
    },
    {
      "word": "die Auswahl",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Auswahlen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Aus-wahl",
      "topics": [
        "shopping-and-services",
        "sales-and-customers",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "business"
      ],
      "contextLabels": [
        "sales",
        "customer-service",
        "hr"
      ],
      "grammarNotes": [
        "feminine noun",
        "means selection or choice; plural is possible but less common"
      ],
      "collocations": [
        {
          "text": "eine große Auswahl",
          "meaning": "a large selection"
        },
        {
          "text": "zur Auswahl stehen",
          "meaning": "to be available for selection"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "auswählen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اختيار؛ تشكيلة؛ مجموعة خيارات"
        },
        {
          "language": "ckb",
          "text": "هەڵبژاردن؛ کۆمەڵە هەڵبژاردە"
        },
        {
          "language": "en",
          "text": "selection; choice"
        },
        {
          "language": "fa",
          "text": "انتخاب؛ مجموعه گزینه‌ها"
        },
        {
          "language": "kmr",
          "text": "hilbijartin; vebijêrk"
        },
        {
          "language": "pl",
          "text": "wybór; asortyment"
        },
        {
          "language": "ro",
          "text": "selecție; alegere"
        },
        {
          "language": "ru",
          "text": "выбор; ассортимент"
        },
        {
          "language": "sq",
          "text": "zgjedhje; përzgjedhje"
        },
        {
          "language": "tr",
          "text": "seçim; seçenekler"
        }
      ],
      "examples": [
        {
          "baseText": "Im Online-Shop gibt es eine große Auswahl an Ersatzteilen.",
          "translations": [
            {
              "language": "ar",
              "text": "يوجد في المتجر الإلكتروني تشكيلة كبيرة من قطع الغيار."
            },
            {
              "language": "ckb",
              "text": "لە فرۆشگای ئۆنلاینەکەدا هەڵبژاردنێکی گەورە لە پارچەی یەدەک هەیە."
            },
            {
              "language": "en",
              "text": "The online shop has a large selection of spare parts."
            },
            {
              "language": "fa",
              "text": "در فروشگاه آنلاین انتخاب بزرگی از قطعات یدکی وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Di firoşgeha online de hilbijartineke mezin ji parçeyên cîgir heye."
            },
            {
              "language": "pl",
              "text": "W sklepie internetowym jest duży wybór części zamiennych."
            },
            {
              "language": "ro",
              "text": "În magazinul online există o selecție mare de piese de schimb."
            },
            {
              "language": "ru",
              "text": "В интернет-магазине большой выбор запасных частей."
            },
            {
              "language": "sq",
              "text": "Në dyqanin online ka një përzgjedhje të madhe pjesësh këmbimi."
            },
            {
              "language": "tr",
              "text": "Çevrimiçi mağazada geniş bir yedek parça seçeneği var."
            }
          ]
        },
        {
          "baseText": "Für das Mittagessen stehen heute drei Gerichte zur Auswahl.",
          "translations": [
            {
              "language": "ar",
              "text": "للغداء توجد اليوم ثلاثة أطباق للاختيار."
            },
            {
              "language": "ckb",
              "text": "بۆ نانی نیوەڕۆ ئەمڕۆ سێ خواردن بۆ هەڵبژاردن هەیە."
            },
            {
              "language": "en",
              "text": "For lunch today, three dishes are available to choose from."
            },
            {
              "language": "fa",
              "text": "برای ناهار امروز سه غذا برای انتخاب وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Ji bo firavînê îro sê xwarin ji bo hilbijartinê hene."
            },
            {
              "language": "pl",
              "text": "Na obiad są dziś do wyboru trzy dania."
            },
            {
              "language": "ro",
              "text": "Pentru prânz sunt astăzi trei feluri de mâncare la alegere."
            },
            {
              "language": "ru",
              "text": "Сегодня на обед на выбор три блюда."
            },
            {
              "language": "sq",
              "text": "Për drekë sot ka tre gjellë për zgjedhje."
            },
            {
              "language": "tr",
              "text": "Bugün öğle yemeği için üç yemek seçeneği var."
            }
          ]
        }
      ]
    },
