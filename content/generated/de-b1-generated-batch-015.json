  "entries": [
    {
      "word": "aufbleiben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufbleiben",
      "pronunciationIpa": null,
      "syllableBreak": "auf-blei-ben",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "healthcare-and-appointments"
      ],
      "usageLabels": [
        "spoken"
      ],
      "contextLabels": [
        "hr",
        "healthcare"
      ],
      "grammarNotes": [
        "separable verb",
        "means to stay awake or stay open"
      ],
      "collocations": [
        {
          "text": "lange aufbleiben",
          "meaning": "to stay up late"
        },
        {
          "text": "das Fenster bleibt auf",
          "meaning": "the window stays open"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bleiben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يبقى مستيقظًا؛ يبقى مفتوحًا"
        },
        {
          "language": "ckb",
          "text": "بێخەو مانەوە؛ کراوە مانەوە"
        },
        {
          "language": "en",
          "text": "to stay up; to stay open"
        },
        {
          "language": "fa",
          "text": "بیدار ماندن؛ باز ماندن"
        },
        {
          "language": "kmr",
          "text": "hişyar man; vekirî man"
        },
        {
          "language": "pl",
          "text": "nie spać; zostać otwartym"
        },
        {
          "language": "ro",
          "text": "a sta treaz; a rămâne deschis"
        },
        {
          "language": "ru",
          "text": "не ложиться спать; оставаться открытым"
        },
        {
          "language": "sq",
          "text": "të rrish zgjuar; të mbetet hapur"
        },
        {
          "language": "tr",
          "text": "geç yatmak; açık kalmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich musste gestern lange aufbleiben, weil der Monatsbericht fertig werden musste.",
          "translations": [
            {
              "language": "ar",
              "text": "اضطررت أمس إلى البقاء مستيقظًا طويلًا لأن تقرير الشهر كان يجب أن يجهز."
            },
            {
              "language": "ckb",
              "text": "دوێنێ ناچار بووم زۆر بێخەو بم، چونکە راپۆرتی مانگانە دەبوو تەواو بکرێت."
            },
            {
              "language": "en",
              "text": "I had to stay up late yesterday because the monthly report had to be finished."
            },
            {
              "language": "fa",
              "text": "دیروز مجبور شدم تا دیر وقت بیدار بمانم، چون گزارش ماهانه باید تمام می‌شد."
            },
            {
              "language": "kmr",
              "text": "Ez duh neçar bûm dereng hişyar bim, ji ber ku rapora mehane diviya biqede."
            },
            {
              "language": "pl",
              "text": "Wczoraj musiałem długo nie spać, bo raport miesięczny musiał być gotowy."
            },
            {
              "language": "ro",
              "text": "Ieri a trebuit să stau treaz până târziu, pentru că raportul lunar trebuia terminat."
            },
            {
              "language": "ru",
              "text": "Вчера мне пришлось долго не ложиться, потому что месячный отчёт нужно было закончить."
            },
            {
              "language": "sq",
              "text": "Dje më duhej të rrija zgjuar deri vonë, sepse raporti mujor duhej përfunduar."
            },
            {
              "language": "tr",
              "text": "Dün aylık raporun bitmesi gerektiği için geç saate kadar uyanık kalmak zorunda kaldım."
            }
          ]
        },
        {
          "baseText": "Das Kind darf heute etwas länger aufbleiben, weil morgen keine Schule ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن للطفل اليوم أن يبقى مستيقظًا قليلًا أكثر لأن غدًا لا توجد مدرسة."
            },
            {
              "language": "ckb",
              "text": "منداڵەکە ئەمڕۆ دەتوانێت کەمێک درەنگتر بێخەو بمێنێتەوە، چونکە سبەی قوتابخانە نییە."
            },
            {
              "language": "en",
              "text": "The child may stay up a little longer today because there is no school tomorrow."
            },
            {
              "language": "fa",
              "text": "بچه امروز اجازه دارد کمی بیشتر بیدار بماند، چون فردا مدرسه نیست."
            },
            {
              "language": "kmr",
