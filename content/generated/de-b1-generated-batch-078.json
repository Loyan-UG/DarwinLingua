  "entries": [
    {
      "word": "die Initiative",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Initiativen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "I-ni-ti-a-ti-ve",
      "topics": [
        "work-and-jobs",
        "planning-and-projects",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; an organized action or first step to improve something"
      ],
      "collocations": [
        {
          "text": "eine Initiative starten",
          "meaning": "to start an initiative"
        },
        {
          "text": "eine Initiative unterstützen",
          "meaning": "to support an initiative"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "initiieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "initiativ",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مبادرة"
        },
        {
          "language": "ckb",
          "text": "دەستپێشخەری؛ ئینیشیاتڤ"
        },
        {
          "language": "en",
          "text": "initiative"
        },
        {
          "language": "fa",
          "text": "ابتکار؛ طرح"
        },
        {
          "language": "kmr",
          "text": "destpêşxerî; însiyatîf"
        },
        {
          "language": "pl",
          "text": "inicjatywa"
        },
        {
          "language": "ro",
          "text": "inițiativă"
        },
        {
          "language": "ru",
          "text": "инициатива"
        },
        {
          "language": "sq",
          "text": "nismë; iniciativë"
        },
        {
          "language": "tr",
          "text": "girişim; inisiyatif"
        }
      ],
      "examples": [
        {
          "baseText": "Das Team startet eine Initiative, um die internen Abläufe zu verbessern.",
          "translations": [
            {
              "language": "ar",
              "text": "يبدأ الفريق مبادرة لتحسين الإجراءات الداخلية."
            },
            {
              "language": "ckb",
              "text": "تیمەکە دەستپێشخەرییەک دەست پێ دەکات بۆ باشترکردنی پرۆسە ناوخۆییەکان."
            },
            {
              "language": "en",
              "text": "The team is starting an initiative to improve internal processes."
            },
            {
              "language": "fa",
              "text": "تیم یک ابتکار را برای بهبود فرایندهای داخلی شروع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Tîm însiyatîfekê dest pê dike da ku pêvajoyên hundirîn çêtir bike."
            },
            {
              "language": "pl",
              "text": "Zespół rozpoczyna inicjatywę, aby usprawnić wewnętrzne procesy."
            },
            {
              "language": "ro",
              "text": "Echipa începe o inițiativă pentru a îmbunătăți procesele interne."
            },
            {
              "language": "ru",
              "text": "Команда запускает инициативу, чтобы улучшить внутренние процессы."
            },
            {
              "language": "sq",
              "text": "Ekipi nis një iniciativë për të përmirësuar proceset e brendshme."
            },
            {
              "language": "tr",
              "text": "Ekip, iç süreçleri iyileştirmek için bir girişim başlatıyor."
            }
          ]
        },
        {
          "baseText": "Viele Nachbarn unterstützen die Initiative für mehr Grün im Viertel.",
          "translations": [
            {
              "language": "ar",
              "text": "يدعم كثير من الجيران المبادرة من أجل مزيد من المساحات الخضراء في الحي."
            },
            {
              "language": "ckb",
              "text": "زۆر دراوسێ پشتگیری لە دەستپێشخەریی زیاترکردنی سەوزایی لە گەڕەکەکە دەکەن."
            },
            {
              "language": "en",
              "text": "Many neighbors support the initiative for more green space in the neighborhood."
            },
            {
              "language": "fa",
              "text": "بسیاری از همسایه‌ها از ابتکار برای فضای سبز بیشتر در محله حمایت می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Gelek cîran piştgirî didin însiyatîfa ji bo keskahiya zêdetir li taxê."
            },
            {
              "language": "pl",
              "text": "Wielu sąsiadów wspiera inicjatywę na rzecz większej ilości zieleni w dzielnicy."
            },
            {
              "language": "ro",
              "text": "Mulți vecini susțin inițiativa pentru mai mult spațiu verde în cartier."
            },
            {
              "language": "ru",
              "text": "Многие соседи поддерживают инициативу за больше зелени в районе."
            },
            {
              "language": "sq",
              "text": "Shumë fqinj mbështesin nismën për më shumë gjelbërim në lagje."
            },
            {
              "language": "tr",
              "text": "Birçok komşu mahallede daha fazla yeşil alan için girişimi destekliyor."
            }
          ]
        }
      ]
    },
    {
      "word": "insgesamt",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ins-ge-samt",
      "topics": [
