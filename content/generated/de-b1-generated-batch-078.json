        "business-communication",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb; means in total or overall"
      ],
      "collocations": [
        {
          "text": "insgesamt zehn Personen",
          "meaning": "ten people in total"
        },
        {
          "text": "insgesamt zufrieden sein",
          "meaning": "to be satisfied overall"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gesamt",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Gesamtsumme",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إجمالاً؛ بشكل عام"
        },
        {
          "language": "ckb",
          "text": "بە گشتی؛ کۆی گشتی"
        },
        {
          "language": "en",
          "text": "in total; overall"
        },
        {
          "language": "fa",
          "text": "در مجموع؛ به طور کلی"
        },
        {
          "language": "kmr",
          "text": "bi giştî; tevahî"
        },
        {
          "language": "pl",
          "text": "łącznie; ogółem"
        },
        {
          "language": "ro",
          "text": "în total; per ansamblu"
        },
        {
          "language": "ru",
          "text": "всего; в целом"
        },
        {
          "language": "sq",
          "text": "gjithsej; në përgjithësi"
        },
        {
          "language": "tr",
          "text": "toplamda; genel olarak"
        }
      ],
      "examples": [
        {
          "baseText": "Insgesamt haben sich 48 Personen für die Schulung angemeldet.",
          "translations": [
            {
              "language": "ar",
              "text": "سجل في التدريب 48 شخصاً إجمالاً."
            },
            {
              "language": "ckb",
              "text": "بە گشتی ٤٨ کەس بۆ ڕاهێنانەکە تۆمار بوون."
            },
            {
              "language": "en",
              "text": "A total of 48 people registered for the training."
            },
            {
              "language": "fa",
              "text": "در مجموع ۴۸ نفر برای آموزش ثبت‌نام کرده‌اند."
            },
            {
              "language": "kmr",
              "text": "Bi tevahî 48 kes ji bo perwerdeyê xwe tomar kirine."
            },
            {
              "language": "pl",
              "text": "Łącznie 48 osób zapisało się na szkolenie."
            },
            {
              "language": "ro",
              "text": "În total, 48 de persoane s-au înscris la instruire."
            },
            {
              "language": "ru",
              "text": "Всего на обучение зарегистрировались 48 человек."
            },
            {
              "language": "sq",
              "text": "Gjithsej 48 persona janë regjistruar për trajnimin."
            },
            {
              "language": "tr",
              "text": "Eğitime toplam 48 kişi kaydoldu."
            }
          ]
        },
        {
          "baseText": "Die Wohnung ist klein, aber insgesamt sehr gemütlich.",
          "translations": [
            {
              "language": "ar",
              "text": "الشقة صغيرة، لكنها بشكل عام مريحة جداً."
            },
            {
              "language": "ckb",
              "text": "شوقەکە بچووکە، بەڵام بە گشتی زۆر خۆش و ئارامە."
            },
            {
              "language": "en",
              "text": "The apartment is small, but overall very cozy."
            },
            {
              "language": "fa",
              "text": "آپارتمان کوچک است، اما در مجموع بسیار دنج است."
            },
            {
              "language": "kmr",
              "text": "Apartman biçûk e, lê bi giştî gelek rehet e."
            },
            {
              "language": "pl",
              "text": "Mieszkanie jest małe, ale ogólnie bardzo przytulne."
            },
            {
              "language": "ro",
              "text": "Apartamentul este mic, dar per ansamblu foarte confortabil."
            },
            {
              "language": "ru",
              "text": "Квартира маленькая, но в целом очень уютная."
            },
            {
              "language": "sq",
              "text": "Apartamenti është i vogël, por në përgjithësi shumë komod."
            },
            {
              "language": "tr",
              "text": "Daire küçük, ama genel olarak çok rahat."
            }
          ]
        }
      ]
    },
