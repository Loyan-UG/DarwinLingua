    {
      "word": "die Methodik",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Methodiken",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Me-tho-dik",
      "topics": [
        "advanced-analysis",
        "education-and-training",
        "data-and-reporting"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Methodik offenlegen",
          "meaning": "to disclose the methodology"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Methode",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "methodisch",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "المنهجية"
        },
        {
          "language": "ckb",
          "text": "میتۆدۆلۆژیا؛ شێوازی کار"
        },
        {
          "language": "en",
          "text": "methodology"
        },
        {
          "language": "fa",
          "text": "روش‌شناسی؛ شیوه کار"
        },
        {
          "language": "kmr",
          "text": "metodîk; rêbaza xebatê"
        },
        {
          "language": "pl",
          "text": "metodyka; metodologia"
        },
        {
          "language": "ro",
          "text": "metodologie; metodică"
        },
        {
          "language": "ru",
          "text": "методика; методология"
        },
        {
          "language": "sq",
          "text": "metodologji"
        },
        {
          "language": "tr",
          "text": "metodoloji; yöntem"
        }
      ],
      "examples": [
        {
          "baseText": "Die Methodik der Studie wurde im Anhang detailliert beschrieben.",
          "translations": [
            {
              "language": "ar",
              "text": "وُصفت منهجية الدراسة بالتفصيل في الملحق."
            },
            {
              "language": "ckb",
              "text": "میتۆدۆلۆژیای توێژینەوەکە بە وردی لە پاشکۆدا باس کرا."
            },
            {
              "language": "en",
              "text": "The methodology of the study was described in detail in the appendix."
            },
            {
              "language": "fa",
              "text": "روش‌شناسی مطالعه در پیوست به‌طور دقیق توضیح داده شد."
            },
            {
              "language": "kmr",
              "text": "Metodîka lêkolînê di pêvekê de bi hûrgilî hate vegotin."
            },
            {
              "language": "pl",
              "text": "Metodyka badania została szczegółowo opisana w załączniku."
            },
            {
              "language": "ro",
              "text": "Metodologia studiului a fost descrisă detaliat în anexă."
            },
            {
              "language": "ru",
              "text": "Методика исследования была подробно описана в приложении."
            },
            {
              "language": "sq",
              "text": "Metodologjia e studimit u përshkrua me hollësi në shtojcë."
            },
            {
              "language": "tr",
              "text": "Çalışmanın metodolojisi ekte ayrıntılı biçimde açıklandı."
            }
          ]
        },
        {
          "baseText": "Für die interne Auswertung müssen wir dieselbe Methodik verwenden wie im Vorjahr.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة إلى التقييم الداخلي يجب أن نستخدم المنهجية نفسها كما في العام الماضي."
            },
            {
              "language": "ckb",
              "text": "بۆ هەڵسەنگاندنی ناوخۆیی دەبێت هەمان میتۆدۆلۆژیا بەکاربهێنین وەک ساڵی ڕابردوو."
            },
            {
              "language": "en",
              "text": "For the internal evaluation, we must use the same methodology as last year."
            },
            {
              "language": "fa",
              "text": "برای ارزیابی داخلی باید همان روش‌شناسی سال گذشته را به کار ببریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo nirxandina hundirîn divê em heman metodîkê wek sala borî bikar bînin."
            },
            {
              "language": "pl",
              "text": "Do wewnętrznej analizy musimy użyć tej samej metodyki co w poprzednim roku."
            },
            {
              "language": "ro",
              "text": "Pentru evaluarea internă trebuie să folosim aceeași metodologie ca anul trecut."
            },
            {
              "language": "ru",
              "text": "Для внутренней оценки мы должны использовать ту же методику, что и в прошлом году."
            },
            {
              "language": "sq",
              "text": "Për vlerësimin e brendshëm duhet të përdorim të njëjtën metodologji si vitin e kaluar."
            },
            {
              "language": "tr",
              "text": "İç değerlendirme için geçen yılkiyle aynı metodolojiyi kullanmalıyız."
            }
          ]
        }
      ]
    },
    {
      "word": "methodisch",
