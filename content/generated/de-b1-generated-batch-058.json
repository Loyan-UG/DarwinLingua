      ],
      "grammarNotes": [
        "feminine noun; public health insurance context in Germany"
      ],
      "collocations": [
        {
          "text": "in der Familienversicherung mitversichert sein",
          "meaning": "to be co-insured under family insurance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Familie",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Versicherung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تأمين عائلي"
        },
        {
          "language": "ckb",
          "text": "بیمەی خێزان"
        },
        {
          "language": "en",
          "text": "family insurance"
        },
        {
          "language": "fa",
          "text": "بیمه خانوادگی"
        },
        {
          "language": "kmr",
          "text": "bîmeya malbatê"
        },
        {
          "language": "pl",
          "text": "ubezpieczenie rodzinne"
        },
        {
          "language": "ro",
          "text": "asigurare de familie"
        },
        {
          "language": "ru",
          "text": "семейное страхование"
        },
        {
          "language": "sq",
          "text": "sigurim familjar"
        },
        {
          "language": "tr",
          "text": "aile sigortası"
        }
      ],
      "examples": [
        {
          "baseText": "Studierende können unter bestimmten Bedingungen in der Familienversicherung bleiben.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن للطلاب البقاء في التأمين العائلي بشروط معينة."
            },
            {
              "language": "ckb",
              "text": "خوێندکاران دەتوانن لە ژێر هەندێک مەرجدا لە بیمەی خێزاندا بمێننەوە."
            },
            {
              "language": "en",
              "text": "Students can remain in family insurance under certain conditions."
            },
            {
              "language": "fa",
              "text": "دانشجویان تحت شرایط خاصی می‌توانند در بیمه خانوادگی بمانند."
            },
            {
              "language": "kmr",
              "text": "Xwendekar dikarin di bin hin mercan de di bîmeya malbatê de bimînin."
            },
            {
              "language": "pl",
              "text": "Studenci mogą pod pewnymi warunkami pozostać w ubezpieczeniu rodzinnym."
            },
            {
              "language": "ro",
              "text": "Studenții pot rămâne în asigurarea de familie în anumite condiții."
            },
            {
              "language": "ru",
              "text": "Студенты могут при определенных условиях оставаться в семейном страховании."
            },
            {
              "language": "sq",
              "text": "Studentët mund të mbeten në sigurimin familjar në kushte të caktuara."
            },
            {
              "language": "tr",
              "text": "Öğrenciler belirli koşullarda aile sigortasında kalabilir."
            }
          ]
        },
        {
          "baseText": "Die Krankenkasse braucht einen Nachweis für die Familienversicherung.",
          "translations": [
            {
              "language": "ar",
              "text": "تحتاج شركة التأمين الصحي إلى إثبات للتأمين العائلي."
            },
            {
              "language": "ckb",
              "text": "سندوقی بیمەی تەندروستی پێویستی بە بەڵگە بۆ بیمەی خێزان هەیە."
            },
            {
              "language": "en",
              "text": "The health insurance provider needs proof for family insurance."
            },
            {
              "language": "fa",
              "text": "بیمه درمانی برای بیمه خانوادگی به مدرک نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Saziya bîmeya tenduristiyê ji bo bîmeya malbatê belge hewce dike."
            },
            {
              "language": "pl",
              "text": "Kasa chorych potrzebuje dowodu do ubezpieczenia rodzinnego."
            },
            {
              "language": "ro",
              "text": "Casa de asigurări de sănătate are nevoie de o dovadă pentru asigurarea de familie."
            },
            {
              "language": "ru",
              "text": "Больничной кассе нужно подтверждение для семейного страхования."
            },
            {
              "language": "sq",
              "text": "Sigurimi shëndetësor ka nevojë për dëshmi për sigurimin familjar."
            },
            {
              "language": "tr",
              "text": "Sağlık sigortası aile sigortası için kanıt istiyor."
            }
          ]
        }
      ]
    },
