      "examples": [
        {
          "baseText": "Viele Leute warten am Bahnhof.",
          "translations": [
            {
              "language": "ar",
              "text": "كثير من الناس ينتظرون في محطة القطار."
            },
            {
              "language": "ckb",
              "text": "زۆر خەڵک لە وێستگەی شەمەندەفەر چاوەڕێ دەکەن."
            },
            {
              "language": "en",
              "text": "Many people are waiting at the train station."
            },
            {
              "language": "fa",
              "text": "افراد زیادی در ایستگاه قطار منتظرند."
            },
            {
              "language": "kmr",
              "text": "Gelek kes li stasyona trênê li bendê ne."
            },
            {
              "language": "pl",
              "text": "Wielu ludzi czeka na dworcu."
            },
            {
              "language": "ro",
              "text": "Mulți oameni așteaptă la gară."
            },
            {
              "language": "ru",
              "text": "Много людей ждет на вокзале."
            },
            {
              "language": "sq",
              "text": "Shumë njerëz po presin në stacionin e trenit."
            },
            {
              "language": "tr",
              "text": "Tren istasyonunda birçok insan bekliyor."
            }
          ]
        },
        {
          "baseText": "Die Leute im Kurs sind nett.",
          "translations": [
            {
              "language": "ar",
              "text": "الناس في الدورة لطفاء."
            },
            {
              "language": "ckb",
              "text": "خەڵکی کۆرسەکە میهرەبانن."
            },
            {
              "language": "en",
              "text": "The people in the course are nice."
            },
            {
              "language": "fa",
              "text": "افراد کلاس مهربان هستند."
            },
            {
              "language": "kmr",
              "text": "Kesên di kursê de xweş in."
            },
            {
              "language": "pl",
              "text": "Ludzie na kursie są mili."
            },
            {
              "language": "ro",
              "text": "Oamenii de la curs sunt drăguți."
            },
            {
              "language": "ru",
              "text": "Люди на курсе приятные."
