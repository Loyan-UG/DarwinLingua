      "collocations": [
        {
          "text": "einen Unterschied machen",
          "meaning": "to make a difference"
        },
        {
          "text": "der wichtigste Unterschied",
          "meaning": "the most important difference"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "unterscheiden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فرق؛ اختلاف"
        },
        {
          "language": "ckb",
          "text": "جیاوازی"
        },
        {
          "language": "en",
          "text": "difference"
        },
        {
          "language": "fa",
          "text": "تفاوت؛ فرق"
        },
        {
          "language": "kmr",
          "text": "cudahî"
        },
        {
          "language": "pl",
          "text": "różnica"
        },
        {
          "language": "ro",
          "text": "diferență"
        },
        {
          "language": "ru",
          "text": "разница; отличие"
        },
        {
          "language": "sq",
          "text": "ndryshim; dallim"
        },
        {
          "language": "tr",
          "text": "fark"
        }
      ],
      "examples": [
        {
          "baseText": "Der wichtigste Unterschied zwischen den Angeboten ist die Vertragslaufzeit.",
          "translations": [
            {
              "language": "ar",
              "text": "أهم فرق بين العروض هو مدة العقد."
            },
            {
              "language": "ckb",
              "text": "گرنگترین جیاوازی نێوان پێشنیارەکان ماوەی گرێبەستەکەیە."
            },
            {
              "language": "en",
              "text": "The most important difference between the offers is the contract duration."
            },
            {
              "language": "fa",
              "text": "مهم‌ترین تفاوت بین پیشنهادها مدت قرارداد است."
            },
            {
              "language": "kmr",
              "text": "Cudahîya herî girîng di navbera pêşniyaran de dirêjahiya peymanê ye."
            },
            {
              "language": "pl",
              "text": "Najważniejsza różnica między ofertami to czas trwania umowy."
            },
            {
              "language": "ro",
              "text": "Cea mai importantă diferență dintre oferte este durata contractului."
            },
            {
              "language": "ru",
              "text": "Самое важное отличие между предложениями — срок договора."
            },
            {
              "language": "sq",
              "text": "Dallimi më i rëndësishëm mes ofertave është kohëzgjatja e kontratës."
            },
            {
              "language": "tr",
              "text": "Teklifler arasındaki en önemli fark sözleşme süresidir."
            }
          ]
        },
        {
          "baseText": "Schon eine kleine Änderung kann im Alltag einen großen Unterschied machen.",
          "translations": [
            {
              "language": "ar",
