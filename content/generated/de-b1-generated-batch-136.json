        "formal",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: unterscheidet, unterschied, hat unterschieden; sich unterscheiden von"
      ],
      "collocations": [
        {
          "text": "zwischen zwei Optionen unterscheiden",
          "meaning": "to distinguish between two options"
        },
        {
          "text": "sich deutlich unterscheiden",
          "meaning": "to differ clearly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Unterschied",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يميز؛ يفرق؛ يختلف"
        },
        {
          "language": "ckb",
          "text": "جیاکردنەوە؛ جیاواز بوون"
        },
        {
          "language": "en",
          "text": "to distinguish; to differ"
        },
        {
          "language": "fa",
          "text": "تشخیص دادن؛ فرق گذاشتن؛ متفاوت بودن"
        },
        {
          "language": "kmr",
          "text": "cuda kirin; cuda bûn"
        },
        {
          "language": "pl",
          "text": "rozróżniać; różnić się"
        },
        {
          "language": "ro",
          "text": "a deosebi; a se diferenția"
        },
        {
          "language": "ru",
          "text": "различать; отличаться"
        },
        {
          "language": "sq",
          "text": "të dallosh; të ndryshosh"
        },
        {
          "language": "tr",
          "text": "ayırt etmek; farklı olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Man muss zwischen einem Fehler und einer neuen Anforderung unterscheiden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب التمييز بين خطأ ومتطلب جديد."
            },
            {
              "language": "ckb",
              "text": "دەبێت جیاوازی بکەیت لە نێوان هەڵەیەک و داواکارییەکی نوێدا."
            },
            {
              "language": "en",
              "text": "You have to distinguish between a bug and a new requirement."
            },
            {
              "language": "fa",
              "text": "باید بین یک خطا و یک نیازمندی جدید تفاوت قائل شد."
            },
            {
              "language": "kmr",
              "text": "Divê mirov di navbera şaşiyekê û daxwazeke nû de cuda bike."
            },
            {
              "language": "pl",
              "text": "Trzeba rozróżnić błąd od nowego wymagania."
            },
            {
              "language": "ro",
              "text": "Trebuie să facem diferența între o eroare și o cerință nouă."
            },
            {
              "language": "ru",
              "text": "Нужно различать ошибку и новое требование."
            },
            {
              "language": "sq",
              "text": "Duhet të dallosh mes një gabimi dhe një kërkese të re."
            },
            {
              "language": "tr",
              "text": "Bir hata ile yeni bir gereksinimi ayırt etmek gerekir."
            }
          ]
        },
        {
          "baseText": "Die beiden Kurse unterscheiden sich vor allem im Preis und in der Dauer.",
          "translations": [
            {
              "language": "ar",
              "text": "تختلف الدورتان خصوصًا في السعر والمدة."
            },
            {
              "language": "ckb",
              "text": "هەردوو کۆرسەکە بە تایبەتی لە نرخ و ماوەدا جیاوازن."
            },
            {
              "language": "en",
              "text": "The two courses differ mainly in price and duration."
            },
            {
              "language": "fa",
              "text": "این دو دوره بیشتر از نظر قیمت و مدت زمان تفاوت دارند."
            },
            {
              "language": "kmr",
              "text": "Her du kurs bi taybetî di biha û demê de cuda ne."
            },
            {
              "language": "pl",
              "text": "Te dwa kursy różnią się przede wszystkim ceną i czasem trwania."
            },
            {
              "language": "ro",
              "text": "Cele două cursuri se diferențiază mai ales prin preț și durată."
            },
            {
              "language": "ru",
              "text": "Эти два курса отличаются прежде всего ценой и длительностью."
            },
            {
              "language": "sq",
              "text": "Dy kurset ndryshojnë kryesisht në çmim dhe kohëzgjatje."
            },
            {
              "language": "tr",
              "text": "İki kurs özellikle fiyat ve süre bakımından farklıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "der Unterschied",
