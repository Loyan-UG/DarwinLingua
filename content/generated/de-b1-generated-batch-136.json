  "entries": [
    {
      "word": "unternehmen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "unternehmen",
      "pronunciationIpa": null,
      "syllableBreak": "un-ter-neh-men",
      "topics": [
        "planning-and-projects",
        "business-communication",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: unternimmt, unternahm, hat unternommen"
      ],
      "collocations": [
        {
          "text": "etwas unternehmen",
          "meaning": "to do something or take action"
        },
        {
          "text": "Schritte unternehmen",
          "meaning": "to take steps"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Unternehmen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفعل؛ يتخذ إجراءً؛ يقوم بنشاط"
        },
        {
          "language": "ckb",
          "text": "کردن؛ هەنگاو نان؛ چالاکی کردن"
        },
        {
          "language": "en",
          "text": "to undertake; to do; to take action"
        },
        {
          "language": "fa",
          "text": "انجام دادن؛ اقدام کردن"
        },
        {
          "language": "kmr",
          "text": "kirin; gav avêtin; dest bi kar kirin"
        },
        {
          "language": "pl",
          "text": "podjąć; robić; przedsięwziąć"
        },
        {
          "language": "ro",
          "text": "a întreprinde; a face; a lua măsuri"
        },
        {
          "language": "ru",
          "text": "предпринимать; делать"
        },
        {
          "language": "sq",
          "text": "të ndërmarrësh; të bësh"
        },
        {
          "language": "tr",
          "text": "girişmek; yapmak; önlem almak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir müssen etwas unternehmen, wenn die Lieferungen weiter zu spät kommen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن نتخذ إجراءً إذا استمرت الشحنات في الوصول متأخرة."
            },
            {
              "language": "ckb",
              "text": "ئەگەر گەیاندنەکان بەردەوام درەنگ بگەن، دەبێت هەنگاوێک بنێین."
            },
            {
              "language": "en",
              "text": "We need to take action if the deliveries continue to arrive late."
            },
            {
              "language": "fa",
              "text": "اگر تحویل‌ها همچنان دیر برسند، باید اقدامی انجام دهیم."
            },
            {
              "language": "kmr",
              "text": "Heke radestkirin her tim dereng bigihêjin, divê em tiştekî bikin."
            },
            {
              "language": "pl",
              "text": "Musimy coś zrobić, jeśli dostawy nadal będą przychodzić za późno."
            },
            {
              "language": "ro",
              "text": "Trebuie să luăm măsuri dacă livrările continuă să întârzie."
            },
            {
              "language": "ru",
              "text": "Нам нужно что-то предпринять, если поставки продолжат приходить с опозданием."
            },
            {
              "language": "sq",
              "text": "Duhet të ndërmarrim diçka nëse dërgesat vazhdojnë të vijnë me vonesë."
            },
            {
              "language": "tr",
              "text": "Teslimatlar gecikmeye devam ederse bir şey yapmamız gerekiyor."
            }
          ]
        },
        {
          "baseText": "Am Wochenende möchten wir mit den Kindern etwas draußen unternehmen.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع نريد أن نقوم بنشاط في الخارج مع الأطفال."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا دەتەوێت لەگەڵ منداڵەکان شتێک لە دەرەوە بکەین."
            },
            {
              "language": "en",
              "text": "At the weekend, we want to do something outside with the children."
            },
            {
              "language": "fa",
              "text": "آخر هفته می‌خواهیم با بچه‌ها بیرون کاری انجام دهیم."
            },
            {
              "language": "kmr",
              "text": "Dawiya hefteyê em dixwazin bi zarokan re li derve tiştekî bikin."
            },
            {
              "language": "pl",
              "text": "W weekend chcemy zrobić coś na zewnątrz z dziećmi."
            },
            {
              "language": "ro",
              "text": "În weekend vrem să facem ceva afară cu copiii."
            },
            {
              "language": "ru",
              "text": "На выходных мы хотим что-нибудь сделать на улице с детьми."
            },
            {
              "language": "sq",
              "text": "Në fundjavë duam të bëjmë diçka jashtë me fëmijët."
            },
            {
              "language": "tr",
              "text": "Hafta sonu çocuklarla dışarıda bir şey yapmak istiyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "unterscheiden",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
