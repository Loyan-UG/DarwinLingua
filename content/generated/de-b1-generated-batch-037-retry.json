      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يربط؛ يُلزم"
        },
        {
          "language": "ckb",
          "text": "بەستن؛ پابەند کردن"
        },
        {
          "language": "en",
          "text": "to bind; to tie; to commit"
        },
        {
          "language": "fa",
          "text": "بستن؛ متعهد کردن"
        },
        {
          "language": "kmr",
          "text": "girêdan; pabend kirin"
        },
        {
          "language": "pl",
          "text": "wiązać; zobowiązywać"
        },
        {
          "language": "ro",
          "text": "a lega; a obliga"
        },
        {
          "language": "ru",
          "text": "связывать; обязывать"
        },
        {
          "language": "sq",
          "text": "të lidhësh; të detyrosh"
        },
        {
          "language": "tr",
          "text": "bağlamak; yükümlü kılmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Vertrag bindet beide Seiten für mindestens ein Jahr.",
          "translations": [
            {
              "language": "ar",
              "text": "يلزم العقد الطرفين لمدة سنة على الأقل."
            },
            {
              "language": "ckb",
              "text": "گرێبەستەکە هەردوو لا بۆ لانیکەم یەک ساڵ پابەند دەکات."
            },
            {
              "language": "en",
              "text": "The contract binds both sides for at least one year."
            },
            {
              "language": "fa",
              "text": "قرارداد هر دو طرف را حداقل برای یک سال متعهد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Peyman her du aliyan herî kêm salekê pabend dike."
            },
            {
              "language": "pl",
              "text": "Umowa wiąże obie strony przez co najmniej rok."
            },
            {
              "language": "ro",
              "text": "Contractul obligă ambele părți pentru cel puțin un an."
            },
            {
              "language": "ru",
              "text": "Договор связывает обе стороны минимум на один год."
            },
            {
              "language": "sq",
              "text": "Kontrata i lidh të dyja palët për të paktën një vit."
            },
            {
              "language": "tr",
              "text": "Sözleşme iki tarafı en az bir yıl bağlar."
            }
          ]
        },
        {
          "baseText": "Guter Service hilft, Kunden an das Unternehmen zu binden.",
          "translations": [
            {
              "language": "ar",
              "text": "تساعد الخدمة الجيدة على ربط العملاء بالشركة."
            },
            {
              "language": "ckb",
              "text": "خزمەتگوزاریی باش یارمەتی دەدات کڕیاران بە کۆمپانیاوە ببەسترێن."
            },
            {
              "language": "en",
              "text": "Good service helps retain customers for the company."
            },
            {
              "language": "fa",
              "text": "خدمات خوب کمک می‌کند مشتریان به شرکت وفادار بمانند."
            },
            {
              "language": "kmr",
              "text": "Xizmeta baş alîkar e ku xerîdar bi şirketê ve bên girêdan."
            },
            {
              "language": "pl",
              "text": "Dobra obsługa pomaga związać klientów z firmą."
            },
            {
              "language": "ro",
              "text": "Serviciul bun ajută la fidelizarea clienților față de firmă."
            },
            {
              "language": "ru",
              "text": "Хороший сервис помогает удерживать клиентов компании."
            },
            {
              "language": "sq",
              "text": "Shërbimi i mirë ndihmon në lidhjen e klientëve me kompaninë."
            },
            {
              "language": "tr",
              "text": "İyi hizmet, müşterileri şirkete bağlamaya yardımcı olur."
            }
          ]
        }
      ]
    }
