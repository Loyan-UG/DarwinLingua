            {
              "language": "ru",
              "text": "Курс начинается в восемь часов."
            },
            {
              "language": "sq",
              "text": "Kursi fillon në orën tetë."
            },
            {
              "language": "tr",
              "text": "Kurs saat sekizde başlıyor."
            }
          ]
        },
        {
          "baseText": "Wir gehen um den Park.",
          "translations": [
            {
              "language": "ar",
              "text": "نحن نمشي حول الحديقة."
            },
            {
              "language": "ckb",
              "text": "لە دەوری پارکەکە دەڕۆین."
            },
            {
              "language": "en",
              "text": "We walk around the park."
            },
            {
              "language": "fa",
              "text": "دور پارک راه می‌رویم."
            },
            {
              "language": "kmr",
              "text": "Em li derdora parkê dimeşin."
            },
            {
              "language": "pl",
              "text": "Idziemy wokół parku."
            },
            {
              "language": "ro",
              "text": "Mergem în jurul parcului."
            },
            {
              "language": "ru",
              "text": "Мы идём вокруг парка."
