            {
              "language": "en",
              "text": "The course starts at eight o’clock."
            },
            {
              "language": "fa",
              "text": "کلاس ساعت هشت شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kurs saet heştê dest pê dike."
            },
            {
              "language": "pl",
              "text": "Kurs zaczyna się o ósmej."
            },
            {
              "language": "ro",
