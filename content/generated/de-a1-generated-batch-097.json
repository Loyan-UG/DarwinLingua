      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "في كل مكان"
        },
        {
          "language": "ckb",
          "text": "هەموو شوێنێک"
        },
        {
          "language": "en",
          "text": "everywhere"
        },
        {
          "language": "fa",
          "text": "همه‌جا"
        },
        {
          "language": "kmr",
          "text": "li her derê"
        },
        {
          "language": "pl",
          "text": "wszędzie"
        },
        {
          "language": "ro",
          "text": "peste tot"
        },
        {
          "language": "ru",
          "text": "везде; повсюду"
        },
        {
          "language": "sq",
          "text": "kudo"
        },
        {
          "language": "tr",
          "text": "her yerde"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe überall gesucht.",
          "translations": [
            {
              "language": "ar",
              "text": "لقد بحثت في كل مكان."
            },
            {
              "language": "ckb",
              "text": "لە هەموو شوێنێک گەڕام."
            },
            {
              "language": "en",
              "text": "I looked everywhere."
            },
            {
              "language": "fa",
              "text": "همه‌جا را گشتم."
            },
            {
              "language": "kmr",
              "text": "Min li her derê lêgeriya."
            },
            {
              "language": "pl",
              "text": "Szukałem wszędzie."
            },
            {
              "language": "ro",
              "text": "Am căutat peste tot."
            },
            {
              "language": "ru",
              "text": "Я искал везде."
            },
            {
              "language": "sq",
              "text": "Kam kërkuar kudo."
            },
            {
              "language": "tr",
              "text": "Her yerde aradım."
            }
          ]
        },
        {
          "baseText": "In der Stadt gibt es überall Cafés.",
          "translations": [
            {
              "language": "ar",
              "text": "في المدينة توجد مقاهٍ في كل مكان."
            },
            {
              "language": "ckb",
              "text": "لە شارەکەدا لە هەموو شوێنێک کافێ هەیە."
            },
            {
              "language": "en",
              "text": "There are cafés everywhere in the city."
            },
            {
              "language": "fa",
              "text": "در شهر همه‌جا کافه هست."
            },
            {
              "language": "kmr",
              "text": "Li bajêr li her derê kafe hene."
            },
            {
              "language": "pl",
              "text": "W mieście wszędzie są kawiarnie."
            },
            {
              "language": "ro",
              "text": "În oraș sunt cafenele peste tot."
            },
            {
              "language": "ru",
              "text": "В городе повсюду есть кафе."
            },
            {
              "language": "sq",
              "text": "Në qytet ka kafene kudo."
            },
            {
              "language": "tr",
              "text": "Şehirde her yerde kafeler var."
            }
          ]
        }
      ]
    },
