  "entries": [
    {
      "word": "die Zielerreichung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ziel-er-rei-chung",
      "topics": [
        "management-and-leadership",
        "data-and-reporting",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "analytics",
        "strategy"
      ],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "die Zielerreichung messen",
          "meaning": "to measure goal achievement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Ziel",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "erreichen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تحقيق الهدف"
        },
        {
          "language": "ckb",
          "text": "گەیشتن بە ئامانج"
        },
        {
          "language": "en",
          "text": "goal achievement"
        },
        {
          "language": "fa",
          "text": "دستیابی به هدف"
        },
        {
          "language": "kmr",
          "text": "gihîştina armancê"
        },
        {
          "language": "pl",
          "text": "osiągnięcie celu"
        },
        {
          "language": "ro",
          "text": "atingerea obiectivului"
        },
        {
          "language": "ru",
          "text": "достижение цели"
        },
        {
          "language": "sq",
          "text": "arritje e objektivit"
        },
        {
          "language": "tr",
          "text": "hedefe ulaşma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Zielerreichung wird am Ende des Quartals anhand klarer Kennzahlen geprüft.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم فحص تحقيق الهدف في نهاية الربع بناءً على مؤشرات واضحة."
            },
            {
              "language": "ckb",
              "text": "گەیشتن بە ئامانج لە کۆتایی چارەکەدا بە پێی پێوەرە ڕوونەکان دەپشکنرێت."
            },
            {
              "language": "en",
              "text": "Goal achievement is checked at the end of the quarter using clear metrics."
            },
            {
              "language": "fa",
              "text": "دستیابی به هدف در پایان فصل با شاخص‌های روشن بررسی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Gihîştina armancê li dawiya çaryekê li gorî pîvanên zelal tê kontrolkirin."
            },
            {
              "language": "pl",
              "text": "Osiągnięcie celu jest sprawdzane na koniec kwartału na podstawie jasnych wskaźników."
            },
            {
              "language": "ro",
              "text": "Atingerea obiectivului este verificată la sfârșitul trimestrului pe baza unor indicatori clari."
            },
            {
              "language": "ru",
              "text": "Достижение цели проверяется в конце квартала по четким показателям."
            },
            {
              "language": "sq",
              "text": "Arritja e objektivit kontrollohet në fund të tremujorit me tregues të qartë."
            },
            {
              "language": "tr",
              "text": "Hedefe ulaşma çeyrek sonunda net göstergelerle kontrol edilir."
            }
          ]
        },
        {
          "baseText": "Ohne regelmäßiges Feedback bleibt die Zielerreichung im Team schwer steuerbar.",
          "translations": [
            {
              "language": "ar",
              "text": "بدون ملاحظات منتظمة يبقى تحقيق الهدف في الفريق صعب الإدارة."
            },
            {
              "language": "ckb",
              "text": "بێ فیدباکی بەردەوام، گەیشتن بە ئامانج لە تیمدا بە زەحمەت کۆنترۆڵ دەکرێت."
            },
            {
              "language": "en",
              "text": "Without regular feedback, goal achievement in the team remains difficult to manage."
            },
            {
              "language": "fa",
              "text": "بدون بازخورد منظم، دستیابی به هدف در تیم به سختی قابل مدیریت است."
            },
            {
              "language": "kmr",
              "text": "Bê vegotina rêkûpêk, gihîştina armancê di tîmê de zehmet tê rêvebirin."
            },
            {
              "language": "pl",
              "text": "Bez regularnej informacji zwrotnej osiąganie celów w zespole jest trudne do sterowania."
            },
            {
              "language": "ro",
              "text": "Fără feedback regulat, atingerea obiectivelor în echipă rămâne greu de gestionat."
            },
            {
              "language": "ru",
              "text": "Без регулярной обратной связи достижением целей в команде трудно управлять."
            },
            {
              "language": "sq",
              "text": "Pa feedback të rregullt, arritja e objektivave në ekip mbetet e vështirë për t’u menaxhuar."
            },
            {
              "language": "tr",
              "text": "Düzenli geri bildirim olmadan ekipte hedefe ulaşmayı yönetmek zorlaşır."
            }
          ]
        }
      ]
    },
    {
      "word": "der Zielkonflikt",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Zielkonflikte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ziel-kon-flikt",
      "topics": [
        "management-and-leadership",
        "planning-and-projects",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "strategy",
        "risk"
      ],
      "grammarNotes": [
        "masculine compound noun; plural: Zielkonflikte"
      ],
      "collocations": [
        {
          "text": "einen Zielkonflikt lösen",
          "meaning": "to resolve a conflict between goals"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Ziel",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Konflikt",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تعارض الأهداف"
        },
        {
          "language": "ckb",
          "text": "ناکۆکی ئامانجەکان"
        },
        {
          "language": "en",
          "text": "conflict of objectives"
        },
        {
          "language": "fa",
          "text": "تعارض اهداف"
        },
        {
          "language": "kmr",
          "text": "nakokiya armancan"
        },
        {
          "language": "pl",
          "text": "konflikt celów"
        },
        {
          "language": "ro",
          "text": "conflict de obiective"
        },
        {
          "language": "ru",
          "text": "конфликт целей"
        },
        {
          "language": "sq",
          "text": "konflikt objektivash"
        },
        {
          "language": "tr",
          "text": "hedef çatışması"
        }
      ],
      "examples": [
        {
          "baseText": "Zwischen schneller Lieferung und niedrigen Kosten entsteht oft ein Zielkonflikt.",
          "translations": [
            {
              "language": "ar",
              "text": "غالبًا ما ينشأ تعارض في الأهداف بين التسليم السريع والتكاليف المنخفضة."
            },
            {
              "language": "ckb",
              "text": "لە نێوان گەیاندنی خێرا و تێچووی نزمدا زۆرجار ناکۆکی ئامانج دروست دەبێت."
            },
            {
              "language": "en",
              "text": "A conflict of objectives often arises between fast delivery and low costs."
            },
            {
              "language": "fa",
              "text": "بین تحویل سریع و هزینه پایین اغلب تعارض هدف ایجاد می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di navbera radestkirina lezgîn û lêçûnên nizm de gelek caran nakokiya armancan çêdibe."
            },
            {
              "language": "pl",
              "text": "Między szybką dostawą a niskimi kosztami często powstaje konflikt celów."
            },
            {
              "language": "ro",
              "text": "Între livrarea rapidă și costurile reduse apare adesea un conflict de obiective."
            },
            {
              "language": "ru",
              "text": "Между быстрой поставкой и низкими затратами часто возникает конфликт целей."
            },
            {
              "language": "sq",
              "text": "Mes dorëzimit të shpejtë dhe kostove të ulëta shpesh lind konflikt objektivash."
            },
            {
