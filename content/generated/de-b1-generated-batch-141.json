  "entries": [
    {
      "word": "der Verkehr",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-kehr",
      "topics": [
        "transport-and-travel",
        "everyday-life",
        "public-services"
      ],
      "usageLabels": [
        "everyday",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "starker Verkehr",
          "meaning": "heavy traffic"
        },
        {
          "text": "öffentlicher Verkehr",
          "meaning": "public transport"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verkehrsreich",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "حركة المرور؛ النقل"
        },
        {
          "language": "ckb",
          "text": "هاتوچۆ؛ گواستنەوە"
        },
        {
          "language": "en",
          "text": "traffic; transport"
        },
        {
          "language": "fa",
          "text": "ترافیک؛ رفت‌وآمد"
        },
        {
          "language": "kmr",
          "text": "trafîk; veguhastin"
        },
        {
          "language": "pl",
          "text": "ruch drogowy; transport"
        },
        {
          "language": "ro",
          "text": "trafic; transport"
        },
        {
          "language": "ru",
          "text": "движение; транспорт"
        },
        {
          "language": "sq",
          "text": "trafik; transport"
        },
        {
          "language": "tr",
          "text": "trafik; ulaşım"
        }
      ],
      "examples": [
        {
          "baseText": "Wegen des starken Verkehrs kam der Lieferwagen später an.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب الازدحام الشديد وصلت شاحنة التوصيل متأخرة."
            },
            {
              "language": "ckb",
              "text": "بەهۆی هاتوچۆی زۆرەوە ئۆتۆمبێلی گەیاندن درەنگتر گەیشت."
            },
            {
              "language": "en",
              "text": "Because of heavy traffic, the delivery van arrived later."
            },
            {
              "language": "fa",
              "text": "به دلیل ترافیک سنگین، خودروی تحویل دیرتر رسید."
            },
            {
              "language": "kmr",
              "text": "Ji ber trafîka giran, erebeya radestkirinê derengtir gihîşt."
            },
            {
              "language": "pl",
              "text": "Z powodu dużego ruchu samochód dostawczy przyjechał później."
            },
            {
              "language": "ro",
              "text": "Din cauza traficului intens, mașina de livrare a ajuns mai târziu."
            },
            {
              "language": "ru",
              "text": "Из-за сильного движения фургон доставки прибыл позже."
            },
            {
              "language": "sq",
              "text": "Për shkak të trafikut të rënduar, furgoni i dërgesës mbërriti më vonë."
            },
            {
              "language": "tr",
              "text": "Yoğun trafik nedeniyle teslimat aracı daha geç geldi."
            }
          ]
        },
        {
          "baseText": "Die Stadt möchte den öffentlichen Verkehr zuverlässiger machen.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد المدينة جعل النقل العام أكثر موثوقية."
            },
            {
              "language": "ckb",
              "text": "شارەکە دەیەوێت هاتوچۆی گشتی پشتپێبەستراوتر بکات."
            },
            {
              "language": "en",
              "text": "The city wants to make public transport more reliable."
            },
            {
              "language": "fa",
              "text": "شهر می‌خواهد حمل‌ونقل عمومی را قابل‌اعتمادتر کند."
            },
            {
              "language": "kmr",
              "text": "Bajar dixwaze veguhastina giştî bawerbarتر bike."
            },
            {
              "language": "pl",
              "text": "Miasto chce uczynić transport publiczny bardziej niezawodnym."
            },
            {
              "language": "ro",
              "text": "Orașul vrea să facă transportul public mai fiabil."
            },
            {
              "language": "ru",
              "text": "Город хочет сделать общественный транспорт надежнее."
            },
            {
              "language": "sq",
              "text": "Qyteti dëshiron ta bëjë transportin publik më të besueshëm."
            },
            {
              "language": "tr",
              "text": "Şehir toplu taşımayı daha güvenilir hale getirmek istiyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Verlängerung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Verlängerungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-län-ge-rung",
      "topics": [
        "contracts-and-negotiation",
        "documents-and-administration",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Verlängerung beantragen",
          "meaning": "to request an extension"
        },
        {
          "text": "Verlängerung des Vertrags",
          "meaning": "extension of the contract"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verlängern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تمديد؛ إطالة"
        },
        {
          "language": "ckb",
          "text": "درێژکردنەوە؛ زیادکردنی ماوە"
        },
        {
          "language": "en",
          "text": "extension; prolongation"
        },
        {
          "language": "fa",
          "text": "تمدید؛ طولانی‌کردن"
        },
        {
          "language": "kmr",
          "text": "dirêjkirin; dirêjkirina demê"
        },
        {
          "language": "pl",
          "text": "przedłużenie"
        },
        {
          "language": "ro",
          "text": "prelungire"
        },
        {
          "language": "ru",
          "text": "продление"
        },
        {
          "language": "sq",
          "text": "zgjatje; shtyrje afati"
        },
        {
          "language": "tr",
          "text": "uzatma; süre uzatımı"
        }
      ],
      "examples": [
        {
          "baseText": "Wir beantragen eine Verlängerung der Frist um zwei Wochen.",
          "translations": [
            {
              "language": "ar",
              "text": "نطلب تمديد المهلة لمدة أسبوعين."
            },
            {
              "language": "ckb",
              "text": "داوای درێژکردنەوەی وادەکە بە دوو هەفتە دەکەین."
            },
            {
              "language": "en",
              "text": "We are requesting an extension of the deadline by two weeks."
            },
            {
              "language": "fa",
              "text": "ما درخواست تمدید مهلت به مدت دو هفته می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Em daxwaza dirêjkirina demê bi du hefteyan dikin."
            },
            {
              "language": "pl",
              "text": "Wnioskujemy o przedłużenie terminu o dwa tygodnie."
            },
            {
              "language": "ro",
              "text": "Solicităm prelungirea termenului cu două săptămâni."
            },
            {
              "language": "ru",
              "text": "Мы просим продлить срок на две недели."
            },
            {
              "language": "sq",
              "text": "Kërkojmë zgjatjen e afatit me dy javë."
            },
            {
              "language": "tr",
              "text": "Sürenin iki hafta uzatılmasını talep ediyoruz."
            }
          ]
        },
        {
          "baseText": "Die Verlängerung des Mietvertrags muss schriftlich bestätigt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب تأكيد تمديد عقد الإيجار كتابيًا."
            },
            {
              "language": "ckb",
              "text": "درێژکردنەوەی گرێبەستی کرێ دەبێت بە نووسراوە پشتڕاست بکرێتەوە."
            },
            {
              "language": "en",
              "text": "The extension of the rental contract must be confirmed in writing."
            },
            {
              "language": "fa",
              "text": "تمدید قرارداد اجاره باید کتبی تأیید شود."
            },
            {
              "language": "kmr",
              "text": "Dirêjkirina peymana kirê divê bi nivîskî were piştrastkirin."
            },
            {
              "language": "pl",
              "text": "Przedłużenie umowy najmu musi zostać potwierdzone pisemnie."
            },
            {
              "language": "ro",
              "text": "Prelungirea contractului de închiriere trebuie confirmată în scris."
            },
            {
              "language": "ru",
              "text": "Продление договора аренды должно быть подтверждено письменно."
            },
            {
              "language": "sq",
              "text": "Zgjatja e kontratës së qirasë duhet të konfirmohet me shkrim."
            },
            {
              "language": "tr",
              "text": "Kira sözleşmesinin uzatılması yazılı olarak onaylanmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "verlässlich",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ver-läss-lich",
      "topics": [
        "work-and-jobs",
        "social-and-relationships",
        "customer-service"
      ],
      "usageLabels": [
        "business",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective"
      ],
      "collocations": [
        {
          "text": "ein verlässlicher Partner",
          "meaning": "a reliable partner"
        },
        {
          "text": "verlässliche Informationen",
          "meaning": "reliable information"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sich verlassen auf",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موثوق؛ يمكن الاعتماد عليه"
        },
        {
          "language": "ckb",
          "text": "پشتپێبەستراو؛ دڵنیا"
        },
        {
          "language": "en",
          "text": "reliable; dependable"
        },
        {
          "language": "fa",
          "text": "قابل‌اعتماد؛ مطمئن"
        },
        {
          "language": "kmr",
          "text": "bawerbar; pêbawer"
        },
        {
          "language": "pl",
          "text": "niezawodny; godny zaufania"
        },
        {
          "language": "ro",
          "text": "fiabil; de încredere"
        },
        {
          "language": "ru",
          "text": "надежный"
        },
        {
          "language": "sq",
          "text": "i besueshëm"
        },
        {
          "language": "tr",
          "text": "güvenilir"
        }
      ],
      "examples": [
        {
          "baseText": "Für dieses Projekt brauchen wir einen verlässlichen Lieferanten.",
          "translations": [
            {
              "language": "ar",
              "text": "لهذا المشروع نحتاج إلى مورد موثوق."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم پڕۆژەیە پێویستمان بە دابینکەرێکی پشتپێبەستراو هەیە."
            },
            {
              "language": "en",
              "text": "For this project, we need a reliable supplier."
            },
            {
              "language": "fa",
              "text": "برای این پروژه به یک تأمین‌کننده قابل‌اعتماد نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê projeyê em hewceyê dabînkerekî bawerbar in."
            },
            {
              "language": "pl",
              "text": "Do tego projektu potrzebujemy niezawodnego dostawcy."
            },
            {
              "language": "ro",
              "text": "Pentru acest proiect avem nevoie de un furnizor de încredere."
            },
            {
              "language": "ru",
              "text": "Для этого проекта нам нужен надежный поставщик."
            },
            {
              "language": "sq",
              "text": "Për këtë projekt na duhet një furnizues i besueshëm."
            },
            {
              "language": "tr",
              "text": "Bu proje için güvenilir bir tedarikçiye ihtiyacımız var."
            }
          ]
        },
        {
          "baseText": "Sie ist sehr verlässlich und kommt fast nie zu spät.",
          "translations": [
            {
              "language": "ar",
              "text": "هي موثوقة جدًا ونادرًا ما تتأخر."
            },
            {
              "language": "ckb",
              "text": "ئەو زۆر پشتپێبەستراوە و نزیکەی هەرگیز درەنگ ناکات."
            },
            {
              "language": "en",
              "text": "She is very reliable and almost never arrives late."
            },
            {
              "language": "fa",
              "text": "او بسیار قابل‌اعتماد است و تقریباً هیچ‌وقت دیر نمی‌کند."
            },
