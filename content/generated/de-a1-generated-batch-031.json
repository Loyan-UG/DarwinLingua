        {
          "language": "pl",
          "text": "raz; jeden raz"
        },
        {
          "language": "ro",
          "text": "o dată"
        },
        {
          "language": "ru",
          "text": "один раз"
        },
        {
          "language": "sq",
          "text": "një herë"
        },
        {
          "language": "tr",
          "text": "bir kez; bir defa"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte sagen Sie das noch einmal.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك قل ذلك مرة أخرى."
            },
            {
              "language": "ckb",
              "text": "تکایە ئەوە جارێکی تر بڵێن."
            },
            {
              "language": "en",
              "text": "Please say that one more time."
            },
            {
              "language": "fa",
              "text": "لطفاً آن را یک بار دیگر بگویید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe vê yekê careke din bibêjin."
            },
            {
              "language": "pl",
              "text": "Proszę powiedzieć to jeszcze raz."
            },
            {
              "language": "ro",
              "text": "Vă rog să spuneți asta încă o dată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, скажите это еще раз."
            },
            {
              "language": "sq",
              "text": "Ju lutem thuajeni edhe një herë."
            },
            {
              "language": "tr",
              "text": "Lütfen bunu bir kez daha söyleyin."
            }
          ]
        },
        {
          "baseText": "Ich war einmal in Berlin.",
          "translations": [
            {
              "language": "ar",
              "text": "كنت مرة واحدة في برلين."
            },
            {
              "language": "ckb",
              "text": "من جارێک لە بەرلین بووم."
            },
            {
              "language": "en",
              "text": "I was in Berlin once."
            },
            {
              "language": "fa",
              "text": "من یک بار در برلین بودم."
            },
            {
              "language": "kmr",
              "text": "Ez carekê li Berlînê bûm."
            },
            {
              "language": "pl",
              "text": "Byłem raz w Berlinie."
            },
            {
              "language": "ro",
              "text": "Am fost o dată în Berlin."
            },
            {
              "language": "ru",
              "text": "Я был в Берлине один раз."
            },
            {
              "language": "sq",
              "text": "Kam qenë një herë në Berlin."
            },
            {
              "language": "tr",
              "text": "Bir kez Berlin’de bulundum."
            }
          ]
        }
      ]
    },
