      "meanings": [
        {
          "language": "ar",
          "text": "يحتفل"
        },
        {
          "language": "ckb",
          "text": "جەژن گرتن؛ ئاهەنگ گێڕان"
        },
        {
          "language": "en",
          "text": "to celebrate"
        },
        {
          "language": "fa",
          "text": "جشن گرفتن"
        },
        {
          "language": "kmr",
          "text": "pîrozbahî kirin; şahî kirin"
        },
        {
          "language": "pl",
          "text": "świętować"
        },
        {
          "language": "ro",
          "text": "a sărbători"
        },
        {
          "language": "ru",
          "text": "праздновать"
        },
        {
          "language": "sq",
          "text": "festoj"
        },
        {
          "language": "tr",
          "text": "kutlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir feiern heute Geburtstag.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتفل اليوم بعيد ميلاد."
            },
            {
              "language": "ckb",
              "text": "ئێمە ئەمڕۆ جەژنی لەدایکبوون دەگرین."
            },
            {
              "language": "en",
              "text": "We are celebrating a birthday today."
            },
            {
              "language": "fa",
              "text": "ما امروز تولد جشن می‌گیریم."
            },
            {
              "language": "kmr",
              "text": "Em îro rojbûnê pîroz dikin."
            },
            {
              "language": "pl",
              "text": "Dzisiaj obchodzimy urodziny."
            },
            {
              "language": "ro",
              "text": "Astăzi sărbătorim o zi de naștere."
            },
            {
              "language": "ru",
              "text": "Сегодня мы празднуем день рождения."
            },
            {
              "language": "sq",
              "text": "Sot festojmë ditëlindjen."
            },
            {
              "language": "tr",
              "text": "Bugün doğum günü kutluyoruz."
            }
          ]
        },
        {
          "baseText": "Sie feiert mit ihrer Familie.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تحتفل مع عائلتها."
            },
            {
              "language": "ckb",
              "text": "ئەو لەگەڵ خێزانەکەی ئاهەنگ دەگێڕێت."
            },
            {
              "language": "en",
              "text": "She celebrates with her family."
            },
            {
              "language": "fa",
              "text": "او با خانواده‌اش جشن می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Ew bi malbata xwe re şahî dike."
            },
            {
              "language": "pl",
              "text": "Ona świętuje z rodziną."
            },
            {
              "language": "ro",
              "text": "Ea sărbătorește cu familia ei."
            },
            {
              "language": "ru",
              "text": "Она празднует со своей семьей."
            },
            {
              "language": "sq",
              "text": "Ajo feston me familjen e saj."
            },
            {
              "language": "tr",
              "text": "O ailesiyle kutluyor."
            }
          ]
        }
      ]
