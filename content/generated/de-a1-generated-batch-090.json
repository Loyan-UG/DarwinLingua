        },
        {
          "language": "ru",
          "text": "воскресенье"
        },
        {
          "language": "sq",
          "text": "e diel"
        },
        {
          "language": "tr",
          "text": "pazar"
        }
      ],
      "examples": [
        {
          "baseText": "Am Sonntag habe ich frei.",
          "translations": [
            {
              "language": "ar",
              "text": "يوم الأحد لديّ إجازة."
            },
            {
              "language": "ckb",
              "text": "یەکشەممە پشووەم هەیە."
            },
            {
              "language": "en",
              "text": "I have the day off on Sunday."
            },
            {
              "language": "fa",
              "text": "یکشنبه آزاد هستم."
            },
            {
              "language": "kmr",
              "text": "Yekşemê ez azad im."
            },
            {
              "language": "pl",
              "text": "W niedzielę mam wolne."
            },
            {
              "language": "ro",
              "text": "Duminică sunt liber."
            },
            {
              "language": "ru",
              "text": "В воскресенье у меня выходной."
            },
            {
              "language": "sq",
              "text": "Të dielën jam pushim."
            },
            {
              "language": "tr",
              "text": "Pazar günü izinliyim."
            }
          ]
        },
        {
          "baseText": "Wir besuchen Oma am Sonntag.",
          "translations": [
            {
              "language": "ar",
              "text": "نزور الجدة يوم الأحد."
            },
            {
              "language": "ckb",
              "text": "یەکشەممە سەردانی داپیرە دەکەین."
            },
            {
              "language": "en",
              "text": "We visit grandma on Sunday."
            },
            {
              "language": "fa",
              "text": "ما یکشنبه به دیدن مادربزرگ می‌رویم."
            },
            {
              "language": "kmr",
              "text": "Em yekşemê serdana dapîrê dikin."
            },
            {
              "language": "pl",
              "text": "W niedzielę odwiedzamy babcię."
            },
            {
              "language": "ro",
              "text": "O vizităm pe bunica duminică."
            },
            {
              "language": "ru",
              "text": "Мы навещаем бабушку в воскресенье."
            },
            {
              "language": "sq",
              "text": "Ne vizitojmë gjyshen të dielën."
            },
            {
              "language": "tr",
              "text": "Pazar günü büyükanneyi ziyaret ediyoruz."
            }
          ]
        }
      ]
