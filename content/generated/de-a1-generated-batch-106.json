      "examples": [
        {
          "baseText": "Im Winter ist es kalt.",
          "translations": [
            {
              "language": "ar",
              "text": "في الشتاء يكون الجو باردًا."
            },
            {
              "language": "ckb",
              "text": "لە زستاندا ساردە."
            },
            {
              "language": "en",
              "text": "It is cold in winter."
            },
            {
              "language": "fa",
              "text": "در زمستان هوا سرد است."
            },
            {
              "language": "kmr",
              "text": "Di zivistanê de sar e."
            },
            {
