            }
          ]
        },
        {
          "baseText": "Wir fahren im Winter mit dem Zug.",
          "translations": [
            {
              "language": "ar",
              "text": "نسافر في الشتاء بالقطار."
            },
            {
              "language": "ckb",
              "text": "لە زستاندا بە شەمەندەفەر دەچین."
            },
            {
              "language": "en",
              "text": "We travel by train in winter."
            },
            {
              "language": "fa",
              "text": "در زمستان با قطار سفر می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em di zivistanê de bi trenê diçin."
            },
            {
              "language": "pl",
              "text": "Zimą jedziemy pociągiem."
            },
            {
              "language": "ro",
              "text": "Iarna mergem cu trenul."
            },
            {
              "language": "ru",
              "text": "Зимой мы едем на поезде."
            },
            {
              "language": "sq",
              "text": "Në dimër udhëtojmë me tren."
            },
            {
              "language": "tr",
              "text": "Kışın trenle seyahat ediyoruz."
            }
