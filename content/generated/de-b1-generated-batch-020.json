  "entries": [
    {
      "word": "aushalten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aushalten",
      "pronunciationIpa": null,
      "syllableBreak": "aus-hal-ten",
      "topics": [
        "work-and-jobs",
        "healthcare-and-appointments",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken"
      ],
      "contextLabels": [
        "hr",
        "healthcare",
