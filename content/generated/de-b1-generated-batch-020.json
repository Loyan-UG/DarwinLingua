      ],
      "grammarNotes": [
        "separable verb",
        "means to endure, tolerate, or stand something"
      ],
      "collocations": [
        {
          "text": "Stress aushalten",
          "meaning": "to endure stress"
        },
        {
          "text": "Lärm nicht aushalten",
          "meaning": "not to stand noise"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "halten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتحمل؛ يطيق"
        },
        {
          "language": "ckb",
          "text": "بەرگەگرتن؛ تەحەمولکردن"
        },
        {
          "language": "en",
          "text": "to endure; to tolerate; to stand"
        },
        {
          "language": "fa",
          "text": "تحمل کردن؛ تاب آوردن"
        },
        {
          "language": "kmr",
          "text": "tehemûl kirin; rabûn li hember"
        },
        {
          "language": "pl",
          "text": "wytrzymać; znieść"
        },
        {
          "language": "ro",
          "text": "a suporta; a îndura"
        },
        {
          "language": "ru",
          "text": "выдержать; терпеть"
        },
        {
          "language": "sq",
          "text": "të durosh; të përballosh"
        },
        {
          "language": "tr",
          "text": "dayanmak; katlanmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bei hoher Arbeitsbelastung kann nicht jeder Mitarbeiter den Druck lange aushalten.",
          "translations": [
            {
              "language": "ar",
              "text": "عند عبء عمل كبير لا يستطيع كل موظف تحمل الضغط لفترة طويلة."
            },
            {
              "language": "ckb",
              "text": "لە کاتی قورسایی زۆری کاردا هەموو کارمەندێک ناتوانێت ماوەیەکی درێژ بەرگەی فشار بگرێت."
            },
            {
              "language": "en",
              "text": "With a heavy workload, not every employee can withstand the pressure for long."
            },
            {
              "language": "fa",
              "text": "در فشار کاری زیاد، هر کارمندی نمی‌تواند مدت طولانی فشار را تحمل کند."
            },
            {
              "language": "kmr",
              "text": "Di barê karê giran de ne her karmend dikare demeke dirêj zextê tehemûl bike."
            },
            {
              "language": "pl",
              "text": "Przy dużym obciążeniu pracą nie każdy pracownik długo wytrzyma presję."
            },
            {
              "language": "ro",
              "text": "La un volum mare de muncă, nu fiecare angajat poate suporta presiunea mult timp."
            },
            {
              "language": "ru",
              "text": "При высокой рабочей нагрузке не каждый сотрудник может долго выдерживать давление."
            },
            {
              "language": "sq",
              "text": "Me ngarkesë të madhe pune, jo çdo punonjës mund ta durojë gjatë presionin."
            },
            {
              "language": "tr",
              "text": "Yüksek iş yükünde her çalışan baskıya uzun süre dayanamaz."
            }
          ]
        },
        {
          "baseText": "Ich kann den Lärm in dieser Wohnung kaum noch aushalten.",
          "translations": [
            {
              "language": "ar",
              "text": "لم أعد أستطيع تقريبًا تحمل الضجيج في هذه الشقة."
            },
            {
              "language": "ckb",
              "text": "ئیدی بە زەحمەت بەرگەی ئەم دەنگە لە خانووەکەدا دەگرم."
            },
            {
              "language": "en",
              "text": "I can hardly stand the noise in this apartment anymore."
            },
            {
              "language": "fa",
              "text": "دیگر به‌سختی می‌توانم سر و صدای این آپارتمان را تحمل کنم."
            },
            {
              "language": "kmr",
              "text": "Ez êdî bi zorî dengê vê apartmanê tehemûl dikim."
            },
            {
              "language": "pl",
              "text": "Ledwo mogę już znieść hałas w tym mieszkaniu."
            },
            {
              "language": "ro",
              "text": "Abia mai pot suporta zgomotul din acest apartament."
            },
            {
