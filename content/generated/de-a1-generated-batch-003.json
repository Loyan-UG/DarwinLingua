              "language": "ckb",
              "text": "تەمەن لێرە گرنگ نییە."
            },
            {
              "language": "en",
              "text": "Age is not important here."
            },
            {
              "language": "fa",
              "text": "سن اینجا مهم نیست."
            },
            {
              "language": "kmr",
              "text": "Temen li vir ne girîng e."
            },
            {
              "language": "pl",
              "text": "Wiek nie jest tutaj ważny."
