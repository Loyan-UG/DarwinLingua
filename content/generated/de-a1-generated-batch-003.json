      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إذن؛ إذاً"
        },
        {
          "language": "ckb",
          "text": "کەواتە؛ باشە"
        },
        {
          "language": "en",
          "text": "so; therefore; well then"
        },
        {
          "language": "fa",
          "text": "پس؛ بنابراین"
        },
        {
          "language": "kmr",
          "text": "wisa; ji ber vê yekê"
        },
        {
          "language": "pl",
          "text": "więc; zatem"
        },
        {
          "language": "ro",
          "text": "deci; așadar"
        },
        {
          "language": "ru",
          "text": "итак; значит"
        },
        {
          "language": "sq",
          "text": "pra; atëherë"
        },
        {
          "language": "tr",
          "text": "o halde; yani"
        }
      ],
      "examples": [
        {
          "baseText": "Also, wir beginnen jetzt.",
          "translations": [
            {
              "language": "ar",
              "text": "إذن، نبدأ الآن."
            },
            {
              "language": "ckb",
              "text": "کەواتە، ئێستا دەست پێدەکەین."
            },
            {
              "language": "en",
              "text": "So, we are starting now."
            },
            {
              "language": "fa",
              "text": "پس، الان شروع می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Wisa, em niha dest pê dikin."
            },
            {
              "language": "pl",
              "text": "Więc zaczynamy teraz."
            },
            {
              "language": "ro",
              "text": "Deci, începem acum."
            },
            {
              "language": "ru",
              "text": "Итак, мы начинаем сейчас."
            },
            {
              "language": "sq",
              "text": "Pra, po fillojmë tani."
            },
            {
              "language": "tr",
              "text": "O halde şimdi başlıyoruz."
            }
          ]
        },
        {
          "baseText": "Du bist krank, also bleibst du zu Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "أنت مريض، لذلك تبقى في البيت."
            },
            {
              "language": "ckb",
              "text": "تۆ نەخۆشیت، کەواتە لە ماڵەوە دەمێنیتەوە."
            },
            {
              "language": "en",
              "text": "You are sick, so you stay at home."
            },
            {
              "language": "fa",
              "text": "تو مریضی، پس در خانه می‌مانی."
            },
            {
              "language": "kmr",
              "text": "Tu nexweş î, ji ber vê yekê li malê dimînî."
            },
            {
              "language": "pl",
              "text": "Jesteś chory, więc zostajesz w domu."
            },
            {
              "language": "ro",
              "text": "Ești bolnav, deci rămâi acasă."
            },
            {
              "language": "ru",
              "text": "Ты болен, значит остаешься дома."
            },
            {
              "language": "sq",
              "text": "Je i sëmurë, prandaj rri në shtëpi."
            },
            {
              "language": "tr",
              "text": "Hastasın, o yüzden evde kalıyorsun."
            }
          ]
        }
      ]
    },
