        "adjective; often with mit + dative"
      ],
      "collocations": [
        {
          "text": "mit dem Service zufrieden sein",
          "meaning": "to be satisfied with the service"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zufriedenheit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "راضٍ؛ قانع"
        },
        {
          "language": "ckb",
          "text": "ڕازی؛ دڵخۆش"
        },
        {
          "language": "en",
          "text": "satisfied; pleased"
        },
        {
          "language": "fa",
          "text": "راضی؛ خشنود"
        },
        {
          "language": "kmr",
          "text": "razî; dilxweş"
        },
        {
          "language": "pl",
          "text": "zadowolony"
        },
        {
          "language": "ro",
          "text": "mulțumit"
        },
        {
          "language": "ru",
          "text": "довольный"
        },
        {
          "language": "sq",
          "text": "i kënaqur"
        },
        {
          "language": "tr",
          "text": "memnun"
        }
      ],
      "examples": [
        {
          "baseText": "Sind Sie mit dem Service zufrieden?",
          "translations": [
            {
              "language": "ar",
              "text": "هل أنتم راضون عن الخدمة؟"
            },
            {
              "language": "ckb",
              "text": "ئایا لە خزمەتگوزارییەکە ڕازین؟"
            },
            {
              "language": "en",
              "text": "Are you satisfied with the service?"
            },
            {
              "language": "fa",
              "text": "آیا از خدمات راضی هستید؟"
            },
            {
              "language": "kmr",
              "text": "Ma hûn ji xizmetê razî ne?"
            },
            {
              "language": "pl",
              "text": "Czy są państwo zadowoleni z obsługi?"
            },
            {
              "language": "ro",
              "text": "Sunteți mulțumit de serviciu?"
            },
            {
              "language": "ru",
              "text": "Вы довольны обслуживанием?"
            },
            {
              "language": "sq",
              "text": "A jeni të kënaqur me shërbimin?"
            },
            {
              "language": "tr",
              "text": "Hizmetten memnun musunuz?"
            }
          ]
        },
        {
          "baseText": "Ich bin mit meinem neuen Zimmer sehr zufrieden.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا راضٍ جداً عن غرفتي الجديدة."
            },
            {
              "language": "ckb",
              "text": "من زۆر لە ژوورە نوێیەکەم ڕازیم."
            },
            {
              "language": "en",
              "text": "I am very satisfied with my new room."
            },
            {
              "language": "fa",
              "text": "من از اتاق جدیدم خیلی راضی هستم."
            },
            {
              "language": "kmr",
              "text": "Ez ji odeya xwe ya nû pir razî me."
            },
            {
              "language": "pl",
              "text": "Jestem bardzo zadowolony z mojego nowego pokoju."
            },
            {
              "language": "ro",
              "text": "Sunt foarte mulțumit de noua mea cameră."
            },
            {
              "language": "ru",
              "text": "Я очень доволен своей новой комнатой."
            },
            {
              "language": "sq",
              "text": "Jam shumë i kënaqur me dhomën time të re."
            },
            {
              "language": "tr",
              "text": "Yeni odamdan çok memnunum."
            }
          ]
        }
      ]
    },
