      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أخيراً؛ في النهاية"
        },
        {
          "language": "ckb",
          "text": "لە کۆتاییدا؛ دوا جار"
        },
        {
          "language": "en",
          "text": "last; lastly; most recently"
        },
        {
          "language": "fa",
          "text": "آخر؛ در پایان؛ اخیراً"
        },
        {
          "language": "kmr",
          "text": "dawî; di dawiyê de"
        },
        {
          "language": "pl",
          "text": "na końcu; ostatnio"
        },
        {
          "language": "ro",
          "text": "la final; ultima dată"
        },
        {
          "language": "ru",
          "text": "в конце; в последний раз"
        },
        {
          "language": "sq",
          "text": "së fundi; në fund"
        },
        {
          "language": "tr",
          "text": "son olarak; en son"
        }
      ],
      "examples": [
        {
          "baseText": "Zuletzt unterschreiben Sie bitte hier.",
          "translations": [
            {
              "language": "ar",
              "text": "أخيراً يرجى التوقيع هنا."
            },
            {
              "language": "ckb",
              "text": "لە کۆتاییدا تکایە لێرە واژۆ بکەن."
            },
            {
              "language": "en",
              "text": "Lastly, please sign here."
            },
            {
              "language": "fa",
              "text": "در پایان لطفاً اینجا امضا کنید."
            },
            {
              "language": "kmr",
              "text": "Di dawiyê de ji kerema xwe li vir îmze bikin."
            },
            {
              "language": "pl",
              "text": "Na końcu proszę podpisać tutaj."
            },
            {
              "language": "ro",
              "text": "La final, vă rog să semnați aici."
            },
            {
              "language": "ru",
              "text": "В конце, пожалуйста, подпишите здесь."
            },
            {
              "language": "sq",
              "text": "Në fund, ju lutem nënshkruani këtu."
            },
            {
              "language": "tr",
              "text": "Son olarak lütfen burayı imzalayın."
            }
          ]
        },
        {
          "baseText": "Ich habe ihn zuletzt am Bahnhof gesehen.",
          "translations": [
            {
              "language": "ar",
              "text": "رأيته آخر مرة في محطة القطار."
            },
            {
              "language": "ckb",
              "text": "دوا جار لە وێستگەی شەمەندەفەر بینیم."
            },
            {
              "language": "en",
              "text": "I last saw him at the train station."
            },
            {
              "language": "fa",
              "text": "آخرین بار او را در ایستگاه قطار دیدم."
            },
            {
              "language": "kmr",
              "text": "Min wî dawî car li stasyona trênê dît."
            },
            {
              "language": "pl",
              "text": "Ostatnio widziałem go na dworcu."
            },
            {
              "language": "ro",
              "text": "L-am văzut ultima dată la gară."
            },
            {
              "language": "ru",
              "text": "Я видел его в последний раз на вокзале."
            },
            {
              "language": "sq",
              "text": "E pashë për herë të fundit në stacionin e trenit."
            },
            {
              "language": "tr",
              "text": "Onu en son tren istasyonunda gördüm."
            }
          ]
        }
      ]
    },
