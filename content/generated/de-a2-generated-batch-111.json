        "adverb of order"
      ],
      "collocations": [
        {
          "text": "zuerst bezahlen",
          "meaning": "to pay first"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "erst",
          "relationLabel": "adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أولاً"
        },
        {
          "language": "ckb",
          "text": "سەرەتا"
        },
        {
          "language": "en",
          "text": "first; at first"
        },
        {
          "language": "fa",
          "text": "اول؛ ابتدا"
        },
        {
          "language": "kmr",
          "text": "pêşî; berê"
        },
        {
          "language": "pl",
          "text": "najpierw"
        },
        {
          "language": "ro",
          "text": "mai întâi"
        },
        {
          "language": "ru",
          "text": "сначала"
        },
        {
          "language": "sq",
          "text": "së pari"
        },
        {
          "language": "tr",
          "text": "önce; ilk olarak"
        }
      ],
      "examples": [
        {
          "baseText": "Zuerst füllen Sie bitte das Formular aus.",
          "translations": [
            {
              "language": "ar",
              "text": "أولاً يرجى ملء الاستمارة."
            },
            {
              "language": "ckb",
              "text": "سەرەتا تکایە فۆرمەکە پڕ بکەنەوە."
            },
            {
              "language": "en",
              "text": "First, please fill out the form."
            },
            {
              "language": "fa",
              "text": "اول لطفاً فرم را پر کنید."
            },
            {
              "language": "kmr",
              "text": "Pêşî ji kerema xwe formê tijî bikin."
            },
            {
              "language": "pl",
              "text": "Najpierw proszę wypełnić formularz."
            },
            {
              "language": "ro",
              "text": "Mai întâi vă rog să completați formularul."
            },
            {
              "language": "ru",
              "text": "Сначала, пожалуйста, заполните форму."
            },
            {
              "language": "sq",
              "text": "Së pari, ju lutem plotësoni formularin."
            },
            {
              "language": "tr",
              "text": "Önce lütfen formu doldurun."
            }
          ]
        },
        {
          "baseText": "Wir gehen zuerst zum Schalter und dann zum Gleis.",
          "translations": [
            {
              "language": "ar",
              "text": "نذهب أولاً إلى الشباك ثم إلى الرصيف."
            },
            {
              "language": "ckb",
              "text": "سەرەتا دەچین بۆ پەنجەرەکە و پاشان بۆ سەکۆ."
            },
            {
              "language": "en",
              "text": "We go first to the counter and then to the platform."
            },
            {
              "language": "fa",
              "text": "اول به باجه می‌رویم و بعد به سکو."
            },
            {
              "language": "kmr",
              "text": "Em pêşî diçin gişeyê û paşê platformê."
            },
            {
              "language": "pl",
              "text": "Najpierw idziemy do okienka, a potem na peron."
            },
            {
              "language": "ro",
              "text": "Mergem mai întâi la ghișeu și apoi la peron."
            },
            {
              "language": "ru",
              "text": "Сначала мы идем к стойке, а потом на платформу."
            },
            {
              "language": "sq",
              "text": "Së pari shkojmë te sporteli dhe pastaj te peroni."
            },
            {
              "language": "tr",
              "text": "Önce gişeye, sonra perona gidiyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "zufrieden",
