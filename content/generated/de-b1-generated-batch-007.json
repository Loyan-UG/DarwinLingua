  "entries": [
    {
      "word": "anfordern",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anfordern",
      "pronunciationIpa": null,
      "syllableBreak": "an-for-dern",
      "topics": [
        "documents-and-administration",
        "customer-service",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "documents",
        "customer-service",
        "administration"
      ],
      "grammarNotes": [
        "separable verb",
        "used for requesting documents, information, or support officially"
      ],
      "collocations": [
        {
          "text": "Unterlagen anfordern",
          "meaning": "to request documents"
        },
        {
          "text": "Informationen anfordern",
          "meaning": "to request information"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Anforderung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يطلب رسميًا؛ يطلب إرسال شيء"
        },
        {
          "language": "ckb",
          "text": "بە فەرمی داواکردن؛ داوای ناردنی شتێک کردن"
        },
        {
          "language": "en",
          "text": "to request; to ask for officially"
        },
        {
          "language": "fa",
          "text": "درخواست کردن؛ رسماً طلب کردن"
        },
        {
          "language": "kmr",
          "text": "daxwaz kirin; bi fermî xwestin"
        },
        {
          "language": "pl",
          "text": "zażądać; poprosić oficjalnie"
        },
        {
          "language": "ro",
          "text": "a solicita; a cere oficial"
        },
        {
          "language": "ru",
          "text": "запросить; потребовать"
        },
        {
          "language": "sq",
          "text": "të kërkosh zyrtarisht"
        },
        {
          "language": "tr",
          "text": "talep etmek; resmi olarak istemek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte fordern Sie die fehlenden Unterlagen direkt beim Kunden an.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى طلب المستندات الناقصة مباشرة من العميل."
            },
            {
              "language": "ckb",
              "text": "تکایە بەڵگەنامە کەمەکان راستەوخۆ لە کڕیار داوا بکەن."
            },
            {
              "language": "en",
              "text": "Please request the missing documents directly from the customer."
            },
            {
              "language": "fa",
              "text": "لطفاً مدارک ناقص را مستقیماً از مشتری درخواست کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeyên kêm rasterast ji xerîdar bixwazin."
            },
            {
              "language": "pl",
              "text": "Proszę poprosić klienta bezpośrednio o brakujące dokumenty."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să solicitați documentele lipsă direct de la client."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, запросите недостающие документы напрямую у клиента."
            },
            {
              "language": "sq",
              "text": "Ju lutem kërkojini dokumentet që mungojnë drejtpërdrejt nga klienti."
            },
            {
              "language": "tr",
              "text": "Lütfen eksik belgeleri doğrudan müşteriden talep edin."
            }
          ]
        },
        {
          "baseText": "Über das Portal können Sie jederzeit eine neue Bescheinigung anfordern.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم طلب شهادة جديدة في أي وقت عبر البوابة."
            },
            {
              "language": "ckb",
              "text": "لە ڕێگەی پۆرتاڵەکەوە دەتوانن هەر کات بڕوانامەیەکی نوێ داوا بکەن."
            },
            {
              "language": "en",
              "text": "You can request a new certificate through the portal at any time."
            },
            {
              "language": "fa",
              "text": "از طریق پورتال می‌توانید هر زمان یک گواهی جدید درخواست کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin her dem bi rêya portalê belgeyek nû bixwazin."
            },
            {
              "language": "pl",
              "text": "Przez portal można w każdej chwili zamówić nowe zaświadczenie."
            },
            {
              "language": "ro",
              "text": "Prin portal puteți solicita oricând o adeverință nouă."
            },
            {
              "language": "ru",
              "text": "Через портал вы можете в любое время запросить новую справку."
            },
            {
              "language": "sq",
              "text": "Përmes portalit mund të kërkoni në çdo kohë një vërtetim të ri."
            },
            {
              "language": "tr",
              "text": "Portal üzerinden istediğiniz zaman yeni bir belge talep edebilirsiniz."
            }
          ]
        }
      ]
    },
