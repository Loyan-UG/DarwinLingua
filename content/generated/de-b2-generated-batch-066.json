  "entries": [
    {
      "word": "beitreten",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beitreten",
      "pronunciationIpa": null,
      "syllableBreak": "bei-tre-ten",
      "topics": [
        "meetings-and-presentations",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "spoken"
      ],
      "contextLabels": [
        "meeting",
        "workplace"
      ],
      "meanings": [
        {
          "text": "الانضمام؛ إضافة/التقاء",
          "language": "ar"
        },
        {
          "text": "پەیوەستبوون؛ دەستەوەردان",
          "language": "ckb"
        },
        {
          "text": "to join (a group, team, meeting, committee)",
          "language": "en"
        },
        {
          "text": "پیوستن؛ الحاق شدن",
          "language": "fa"
        },
        {
          "text": "beşdar bûn; tevlî bûn",
          "language": "kmr"
        },
        {
          "text": "dołączać; przystępować",
          "language": "pl"
        },
        {
          "text": "a se alătura; a adera",
          "language": "ro"
        },
        {
          "text": "присоединяться",
          "language": "ru"
        },
        {
          "text": "të bashkangjesh; të përfshihesh",
          "language": "sq"
        },
        {
          "text": "katılmak; dahil olmak",
          "language": "tr"
        }
      ],
      "examples": [
        {
          "baseText": "Fünf neue Entwickler sind gestern dem Projektteam beigetreten.",
          "translations": [
            {
              "text": "پنج برنامه‌نویس جدید دیروز به تیم پروژه پیوستند.",
              "language": "ar"
            },
            {
              "text": "پێنج پەرەپێدەر دوێنەی کۆتایەوە پەیوەندیدا بۆ تیمی پڕۆژە بوون.",
              "language": "ckb"
            },
            {
              "text": "Five new developers joined the project team yesterday.",
              "language": "en"
            },
            {
              "text": "پنج توسعه‌دهنده جدید دیروز به تیم پروژه پیوستند.",
              "language": "fa"
            },
            {
              "text": "Pênj pêşewrên nû do niverokê tevlî tîma projeyê bûn.",
              "language": "kmr"
            },
            {
              "text": "Wczoraj dołączyło do zespołu projektowego pięciu programistów.",
              "language": "pl"
            },
            {
              "text": "Ieri, cinci dezvoltatori noi s-au alăturat echipei de proiect.",
              "language": "ro"
            },
            {
              "text": "Вчера к команде проекта присоединилось пять новых разработчиков.",
              "language": "ru"
            },
            {
              "text": "Pesë zhvillues të rinj iu bashkuan ekipit të projektit dje.",
              "language": "sq"
            },
            {
              "text": "Dün, projeye beş yeni geliştirici katıldı.",
              "language": "tr"
            }
          ]
        },
        {
          "baseText": "Die neue Abteilungsleiterin ist der Qualitätsgruppe beigetreten.",
          "translations": [
            {
              "text": "مديرة القسم الجديدة انضمت إلى مجموعة الجودة.",
              "language": "ar"
            },
            {
              "text": "بەڕێوبەری نوێی بەشەکە پەیوەستبوو بە گروپی کوالێتیەکە.",
              "language": "ckb"
            },
            {
              "text": "The new department head joined the quality group.",
              "language": "en"
            },
            {
              "text": "مدیر جدید بخش به گروه کیفیت پیوست.",
              "language": "fa"
            },
            {
              "text": "Serkarê nû ya beşa beşdarî koma kaliteyê bû.",
              "language": "kmr"
            },
            {
              "text": "Nowa kierowniczka działu dołączyła do zespołu jakości.",
              "language": "pl"
            },
            {
              "text": "Noii șef de departament s-a alăturat echipei de calitate.",
              "language": "ro"
            },
            {
              "text": "Новый руководитель отдела присоединился к группе по качеству.",
              "language": "ru"
            },
            {
              "text": "Kryesore e re e departamentit iu bashkua grupit të cilësisë.",
              "language": "sq"
            },
            {
              "text": "Yeni bölüm yöneticisi kalite ekibine katıldı.",
              "language": "tr"
            }
          ]
        }
      ],
      "grammarNotes": [
        "intransitive verb for joining a group or institution"
      ],
      "collocations": [
        {
          "text": "Dem Team beitreten",
          "meaning": "join a team"
        }
      ]
    },
