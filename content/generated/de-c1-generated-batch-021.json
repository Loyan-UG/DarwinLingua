      ],
      "meanings": [
        {
          "language": "ar",
          "text": "مفاهيمي؛ اصطلاحي"
        },
        {
          "language": "ckb",
          "text": "چەمکی؛ پەیوەندیدار بە دەستەواژە"
        },
        {
          "language": "en",
          "text": "conceptual; terminological"
        },
        {
          "language": "fa",
          "text": "مفهومی؛ اصطلاحی"
        },
        {
          "language": "kmr",
          "text": "têgehî; peyvnasî"
        },
        {
          "language": "pl",
          "text": "pojęciowy; terminologiczny"
        },
        {
          "language": "ro",
          "text": "conceptual; terminologic"
        },
        {
          "language": "ru",
          "text": "понятийный; терминологический"
        },
        {
          "language": "sq",
          "text": "konceptual; terminologjik"
        },
        {
          "language": "tr",
          "text": "kavramsal; terminolojik"
        }
      ],
      "examples": [
        {
          "baseText": "Im Strategiepapier werden operative Risiken und strategische Risiken begrifflich nicht sauber getrennt.",
          "translations": [
            {
              "language": "ar",
              "text": "في ورقة الاستراتيجية لا يتم الفصل مفاهيميًا بدقة بين المخاطر التشغيلية والاستراتيجية."
            },
            {
              "language": "ckb",
              "text": "لە بەڵگەنامەی ستراتیژیدا مەترسییە کارگێڕی و ستراتیژییەکان بە چەمکی بە پاکی جیا نەکراونەتەوە."
            },
            {
