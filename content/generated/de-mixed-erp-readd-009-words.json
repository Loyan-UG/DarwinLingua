      "word": "der Vorgang",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Vorgänge",
      "infinitive": null,
      "syllableBreak": "Vor-gang",
      "topics": [
        "documents-and-administration",
        "erp-and-business-systems",
        "customer-service"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "process"
      ],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "einen Vorgang öffnen",
          "meaning": "to open a case/process"
        },
        {
          "text": "den Vorgang bearbeiten",
          "meaning": "to process the case"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vorgehen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "عملية؛ ملف حالة"
        },
        {
          "language": "ckb",
          "text": "پڕۆسە؛ کەیس"
        },
        {
          "language": "en",
          "text": "process; case; transaction"
        },
        {
          "language": "fa",
          "text": "فرآیند؛ پرونده؛ مورد"
        },
        {
          "language": "kmr",
          "text": "pêvajo; doz"
        },
        {
          "language": "pl",
          "text": "sprawa; proces"
        },
        {
          "language": "ro",
          "text": "procedură; caz"
        },
        {
          "language": "ru",
          "text": "процесс; дело; операция"
        },
        {
          "language": "sq",
          "text": "proces; rast"
        },
        {
          "language": "tr",
          "text": "işlem; süreç; dosya"
        }
      ],
      "examples": [
        {
          "baseText": "Der Vorgang ist im ERP-System noch offen.",
          "translations": [
            {
              "language": "ar",
              "text": "العملية ما زالت مفتوحة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "پڕۆسەکە هێشتا لە سیستەمی ERPدا کراوەیە."
            },
            {
              "language": "en",
              "text": "The case is still open in the ERP system."
            },
            {
              "language": "fa",
              "text": "این مورد هنوز در سیستم ERP باز است."
            },
            {
              "language": "kmr",
              "text": "Doz hîn di pergala ERP de vekirî ye."
            },
            {
              "language": "pl",
              "text": "Sprawa jest nadal otwarta w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Cazul este încă deschis în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Дело все еще открыто в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Rasti është ende i hapur në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "İşlem ERP sisteminde hâlâ açık."
            }
          ]
        },
        {
          "baseText": "Bitte geben Sie mir die Nummer des Vorgangs.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إعطائي رقم العملية."
            },
            {
              "language": "ckb",
              "text": "تکایە ژمارەی پڕۆسەکە پێم بدەن."
            },
            {
              "language": "en",
              "text": "Please give me the case number."
            },
            {
              "language": "fa",
              "text": "لطفاً شماره پرونده را به من بدهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe jimareya dozê bide min."
            },
            {
              "language": "pl",
              "text": "Proszę podać mi numer sprawy."
            },
            {
              "language": "ro",
              "text": "Vă rog să-mi dați numărul cazului."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, дайте мне номер дела."
            },
            {
              "language": "sq",
              "text": "Ju lutem më jepni numrin e rastit."
            },
            {
              "language": "tr",
              "text": "Lütfen bana işlem numarasını verin."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Zahlungsart",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Zahlungsarten",
      "infinitive": null,
      "syllableBreak": "Zah-lungs-art",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "customer-facing"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Zahlungsart auswählen",
          "meaning": "to select a payment type"
        },
        {
          "text": "Zahlungsart ändern",
          "meaning": "to change payment type"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zahlung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Art",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "طريقة الدفع"
        },
        {
          "language": "ckb",
          "text": "جۆری پارەدان"
        },
        {
          "language": "en",
          "text": "payment type; payment method"
        },
        {
          "language": "fa",
          "text": "نوع پرداخت؛ روش پرداخت"
        },
        {
          "language": "kmr",
          "text": "awayê pere dayînê"
        },
        {
          "language": "pl",
          "text": "forma płatności"
        },
        {
          "language": "ro",
          "text": "modalitate de plată"
        },
        {
          "language": "ru",
          "text": "способ оплаты"
        },
        {
          "language": "sq",
          "text": "lloj pagese; mënyrë pagese"
        },
        {
          "language": "tr",
          "text": "ödeme türü; ödeme şekli"
        }
      ],
      "examples": [
        {
          "baseText": "Die Zahlungsart muss vor der Fakturierung im ERP-System gewählt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب اختيار طريقة الدفع في نظام تخطيط موارد المؤسسة قبل إصدار الفاتورة."
            },
            {
              "language": "ckb",
              "text": "جۆری پارەدان پێویستە پێش فاکتورکردن لە سیستەمی ERPدا هەڵبژێردرێت."
            },
            {
              "language": "en",
              "text": "The payment type must be selected in the ERP system before invoicing."
            },
            {
              "language": "fa",
              "text": "نوع پرداخت باید قبل از صدور فاکتور در سیستم ERP انتخاب شود."
            },
            {
              "language": "kmr",
              "text": "Awayê pere dayînê divê berî fatûrekirinê di pergala ERP de were hilbijartin."
            },
            {
              "language": "pl",
              "text": "Forma płatności musi zostać wybrana w systemie ERP przed fakturowaniem."
            },
            {
              "language": "ro",
              "text": "Modalitatea de plată trebuie aleasă în sistemul ERP înainte de facturare."
            },
            {
              "language": "ru",
              "text": "Способ оплаты должен быть выбран в ERP-системе до выставления счета."
            },
            {
              "language": "sq",
              "text": "Lloji i pagesës duhet zgjedhur në sistemin ERP para faturimit."
            },
            {
              "language": "tr",
              "text": "Ödeme türü faturalandırmadan önce ERP sisteminde seçilmelidir."
            }
          ]
        },
        {
          "baseText": "Welche Zahlungsart möchten Sie verwenden: Karte oder Überweisung?",
          "translations": [
            {
              "language": "ar",
              "text": "ما طريقة الدفع التي تريد استخدامها: بطاقة أم تحويل بنكي؟"
            },
            {
              "language": "ckb",
              "text": "دەتەوێت کام جۆری پارەدان بەکاربهێنیت: کارت یان گواستنەوەی بانکی؟"
            },
            {
              "language": "en",
              "text": "Which payment method would you like to use: card or bank transfer?"
            },
            {
              "language": "fa",
              "text": "از کدام روش پرداخت می‌خواهید استفاده کنید: کارت یا حواله بانکی؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dixwazin kîjan awayê pere dayînê bikar bînin: kart an veguhastina bankî?"
            },
            {
              "language": "pl",
              "text": "Jakiej formy płatności chce Pan/Pani użyć: kartą czy przelewem?"
            },
            {
              "language": "ro",
              "text": "Ce modalitate de plată doriți să folosiți: card sau transfer bancar?"
            },
            {
              "language": "ru",
              "text": "Какой способ оплаты вы хотите использовать: карту или банковский перевод?"
            },
            {
              "language": "sq",
              "text": "Cilën mënyrë pagese dëshironi të përdorni: kartë apo transfertë bankare?"
            },
            {
              "language": "tr",
              "text": "Hangi ödeme yöntemini kullanmak istersiniz: kart mı banka havalesi mi?"
            }
          ]
        }
      ]
    },
