  "entries": [
    {
      "word": "unterbringen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "unterbringen",
      "pronunciationIpa": null,
      "syllableBreak": "un-ter-brin-gen",
      "topics": [
        "housing-and-real-estate",
        "transport-and-travel",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; bringt unter, brachte unter, hat untergebracht"
      ],
      "collocations": [
        {
          "text": "Gäste unterbringen",
          "meaning": "to accommodate guests"
        },
        {
          "text": "in einem Hotel unterbringen",
          "meaning": "to accommodate in a hotel"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Unterbringung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسكن؛ يوفر مكانًا؛ يضع في مكان"
        },
        {
          "language": "ckb",
          "text": "جێگیرکردن؛ شوێن دان؛ نیشتەجێکردن"
        },
        {
          "language": "en",
          "text": "to accommodate; to house; to place"
        },
        {
          "language": "fa",
          "text": "اسکان دادن؛ جا دادن"
        },
        {
          "language": "kmr",
          "text": "bicihkirin; cih dayîn"
        },
        {
          "language": "pl",
          "text": "zakwaterować; umieścić"
        },
        {
          "language": "ro",
          "text": "a caza; a adăposti; a plasa"
        },
        {
          "language": "ru",
          "text": "размещать; поселять"
        },
        {
          "language": "sq",
          "text": "të akomodosh; të vendosësh"
        },
        {
          "language": "tr",
          "text": "yerleştirmek; barındırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Firma bringt die Gäste für die Messe in einem Hotel in der Nähe unter.",
          "translations": [
            {
              "language": "ar",
              "text": "تسكن الشركة الضيوف من أجل المعرض في فندق قريب."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە میوانەکان بۆ پێشانگاکە لە هۆتێلێکی نزیک جێگیر دەکات."
            },
            {
              "language": "en",
              "text": "The company accommodates the guests for the trade fair in a nearby hotel."
            },
            {
              "language": "fa",
              "text": "شرکت مهمانان نمایشگاه را در یک هتل نزدیک اسکان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Şirket ji bo pêşangehê mêvanan li otêleke nêzîk bicih dike."
            },
            {
              "language": "pl",
              "text": "Firma kwateruje gości na targi w pobliskim hotelu."
            },
            {
              "language": "ro",
              "text": "Firma cazează oaspeții pentru târg într-un hotel din apropiere."
            },
            {
              "language": "ru",
              "text": "Компания размещает гостей выставки в близлежащем отеле."
            },
            {
              "language": "sq",
              "text": "Kompania i akomodon mysafirët për panairin në një hotel pranë."
            },
            {
              "language": "tr",
              "text": "Şirket fuar için misafirleri yakındaki bir otele yerleştiriyor."
            }
          ]
        },
        {
          "baseText": "Nach dem Wasserrohrbruch musste die Stadt mehrere Familien vorübergehend unterbringen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد انفجار أنبوب الماء اضطرت المدينة إلى إسكان عدة عائلات مؤقتًا."
            },
            {
              "language": "ckb",
              "text": "دوای شکاوی بۆڕی ئاو، شارەکە ناچار بوو چەند خێزانێک بە شێوەی کاتی جێگیر بکات."
            },
            {
              "language": "en",
              "text": "After the burst water pipe, the city had to temporarily accommodate several families."
            },
            {
              "language": "fa",
              "text": "بعد از ترکیدگی لوله آب، شهر مجبور شد چند خانواده را موقتاً اسکان دهد."
            },
            {
              "language": "kmr",
              "text": "Piştî şikestina boriyê avê, bajar neçar bû çend malbatan demkî bicih bike."
            },
            {
              "language": "pl",
              "text": "Po pęknięciu rury wodnej miasto musiało tymczasowo zakwaterować kilka rodzin."
            },
            {
              "language": "ro",
              "text": "După spargerea conductei de apă, orașul a trebuit să cazeze temporar mai multe familii."
            },
            {
              "language": "ru",
              "text": "После прорыва водопровода город был вынужден временно разместить несколько семей."
            },
            {
              "language": "sq",
              "text": "Pas çarjes së tubit të ujit, qyteti duhej të akomodonte përkohësisht disa familje."
            },
            {
              "language": "tr",
              "text": "Su borusu patladıktan sonra şehir birkaç aileyi geçici olarak barındırmak zorunda kaldı."
            }
          ]
        }
      ]
    },
    {
      "word": "untergehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "untergehen",
      "pronunciationIpa": null,
      "syllableBreak": "un-ter-ge-hen",
      "topics": [
        "everyday-life",
        "business-communication",
        "culture-and-media"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; geht unter, ging unter, ist untergegangen"
      ],
      "collocations": [
        {
          "text": "die Sonne geht unter",
          "meaning": "the sun sets"
        },
        {
          "text": "in der Diskussion untergehen",
          "meaning": "to get lost in the discussion"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Untergang",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يغرب؛ يغرق؛ يضيع وسط شيء"
        },
        {
          "language": "ckb",
          "text": "ئاوا بوون؛ نقوم بوون؛ ونبوون لە ناو شتێک"
        },
        {
          "language": "en",
          "text": "to set; to sink; to get lost"
        },
        {
          "language": "fa",
          "text": "غروب کردن؛ غرق شدن؛ در میان چیزی گم شدن"
        },
        {
          "language": "kmr",
          "text": "ava bûn; binav bûn; winda bûn"
        },
        {
          "language": "pl",
          "text": "zachodzić; tonąć; ginąć w czymś"
        },
        {
          "language": "ro",
          "text": "a apune; a se scufunda; a se pierde"
        },
        {
          "language": "ru",
          "text": "заходить; тонуть; теряться"
        },
        {
          "language": "sq",
          "text": "të perëndojë; të fundoset; të humbasë"
        },
        {
          "language": "tr",
          "text": "batmak; kaybolmak"
        }
      ],
      "examples": [
        {
          "baseText": "Im Sommer geht die Sonne erst spät am Abend unter.",
          "translations": [
            {
              "language": "ar",
              "text": "في الصيف تغرب الشمس في وقت متأخر من المساء."
            },
            {
              "language": "ckb",
              "text": "لە هاویندا خۆر تەنها درەنگانی ئێوارە ئاوا دەبێت."
            },
            {
              "language": "en",
              "text": "In summer, the sun sets late in the evening."
            },
            {
              "language": "fa",
              "text": "در تابستان خورشید تازه دیر وقتِ عصر غروب می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di havînê de roj tenê dereng êvarê ava dibe."
            },
            {
              "language": "pl",
              "text": "Latem słońce zachodzi dopiero późnym wieczorem."
            },
            {
              "language": "ro",
              "text": "Vara soarele apune abia târziu seara."
            },
            {
              "language": "ru",
              "text": "Летом солнце заходит только поздно вечером."
            },
            {
              "language": "sq",
              "text": "Në verë dielli perëndon vetëm vonë në mbrëmje."
            },
            {
              "language": "tr",
              "text": "Yazın güneş ancak akşam geç saatlerde batar."
            }
          ]
        },
        {
          "baseText": "In der langen E-Mail ist die wichtigste Information fast untergegangen.",
          "translations": [
            {
              "language": "ar",
              "text": "في البريد الإلكتروني الطويل كادت أهم معلومة أن تضيع."
            },
            {
              "language": "ckb",
              "text": "لە ئیمەیڵە درێژەکەدا گرنگترین زانیاری نزیک بوو ون ببێت."
            },
            {
              "language": "en",
              "text": "In the long email, the most important information was almost lost."
            },
            {
              "language": "fa",
              "text": "در ایمیل طولانی، مهم‌ترین اطلاعات تقریباً گم شده بود."
            },
            {
              "language": "kmr",
              "text": "Di e-nameya dirêj de agahdariya herî girîng nêzîk bû winda bibe."
            },
            {
              "language": "pl",
              "text": "W długim e-mailu najważniejsza informacja prawie zginęła."
            },
            {
              "language": "ro",
              "text": "În e-mailul lung, cea mai importantă informație aproape s-a pierdut."
            },
            {
              "language": "ru",
              "text": "В длинном письме самая важная информация почти потерялась."
            },
            {
              "language": "sq",
              "text": "Në emailin e gjatë, informacioni më i rëndësishëm pothuajse humbi."
            },
            {
              "language": "tr",
              "text": "Uzun e-postada en önemli bilgi neredeyse kayboldu."
            }
          ]
        }
      ]
    },
    {
      "word": "unterhalten",
