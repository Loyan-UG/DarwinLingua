      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: unterhält, unterhielt, hat unterhalten; sich unterhalten = to talk"
      ],
      "collocations": [
        {
          "text": "sich mit jemandem unterhalten",
          "meaning": "to talk with someone"
        },
        {
          "text": "ein System unterhalten",
          "meaning": "to maintain a system"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Unterhaltung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتحدث؛ يسلّي؛ يصون/يدير"
        },
        {
          "language": "ckb",
          "text": "قسەکردن؛ خۆشکردن؛ بەڕێوەبردن/پاراستن"
        },
        {
          "language": "en",
          "text": "to talk; to entertain; to maintain"
        },
        {
          "language": "fa",
          "text": "گفت‌وگو کردن؛ سرگرم کردن؛ نگهداری کردن"
        },
        {
          "language": "kmr",
          "text": "axaftin; kêfxweş kirin; parastin"
        },
        {
          "language": "pl",
          "text": "rozmawiać; zabawiać; utrzymywać"
        },
        {
          "language": "ro",
          "text": "a discuta; a distra; a întreține"
        },
        {
          "language": "ru",
          "text": "разговаривать; развлекать; обслуживать"
        },
        {
          "language": "sq",
          "text": "të bisedosh; të argëtosh; të mirëmbash"
        },
        {
          "language": "tr",
          "text": "sohbet etmek; eğlendirmek; bakımını yapmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Besprechung habe ich mich kurz mit der neuen Kollegin unterhalten.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الاجتماع تحدثت قليلًا مع الزميلة الجديدة."
            },
            {
              "language": "ckb",
              "text": "دوای کۆبوونەوەکە کەمێک لەگەڵ هاوکارە نوێیەکە قسەم کرد."
            },
            {
              "language": "en",
              "text": "After the meeting, I briefly talked with the new colleague."
            },
            {
              "language": "fa",
              "text": "بعد از جلسه، کوتاه با همکار جدید صحبت کردم."
            },
            {
              "language": "kmr",
              "text": "Piştî civînê min kurt bi hevkara nû re axivî."
            },
            {
              "language": "pl",
              "text": "Po spotkaniu krótko porozmawiałem z nową koleżanką."
            },
            {
              "language": "ro",
