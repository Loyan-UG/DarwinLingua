  "entries": [
    {
      "word": "überwiegen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "überwiegen",
      "pronunciationIpa": null,
      "syllableBreak": "ü-ber-wie-gen",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "planning-and-projects"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb; often used with Vorteile/Nachteile"
      ],
      "collocations": [
        {
          "text": "die Vorteile überwiegen",
          "meaning": "the advantages outweigh"
        },
        {
          "text": "klar überwiegen",
          "meaning": "to clearly predominate"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "wiegen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يرجح؛ يكون أغلب أو أكثر أهمية"
        },
        {
          "language": "ckb",
          "text": "زیاتر بوون؛ باڵادەست بوون"
        },
        {
          "language": "en",
          "text": "to outweigh; to predominate"
        },
        {
          "language": "fa",
          "text": "غلبه داشتن؛ بیشتر بودن"
        },
        {
          "language": "kmr",
          "text": "zêdetir giran bûn; serdest bûn"
        },
        {
          "language": "pl",
          "text": "przeważać; dominować"
        },
        {
          "language": "ro",
          "text": "a prevala; a cântări mai mult"
        },
        {
          "language": "ru",
          "text": "преобладать; перевешивать"
        },
        {
          "language": "sq",
          "text": "të mbizotërosh; të peshojë më shumë"
        },
        {
          "language": "tr",
          "text": "ağır basmak; baskın olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bei der neuen Software überwiegen die Vorteile klar.",
          "translations": [
            {
              "language": "ar",
              "text": "في البرنامج الجديد ترجح المزايا بوضوح."
            },
            {
              "language": "ckb",
              "text": "لە نەرمەکاڵای نوێدا سوودەکان بە ڕوونی باڵادەستن."
            },
            {
              "language": "en",
              "text": "With the new software, the advantages clearly outweigh the disadvantages."
            },
            {
              "language": "fa",
              "text": "در نرم‌افزار جدید، مزایا به‌وضوح بیشتر هستند."
            },
            {
              "language": "kmr",
              "text": "Di nermalava nû de feyde bi zelalî zêdetir in."
            },
            {
              "language": "pl",
              "text": "W przypadku nowego oprogramowania zalety wyraźnie przeważają."
            },
            {
              "language": "ro",
              "text": "La noul software, avantajele prevalează clar."
            },
            {
              "language": "ru",
              "text": "В новом программном обеспечении преимущества явно перевешивают."
            },
            {
              "language": "sq",
              "text": "Te softueri i ri, përparësitë mbizotërojnë qartë."
            },
            {
              "language": "tr",
              "text": "Yeni yazılımda avantajlar açıkça ağır basıyor."
            }
          ]
        },
        {
          "baseText": "Trotz einiger Risiken überwiegen für uns die positiven Punkte.",
          "translations": [
            {
              "language": "ar",
              "text": "رغم بعض المخاطر، فإن النقاط الإيجابية ترجح بالنسبة لنا."
            },
            {
              "language": "ckb",
              "text": "سەرەڕای هەندێک مەترسی، خاڵە ئەرێنییەکان بۆ ئێمە زیاتر باڵادەستن."
            },
            {
              "language": "en",
              "text": "Despite some risks, the positive points outweigh them for us."
            },
            {
              "language": "fa",
              "text": "با وجود برخی ریسک‌ها، نکات مثبت برای ما غلبه دارند."
            },
            {
              "language": "kmr",
              "text": "Tevî hin metirsiyan, xalên erênî ji bo me zêdetir giran in."
            },
            {
              "language": "pl",
              "text": "Mimo pewnych ryzyk pozytywne punkty dla nas przeważają."
            },
            {
              "language": "ro",
              "text": "În ciuda unor riscuri, punctele pozitive cântăresc mai mult pentru noi."
            },
            {
              "language": "ru",
              "text": "Несмотря на некоторые риски, положительные моменты для нас перевешивают."
            },
            {
              "language": "sq",
              "text": "Pavarësisht disa rreziqeve, pikat pozitive peshojnë më shumë për ne."
            },
            {
              "language": "tr",
              "text": "Bazı risklere rağmen bizim için olumlu noktalar ağır basıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "überzeugen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "überzeugen",
      "pronunciationIpa": null,
      "syllableBreak": "ü-ber-zeu-gen",
      "topics": [
        "business-communication",
        "sales-and-customers",
        "social-and-relationships"
      ],
      "usageLabels": [
        "business",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb; jemanden von etwas überzeugen"
      ],
      "collocations": [
        {
          "text": "einen Kunden überzeugen",
          "meaning": "to convince a customer"
        },
        {
          "text": "von einer Idee überzeugen",
          "meaning": "to convince someone of an idea"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Überzeugung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقنع"
        },
        {
          "language": "ckb",
          "text": "قایلکردن؛ باوەڕ پێهێنان"
        },
        {
          "language": "en",
          "text": "to convince; to persuade"
        },
        {
          "language": "fa",
          "text": "قانع کردن؛ متقاعد کردن"
        },
        {
          "language": "kmr",
          "text": "qane kirin; razî kirin"
        },
        {
          "language": "pl",
          "text": "przekonać"
        },
        {
          "language": "ro",
          "text": "a convinge"
        },
        {
          "language": "ru",
          "text": "убеждать"
        },
        {
          "language": "sq",
          "text": "të bindësh"
        },
        {
          "language": "tr",
          "text": "ikna etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Mit einer klaren Demo konnten wir den Kunden überzeugen.",
          "translations": [
            {
              "language": "ar",
              "text": "استطعنا إقناع العميل بعرض توضيحي واضح."
            },
            {
              "language": "ckb",
              "text": "بە دیمۆیەکی ڕوون توانیمان کڕیارەکە قایل بکەین."
            },
            {
              "language": "en",
              "text": "With a clear demo, we were able to convince the customer."
            },
            {
              "language": "fa",
              "text": "با یک دموی واضح توانستیم مشتری را قانع کنیم."
            },
            {
              "language": "kmr",
              "text": "Bi demoyeke zelal me karî xerîdar qane bikin."
            },
            {
              "language": "pl",
              "text": "Dzięki jasnej prezentacji udało nam się przekonać klienta."
            },
            {
              "language": "ro",
              "text": "Cu o demonstrație clară am reușit să convingem clientul."
            },
            {
              "language": "ru",
              "text": "С помощью понятной демонстрации мы смогли убедить клиента."
            },
            {
              "language": "sq",
              "text": "Me një demo të qartë arritëm ta bindim klientin."
            },
            {
              "language": "tr",
              "text": "Net bir demo ile müşteriyi ikna edebildik."
            }
          ]
        },
        {
          "baseText": "Sie versucht ihre Eltern zu überzeugen, dass der Umzug sinnvoll ist.",
          "translations": [
            {
              "language": "ar",
              "text": "تحاول إقناع والديها بأن الانتقال منطقي."
            },
            {
              "language": "ckb",
              "text": "هەوڵ دەدات دایک و باوکی قایل بکات کە گواستنەوەکە مانادارە."
            },
            {
              "language": "en",
              "text": "She is trying to convince her parents that the move makes sense."
            },
            {
              "language": "fa",
              "text": "او سعی می‌کند والدینش را قانع کند که جابه‌جایی منطقی است."
            },
            {
              "language": "kmr",
              "text": "Ew hewl dide dêûbavên xwe qane bike ku barkirin maqûl e."
            },
            {
              "language": "pl",
              "text": "Próbuje przekonać rodziców, że przeprowadzka ma sens."
            },
            {
              "language": "ro",
              "text": "Ea încearcă să își convingă părinții că mutarea are sens."
            },
            {
              "language": "ru",
              "text": "Она пытается убедить родителей, что переезд имеет смысл."
            },
            {
              "language": "sq",
              "text": "Ajo përpiqet t’i bindë prindërit se shpërngulja ka kuptim."
            },
            {
              "language": "tr",
              "text": "Taşınmanın mantıklı olduğuna ailesini ikna etmeye çalışıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Überzeugung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Überzeugungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ü-ber-zeu-gung",
      "topics": [
        "social-and-relationships",
        "business-communication",
        "culture-and-media"
      ],
      "usageLabels": [
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine feste Überzeugung",
          "meaning": "a firm belief"
        },
        {
          "text": "aus Überzeugung handeln",
          "meaning": "to act out of conviction"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "überzeugen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قناعة؛ اعتقاد"
        },
        {
          "language": "ckb",
          "text": "باوەڕ؛ قەناعەت"
        },
        {
          "language": "en",
          "text": "conviction; belief"
        },
        {
          "language": "fa",
          "text": "باور؛ اعتقاد؛ قناعت"
        },
        {
          "language": "kmr",
          "text": "bawerî; qanehî"
        },
        {
          "language": "pl",
          "text": "przekonanie"
        },
        {
          "language": "ro",
          "text": "convingere"
        },
        {
          "language": "ru",
          "text": "убеждение"
        },
        {
          "language": "sq",
          "text": "bindje; besim"
        },
        {
          "language": "tr",
          "text": "inanç; kanaat"
        }
      ],
      "examples": [
        {
          "baseText": "Aus meiner Überzeugung sollten wir offener mit Kritik umgehen.",
          "translations": [
            {
              "language": "ar",
              "text": "من قناعتي، يجب أن نتعامل مع النقد بانفتاح أكبر."
            },
            {
              "language": "ckb",
              "text": "بەپێی باوەڕی من، دەبێت بە کراوەیی زیاتر مامەڵە لەگەڵ ڕەخنە بکەین."
            },
            {
              "language": "en",
              "text": "In my conviction, we should deal with criticism more openly."
            },
            {
              "language": "fa",
              "text": "به باور من، باید با انتقاد بازتر برخورد کنیم."
            },
            {
              "language": "kmr",
              "text": "Li gor baweriya min, divê em bi rexneyê vekirîtir reftar bikin."
            },
            {
              "language": "pl",
              "text": "Moim zdaniem powinniśmy bardziej otwarcie podchodzić do krytyki."
            },
            {
              "language": "ro",
              "text": "După convingerea mea, ar trebui să tratăm critica mai deschis."
            },
            {
              "language": "ru",
              "text": "По моему убеждению, нам следует более открыто относиться к критике."
            },
            {
              "language": "sq",
              "text": "Sipas bindjes sime, duhet ta trajtojmë kritikën më hapur."
            },
            {
              "language": "tr",
              "text": "Benim kanaatime göre eleştiriye daha açık yaklaşmalıyız."
            }
          ]
        },
        {
          "baseText": "Er hat die Stelle angenommen, weil sie zu seinen Überzeugungen passt.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الوظيفة لأنها تناسب قناعاته."
            },
            {
              "language": "ckb",
              "text": "ئەو کارەکەی قبوڵ کرد چونکە لەگەڵ باوەڕەکانی دەگونجێت."
            },
            {
              "language": "en",
              "text": "He accepted the position because it fits his convictions."
            },
            {
              "language": "fa",
              "text": "او این موقعیت شغلی را پذیرفت چون با باورهایش سازگار است."
            },
            {
              "language": "kmr",
              "text": "Wî kar qebûl kir ji ber ku bi baweriyên wî re tê."
            },
            {
              "language": "pl",
              "text": "Przyjął tę posadę, bo pasuje do jego przekonań."
            },
            {
              "language": "ro",
              "text": "A acceptat postul pentru că se potrivește cu convingerile lui."
            },
            {
              "language": "ru",
              "text": "Он принял эту должность, потому что она соответствует его убеждениям."
            },
            {
              "language": "sq",
              "text": "Ai e pranoi vendin e punës sepse përputhet me bindjet e tij."
            },
            {
              "language": "tr",
              "text": "Pozisyonu kabul etti çünkü inançlarına uyuyor."
            }
          ]
        }
      ]
    },
    {
