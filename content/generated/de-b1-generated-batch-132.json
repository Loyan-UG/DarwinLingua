      "examples": [
        {
          "baseText": "Unsere Besprechungen dauern üblicherweise nicht länger als dreißig Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "اجتماعاتنا لا تستغرق عادة أكثر من ثلاثين دقيقة."
            },
            {
              "language": "ckb",
              "text": "کۆبوونەوەکانمان بەزۆری زیاتر لە سی خولەک ناخایەنن."
            },
            {
              "language": "en",
              "text": "Our meetings usually do not last longer than thirty minutes."
            },
            {
              "language": "fa",
              "text": "جلسه‌های ما معمولاً بیشتر از سی دقیقه طول نمی‌کشند."
            },
            {
              "language": "kmr",
              "text": "Civînên me bi gelemperî ji sî deqîqeyan dirêjtir nadomînin."
            },
            {
              "language": "pl",
              "text": "Nasze spotkania zwykle nie trwają dłużej niż trzydzieści minut."
            },
            {
              "language": "ro",
              "text": "Ședințele noastre de obicei nu durează mai mult de treizeci de minute."
            },
            {
              "language": "ru",
              "text": "Наши встречи обычно длятся не больше тридцати минут."
            },
            {
              "language": "sq",
              "text": "Takimet tona zakonisht nuk zgjasin më shumë se tridhjetë minuta."
            },
            {
              "language": "tr",
              "text": "Toplantılarımız genellikle otuz dakikadan uzun sürmez."
            }
          ]
        },
        {
          "baseText": "Üblicherweise kaufe ich Brot auf dem Weg nach Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "عادةً أشتري الخبز في الطريق إلى المنزل."
            },
            {
              "language": "ckb",
              "text": "بەزۆری لە ڕێگای ماڵەوە نان دەکڕم."
            },
            {
              "language": "en",
              "text": "I usually buy bread on the way home."
            },
            {
              "language": "fa",
              "text": "معمولاً در راه خانه نان می‌خرم."
            },
            {
              "language": "kmr",
              "text": "Bi gelemperî ez li ser rêya malê nan dikirim."
            },
            {
              "language": "pl",
              "text": "Zwykle kupuję chleb w drodze do domu."
            },
            {
              "language": "ro",
              "text": "De obicei cumpăr pâine în drum spre casă."
            },
            {
              "language": "ru",
              "text": "Обычно я покупаю хлеб по дороге домой."
            },
            {
              "language": "sq",
              "text": "Zakonisht blej bukë rrugës për në shtëpi."
            },
            {
              "language": "tr",
              "text": "Genellikle eve giderken ekmek alırım."
            }
          ]
        }
