  "entries": [
    {
      "word": "unterbleiben",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "unterbleiben",
      "pronunciationIpa": null,
      "syllableBreak": "un-ter-blei-ben",
      "topics": [
        "documents-and-administration",
        "law-and-compliance",
        "business-communication"
      ],
      "usageLabels": [
        "written",
        "business"
      ],
      "contextLabels": [
        "administration",
        "legal",
        "compliance"
      ],
      "grammarNotes": [
        "formal intransitive verb: unterbleibt, unterblieb, ist unterblieben; means not to take place or to be omitted"
      ],
      "collocations": [
        {
          "text": "eine Reaktion unterbleibt",
          "meaning": "a response does not occur"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bleiben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "لا يحدث؛ يُترك دون تنفيذ"
        },
        {
          "language": "ckb",
          "text": "ڕوونادات؛ ئەنجام نادرێت"
        },
        {
          "language": "en",
          "text": "to fail to happen; to be omitted"
        },
        {
          "language": "fa",
          "text": "انجام نشدن؛ رخ ندادن"
        },
        {
          "language": "kmr",
          "text": "pêk nehatin; nehatiye kirin"
        },
        {
          "language": "pl",
          "text": "nie dojść do skutku; zostać pominiętym"
        },
        {
          "language": "ro",
          "text": "a nu avea loc; a fi omis"
        },
        {
          "language": "ru",
          "text": "не состояться; быть упущенным"
        },
        {
          "language": "sq",
          "text": "të mos ndodhë; të lihet pa bërë"
        },
        {
          "language": "tr",
          "text": "gerçekleşmemek; yapılmamak"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn die Zahlung nicht eingeht, unterbleibt die automatische Freischaltung des Kontos.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا لم تصل الدفعة، فلن يتم التفعيل التلقائي للحساب."
            },
            {
              "language": "ckb",
              "text": "ئەگەر پارەدانەکە نەگات، چالاککردنی ئۆتۆماتیکی هەژمارەکە ئەنجام نادرێت."
            },
            {
              "language": "en",
              "text": "If the payment is not received, the automatic activation of the account will not take place."
            },
            {
              "language": "fa",
              "text": "اگر پرداخت دریافت نشود، فعال‌سازی خودکار حساب انجام نمی‌شود."
            },
            {
              "language": "kmr",
              "text": "Ger dayîna pereyan negihêje, çalakkirina xweber a hesabê pêk nayê."
            },
            {
              "language": "pl",
              "text": "Jeśli płatność nie wpłynie, automatyczna aktywacja konta nie nastąpi."
            },
            {
              "language": "ro",
              "text": "Dacă plata nu intră, activarea automată a contului nu are loc."
            },
            {
              "language": "ru",
              "text": "Если платеж не поступит, автоматическая активация учетной записи не состоится."
            },
            {
              "language": "sq",
              "text": "Nëse pagesa nuk merret, aktivizimi automatik i llogarisë nuk bëhet."
            },
            {
              "language": "tr",
              "text": "Ödeme alınmazsa hesabın otomatik aktivasyonu gerçekleşmez."
            }
          ]
        },
        {
          "baseText": "Eine öffentliche Stellungnahme unterblieb, weil die Prüfung noch nicht abgeschlossen war.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يصدر تصريح علني لأن المراجعة لم تكن قد اكتملت بعد."
            },
            {
              "language": "ckb",
              "text": "لێدوانێکی گشتی نەدرا، چونکە پشکنینەکە هێشتا تەواو نەبووبوو."
            },
            {
              "language": "en",
              "text": "A public statement was not issued because the review had not yet been completed."
            },
            {
              "language": "fa",
              "text": "اظهارنظر عمومی انجام نشد، چون بررسی هنوز کامل نشده بود."
            },
            {
              "language": "kmr",
              "text": "Daxuyaniyeke giştî nehat dayîn, ji ber ku kontrol hîn neqediyabû."
            },
            {
              "language": "pl",
              "text": "Publiczne stanowisko nie zostało wydane, ponieważ kontrola nie była jeszcze zakończona."
            },
            {
              "language": "ro",
              "text": "O declarație publică nu a avut loc deoarece verificarea nu fusese încă finalizată."
            },
            {
              "language": "ru",
              "text": "Публичное заявление не было сделано, потому что проверка еще не была завершена."
            },
            {
              "language": "sq",
              "text": "Një deklaratë publike nuk u bë, sepse kontrolli nuk kishte përfunduar ende."
            },
            {
              "language": "tr",
              "text": "İnceleme henüz tamamlanmadığı için kamuya açık bir açıklama yapılmadı."
            }
          ]
        }
      ]
    },
    {
      "word": "unterlaufen",
