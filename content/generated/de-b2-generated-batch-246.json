      "grammarNotes": [
        "often impersonal: jemandem unterläuft ein Fehler; also means to undermine in other contexts"
      ],
      "collocations": [
        {
          "text": "jemandem unterläuft ein Fehler",
          "meaning": "someone makes a mistake unintentionally"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "laufen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقع خطأ غير مقصود؛ يقوّض"
        },
        {
          "language": "ckb",
          "text": "ڕوودانی هەڵەی نەویستراو؛ لاوازکردن"
        },
        {
          "language": "en",
          "text": "to occur as an unintended mistake; to undermine"
        },
        {
          "language": "fa",
          "text": "اشتباهی سهواً رخ دادن؛ تضعیف کردن"
        },
        {
          "language": "kmr",
          "text": "çewtiyek bê mebest çêbûn; lawaz kirin"
        },
        {
          "language": "pl",
          "text": "przydarzyć się jako błąd; podważać"
