      ],
      "collocations": [
        {
          "text": "methodische Erkenntnisgrenzen",
          "meaning": "methodological limits of knowledge"
        },
        {
          "text": "Erkenntnisgrenzen offenlegen",
          "meaning": "to disclose limits of what can be known"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erkenntnis",
