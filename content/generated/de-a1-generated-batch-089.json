      "examples": [
        {
          "baseText": "Die Kinder singen ein Lied.",
          "translations": [
            {
              "language": "ar",
              "text": "الأطفال يغنون أغنية."
            },
            {
              "language": "ckb",
              "text": "منداڵەکان گۆرانییەک دەڵێن."
            },
            {
              "language": "en",
              "text": "The children are singing a song."
            },
            {
              "language": "fa",
              "text": "بچه‌ها یک آهنگ می‌خوانند."
            },
            {
              "language": "kmr",
              "text": "Zarok stranekê dibêjin."
            },
            {
              "language": "pl",
              "text": "Dzieci śpiewają piosenkę."
            },
            {
              "language": "ro",
              "text": "Copiii cântă un cântec."
            },
            {
              "language": "ru",
              "text": "Дети поют песню."
            },
            {
              "language": "sq",
              "text": "Fëmijët këndojnë një këngë."
            },
            {
              "language": "tr",
              "text": "Çocuklar bir şarkı söylüyor."
            }
          ]
        },
        {
          "baseText": "Ich singe gern im Auto.",
          "translations": [
            {
              "language": "ar",
              "text": "أحب الغناء في السيارة."
            },
            {
              "language": "ckb",
              "text": "من حەزم لە گۆرانی گوتنە لە ئۆتۆمبێلدا."
            },
            {
              "language": "en",
              "text": "I like singing in the car."
            },
            {
              "language": "fa",
              "text": "من دوست دارم در ماشین آواز بخوانم."
            },
            {
              "language": "kmr",
              "text": "Ez li erebeyê bi kêfxweşî stran dibêjim."
            },
            {
              "language": "pl",
              "text": "Lubię śpiewać w samochodzie."
            },
            {
              "language": "ro",
              "text": "Îmi place să cânt în mașină."
            },
            {
              "language": "ru",
              "text": "Я люблю петь в машине."
            },
            {
              "language": "sq",
              "text": "Më pëlqen të këndoj në makinë."
            },
            {
              "language": "tr",
              "text": "Arabada şarkı söylemeyi severim."
            }
          ]
        }
