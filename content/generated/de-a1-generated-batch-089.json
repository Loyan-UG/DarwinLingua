            {
              "language": "en",
              "text": "Please send the invoice right away."
            },
            {
              "language": "fa",
              "text": "لطفاً فاکتور را فوراً بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fatûreyê yekser bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę wysłać fakturę natychmiast."
            },
            {
              "language": "ro",
              "text": "Vă rog să trimiteți factura imediat."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте счёт сразу."
            },
            {
              "language": "sq",
              "text": "Ju lutem dërgoni faturën menjëherë."
            },
