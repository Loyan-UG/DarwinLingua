        },
        {
          "language": "tr",
          "text": "şarkıcı; erkek şarkıcı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Sänger steht heute Abend auf der Bühne.",
          "translations": [
            {
              "language": "ar",
              "text": "يقف المغني على المسرح هذا المساء."
            },
            {
              "language": "ckb",
              "text": "گۆرانیبێژەکە ئەمشەو لەسەر سەکۆیە."
            },
            {
              "language": "en",
              "text": "The singer is on stage this evening."
            },
            {
              "language": "fa",
              "text": "خواننده امشب روی صحنه است."
            },
            {
              "language": "kmr",
              "text": "Stranbêj îşev li ser sehnê ye."
            },
            {
              "language": "pl",
              "text": "Piosenkarz stoi dziś wieczorem na scenie."
            },
            {
              "language": "ro",
              "text": "Cântărețul este pe scenă în această seară."
            },
            {
              "language": "ru",
              "text": "Певец сегодня вечером на сцене."
            },
            {
              "language": "sq",
              "text": "Këngëtari është sonte në skenë."
            },
            {
              "language": "tr",
              "text": "Şarkıcı bu akşam sahnede."
            }
          ]
        },
        {
          "baseText": "Mein Bruder möchte Sänger werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد أخي أن يصبح مغنياً."
            },
            {
              "language": "ckb",
              "text": "براکەم دەیەوێت ببێتە گۆرانیبێژ."
            },
            {
              "language": "en",
              "text": "My brother wants to become a singer."
            },
            {
              "language": "fa",
              "text": "برادرم می‌خواهد خواننده شود."
            },
            {
              "language": "kmr",
              "text": "Birayê min dixwaze bibe stranbêj."
            },
            {
              "language": "pl",
              "text": "Mój brat chce zostać piosenkarzem."
            },
            {
              "language": "ro",
              "text": "Fratele meu vrea să devină cântăreț."
            },
            {
              "language": "ru",
              "text": "Мой брат хочет стать певцом."
            },
            {
              "language": "sq",
              "text": "Vëllai im dëshiron të bëhet këngëtar."
            },
            {
              "language": "tr",
              "text": "Kardeşim şarkıcı olmak istiyor."
            }
          ]
        }
      ]
