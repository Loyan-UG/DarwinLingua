            }
          ]
        },
        {
          "baseText": "Wir hören die neue CD der Sängerin.",
          "translations": [
            {
              "language": "ar",
              "text": "نستمع إلى القرص الجديد للمغنية."
            },
            {
              "language": "ckb",
              "text": "ئێمە گوێ لە CDی نوێی گۆرانیبێژەکە دەگرین."
            },
            {
              "language": "en",
              "text": "We are listening to the singer’s new CD."
            },
            {
              "language": "fa",
              "text": "ما به سی‌دی جدید خواننده گوش می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Em guhdariya CDya nû ya stranbêjê dikin."
            },
            {
              "language": "pl",
              "text": "Słuchamy nowej płyty tej piosenkarki."
            },
            {
              "language": "ro",
              "text": "Ascultăm noul CD al cântăreței."
            },
            {
              "language": "ru",
              "text": "Мы слушаем новый диск певицы."
            },
            {
              "language": "sq",
              "text": "Ne po dëgjojmë CD-në e re të këngëtares."
