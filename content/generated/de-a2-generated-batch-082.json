      "examples": [
        {
          "baseText": "Möchten Sie Sahne in den Kaffee?",
          "translations": [
            {
              "language": "ar",
              "text": "هل ترغب في قشدة في القهوة؟"
            },
            {
              "language": "ckb",
              "text": "دەتەوێت سەرشیر بخەیتە ناو قاوەکەت؟"
            },
            {
              "language": "en",
              "text": "Would you like cream in your coffee?"
            },
            {
              "language": "fa",
              "text": "آیا در قهوه‌تان خامه می‌خواهید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dixwazin qeymaxê bixin qehweya xwe?"
            },
            {
              "language": "pl",
              "text": "Czy chce pan/pani śmietankę do kawy?"
            },
            {
              "language": "ro",
              "text": "Doriți smântână în cafea?"
            },
            {
              "language": "ru",
              "text": "Хотите сливки в кофе?"
            },
            {
              "language": "sq",
              "text": "Dëshironi ajkë në kafe?"
            },
            {
              "language": "tr",
              "text": "Kahvenize krema ister misiniz?"
            }
          ]
        },
        {
          "baseText": "Für den Kuchen brauchen wir Sahne.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج إلى قشدة للكعكة."
            },
            {
              "language": "ckb",
              "text": "بۆ کێکەکە پێویستمان بە سەرشیر هەیە."
            },
            {
              "language": "en",
              "text": "We need cream for the cake."
            },
            {
              "language": "fa",
              "text": "برای کیک به خامه نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo kekê em hewceyê qeymaxê ne."
            },
            {
              "language": "pl",
              "text": "Do ciasta potrzebujemy śmietany."
            },
            {
              "language": "ro",
              "text": "Pentru prăjitură avem nevoie de smântână."
            },
            {
              "language": "ru",
              "text": "Для торта нам нужны сливки."
            },
            {
              "language": "sq",
              "text": "Për tortën na duhet ajkë."
            },
            {
              "language": "tr",
              "text": "Kek için kremaya ihtiyacımız var."
