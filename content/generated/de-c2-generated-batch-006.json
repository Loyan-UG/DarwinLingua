  "entries": [
    {
      "word": "die Anmaßung",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Anmaßungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-ma-ßung",
      "topics": [
        "business-communication",
        "management-and-leadership",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; often describes presumptuous or arrogant overstepping"
      ],
      "collocations": [
        {
          "text": "eine unerträgliche Anmaßung",
          "meaning": "an intolerable presumption"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "anmaßend",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "sich anmaßen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "غطرسة؛ ادعاء متجاوز؛ وقاحة"
        },
        {
          "language": "ckb",
          "text": "خۆبەزلزانی؛ داوای بێجێ؛ سنووربەزاندن"
        },
        {
          "language": "en",
          "text": "presumption; arrogance; overstepping"
        },
        {
          "language": "fa",
          "text": "گستاخی؛ خودبزرگ‌بینی؛ ادعای بی‌جا"
        },
        {
          "language": "kmr",
          "text": "xwe-mezinbînî; daxwaza bêcih; derbasbûna sînor"
        },
        {
          "language": "pl",
          "text": "arogancja; uzurpacja; zarozumiałość"
        },
        {
          "language": "ro",
          "text": "aroganță; pretenție nejustificată; depășire a limitelor"
        },
        {
          "language": "ru",
          "text": "самонадеянность; высокомерие; неправомерное притязание"
        },
        {
          "language": "sq",
          "text": "arrogancë; pretendim i pajustifikuar; tejkalim"
        },
        {
          "language": "tr",
          "text": "kibir; haddini aşma; yersiz iddia"
        }
      ],
      "examples": [
        {
          "baseText": "Die Anmaßung, ohne Mandat im Namen des gesamten Teams zu sprechen, führte zu erheblichem Unmut.",
          "translations": [
            {
              "language": "ar",
              "text": "أدى الادعاء بالتحدث باسم الفريق كله من دون تفويض إلى استياء كبير."
            },
            {
              "language": "ckb",
              "text": "ئەو سنووربەزاندنەی بەبێ ماندات بە ناوی هەموو تیمەکەوە قسە بکات، ناڕەزاییەکی زۆری دروست کرد."
            },
            {
              "language": "en",
              "text": "The presumption of speaking on behalf of the entire team without a mandate caused considerable resentment."
            },
            {
              "language": "fa",
              "text": "این گستاخی که بدون اختیار از طرف کل تیم صحبت کند، نارضایتی زیادی ایجاد کرد."
            },
            {
              "language": "kmr",
              "text": "Xwe-mezinbîniya ku bê destûr bi navê hemû tîmê biaxive, nerazîbûneke mezin çêkir."
            },
            {
              "language": "pl",
              "text": "Uzurpacja prawa do wypowiadania się w imieniu całego zespołu bez mandatu wywołała znaczne niezadowolenie."
            },
            {
              "language": "ro",
              "text": "Pretenția de a vorbi în numele întregii echipe fără mandat a provocat nemulțumiri considerabile."
            },
            {
              "language": "ru",
              "text": "Самонадеянная попытка говорить от имени всей команды без полномочий вызвала значительное недовольство."
            },
            {
              "language": "sq",
              "text": "Pretendimi për të folur në emër të gjithë ekipit pa mandat shkaktoi pakënaqësi të madhe."
            },
            {
              "language": "tr",
              "text": "Yetki olmadan tüm ekip adına konuşma haddini aşması ciddi hoşnutsuzluğa yol açtı."
            }
          ]
        },
        {
          "baseText": "Viele empfanden es als Anmaßung, dass die Behörde die Betroffenen erst nach der Entscheidung anhörte.",
          "translations": [
            {
              "language": "ar",
              "text": "اعتبر كثيرون أنه تجاوز أن تسمع الجهة الحكومية المتأثرين فقط بعد اتخاذ القرار."
            },
            {
              "language": "ckb",
              "text": "زۆر کەس ئەوەیان بە خۆبەزلزانی زانی کە دامەزراوەکە تەنها دوای بڕیارەکە گوێی لە کەسانی کاریگەری لێکەوتوو گرت."
            },
            {
              "language": "en",
              "text": "Many saw it as presumptuous that the authority heard those affected only after the decision had been made."
            },
            {
              "language": "fa",
              "text": "بسیاری این را گستاخی دانستند که اداره فقط پس از تصمیم‌گیری نظر افراد درگیر را شنید."
            },
            {
              "language": "kmr",
              "text": "Gelekan ew wek xwe-mezinbînî dît ku dezgeh tenê piştî biryarê guhdarîya kesên bandorlêketî kir."
            },
            {
              "language": "pl",
              "text": "Wiele osób uznało za arogancję, że urząd wysłuchał zainteresowanych dopiero po podjęciu decyzji."
            },
            {
              "language": "ro",
              "text": "Mulți au considerat o aroganță faptul că autoritatea i-a ascultat pe cei afectați abia după decizie."
            },
            {
              "language": "ru",
              "text": "Многие сочли самонадеянностью то, что ведомство выслушало затронутых людей только после принятия решения."
            },
            {
              "language": "sq",
              "text": "Shumë e panë si arrogancë faktin që autoriteti i dëgjoi të prekurit vetëm pas vendimit."
            },
            {
              "language": "tr",
              "text": "Birçok kişi, kurumun etkilenenleri ancak karardan sonra dinlemesini haddini aşmak olarak gördü."
            }
          ]
        }
      ]
    },
    {
      "word": "der Anschein",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-schein",
      "topics": [
        "advanced-analysis",
        "business-communication",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "written",
        "analysis",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; usually singular; often in phrases like dem Anschein nach and den Anschein erwecken"
      ],
      "collocations": [
        {
          "text": "den Anschein erwecken",
          "meaning": "to give the impression"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "scheinen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مظهر؛ انطباع؛ ظاهر الأمر"
        },
        {
          "language": "ckb",
          "text": "دەرکەوتن؛ وێنەی دەرەکی؛ وا دیاربوون"
        },
        {
          "language": "en",
          "text": "appearance; impression; semblance"
        },
        {
          "language": "fa",
          "text": "ظاهر؛ نمود؛ برداشت اولیه"
        },
        {
          "language": "kmr",
          "text": "xuyabûn; bandora derveyî; şibandin"
        },
        {
          "language": "pl",
          "text": "pozór; wrażenie; wygląd"
        },
        {
          "language": "ro",
          "text": "aparență; impresie; aparență exterioară"
        },
        {
          "language": "ru",
          "text": "видимость; впечатление; кажимость"
        },
        {
          "language": "sq",
          "text": "pamje e jashtme; përshtypje; dukje"
        },
        {
          "language": "tr",
          "text": "görünüş; izlenim; intiba"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bericht erweckte den Anschein vollständiger Transparenz, verschwieg aber die wichtigsten Annahmen.",
          "translations": [
            {
              "language": "ar",
              "text": "أعطى التقرير انطباعاً بالشفافية الكاملة، لكنه أخفى أهم الافتراضات."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتەکە وێنەی ڕوونی تەواوی دروست کرد، بەڵام گرنگترین گریمانەکانی شاردەوە."
            },
            {
              "language": "en",
              "text": "The report gave the impression of full transparency but concealed the most important assumptions."
            },
            {
              "language": "fa",
              "text": "گزارش ظاهری از شفافیت کامل ایجاد می‌کرد، اما مهم‌ترین فرض‌ها را پنهان می‌کرد."
            },
            {
              "language": "kmr",
              "text": "Rapor bandora şefafiyeta temam da, lê girîngtirîn texmînan veşart."
            },
            {
              "language": "pl",
              "text": "Raport sprawiał wrażenie pełnej przejrzystości, ale przemilczał najważniejsze założenia."
            },
            {
              "language": "ro",
              "text": "Raportul dădea impresia unei transparențe complete, dar ascundea cele mai importante ipoteze."
            },
            {
              "language": "ru",
              "text": "Отчёт создавал впечатление полной прозрачности, но умалчивал о важнейших допущениях."
            },
            {
              "language": "sq",
              "text": "Raporti krijonte përshtypjen e transparencës së plotë, por fshihte supozimet më të rëndësishme."
            },
            {
              "language": "tr",
              "text": "Rapor tam şeffaflık izlenimi veriyordu, ancak en önemli varsayımları gizliyordu."
            }
          ]
        },
        {
          "baseText": "Dem Anschein nach war die Beschwerde erledigt, doch der Kunde wartete weiterhin auf eine verbindliche Antwort.",
          "translations": [
            {
              "language": "ar",
              "text": "بحسب الظاهر كانت الشكوى قد أُغلقت، لكن العميل كان لا يزال ينتظر جواباً ملزماً."
            },
            {
              "language": "ckb",
              "text": "بە دەرکەوتنەوە، سکاڵاکە چارەسەر کرابوو، بەڵام کڕیارەکە هێشتا چاوەڕێی وەڵامێکی پابەند بوو."
            },
            {
              "language": "en",
              "text": "Apparently the complaint had been resolved, but the customer was still waiting for a binding response."
            },
            {
              "language": "fa",
              "text": "ظاهراً شکایت حل شده بود، اما مشتری همچنان منتظر پاسخی الزام‌آور بود."
            },
            {
              "language": "kmr",
              "text": "Li gor xuyabûnê gilî hatibû çareserkirin, lê xerîdar hîn li benda bersiveke girêdayî bû."
            },
            {
              "language": "pl",
              "text": "Z pozoru reklamacja była załatwiona, lecz klient nadal czekał na wiążącą odpowiedź."
            },
            {
              "language": "ro",
              "text": "După aparențe, reclamația fusese rezolvată, însă clientul încă aștepta un răspuns ferm."
            },
            {
              "language": "ru",
              "text": "С виду жалоба была закрыта, но клиент всё ещё ждал обязательного ответа."
            },
            {
              "language": "sq",
              "text": "Në dukje ankesa ishte zgjidhur, por klienti ende priste një përgjigje detyruese."
            },
            {
              "language": "tr",
              "text": "Görünüşe göre şikâyet çözülmüştü, ancak müşteri hâlâ bağlayıcı bir yanıt bekliyordu."
            }
          ]
        }
      ]
    },
