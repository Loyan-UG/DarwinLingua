  "entries": [
    {
      "word": "durchfallen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "durchfallen",
      "pronunciationIpa": null,
      "syllableBreak": "durch-fal-len",
      "topics": [
        "education-and-training",
        "work-and-jobs",
        "everyday-life"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "education",
        "training",
        "administration"
      ],
      "grammarNotes": [
        "separable strong verb: fällt durch, fiel durch, ist durchgefallen"
      ],
      "collocations": [
        {
          "text": "bei einer Prüfung durchfallen",
          "meaning": "to fail an exam"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fallen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يرسب؛ لا ينجح"
        },
        {
          "language": "ckb",
          "text": "دەرنەچوون؛ شکست هێنان لە تاقیکردنەوە"
        },
        {
          "language": "en",
          "text": "to fail an exam or test"
        },
        {
          "language": "fa",
          "text": "رد شدن؛ قبول نشدن"
        },
        {
          "language": "kmr",
          "text": "di azmûnê de têk çûn"
        },
        {
          "language": "pl",
          "text": "oblać; nie zdać"
        },
        {
          "language": "ro",
          "text": "a pica; a nu promova"
        },
        {
          "language": "ru",
          "text": "провалиться; не сдать"
        },
        {
          "language": "sq",
          "text": "të ngelësh; të mos kalosh"
        },
        {
          "language": "tr",
          "text": "kalmak; başarısız olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn ich bei der Prüfung durchfalle, kann ich sie im Herbst wiederholen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا رسبت في الامتحان، يمكنني إعادته في الخريف."
            },
            {
              "language": "ckb",
              "text": "ئەگەر لە تاقیکردنەوەکە دەرنەچم، دەتوانم لە پاییزدا دووبارەی بکەمەوە."
            },
            {
              "language": "en",
              "text": "If I fail the exam, I can repeat it in autumn."
            },
            {
              "language": "fa",
              "text": "اگر در امتحان رد شوم، می‌توانم پاییز دوباره آن را بدهم."
            },
            {
              "language": "kmr",
              "text": "Heke ez di azmûnê de têk biçim, ez dikarim payîzê wê dubare bikim."
            },
            {
              "language": "pl",
              "text": "Jeśli nie zdam egzaminu, mogę go powtórzyć jesienią."
            },
            {
              "language": "ro",
              "text": "Dacă pic examenul, îl pot repeta în toamnă."
            },
            {
              "language": "ru",
              "text": "Если я не сдам экзамен, я смогу пересдать его осенью."
            },
            {
              "language": "sq",
              "text": "Nëse ngel në provim, mund ta përsëris në vjeshtë."
            },
            {
              "language": "tr",
              "text": "Sınavda kalırsam sonbaharda tekrar girebilirim."
            }
          ]
        },
        {
          "baseText": "Beim ersten Fahrtest ist er durchgefallen, weil er zu schnell gefahren ist.",
          "translations": [
            {
              "language": "ar",
              "text": "رسب في اختبار القيادة الأول لأنه قاد بسرعة كبيرة."
            },
            {
              "language": "ckb",
              "text": "لە یەکەم تاقیکردنەوەی شۆفێریدا دەرنەچوو، چونکە زۆر خێرا لێیخوڕی."
            },
            {
              "language": "en",
              "text": "He failed the first driving test because he drove too fast."
            },
            {
              "language": "fa",
              "text": "در اولین آزمون رانندگی رد شد، چون خیلی تند رانندگی کرد."
            },
            {
              "language": "kmr",
              "text": "Di testa ajotinê ya yekem de têk çû, ji ber ku pir bilez ajot."
            },
            {
              "language": "pl",
              "text": "Nie zdał pierwszego egzaminu na prawo jazdy, bo jechał za szybko."
            },
            {
              "language": "ro",
              "text": "A picat primul examen auto pentru că a condus prea repede."
            },
            {
              "language": "ru",
              "text": "Он провалил первый экзамен по вождению, потому что ехал слишком быстро."
            },
            {
              "language": "sq",
              "text": "Ai ngeli në testin e parë të vozitjes sepse voziti shumë shpejt."
            },
            {
              "language": "tr",
              "text": "İlk direksiyon sınavında çok hızlı sürdüğü için kaldı."
            }
          ]
        }
      ]
    },
    {
      "word": "durchlesen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "durchlesen",
      "pronunciationIpa": null,
      "syllableBreak": "durch-le-sen",
      "topics": [
        "documents-and-administration",
        "business-communication",
        "education-and-training"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "formal"
      ],
      "contextLabels": [
        "documents",
        "administration",
        "training"
      ],
      "grammarNotes": [
        "separable strong verb: liest durch, las durch, hat durchgelesen"
      ],
      "collocations": [
        {
          "text": "einen Vertrag gründlich durchlesen",
          "meaning": "to read through a contract carefully"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "lesen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقرأ بالكامل؛ يراجع قراءةً"
        },
        {
          "language": "ckb",
          "text": "بە تەواوی خوێندنەوە"
        },
        {
          "language": "en",
          "text": "to read through"
        },
        {
          "language": "fa",
          "text": "کامل خواندن؛ مرور کردن"
        },
        {
          "language": "kmr",
          "text": "bi tevahî xwendin"
        },
        {
          "language": "pl",
          "text": "przeczytać; przejrzeć"
        },
        {
          "language": "ro",
          "text": "a citi integral; a parcurge"
        },
        {
          "language": "ru",
          "text": "прочитать; просмотреть"
        },
        {
          "language": "sq",
          "text": "ta lexosh deri në fund"
        },
        {
          "language": "tr",
          "text": "baştan sona okumak; gözden geçirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte lesen Sie den Vertrag genau durch, bevor Sie unterschreiben.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى قراءة العقد بدقة قبل أن توقع."
            },
            {
              "language": "ckb",
              "text": "تکایە گرێبەستەکە بە وردی بخوێننەوە پێش ئەوەی واژۆ بکەن."
            },
            {
              "language": "en",
              "text": "Please read the contract carefully before you sign it."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از امضا قرارداد را دقیق بخوانید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî îmzekirinê peymanê bi baldarî bixwînin."
            },
            {
              "language": "pl",
              "text": "Proszę dokładnie przeczytać umowę przed podpisaniem."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să citiți contractul cu atenție înainte de semnare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, внимательно прочитайте договор перед подписью."
            },
            {
              "language": "sq",
              "text": "Ju lutemi lexojeni kontratën me kujdes para se ta nënshkruani."
            },
            {
              "language": "tr",
              "text": "İmzalamadan önce lütfen sözleşmeyi dikkatlice okuyun."
            }
          ]
        },
        {
          "baseText": "Ich lese mir die Anleitung heute Abend in Ruhe durch.",
          "translations": [
            {
              "language": "ar",
              "text": "سأقرأ الدليل هذا المساء بهدوء."
            },
            {
              "language": "ckb",
