      "examples": [
        {
          "baseText": "Ich rufe den Arzt.",
          "translations": [
            {
              "language": "ar",
              "text": "سأتصل بالطبيب."
            },
            {
              "language": "ckb",
              "text": "من پزیشکەکە بانگ دەکەم."
            },
            {
              "language": "en",
              "text": "I am calling the doctor."
            },
            {
              "language": "fa",
              "text": "من به دکتر زنگ می‌زنم."
            },
            {
              "language": "kmr",
              "text": "Ez bijîjk bang dikim."
            },
            {
              "language": "pl",
              "text": "Dzwonię po lekarza."
            },
            {
              "language": "ro",
