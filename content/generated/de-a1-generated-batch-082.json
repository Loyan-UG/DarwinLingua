            {
              "language": "ru",
              "text": "Я звоню врачу."
            },
            {
              "language": "sq",
              "text": "Po thërras mjekun."
            },
            {
              "language": "tr",
              "text": "Doktoru arıyorum."
            }
          ]
        },
        {
          "baseText": "Bitte rufen Sie mich morgen an.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك اتصل بي غدًا."
            },
            {
              "language": "ckb",
              "text": "تکایە سبەی پەیوەندیم پێوە بکە."
            },
            {
              "language": "en",
              "text": "Please call me tomorrow."
            },
            {
              "language": "fa",
              "text": "لطفاً فردا به من زنگ بزنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe sibê telefonî min bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zadzwonić do mnie jutro."
            },
            {
              "language": "ro",
              "text": "Vă rog să mă sunați mâine."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, позвоните мне завтра."
            },
            {
              "language": "sq",
              "text": "Ju lutem më telefononi nesër."
            },
            {
              "language": "tr",
              "text": "Lütfen yarın beni arayın."
            }
