          "language": "tr",
          "text": "ders programı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Stundenplan hängt neben der Tür.",
          "translations": [
            {
              "language": "ar",
              "text": "جدول الحصص معلق بجانب الباب."
            },
            {
              "language": "ckb",
              "text": "خشتەی وانەکان لە تەنیشت دەرگاکە هەڵواسراوە."
            },
            {
              "language": "en",
              "text": "The timetable is hanging next to the door."
            },
            {
              "language": "fa",
              "text": "برنامه درسی کنار در آویزان است."
            },
            {
              "language": "kmr",
              "text": "Bernameya dersan li kêleka derî daleqandî ye."
            },
            {
              "language": "pl",
              "text": "Plan lekcji wisi obok drzwi."
            },
            {
              "language": "ro",
              "text": "Orarul este afișat lângă ușă."
            },
            {
              "language": "ru",
              "text": "Расписание висит рядом с дверью."
            },
            {
              "language": "sq",
              "text": "Orari i mësimeve është varur pranë derës."
            },
            {
              "language": "tr",
              "text": "Ders programı kapının yanında asılı."
            }
          ]
        },
        {
          "baseText": "Ich habe morgen Mathe auf dem Stundenplan.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي غداً رياضيات في جدول الحصص."
            },
            {
              "language": "ckb",
              "text": "سبەی بیرکاریم لە خشتەی وانەکاندا هەیە."
            },
            {
              "language": "en",
              "text": "I have math on the timetable tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا در برنامه درسی‌ام ریاضی دارم."
            },
            {
              "language": "kmr",
              "text": "Sibê di bernameya min de matematîk heye."
            },
            {
              "language": "pl",
              "text": "Jutro mam matematykę w planie lekcji."
            },
            {
              "language": "ro",
              "text": "Mâine am matematică în orar."
            },
            {
              "language": "ru",
              "text": "Завтра у меня математика по расписанию."
            },
            {
              "language": "sq",
              "text": "Nesër kam matematikë në orar."
            },
            {
              "language": "tr",
              "text": "Yarın ders programımda matematik var."
            }
          ]
        }
      ]
