  "entries": [
    {
      "word": "vorgehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vorgehen",
      "pronunciationIpa": null,
      "syllableBreak": "vor-ge-hen",
      "topics": [
        "planning-and-projects",
        "business-communication",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: geht vor, ging vor, ist vorgegangen; also: nach Plan vorgehen"
      ],
      "collocations": [
        {
          "text": "systematisch vorgehen",
          "meaning": "to proceed systematically"
        },
        {
          "text": "nach Plan vorgehen",
          "meaning": "to proceed according to plan"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Vorgehen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتصرف؛ يتبع طريقة؛ يتقدم"
        },
        {
          "language": "ckb",
          "text": "بە شێوازێک کارکردن؛ پێشکەوتن"
        },
        {
          "language": "en",
          "text": "to proceed; to act; to go ahead"
        },
        {
          "language": "fa",
          "text": "اقدام کردن؛ طبق روشی پیش رفتن"
        },
        {
          "language": "kmr",
          "text": "li gor rêbazê çûn; kiryar kirin"
        },
        {
          "language": "pl",
          "text": "postępować; działać"
        },
        {
          "language": "ro",
          "text": "a proceda; a acționa"
        },
        {
          "language": "ru",
          "text": "действовать; поступать; продвигаться"
        },
        {
          "language": "sq",
          "text": "të veprosh; të procedosh"
        },
        {
          "language": "tr",
          "text": "hareket etmek; izlemek; ilerlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Bei technischen Problemen gehen wir zuerst die Checkliste durch.",
          "translations": [
            {
              "language": "ar",
              "text": "عند وجود مشاكل تقنية نراجع أولًا قائمة التحقق."
            },
            {
              "language": "ckb",
              "text": "لە کێشە تەکنیکییەکاندا سەرەتا لیستی پشکنینەکە تێدەپەڕێنین."
            },
            {
              "language": "en",
              "text": "For technical problems, we first go through the checklist."
            },
            {
              "language": "fa",
              "text": "در مشکلات فنی، اول چک‌لیست را مرور می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di pirsgirêkên teknîkî de em pêşî lîsteya kontrolê derbas dikin."
            },
            {
              "language": "pl",
              "text": "Przy problemach technicznych najpierw przechodzimy przez listę kontrolną."
            },
            {
              "language": "ro",
              "text": "În cazul problemelor tehnice, parcurgem mai întâi lista de verificare."
            },
            {
              "language": "ru",
              "text": "При технических проблемах мы сначала проходим чек-лист."
            },
            {
              "language": "sq",
              "text": "Për problemet teknike, së pari kalojmë listën e kontrollit."
            },
            {
              "language": "tr",
              "text": "Teknik sorunlarda önce kontrol listesinden geçeriz."
            }
          ]
        },
        {
          "baseText": "Wie sollen wir vorgehen, wenn der Kunde nicht antwortet?",
          "translations": [
            {
              "language": "ar",
              "text": "كيف يجب أن نتصرف إذا لم يرد العميل؟"
            },
            {
              "language": "ckb",
              "text": "ئەگەر کڕیار وەڵام نەدات، چۆن دەبێت کار بکەین؟"
            },
            {
              "language": "en",
              "text": "How should we proceed if the customer does not respond?"
            },
            {
              "language": "fa",
              "text": "اگر مشتری پاسخ ندهد، چطور باید اقدام کنیم؟"
            },
            {
              "language": "kmr",
              "text": "Heke xerîdar bersiv nede, em çawa divê biçe pêş?"
            },
            {
              "language": "pl",
              "text": "Jak mamy postąpić, jeśli klient nie odpowiada?"
            },
            {
              "language": "ro",
              "text": "Cum ar trebui să procedăm dacă clientul nu răspunde?"
            },
            {
              "language": "ru",
              "text": "Как нам действовать, если клиент не отвечает?"
            },
            {
              "language": "sq",
              "text": "Si duhet të veprojmë nëse klienti nuk përgjigjet?"
            },
            {
              "language": "tr",
              "text": "Müşteri yanıt vermezse nasıl ilerlemeliyiz?"
            }
          ]
        }
      ]
    },
    {
      "word": "der Vorgesetzte",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Vorgesetzte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Vor-ge-setz-te",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "human-resources"
      ],
      "usageLabels": [
        "formal",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine adjective noun; plural: die Vorgesetzten"
      ],
      "collocations": [
        {
          "text": "den Vorgesetzten informieren",
          "meaning": "to inform the supervisor"
        },
        {
          "text": "direkter Vorgesetzter",
          "meaning": "direct supervisor"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vorgesetzt",
          "relationLabel": "adjective/participle",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الرئيس المباشر؛ المشرف"
        },
        {
          "language": "ckb",
          "text": "سەرپەرشتیار؛ بەرپرسی سەرەوە"
        },
        {
          "language": "en",
          "text": "supervisor; superior"
        },
        {
          "language": "fa",
          "text": "سرپرست؛ مافوق"
        },
        {
          "language": "kmr",
          "text": "serperişt; serdest"
        },
        {
          "language": "pl",
          "text": "przełożony"
        },
        {
          "language": "ro",
          "text": "superior; șef direct"
        },
        {
          "language": "ru",
          "text": "руководитель; начальник"
        },
        {
          "language": "sq",
          "text": "epror; mbikëqyrës"
        },
        {
          "language": "tr",
          "text": "amir; yönetici"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte informieren Sie Ihren Vorgesetzten über die Verspätung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إبلاغ رئيسك المباشر بالتأخير."
            },
            {
              "language": "ckb",
              "text": "تکایە سەرپەرشتیارەکەت لە دواکەوتنەکە ئاگادار بکەوە."
            },
            {
              "language": "en",
              "text": "Please inform your supervisor about the delay."
            },
            {
              "language": "fa",
              "text": "لطفاً سرپرست خود را از تأخیر مطلع کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe serperiştê xwe li ser derengmayînê agahdar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę poinformować przełożonego o spóźnieniu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să vă informați superiorul despre întârziere."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сообщите своему руководителю об опоздании."
            },
            {
              "language": "sq",
              "text": "Ju lutemi informoni eprorin tuaj për vonesën."
            },
            {
              "language": "tr",
              "text": "Lütfen gecikme hakkında amirinizi bilgilendirin."
            }
          ]
        },
        {
          "baseText": "Der Vorgesetzte entscheidet, wer die Urlaubsvertretung übernimmt.",
          "translations": [
            {
              "language": "ar",
              "text": "يقرر المشرف من سيتولى تغطية الإجازة."
            },
            {
              "language": "ckb",
              "text": "سەرپەرشتیار بڕیار دەدات کێ جێگری پشوویەکە وەردەگرێت."
            },
            {
              "language": "en",
              "text": "The supervisor decides who will take over vacation cover."
            },
            {
              "language": "fa",
              "text": "سرپرست تصمیم می‌گیرد چه کسی جانشینی مرخصی را به عهده بگیرد."
            },
            {
              "language": "kmr",
              "text": "Serperişt biryar dide ka kî cihgirtiya betlaneyê digire."
            },
            {
              "language": "pl",
              "text": "Przełożony decyduje, kto przejmie zastępstwo urlopowe."
            },
            {
              "language": "ro",
              "text": "Superiorul decide cine preia înlocuirea pe perioada concediului."
            },
            {
              "language": "ru",
              "text": "Руководитель решает, кто будет замещать во время отпуска."
            },
            {
              "language": "sq",
              "text": "Eprori vendos kush do ta marrë zëvendësimin gjatë pushimit."
            },
            {
              "language": "tr",
              "text": "Amir izin vekaletini kimin üstleneceğine karar verir."
            }
          ]
        }
      ]
    },
    {
      "word": "vorhaben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vorhaben",
      "pronunciationIpa": null,
      "syllableBreak": "vor-ha-ben",
      "topics": [
        "everyday-life",
        "planning-and-projects",
        "social-and-relationships"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: hat vor, hatte vor, hat vorgehabt"
      ],
      "collocations": [
        {
          "text": "etwas vorhaben",
          "meaning": "to plan to do something"
        },
        {
          "text": "heute Abend etwas vorhaben",
          "meaning": "to have plans tonight"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Vorhaben",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينوي؛ لديه خطط"
        },
        {
          "language": "ckb",
          "text": "نیازبوون؛ پلان هەبوون"
        },
        {
          "language": "en",
          "text": "to plan; to intend; to have plans"
        },
        {
          "language": "fa",
          "text": "قصد داشتن؛ برنامه داشتن"
        },
        {
          "language": "kmr",
          "text": "niyet kirin; plan hebûn"
        },
        {
          "language": "pl",
          "text": "zamierzać; mieć plany"
        },
        {
          "language": "ro",
          "text": "a intenționa; a avea planuri"
        },
        {
          "language": "ru",
          "text": "планировать; намереваться"
        },
        {
          "language": "sq",
          "text": "të kesh ndërmend; të kesh plane"
        },
        {
          "language": "tr",
          "text": "niyet etmek; planı olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Was haben Sie für das nächste Teammeeting vor?",
          "translations": [
            {
              "language": "ar",
              "text": "ما الذي تخطط له لاجتماع الفريق القادم؟"
            },
            {
              "language": "ckb",
              "text": "بۆ کۆبوونەوەی داهاتووی تیم چی لە پلاندا هەیە؟"
            },
            {
              "language": "en",
              "text": "What are you planning for the next team meeting?"
            },
            {
              "language": "fa",
              "text": "برای جلسه بعدی تیم چه برنامه‌ای دارید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn ji bo civîna tîmê ya bê çi plan dikin?"
            },
            {
              "language": "pl",
              "text": "Co planują Państwo na następne spotkanie zespołu?"
            },
            {
              "language": "ro",
              "text": "Ce aveți în plan pentru următoarea ședință de echipă?"
            },
            {
              "language": "ru",
              "text": "Что вы планируете для следующей командной встречи?"
            },
            {
              "language": "sq",
              "text": "Çfarë keni planifikuar për takimin e ardhshëm të ekipit?"
            },
            {
              "language": "tr",
              "text": "Bir sonraki ekip toplantısı için ne planlıyorsunuz?"
            }
          ]
        },
        {
          "baseText": "Am Sonntag haben wir vor, meine Eltern zu besuchen.",
          "translations": [
            {
              "language": "ar",
              "text": "نخطط يوم الأحد لزيارة والديّ."
            },
            {
              "language": "ckb",
              "text": "یەکشەممە پلانمان هەیە سەردانی دایک و باوکم بکەین."
            },
            {
              "language": "en",
              "text": "On Sunday, we plan to visit my parents."
            },
            {
              "language": "fa",
