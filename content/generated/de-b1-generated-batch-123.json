  "entries": [
    {
      "word": "sondern",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Conjunction",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "son-dern",
      "topics": [
        "business-communication",
        "everyday-life",
        "education-and-training"
      ],
      "usageLabels": [
        "everyday",
        "written",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "coordinating conjunction after a negative statement; contrasts and corrects information"
      ],
      "collocations": [
        {
          "text": "nicht ..., sondern ...",
          "meaning": "not ..., but rather ..."
        },
        {
          "text": "nicht heute, sondern morgen",
          "meaning": "not today, but tomorrow"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "besonders",
          "relationLabel": "related adverb/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بل؛ وإنما"
        },
        {
          "language": "ckb",
          "text": "بەڵکو؛ نە ... بەڵکو"
        },
        {
          "language": "en",
          "text": "but rather; but instead"
        },
        {
          "language": "fa",
          "text": "بلکه؛ بلکه برعکس"
        },
        {
          "language": "kmr",
          "text": "belkî; lê berevajî"
        },
        {
          "language": "pl",
          "text": "lecz; tylko; ale raczej"
        },
        {
          "language": "ro",
          "text": "ci; ci mai degrabă"
        },
        {
          "language": "ru",
          "text": "а; а именно; но скорее"
        },
        {
          "language": "sq",
          "text": "por; por përkundrazi"
        },
        {
          "language": "tr",
          "text": "aksine; bilakis; değil ..., बल्कि ..."
        }
      ],
      "examples": [
        {
          "baseText": "Wir liefern nicht am Freitag, sondern am Montag.",
          "translations": [
            {
              "language": "ar",
              "text": "لن نسلّم يوم الجمعة، بل يوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "ئێمە هەینی ناگەیەنین، بەڵکو دووشەممە دەگەیەنین."
            },
            {
              "language": "en",
              "text": "We are not delivering on Friday, but on Monday."
            },
            {
              "language": "fa",
              "text": "ما جمعه تحویل نمی‌دهیم، بلکه دوشنبه تحویل می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Em roja înê radest nakin, belkî duşemiyê radest dikin."
            },
            {
              "language": "pl",
              "text": "Nie dostarczamy w piątek, tylko w poniedziałek."
            },
            {
              "language": "ro",
              "text": "Nu livrăm vineri, ci luni."
            },
            {
              "language": "ru",
              "text": "Мы доставляем не в пятницу, а в понедельник."
            },
            {
              "language": "sq",
              "text": "Nuk dorëzojmë të premten, por të hënën."
            },
            {
              "language": "tr",
              "text": "Cuma değil, pazartesi teslim ediyoruz."
            }
          ]
        },
        {
          "baseText": "Das ist keine Rechnung, sondern nur ein Angebot.",
          "translations": [
            {
              "language": "ar",
              "text": "هذه ليست فاتورة، بل مجرد عرض."
            },
            {
              "language": "ckb",
              "text": "ئەمە فاکتور نییە، بەڵکو تەنها پێشنیارێکە."
            },
            {
              "language": "en",
              "text": "This is not an invoice, but only an offer."
            },
            {
              "language": "fa",
              "text": "این فاکتور نیست، بلکه فقط یک پیشنهاد است."
            },
            {
              "language": "kmr",
              "text": "Ev ne fatûre ye, belkî tenê pêşniyarek e."
            },
            {
              "language": "pl",
              "text": "To nie jest faktura, tylko oferta."
            },
            {
              "language": "ro",
              "text": "Aceasta nu este o factură, ci doar o ofertă."
            },
            {
              "language": "ru",
              "text": "Это не счёт, а только предложение."
            },
            {
              "language": "sq",
              "text": "Kjo nuk është faturë, por vetëm ofertë."
            },
            {
              "language": "tr",
              "text": "Bu bir fatura değil, sadece bir tekliftir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Sonderregelung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Sonderregelungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Son-der-re-ge-lung",
      "topics": [
        "law-and-compliance",
        "documents-and-administration",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Sonderregelung vereinbaren",
          "meaning": "to agree on a special rule"
        },
        {
          "text": "eine Sonderregelung gelten",
          "meaning": "a special rule applies"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "besonders",
          "relationLabel": "adjective/adverb",
          "note": null
        },
        {
          "lemma": "die Regelung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ترتيب خاص؛ قاعدة استثنائية"
        },
        {
          "language": "ckb",
          "text": "ڕێکخستنی تایبەت؛ ڕێسای تایبەت"
        },
        {
          "language": "en",
          "text": "special regulation; special arrangement"
        },
        {
          "language": "fa",
          "text": "مقرره خاص؛ ترتیب استثنایی"
        },
        {
          "language": "kmr",
          "text": "rêziknameya taybet; rêkeftina taybet"
        },
        {
          "language": "pl",
          "text": "specjalne uregulowanie; wyjątek"
        },
        {
          "language": "ro",
          "text": "reglementare specială; aranjament special"
        },
        {
          "language": "ru",
          "text": "особое правило; специальное положение"
        },
        {
          "language": "sq",
          "text": "rregullim i veçantë; marrëveshje e veçantë"
        },
        {
          "language": "tr",
          "text": "özel düzenleme; istisnai kural"
        }
      ],
      "examples": [
        {
          "baseText": "Für Eltern mit kleinen Kindern gibt es eine Sonderregelung zur Arbeitszeit.",
          "translations": [
            {
              "language": "ar",
              "text": "توجد قاعدة خاصة لساعات العمل للآباء والأمهات الذين لديهم أطفال صغار."
            },
            {
              "language": "ckb",
              "text": "بۆ دایک و باوکی خاوەن منداڵی بچووک ڕێکخستنێکی تایبەت بۆ کاتی کار هەیە."
            },
            {
              "language": "en",
              "text": "There is a special arrangement for working hours for parents with small children."
            },
            {
              "language": "fa",
              "text": "برای والدینی که فرزند کوچک دارند، مقرره خاصی درباره ساعات کار وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Ji bo dê û bavên bi zarokên piçûk rêkeftineke taybet li ser demjimêrên kar heye."
            },
            {
              "language": "pl",
              "text": "Dla rodziców z małymi dziećmi istnieje specjalne uregulowanie dotyczące czasu pracy."
            },
            {
              "language": "ro",
              "text": "Pentru părinții cu copii mici există o reglementare specială privind programul de lucru."
            },
            {
              "language": "ru",
              "text": "Для родителей с маленькими детьми действует особое правило по рабочему времени."
            },
            {
              "language": "sq",
              "text": "Për prindërit me fëmijë të vegjël ka një rregullim të veçantë për orarin e punës."
            },
            {
              "language": "tr",
              "text": "Küçük çocuğu olan ebeveynler için çalışma saatleriyle ilgili özel bir düzenleme var."
            }
          ]
        },
        {
          "baseText": "Die Sonderregelung gilt nur bis Ende des Jahres.",
          "translations": [
            {
              "language": "ar",
              "text": "تسري القاعدة الخاصة فقط حتى نهاية السنة."
            },
            {
              "language": "ckb",
              "text": "ڕێسای تایبەتەکە تەنها تا کۆتایی ساڵ کاریگەرە."
            },
            {
              "language": "en",
              "text": "The special regulation applies only until the end of the year."
            },
            {
              "language": "fa",
              "text": "مقرره خاص فقط تا پایان سال معتبر است."
            },
            {
              "language": "kmr",
              "text": "Rêziknameya taybet tenê heta dawiya salê derbasdar e."
            },
            {
              "language": "pl",
              "text": "Specjalne uregulowanie obowiązuje tylko do końca roku."
            },
            {
              "language": "ro",
              "text": "Reglementarea specială se aplică doar până la sfârșitul anului."
            },
            {
              "language": "ru",
              "text": "Особое правило действует только до конца года."
            },
            {
              "language": "sq",
              "text": "Rregullimi i veçantë vlen vetëm deri në fund të vitit."
            },
            {
              "language": "tr",
              "text": "Özel düzenleme yalnızca yıl sonuna kadar geçerlidir."
            }
          ]
        }
      ]
    },
