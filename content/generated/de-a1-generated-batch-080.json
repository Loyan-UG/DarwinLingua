        {
          "language": "sq",
          "text": "faturë; llogari"
        },
        {
          "language": "tr",
          "text": "fatura; hesap"
        }
      ],
      "examples": [
        {
          "baseText": "Kann ich bitte die Rechnung haben?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني الحصول على الفاتورة من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم پسووڵەکە وەربگرم، تکایە؟"
            },
            {
              "language": "en",
              "text": "Can I have the bill, please?"
            },
            {
              "language": "fa",
              "text": "می‌توانم لطفاً صورتحساب را داشته باشم؟"
            },
            {
              "language": "kmr",
              "text": "Ma ez dikarim fatûreyê bistînim, ji kerema xwe?"
            },
            {
              "language": "pl",
              "text": "Czy mogę prosić o rachunek?"
            },
            {
              "language": "ro",
              "text": "Pot primi nota de plată, vă rog?"
            },
            {
              "language": "ru",
              "text": "Можно мне счёт, пожалуйста?"
            },
            {
              "language": "sq",
              "text": "A mund ta marr faturën, ju lutem?"
            },
            {
              "language": "tr",
              "text": "Hesabı alabilir miyim lütfen?"
            }
          ]
        },
        {
          "baseText": "Die Rechnung ist schon bezahlt.",
          "translations": [
            {
              "language": "ar",
              "text": "الفاتورة مدفوعة بالفعل."
            },
            {
              "language": "ckb",
              "text": "پسووڵەکە پێشتر دراوە."
            },
            {
              "language": "en",
              "text": "The bill is already paid."
            },
            {
              "language": "fa",
              "text": "صورتحساب قبلاً پرداخت شده است."
            },
            {
              "language": "kmr",
              "text": "Fatûre jixwe hatiye dayîn."
            },
            {
              "language": "pl",
              "text": "Rachunek jest już zapłacony."
            },
            {
              "language": "ro",
              "text": "Factura este deja plătită."
            },
            {
              "language": "ru",
              "text": "Счёт уже оплачен."
            },
            {
              "language": "sq",
              "text": "Fatura është paguar tashmë."
            },
            {
              "language": "tr",
              "text": "Fatura zaten ödendi."
            }
          ]
        }
      ]
