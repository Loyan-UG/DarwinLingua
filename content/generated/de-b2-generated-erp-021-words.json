  "entries": [
    {
      "word": "Preislistenpreis",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Preislistenpreise",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Preis-lis-ten-preis",
      "topics": [
        "sales-and-customers",
        "finance-and-accounting",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; standard price from a price list"
      ],
      "collocations": [
        {
          "text": "den Preislistenpreis übernehmen",
          "meaning": "to copy the list price"
        },
        {
          "text": "vom Preislistenpreis abweichen",
          "meaning": "to differ from the list price"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Preisliste",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Preis",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "سعر قائمة الأسعار"
        },
        {
          "language": "ckb",
          "text": "نرخی لیستی نرخ"
        },
        {
          "language": "en",
          "text": "list price"
        },
        {
          "language": "fa",
          "text": "قیمت لیست؛ قیمت رسمی"
        },
        {
          "language": "kmr",
          "text": "bihayê lîsteya bihayan"
        },
        {
          "language": "pl",
          "text": "cena z cennika"
        },
        {
          "language": "ro",
          "text": "preț de listă"
        },
        {
          "language": "ru",
          "text": "цена по прайс-листу"
        },
        {
          "language": "sq",
          "text": "çmim liste"
        },
        {
          "language": "tr",
          "text": "liste fiyatı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Preislistenpreis wird im ERP automatisch in das Angebot übernommen.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم نقل سعر قائمة الأسعار تلقائيًا إلى العرض في ERP."
            },
            {
              "language": "ckb",
              "text": "نرخی لیستی نرخ لە ERP دا خۆکارانە دەگوازرێتەوە ناو پێشنیارەکە."
            },
            {
              "language": "en",
              "text": "The list price is automatically copied into the quotation in the ERP."
            },
            {
              "language": "fa",
              "text": "قیمت لیست به‌صورت خودکار در ERP وارد پیشنهاد قیمت می‌شود."
            },
            {
              "language": "kmr",
              "text": "Bihayê lîsteya bihayan di ERP de xweber tê veguhastin nav pêşniyarê."
            },
            {
              "language": "pl",
              "text": "Cena z cennika jest automatycznie przenoszona w ERP do oferty."
            },
            {
              "language": "ro",
              "text": "Prețul de listă este preluat automat în oferta din ERP."
            },
            {
              "language": "ru",
              "text": "Цена по прайс-листу автоматически переносится в предложение в ERP."
            },
            {
              "language": "sq",
              "text": "Çmimi i listës kalon automatikisht në ofertë në ERP."
            },
            {
              "language": "tr",
              "text": "Liste fiyatı ERP’de otomatik olarak teklife aktarılır."
            }
          ]
        },
        {
          "baseText": "Der Kunde fragt, warum der Angebotspreis höher ist als der Preislistenpreis.",
          "translations": [
            {
              "language": "ar",
              "text": "يسأل العميل لماذا سعر العرض أعلى من سعر قائمة الأسعار."
            },
            {
              "language": "ckb",
              "text": "کڕیار دەپرسێت بۆچی نرخی پێشنیارەکە لە نرخی لیستی نرخ بەرزترە."
            },
            {
              "language": "en",
              "text": "The customer asks why the quotation price is higher than the list price."
            },
            {
              "language": "fa",
              "text": "مشتری می‌پرسد چرا قیمت پیشنهادی از قیمت لیست بالاتر است."
            },
            {
              "language": "kmr",
              "text": "Mişterî dipirse çima bihayê pêşniyarê ji bihayê lîsteyê bilindtir e."
            },
            {
              "language": "pl",
              "text": "Klient pyta, dlaczego cena ofertowa jest wyższa niż cena z cennika."
            },
            {
              "language": "ro",
              "text": "Clientul întreabă de ce prețul din ofertă este mai mare decât prețul de listă."
            },
            {
              "language": "ru",
              "text": "Клиент спрашивает, почему цена в предложении выше цены по прайс-листу."
            },
            {
              "language": "sq",
              "text": "Klienti pyet pse çmimi i ofertës është më i lartë se çmimi i listës."
            },
            {
              "language": "tr",
              "text": "Müşteri teklif fiyatının neden liste fiyatından yüksek olduğunu soruyor."
            }
          ]
        }
      ]
    },
    {
      "word": "Preisrundung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Preisrundungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Preis-run-dung",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; rounding rule applied to prices"
      ],
      "collocations": [
        {
          "text": "eine Preisrundung anwenden",
          "meaning": "to apply price rounding"
        },
        {
          "text": "die Preisrundung prüfen",
          "meaning": "to check price rounding"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Preis",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "runden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تقريب السعر"
        },
        {
          "language": "ckb",
          "text": "ڕووندکردنی نرخ"
        },
        {
          "language": "en",
          "text": "price rounding"
        },
        {
          "language": "fa",
          "text": "گرد کردن قیمت"
        },
        {
          "language": "kmr",
          "text": "giloverkirina bihayê"
        },
        {
          "language": "pl",
          "text": "zaokrąglenie ceny"
        },
        {
          "language": "ro",
          "text": "rotunjirea prețului"
        },
        {
          "language": "ru",
          "text": "округление цены"
        },
        {
          "language": "sq",
          "text": "rrumbullakim çmimi"
        },
        {
          "language": "tr",
          "text": "fiyat yuvarlama"
        }
      ],
      "examples": [
        {
          "baseText": "Die Preisrundung im ERP rundet den Verkaufspreis auf zwei Nachkommastellen.",
          "translations": [
            {
              "language": "ar",
              "text": "تقرب قاعدة تقريب السعر في ERP سعر البيع إلى منزلتين عشريتين."
            },
            {
              "language": "ckb",
              "text": "ڕووندکردنی نرخ لە ERP دا نرخی فرۆشتن بۆ دوو خانەی دوای خاڵ ڕووند دەکات."
            },
            {
              "language": "en",
              "text": "The price rounding in the ERP rounds the sales price to two decimal places."
            },
            {
              "language": "fa",
              "text": "گرد کردن قیمت در ERP قیمت فروش را تا دو رقم اعشار گرد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Giloverkirina bihayê di ERP de bihayê firotanê heya du xaneyên piştî xalê gilover dike."
            },
            {
              "language": "pl",
              "text": "Zaokrąglenie ceny w ERP zaokrągla cenę sprzedaży do dwóch miejsc po przecinku."
            },
            {
              "language": "ro",
              "text": "Rotunjirea prețului în ERP rotunjește prețul de vânzare la două zecimale."
            },
            {
              "language": "ru",
              "text": "Округление цены в ERP округляет продажную цену до двух знаков после запятой."
            },
            {
              "language": "sq",
              "text": "Rrumbullakimi i çmimit në ERP e rrumbullakos çmimin e shitjes në dy shifra dhjetore."
            },
            {
              "language": "tr",
              "text": "ERP’deki fiyat yuvarlama satış fiyatını iki ondalık basamağa yuvarlar."
            }
          ]
        },
        {
          "baseText": "Nach der Preisrundung unterscheidet sich der Endbetrag um wenige Cent.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تقريب السعر يختلف المبلغ النهائي ببضعة سنتات."
            },
            {
              "language": "ckb",
              "text": "دوای ڕووندکردنی نرخ، بڕی کۆتایی بە چەند سەنتێک جیاواز دەبێت."
            },
            {
              "language": "en",
              "text": "After price rounding, the final amount differs by a few cents."
            },
            {
              "language": "fa",
              "text": "پس از گرد کردن قیمت، مبلغ نهایی چند سنت تفاوت دارد."
            },
            {
              "language": "kmr",
              "text": "Piştî giloverkirina bihayê, mîqdara dawî bi çend sentan cuda dibe."
            },
            {
              "language": "pl",
              "text": "Po zaokrągleniu ceny kwota końcowa różni się o kilka centów."
            },
            {
              "language": "ro",
              "text": "După rotunjirea prețului, suma finală diferă cu câțiva cenți."
            },
            {
              "language": "ru",
              "text": "После округления цены итоговая сумма отличается на несколько центов."
            },
            {
              "language": "sq",
              "text": "Pas rrumbullakimit të çmimit, shuma përfundimtare ndryshon me disa centë."
            },
            {
              "language": "tr",
              "text": "Fiyat yuvarlamadan sonra son tutar birkaç sent farklı olur."
            }
          ]
        }
      ]
    },
