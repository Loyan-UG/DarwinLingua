      "meanings": [
        {
          "language": "ar",
          "text": "استخدام السعر"
        },
        {
          "language": "ckb",
          "text": "بەکارهێنانی نرخ"
        },
        {
          "language": "en",
          "text": "price usage"
        },
        {
          "language": "fa",
          "text": "کاربرد قیمت"
        },
        {
          "language": "kmr",
          "text": "bikaranîna bihayê"
        },
        {
          "language": "pl",
