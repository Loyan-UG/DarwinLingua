        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; product or goods group used for classification and reporting"
      ],
      "collocations": [
        {
          "text": "eine Warengruppe zuordnen",
          "meaning": "to assign a product group"
        },
        {
          "text": "nach Warengruppe auswerten",
          "meaning": "to analyze by product group"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Ware",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Gruppe",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مجموعة السلع"
        },
        {
          "language": "ckb",
          "text": "گرووپی کاڵا"
        },
        {
          "language": "en",
          "text": "product group; goods group"
        },
        {
          "language": "fa",
          "text": "گروه کالا"
        },
        {
          "language": "kmr",
          "text": "koma malan"
        },
        {
          "language": "pl",
          "text": "grupa towarowa"
        },
        {
          "language": "ro",
          "text": "grupă de mărfuri"
        },
        {
          "language": "ru",
          "text": "товарная группа"
        },
        {
          "language": "sq",
          "text": "grup mallrash"
        },
        {
          "language": "tr",
          "text": "ürün grubu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Warengruppe wird im ERP für Statistik und Kontenfindung verwendet.",
          "translations": [
            {
              "language": "ar",
              "text": "تُستخدم مجموعة السلع في ERP للإحصاءات وتحديد الحسابات."
            },
            {
              "language": "ckb",
              "text": "گرووپی کاڵا لە ERP دا بۆ ئامار و دۆزینەوەی هەژمار بەکاردێت."
            },
            {
              "language": "en",
              "text": "The product group is used in the ERP for statistics and account determination."
            },
            {
              "language": "fa",
              "text": "گروه کالا در ERP برای آمار و تعیین حساب‌ها استفاده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Koma malan di ERP de ji bo statistik û diyarkirina hesabê tê bikaranîn."
            },
            {
              "language": "pl",
              "text": "Grupa towarowa jest używana w ERP do statystyk i ustalania kont."
            },
            {
              "language": "ro",
              "text": "Grupa de mărfuri este folosită în ERP pentru statistici și determinarea conturilor."
            },
            {
              "language": "ru",
              "text": "Товарная группа используется в ERP для статистики и определения счетов."
            },
            {
              "language": "sq",
              "text": "Grupi i mallrave përdoret në ERP për statistika dhe përcaktimin e llogarive."
            },
            {
              "language": "tr",
              "text": "Ürün grubu ERP’de istatistikler ve hesap belirleme için kullanılır."
            }
          ]
        },
        {
          "baseText": "Der Einkauf möchte die neue Warengruppe erst nach Rücksprache mit Controlling anlegen.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد قسم المشتريات إنشاء مجموعة السلع الجديدة فقط بعد التشاور مع قسم الرقابة المالية."
            },
            {
              "language": "ckb",
              "text": "بەشی کڕین دەیەوێت گرووپی کاڵای نوێ تەنها دوای ڕاوێژ لەگەڵ کۆنترۆڵینگ دروست بکات."
            },
            {
              "language": "en",
              "text": "Purchasing wants to create the new product group only after consulting controlling."
            },
            {
              "language": "fa",
              "text": "واحد خرید می‌خواهد گروه کالای جدید را فقط پس از هماهنگی با کنترل مالی ایجاد کند."
            },
            {
              "language": "kmr",
              "text": "Beşa kirînê dixwaze koma malan a nû tenê piştî şêwirmendî bi kontrolê re çêbike."
            },
            {
              "language": "pl",
              "text": "Dział zakupów chce utworzyć nową grupę towarową dopiero po konsultacji z controllingiem."
            },
            {
              "language": "ro",
              "text": "Achizițiile doresc să creeze noua grupă de mărfuri doar după consultarea controllingului."
            },
            {
              "language": "ru",
              "text": "Отдел закупок хочет создать новую товарную группу только после согласования с контроллингом."
            },
            {
              "language": "sq",
              "text": "Blerja dëshiron ta krijojë grupin e ri të mallrave vetëm pas konsultimit me kontrollingu."
            },
            {
              "language": "tr",
              "text": "Satın alma yeni ürün grubunu ancak kontrol departmanıyla görüştükten sonra oluşturmak istiyor."
            }
          ]
        }
      ]
    },
    {
      "word": "Zahlungskondition",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Zahlungskonditionen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Zah-lungs-kon-di-ti-on",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; payment condition such as due date, discount, or installment rule"
      ],
      "collocations": [
        {
          "text": "eine Zahlungskondition vereinbaren",
          "meaning": "to agree on a payment term"
        },
        {
          "text": "Zahlungskonditionen pflegen",
          "meaning": "to maintain payment terms"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zahlung",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Kondition",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شرط الدفع"
        },
        {
          "language": "ckb",
          "text": "مەرجی پارەدان"
        },
        {
          "language": "en",
          "text": "payment term; payment condition"
        },
        {
          "language": "fa",
          "text": "شرط پرداخت"
        },
        {
          "language": "kmr",
          "text": "mercê dayînê"
        },
        {
          "language": "pl",
          "text": "warunek płatności"
        },
        {
          "language": "ro",
          "text": "condiție de plată"
        },
        {
          "language": "ru",
          "text": "условие оплаты"
        },
        {
          "language": "sq",
          "text": "kusht pagese"
        },
        {
          "language": "tr",
          "text": "ödeme koşulu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Zahlungskondition wird im ERP aus dem Kundenstamm in den Auftrag übernommen.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم نقل شرط الدفع في ERP من بيانات العميل الأساسية إلى الطلب."
            },
            {
              "language": "ckb",
              "text": "مەرجی پارەدان لە ERP دا لە داتای بنەڕەتیی کڕیارەوە بۆ داواکاری دەگوازرێتەوە."
            },
            {
              "language": "en",
              "text": "The payment term is copied in the ERP from the customer master data into the order."
            },
            {
              "language": "fa",
              "text": "شرط پرداخت در ERP از داده‌های پایه مشتری به سفارش منتقل می‌شود."
            },
            {
              "language": "kmr",
              "text": "Mercê dayînê di ERP de ji daneyên bingehîn ên mişterî tê girtin û dikeve fermanê."
            },
            {
              "language": "pl",
              "text": "Warunek płatności jest przenoszony w ERP z danych podstawowych klienta do zamówienia."
            },
            {
              "language": "ro",
              "text": "Condiția de plată este preluată în ERP din datele master ale clientului în comandă."
            },
            {
              "language": "ru",
              "text": "Условие оплаты переносится в ERP из основных данных клиента в заказ."
            },
            {
              "language": "sq",
              "text": "Kushti i pagesës merret në ERP nga të dhënat bazë të klientit në porosi."
            },
            {
              "language": "tr",
              "text": "Ödeme koşulu ERP’de müşteri ana verilerinden siparişe aktarılır."
            }
          ]
        },
        {
          "baseText": "Der Kunde akzeptiert die Zahlungskondition nur, wenn Skonto möglich ist.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يقبل العميل شرط الدفع إلا إذا كان الخصم النقدي ممكنًا."
            },
            {
              "language": "ckb",
              "text": "کڕیار مەرجی پارەدان تەنها کاتێک قبوڵ دەکات کە داشکاندنی خێرا پارەدان هەبێت."
            },
            {
              "language": "en",
              "text": "The customer accepts the payment term only if a cash discount is possible."
            },
            {
              "language": "fa",
              "text": "مشتری شرط پرداخت را فقط در صورت امکان تخفیف پرداخت زودهنگام می‌پذیرد."
            },
            {
              "language": "kmr",
              "text": "Mişterî mercê dayînê tenê dema qebûl dike ku daxistina zûdayînê mumkin be."
            },
            {
              "language": "pl",
              "text": "Klient akceptuje warunek płatności tylko wtedy, gdy możliwe jest skonto."
            },
            {
              "language": "ro",
              "text": "Clientul acceptă condiția de plată doar dacă este posibil un discount de plată rapidă."
            },
            {
              "language": "ru",
              "text": "Клиент принимает условие оплаты только если возможна скидка за раннюю оплату."
            },
            {
              "language": "sq",
              "text": "Klienti e pranon kushtin e pagesës vetëm nëse është e mundur zbritja për pagesë të shpejtë."
            },
            {
              "language": "tr",
              "text": "Müşteri ödeme koşulunu yalnızca erken ödeme indirimi mümkünse kabul eder."
            }
          ]
        }
      ]
    },
