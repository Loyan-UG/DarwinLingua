      "examples": [
        {
          "baseText": "Das Zahlungsziel wird im ERP automatisch aus der Rechnung berechnet.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم حساب مهلة الدفع في ERP تلقائيًا من الفاتورة."
            },
            {
              "language": "ckb",
              "text": "کاتی پارەدان لە ERP دا خۆکارانە لە فاکتورەکەوە هەژمار دەکرێت."
            },
            {
              "language": "en",
              "text": "The payment deadline is calculated automatically in the ERP from the invoice."
            },
            {
              "language": "fa",
