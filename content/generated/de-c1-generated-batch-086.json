        }
      ],
      "wordFamilies": [
        {
          "lemma": "problematisieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "طرح إشكالي؛ مناقشة نقدية"
        },
        {
          "language": "ckb",
          "text": "کێشەیی کردن؛ خستنە بەر باسی ڕەخنەیی"
        },
        {
          "language": "en",
          "text": "problematization; critical questioning"
        },
        {
          "language": "fa",
          "text": "مسئله‌مند سازی؛ طرح انتقادی"
        },
        {
          "language": "kmr",
          "text": "problematîzekirin"
        },
        {
          "language": "pl",
          "text": "problematyzacja"
        },
        {
          "language": "ro",
          "text": "problematizare"
        },
        {
          "language": "ru",
          "text": "проблематизация"
        },
        {
          "language": "sq",
          "text": "problematizim"
        },
        {
          "language": "tr",
          "text": "sorunsallaştırma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Problematisierung der Kennzahl zeigte, dass sie falsche Anreize setzt.",
          "translations": [
            {
              "language": "ar",
              "text": "أظهر طرح المؤشر كإشكالية أنه يخلق حوافز خاطئة."
            },
            {
              "language": "ckb",
              "text": "کێشەیی کردنی پێوەرەکە پیشانی دا کە هاندەری هەڵە دروست دەکات."
            },
            {
              "language": "en",
              "text": "The problematization of the metric showed that it creates wrong incentives."
            },
            {
              "language": "fa",
              "text": "مسئله‌مند سازی شاخص نشان داد که انگیزه‌های نادرست ایجاد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Problematîzekirina pîvanê nîşan da ku ew teşwîqên şaş çêdike."
            },
            {
              "language": "pl",
              "text": "Problematyzacja wskaźnika pokazała, że tworzy on błędne zachęty."
            },
            {
              "language": "ro",
              "text": "Problematizarea indicatorului a arătat că acesta creează stimulente greșite."
            },
            {
              "language": "ru",
              "text": "Проблематизация показателя показала, что он создает неверные стимулы."
            },
            {
              "language": "sq",
              "text": "Problematizimi i treguesit tregoi se ai krijon nxitje të gabuara."
            },
            {
              "language": "tr",
              "text": "Göstergenin sorunsallaştırılması yanlış teşvikler yarattığını gösterdi."
            }
          ]
        },
        {
          "baseText": "In der Ausstellung gelingt die Problematisierung kolonialer Sammlungspraktiken ohne moralisierenden Ton.",
          "translations": [
            {
              "language": "ar",
              "text": "ينجح المعرض في مناقشة ممارسات الجمع الاستعمارية نقدياً من دون نبرة وعظية."
            },
            {
              "language": "ckb",
              "text": "لە پێشانگاکەدا کێشەیی کردنی شێوازەکانی کۆکردنەوەی کۆلۆنیالی بەبێ دەنگی ئەخلاقی سەرکەوتووە."
            },
            {
              "language": "en",
              "text": "The exhibition succeeds in problematizing colonial collecting practices without a moralizing tone."
            },
            {
              "language": "fa",
              "text": "نمایشگاه موفق می‌شود شیوه‌های گردآوری استعماری را بدون لحن اخلاق‌زده مسئله‌مند کند."
            },
            {
              "language": "kmr",
              "text": "Pêşangeh di problematîzekirina pratîkên komkirina kolonîal de bê dengê moralî serkeftî ye."
            },
            {
              "language": "pl",
              "text": "Wystawie udaje się problematyzować kolonialne praktyki kolekcjonerskie bez moralizującego tonu."
            },
            {
              "language": "ro",
              "text": "Expoziția reușește problematizarea practicilor coloniale de colecționare fără ton moralizator."
            },
            {
              "language": "ru",
              "text": "Выставке удается проблематизировать колониальные практики собирания без морализаторского тона."
            },
            {
              "language": "sq",
              "text": "Ekspozita arrin të problematizojë praktikat koloniale të mbledhjes pa ton moralizues."
            },
            {
              "language": "tr",
              "text": "Sergi, sömürgeci toplama pratiklerini ahlakçı bir ton olmadan sorunsallaştırmayı başarıyor."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
