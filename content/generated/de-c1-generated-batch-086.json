      "word": "der Problemdruck",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "infinitive": null,
      "syllableBreak": "Pro-blem-druck",
      "topics": [
        "management-and-leadership",
        "quality-and-risk",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "masculine compound noun; usually singular"
      ],
      "collocations": [
        {
          "text": "steigender Problemdruck",
          "meaning": "increasing pressure to solve a problem"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Problem",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Druck",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ضغط المشكلة؛ الحاجة الملحة للحل"
        },
        {
          "language": "ckb",
          "text": "فشاری کێشە؛ پێویستیی فەوری بۆ چارەسەر"
        },
        {
          "language": "en",
          "text": "pressure caused by a problem; urgency to act"
        },
        {
          "language": "fa",
          "text": "فشار مسئله؛ ضرورت اقدام"
        },
        {
          "language": "kmr",
          "text": "zexta pirsgirêkê"
        },
        {
          "language": "pl",
          "text": "presja problemu"
        },
        {
          "language": "ro",
          "text": "presiune a problemei"
        },
        {
          "language": "ru",
          "text": "давление проблемы; срочность решения"
        },
        {
          "language": "sq",
          "text": "presion problemi"
        },
        {
          "language": "tr",
          "text": "sorun baskısı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Problemdruck stieg, als die Beschwerden wichtiger Kunden öffentlich wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "ازداد ضغط المشكلة عندما أصبحت شكاوى عملاء مهمين علنية."
            },
            {
              "language": "ckb",
              "text": "فشاری کێشەکە زیاد بوو کاتێک سکاڵای کڕیارە گرنگەکان ئاشکرا بوو."
            },
            {
              "language": "en",
              "text": "The pressure to act increased when complaints from key customers became public."
            },
            {
              "language": "fa",
              "text": "فشار مسئله زمانی افزایش یافت که شکایت مشتریان مهم عمومی شد."
            },
            {
              "language": "kmr",
              "text": "Zexta pirsgirêkê zêde bû dema gazinên xerîdarên girîng bûn giştî."
            },
            {
              "language": "pl",
              "text": "Presja problemu wzrosła, gdy skargi ważnych klientów stały się publiczne."
            },
            {
              "language": "ro",
              "text": "Presiunea problemei a crescut când reclamațiile clienților importanți au devenit publice."
            },
            {
              "language": "ru",
              "text": "Давление проблемы выросло, когда жалобы ключевых клиентов стали публичными."
            },
            {
              "language": "sq",
              "text": "Presioni i problemit u rrit kur ankesat e klientëve kryesorë u bënë publike."
            },
            {
              "language": "tr",
              "text": "Önemli müşterilerin şikayetleri kamuya açılınca sorun baskısı arttı."
            }
          ]
        },
        {
          "baseText": "In der Kommunalpolitik entsteht Problemdruck oft erst, wenn alltägliche Einschränkungen sichtbar werden.",
          "translations": [
            {
