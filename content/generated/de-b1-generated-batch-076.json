  "entries": [
    {
      "word": "hinweisen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hinweisen",
      "pronunciationIpa": null,
      "syllableBreak": "hin-wei-sen",
      "topics": [
        "business-communication",
        "customer-service",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "business",
        "polite"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; past participle: hingewiesen; often used with auf plus accusative"
      ],
      "collocations": [
        {
          "text": "auf einen Fehler hinweisen",
          "meaning": "to point out an error"
        },
        {
          "text": "auf die Regeln hinweisen",
          "meaning": "to point out the rules"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Hinweis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "weisen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يشير إلى؛ ينبه إلى"
        },
        {
          "language": "ckb",
          "text": "ئاماژەکردن بە؛ ئاگادارکردنەوە"
        },
        {
          "language": "en",
          "text": "to point out; to indicate; to draw attention to"
        },
        {
          "language": "fa",
          "text": "اشاره کردن؛ تذکر دادن"
        },
        {
          "language": "kmr",
          "text": "nîşan dan; agahdar kirin"
        },
        {
          "language": "pl",
          "text": "wskazywać; zwracać uwagę"
        },
        {
          "language": "ro",
          "text": "a indica; a atrage atenția"
        },
        {
          "language": "ru",
          "text": "указывать; обращать внимание"
        },
        {
          "language": "sq",
          "text": "të tregosh; të tërheqësh vëmendjen"
        },
        {
          "language": "tr",
          "text": "işaret etmek; dikkat çekmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte weisen Sie den Kunden auf die neue Zahlungsfrist hin.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تنبيه العميل إلى مهلة الدفع الجديدة."
            },
            {
              "language": "ckb",
              "text": "تکایە کڕیارەکە لە ماوەی نوێی پارەدان ئاگادار بکەنەوە."
            },
            {
              "language": "en",
              "text": "Please point out the new payment deadline to the customer."
            },
            {
              "language": "fa",
              "text": "لطفاً مهلت جدید پرداخت را به مشتری یادآوری کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe xerîdar li ser dema nû ya dayîna pereyan agahdar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę poinformować klienta o nowym terminie płatności."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să atrageți atenția clientului asupra noului termen de plată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, укажите клиенту на новый срок оплаты."
            },
            {
              "language": "sq",
              "text": "Ju lutemi njoftojeni klientin për afatin e ri të pagesës."
            },
            {
              "language": "tr",
              "text": "Lütfen müşteriye yeni ödeme süresini belirtin."
            }
          ]
        },
        {
          "baseText": "Der Arzt weist darauf hin, dass die Tabletten nach dem Essen genommen werden sollen.",
          "translations": [
            {
              "language": "ar",
              "text": "يشير الطبيب إلى أن الأقراص يجب أن تُؤخذ بعد الطعام."
            },
            {
              "language": "ckb",
              "text": "پزیشکەکە ئاماژە دەکات کە حەبەکان دەبێت دوای خواردن وەربگیرێن."
            },
            {
              "language": "en",
              "text": "The doctor points out that the tablets should be taken after meals."
            },
            {
              "language": "fa",
              "text": "پزشک اشاره می‌کند که قرص‌ها باید بعد از غذا مصرف شوند."
            },
            {
              "language": "kmr",
              "text": "Bijîşk destnîşan dike ku tablet divê piştî xwarinê bêne vexwarin."
            },
            {
              "language": "pl",
              "text": "Lekarz zwraca uwagę, że tabletki należy przyjmować po jedzeniu."
            },
            {
              "language": "ro",
              "text": "Medicul atrage atenția că pastilele trebuie luate după masă."
            },
            {
              "language": "ru",
              "text": "Врач указывает, что таблетки следует принимать после еды."
            },
            {
              "language": "sq",
              "text": "Mjeku thekson se tabletat duhet të merren pas ushqimit."
            },
            {
              "language": "tr",
              "text": "Doktor tabletlerin yemekten sonra alınması gerektiğini belirtir."
            }
          ]
        }
      ]
    },
    {
      "word": "hochgehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hochgehen",
      "pronunciationIpa": null,
      "syllableBreak": "hoch-ge-hen",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; past participle: hochgegangen; means to go up or increase"
      ],
      "collocations": [
        {
          "text": "die Treppe hochgehen",
          "meaning": "to go up the stairs"
        },
        {
          "text": "die Preise gehen hoch",
          "meaning": "prices go up"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gehen",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "hoch",
          "relationLabel": "adverb/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصعد؛ يرتفع"
        },
        {
          "language": "ckb",
          "text": "چوونە سەرەوە؛ زیادبوون"
        },
        {
          "language": "en",
          "text": "to go up; to rise"
        },
        {
          "language": "fa",
          "text": "بالا رفتن؛ افزایش یافتن"
        },
        {
          "language": "kmr",
          "text": "çûn jor; zêde bûn"
        },
        {
          "language": "pl",
          "text": "iść w górę; rosnąć"
        },
        {
          "language": "ro",
          "text": "a urca; a crește"
        },
        {
          "language": "ru",
          "text": "подниматься; повышаться"
        },
        {
          "language": "sq",
          "text": "të ngjitesh; të rritet"
        },
        {
          "language": "tr",
          "text": "yukarı çıkmak; yükselmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kosten für den Serverbetrieb sind dieses Jahr deutlich hochgegangen.",
          "translations": [
            {
              "language": "ar",
              "text": "ارتفعت تكاليف تشغيل الخوادم هذا العام بشكل واضح."
            },
            {
              "language": "ckb",
              "text": "تێچووی بەڕێوەبردنی سێرڤەرەکان ئەمساڵ بە ڕوونی زیاد بووە."
            },
            {
              "language": "en",
              "text": "The costs of running the servers have risen significantly this year."
            },
            {
              "language": "fa",
              "text": "هزینه‌های راه‌اندازی و نگهداری سرورها امسال به‌طور قابل توجهی بالا رفته است."
            },
            {
              "language": "kmr",
              "text": "Lêçûnên xebitandina serveran îsal bi awayekî berbiçav zêde bûne."
            },
            {
              "language": "pl",
              "text": "Koszty utrzymania serwerów w tym roku wyraźnie wzrosły."
            },
            {
              "language": "ro",
              "text": "Costurile de operare a serverelor au crescut semnificativ anul acesta."
            },
            {
              "language": "ru",
              "text": "Расходы на эксплуатацию серверов в этом году заметно выросли."
            },
            {
              "language": "sq",
              "text": "Kostot e funksionimit të serverëve janë rritur ndjeshëm këtë vit."
            },
            {
              "language": "tr",
              "text": "Sunucu işletme maliyetleri bu yıl belirgin şekilde arttı."
            }
          ]
        },
        {
          "baseText": "Gehen Sie bitte eine Etage hoch, dort ist die Anmeldung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الصعود طابقاً واحداً، فهناك مكتب التسجيل."
            },
            {
              "language": "ckb",
              "text": "تکایە نهۆمێک بچنە سەرەوە، تۆمارکردن لەوێیە."
            },
            {
              "language": "en",
              "text": "Please go up one floor; registration is there."
            },
            {
              "language": "fa",
              "text": "لطفاً یک طبقه بالا بروید، ثبت‌نام آنجاست."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe qatekê biçin jor, qeyd li wir e."
            },
            {
              "language": "pl",
