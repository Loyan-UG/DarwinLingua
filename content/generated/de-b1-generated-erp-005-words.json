      "plural": "Korrekturen",
      "infinitive": null,
      "syllableBreak": "Kor-rek-tur",
      "topics": [
        "documents-and-administration",
        "quality-and-risk",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "written",
