      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Korrektur vornehmen",
          "meaning": "to make a correction"
        },
        {
          "text": "eine Korrektur prüfen",
          "meaning": "to check a correction"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "korrigieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تصحيح"
        },
        {
          "language": "ckb",
          "text": "ڕاستکردنەوە"
        },
        {
          "language": "en",
          "text": "correction"
        },
        {
          "language": "fa",
          "text": "اصلاح؛ تصحیح"
        },
        {
          "language": "kmr",
          "text": "rastkirin"
        },
        {
          "language": "pl",
          "text": "korekta; poprawka"
        },
        {
          "language": "ro",
          "text": "corectură; corecție"
        },
        {
          "language": "ru",
          "text": "исправление; корректировка"
        },
        {
          "language": "sq",
          "text": "korrigjim"
        },
        {
          "language": "tr",
          "text": "düzeltme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Korrektur der Rechnung ist im ERP-System gespeichert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم حفظ تصحيح الفاتورة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "ڕاستکردنەوەی فاکتورەکە لە سیستەمی ERPدا پاشەکەوت کراوە."
            },
            {
              "language": "en",
              "text": "The correction of the invoice is saved in the ERP system."
            },
            {
              "language": "fa",
              "text": "اصلاح فاکتور در سیستم ERP ذخیره شده است."
            },
            {
              "language": "kmr",
              "text": "Rastkirina fatûreyê di pergala ERP de hatiye tomarkirin."
            },
            {
              "language": "pl",
              "text": "Korekta faktury jest zapisana w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Corectura facturii este salvată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Корректировка счета сохранена в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Korrigjimi i faturës është ruajtur në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Fatura düzeltmesi ERP sisteminde kaydedildi."
            }
          ]
        },
        {
          "baseText": "Danke für die schnelle Korrektur im Dokument.",
          "translations": [
            {
              "language": "ar",
              "text": "شكرًا على التصحيح السريع في المستند."
            },
            {
              "language": "ckb",
              "text": "سوپاس بۆ ڕاستکردنەوەی خێرا لە بەڵگەنامەکەدا."
            },
            {
              "language": "en",
              "text": "Thank you for the quick correction in the document."
            },
            {
              "language": "fa",
              "text": "ممنون بابت اصلاح سریع در سند."
            },
            {
              "language": "kmr",
              "text": "Spas ji bo rastkirina bilez di belgeyê de."
            },
            {
              "language": "pl",
              "text": "Dziękuję za szybką korektę w dokumencie."
            },
            {
              "language": "ro",
              "text": "Mulțumesc pentru corectura rapidă din document."
            },
            {
              "language": "ru",
              "text": "Спасибо за быстрое исправление в документе."
            },
            {
              "language": "sq",
              "text": "Faleminderit për korrigjimin e shpejtë në dokument."
            },
            {
              "language": "tr",
              "text": "Belgedeki hızlı düzeltme için teşekkürler."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "der Kostenträger",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Kostenträger",
      "infinitive": null,
      "syllableBreak": "Kos-ten-trä-ger",
      "topics": [
        "finance-and-accounting",
        "documents-and-administration",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "technical",
        "administrative"
      ],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "einen Kostenträger zuordnen",
          "meaning": "to assign a cost object"
        },
        {
          "text": "Kosten auf den Kostenträger buchen",
          "meaning": "to post costs to the cost object"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kosten",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "tragen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "حامل التكلفة؛ مركز تحميل التكلفة"
        },
        {
          "language": "ckb",
          "text": "هەڵگری تێچوو"
        },
        {
          "language": "en",
          "text": "cost object; cost bearer"
        },
        {
          "language": "fa",
          "text": "مرکز/موضوع هزینه"
        },
        {
          "language": "kmr",
          "text": "hilgirê mesrefê"
        },
        {
          "language": "pl",
          "text": "nośnik kosztów"
        },
        {
          "language": "ro",
          "text": "purtător de costuri"
        },
        {
          "language": "ru",
          "text": "носитель затрат"
        },
        {
          "language": "sq",
          "text": "bartës kostoje"
        },
        {
          "language": "tr",
          "text": "maliyet taşıyıcı"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte ordnen Sie dem Auftrag den richtigen Kostenträger im ERP-System zu.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى ربط الطلب بحامل التكلفة الصحيح في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "تکایە داواکارییەکە لە سیستەمی ERPدا بە هەڵگری تێچووی دروستەوە ببەستن."
            },
            {
              "language": "en",
              "text": "Please assign the correct cost object to the order in the ERP system."
            },
            {
              "language": "fa",
              "text": "لطفاً در سیستم ERP مرکز هزینه درست را به سفارش اختصاص دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe di pergala ERP de hilgirê mesrefê yê rast ji fermarişê re diyar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę przypisać do zamówienia właściwy nośnik kosztów w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să alocați comenzii purtătorul de costuri corect în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, назначьте заказу правильный носитель затрат в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Ju lutemi caktoni bartësin e saktë të kostos për porosinë në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Lütfen siparişe ERP sisteminde doğru maliyet taşıyıcıyı atayın."
            }
          ]
        },
        {
          "baseText": "Ohne Kostenträger kann die Buchhaltung die Kosten nicht richtig buchen.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون حامل تكلفة لا تستطيع المحاسبة تسجيل التكاليف بشكل صحيح."
            },
            {
              "language": "ckb",
              "text": "بێ هەڵگری تێچوو، ژمێریاری ناتوانێت تێچووەکان بە دروستی تۆمار بکات."
            },
            {
              "language": "en",
              "text": "Without a cost object, accounting cannot post the costs correctly."
            },
            {
              "language": "fa",
              "text": "بدون مرکز هزینه، حسابداری نمی‌تواند هزینه‌ها را درست ثبت کند."
            },
            {
              "language": "kmr",
              "text": "Bê hilgirê mesrefê, hesabdarî nikare mesrefan rast tomar bike."
            },
            {
              "language": "pl",
              "text": "Bez nośnika kosztów księgowość nie może poprawnie zaksięgować kosztów."
            },
            {
              "language": "ro",
              "text": "Fără purtător de costuri, contabilitatea nu poate înregistra corect costurile."
            },
            {
              "language": "ru",
              "text": "Без носителя затрат бухгалтерия не может правильно провести расходы."
            },
            {
              "language": "sq",
              "text": "Pa bartës kostoje, kontabiliteti nuk mund t’i regjistrojë saktë kostot."
            },
            {
              "language": "tr",
              "text": "Maliyet taşıyıcı olmadan muhasebe maliyetleri doğru kaydedemez."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
