      ],
      "examples": [
        {
          "baseText": "Meine Großmutter kocht sehr gern.",
          "translations": [
            {
              "language": "ar",
              "text": "جدتي تحب الطبخ كثيراً."
            },
            {
              "language": "ckb",
              "text": "داپیرم زۆر حەزی لە چێشتلێنانە."
            },
            {
              "language": "en",
              "text": "My grandmother really likes cooking."
            },
            {
              "language": "fa",
              "text": "مادربزرگم خیلی دوست دارد آشپزی کند."
            },
            {
              "language": "kmr",
              "text": "Dapîra min gelek ji xwarinçêkirinê hez dike."
            },
            {
              "language": "pl",
              "text": "Moja babcia bardzo lubi gotować."
            },
            {
              "language": "ro",
              "text": "Bunica mea gătește cu mare plăcere."
            },
            {
              "language": "ru",
              "text": "Моя бабушка очень любит готовить."
            },
            {
              "language": "sq",
              "text": "Gjyshja ime pëlqen shumë të gatuajë."
            },
            {
              "language": "tr",
              "text": "Büyükannem yemek yapmayı çok sever."
            }
          ]
        },
        {
          "baseText": "Ich telefoniere jeden Sonntag mit meiner Großmutter.",
          "translations": [
            {
              "language": "ar",
              "text": "أتحدث مع جدتي بالهاتف كل يوم أحد."
            },
            {
              "language": "ckb",
              "text": "هەموو یەکشەممەیەک پەیوەندی بە داپیرمەوە دەکەم."
            },
            {
              "language": "en",
              "text": "I call my grandmother every Sunday."
            },
            {
              "language": "fa",
              "text": "هر یکشنبه با مادربزرگم تلفنی صحبت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez her yekşemê bi dapîra xwe re telefon dikim."
            },
            {
              "language": "pl",
              "text": "Dzwonię do babci w każdą niedzielę."
            },
            {
              "language": "ro",
              "text": "Vorbesc la telefon cu bunica mea în fiecare duminică."
            },
            {
              "language": "ru",
              "text": "Я звоню своей бабушке каждое воскресенье."
            },
            {
              "language": "sq",
              "text": "Flas në telefon me gjyshen time çdo të diel."
            },
            {
              "language": "tr",
              "text": "Her pazar büyükannemle telefonda konuşurum."
            }
          ]
        }
      ]
    },
