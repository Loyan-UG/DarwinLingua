      "examples": [
        {
          "baseText": "Mein Großvater erzählt oft von früher.",
          "translations": [
            {
              "language": "ar",
              "text": "جدي يتحدث كثيراً عن الماضي."
            },
            {
              "language": "ckb",
              "text": "باپیرم زۆرجار باس لە کۆن دەکات."
            },
            {
              "language": "en",
              "text": "My grandfather often talks about the past."
            },
            {
              "language": "fa",
              "text": "پدربزرگم اغلب از گذشته حرف می‌زند."
            },
            {
              "language": "kmr",
              "text": "Bapîrê min gelek caran li ser demên berê diaxive."
            },
            {
              "language": "pl",
              "text": "Mój dziadek często opowiada o dawnych czasach."
            },
            {
              "language": "ro",
              "text": "Bunicul meu vorbește des despre trecut."
            },
            {
              "language": "ru",
              "text": "Мой дедушка часто рассказывает о прошлом."
            },
            {
              "language": "sq",
              "text": "Gjyshi im shpesh flet për të kaluarën."
            },
            {
              "language": "tr",
              "text": "Büyükbabam sık sık eskilerden bahseder."
            }
          ]
        },
        {
          "baseText": "Am Nachmittag besuchen wir den Großvater.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الظهر نزور الجد."
            },
            {
              "language": "ckb",
              "text": "دوای نیوەڕۆ سەردانی باپیر دەکەین."
            },
            {
              "language": "en",
              "text": "In the afternoon we visit grandfather."
            },
            {
              "language": "fa",
              "text": "بعدازظهر به دیدن پدربزرگ می‌رویم."
            },
            {
              "language": "kmr",
              "text": "Piştî nîvro em serdana bapîr dikin."
            },
            {
              "language": "pl",
              "text": "Po południu odwiedzamy dziadka."
            },
            {
              "language": "ro",
              "text": "După-amiază îl vizităm pe bunic."
            },
            {
              "language": "ru",
              "text": "Днём мы навещаем дедушку."
            },
            {
              "language": "sq",
              "text": "Pasdite vizitojmë gjyshin."
            },
            {
              "language": "tr",
              "text": "Öğleden sonra büyükbabayı ziyaret ediyoruz."
            }
          ]
