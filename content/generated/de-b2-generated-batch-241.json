  "entries": [
    {
      "word": "übersteigen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "übersteigen",
      "pronunciationIpa": null,
      "syllableBreak": "ü-ber-stei-gen",
      "topics": [
        "finance-and-accounting",
        "data-and-reporting",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "finance",
        "analytics",
        "risk"
      ],
      "grammarNotes": [
        "inseparable irregular verb: übersteigt, überstieg, hat überstiegen; means to exceed"
      ],
      "collocations": [
        {
          "text": "die Erwartungen übersteigen",
          "meaning": "to exceed expectations"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "steigen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتجاوز؛ يفوق"
        },
        {
          "language": "ckb",
          "text": "تێپەڕاندن؛ زیاتر بوون لە"
        },
        {
          "language": "en",
          "text": "to exceed; to be more than"
        },
        {
          "language": "fa",
          "text": "فراتر رفتن؛ بیشتر بودن از"
        },
        {
          "language": "kmr",
          "text": "derbas kirin; ji tiştekî zêdetir bûn"
        },
        {
          "language": "pl",
          "text": "przekraczać; przewyższać"
        },
        {
          "language": "ro",
          "text": "a depăși"
        },
        {
          "language": "ru",
          "text": "превышать"
        },
        {
          "language": "sq",
          "text": "të tejkalosh"
        },
        {
          "language": "tr",
          "text": "aşmak; üzerinde olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kosten für die Reparatur übersteigen den ursprünglichen Kostenvoranschlag deutlich.",
          "translations": [
            {
              "language": "ar",
              "text": "تتجاوز تكاليف الإصلاح التقدير الأصلي بوضوح."
            },
            {
              "language": "ckb",
              "text": "تێچووی چاککردنەوەکە بە ڕوونی خەمڵاندنی سەرەتایی تێدەپەڕێنێت."
            },
            {
              "language": "en",
              "text": "The repair costs clearly exceed the original estimate."
            },
            {
              "language": "fa",
              "text": "هزینه‌های تعمیر به‌طور واضح از برآورد اولیه فراتر می‌رود."
            },
            {
              "language": "kmr",
              "text": "Lêçûnên tamîrê bi eşkere texmîna destpêkê derbas dikin."
            },
            {
              "language": "pl",
              "text": "Koszty naprawy wyraźnie przekraczają pierwotny kosztorys."
            },
            {
              "language": "ro",
              "text": "Costurile reparației depășesc clar estimarea inițială."
            },
            {
              "language": "ru",
              "text": "Стоимость ремонта явно превышает первоначальную смету."
            },
            {
              "language": "sq",
              "text": "Kostot e riparimit e tejkalojnë qartë vlerësimin fillestar."
            },
            {
              "language": "tr",
              "text": "Onarım maliyetleri ilk tahmini açıkça aşıyor."
            }
          ]
        },
        {
          "baseText": "Die Zahl der Anmeldungen übersteigt unsere Erwartungen.",
          "translations": [
            {
              "language": "ar",
              "text": "يتجاوز عدد التسجيلات توقعاتنا."
            },
            {
              "language": "ckb",
              "text": "ژمارەی تۆمارکردنەکان چاوەڕوانییەکانمان تێدەپەڕێنێت."
            },
            {
              "language": "en",
              "text": "The number of registrations exceeds our expectations."
            },
            {
              "language": "fa",
              "text": "تعداد ثبت‌نام‌ها از انتظار ما بیشتر است."
            },
            {
              "language": "kmr",
              "text": "Hejmara tomarkirinan hêviyên me derbas dike."
            },
            {
              "language": "pl",
              "text": "Liczba zgłoszeń przekracza nasze oczekiwania."
            },
            {
              "language": "ro",
              "text": "Numărul înscrierilor depășește așteptările noastre."
            },
            {
              "language": "ru",
              "text": "Количество регистраций превышает наши ожидания."
            },
            {
              "language": "sq",
              "text": "Numri i regjistrimeve i tejkalon pritjet tona."
            },
            {
              "language": "tr",
              "text": "Kayıt sayısı beklentilerimizi aşıyor."
            }
          ]
        }
      ]
    },
