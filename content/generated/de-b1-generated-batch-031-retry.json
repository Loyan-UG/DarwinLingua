        "written"
      ],
      "contextLabels": [
        "hr",
        "administration"
      ],
      "grammarNotes": [
        "adjective; often used with sein"
      ],
      "collocations": [
        {
          "text": "sehr beschäftigt sein",
          "meaning": "to be very busy"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "beschäftigen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Beschäftigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مشغول؛ شاغل"
        },
        {
          "language": "ckb",
          "text": "سەرقاڵ؛ خاوەن کار"
        },
        {
          "language": "en",
          "text": "busy; employed"
        },
        {
          "language": "fa",
          "text": "مشغول؛ شاغل"
        },
        {
          "language": "kmr",
          "text": "mijûl; xwedî kar"
        },
        {
          "language": "pl",
          "text": "zajęty; zatrudniony"
        },
        {
          "language": "ro",
          "text": "ocupat; angajat"
        },
        {
          "language": "ru",
          "text": "занятый; трудоустроенный"
        },
        {
          "language": "sq",
          "text": "i zënë; i punësuar"
        },
        {
          "language": "tr",
          "text": "meşgul; çalışan"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin heute sehr beschäftigt und rufe Sie morgen zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا مشغول جدًا اليوم وسأتصل بك غدًا."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ زۆر سەرقاڵم و سبەی پەیوەندیت پێوە دەکەمەوە."
            },
            {
              "language": "en",
              "text": "I am very busy today and will call you back tomorrow."
            },
            {
              "language": "fa",
              "text": "امروز خیلی مشغولم و فردا با شما تماس می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez îro pir mijûl im û sibê vedigerim we telefon dikim."
            },
            {
              "language": "pl",
              "text": "Dzisiaj jestem bardzo zajęty i oddzwonię jutro."
            },
            {
              "language": "ro",
              "text": "Sunt foarte ocupat astăzi și vă sun înapoi mâine."
            },
            {
              "language": "ru",
              "text": "Сегодня я очень занят и перезвоню вам завтра."
            },
            {
              "language": "sq",
              "text": "Sot jam shumë i zënë dhe do t’ju telefonoj nesër."
            },
            {
              "language": "tr",
              "text": "Bugün çok meşgulüm, sizi yarın geri arayacağım."
            }
          ]
        },
        {
          "baseText": "In der Firma sind zurzeit mehr als fünfzig Personen beschäftigt.",
          "translations": [
            {
              "language": "ar",
              "text": "يعمل في الشركة حاليًا أكثر من خمسين شخصًا."
            },
            {
              "language": "ckb",
              "text": "لە کۆمپانیاکەدا لە ئێستادا زیاتر لە پەنجا کەس کار دەکەن."
            },
            {
              "language": "en",
              "text": "More than fifty people are currently employed at the company."
            },
            {
              "language": "fa",
              "text": "در شرکت در حال حاضر بیش از پنجاه نفر شاغل هستند."
            },
            {
              "language": "kmr",
              "text": "Li şirkêtê niha zêdetirî pêncî kes dixebitin."
            },
            {
              "language": "pl",
              "text": "W firmie jest obecnie zatrudnionych ponad pięćdziesiąt osób."
            },
            {
              "language": "ro",
              "text": "În firmă sunt angajate în prezent peste cincizeci de persoane."
            },
            {
              "language": "ru",
              "text": "В компании сейчас занято более пятидесяти человек."
            },
            {
              "language": "sq",
              "text": "Në kompani aktualisht janë të punësuar më shumë se pesëdhjetë persona."
            },
            {
              "language": "tr",
              "text": "Şirkette şu anda elliden fazla kişi çalışıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Beschränkung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Beschränkungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-schrän-kung",
      "topics": [
        "law-and-compliance",
        "public-services",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written"
      ],
      "contextLabels": [
        "compliance",
        "administration",
        "risk"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Beschränkung beachten",
          "meaning": "to observe a restriction"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "beschränken",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تقييد؛ حدّ"
        },
        {
          "language": "ckb",
          "text": "سنووردارکردن؛ بەربەست"
        },
        {
          "language": "en",
          "text": "restriction; limitation"
        },
        {
          "language": "fa",
          "text": "محدودیت؛ محدودسازی"
        },
        {
          "language": "kmr",
          "text": "sînordarkirin; astengî"
        },
        {
          "language": "pl",
          "text": "ograniczenie"
        },
        {
          "language": "ro",
          "text": "restricție; limitare"
        },
        {
          "language": "ru",
          "text": "ограничение"
        },
        {
          "language": "sq",
          "text": "kufizim"
        },
        {
          "language": "tr",
          "text": "kısıtlama; sınırlama"
        }
      ],
      "examples": [
        {
          "baseText": "Wegen der Beschränkung dürfen nur zehn Personen in den Raum.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب التقييد يُسمح بدخول عشرة أشخاص فقط إلى الغرفة."
            },
            {
              "language": "ckb",
              "text": "بەهۆی سنووردارکردنەکە تەنها دە کەس دەتوانن بچنە ژوورەکە."
            },
            {
              "language": "en",
              "text": "Because of the restriction, only ten people may enter the room."
            },
            {
              "language": "fa",
              "text": "به دلیل محدودیت، فقط ده نفر اجازه ورود به اتاق را دارند."
            },
            {
              "language": "kmr",
              "text": "Ji ber sînordarkirinê tenê deh kes dikarin bikevin odeyê."
            },
            {
              "language": "pl",
              "text": "Z powodu ograniczenia do sali może wejść tylko dziesięć osób."
            },
            {
              "language": "ro",
              "text": "Din cauza restricției, doar zece persoane au voie să intre în cameră."
            },
            {
              "language": "ru",
              "text": "Из-за ограничения в помещение могут войти только десять человек."
            },
            {
              "language": "sq",
              "text": "Për shkak të kufizimit, vetëm dhjetë persona mund të hyjnë në dhomë."
            },
            {
              "language": "tr",
              "text": "Kısıtlama nedeniyle odaya sadece on kişi girebilir."
            }
          ]
        },
        {
          "baseText": "Die neue Beschränkung gilt für alle privaten Daten im System.",
          "translations": [
            {
              "language": "ar",
              "text": "ينطبق القيد الجديد على جميع البيانات الخاصة في النظام."
            },
            {
              "language": "ckb",
              "text": "سنووردارکردنی نوێ بۆ هەموو داتای تایبەتی لە سیستەمەکەدا کاریگەرە."
            },
            {
              "language": "en",
              "text": "The new restriction applies to all private data in the system."
            },
            {
              "language": "fa",
              "text": "محدودیت جدید برای همه داده‌های خصوصی در سیستم اعمال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Sînordarkirina nû ji bo hemû daneyên taybet di pergalê de derbas dibe."
            },
            {
              "language": "pl",
              "text": "Nowe ograniczenie dotyczy wszystkich danych prywatnych w systemie."
            },
            {
              "language": "ro",
              "text": "Noua restricție se aplică tuturor datelor private din sistem."
            },
            {
              "language": "ru",
              "text": "Новое ограничение распространяется на все частные данные в системе."
            },
            {
              "language": "sq",
              "text": "Kufizimi i ri vlen për të gjitha të dhënat private në sistem."
            },
            {
              "language": "tr",
              "text": "Yeni kısıtlama sistemdeki tüm özel veriler için geçerlidir."
            }
          ]
        }
      ]
    }
  ],
