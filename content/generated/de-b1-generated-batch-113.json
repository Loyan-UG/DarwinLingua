  "entries": [
    {
      "word": "das Rezept",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Rezepte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Re-zept",
      "topics": [
        "healthcare-and-appointments",
        "everyday-life",
        "shopping-and-services"
      ],
      "usageLabels": [
        "everyday",
        "formal",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; can mean prescription or cooking recipe"
      ],
      "collocations": [
        {
          "text": "ein Rezept einlösen",
          "meaning": "to redeem a prescription"
        },
        {
          "text": "ein einfaches Rezept",
          "meaning": "a simple recipe"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verschreiben",
          "relationLabel": "verb",
          "note": "for medical prescriptions"
        },
        {
          "lemma": "kochen",
          "relationLabel": "verb",
          "note": "for cooking recipes"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وصفة طبية؛ وصفة طبخ"
        },
        {
          "language": "ckb",
          "text": "ڕەچەتەی پزیشکی؛ ڕێنمایی چێشتلێنان"
        },
        {
          "language": "en",
          "text": "prescription; recipe"
        },
        {
          "language": "fa",
          "text": "نسخه پزشک؛ دستور غذا"
        },
        {
          "language": "kmr",
          "text": "reçete; tarîfa xwarinê"
        },
        {
          "language": "pl",
          "text": "recepta; przepis"
        },
        {
          "language": "ro",
          "text": "rețetă medicală; rețetă culinară"
        },
        {
          "language": "ru",
          "text": "рецепт врача; кулинарный рецепт"
        },
        {
          "language": "sq",
          "text": "recetë mjekësore; recetë gatimi"
        },
        {
          "language": "tr",
          "text": "reçete; yemek tarifi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Arzt hat mir ein Rezept für die Tabletten gegeben.",
          "translations": [
            {
              "language": "ar",
              "text": "أعطاني الطبيب وصفة طبية للأقراص."
            },
            {
              "language": "ckb",
              "text": "پزیشکەکە ڕەچەتەیەکی بۆ حەبەکان دام."
            },
            {
              "language": "en",
              "text": "The doctor gave me a prescription for the tablets."
            },
            {
              "language": "fa",
              "text": "پزشک برای قرص‌ها به من نسخه داد."
            },
            {
              "language": "kmr",
              "text": "Bijîşk ji bo heban reçeteyek da min."
            },
            {
              "language": "pl",
              "text": "Lekarz dał mi receptę na tabletki."
            },
            {
              "language": "ro",
              "text": "Medicul mi-a dat o rețetă pentru tablete."
            },
            {
              "language": "ru",
              "text": "Врач дал мне рецепт на таблетки."
            },
            {
              "language": "sq",
              "text": "Mjeku më dha një recetë për tabletat."
            },
            {
              "language": "tr",
              "text": "Doktor bana tabletler için reçete verdi."
            }
          ]
        },
        {
          "baseText": "Kannst du mir das Rezept für den Kuchen schicken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن ترسل لي وصفة الكعكة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت ڕێنمایی دروستکردنی کێکەکە بۆم بنێریت؟"
            },
            {
              "language": "en",
              "text": "Can you send me the recipe for the cake?"
            },
            {
              "language": "fa",
              "text": "می‌توانی دستور کیک را برایم بفرستی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî tarîfa kekê ji min re bişînî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz wysłać mi przepis na ciasto?"
            },
            {
              "language": "ro",
              "text": "Poți să-mi trimiți rețeta pentru prăjitură?"
            },
            {
              "language": "ru",
              "text": "Можешь отправить мне рецепт пирога?"
            },
            {
              "language": "sq",
              "text": "A mund të ma dërgosh recetën e tortës?"
            },
            {
              "language": "tr",
              "text": "Bana kekin tarifini gönderebilir misin?"
            }
          ]
        }
      ]
    },
    {
      "word": "die Rückerstattung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Rückerstattungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Rück-er-stat-tung",
      "topics": [
        "finance-and-accounting",
        "customer-service",
        "shopping-and-services"
      ],
      "usageLabels": [
        "formal",
        "customer-facing",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Rückerstattung erhalten",
          "meaning": "to receive a refund"
        },
        {
          "text": "eine Rückerstattung beantragen",
          "meaning": "to request a refund"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "erstatten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "zurückerstatten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استرداد مبلغ؛ تعويض مالي"
        },
        {
          "language": "ckb",
          "text": "گەڕاندنەوەی پارە؛ قەرەبوو"
        },
        {
          "language": "en",
          "text": "refund; reimbursement"
        },
        {
          "language": "fa",
          "text": "بازپرداخت؛ استرداد وجه"
        },
        {
          "language": "kmr",
          "text": "vegerandina pereyan; tezmînat"
        },
        {
          "language": "pl",
          "text": "zwrot pieniędzy; refundacja"
        },
        {
          "language": "ro",
          "text": "rambursare; restituire"
        },
        {
          "language": "ru",
          "text": "возврат денег; возмещение"
        },
        {
          "language": "sq",
          "text": "rimbursim; kthim parash"
        },
        {
          "language": "tr",
          "text": "geri ödeme; iade"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rückerstattung wird innerhalb von fünf Werktagen überwiesen.",
          "translations": [
            {
              "language": "ar",
              "text": "سيتم تحويل مبلغ الاسترداد خلال خمسة أيام عمل."
            },
            {
              "language": "ckb",
              "text": "گەڕاندنەوەی پارەکە لە ماوەی پێنج ڕۆژی کاردا دەگوازرێتەوە."
            },
            {
              "language": "en",
              "text": "The refund will be transferred within five business days."
            },
            {
              "language": "fa",
              "text": "بازپرداخت ظرف پنج روز کاری واریز می‌شود."
            },
            {
              "language": "kmr",
              "text": "Vegera pereyan di nav pênc rojên kar de tê veguhestin."
            },
            {
              "language": "pl",
              "text": "Zwrot pieniędzy zostanie przelany w ciągu pięciu dni roboczych."
            },
            {
              "language": "ro",
              "text": "Rambursarea va fi transferată în termen de cinci zile lucrătoare."
            },
            {
              "language": "ru",
              "text": "Возврат денег будет переведён в течение пяти рабочих дней."
            },
            {
              "language": "sq",
              "text": "Rimbursimi do të transferohet brenda pesë ditëve pune."
            },
            {
              "language": "tr",
              "text": "Geri ödeme beş iş günü içinde havale edilir."
            }
          ]
        },
        {
          "baseText": "Für die Rückerstattung brauchen wir die Rechnungskopie.",
          "translations": [
            {
              "language": "ar",
              "text": "للاسترداد نحتاج إلى نسخة من الفاتورة."
            },
            {
              "language": "ckb",
              "text": "بۆ گەڕاندنەوەی پارە پێویستمان بە کۆپیی فاکتورەکە هەیە."
            },
            {
              "language": "en",
              "text": "For the refund, we need the invoice copy."
            },
            {
              "language": "fa",
              "text": "برای بازپرداخت به کپی فاکتور نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo vegera pereyan em hewceyê kopiya fatûreyê ne."
            },
            {
              "language": "pl",
              "text": "Do zwrotu pieniędzy potrzebujemy kopii faktury."
            },
            {
              "language": "ro",
              "text": "Pentru rambursare avem nevoie de copia facturii."
            },
            {
              "language": "ru",
              "text": "Для возврата денег нам нужна копия счёта."
            },
            {
              "language": "sq",
              "text": "Për rimbursimin na duhet kopja e faturës."
            },
            {
              "language": "tr",
              "text": "Geri ödeme için fatura kopyasına ihtiyacımız var."
            }
          ]
        }
      ]
    },
