  "entries": [
    {
      "word": "Verkaufsklassifizierung",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Verkaufsklassifizierungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-kaufs-klas-si-fi-zie-rung",
      "topics": [
        "sales-and-customers",
        "erp-and-business-systems",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP terminology"
      ],
      "collocations": [
        {
          "text": "eine Verkaufsklassifizierung pflegen",
          "meaning": "to maintain a sales classification"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "klassifizieren",
          "relationLabel": "verb",
          "note": "to classify"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تصنيف المبيعات"
        },
        {
          "language": "ckb",
          "text": "پۆلێنکردنی فرۆشتن"
        },
        {
          "language": "en",
          "text": "sales classification"
        },
        {
          "language": "fa",
          "text": "طبقه‌بندی فروش"
        },
        {
          "language": "kmr",
          "text": "tesnîfkirina firotanê"
        },
        {
          "language": "pl",
          "text": "klasyfikacja sprzedaży"
        },
        {
          "language": "ro",
          "text": "clasificare a vânzărilor"
        },
        {
          "language": "ru",
          "text": "классификация продаж"
        },
        {
          "language": "sq",
          "text": "klasifikim i shitjeve"
        },
        {
          "language": "tr",
          "text": "satış sınıflandırması"
        }
      ],
      "examples": [
        {
          "baseText": "Die Verkaufsklassifizierung entscheidet im ERP-System, ob ein Auftrag als Projektgeschäft, Seriengeschäft oder Rahmenabruf behandelt wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يحدد تصنيف المبيعات في نظام ERP ما إذا كان الطلب سيُعامل كعمل مشروع أو بيع متكرر أو سحب من عقد إطار."
            },
            {
              "language": "ckb",
              "text": "پۆلێنکردنی فرۆشتن لە سیستەمی ERPدا دیاری دەکات ئایا داواکارییەک وەک کاری پڕۆژە، کاری زنجیرەیی یان بانگهێشتی چوارچێوەیی مامەڵەی لەگەڵ دەکرێت."
            },
            {
              "language": "en",
              "text": "The sales classification determines in the ERP system whether an order is handled as project business, recurring business, or a call-off from a framework agreement."
            },
            {
              "language": "fa",
              "text": "طبقه‌بندی فروش در سیستم ERP تعیین می‌کند که یک سفارش به عنوان کسب‌وکار پروژه‌ای، فروش تکراری یا برداشت از قرارداد چارچوبی پردازش شود."
            },
            {
              "language": "kmr",
              "text": "Tesnîfkirina firotanê di pergala ERP de diyar dike ka fermanek wek karê projeyê, karê dubare an bangek ji peymana çarçoveyê were rêvebirin."
            },
            {
              "language": "pl",
              "text": "Klasyfikacja sprzedaży decyduje w systemie ERP, czy zamówienie jest obsługiwane jako projekt, sprzedaż seryjna czy odwołanie z umowy ramowej."
            },
            {
              "language": "ro",
              "text": "Clasificarea vânzărilor decide în sistemul ERP dacă o comandă este tratată ca proiect, afacere recurentă sau apel dintr-un acord-cadru."
            },
            {
              "language": "ru",
              "text": "Классификация продаж определяет в ERP-системе, обрабатывать ли заказ как проектную сделку, серийную продажу или поставку по рамочному договору."
            },
            {
              "language": "sq",
              "text": "Klasifikimi i shitjeve përcakton në sistemin ERP nëse një porosi trajtohet si projekt, biznes i përsëritur apo tërheqje nga marrëveshja kornizë."
            },
            {
              "language": "tr",
              "text": "Satış sınıflandırması, ERP sisteminde bir siparişin proje işi, seri satış ya da çerçeve anlaşma çağrısı olarak işlenip işlenmeyeceğini belirler."
            }
          ]
        },
        {
          "baseText": "Ohne konsistente Verkaufsklassifizierung verlieren die Margenberichte ihre Aussagekraft, weil sehr unterschiedliche Geschäftsmodelle vermischt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون تصنيف مبيعات متسق تفقد تقارير الهوامش دلالتها، لأن نماذج أعمال مختلفة جدًا تُخلط معًا."
            },
            {
              "language": "ckb",
              "text": "بەبێ پۆلێنکردنی یەکگرتووی فرۆشتن، ڕاپۆرتەکانی پەراوێز واتای خۆیان لەدەست دەدەن، چونکە مۆدێلی بازرگانی زۆر جیاواز تێکەڵ دەکرێن."
            },
            {
              "language": "en",
              "text": "Without consistent sales classification, margin reports lose their explanatory value because very different business models are mixed together."
            },
            {
              "language": "fa",
              "text": "بدون طبقه‌بندی فروش سازگار، گزارش‌های حاشیه سود ارزش تحلیلی خود را از دست می‌دهند، چون مدل‌های کسب‌وکار بسیار متفاوت با هم مخلوط می‌شوند."
            },
            {
              "language": "kmr",
              "text": "Bê tesnîfkirina firotanê ya hevgirtî, raporên marjê wateya xwe winda dikin, ji ber ku modelên bazirganiyê yên gelek cuda tevlihev dibin."
            },
            {
              "language": "pl",
              "text": "Bez spójnej klasyfikacji sprzedaży raporty marż tracą wartość informacyjną, ponieważ mieszają się bardzo różne modele biznesowe."
            },
            {
              "language": "ro",
              "text": "Fără o clasificare consecventă a vânzărilor, rapoartele de marjă își pierd relevanța, deoarece sunt amestecate modele de afaceri foarte diferite."
            },
            {
              "language": "ru",
              "text": "Без последовательной классификации продаж отчеты по марже теряют смысл, потому что смешиваются совершенно разные бизнес-модели."
            },
            {
              "language": "sq",
              "text": "Pa klasifikim të qëndrueshëm të shitjeve, raportet e marzhit humbin vlerën shpjeguese, sepse përzihen modele shumë të ndryshme biznesi."
            },
            {
              "language": "tr",
              "text": "Tutarlı satış sınıflandırması olmadan marj raporları anlamını kaybeder, çünkü çok farklı iş modelleri birbirine karışır."
            }
          ]
        }
      ]
    },
    {
      "word": "Versandkontrollposition",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Versandkontrollpositionen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-sand-kon-troll-po-si-ti-on",
      "topics": [
        "warehouse-and-logistics",
        "erp-and-business-systems",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP terminology"
      ],
      "collocations": [
        {
          "text": "eine Versandkontrollposition freigeben",
          "meaning": "to release a shipping control item"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Versandkontrolle",
          "relationLabel": "compound base",
          "note": "shipping control context"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بند مراقبة الشحن"
        },
        {
          "language": "ckb",
          "text": "بڕگەی کۆنترۆڵی ناردن"
        },
        {
          "language": "en",
          "text": "shipping control item"
        },
        {
          "language": "fa",
          "text": "آیتم کنترل ارسال"
        },
        {
          "language": "kmr",
          "text": "hêmana kontrola şandinê"
        },
        {
          "language": "pl",
          "text": "pozycja kontroli wysyłki"
        },
        {
          "language": "ro",
          "text": "poziție de control al expedierii"
        },
        {
          "language": "ru",
          "text": "позиция контроля отгрузки"
        },
        {
          "language": "sq",
          "text": "pozicion kontrolli i dërgesës"
        },
        {
          "language": "tr",
          "text": "sevkiyat kontrol kalemi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Versandkontrollposition bleibt im ERP-System gesperrt, bis Gewicht, Gefahrgutkennzeichen und Spediteur bestätigt sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يبقى بند مراقبة الشحن مقفلاً في نظام ERP إلى أن يتم تأكيد الوزن وعلامة البضائع الخطرة وشركة النقل."
            },
            {
              "language": "ckb",
              "text": "بڕگەی کۆنترۆڵی ناردن لە سیستەمی ERPدا قفڵ دەبێت تا کێش، نیشانەی مادەی مەترسیدار و کۆمپانیای گواستنەوە پشتڕاست بکرێنەوە."
            },
            {
              "language": "en",
              "text": "The shipping control item remains blocked in the ERP system until weight, hazardous-goods indicator, and carrier are confirmed."
            },
            {
              "language": "fa",
              "text": "آیتم کنترل ارسال در سیستم ERP مسدود می‌ماند تا وزن، علامت کالای خطرناک و شرکت حمل‌ونقل تأیید شوند."
            },
            {
              "language": "kmr",
              "text": "Hêmana kontrola şandinê di pergala ERP de girtî dimîne heta giranî, nîşana tiştên xeternak û barkêş bêne piştrastkirin."
            },
            {
              "language": "pl",
              "text": "Pozycja kontroli wysyłki pozostaje zablokowana w systemie ERP, dopóki waga, oznaczenie towaru niebezpiecznego i przewoźnik nie zostaną potwierdzone."
            },
            {
              "language": "ro",
              "text": "Poziția de control al expedierii rămâne blocată în sistemul ERP până când greutatea, marcajul pentru mărfuri periculoase și transportatorul sunt confirmate."
            },
            {
              "language": "ru",
              "text": "Позиция контроля отгрузки остается заблокированной в ERP-системе, пока не подтверждены вес, признак опасного груза и перевозчик."
            },
            {
              "language": "sq",
              "text": "Pozicioni i kontrollit të dërgesës mbetet i bllokuar në sistemin ERP derisa të konfirmohen pesha, shenja e mallrave të rrezikshme dhe transportuesi."
            },
            {
              "language": "tr",
              "text": "Sevkiyat kontrol kalemi, ağırlık, tehlikeli madde işareti ve taşıyıcı onaylanana kadar ERP sisteminde blokeli kalır."
            }
          ]
        },
        {
          "baseText": "Bei internationalen Lieferungen ist eine unvollständige Versandkontrollposition oft der Grund, warum der Zollprozess erst am Tor auffällt.",
          "translations": [
            {
              "language": "ar",
              "text": "في الشحنات الدولية يكون بند مراقبة الشحن غير المكتمل غالبًا سبب اكتشاف مشكلة الجمارك فقط عند البوابة."
            },
            {
              "language": "ckb",
              "text": "لە ناردنی نێودەوڵەتیدا، بڕگەی کۆنترۆڵی ناردنی ناتەواو زۆرجار هۆکارە بۆ ئەوەی کێشەی گومرگ تەنها لە دەروازەدا دەربکەوێت."
            },
            {
              "language": "en",
              "text": "For international deliveries, an incomplete shipping control item is often the reason the customs issue is only noticed at the gate."
            },
            {
              "language": "fa",
              "text": "در ارسال‌های بین‌المللی، آیتم ناقص کنترل ارسال اغلب دلیل این است که مشکل گمرکی تازه در دروازه مشخص می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di radestkirinên navneteweyî de, hêmana kontrola şandinê ya netemam gelek caran sedem e ku pirsgirêka gumrikê tenê li dergehê xuya dibe."
            },
            {
              "language": "pl",
              "text": "Przy dostawach międzynarodowych niekompletna pozycja kontroli wysyłki często powoduje, że problem celny wychodzi na jaw dopiero przy bramie."
            },
            {
              "language": "ro",
              "text": "La livrările internaționale, o poziție incompletă de control al expedierii este adesea motivul pentru care problema vamală apare abia la poartă."
            },
            {
              "language": "ru",
              "text": "При международных поставках неполная позиция контроля отгрузки часто становится причиной того, что проблема с таможней обнаруживается только у ворот."
            },
            {
              "language": "sq",
              "text": "Në dërgesat ndërkombëtare, një pozicion i paplotë i kontrollit të dërgesës shpesh është arsyeja pse problemi doganor vërehet vetëm te porta."
            },
            {
              "language": "tr",
              "text": "Uluslararası teslimatlarda eksik bir sevkiyat kontrol kalemi, gümrük sorununun çoğu zaman ancak kapıda fark edilmesine neden olur."
            }
          ]
        }
      ]
    }
  ],
