      "examples": [
        {
          "baseText": "Die Treppe ist links.",
          "translations": [
            {
              "language": "ar",
              "text": "الدرج على اليسار."
            },
            {
              "language": "ckb",
              "text": "قادرمەکە لای چەپە."
            },
            {
              "language": "en",
              "text": "The stairs are on the left."
            },
            {
              "language": "fa",
              "text": "پله‌ها سمت چپ هستند."
            },
            {
              "language": "kmr",
              "text": "Pêlik li çepê ne."
            },
            {
              "language": "pl",
              "text": "Schody są po lewej."
            },
            {
              "language": "ro",
              "text": "Scara este în stânga."
            },
            {
              "language": "ru",
              "text": "Лестница слева."
            },
            {
              "language": "sq",
              "text": "Shkallët janë majtas."
            },
            {
              "language": "tr",
              "text": "Merdiven solda."
            }
          ]
        },
        {
          "baseText": "Bitte nehmen Sie die Treppe.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك استخدم الدرج."
            },
            {
              "language": "ckb",
              "text": "تکایە بە قادرمەکان بچۆ."
            },
            {
              "language": "en",
              "text": "Please take the stairs."
            },
            {
              "language": "fa",
              "text": "لطفاً از پله‌ها بروید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pêlikan bikar bînin."
            },
            {
              "language": "pl",
              "text": "Proszę skorzystać ze schodów."
            },
            {
              "language": "ro",
              "text": "Vă rog să folosiți scara."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, воспользуйтесь лестницей."
            },
            {
              "language": "sq",
              "text": "Ju lutem përdorni shkallët."
            },
            {
              "language": "tr",
              "text": "Lütfen merdiveni kullanın."
            }
          ]
        }
      ]
