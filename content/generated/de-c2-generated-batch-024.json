      "examples": [
        {
          "baseText": "Ihre durchdringende Analyse zeigte, warum die scheinbar stabile Marge nicht belastbar war.",
          "translations": [
            {
              "language": "ar",
              "text": "أظهر تحليلها الثاقب لماذا لم يكن الهامش الذي بدا مستقراً قابلاً للاعتماد."
            },
            {
              "language": "ckb",
              "text": "شیکردنەوەی قووڵبینانەکەی نیشانی دا بۆچی پەراوێزی قازانجی وا جێگیر دیاربوو جێی متمانە نەبوو."
            },
            {
              "language": "en",
              "text": "Her penetrating analysis showed why the seemingly stable margin was not reliable."
            },
            {
              "language": "fa",
              "text": "تحلیل نافذ او نشان داد چرا حاشیه سود ظاهراً پایدار قابل اتکا نبود."
            },
            {
              "language": "kmr",
              "text": "Analîza wê ya kûrbîn nîşan da ka çima margeya ku sekinbar xuya dikir ne bawerbar bû."
            },
            {
              "language": "pl",
              "text": "Jej przenikliwa analiza pokazała, dlaczego pozornie stabilna marża nie była wiarygodna."
            },
            {
              "language": "ro",
              "text": "Analiza ei pătrunzătoare a arătat de ce marja aparent stabilă nu era solidă."
            },
            {
              "language": "ru",
              "text": "Её проницательный анализ показал, почему кажущаяся стабильной маржа не была надёжной."
            },
            {
              "language": "sq",
              "text": "Analiza e saj depërtuese tregoi pse marzhi në dukje i qëndrueshëm nuk ishte i besueshëm."
            },
            {
              "language": "tr",
              "text": "Nüfuz edici analizi, görünüşte istikrarlı marjın neden güvenilir olmadığını gösterdi."
            }
          ]
        },
        {
          "baseText": "Ein durchdringender Geruch nach Rauch lag noch Stunden später im Treppenhaus.",
          "translations": [
            {
              "language": "ar",
              "text": "بقيت رائحة دخان نفاذة في بيت الدرج بعد ساعات."
            },
            {
              "language": "ckb",
              "text": "بۆنێکی تێپەڕی دووکەڵ چەند کاتژمێر دواتریش لە پەیژەخانەکەدا مابووەوە."
            },
            {
              "language": "en",
              "text": "A penetrating smell of smoke still lingered in the stairwell hours later."
            },
            {
              "language": "fa",
              "text": "بوی نافذ دود ساعت‌ها بعد هنوز در راه‌پله مانده بود."
            },
            {
              "language": "kmr",
              "text": "Bihna duxanê ya tûj hîn saetan paşê di derencexanê de mabû."
            },
            {
              "language": "pl",
              "text": "Przenikliwy zapach dymu unosił się na klatce schodowej jeszcze wiele godzin później."
            },
            {
              "language": "ro",
              "text": "Un miros pătrunzător de fum persista pe casa scării ore mai târziu."
            },
            {
              "language": "ru",
              "text": "Пронзительный запах дыма ещё часы спустя держался на лестничной клетке."
            },
            {
              "language": "sq",
              "text": "Një erë depërtuese tymi mbeti në shkallë edhe disa orë më vonë."
            },
            {
              "language": "tr",
              "text": "Keskin bir duman kokusu saatler sonra bile merdiven boşluğunda kalmıştı."
