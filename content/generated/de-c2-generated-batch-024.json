      "examples": [
        {
          "baseText": "Der sachliche Duktus des Berichts verdeckte, wie politisch brisant die Ergebnisse waren.",
          "translations": [
            {
              "language": "ar",
              "text": "غطى الأسلوب الموضوعي للتقرير مدى الحساسية السياسية للنتائج."
            },
            {
              "language": "ckb",
              "text": "شێوازی بابەتی ڕاپۆرتەکە شاردییەوە کە ئەنجامەکان چەندە لە ڕووی سیاسییەوە هەستیار بوون."
            },
            {
              "language": "en",
              "text": "The factual style of the report obscured how politically explosive the findings were."
            },
            {
              "language": "fa",
              "text": "سبک بی‌طرفانه گزارش پنهان می‌کرد که نتایج از نظر سیاسی چقدر حساس‌اند."
            },
            {
              "language": "kmr",
              "text": "Şêwaza rastîn a raporê veşart ku encam çiqas siyaseten teqemenî ne."
            },
            {
              "language": "pl",
              "text": "Rzeczowy dukt raportu przesłaniał, jak politycznie drażliwe były wyniki."
            },
