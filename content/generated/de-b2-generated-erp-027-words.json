  "entries": [
    {
      "word": "Tourtermin",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Tourtermine",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Tour-ter-min",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; scheduled date or appointment for a delivery route"
      ],
      "collocations": [
        {
          "text": "einen Tourtermin verschieben",
          "meaning": "to postpone a route appointment"
        },
        {
          "text": "den Tourtermin bestätigen",
          "meaning": "to confirm the route appointment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Tour",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Termin",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موعد الجولة"
        },
        {
          "language": "ckb",
          "text": "کاتی گەشت"
        },
        {
          "language": "en",
          "text": "route appointment; tour date"
        },
        {
          "language": "fa",
          "text": "زمان مسیر؛ موعد تور"
        },
        {
          "language": "kmr",
          "text": "demê rêyê"
        },
        {
          "language": "pl",
          "text": "termin trasy"
        },
        {
          "language": "ro",
          "text": "termen de rută"
        },
        {
          "language": "ru",
          "text": "срок маршрута"
        },
        {
          "language": "sq",
          "text": "afati i turit"
        },
        {
          "language": "tr",
          "text": "tur tarihi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Tourtermin wird im ERP automatisch an den Kundenservice übermittelt.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم نقل موعد الجولة في ERP تلقائيًا إلى خدمة العملاء."
            },
            {
              "language": "ckb",
              "text": "کاتی گەشت لە ERP دا خۆکارانە بۆ خزمەتگوزاریی کڕیار دەنێردرێت."
            },
            {
              "language": "en",
              "text": "The route appointment is automatically transferred in the ERP to customer service."
            },
            {
              "language": "fa",
              "text": "زمان مسیر در ERP به‌صورت خودکار به خدمات مشتری منتقل می‌شود."
            },
            {
              "language": "kmr",
              "text": "Demê rêyê di ERP de xweber ji xizmeta mişterî re tê şandin."
            },
            {
              "language": "pl",
              "text": "Termin trasy jest automatycznie przekazywany w ERP do obsługi klienta."
            },
            {
              "language": "ro",
              "text": "Termenul de rută este transmis automat în ERP către serviciul clienți."
            },
            {
              "language": "ru",
              "text": "Срок маршрута автоматически передается в ERP в службу поддержки клиентов."
            },
            {
              "language": "sq",
              "text": "Afati i turit transferohet automatikisht në ERP te shërbimi ndaj klientit."
            },
            {
              "language": "tr",
              "text": "Tur tarihi ERP’de otomatik olarak müşteri hizmetlerine aktarılır."
            }
          ]
        },
        {
          "baseText": "Der Tourtermin musste verschoben werden, weil der Fahrer im Stau stand.",
          "translations": [
            {
              "language": "ar",
              "text": "كان يجب تأجيل موعد الجولة لأن السائق كان عالقًا في الازدحام."
            },
            {
              "language": "ckb",
              "text": "کاتی گەشت پێویست بوو دوا بخرێت چونکە شۆفێر لە قەرەباڵغیدا گیر بوو."
            },
            {
              "language": "en",
              "text": "The route appointment had to be postponed because the driver was stuck in traffic."
            },
            {
              "language": "fa",
              "text": "زمان مسیر باید عقب می‌افتاد، چون راننده در ترافیک مانده بود."
            },
            {
              "language": "kmr",
              "text": "Demê rêyê diviya paş bixe, ji ber ku ajokar di trafîkê de mabû."
            },
            {
              "language": "pl",
              "text": "Termin trasy musiał zostać przesunięty, ponieważ kierowca utknął w korku."
            },
            {
              "language": "ro",
              "text": "Termenul rutei a trebuit amânat deoarece șoferul era blocat în trafic."
            },
            {
              "language": "ru",
              "text": "Срок маршрута пришлось перенести, потому что водитель застрял в пробке."
            },
            {
              "language": "sq",
              "text": "Afati i turit duhej shtyrë sepse shoferi kishte ngecur në trafik."
            },
            {
              "language": "tr",
              "text": "Şoför trafikte kaldığı için tur tarihi ertelenmek zorunda kaldı."
            }
          ]
        }
      ]
    },
    {
      "word": "Umlagerungstour",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Umlagerungstouren",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Um-la-ge-rungs-tour",
      "topics": [
        "warehouse-and-logistics",
        "transport-and-travel",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; route used for stock transfers between storage locations or sites"
      ],
      "collocations": [
        {
          "text": "eine Umlagerungstour planen",
          "meaning": "to plan a transfer route"
        },
        {
          "text": "eine Umlagerungstour starten",
          "meaning": "to start a stock transfer route"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "umlagerung",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Tour",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جولة نقل داخلي للمخزون"
        },
        {
          "language": "ckb",
          "text": "گەشتی گواستنەوەی کۆگا"
        },
        {
          "language": "en",
          "text": "stock transfer route"
        },
        {
          "language": "fa",
          "text": "مسیر انتقال موجودی"
        },
        {
          "language": "kmr",
          "text": "rêya veguheztina stokê"
        },
        {
          "language": "pl",
          "text": "trasa przesunięcia magazynowego"
        },
        {
          "language": "ro",
          "text": "rută de transfer de stoc"
        },
        {
          "language": "ru",
          "text": "маршрут перемещения запасов"
        },
        {
          "language": "sq",
          "text": "tur transferimi stoku"
        },
        {
          "language": "tr",
          "text": "stok transfer turu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Umlagerungstour bringt Ware vom Außenlager in das Hauptlager.",
          "translations": [
            {
              "language": "ar",
              "text": "تنقل جولة نقل المخزون البضاعة من المستودع الخارجي إلى المستودع الرئيسي."
            },
            {
              "language": "ckb",
              "text": "گەشتی گواستنەوەی کۆگا کاڵا لە کۆگای دەرەکییەوە بۆ کۆگای سەرەکی دەبات."
            },
            {
              "language": "en",
              "text": "The stock transfer route brings goods from the external warehouse to the main warehouse."
            },
            {
              "language": "fa",
              "text": "مسیر انتقال موجودی کالا را از انبار بیرونی به انبار اصلی می‌آورد."
            },
            {
              "language": "kmr",
              "text": "Rêya veguheztina stokê mal ji embarê derveyî tîne embarê sereke."
            },
            {
              "language": "pl",
              "text": "Trasa przesunięcia magazynowego przewozi towar z magazynu zewnętrznego do głównego."
            },
            {
              "language": "ro",
              "text": "Ruta de transfer de stoc aduce marfa din depozitul extern în depozitul principal."
            },
            {
              "language": "ru",
              "text": "Маршрут перемещения запасов доставляет товар с внешнего склада на главный склад."
            },
            {
              "language": "sq",
              "text": "Turi i transferimit të stokut sjell mallin nga magazina e jashtme në magazinën kryesore."
            },
            {
              "language": "tr",
              "text": "Stok transfer turu malı dış depodan ana depoya getirir."
            }
          ]
        },
        {
          "baseText": "Im ERP ist die Umlagerungstour noch offen, weil zwei Paletten fehlen.",
          "translations": [
            {
              "language": "ar",
              "text": "جولة نقل المخزون ما زالت مفتوحة في ERP لأن منصتين مفقودتان."
            },
            {
              "language": "ckb",
              "text": "لە ERP دا گەشتی گواستنەوەی کۆگا هێشتا کراوەیە چونکە دوو پالێت کەمە."
            },
            {
              "language": "en",
              "text": "The stock transfer route is still open in the ERP because two pallets are missing."
            },
            {
              "language": "fa",
              "text": "مسیر انتقال موجودی در ERP هنوز باز است، چون دو پالت کم است."
            },
            {
              "language": "kmr",
              "text": "Rêya veguheztina stokê di ERP de hîn vekirî ye, ji ber ku du palet kêm in."
            },
            {
              "language": "pl",
              "text": "Trasa przesunięcia magazynowego jest w ERP nadal otwarta, ponieważ brakuje dwóch palet."
            },
            {
              "language": "ro",
              "text": "Ruta de transfer de stoc este încă deschisă în ERP deoarece lipsesc doi paleți."
            },
            {
              "language": "ru",
              "text": "Маршрут перемещения запасов все еще открыт в ERP, потому что не хватает двух палет."
            },
            {
              "language": "sq",
              "text": "Turi i transferimit të stokut është ende i hapur në ERP sepse mungojnë dy paleta."
            },
            {
              "language": "tr",
              "text": "Stok transfer turu ERP’de hâlâ açık, çünkü iki palet eksik."
            }
          ]
        }
      ]
    },
