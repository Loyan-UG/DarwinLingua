  "entries": [
    {
      "word": "herunterladen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "herunterladen",
      "pronunciationIpa": null,
      "syllableBreak": "he-run-ter-la-den",
      "topics": [
        "technology-and-it",
        "documents-and-administration",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "technical",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; past participle: heruntergeladen"
      ],
      "collocations": [
        {
          "text": "eine Datei herunterladen",
          "meaning": "to download a file"
        },
        {
          "text": "eine App herunterladen",
          "meaning": "to download an app"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "laden",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "der Download",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحمّل؛ ينزّل"
        },
        {
          "language": "ckb",
          "text": "دابەزاندن؛ داگرتن"
        },
        {
          "language": "en",
          "text": "to download"
        },
        {
          "language": "fa",
          "text": "دانلود کردن"
        },
        {
          "language": "kmr",
          "text": "daxistin; dakêşan"
        },
        {
          "language": "pl",
          "text": "pobierać"
        },
        {
          "language": "ro",
          "text": "a descărca"
        },
        {
          "language": "ru",
          "text": "скачивать"
        },
        {
          "language": "sq",
          "text": "të shkarkosh"
        },
        {
          "language": "tr",
          "text": "indirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Sie können die Rechnung direkt im Kundenportal herunterladen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم تنزيل الفاتورة مباشرة من بوابة العملاء."
            },
            {
              "language": "ckb",
              "text": "دەتوانن فاکتورەکە ڕاستەوخۆ لە پۆرتاڵی کڕیار دابگرن."
            },
            {
              "language": "en",
              "text": "You can download the invoice directly in the customer portal."
            },
            {
              "language": "fa",
              "text": "می‌توانید فاکتور را مستقیم از پورتال مشتری دانلود کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin fatûreyê rasterast di portala xerîdar de daxînin."
            },
            {
              "language": "pl",
              "text": "Mogą Państwo pobrać fakturę bezpośrednio z portalu klienta."
            },
            {
              "language": "ro",
              "text": "Puteți descărca factura direct din portalul pentru clienți."
            },
            {
              "language": "ru",
              "text": "Вы можете скачать счёт напрямую в клиентском портале."
            },
            {
              "language": "sq",
              "text": "Mund ta shkarkoni faturën direkt në portalin e klientit."
            },
            {
              "language": "tr",
              "text": "Faturayı doğrudan müşteri portalından indirebilirsiniz."
            }
          ]
        },
        {
          "baseText": "Vor der Reise lädt er die Karte auf sein Handy herunter.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل السفر يحمّل الخريطة على هاتفه."
            },
            {
              "language": "ckb",
              "text": "پێش گەشتەکە نەخشەکە بۆ مۆبایلەکەی دادەگرێت."
            },
            {
              "language": "en",
              "text": "Before the trip, he downloads the map to his phone."
            },
            {
              "language": "fa",
              "text": "قبل از سفر، نقشه را روی گوشی‌اش دانلود می‌کند."
            },
            {
              "language": "kmr",
              "text": "Berî rêwîtiyê ew nexşeyê li ser telefona xwe daxîne."
            },
            {
              "language": "pl",
              "text": "Przed podróżą pobiera mapę na telefon."
            },
            {
              "language": "ro",
              "text": "Înainte de călătorie, descarcă harta pe telefon."
            },
            {
              "language": "ru",
              "text": "Перед поездкой он скачивает карту на телефон."
            },
            {
              "language": "sq",
              "text": "Para udhëtimit ai e shkarkon hartën në telefon."
            },
            {
              "language": "tr",
              "text": "Seyahatten önce haritayı telefonuna indirir."
            }
          ]
        }
      ]
    },
    {
      "word": "hervorheben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hervorheben",
      "pronunciationIpa": null,
      "syllableBreak": "her-vor-he-ben",
      "topics": [
        "business-communication",
        "meetings-and-presentations",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; past participle: hervorgehoben"
      ],
      "collocations": [
        {
          "text": "einen Punkt hervorheben",
          "meaning": "to emphasize a point"
        },
        {
          "text": "im Text hervorheben",
          "meaning": "to highlight in the text"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "heben",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "die Hervorhebung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يبرز؛ يؤكد"
        },
        {
          "language": "ckb",
          "text": "جەختکردنەوە؛ دیاریکردن"
        },
        {
          "language": "en",
          "text": "to highlight; to emphasize"
        },
        {
          "language": "fa",
          "text": "برجسته کردن؛ تأکید کردن"
        },
        {
          "language": "kmr",
          "text": "destnîşan kirin; girîng kirin"
        },
        {
          "language": "pl",
          "text": "podkreślać; wyróżniać"
        },
        {
          "language": "ro",
          "text": "a evidenția; a sublinia"
        },
        {
          "language": "ru",
          "text": "выделять; подчёркивать"
        },
        {
          "language": "sq",
          "text": "të theksosh; të nxjerrësh në pah"
        },
        {
          "language": "tr",
          "text": "vurgulamak; öne çıkarmak"
        }
      ],
      "examples": [
        {
          "baseText": "Im Angebot sollten wir die Vorteile des Wartungsvertrags klar hervorheben.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي أن نبرز مزايا عقد الصيانة بوضوح في العرض."
            },
            {
              "language": "ckb",
              "text": "لە پێشنیارەکەدا دەبێت سوودەکانی گرێبەستی چاکسازی بە ڕوونی جەخت بکەینەوە."
            },
            {
              "language": "en",
              "text": "In the offer, we should clearly highlight the benefits of the maintenance contract."
            },
            {
              "language": "fa",
              "text": "در پیشنهاد باید مزایای قرارداد نگهداری را واضح برجسته کنیم."
            },
            {
              "language": "kmr",
              "text": "Di pêşniyarê de divê em sûdên peymana lênêrînê bi zelalî destnîşan bikin."
            },
            {
              "language": "pl",
              "text": "W ofercie powinniśmy wyraźnie podkreślić zalety umowy serwisowej."
            },
            {
              "language": "ro",
              "text": "În ofertă ar trebui să evidențiem clar avantajele contractului de mentenanță."
            },
            {
              "language": "ru",
              "text": "В предложении мы должны чётко подчеркнуть преимущества договора обслуживания."
            },
            {
              "language": "sq",
              "text": "Në ofertë duhet t’i theksojmë qartë përfitimet e kontratës së mirëmbajtjes."
            },
            {
              "language": "tr",
              "text": "Teklifte bakım sözleşmesinin avantajlarını net şekilde vurgulamalıyız."
            }
          ]
        },
        {
          "baseText": "Die Lehrerin hebt im Text die wichtigsten Wörter hervor.",
          "translations": [
            {
              "language": "ar",
              "text": "تُبرز المعلمة أهم الكلمات في النص."
            },
            {
              "language": "ckb",
              "text": "مامۆستا وشە گرنگەکان لە دەقەکەدا دیاری دەکات."
            },
            {
              "language": "en",
              "text": "The teacher highlights the most important words in the text."
            },
            {
              "language": "fa",
              "text": "معلم مهم‌ترین کلمات را در متن برجسته می‌کند."
            },
            {
              "language": "kmr",
              "text": "Mamoste peyvên herî girîng di nivîsê de destnîşan dike."
            },
            {
              "language": "pl",
              "text": "Nauczycielka wyróżnia w tekście najważniejsze słowa."
            },
            {
              "language": "ro",
              "text": "Profesoara evidențiază cele mai importante cuvinte din text."
            },
            {
              "language": "ru",
              "text": "Учительница выделяет в тексте самые важные слова."
            },
            {
              "language": "sq",
              "text": "Mësuesja i thekson fjalët më të rëndësishme në tekst."
            },
            {
              "language": "tr",
              "text": "Öğretmen metindeki en önemli kelimeleri vurgular."
            }
          ]
        }
      ]
    },
