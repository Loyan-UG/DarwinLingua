            {
              "language": "tr",
              "text": "Dijital egemenlik izolasyon değil, kontrollü hareket kabiliyeti demektir."
            }
          ]
        },
        {
          "baseText": "In der Außenpolitik wird Souveränität häufig gegen internationale Verpflichtungen abgewogen.",
          "translations": [
