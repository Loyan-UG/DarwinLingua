      "infinitive": null,
      "syllableBreak": "Bruch-li-nie",
      "topics": [
        "advanced-analysis",
        "social-and-relationships",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "analysis",
