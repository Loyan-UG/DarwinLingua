        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يرسل"
        },
        {
          "language": "ckb",
          "text": "دەنێرێت"
        },
        {
          "language": "en",
          "text": "to send"
        },
        {
          "language": "fa",
          "text": "فرستادن"
        },
        {
          "language": "kmr",
          "text": "şandin"
        },
        {
          "language": "pl",
          "text": "wysyłać"
        },
        {
          "language": "ro",
          "text": "a trimite"
        },
        {
          "language": "ru",
          "text": "отправлять"
        },
        {
          "language": "sq",
          "text": "të dërgosh"
        },
        {
          "language": "tr",
          "text": "göndermek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich schicke Ihnen die Rechnung per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "سأرسل لكم الفاتورة عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "من فاکتورەکە بە ئیمەیڵ بۆتان دەنێرم."
            },
            {
              "language": "en",
              "text": "I will send you the invoice by email."
            },
            {
              "language": "fa",
              "text": "فاکتور را با ایمیل برای شما می‌فرستم."
            },
            {
              "language": "kmr",
              "text": "Ez fatûreyê bi e-nameyê ji we re dişînim."
            },
            {
              "language": "pl",
              "text": "Wyślę państwu fakturę e-mailem."
            },
            {
              "language": "ro",
              "text": "Vă trimit factura prin e-mail."
            },
            {
              "language": "ru",
              "text": "Я отправлю вам счет по электронной почте."
            },
            {
              "language": "sq",
              "text": "Do t’jua dërgoj faturën me email."
            },
            {
              "language": "tr",
              "text": "Faturayı size e-posta ile gönderiyorum."
            }
          ]
        },
        {
          "baseText": "Kannst du mir ein Foto schicken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن ترسل لي صورة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت وێنەیەکم بۆ بنێریت؟"
            },
            {
              "language": "en",
              "text": "Can you send me a photo?"
            },
            {
              "language": "fa",
              "text": "می‌توانی یک عکس برایم بفرستی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî wêneyekê ji min re bişînî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz mi wysłać zdjęcie?"
            },
            {
              "language": "ro",
              "text": "Poți să-mi trimiți o fotografie?"
            },
            {
              "language": "ru",
              "text": "Можешь отправить мне фотографию?"
            },
            {
              "language": "sq",
              "text": "A mund të më dërgosh një foto?"
            },
            {
              "language": "tr",
              "text": "Bana bir fotoğraf gönderebilir misin?"
            }
          ]
        }
      ]
    },
    {
      "word": "der Schinken",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Schinken",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Schin-ken",
      "topics": [
        "everyday-life",
        "shopping-and-services"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; plural has the same form"
      ],
      "collocations": [
        {
          "text": "Brot mit Schinken",
          "meaning": "bread with ham"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "لحم خنزير مقدد؛ هام"
        },
        {
          "language": "ckb",
          "text": "گۆشتی بەراز؛ شینکەن"
        },
        {
          "language": "en",
          "text": "ham"
        },
        {
          "language": "fa",
          "text": "ژامبون؛ گوشت خوک فرآوری‌شده"
        },
        {
          "language": "kmr",
          "text": "goştê berazê pijandî; ham"
        },
        {
          "language": "pl",
          "text": "szynka"
        },
        {
          "language": "ro",
          "text": "șuncă"
        },
        {
          "language": "ru",
          "text": "ветчина"
        },
        {
          "language": "sq",
          "text": "proshutë"
        },
        {
          "language": "tr",
          "text": "jambon"
        }
      ],
      "examples": [
        {
          "baseText": "Ich nehme ein Brötchen mit Schinken.",
          "translations": [
            {
              "language": "ar",
              "text": "سآخذ خبزة صغيرة مع لحم الهام."
            },
            {
              "language": "ckb",
              "text": "من نانۆکەیەک بە شینکەن وەردەگرم."
            },
            {
              "language": "en",
              "text": "I’ll take a roll with ham."
            },
            {
              "language": "fa",
              "text": "یک نان کوچک با ژامبون می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez nanekî biçûk bi hamê digirim."
            },
            {
              "language": "pl",
              "text": "Wezmę bułkę z szynką."
            },
            {
              "language": "ro",
              "text": "Iau o chiflă cu șuncă."
            },
            {
              "language": "ru",
              "text": "Я возьму булочку с ветчиной."
            },
            {
              "language": "sq",
              "text": "Do të marr një simite me proshutë."
            },
            {
              "language": "tr",
              "text": "Jambonlu bir sandviç ekmeği alacağım."
            }
          ]
        },
        {
          "baseText": "Gibt es den Schinken auch ohne Brot?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يوجد الهام أيضاً من دون خبز؟"
            },
            {
              "language": "ckb",
              "text": "ئایا شینکەنەکە بێ نانیش هەیە؟"
            },
            {
              "language": "en",
              "text": "Is the ham also available without bread?"
            },
            {
              "language": "fa",
              "text": "آیا ژامبون بدون نان هم هست؟"
            },
            {
              "language": "kmr",
              "text": "Ma ham bê nan jî heye?"
            },
            {
              "language": "pl",
              "text": "Czy szynka jest też bez chleba?"
            },
            {
              "language": "ro",
              "text": "Șunca este disponibilă și fără pâine?"
            },
            {
              "language": "ru",
              "text": "Есть ветчина также без хлеба?"
            },
            {
              "language": "sq",
              "text": "A ka proshutë edhe pa bukë?"
            },
            {
              "language": "tr",
              "text": "Jambon ekmeksiz de var mı?"
            }
          ]
        }
      ]
    },
