      ],
      "examples": [
        {
          "baseText": "Nimm bitte einen Schirm mit, es regnet.",
          "translations": [
            {
              "language": "ar",
              "text": "خذ مظلة من فضلك، إنها تمطر."
            },
            {
              "language": "ckb",
              "text": "تکایە چەتری باران لەگەڵ خۆت ببە، باران دەبارێت."
            },
            {
              "language": "en",
              "text": "Please take an umbrella; it is raining."
            },
            {
              "language": "fa",
              "text": "لطفاً چتر بردار، باران می‌آید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe sîwanekê bi xwe re bibe, baran dibare."
            },
            {
              "language": "pl",
              "text": "Weź proszę parasol, pada deszcz."
            },
            {
              "language": "ro",
              "text": "Ia, te rog, o umbrelă, plouă."
            },
            {
              "language": "ru",
              "text": "Возьми, пожалуйста, зонт, идет дождь."
            },
            {
              "language": "sq",
              "text": "Merr një çadër, të lutem, po bie shi."
            },
            {
              "language": "tr",
              "text": "Lütfen yanına bir şemsiye al, yağmur yağıyor."
            }
          ]
        },
        {
          "baseText": "Mein Schirm steht neben der Tür.",
          "translations": [
            {
              "language": "ar",
              "text": "مظلتي بجانب الباب."
            },
            {
              "language": "ckb",
              "text": "چەتری بارانەکەم لە تەنیشت دەرگاکەیە."
            },
            {
              "language": "en",
              "text": "My umbrella is next to the door."
            },
            {
              "language": "fa",
              "text": "چترم کنار در است."
            },
            {
              "language": "kmr",
              "text": "Sîwana min li kêleka derî ye."
            },
            {
              "language": "pl",
              "text": "Mój parasol stoi obok drzwi."
            },
            {
              "language": "ro",
              "text": "Umbrela mea este lângă ușă."
            },
            {
              "language": "ru",
              "text": "Мой зонт стоит рядом с дверью."
            },
            {
              "language": "sq",
              "text": "Çadra ime është pranë derës."
            },
            {
              "language": "tr",
              "text": "Şemsiyem kapının yanında."
            }
          ]
        }
      ]
