      "examples": [
        {
          "baseText": "Am Donnerstag habe ich frei.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا متفرغ يوم الخميس."
            },
            {
              "language": "ckb",
              "text": "پێنجشەممە پشووم هەیە."
            },
            {
              "language": "en",
              "text": "I am free on Thursday."
            },
            {
              "language": "fa",
              "text": "پنج‌شنبه آزاد هستم."
            },
            {
              "language": "kmr",
              "text": "Roja Pêncşemê ez vala me."
            },
            {
              "language": "pl",
              "text": "W czwartek mam wolne."
            },
            {
              "language": "ro",
              "text": "Joi sunt liber."
            },
            {
              "language": "ru",
              "text": "В четверг я свободен."
            },
            {
              "language": "sq",
              "text": "Të enjten jam i lirë."
            },
            {
              "language": "tr",
              "text": "Perşembe günü boşum."
            }
          ]
        },
        {
          "baseText": "Der Termin ist am Donnerstag.",
          "translations": [
            {
              "language": "ar",
              "text": "الموعد يوم الخميس."
            },
            {
              "language": "ckb",
              "text": "کاتەکە پێنجشەممەیە."
            },
            {
              "language": "en",
              "text": "The appointment is on Thursday."
            },
            {
              "language": "fa",
              "text": "قرار پنج‌شنبه است."
            },
            {
              "language": "kmr",
              "text": "Dem roja Pêncşemê ye."
            },
            {
              "language": "pl",
              "text": "Termin jest w czwartek."
            },
            {
              "language": "ro",
              "text": "Programarea este joi."
            },
            {
              "language": "ru",
              "text": "Встреча в четверг."
            },
            {
              "language": "sq",
              "text": "Takimi është të enjten."
            },
            {
              "language": "tr",
              "text": "Randevu Perşembe günü."
            }
          ]
        }
      ]
