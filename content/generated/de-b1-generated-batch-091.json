          "text": "die Temperatur messen",
          "meaning": "to measure the temperature"
        },
        {
          "text": "den Abstand messen",
          "meaning": "to measure the distance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Messung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "messbar",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقيس"
        },
        {
          "language": "ckb",
          "text": "دەپێوێت"
        },
        {
          "language": "en",
          "text": "to measure"
        },
        {
          "language": "fa",
          "text": "اندازه گرفتن"
        },
        {
          "language": "kmr",
          "text": "pîvan"
        },
        {
          "language": "pl",
          "text": "mierzyć"
        },
        {
          "language": "ro",
          "text": "a măsura"
        },
        {
          "language": "ru",
          "text": "измерять"
        },
        {
          "language": "sq",
          "text": "të matësh"
        },
        {
          "language": "tr",
          "text": "ölçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Techniker misst den Abstand zwischen den beiden Maschinen.",
          "translations": [
            {
              "language": "ar",
              "text": "يقيس الفني المسافة بين الآلتين."
            },
            {
              "language": "ckb",
              "text": "تەکنیککارەکە دووری نێوان دوو ئامێرەکە دەپێوێت."
            },
            {
              "language": "en",
              "text": "The technician measures the distance between the two machines."
            },
            {
              "language": "fa",
              "text": "تکنسین فاصله بین دو دستگاه را اندازه می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Teknîsyen dûrahiya di navbera her du makîneyan de dipîve."
            },
            {
              "language": "pl",
              "text": "Technik mierzy odległość między dwiema maszynami."
            },
            {
              "language": "ro",
              "text": "Tehnicianul măsoară distanța dintre cele două mașini."
            },
            {
              "language": "ru",
              "text": "Техник измеряет расстояние между двумя машинами."
            },
            {
              "language": "sq",
              "text": "Tekniku mat largësinë midis dy makinerive."
            },
            {
              "language": "tr",
              "text": "Teknisyen iki makine arasındaki mesafeyi ölçüyor."
            }
          ]
        },
        {
          "baseText": "Ich messe kurz Fieber, bevor ich zur Arbeit gehe.",
          "translations": [
            {
              "language": "ar",
              "text": "أقيس حرارتي بسرعة قبل أن أذهب إلى العمل."
            },
            {
              "language": "ckb",
              "text": "پێش ئەوەی بچم بۆ کار بە خێرایی پلەی گەرمیم دەپێوم."
            },
            {
              "language": "en",
              "text": "I quickly take my temperature before I go to work."
            },
            {
              "language": "fa",
              "text": "قبل از رفتن به محل کار سریع تبم را اندازه می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Berî ku biçim kar ez bi lez germiya xwe dipîvim."
            },
            {
              "language": "pl",
              "text": "Szybko mierzę temperaturę, zanim pójdę do pracy."
            },
            {
              "language": "ro",
              "text": "Îmi măsor repede temperatura înainte să merg la serviciu."
            },
            {
              "language": "ru",
              "text": "Я быстро измеряю температуру перед тем, как пойти на работу."
            },
            {
              "language": "sq",
              "text": "E mas shpejt temperaturën para se të shkoj në punë."
            },
            {
              "language": "tr",
              "text": "İşe gitmeden önce hızlıca ateşimi ölçüyorum."
            }
          ]
        }
      ]
    },
