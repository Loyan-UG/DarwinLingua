  "entries": [
    {
      "word": "melden",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "melden",
      "pronunciationIpa": null,
      "syllableBreak": "mel-den",
      "topics": [
        "public-services",
        "business-communication",
        "customer-service"
      ],
      "usageLabels": [
        "everyday",
        "formal",
        "workplace",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb; can mean to report, register, or get in touch depending on context"
      ],
      "collocations": [
        {
          "text": "sich beim Bürgeramt melden",
          "meaning": "to register or report to the citizens office"
        },
        {
          "text": "sich später melden",
          "meaning": "to get back to someone later"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Meldung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "angemeldet",
          "relationLabel": "participle/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يُبلّغ؛ يسجّل؛ يتواصل"
        },
        {
          "language": "ckb",
          "text": "ڕاپۆرت دەدات؛ تۆمار دەکات؛ پەیوەندی دەکات"
        },
        {
          "language": "en",
          "text": "to report; to register; to get in touch"
        },
        {
          "language": "fa",
          "text": "گزارش دادن؛ ثبت‌نام کردن؛ تماس گرفتن"
        },
        {
          "language": "kmr",
          "text": "ragihandin; qeydkirin; têkilî danîn"
        },
        {
          "language": "pl",
          "text": "zgłaszać; rejestrować się; odezwać się"
        },
        {
          "language": "ro",
          "text": "a anunța; a se înregistra; a lua legătura"
        },
        {
          "language": "ru",
          "text": "сообщать; регистрироваться; связаться"
        },
        {
          "language": "sq",
          "text": "të njoftosh; të regjistrohesh; të kontaktosh"
        },
        {
          "language": "tr",
          "text": "bildirmek; kayıt yaptırmak; iletişime geçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte melden Sie sich, wenn der Kunde zurückruft.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إبلاغنا عندما يعاود العميل الاتصال."
            },
            {
              "language": "ckb",
              "text": "تکایە ئاگادارمان بکەرەوە کاتێک کڕیارەکە پەیوەندی دەکاتەوە."
            },
            {
              "language": "en",
              "text": "Please let us know when the customer calls back."
            },
            {
              "language": "fa",
              "text": "لطفاً وقتی مشتری دوباره تماس گرفت، خبر بدهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe gava mişterî vegere telefonê me agahdar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę dać znać, kiedy klient oddzwoni."
            },
            {
              "language": "ro",
              "text": "Vă rog să ne anunțați când clientul sună înapoi."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сообщите, когда клиент перезвонит."
            },
            {
              "language": "sq",
              "text": "Ju lutem na njoftoni kur klienti të telefonojë përsëri."
            },
            {
              "language": "tr",
              "text": "Müşteri geri aradığında lütfen bize haber verin."
            }
          ]
        },
        {
          "baseText": "Nach dem Umzug müssen Sie sich innerhalb von zwei Wochen anmelden.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الانتقال يجب أن تسجّل عنوانك خلال أسبوعين."
            },
            {
              "language": "ckb",
              "text": "دوای گواستنەوە پێویستە لە ماوەی دوو هەفتەدا خۆت تۆمار بکەیت."
            },
            {
              "language": "en",
              "text": "After moving, you must register within two weeks."
            },
            {
              "language": "fa",
              "text": "بعد از اسباب‌کشی باید ظرف دو هفته ثبت‌نام کنید."
            },
            {
              "language": "kmr",
              "text": "Piştî bar kirinê divê hûn di nav du hefteyan de xwe qeyd bikin."
            },
            {
              "language": "pl",
              "text": "Po przeprowadzce trzeba się zameldować w ciągu dwóch tygodni."
            },
            {
              "language": "ro",
              "text": "După mutare trebuie să vă înregistrați în termen de două săptămâni."
            },
            {
              "language": "ru",
              "text": "После переезда нужно зарегистрироваться в течение двух недель."
            },
            {
              "language": "sq",
              "text": "Pas zhvendosjes duhet të regjistroheni brenda dy javësh."
            },
            {
              "language": "tr",
              "text": "Taşındıktan sonra iki hafta içinde kayıt yaptırmanız gerekir."
            }
          ]
        }
      ]
    },
    {
      "word": "messen",
