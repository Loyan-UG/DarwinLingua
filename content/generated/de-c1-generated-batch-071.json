      "meanings": [
        {
          "language": "ar",
          "text": "التواصل في الأزمات؛ إدارة الرسائل أثناء الأزمة"
        },
        {
          "language": "ckb",
          "text": "پەیوەندی لە کاتی قەیراندا"
        },
        {
          "language": "en",
          "text": "crisis communication"
        },
        {
          "language": "fa",
          "text": "ارتباطات بحران؛ اطلاع‌رسانی در بحران"
        },
        {
          "language": "kmr",
          "text": "ragihandina di krîzê de"
        },
        {
          "language": "pl",
          "text": "komunikacja kryzysowa"
        },
        {
          "language": "ro",
          "text": "comunicare de criză"
        },
        {
          "language": "ru",
          "text": "кризисная коммуникация"
        },
        {
          "language": "sq",
          "text": "komunikim në krizë"
        },
        {
          "language": "tr",
          "text": "kriz iletişimi"
        }
      ],
      "examples": [
        {
          "baseText": "Eine klare Krisenkommunikation verhindert, dass Gerüchte die öffentliche Wahrnehmung bestimmen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمنع التواصل الواضح في الأزمات أن تحدد الشائعات تصور الجمهور."
            },
            {
              "language": "ckb",
              "text": "پەیوەندیی ڕوون لە کاتی قەیراندا ڕێ دەگرێت لەوەی دەنگۆکان تێگەیشتنی گشتی دیاری بکەن."
            },
            {
              "language": "en",
              "text": "Clear crisis communication prevents rumors from shaping public perception."
            },
            {
              "language": "fa",
              "text": "ارتباطات شفاف بحران مانع می‌شود شایعات برداشت عمومی را شکل دهند."
            },
            {
              "language": "kmr",
              "text": "Ragihandina zelal di krîzê de rê nade ku gotegot têgihiştina giştî diyar bikin."
            },
            {
              "language": "pl",
              "text": "Jasna komunikacja kryzysowa zapobiega temu, by plotki kształtowały odbiór publiczny."
            },
            {
              "language": "ro",
              "text": "O comunicare clară de criză împiedică zvonurile să determine percepția publică."
            },
            {
              "language": "ru",
              "text": "Четкая кризисная коммуникация не позволяет слухам формировать общественное восприятие."
            },
            {
              "language": "sq",
              "text": "Komunikimi i qartë në krizë pengon që thashethemet të përcaktojnë perceptimin publik."
            },
            {
              "language": "tr",
              "text": "Açık kriz iletişimi, söylentilerin kamu algısını belirlemesini engeller."
            }
          ]
        },
        {
          "baseText": "Nach dem Datenleck wurde die Krisenkommunikation zentral vom Datenschutzteam koordiniert.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تسرب البيانات نُسق التواصل في الأزمة مركزياً من قبل فريق حماية البيانات."
            },
            {
              "language": "ckb",
              "text": "دوای داتالێکەکە پەیوەندیی قەیرانەکە بە ناوەندی لەلایەن تیمی پاراستنی داتاوە ڕێکخرا."
            },
            {
              "language": "en",
              "text": "After the data leak, crisis communication was coordinated centrally by the data protection team."
            },
            {
              "language": "fa",
              "text": "پس از نشت داده، ارتباطات بحران به‌صورت مرکزی توسط تیم حفاظت از داده هماهنگ شد."
            },
            {
              "language": "kmr",
              "text": "Piştî derketina daneyan, ragihandina krîzê ji aliyê tîma parastina daneyan ve navendî hat koordîne kirin."
            },
            {
              "language": "pl",
              "text": "Po wycieku danych komunikacja kryzysowa była centralnie koordynowana przez zespół ochrony danych."
            },
            {
              "language": "ro",
              "text": "După scurgerea de date, comunicarea de criză a fost coordonată central de echipa de protecție a datelor."
            },
            {
              "language": "ru",
              "text": "После утечки данных кризисную коммуникацию централизованно координировала команда по защите данных."
            },
            {
              "language": "sq",
              "text": "Pas rrjedhjes së të dhënave, komunikimi në krizë u koordinua në mënyrë qendrore nga ekipi i mbrojtjes së të dhënave."
            },
            {
              "language": "tr",
              "text": "Veri sızıntısından sonra kriz iletişimi veri koruma ekibi tarafından merkezi olarak koordine edildi."
            }
          ]
        }
      ]
    },
