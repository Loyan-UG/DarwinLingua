      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينجح في؛ يوجد؛ يتكون من"
        },
        {
          "language": "ckb",
          "text": "دەرچوون؛ بوون؛ پێک هاتن لە"
        },
        {
          "language": "en",
          "text": "to pass; to exist; to consist of"
        },
        {
          "language": "fa",
          "text": "قبول شدن؛ وجود داشتن؛ تشکیل شدن از"
        },
        {
          "language": "kmr",
          "text": "derbas bûn; hebûn; ji tiştekê pêk hatin"
        },
        {
          "language": "pl",
          "text": "zdać; istnieć; składać się z"
        },
        {
          "language": "ro",
          "text": "a promova; a exista; a consta din"
        },
        {
          "language": "ru",
          "text": "сдать; существовать; состоять из"
        },
        {
          "language": "sq",
          "text": "të kalosh; të ekzistosh; të përbëhesh nga"
        },
        {
          "language": "tr",
          "text": "geçmek; var olmak; oluşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn ich die Prüfung bestehe, kann ich im Sommer mit der Ausbildung anfangen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا نجحت في الامتحان، يمكنني أن أبدأ التدريب المهني في الصيف."
            },
            {
              "language": "ckb",
              "text": "ئەگەر لە تاقیکردنەوەکە دەرچم، دەتوانم لە هاویندا دەست بە فێربوونی پیشەیی بکەم."
            },
            {
              "language": "en",
              "text": "If I pass the exam, I can start the vocational training in summer."
            },
            {
              "language": "fa",
              "text": "اگر در امتحان قبول شوم، می‌توانم تابستان آموزش حرفه‌ای را شروع کنم."
            },
            {
              "language": "kmr",
              "text": "Heke ez di azmûnê de derbas bibim, ez dikarim havînê dest bi perwerdeya pîşeyî bikim."
            },
            {
              "language": "pl",
              "text": "Jeśli zdam egzamin, mogę latem rozpocząć szkolenie zawodowe."
            },
            {
              "language": "ro",
              "text": "Dacă promovez examenul, pot începe formarea profesională vara."
            },
            {
              "language": "ru",
              "text": "Если я сдам экзамен, летом смогу начать профессиональное обучение."
            },
            {
              "language": "sq",
              "text": "Nëse e kaloj provimin, mund ta filloj trajnimin profesional në verë."
            },
            {
              "language": "tr",
              "text": "Sınavı geçersem yazın mesleki eğitime başlayabilirim."
            }
          ]
        },
        {
          "baseText": "Der Vertrag besteht aus drei Teilen und zwei Anlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "يتكون العقد من ثلاثة أجزاء وملحقين."
            },
            {
              "language": "ckb",
              "text": "گرێبەستەکە لە سێ بەش و دوو پاشکۆ پێک هاتووە."
            },
            {
              "language": "en",
              "text": "The contract consists of three parts and two attachments."
            },
            {
              "language": "fa",
              "text": "قرارداد از سه بخش و دو پیوست تشکیل شده است."
            },
            {
              "language": "kmr",
              "text": "Peyman ji sê beşan û du pêvekan pêk tê."
            },
            {
              "language": "pl",
              "text": "Umowa składa się z trzech części i dwóch załączników."
            },
            {
              "language": "ro",
              "text": "Contractul constă din trei părți și două anexe."
            },
            {
              "language": "ru",
              "text": "Договор состоит из трех частей и двух приложений."
            },
            {
              "language": "sq",
              "text": "Kontrata përbëhet nga tri pjesë dhe dy shtojca."
            },
            {
              "language": "tr",
              "text": "Sözleşme üç bölümden ve iki ekten oluşuyor."
            }
          ]
        }
      ]
    }
