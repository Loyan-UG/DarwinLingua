        {
          "baseText": "Kann ich Ihr Telefon benutzen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني استخدام هاتفك؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم تەلەفۆنەکەتان بەکاربهێنم؟"
            },
            {
              "language": "en",
              "text": "Can I use your phone?"
            },
            {
              "language": "fa",
              "text": "می‌توانم از تلفن شما استفاده کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim telefona we bikar bînim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę skorzystać z pana telefonu?"
            },
            {
              "language": "ro",
              "text": "Pot să folosesc telefonul dumneavoastră?"
            },
            {
              "language": "ru",
              "text": "Можно мне воспользоваться вашим телефоном?"
            },
            {
              "language": "sq",
              "text": "A mund ta përdor telefonin tuaj?"
            },
            {
              "language": "tr",
              "text": "Telefonunuzu kullanabilir miyim?"
            }
          ]
        },
        {
          "baseText": "Bitte benutzen Sie den Eingang rechts.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى استخدام المدخل على اليمين."
            },
            {
              "language": "ckb",
              "text": "تکایە دەرگای چوونەژوورەوەی لای ڕاست بەکاربهێنن."
            },
            {
              "language": "en",
              "text": "Please use the entrance on the right."
            },
            {
              "language": "fa",
              "text": "لطفاً از ورودی سمت راست استفاده کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe deriyê ketinê yê rastê bikar bînin."
            },
            {
              "language": "pl",
              "text": "Proszę skorzystać z wejścia po prawej stronie."
            },
            {
              "language": "ro",
              "text": "Vă rog să folosiți intrarea din dreapta."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, используйте вход справа."
            },
            {
              "language": "sq",
              "text": "Ju lutem përdorni hyrjen në të djathtë."
            },
            {
              "language": "tr",
              "text": "Lütfen sağdaki girişi kullanın."
            }
