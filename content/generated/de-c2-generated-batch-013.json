  "entries": [
    {
      "word": "befliegen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "befliegen",
      "pronunciationIpa": null,
      "syllableBreak": "be-flie-gen",
      "topics": [
        "transport-and-travel",
        "business-communication",
        "planning-and-projects"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "transitive verb; befliegt, beflog, hat beflogen; used for routes served by aircraft"
      ],
      "collocations": [
        {
          "text": "eine Strecke regelmäßig befliegen",
          "meaning": "to serve a route regularly by air"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Flug",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسيّر رحلات جوية إلى؛ يخدم خطاً جوياً"
        },
        {
          "language": "ckb",
          "text": "هێڵێکی ئاسمانی بە فڕۆکە خزمەت بکات"
        },
        {
          "language": "en",
          "text": "to serve an air route; to fly to regularly"
        },
        {
          "language": "fa",
          "text": "به‌طور منظم به مسیر هوایی پرواز کردن"
        },
        {
          "language": "kmr",
          "text": "rêyek hewayî bi rêkûpêk firandin"
        },
        {
          "language": "pl",
          "text": "obsługiwać trasę lotniczą"
        },
        {
          "language": "ro",
          "text": "a opera o rută aeriană"
        },
        {
          "language": "ru",
          "text": "обслуживать авиамаршрут"
        },
        {
          "language": "sq",
          "text": "të shërbesh një linjë ajrore"
        },
        {
          "language": "tr",
          "text": "bir hava hattına düzenli uçmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Airline befliegt die Strecke nach Zürich ab Juni wieder täglich.",
          "translations": [
            {
              "language": "ar",
              "text": "ستسيّر شركة الطيران رحلات يومية إلى زيورخ مرة أخرى اعتباراً من يونيو."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیای فڕۆکەوانییەکە لە حوزەیرانەوە هێڵی زوریخ جارێکی تر ڕۆژانە دەخاتە کار."
            },
            {
              "language": "en",
              "text": "The airline will serve the route to Zurich daily again from June."
            },
            {
              "language": "fa",
              "text": "شرکت هواپیمایی از ژوئن دوباره مسیر زوریخ را روزانه پوشش می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Şirketa balafiran ji hezîranê ve rêya Zurichê dîsa rojane dixebitîne."
            },
            {
              "language": "pl",
              "text": "Linia lotnicza od czerwca znów będzie codziennie obsługiwać trasę do Zurychu."
            },
            {
              "language": "ro",
              "text": "Compania aeriană va opera din nou zilnic ruta spre Zürich începând din iunie."
            },
            {
              "language": "ru",
              "text": "Авиакомпания снова будет ежедневно обслуживать маршрут до Цюриха с июня."
            },
            {
              "language": "sq",
              "text": "Kompania ajrore do ta shërbejë sërish çdo ditë linjën për në Cyrih nga qershori."
            },
            {
              "language": "tr",
              "text": "Havayolu hazirandan itibaren Zürih hattına yeniden günlük uçacak."
            }
          ]
        },
        {
          "baseText": "Für das neue Werk wurde geprüft, welche europäischen Drehkreuze zuverlässig beflogen werden.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة إلى المصنع الجديد تم فحص أي مراكز أوروبية تُخدم جوياً بشكل موثوق."
            },
            {
              "language": "ckb",
              "text": "بۆ کارگە نوێیەکە پشکنرا کە کام ناوەندی ئەورووپی بە متمانەوە بە فڕۆکە خزمەت دەکرێن."
            },
            {
              "language": "en",
              "text": "For the new plant, they checked which European hubs are served reliably by air."
            },
            {
              "language": "fa",
              "text": "برای کارخانه جدید بررسی شد کدام قطب‌های اروپایی به‌طور قابل اعتماد با پرواز پوشش داده می‌شوند."
            },
            {
              "language": "kmr",
              "text": "Ji bo kargeha nû hate kontrolkirin ka kîjan navendên Ewropayê bi bawerî tên firandin."
            },
            {
              "language": "pl",
              "text": "Dla nowego zakładu sprawdzono, które europejskie huby są niezawodnie obsługiwane lotniczo."
            },
            {
              "language": "ro",
              "text": "Pentru noua fabrică s-a verificat ce huburi europene sunt deservite fiabil pe calea aerului."
            },
            {
              "language": "ru",
              "text": "Для нового завода проверили, какие европейские хабы надёжно обслуживаются авиарейсами."
            },
            {
              "language": "sq",
              "text": "Për fabrikën e re u kontrollua cilat qendra evropiane shërbehen me besueshmëri nga ajri."
            },
            {
              "language": "tr",
              "text": "Yeni tesis için hangi Avrupa merkezlerine güvenilir şekilde uçulduğu kontrol edildi."
            }
          ]
        }
      ]
    },
    {
      "word": "begehren",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "begehren",
      "pronunciationIpa": null,
      "syllableBreak": "be-geh-ren",
      "topics": [
        "law-and-compliance",
        "social-and-relationships",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "transitive/intransitive verb; begehrt, begehrte, hat begehrt; elevated: to desire or request formally"
      ],
      "collocations": [
        {
          "text": "Auskunft begehren",
          "meaning": "to formally request information"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Begehren",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يرغب بشدة؛ يطلب رسمياً"
        },
        {
          "language": "ckb",
          "text": "بە توندی ئارەزوو بکات؛ بە فەرمی داوا بکات"
        },
        {
          "language": "en",
          "text": "to desire; to request formally"
        },
        {
          "language": "fa",
          "text": "خواستن؛ میل شدید داشتن؛ رسماً درخواست کردن"
        },
        {
          "language": "kmr",
          "text": "bi xwestekê xwestin; bi fermî daxwaz kirin"
        },
        {
          "language": "pl",
          "text": "pożądać; żądać formalnie"
        },
        {
          "language": "ro",
          "text": "a dori intens; a solicita formal"
        },
        {
          "language": "ru",
          "text": "желать; официально требовать"
        },
        {
          "language": "sq",
          "text": "të dëshirosh fort; të kërkosh zyrtarisht"
        },
        {
          "language": "tr",
          "text": "arzulamak; resmen talep etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kläger begehrt Einsicht in die Unterlagen, auf die sich die Entscheidung stützt.",
          "translations": [
            {
              "language": "ar",
              "text": "يطالب المدعي بالاطلاع على الوثائق التي يستند إليها القرار."
            },
            {
              "language": "ckb",
              "text": "داواکەر داوای بینینی ئەو بەڵگەنامانە دەکات کە بڕیارەکە لەسەریان دامەزراوە."
            },
            {
              "language": "en",
              "text": "The plaintiff seeks access to the documents on which the decision is based."
            },
            {
              "language": "fa",
              "text": "خواهان درخواست دسترسی به مدارکی را دارد که تصمیم بر آن‌ها استوار است."
            },
            {
              "language": "kmr",
              "text": "Dozger daxwaza dîtina belgeyên ku biryar li ser wan ava ye dike."
            },
            {
              "language": "pl",
              "text": "Powód domaga się wglądu w dokumenty, na których opiera się decyzja."
            },
            {
              "language": "ro",
              "text": "Reclamantul solicită acces la documentele pe care se bazează decizia."
            },
            {
              "language": "ru",
              "text": "Истец требует ознакомления с документами, на которых основано решение."
            },
            {
              "language": "sq",
              "text": "Paditësi kërkon qasje në dokumentet mbi të cilat mbështetet vendimi."
            },
            {
              "language": "tr",
              "text": "Davacı, kararın dayandığı belgelere erişim talep ediyor."
            }
          ]
        },
        {
          "baseText": "Die Erzählung zeigt, wie sehr die Figur nach Anerkennung begehrt.",
          "translations": [
            {
              "language": "ar",
              "text": "تُظهر القصة مدى توق الشخصية إلى الاعتراف."
            },
            {
              "language": "ckb",
              "text": "چیرۆکەکە پیشان دەدات کارەکتەرەکە چەندە بەدوای ناسینەوەدا دەگەڕێت."
            },
            {
              "language": "en",
              "text": "The narrative shows how deeply the character longs for recognition."
            },
            {
              "language": "fa",
              "text": "روایت نشان می‌دهد شخصیت تا چه اندازه در طلب به‌رسمیت‌شناخته‌شدن است."
            },
            {
              "language": "kmr",
              "text": "Çîrok nîşan dide karakter çiqas bi kûrî naskirinê dixwaze."
            },
            {
              "language": "pl",
              "text": "Opowieść pokazuje, jak bardzo postać pragnie uznania."
            },
            {
              "language": "ro",
              "text": "Narațiunea arată cât de mult tânjește personajul după recunoaștere."
            },
            {
              "language": "ru",
              "text": "Повествование показывает, насколько персонаж жаждет признания."
            },
            {
              "language": "sq",
              "text": "Rrëfimi tregon sa shumë personazhi dëshiron njohje."
            },
            {
              "language": "tr",
              "text": "Anlatı, karakterin tanınmayı ne kadar derinden arzuladığını gösterir."
            }
          ]
        }
      ]
    },
