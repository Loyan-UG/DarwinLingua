            },
            {
              "language": "en",
              "text": "Can you please sort the laundry?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً لباس‌های شسته را جدا کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî ji kerema xwe cilşûştinê veqetînî?"
