      "examples": [
        {
          "baseText": "Ich sortiere die Rechnungen nach Datum.",
          "translations": [
            {
              "language": "ar",
              "text": "أرتب الفواتير حسب التاريخ."
            },
            {
              "language": "ckb",
              "text": "من فاکتورەکان بە پێی بەروار ڕیز دەکەم."
            },
            {
              "language": "en",
              "text": "I sort the invoices by date."
            },
            {
              "language": "fa",
              "text": "من فاکتورها را بر اساس تاریخ مرتب می‌کنم."
            },
