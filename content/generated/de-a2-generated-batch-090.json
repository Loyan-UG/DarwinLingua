        },
        {
          "language": "tr",
          "text": "güneşli"
        }
      ],
      "examples": [
        {
          "baseText": "Morgen wird es sonnig und warm.",
          "translations": [
            {
              "language": "ar",
              "text": "غداً سيكون الجو مشمساً ودافئاً."
            },
            {
              "language": "ckb",
              "text": "سبەی کەش خۆراوی و گەرم دەبێت."
            },
            {
              "language": "en",
              "text": "Tomorrow it will be sunny and warm."
            },
            {
              "language": "fa",
              "text": "فردا هوا آفتابی و گرم می‌شود."
            },
            {
              "language": "kmr",
              "text": "Sibê dê hewa tavî û germ be."
            },
            {
              "language": "pl",
              "text": "Jutro będzie słonecznie i ciepło."
            },
            {
              "language": "ro",
              "text": "Mâine va fi însorit și cald."
            },
            {
              "language": "ru",
              "text": "Завтра будет солнечно и тепло."
            },
            {
              "language": "sq",
              "text": "Nesër do të jetë me diell dhe ngrohtë."
            },
            {
              "language": "tr",
              "text": "Yarın hava güneşli ve sıcak olacak."
            }
          ]
        },
        {
          "baseText": "Wir sitzen gern auf dem sonnigen Balkon.",
          "translations": [
            {
              "language": "ar",
              "text": "نحب الجلوس على الشرفة المشمسة."
            },
            {
              "language": "ckb",
              "text": "ئێمە حەز دەکەین لە بالکۆنە خۆراوییەکە دابنیشین."
            },
            {
              "language": "en",
              "text": "We like sitting on the sunny balcony."
            },
            {
              "language": "fa",
              "text": "ما دوست داریم روی بالکن آفتابی بنشینیم."
            },
            {
              "language": "kmr",
              "text": "Em hez dikin li balkonê tavî rûnin."
            },
            {
              "language": "pl",
              "text": "Lubimy siedzieć na słonecznym balkonie."
            },
            {
              "language": "ro",
              "text": "Ne place să stăm pe balconul însorit."
            },
            {
              "language": "ru",
              "text": "Мы любим сидеть на солнечном балконе."
            },
            {
              "language": "sq",
              "text": "Na pëlqen të ulemi në ballkonin me diell."
            },
            {
              "language": "tr",
              "text": "Güneşli balkonda oturmayı seviyoruz."
            }
          ]
        }
