      "meanings": [
        {
          "language": "ar",
          "text": "نظارة شمسية"
        },
        {
          "language": "ckb",
          "text": "چاویلکەی خۆر"
        },
        {
          "language": "en",
          "text": "sunglasses"
        },
        {
          "language": "fa",
          "text": "عینک آفتابی"
        },
        {
          "language": "kmr",
          "text": "çavikên tavê"
        },
        {
          "language": "pl",
          "text": "okulary przeciwsłoneczne"
        },
        {
          "language": "ro",
          "text": "ochelari de soare"
        },
        {
          "language": "ru",
          "text": "солнцезащитные очки"
        },
        {
          "language": "sq",
          "text": "syze dielli"
        },
        {
          "language": "tr",
          "text": "güneş gözlüğü"
        }
      ],
      "examples": [
        {
          "baseText": "Ich brauche eine Sonnenbrille für den Urlaub.",
          "translations": [
            {
              "language": "ar",
              "text": "أحتاج إلى نظارة شمسية للعطلة."
            },
            {
              "language": "ckb",
              "text": "من بۆ پشوویەکە پێویستم بە چاویلکەی خۆر هەیە."
            },
            {
              "language": "en",
              "text": "I need sunglasses for the vacation."
            },
            {
              "language": "fa",
              "text": "برای سفر به عینک آفتابی نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ez ji bo betlaneyê hewceyê çavikên tavê me."
            },
            {
              "language": "pl",
              "text": "Potrzebuję okularów przeciwsłonecznych na urlop."
            },
            {
              "language": "ro",
              "text": "Am nevoie de ochelari de soare pentru vacanță."
            },
            {
              "language": "ru",
              "text": "Мне нужны солнцезащитные очки для отпуска."
            },
            {
              "language": "sq",
              "text": "Më duhen syze dielli për pushime."
            },
            {
              "language": "tr",
              "text": "Tatil için güneş gözlüğüne ihtiyacım var."
            }
          ]
        },
        {
          "baseText": "Haben Sie diese Sonnenbrille auch in Schwarz?",
          "translations": [
            {
              "language": "ar",
              "text": "هل لديكم هذه النظارة الشمسية أيضاً باللون الأسود؟"
            },
            {
              "language": "ckb",
              "text": "ئایا ئەم چاویلکەی خۆرەتان بە ڕەشییش هەیە؟"
            },
            {
              "language": "en",
              "text": "Do you also have these sunglasses in black?"
            },
            {
              "language": "fa",
              "text": "آیا این عینک آفتابی را به رنگ مشکی هم دارید؟"
            },
            {
              "language": "kmr",
              "text": "Ma ev çavikên tavê bi reş jî hene?"
            },
            {
              "language": "pl",
              "text": "Czy mają państwo te okulary przeciwsłoneczne także w czarnym kolorze?"
            },
            {
              "language": "ro",
              "text": "Aveți acești ochelari de soare și pe negru?"
            },
            {
              "language": "ru",
              "text": "У вас есть эти солнцезащитные очки также в черном цвете?"
            },
            {
              "language": "sq",
              "text": "A i keni këto syze dielli edhe në të zezë?"
            },
            {
              "language": "tr",
              "text": "Bu güneş gözlüğünün siyahı da var mı?"
            }
          ]
        }
      ]
    },
