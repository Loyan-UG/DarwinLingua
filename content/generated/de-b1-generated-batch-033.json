  "entries": [
    {
      "word": "die Besprechungsnotiz",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Besprechungsnotizen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-spre-chungs-no-tiz",
      "topics": [
        "meetings-and-presentations",
        "documents-and-administration",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "written",
        "formal"
      ],
      "contextLabels": [
        "documents",
        "administration",
        "management"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Besprechungsnotiz schreiben",
          "meaning": "to write a meeting note"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Besprechung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Notiz",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ملاحظة اجتماع؛ مذكرة اجتماع"
        },
        {
          "language": "ckb",
          "text": "تێبینی کۆبوونەوە"
        },
        {
          "language": "en",
          "text": "meeting note; meeting memo"
        },
        {
          "language": "fa",
          "text": "یادداشت جلسه؛ نکته‌های جلسه"
        },
        {
          "language": "kmr",
          "text": "nîşeya civînê; notê civînê"
        },
        {
          "language": "pl",
          "text": "notatka ze spotkania"
        },
        {
          "language": "ro",
          "text": "notă de ședință"
        },
        {
          "language": "ru",
          "text": "заметка по итогам встречи; служебная запись"
        },
        {
          "language": "sq",
          "text": "shënim takimi"
        },
        {
          "language": "tr",
          "text": "toplantı notu"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du mir die Besprechungsnotiz von gestern schicken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن ترسل لي ملاحظة اجتماع الأمس؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت تێبینی کۆبوونەوەی دوێنێم بۆ بنێریت؟"
            },
            {
              "language": "en",
              "text": "Can you send me yesterday’s meeting note?"
            },
            {
              "language": "fa",
              "text": "می‌توانی یادداشت جلسه دیروز را برایم بفرستی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî notê civîna duh ji min re bişînî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz wysłać mi notatkę z wczorajszego spotkania?"
            },
            {
              "language": "ro",
              "text": "Poți să-mi trimiți nota de ședință de ieri?"
            },
            {
              "language": "ru",
              "text": "Можешь прислать мне заметку со вчерашнего совещания?"
            },
            {
              "language": "sq",
              "text": "A mund të ma dërgosh shënimin e takimit të djeshëm?"
            },
            {
              "language": "tr",
              "text": "Dünkü toplantı notunu bana gönderebilir misin?"
            }
          ]
        },
        {
          "baseText": "In der Besprechungsnotiz stehen die nächsten Schritte und die offenen Fragen.",
          "translations": [
            {
              "language": "ar",
              "text": "تتضمن ملاحظة الاجتماع الخطوات التالية والأسئلة المفتوحة."
            },
            {
              "language": "ckb",
              "text": "لە تێبینی کۆبوونەوەکەدا هەنگاوە داهاتووەکان و پرسیارە کراوەکان هەن."
            },
            {
              "language": "en",
              "text": "The meeting note contains the next steps and the open questions."
            },
            {
              "language": "fa",
              "text": "در یادداشت جلسه، مراحل بعدی و پرسش‌های باز آمده است."
            },
            {
              "language": "kmr",
              "text": "Di nota civînê de gavên pêşeroj û pirsên vekirî hene."
            },
            {
              "language": "pl",
              "text": "W notatce ze spotkania są kolejne kroki i otwarte pytania."
            },
            {
              "language": "ro",
              "text": "În nota de ședință sunt pașii următori și întrebările deschise."
            },
            {
              "language": "ru",
              "text": "В заметке по встрече указаны следующие шаги и открытые вопросы."
            },
            {
              "language": "sq",
              "text": "Në shënimin e takimit janë hapat e ardhshëm dhe pyetjet e hapura."
            },
            {
              "language": "tr",
              "text": "Toplantı notunda sonraki adımlar ve açık sorular yer alıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "bestehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "bestehen",
