      "collocations": [
        {
          "text": "ein Badetuch mitnehmen",
          "meaning": "to take a bath towel"
        },
        {
          "text": "ein großes Badetuch",
          "meaning": "a large bath towel"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "baden",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "das Tuch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "منشفة حمام؛ منشفة شاطئ"
        },
        {
          "language": "ckb",
          "text": "خاولی گەورەی حەمام/مەلە"
        },
        {
          "language": "en",
          "text": "bath towel; beach towel"
        },
        {
          "language": "fa",
          "text": "حوله حمام؛ حوله ساحل"
        },
        {
          "language": "kmr",
          "text": "destmalê mezin ê avjeniyê"
        },
        {
          "language": "pl",
          "text": "ręcznik kąpielowy"
        },
        {
          "language": "ro",
          "text": "prosop de baie"
        },
        {
          "language": "ru",
          "text": "банное полотенце"
        },
        {
          "language": "sq",
          "text": "peshqir banje"
        },
        {
          "language": "tr",
          "text": "banyo havlusu; plaj havlusu"
        }
      ],
      "examples": [
        {
          "baseText": "Nimm bitte ein Badetuch mit ins Schwimmbad.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك خذ منشفة حمام معك إلى المسبح."
            },
            {
              "language": "ckb",
              "text": "تکایە خاولییەکی گەورە لەگەڵ خۆت بۆ مەلەوانگە ببە."
            },
            {
              "language": "en",
              "text": "Please take a bath towel with you to the swimming pool."
            },
            {
              "language": "fa",
              "text": "لطفاً یک حوله حمام با خودت به استخر ببر."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe destmalek mezin bi xwe re bibe hewzê."
            },
            {
              "language": "pl",
              "text": "Weź proszę ręcznik kąpielowy na basen."
            },
            {
              "language": "ro",
              "text": "Te rog să iei un prosop de baie la piscină."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, возьми полотенце в бассейн."
            },
            {
              "language": "sq",
              "text": "Të lutem merre një peshqir banje në pishinë."
            },
            {
              "language": "tr",
              "text": "Lütfen havuza bir banyo havlusu götür."
            }
          ]
        },
        {
          "baseText": "Das Badetuch ist noch nass.",
          "translations": [
            {
              "language": "ar",
              "text": "منشفة الحمام ما زالت مبللة."
            },
            {
              "language": "ckb",
              "text": "خاولییەکە هێشتا تەڕە."
            },
            {
              "language": "en",
              "text": "The bath towel is still wet."
            },
            {
              "language": "fa",
              "text": "حوله هنوز خیس است."
            },
            {
              "language": "kmr",
              "text": "Destmal hîn şil e."
            },
            {
              "language": "pl",
              "text": "Ręcznik kąpielowy jest jeszcze mokry."
            },
            {
              "language": "ro",
              "text": "Prosopul de baie este încă ud."
            },
            {
              "language": "ru",
              "text": "Полотенце еще мокрое."
            },
            {
              "language": "sq",
              "text": "Peshqiri i banjës është ende i lagur."
            },
            {
              "language": "tr",
              "text": "Banyo havlusu hâlâ ıslak."
            }
          ]
        }
      ]
    },
