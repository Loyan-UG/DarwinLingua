      ],
      "examples": [
        {
          "baseText": "Der Bäcker backt jeden Morgen frisches Brot.",
          "translations": [
            {
              "language": "ar",
              "text": "يخبز الخبّاز خبزاً طازجاً كل صباح."
            },
            {
              "language": "ckb",
              "text": "نانەواکە هەموو بەیانی نانی تازە دەکات."
            },
            {
              "language": "en",
              "text": "The baker bakes fresh bread every morning."
            },
            {
              "language": "fa",
              "text": "نانوا هر صبح نان تازه می‌پزد."
            },
            {
              "language": "kmr",
              "text": "Nanpêj her sibeh nanê teze dipêje."
            },
            {
              "language": "pl",
              "text": "Piekarz piecze świeży chleb każdego ranka."
            },
            {
              "language": "ro",
              "text": "Brutarul coace pâine proaspătă în fiecare dimineață."
            },
            {
              "language": "ru",
              "text": "Пекарь каждое утро печет свежий хлеб."
            },
            {
              "language": "sq",
              "text": "Bukëpjekësi pjek bukë të freskët çdo mëngjes."
            },
            {
              "language": "tr",
              "text": "Fırıncı her sabah taze ekmek pişirir."
            }
          ]
        },
        {
          "baseText": "Ich kaufe die Brötchen beim Bäcker um die Ecke.",
          "translations": [
            {
              "language": "ar",
              "text": "أشتري الخبز الصغير من الخبّاز عند الزاوية."
            },
            {
              "language": "ckb",
              "text": "بولکەکان لە نانەوای نزیک گوچەکە دەکڕم."
            },
            {
              "language": "en",
              "text": "I buy the rolls at the baker around the corner."
            },
            {
              "language": "fa",
              "text": "نان‌های کوچک را از نانوایی سر کوچه می‌خرم."
            },
            {
              "language": "kmr",
              "text": "Ez nanikên xwe ji nanpêjê li quncikê dikirim."
            },
            {
              "language": "pl",
              "text": "Kupuję bułki u piekarza za rogiem."
            },
            {
              "language": "ro",
              "text": "Cumpăr chiflele de la brutarul de după colț."
            },
            {
              "language": "ru",
              "text": "Я покупаю булочки у пекаря за углом."
            },
            {
              "language": "sq",
              "text": "I blej simitet te bukëpjekësi te cepi."
            },
            {
              "language": "tr",
              "text": "Köşedeki fırıncıdan ekmekçik alıyorum."
            }
          ]
        }
      ]
