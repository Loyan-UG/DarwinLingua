            {
              "language": "ro",
              "text": "Articolul preferat este propus în ERP când sunt posibile mai multe piese de schimb."
            },
            {
              "language": "ru",
              "text": "Предпочтительный товар предлагается в ERP, когда возможно несколько запасных частей."
            },
            {
              "language": "sq",
              "text": "Artikulli i preferuar sugjerohet në ERP kur ka disa pjesë rezervë të mundshme."
            },
            {
              "language": "tr",
              "text": "Birden fazla yedek parça mümkün olduğunda tercih edilen ürün ERP’de önerilir."
            }
          ]
        },
        {
          "baseText": "Der Einkauf hat diesen Lieferantenartikel als Vorzugsartikel markiert.",
          "translations": [
            {
              "language": "ar",
              "text": "قام قسم المشتريات بوسم صنف المورد هذا كصنف مفضل."
            },
            {
              "language": "ckb",
              "text": "بەشی کڕین ئەم ماددەی دابینکەرەی وەک ماددەی پەسەندکراو نیشان کردووە."
            },
            {
              "language": "en",
              "text": "Purchasing marked this supplier item as the preferred item."
            },
            {
              "language": "fa",
              "text": "واحد خرید این کالای تأمین‌کننده را به عنوان کالای ترجیحی علامت زده است."
            },
            {
              "language": "kmr",
              "text": "Beşa kirînê ev babetê dabînker wekî babetê tercîhkirî nîşan kiriye."
            },
            {
              "language": "pl",
              "text": "Dział zakupów oznaczył ten artykuł dostawcy jako preferowany."
            },
            {
              "language": "ro",
              "text": "Achizițiile au marcat acest articol furnizor ca articol preferat."
            },
            {
              "language": "ru",
              "text": "Отдел закупок отметил этот товар поставщика как предпочтительный."
            },
            {
              "language": "sq",
              "text": "Blerja e ka shënuar këtë artikull furnitori si të preferuar."
            },
            {
              "language": "tr",
              "text": "Satın alma bu tedarikçi ürününü tercih edilen ürün olarak işaretledi."
