      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; predefined default value in a form or system field"
      ],
      "collocations": [
        {
          "text": "eine Vorbelegung ändern",
          "meaning": "to change a default value"
        },
        {
          "text": "automatische Vorbelegung",
          "meaning": "automatic prefill"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vorbelegen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قيمة افتراضية مسبقة"
        },
        {
          "language": "ckb",
          "text": "پێشوەختە پڕکردنەوە"
        },
        {
          "language": "en",
          "text": "default value; prefill"
        },
        {
          "language": "fa",
          "text": "مقدار پیش‌فرض؛ پیش‌پرکردن"
        },
        {
          "language": "kmr",
          "text": "nirxa pêşdanasînê"
        },
        {
          "language": "pl",
          "text": "wartość domyślna"
        },
        {
          "language": "ro",
          "text": "valoare implicită"
        },
        {
          "language": "ru",
          "text": "значение по умолчанию"
        },
        {
          "language": "sq",
          "text": "vlerë e paracaktuar"
        },
        {
          "language": "tr",
          "text": "varsayılan değer"
        }
      ],
      "examples": [
        {
          "baseText": "Die Vorbelegung im ERP setzt automatisch den richtigen Lagerort ein.",
          "translations": [
            {
              "language": "ar",
              "text": "تضع القيمة الافتراضية في ERP موقع التخزين الصحيح تلقائيًا."
            },
            {
              "language": "ckb",
              "text": "پێشوەختە پڕکردنەوە لە ERP دا خۆکارانە شوێنی کۆگای دروست دادەنێت."
            },
            {
              "language": "en",
              "text": "The default value in the ERP automatically inserts the correct storage location."
            },
            {
              "language": "fa",
              "text": "مقدار پیش‌فرض در ERP به‌صورت خودکار محل انبار درست را وارد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Nirxa pêşdanasînê di ERP de xweber cihê rast ê embarê têxe."
            },
            {
              "language": "pl",
              "text": "Wartość domyślna w ERP automatycznie wstawia właściwą lokalizację magazynową."
            },
            {
              "language": "ro",
              "text": "Valoarea implicită din ERP introduce automat locația corectă de depozitare."
            },
            {
              "language": "ru",
              "text": "Значение по умолчанию в ERP автоматически подставляет правильное место хранения."
            },
            {
              "language": "sq",
              "text": "Vlera e paracaktuar në ERP vendos automatikisht lokacionin e saktë të magazinimit."
            },
            {
              "language": "tr",
              "text": "ERP’deki varsayılan değer doğru depo yerini otomatik olarak girer."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie die Vorbelegung, bevor neue Benutzer mit dem Formular arbeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى فحص القيمة الافتراضية قبل أن يعمل المستخدمون الجدد بالنموذج."
            },
            {
              "language": "ckb",
              "text": "تکایە پێشوەختە پڕکردنەوە بپشکنن پێش ئەوەی بەکارهێنەرانی نوێ بە فۆرمەکە کار بکەن."
            },
            {
              "language": "en",
              "text": "Please check the default value before new users work with the form."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از اینکه کاربران جدید با فرم کار کنند، مقدار پیش‌فرض را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe nirxa pêşdanasînê kontrol bikin berî ku bikarhênerên nû bi formê bixebitin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić wartość domyślną, zanim nowi użytkownicy zaczną pracować z formularzem."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați valoarea implicită înainte ca utilizatorii noi să lucreze cu formularul."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте значение по умолчанию, прежде чем новые пользователи начнут работать с формой."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni vlerën e paracaktuar para se përdoruesit e rinj të punojnë me formularin."
            },
            {
              "language": "tr",
              "text": "Yeni kullanıcılar formla çalışmadan önce lütfen varsayılan değeri kontrol edin."
            }
          ]
        }
      ]
    },
    {
      "word": "Vorverkaufsphase",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Vorverkaufsphasen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Vor-ver-kaufs-pha-se",
      "topics": [
        "sales-and-customers",
        "erp-and-business-systems",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; early sales stage before regular sale or order release"
      ],
      "collocations": [
        {
          "text": "eine Vorverkaufsphase starten",
          "meaning": "to start a presales phase"
        },
        {
          "text": "in der Vorverkaufsphase erfassen",
          "meaning": "to record during the presales phase"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Vorverkauf",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Phase",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مرحلة ما قبل البيع"
        },
        {
          "language": "ckb",
          "text": "قۆناغی پێشفرۆشتن"
        },
        {
          "language": "en",
          "text": "presales phase"
        },
        {
          "language": "fa",
          "text": "مرحله پیش‌فروش"
        },
        {
          "language": "kmr",
          "text": "qonaxa pêşfirotanê"
        },
        {
          "language": "pl",
          "text": "faza przedsprzedaży"
        },
        {
          "language": "ro",
          "text": "fază de prevânzare"
        },
        {
          "language": "ru",
          "text": "этап предпродажи"
        },
        {
          "language": "sq",
          "text": "fazë para-shitjeje"
        },
        {
          "language": "tr",
          "text": "ön satış aşaması"
        }
      ],
      "examples": [
        {
          "baseText": "In der Vorverkaufsphase werden Interessenten im ERP noch nicht als feste Kundenaufträge geführt.",
          "translations": [
            {
              "language": "ar",
              "text": "في مرحلة ما قبل البيع لا تُدار الجهات المهتمة في ERP كطلبات عملاء مؤكدة بعد."
            },
            {
              "language": "ckb",
              "text": "لە قۆناغی پێشفرۆشتندا، ئارەزوومەندان لە ERP دا هێشتا وەک داواکاریی کڕیاری دڵنیا تۆمار ناکرێن."
            },
            {
              "language": "en",
              "text": "In the presales phase, prospects are not yet managed in the ERP as firm customer orders."
            },
            {
              "language": "fa",
              "text": "در مرحله پیش‌فروش، مشتریان بالقوه هنوز در ERP به عنوان سفارش قطعی مشتری ثبت نمی‌شوند."
            },
            {
              "language": "kmr",
              "text": "Di qonaxa pêşfirotanê de, kesên eleqedar hîn di ERP de wekî fermanên sabît ên mişterî nayên rêvebirin."
            },
            {
              "language": "pl",
              "text": "W fazie przedsprzedaży zainteresowani nie są jeszcze prowadzeni w ERP jako wiążące zamówienia klientów."
            },
            {
              "language": "ro",
              "text": "În faza de prevânzare, potențialii clienți nu sunt încă gestionați în ERP ca ordine ferme."
            },
            {
              "language": "ru",
              "text": "На этапе предпродажи заинтересованные лица еще не ведутся в ERP как твердые заказы клиентов."
            },
            {
              "language": "sq",
              "text": "Në fazën para-shitjes, interesentët ende nuk menaxhohen në ERP si porosi të sigurta klientësh."
            },
            {
              "language": "tr",
              "text": "Ön satış aşamasında ilgililer ERP’de henüz kesin müşteri siparişleri olarak yönetilmez."
            }
          ]
        },
        {
          "baseText": "Das Vertriebsteam sammelt in der Vorverkaufsphase alle technischen Fragen des Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجمع فريق المبيعات في مرحلة ما قبل البيع جميع الأسئلة الفنية للعميل."
            },
            {
              "language": "ckb",
              "text": "تیمی فرۆشتن لە قۆناغی پێشفرۆشتندا هەموو پرسیارە تەکنیکییەکانی کڕیار کۆدەکاتەوە."
            },
            {
              "language": "en",
              "text": "During the presales phase, the sales team collects all technical questions from the customer."
            },
            {
              "language": "fa",
              "text": "تیم فروش در مرحله پیش‌فروش همه پرسش‌های فنی مشتری را جمع‌آوری می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di qonaxa pêşfirotanê de tîma firotanê hemû pirsên teknîkî yên mişterî kom dike."
            },
            {
              "language": "pl",
              "text": "W fazie przedsprzedaży zespół sprzedaży zbiera wszystkie techniczne pytania klienta."
            },
            {
              "language": "ro",
              "text": "În faza de prevânzare, echipa de vânzări adună toate întrebările tehnice ale clientului."
            },
            {
              "language": "ru",
              "text": "На этапе предпродажи отдел продаж собирает все технические вопросы клиента."
            },
            {
              "language": "sq",
              "text": "Gjatë fazës para-shitjes, ekipi i shitjeve mbledh të gjitha pyetjet teknike të klientit."
            },
            {
              "language": "tr",
              "text": "Ön satış aşamasında satış ekibi müşterinin tüm teknik sorularını toplar."
            }
          ]
        }
      ]
    },
