  "entries": [
    {
      "word": "anfahren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anfahren",
      "pronunciationIpa": null,
      "syllableBreak": "an-fahr-en",
      "topics": [
        "transport-and-travel",
        "work-and-jobs",
        "technology-and-it"
      ],
      "usageLabels": [
        "workplace",
        "technical"
      ],
      "contextLabels": [
        "software",
        "it"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "أن يقترب؛ يمر"
        },
        {
          "language": "ckb",
          "text": "نزیک بوون/گەشتن بەرەو"
        },
        {
          "language": "en",
          "text": "to approach; to come up to"
        },
        {
          "language": "fa",
          "text": "نزدیک شدن؛ رسیدن به"
        },
        {
          "language": "kmr",
          "text": "nêzîkbûn; berçav ketin"
        },
        {
          "language": "pl",
          "text": "zbiegać; podjeżdżać"
        },
        {
          "language": "ro",
          "text": "a se apropia"
        },
        {
          "language": "ru",
          "text": "приближаться; подъезжать"
        },
        {
          "language": "sq",
          "text": "i afrohet; afrohet"
        },
        {
          "language": "tr",
          "text": "yaklaşmak; yaklaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Gabelstaplerfahrer fuhr langsam an die Rampe an, damit die Einpacker sicher arbeiten konnten.",
          "translations": [
            {
              "language": "ar",
              "text": "رانِسِ الترامبَل ببطء باتجاه المنحدر حتى يتمكن العبّاؤون من العمل بأمان."
            },
            {
              "language": "ckb",
              "text": "شوفێری فۆڕکلیفت کەمەوکە بەرەو پەلەوەی بارکردن دەچوو تا کارمەندانی مەحتویەوە بتوانن بەبەهێز کار بکەن."
            },
            {
              "language": "en",
              "text": "The forklift operator drove slowly toward the loading ramp so the packers could work safely."
            },
            {
              "language": "fa",
              "text": "اپراتور لیفتراک به‌آرامی به طرف رمپ بارگیری نزدیک شد تا بسته‌بندها بتوانند ایمن کار کنند."
            },
            {
              "language": "kmr",
              "text": "Fûnkariya forklift-ê hêdî hêdî berê qada barkirinê kir ku karûbarên barkirinê bi ewlekarî kar bikin."
            },
            {
              "language": "pl",
              "text": "Operator wózka widłowego podjechał powoli do rampy załadunkowej, aby pakujący mogli bezpiecznie pracować."
            },
            {
              "language": "ro",
              "text": "Operatorul stivuitorului s-a apropiat încet de rampa de încărcare, astfel încât ambalatorii să poată lucra în siguranță."
            },
            {
              "language": "ru",
              "text": "Оператор погрузчика медленно подъехал к загрузочной рампе, чтобы грузчики могли работать безопасно."
            },
            {
              "language": "sq",
              "text": "Operatori i ngarkuesit u afrua ngadalë drejt rampës së ngarkimit në mënyrë që paketuesit të punonin me siguri."
            },
            {
              "language": "tr",
              "text": "Forklift operatörü, paketleme ekibi güvenle çalışabilsin diye yükleme rampaına yavaşça yaklaştı."
            }
          ]
        },
        {
          "baseText": "Der Bus fuhr an den Haupteingang an und die Lieferzeit blieb ohne Verzögerung im Plan.",
          "translations": [
            {
              "language": "ar",
              "text": "اقترب الحافلة من المدخل الرئيسي وبقيت مدة التسليم ضمن الخطة دون تأخير."
            },
            {
              "language": "ckb",
              "text": "بەسەکە بەرەو دەروازەی سەرەکیی پێویستەدا هەتا گەشت و کاتی گەیاندن بە پلانەوەیەوە نەبەسترا."
            },
            {
              "language": "en",
              "text": "The bus pulled up to the main entrance, and the delivery timing stayed on schedule without delay."
            },
            {
              "language": "fa",
              "text": "اتوبوس به ورودی اصلی نزدیک شد و زمان تحویل طبق برنامه بدون تأخیر ماند."
            },
            {
              "language": "kmr",
              "text": "Otobûs bi hêdî li derveyî têgihandina sereke girt û dema barkirinê bêderengî di plânê de maye."
            },
            {
              "language": "pl",
              "text": "Autobus podjechał pod główne wejście i dostawa pozostała bez opóźnienia zgodnie z planem."
            },
            {
              "language": "ro",
              "text": "Autobuzul a intrat încet pe la intrarea principală, iar intervalul de livrare a rămas fără întârzieri conform planului."
            },
            {
              "language": "ru",
              "text": "Автобус подъехал к главному входу, и время доставки осталось в графике без задержек."
            },
            {
              "language": "sq",
              "text": "Autobusi u afrua te hyrja kryesore, dhe koha e dorëzimit mbeti sipas planit pa vonesa."
            },
            {
              "language": "tr",
              "text": "Otobüs ana girişe yanaştı ve teslimat süresi plana sadık kalarak gecikmesiz devam etti."
            }
          ]
        }
      ]
    },
    {
      "word": "anfallen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anfallen",
      "pronunciationIpa": null,
      "syllableBreak": "an-fal-len",
      "topics": [
        "finance-and-accounting",
        "work-and-jobs",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "erp"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يثبت/يترتب"
        },
        {
          "language": "ckb",
          "text": "سەرچاوە دێت/پێش ئەوی دەکەیت"
        },
        {
          "language": "en",
          "text": "to fall due; to accrue"
        },
        {
          "language": "fa",
          "text": "تحمیل می‌شود/تحمیل بودن"
        },
        {
          "language": "kmr",
          "text": "dibe, tê da ku"
        },
        {
          "language": "pl",
          "text": "powstać; należeć"
        },
        {
          "language": "ro",
          "text": "a se aplica; de a recurge"
        },
        {
          "language": "ru",
          "text": "падать в расход/взысканию"
        },
        {
          "language": "sq",
          "text": "rri, ngarkohet"
        },
        {
          "language": "tr",
          "text": "düşmek; doğmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn der Kunde die Frist verpasst, fallen zusätzliche Bearbeitungsgebühren an.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا فات العميل الموعد النهائي، تُفرض عليه رسوم معالجة إضافية."
            },
            {
              "language": "ckb",
              "text": "ئەگەر کڕیار کۆتا ڕۆژ را نەدات، فەیەدانی فەرمودنی زیادە دەسەڕچ دەبێت."
            },
            {
              "language": "en",
              "text": "If the customer misses the deadline, additional handling fees will be charged."
            },
            {
              "language": "fa",
              "text": "اگر مشتری مهلت را از دست بدهد، هزینه‌های پردازش اضافه به او تعلق می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Ger xerîdar serî dema domandînê berdê, xercên barkirinê yên zêde dixistin."
            },
            {
              "language": "pl",
              "text": "Jeśli klient przegapi termin, naliczone zostaną dodatkowe opłaty administracyjne."
            },
            {
              "language": "ro",
              "text": "Dacă clientul pierde termenul, se vor aplica taxe suplimentare de procesare."
            },
            {
              "language": "ru",
              "text": "Если клиент пропустит срок, будут взиматься дополнительные сборы за обработку."
            },
            {
              "language": "sq",
              "text": "Nëse klienti e humb afatin, ngarkohen tarifa shtesë përpunimi."
            },
            {
              "language": "tr",
              "text": "Müşteri son tarihi kaçırırsa ek işlem ücretleri uygulanır."
            }
          ]
        },
        {
          "baseText": "Für die Wartung der Maschinen fallen im nächsten Quartal jährliche Pauschalen an.",
          "translations": [
            {
              "language": "ar",
              "text": "في الربع القادم ستتراكم رسوم صيانة الأجهزة بشكل سنوي."
            },
            {
              "language": "ckb",
              "text": "بۆ چاککردنی ئۆتۆماتەکان، لە بەشەی داهاتوودا پارەکانی ساڵانە دێنە سەر."
            },
            {
              "language": "en",
              "text": "Annual maintenance fees will be charged for the machinery next quarter."
            },
            {
              "language": "fa",
              "text": "در فصل بعدی هزینه‌های نگهداری سالانه برای ماشین‌آلات محاسبه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ji bo parastina amûrên karbarî, di caturmisalê paşîn de pereke salane tê pêşxistin."
            },
            {
              "language": "pl",
              "text": "W następnym kwartale za konserwację maszyn naliczone zostaną opłaty roczne."
            },
            {
              "language": "ro",
              "text": "În trimestrul următor se vor aplica taxe anuale de întreținere pentru echipamente."
            },
            {
              "language": "ru",
              "text": "В следующем квартале по обслуживанию машин будут начисляться ежегодные платежи."
            },
            {
              "language": "sq",
              "text": "Në tremujorin e ardhshëm, për mirëmbajtjen e makinave do të ngarkohen tarifa vjetore."
            },
            {
              "language": "tr",
              "text": "Makinelerin bakımı için bir sonraki çeyrekte yıllık bedeller doğacak."
            }
          ]
        }
      ]
    },
