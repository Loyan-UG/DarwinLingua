      "meanings": [
        {
          "language": "ar",
          "text": "معلومة إضافية عن العميل"
        },
        {
          "language": "ckb",
          "text": "زانیاری زیادەی کڕیار"
        },
        {
          "language": "en",
          "text": "additional customer information"
        },
        {
          "language": "fa",
          "text": "اطلاعات تکمیلی مشتری"
        },
        {
          "language": "kmr",
          "text": "agahdariya zêde ya xerîdar"
        },
        {
          "language": "pl",
          "text": "dodatkowa informacja o kliencie"
        },
        {
          "language": "ro",
          "text": "informație suplimentară despre client"
        },
        {
          "language": "ru",
          "text": "дополнительная информация о клиенте"
        },
        {
          "language": "sq",
          "text": "informacion shtesë për klientin"
        },
        {
          "language": "tr",
          "text": "müşteri ek bilgisi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kundenzusatzinfo erscheint im ERP automatisch im Auftrag, wenn der Kunde besondere Lieferfenster vereinbart hat.",
          "translations": [
            {
              "language": "ar",
              "text": "تظهر المعلومة الإضافية عن العميل في ERP تلقائيًا في الطلب إذا اتفق العميل على نوافذ تسليم خاصة."
            },
            {
              "language": "ckb",
              "text": "زانیاری زیادەی کڕیار لە ERPدا بە خۆکار لە داواکارییەکە دەردەکەوێت ئەگەر کڕیار کاتی تایبەتی گەیاندنی هەبێت."
            },
            {
              "language": "en",
              "text": "The additional customer information appears automatically in the ERP order when the customer has agreed special delivery windows."
            },
            {
              "language": "fa",
              "text": "اطلاعات تکمیلی مشتری در ERP وقتی مشتری بازه‌های تحویل خاص دارد، خودکار در سفارش ظاهر می‌شود."
            },
            {
              "language": "kmr",
              "text": "Agahdariya zêde ya xerîdar di ERP de bixweber di fermanê de xuya dibe dema xerîdar demên taybet ên radestkirinê lihevkiribe."
            },
            {
              "language": "pl",
              "text": "Dodatkowa informacja o kliencie pojawia się automatycznie w zleceniu ERP, gdy klient uzgodnił specjalne okna dostawy."
            },
            {
              "language": "ro",
              "text": "Informația suplimentară despre client apare automat în comanda ERP când clientul are ferestre speciale de livrare."
            },
            {
              "language": "ru",
              "text": "Дополнительная информация о клиенте автоматически появляется в заказе ERP, если согласованы особые окна доставки."
            },
            {
              "language": "sq",
              "text": "Informacioni shtesë për klientin shfaqet automatikisht në porosinë ERP kur klienti ka dritare të veçanta dorëzimi."
            },
            {
              "language": "tr",
              "text": "Müşteri ek bilgisi, özel teslim pencereleri varsa ERP siparişinde otomatik görünür."
            }
          ]
        },
        {
          "baseText": "Der Innendienst ergänzte die Kundenzusatzinfo, damit neue Kollegen die Eskalationshistorie sofort verstehen.",
          "translations": [
            {
              "language": "ar",
              "text": "أضاف فريق الدعم الداخلي معلومة العميل الإضافية كي يفهم الزملاء الجدد تاريخ التصعيد فورًا."
            },
            {
              "language": "ckb",
              "text": "تیمی ناوخۆ زانیاری زیادەی کڕیار زیاد کرد تاکو هاوکارانی نوێ مێژووی هەڵکشانی کێشە دەستبەجێ تێبگەن."
            },
            {
              "language": "en",
              "text": "Inside sales added the additional customer information so new colleagues immediately understand the escalation history."
            },
            {
              "language": "fa",
              "text": "واحد داخلی فروش اطلاعات تکمیلی مشتری را اضافه کرد تا همکاران جدید فوراً سابقه پیگیری را بفهمند."
            },
            {
              "language": "kmr",
              "text": "Firotana navxweyî agahdariya zêde zêde kir da hevkarên nû dîroka bilindkirinê yekser fêm bikin."
            },
            {
              "language": "pl",
              "text": "Dział obsługi wewnętrznej uzupełnił informację, aby nowi pracownicy od razu rozumieli historię eskalacji."
            },
            {
              "language": "ro",
              "text": "Echipa internă a completat informația pentru ca noii colegi să înțeleagă imediat istoricul escaladării."
            },
            {
              "language": "ru",
              "text": "Внутренний отдел продаж добавил информацию, чтобы новые коллеги сразу понимали историю эскалации."
            },
            {
              "language": "sq",
              "text": "Shitjet e brendshme shtuan informacionin që kolegët e rinj të kuptojnë menjëherë historikun e eskalimit."
            },
            {
              "language": "tr",
              "text": "İç satış ekibi, yeni çalışanlar eskalasyon geçmişini hemen anlasın diye müşteri ek bilgisini tamamladı."
            }
          ]
        }
      ]
    }
  ],
