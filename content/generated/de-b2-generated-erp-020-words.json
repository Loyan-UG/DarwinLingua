      "meanings": [
        {
          "language": "ar",
          "text": "حساب الوديعة"
        },
        {
          "language": "ckb",
          "text": "هەژماری بارمتە"
        },
        {
          "language": "en",
          "text": "deposit account"
        },
        {
          "language": "fa",
          "text": "حساب ودیعه"
        },
        {
          "language": "kmr",
          "text": "hesabê depozîtoyê"
        },
        {
          "language": "pl",
          "text": "konto kaucji"
        },
        {
