      ],
      "usageLabels": [
        "business",
        "workplace",
        "administrative",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; deposit charged for returnable packaging or containers"
      ],
      "collocations": [
        {
          "text": "Pfand berechnen",
          "meaning": "to calculate a deposit"
        },
        {
          "text": "Pfand zurückerstatten",
          "meaning": "to refund a deposit"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "pfandpflichtig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وديعة؛ رهن مسترجع"
        },
        {
          "language": "ckb",
          "text": "بارمتە؛ پارەی گەڕاوە"
        },
        {
          "language": "en",
          "text": "deposit; returnable deposit"
        },
        {
          "language": "fa",
          "text": "ودیعه؛ مبلغ قابل بازگشت"
        },
        {
          "language": "kmr",
          "text": "depozîto; pereyê vegerandinê"
        },
        {
          "language": "pl",
          "text": "kaucja; zastaw"
        },
        {
          "language": "ro",
          "text": "garanție; depozit returnabil"
        },
        {
          "language": "ru",
          "text": "залог; возвратный депозит"
        },
        {
          "language": "sq",
          "text": "depozitë; garanci e kthyeshme"
        },
        {
          "language": "tr",
          "text": "depozito; iade bedeli"
        }
      ],
      "examples": [
        {
          "baseText": "Das Pfand wird im ERP automatisch auf der Rechnung ausgewiesen.",
          "translations": [
            {
              "language": "ar",
              "text": "تظهر الوديعة في ERP تلقائيًا على الفاتورة."
            },
            {
              "language": "ckb",
              "text": "بارمتەکە لە ERP دا خۆکارانە لەسەر فاکتورەکە نیشان دەدرێت."
            },
            {
              "language": "en",
              "text": "The deposit is shown automatically on the invoice in the ERP."
            },
            {
              "language": "fa",
              "text": "ودیعه در ERP به‌صورت خودکار روی فاکتور نمایش داده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Depozîto di ERP de xweber li ser fatûreyê tê nîşandan."
            },
            {
              "language": "pl",
              "text": "Kaucja jest automatycznie wykazywana na fakturze w ERP."
            },
            {
              "language": "ro",
              "text": "Garanția este afișată automat pe factură în ERP."
            },
            {
              "language": "ru",
              "text": "Залог автоматически отображается в счете в ERP."
            },
            {
              "language": "sq",
              "text": "Depozita shfaqet automatikisht në faturë në ERP."
            },
            {
              "language": "tr",
              "text": "Depozito ERP’de faturada otomatik olarak gösterilir."
            }
          ]
        },
        {
          "baseText": "Der Kunde bekommt das Pfand zurück, wenn er die leeren Kisten abgibt.",
          "translations": [
            {
              "language": "ar",
              "text": "يسترد العميل الوديعة عندما يعيد الصناديق الفارغة."
            },
            {
              "language": "ckb",
              "text": "کڕیار بارمتەکە وەردەگرێتەوە کاتێک سندوقە بەتاڵەکان دەداتەوە."
            },
            {
              "language": "en",
              "text": "The customer gets the deposit back when he returns the empty crates."
            },
            {
              "language": "fa",
              "text": "مشتری وقتی جعبه‌های خالی را تحویل دهد، ودیعه را پس می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Mişterî dema qutiyên vala vedigerîne depozîtoyê vedistîne."
            },
            {
              "language": "pl",
              "text": "Klient otrzymuje kaucję z powrotem, gdy odda puste skrzynki."
            },
            {
              "language": "ro",
              "text": "Clientul primește garanția înapoi când predă lăzile goale."
            },
            {
              "language": "ru",
              "text": "Клиент получает залог обратно, когда возвращает пустые ящики."
            },
            {
              "language": "sq",
              "text": "Klienti e merr depozitën mbrapsht kur dorëzon arkat bosh."
            },
            {
              "language": "tr",
              "text": "Müşteri boş kasaları teslim ettiğinde depozitoyu geri alır."
            }
          ]
        }
      ]
    },
    {
      "word": "Pfandartikel",
