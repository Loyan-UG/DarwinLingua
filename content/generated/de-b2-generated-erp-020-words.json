        {
          "lemma": "der Artikel",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "صنف عليه وديعة"
        },
        {
          "language": "ckb",
          "text": "ماددەی بارمتەدار"
        },
        {
          "language": "en",
          "text": "deposit item"
        },
        {
          "language": "fa",
          "text": "کالای دارای ودیعه"
        },
        {
          "language": "kmr",
          "text": "babetê bi depozîto"
        },
        {
          "language": "pl",
          "text": "artykuł kaucyjny"
        },
        {
          "language": "ro",
          "text": "articol cu garanție"
        },
        {
          "language": "ru",
          "text": "товар с залогом"
        },
        {
          "language": "sq",
          "text": "artikull me depozitë"
        },
        {
          "language": "tr",
          "text": "depozitolu ürün"
        }
      ],
      "examples": [
        {
          "baseText": "Der Pfandartikel ist im ERP mit einem separaten Pfandkonto verknüpft.",
          "translations": [
            {
              "language": "ar",
              "text": "صنف الوديعة مرتبط في ERP بحساب وديعة منفصل."
            },
            {
              "language": "ckb",
              "text": "ماددەی بارمتەدار لە ERP دا بە هەژمارێکی جیاوازی بارمتە بەستراوەتەوە."
            },
            {
              "language": "en",
              "text": "The deposit item is linked in the ERP to a separate deposit account."
            },
            {
              "language": "fa",
              "text": "کالای دارای ودیعه در ERP به یک حساب ودیعه جداگانه متصل است."
            },
            {
              "language": "kmr",
              "text": "Babetê bi depozîto di ERP de bi hesabekî depozîtoyê yê cuda ve girêdayî ye."
            },
            {
              "language": "pl",
              "text": "Artykuł kaucyjny jest w ERP powiązany z osobnym kontem kaucji."
            },
            {
              "language": "ro",
              "text": "Articolul cu garanție este legat în ERP de un cont separat de garanție."
            },
            {
              "language": "ru",
              "text": "Товар с залогом связан в ERP с отдельным залоговым счетом."
            },
            {
              "language": "sq",
              "text": "Artikulli me depozitë lidhet në ERP me një llogari të veçantë depozite."
            },
            {
              "language": "tr",
              "text": "Depozitolu ürün ERP’de ayrı bir depozito hesabıyla ilişkilidir."
            }
          ]
        },
        {
          "baseText": "An der Kasse muss der Pfandartikel zusammen mit der Flasche gescannt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "عند الصندوق يجب مسح صنف الوديعة مع الزجاجة."
            },
            {
              "language": "ckb",
              "text": "لە کاشێر پێویستە ماددەی بارمتەدار لەگەڵ بوتڵەکە سکان بکرێت."
            },
            {
              "language": "en",
              "text": "At the checkout, the deposit item must be scanned together with the bottle."
            },
            {
              "language": "fa",
              "text": "در صندوق، کالای دارای ودیعه باید همراه بطری اسکن شود."
            },
            {
              "language": "kmr",
              "text": "Li kasayê divê babetê bi depozîto bi şûşeyê re were skenkirin."
            },
            {
              "language": "pl",
              "text": "Przy kasie artykuł kaucyjny musi zostać zeskanowany razem z butelką."
            },
            {
              "language": "ro",
              "text": "La casă, articolul cu garanție trebuie scanat împreună cu sticla."
            },
            {
              "language": "ru",
              "text": "На кассе товар с залогом нужно сканировать вместе с бутылкой."
            },
            {
              "language": "sq",
              "text": "Në arkë artikulli me depozitë duhet të skanohet bashkë me shishen."
            },
            {
              "language": "tr",
              "text": "Kasada depozitolu ürün şişeyle birlikte taranmalıdır."
            }
          ]
        }
      ]
    },
