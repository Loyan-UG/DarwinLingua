              "language": "ckb",
              "text": "ڕۆژ باش، خانم."
            },
            {
              "language": "en",
              "text": "Good afternoon, madam."
            },
            {
              "language": "fa",
              "text": "روز بخیر، خانم."
            },
            {
              "language": "kmr",
              "text": "Roj baş, xanim."
            },
            {
              "language": "pl",
              "text": "Dzień dobry, proszę pani."
            },
            {
              "language": "ro",
              "text": "Bună ziua, doamnă."
            },
            {
