            {
              "language": "en",
              "text": "The lady is waiting here."
            },
            {
              "language": "fa",
              "text": "خانم اینجا منتظر است."
            },
            {
              "language": "kmr",
              "text": "Xanim li vir li bendê ye."
            },
            {
              "language": "pl",
              "text": "Ta pani czeka tutaj."
            },
            {
              "language": "ro",
              "text": "Doamna așteaptă aici."
