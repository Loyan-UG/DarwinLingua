      "examples": [
        {
          "baseText": "Die Dame wartet hier.",
          "translations": [
            {
              "language": "ar",
              "text": "السيدة تنتظر هنا."
            },
            {
              "language": "ckb",
              "text": "خانمەکە لێرە چاوەڕێ دەکات."
