    {
      "word": "der Chef",
      "language": "de",
      "cefrLevel": "A1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Chefs",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Chef",
      "topics": [
        "work-and-jobs",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; feminine form: die Chefin"
      ],
      "collocations": [
        {
          "text": "mein Chef",
          "meaning": "my boss"
        },
        {
          "text": "den Chef fragen",
          "meaning": "to ask the boss"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Chefin",
          "relationLabel": "noun",
          "note": "feminine form"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مدير؛ رئيس"
        },
        {
          "language": "ckb",
          "text": "سەرۆک؛ بەڕێوەبەر"
        },
        {
          "language": "en",
          "text": "boss; manager"
        },
        {
          "language": "fa",
          "text": "رئیس؛ مدیر"
        },
        {
          "language": "kmr",
          "text": "serok; rêveber"
        },
        {
          "language": "pl",
          "text": "szef"
        },
        {
          "language": "ro",
          "text": "șef"
        },
        {
          "language": "ru",
          "text": "начальник; шеф"
        },
        {
          "language": "sq",
          "text": "shef"
        },
        {
          "language": "tr",
          "text": "şef; patron"
        }
      ],
      "examples": [
        {
          "baseText": "Mein Chef ist heute nicht da.",
          "translations": [
            {
              "language": "ar",
              "text": "مديري ليس هنا اليوم."
            },
            {
              "language": "ckb",
              "text": "سەرۆکەکەم ئەمڕۆ لێرە نییە."
            },
            {
              "language": "en",
              "text": "My boss is not here today."
            },
            {
              "language": "fa",
              "text": "رئیس من امروز اینجا نیست."
            },
            {
              "language": "kmr",
              "text": "Serokê min îro li vir nîne."
            },
            {
              "language": "pl",
              "text": "Mojego szefa dzisiaj nie ma."
            },
            {
              "language": "ro",
              "text": "Șeful meu nu este aici astăzi."
            },
            {
              "language": "ru",
              "text": "Моего начальника сегодня нет."
            },
            {
              "language": "sq",
              "text": "Shefi im nuk është këtu sot."
            },
            {
              "language": "tr",
              "text": "Şefim bugün burada değil."
            }
          ]
        },
        {
          "baseText": "Ich frage den Chef.",
          "translations": [
            {
              "language": "ar",
              "text": "سأسأل المدير."
            },
            {
              "language": "ckb",
              "text": "من پرسیار لە سەرۆکەکە دەکەم."
            },
            {
              "language": "en",
              "text": "I will ask the boss."
            },
            {
              "language": "fa",
              "text": "من از رئیس می‌پرسم."
            },
            {
              "language": "kmr",
              "text": "Ez ji serokî dipirsim."
            },
            {
              "language": "pl",
              "text": "Zapytam szefa."
            },
            {
              "language": "ro",
              "text": "Îl întreb pe șef."
            },
            {
              "language": "ru",
              "text": "Я спрошу начальника."
            },
            {
              "language": "sq",
              "text": "Do ta pyes shefin."
            },
            {
              "language": "tr",
              "text": "Şefe soruyorum."
            }
          ]
        }
      ]
    },
