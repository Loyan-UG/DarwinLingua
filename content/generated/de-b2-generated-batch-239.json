  "entries": [
    {
      "word": "überlassen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "überlassen",
      "pronunciationIpa": null,
      "syllableBreak": "ü-ber-las-sen",
      "topics": [
        "business-communication",
        "management-and-leadership",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "business",
        "spoken"
      ],
      "contextLabels": [
        "management",
        "contracts",
        "customer-service"
      ],
      "grammarNotes": [
        "inseparable irregular verb: überlässt, überließ, hat überlassen; often with dative person and accusative object"
      ],
      "collocations": [
        {
          "text": "jemandem die Entscheidung überlassen",
          "meaning": "to leave the decision to someone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "lassen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Überlassung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يترك لشخص؛ يسلّم أو يتيح"
        },
        {
          "language": "ckb",
          "text": "بۆ کەسێک بەجێ دەهێڵێت؛ ڕادەست دەکات"
        },
        {
          "language": "en",
          "text": "to leave to someone; to hand over; to provide for use"
        },
        {
          "language": "fa",
          "text": "به کسی واگذار کردن؛ در اختیار گذاشتن"
        },
        {
          "language": "kmr",
          "text": "ji kesekî re hiştin; radest kirin"
        },
        {
          "language": "pl",
          "text": "pozostawić komuś; przekazać do użycia"
        },
        {
          "language": "ro",
          "text": "a lăsa cuiva; a pune la dispoziție"
        },
        {
          "language": "ru",
          "text": "предоставить; оставить на усмотрение"
        },
        {
          "language": "sq",
          "text": "t’ia lësh dikujt; të vësh në dispozicion"
        },
        {
          "language": "tr",
          "text": "birine bırakmak; kullanımına vermek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir überlassen dem Kunden die Entscheidung, ob er den Vertrag verlängern möchte.",
          "translations": [
            {
              "language": "ar",
              "text": "نترك للعميل قرار ما إذا كان يريد تمديد العقد."
            },
            {
              "language": "ckb",
              "text": "بڕیاری ئەوەی کە گرێبەستەکە درێژ بکاتەوە یان نا، بۆ کڕیارەکە بەجێ دەهێڵین."
            },
            {
              "language": "en",
              "text": "We leave the decision to the customer whether they want to extend the contract."
            },
            {
              "language": "fa",
              "text": "تصمیم تمدید قرارداد را به مشتری واگذار می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em biryara dirêjkirina peymanê ji xerîdar re dihêlin."
            },
            {
              "language": "pl",
              "text": "Pozostawiamy klientowi decyzję, czy chce przedłużyć umowę."
            },
            {
              "language": "ro",
              "text": "Lăsăm clientului decizia dacă dorește să prelungească contractul."
            },
            {
              "language": "ru",
              "text": "Мы оставляем клиенту решение, хочет ли он продлить договор."
            },
            {
              "language": "sq",
              "text": "Ia lëmë klientit vendimin nëse dëshiron ta zgjasë kontratën."
            },
            {
              "language": "tr",
              "text": "Sözleşmeyi uzatıp uzatmama kararını müşteriye bırakıyoruz."
            }
          ]
        },
        {
          "baseText": "Für die Präsentation überlasse ich dir die Einleitung, weil du das Projekt am besten kennst.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة للعرض سأترك لك المقدمة لأنك تعرف المشروع أفضل من غيرك."
            },
            {
              "language": "ckb",
              "text": "بۆ پێشکەشکردنەکە، پێشەکییەکە بۆ تۆ بەجێ دەهێڵم چونکە تۆ پڕۆژەکە باشترین دەناسیت."
            },
            {
              "language": "en",
              "text": "For the presentation, I will leave the introduction to you because you know the project best."
            },
            {
              "language": "fa",
              "text": "برای ارائه، مقدمه را به تو می‌سپارم چون پروژه را بهتر از همه می‌شناسی."
            },
            {
              "language": "kmr",
              "text": "Ji bo pêşkêşiyê ez destpêkê ji te re dihêlim, ji ber ku tu projeyê herî baş nas dikî."
            },
            {
              "language": "pl",
              "text": "W prezentacji zostawię ci wstęp, bo najlepiej znasz projekt."
            },
            {
              "language": "ro",
              "text": "Pentru prezentare îți las ție introducerea, deoarece cunoști cel mai bine proiectul."
            },
            {
              "language": "ru",
              "text": "В презентации я оставлю вступление тебе, потому что ты лучше всех знаешь проект."
            },
            {
              "language": "sq",
              "text": "Për prezantimin, hyrjen po ta lë ty, sepse ti e njeh më mirë projektin."
            },
            {
              "language": "tr",
              "text": "Sunumda girişi sana bırakıyorum çünkü projeyi en iyi sen biliyorsun."
            }
          ]
        }
      ]
    },
    {
      "word": "überlaufen",
