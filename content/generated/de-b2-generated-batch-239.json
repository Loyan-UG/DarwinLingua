      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفيض؛ يمتلئ بشكل زائد"
        },
        {
          "language": "ckb",
          "text": "ڕژان؛ زۆر پڕبوون"
        },
        {
          "language": "en",
          "text": "to overflow; to be flooded or overcrowded"
        },
        {
          "language": "fa",
          "text": "سرریز شدن؛ بیش از حد پر شدن"
        },
        {
          "language": "kmr",
          "text": "serrijandin; pir zêde tijî bûn"
        },
        {
          "language": "pl",
          "text": "przepełnić się; być zalanym zgłoszeniami"
        },
        {
          "language": "ro",
          "text": "a se revărsa; a fi copleșit"
        },
        {
          "language": "ru",
          "text": "переполниться; быть заваленным"
        },
        {
          "language": "sq",
          "text": "të derdhet; të mbingarkohet"
        },
        {
          "language": "tr",
          "text": "taşmak; aşırı dolmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Störung ist der Support mit Anfragen überlaufen.",
          "translations": [
