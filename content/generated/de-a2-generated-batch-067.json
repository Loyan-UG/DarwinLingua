            {
              "language": "en",
              "text": "I buy a monthly pass for the bus."
            },
            {
              "language": "fa",
              "text": "برای اتوبوس کارت ماهانه می‌خرم."
            },
            {
              "language": "kmr",
              "text": "Ez karta mehane ji bo otobusê dikirim."
