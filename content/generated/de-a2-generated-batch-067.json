      ],
      "collocations": [
        {
          "text": "monatlich bezahlen",
          "meaning": "to pay monthly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Monat",
          "relationLabel": "noun",
          "note": "month"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شهري؛ شهرياً"
        },
        {
          "language": "ckb",
          "text": "مانگانە"
        },
        {
          "language": "en",
          "text": "monthly"
        },
        {
          "language": "fa",
          "text": "ماهانه"
        },
        {
          "language": "kmr",
          "text": "mehane"
        },
        {
          "language": "pl",
          "text": "miesięczny; co miesiąc"
        },
        {
          "language": "ro",
          "text": "lunar; lunarmente"
        },
        {
          "language": "ru",
          "text": "ежемесячный; ежемесячно"
        },
        {
          "language": "sq",
          "text": "mujor; çdo muaj"
        },
        {
          "language": "tr",
          "text": "aylık; ayda bir"
        }
      ],
      "examples": [
        {
          "baseText": "Die Miete zahlen wir monatlich.",
          "translations": [
            {
              "language": "ar",
              "text": "ندفع الإيجار شهرياً."
            },
            {
              "language": "ckb",
              "text": "کرێی خانوو مانگانە دەدەین."
            },
            {
              "language": "en",
              "text": "We pay the rent monthly."
            },
            {
              "language": "fa",
              "text": "اجاره را ماهانه پرداخت می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em kirêyê mehane didin."
            },
            {
              "language": "pl",
              "text": "Czynsz płacimy co miesiąc."
            },
            {
              "language": "ro",
              "text": "Plătim chiria lunar."
            },
            {
              "language": "ru",
              "text": "Мы платим аренду ежемесячно."
            },
            {
              "language": "sq",
              "text": "Qiranë e paguajmë çdo muaj."
            },
            {
              "language": "tr",
              "text": "Kirayı aylık ödüyoruz."
            }
          ]
        },
        {
          "baseText": "Der Kurs kostet monatlich 40 Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "الدورة تكلف 40 يورو شهرياً."
            },
            {
              "language": "ckb",
              "text": "کۆرسەکە مانگانە ٤٠ یۆرۆیە."
            },
            {
              "language": "en",
              "text": "The course costs 40 euros per month."
            },
            {
              "language": "fa",
              "text": "دوره ماهانه ۴۰ یورو هزینه دارد."
            },
            {
              "language": "kmr",
              "text": "Kurs mehane 40 euro ye."
            },
            {
              "language": "pl",
              "text": "Kurs kosztuje miesięcznie 40 euro."
            },
            {
              "language": "ro",
              "text": "Cursul costă lunar 40 de euro."
            },
            {
              "language": "ru",
              "text": "Курс стоит 40 евро в месяц."
            },
            {
              "language": "sq",
              "text": "Kursi kushton 40 euro në muaj."
            },
            {
              "language": "tr",
              "text": "Kurs aylık 40 avro."
            }
          ]
        }
      ]
    },
