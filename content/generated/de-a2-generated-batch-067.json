            },
            {
              "language": "fa",
              "text": "آپارتمان روشن و مدرن است."
            },
            {
              "language": "kmr",
              "text": "Apartman ronahî û modern e."
            },
            {
              "language": "pl",
              "text": "Mieszkanie jest jasne i nowoczesne."
            },
