            {
              "language": "en",
              "text": "Our office has modern computers."
            },
            {
              "language": "fa",
              "text": "دفتر ما کامپیوترهای مدرن دارد."
            },
            {
              "language": "kmr",
              "text": "Ofîsa me komputerên modern hene."
            },
            {
              "language": "pl",
              "text": "Nasze biuro ma nowoczesne komputery."
            },
            {
              "language": "ro",
              "text": "Biroul nostru are computere moderne."
