            },
            {
              "language": "ru",
              "text": "Квартира светлая и современная."
            },
            {
              "language": "sq",
              "text": "Banesa është e ndritshme dhe moderne."
            },
            {
              "language": "tr",
              "text": "Daire aydınlık ve modern."
            }
          ]
        },
        {
          "baseText": "Unser Büro hat moderne Computer.",
