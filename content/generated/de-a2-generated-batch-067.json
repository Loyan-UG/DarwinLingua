            },
            {
              "language": "ckb",
              "text": "کارتە مانگانەکە تا کۆتایی ئایار دروستە."
            },
            {
              "language": "en",
              "text": "The monthly pass is valid until the end of May."
            },
            {
              "language": "fa",
              "text": "کارت ماهانه تا پایان ماه مه اعتبار دارد."
            },
            {
              "language": "kmr",
              "text": "Karta mehane heta dawiya gulanê derbasdar e."
            },
            {
              "language": "pl",
              "text": "Bilet miesięczny jest ważny do końca maja."
