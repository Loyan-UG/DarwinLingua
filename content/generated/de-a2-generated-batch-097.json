      "examples": [
        {
          "baseText": "Sie können den Termin auch telefonisch ändern.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم تغيير الموعد أيضاً عبر الهاتف."
            },
            {
              "language": "ckb",
              "text": "دەتوانن کاتەکە بە تەلەفۆنیش بگۆڕن."
            },
            {
              "language": "en",
              "text": "You can also change the appointment by phone."
            },
            {
              "language": "fa",
              "text": "می‌توانید وقت را تلفنی هم تغییر دهید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin demê bi telefonê jî biguherînin."
            },
            {
              "language": "pl",
              "text": "Mogą państwo zmienić termin także telefonicznie."
            },
            {
              "language": "ro",
              "text": "Puteți modifica programarea și telefonic."
            },
            {
              "language": "ru",
              "text": "Вы также можете изменить запись по телефону."
            },
            {
              "language": "sq",
              "text": "Mund ta ndryshoni takimin edhe me telefon."
            },
            {
              "language": "tr",
              "text": "Randevuyu telefonla da değiştirebilirsiniz."
            }
          ]
        },
        {
          "baseText": "Das Büro ist heute nur telefonisch erreichbar.",
          "translations": [
            {
              "language": "ar",
              "text": "المكتب اليوم متاح فقط عبر الهاتف."
            },
            {
              "language": "ckb",
              "text": "نووسینگەکە ئەمڕۆ تەنها بە تەلەفۆن دەستپێگەیشتووە."
            },
            {
              "language": "en",
              "text": "The office can only be reached by phone today."
            },
            {
              "language": "fa",
              "text": "دفتر امروز فقط تلفنی در دسترس است."
            },
            {
              "language": "kmr",
              "text": "Nivîsgeh îro tenê bi telefonê dikare were girtin."
            },
            {
              "language": "pl",
              "text": "Biuro jest dziś dostępne tylko telefonicznie."
            },
            {
              "language": "ro",
              "text": "Biroul este disponibil astăzi doar telefonic."
            },
            {
              "language": "ru",
              "text": "Сегодня офис доступен только по телефону."
