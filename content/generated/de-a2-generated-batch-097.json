      "examples": [
        {
          "baseText": "Die neue Teilnehmerin kommt aus Polen.",
          "translations": [
            {
              "language": "ar",
              "text": "المشاركة الجديدة من بولندا."
            },
            {
              "language": "ckb",
              "text": "بەشداربووە ژنە نوێیەکە لە پۆڵەندەوەیە."
            },
            {
              "language": "en",
              "text": "The new participant comes from Poland."
            },
            {
              "language": "fa",
              "text": "شرکت‌کننده جدید از لهستان می‌آید."
            },
            {
              "language": "kmr",
              "text": "Beşdara nû ji Polonyayê tê."
            },
            {
              "language": "pl",
              "text": "Nowa uczestniczka pochodzi z Polski."
            },
            {
              "language": "ro",
              "text": "Noua participantă vine din Polonia."
            },
            {
              "language": "ru",
              "text": "Новая участница приехала из Польши."
            },
            {
              "language": "sq",
              "text": "Pjesëmarrësja e re vjen nga Polonia."
            },
            {
              "language": "tr",
              "text": "Yeni katılımcı Polonya’dan geliyor."
            }
          ]
        },
        {
          "baseText": "Die Teilnehmerin stellt eine Frage zum Formular.",
          "translations": [
            {
              "language": "ar",
              "text": "تطرح المشاركة سؤالاً عن الاستمارة."
            },
            {
              "language": "ckb",
              "text": "بەشداربووە ژنەکە پرسیارێک دەربارەی فۆرمەکە دەکات."
            },
            {
              "language": "en",
              "text": "The participant asks a question about the form."
            },
            {
              "language": "fa",
              "text": "شرکت‌کننده درباره فرم سؤال می‌پرسد."
            },
            {
              "language": "kmr",
              "text": "Beşdar li ser formê pirsê dike."
            },
            {
              "language": "pl",
              "text": "Uczestniczka zadaje pytanie o formularz."
            },
            {
              "language": "ro",
              "text": "Participanta pune o întrebare despre formular."
            },
            {
              "language": "ru",
              "text": "Участница задает вопрос о форме."
            },
            {
              "language": "sq",
              "text": "Pjesëmarrësja bën një pyetje për formularin."
            },
            {
              "language": "tr",
              "text": "Katılımcı form hakkında bir soru soruyor."
            }
