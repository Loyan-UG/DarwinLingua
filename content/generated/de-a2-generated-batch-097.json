          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بطاقة مشارك"
        },
        {
          "language": "ckb",
          "text": "ناسنامەی بەشداربوو"
        },
        {
          "language": "en",
          "text": "participant ID; participant card"
        },
        {
          "language": "fa",
          "text": "کارت شرکت‌کننده"
        },
        {
          "language": "kmr",
          "text": "kartê beşdarî; nasnameya beşdar"
        },
        {
          "language": "pl",
          "text": "identyfikator uczestnika"
        },
        {
          "language": "ro",
          "text": "legitimație de participant"
        },
        {
          "language": "ru",
          "text": "удостоверение участника"
        },
        {
          "language": "sq",
          "text": "kartë pjesëmarrësi"
        },
        {
          "language": "tr",
          "text": "katılımcı kartı"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte zeigen Sie am Eingang Ihren Teilnehmerausweis.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إظهار بطاقة المشارك عند المدخل."
            },
            {
              "language": "ckb",
              "text": "تکایە لە دەروازە ناسنامەی بەشداربوونتان پیشان بدەن."
            },
            {
              "language": "en",
              "text": "Please show your participant ID at the entrance."
            },
            {
              "language": "fa",
              "text": "لطفاً کارت شرکت‌کننده خود را در ورودی نشان دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li derketinê kartê beşdariya xwe nîşan bidin."
            },
            {
              "language": "pl",
              "text": "Proszę pokazać identyfikator uczestnika przy wejściu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să arătați legitimația de participant la intrare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, покажите удостоверение участника на входе."
            },
            {
              "language": "sq",
              "text": "Ju lutem tregoni kartën e pjesëmarrësit në hyrje."
            },
            {
              "language": "tr",
              "text": "Lütfen girişte katılımcı kartınızı gösterin."
            }
          ]
        },
        {
          "baseText": "Ich habe meinen Teilnehmerausweis im Kursraum vergessen.",
          "translations": [
            {
              "language": "ar",
              "text": "نسيت بطاقة المشارك في قاعة الدورة."
            },
            {
              "language": "ckb",
              "text": "ناسنامەی بەشداربوونم لە ژووری خولەکە لەبیر کردووە."
            },
            {
              "language": "en",
              "text": "I forgot my participant card in the course room."
            },
            {
              "language": "fa",
              "text": "کارت شرکت‌کننده‌ام را در کلاس جا گذاشتم."
            },
            {
              "language": "kmr",
              "text": "Min kartê beşdariya xwe li odeya kursê ji bîr kir."
            },
            {
              "language": "pl",
              "text": "Zapomniałem identyfikatora uczestnika w sali kursowej."
            },
            {
              "language": "ro",
              "text": "Mi-am uitat legitimația de participant în sala de curs."
            },
            {
              "language": "ru",
              "text": "Я забыл удостоверение участника в учебной комнате."
            },
            {
              "language": "sq",
              "text": "E harrova kartën e pjesëmarrësit në sallën e kursit."
            },
            {
              "language": "tr",
              "text": "Katılımcı kartımı kurs odasında unuttum."
            }
          ]
        }
      ]
    },
