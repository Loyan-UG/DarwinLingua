  "entries": [
    {
      "word": "die Nachfrage",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Nachfragen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Nach-fra-ge",
      "topics": [
        "sales-and-customers",
        "business-communication",
        "customer-service"
      ],
      "usageLabels": [
        "business",
        "customer-facing",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; can mean demand or follow-up question depending on context"
      ],
      "collocations": [
        {
          "text": "hohe Nachfrage",
          "meaning": "high demand"
        },
        {
          "text": "eine Nachfrage stellen",
          "meaning": "to ask a follow-up question"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "nachfragen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Frage",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "طلب؛ استفسار إضافي"
        },
        {
          "language": "ckb",
          "text": "داوا؛ پرسیاری زیاتر"
        },
        {
          "language": "en",
          "text": "demand; follow-up question"
        },
        {
          "language": "fa",
          "text": "تقاضا؛ پرسش تکمیلی"
        },
        {
          "language": "kmr",
          "text": "daxwaz; pirsa pêvek"
        },
        {
          "language": "pl",
          "text": "popyt; dodatkowe pytanie"
        },
        {
          "language": "ro",
          "text": "cerere; întrebare suplimentară"
        },
        {
          "language": "ru",
          "text": "спрос; уточняющий вопрос"
        },
        {
          "language": "sq",
          "text": "kërkesë; pyetje shtesë"
        },
        {
          "language": "tr",
          "text": "talep; ek soru"
        }
      ],
      "examples": [
        {
          "baseText": "Die Nachfrage nach dem neuen Produkt ist höher als erwartet.",
          "translations": [
            {
              "language": "ar",
              "text": "الطلب على المنتج الجديد أعلى مما كان متوقعًا."
            },
            {
              "language": "ckb",
              "text": "داوا بۆ بەرهەمی نوێ زیاترە لەوەی چاوەڕوان دەکرا."
            },
            {
              "language": "en",
              "text": "Demand for the new product is higher than expected."
            },
            {
              "language": "fa",
              "text": "تقاضا برای محصول جدید بیشتر از انتظار است."
            },
            {
              "language": "kmr",
              "text": "Daxwaza ji bo hilbera nû ji ya bendewarî zêdetir e."
            },
            {
              "language": "pl",
              "text": "Popyt na nowy produkt jest wyższy niż oczekiwano."
            },
            {
              "language": "ro",
              "text": "Cererea pentru noul produs este mai mare decât se aștepta."
            },
            {
              "language": "ru",
              "text": "Спрос на новый продукт выше ожидаемого."
            },
            {
              "language": "sq",
              "text": "Kërkesa për produktin e ri është më e lartë se pritej."
            },
            {
              "language": "tr",
              "text": "Yeni ürüne olan talep beklenenden daha yüksek."
            }
          ]
        },
        {
          "baseText": "Bei weiteren Nachfragen erreichen Sie uns per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "للاستفسارات الإضافية يمكنكم التواصل معنا عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "بۆ پرسیاری زیاتر دەتوانن بە ئیمەیڵ پەیوەندیمان پێوە بکەن."
            },
            {
              "language": "en",
              "text": "If you have further questions, you can reach us by email."
            },
            {
              "language": "fa",
              "text": "در صورت پرسش‌های بیشتر، می‌توانید از طریق ایمیل با ما تماس بگیرید."
            },
            {
              "language": "kmr",
              "text": "Heke pirsên we yên din hebin, hûn dikarin bi e-nameyê bigihîjin me."
            },
            {
              "language": "pl",
              "text": "W razie dalszych pytań można się z nami skontaktować e-mailem."
            },
            {
              "language": "ro",
              "text": "Pentru întrebări suplimentare, ne puteți contacta prin e-mail."
            },
            {
              "language": "ru",
              "text": "При дополнительных вопросах вы можете связаться с нами по электронной почте."
            },
            {
              "language": "sq",
              "text": "Për pyetje të tjera mund të na kontaktoni me email."
            },
            {
              "language": "tr",
              "text": "Başka sorularınız olursa bize e-posta ile ulaşabilirsiniz."
            }
          ]
        }
      ]
    },
