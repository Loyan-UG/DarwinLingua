      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يستفسر؛ يسأل مرة أخرى"
        },
        {
          "language": "ckb",
          "text": "پرسیار دەکاتەوە؛ ڕوونکردنەوە داوا دەکات"
        },
        {
          "language": "en",
          "text": "to ask; to ask for clarification"
        },
        {
          "language": "fa",
          "text": "سؤال کردن؛ پیگیری/استعلام کردن"
        },
        {
          "language": "kmr",
          "text": "pirsîn; zelalkirin xwestin"
        },
        {
          "language": "pl",
          "text": "dopytać; zapytać ponownie"
        },
        {
          "language": "ro",
          "text": "a întreba; a cere clarificări"
        },
        {
          "language": "ru",
          "text": "уточнять; переспрашивать"
        },
        {
          "language": "sq",
          "text": "të pyesësh; të kërkosh sqarim"
        },
        {
          "language": "tr",
          "text": "sormak; açıklama istemek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich frage beim Kunden nach, welche Lieferadresse richtig ist.",
          "translations": [
            {
              "language": "ar",
              "text": "سأستفسر من العميل عن عنوان التسليم الصحيح."
            },
            {
              "language": "ckb",
              "text": "لە کڕیارەکە دەپرسەم کام ناونیشانی گەیاندن دروستە."
            },
            {
              "language": "en",
              "text": "I will ask the customer which delivery address is correct."
            },
            {
              "language": "fa",
              "text": "از مشتری می‌پرسم کدام آدرس تحویل درست است."
            },
            {
              "language": "kmr",
              "text": "Ez ê ji mişterî bipirsim ka kîjan navnîşana radestkirinê rast e."
            },
            {
              "language": "pl",
              "text": "Dopytam klienta, który adres dostawy jest prawidłowy."
            },
            {
              "language": "ro",
              "text": "Îl întreb pe client care adresă de livrare este corectă."
            },
            {
              "language": "ru",
              "text": "Я уточню у клиента, какой адрес доставки правильный."
            },
            {
              "language": "sq",
              "text": "Do ta pyes klientin cila adresë dorëzimi është e saktë."
            },
            {
              "language": "tr",
              "text": "Müşteriye hangi teslimat adresinin doğru olduğunu soracağım."
            }
          ]
        },
        {
          "baseText": "Wenn du etwas nicht verstehst, frag bitte direkt nach.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا لم تفهم شيئًا، فاسأل مباشرة من فضلك."
            },
            {
              "language": "ckb",
              "text": "ئەگەر شتێکت تێنەگەیشت، تکایە ڕاستەوخۆ بپرسەوە."
            },
            {
              "language": "en",
              "text": "If you do not understand something, please ask directly."
            },
            {
              "language": "fa",
              "text": "اگر چیزی را متوجه نشدی، لطفاً مستقیم بپرس."
            },
            {
              "language": "kmr",
              "text": "Heke tu tiştekî fam nekî, ji kerema xwe rasterast bipirse."
            },
            {
              "language": "pl",
              "text": "Jeśli czegoś nie rozumiesz, zapytaj od razu."
            },
            {
              "language": "ro",
              "text": "Dacă nu înțelegi ceva, te rog întreabă direct."
            },
            {
              "language": "ru",
              "text": "Если ты что-то не понимаешь, пожалуйста, сразу спроси."
            },
            {
              "language": "sq",
              "text": "Nëse nuk kupton diçka, të lutem pyet drejtpërdrejt."
            },
            {
              "language": "tr",
              "text": "Bir şeyi anlamazsan lütfen doğrudan sor."
            }
          ]
        }
      ]
    },
