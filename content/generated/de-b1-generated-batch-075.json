  "entries": [
    {
      "word": "hinfallen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hinfallen",
      "pronunciationIpa": null,
      "syllableBreak": "hin-fal-len",
      "topics": [
        "everyday-life",
        "healthcare-and-appointments",
        "quality-and-risk"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; past participle: hingefallen; means to fall down"
      ],
      "collocations": [
        {
          "text": "auf den Boden hinfallen",
          "meaning": "to fall down onto the floor"
        },
        {
          "text": "beim Laufen hinfallen",
          "meaning": "to fall while walking or running"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fallen",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "der Unfall",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسقط؛ يقع أرضاً"
        },
        {
          "language": "ckb",
          "text": "کەوتن؛ کەوتنە خوارەوە"
        },
        {
          "language": "en",
          "text": "to fall down"
        },
        {
          "language": "fa",
          "text": "زمین خوردن؛ افتادن"
        },
        {
          "language": "kmr",
          "text": "ketin xwarê"
        },
        {
          "language": "pl",
          "text": "przewrócić się; upaść"
        },
        {
          "language": "ro",
          "text": "a cădea"
        },
        {
          "language": "ru",
          "text": "упасть; падать"
        },
        {
          "language": "sq",
          "text": "të rrëzohesh"
        },
        {
          "language": "tr",
          "text": "düşmek; yere düşmek"
        }
      ],
      "examples": [
        {
          "baseText": "Im Lager ist ein Mitarbeiter hingefallen, weil der Boden nass war.",
          "translations": [
            {
              "language": "ar",
              "text": "سقط أحد الموظفين في المستودع لأن الأرضية كانت مبللة."
            },
            {
              "language": "ckb",
              "text": "لە کۆگادا کارمەندێک کەوت، چونکە زەوییەکە تەڕ بوو."
            },
            {
              "language": "en",
              "text": "An employee fell down in the warehouse because the floor was wet."
            },
            {
              "language": "fa",
              "text": "در انبار یکی از کارکنان زمین خورد چون کف زمین خیس بود."
            },
            {
              "language": "kmr",
              "text": "Li embarê karmendek ket xwarê, ji ber ku erd şil bû."
            },
            {
              "language": "pl",
              "text": "W magazynie pracownik przewrócił się, ponieważ podłoga była mokra."
            },
            {
              "language": "ro",
              "text": "În depozit, un angajat a căzut deoarece podeaua era udă."
            },
            {
              "language": "ru",
              "text": "На складе сотрудник упал, потому что пол был мокрым."
            },
            {
              "language": "sq",
              "text": "Në magazinë një punonjës u rrëzua, sepse dyshemeja ishte e lagur."
            },
            {
              "language": "tr",
              "text": "Depoda bir çalışan zemin ıslak olduğu için düştü."
            }
          ]
        },
        {
          "baseText": "Das Kind ist auf dem Spielplatz hingefallen, aber es hat sich nicht verletzt.",
          "translations": [
            {
              "language": "ar",
              "text": "سقط الطفل في الملعب، لكنه لم يُصب."
            },
            {
              "language": "ckb",
              "text": "منداڵەکە لە یاریگاکە کەوت، بەڵام بریندار نەبوو."
            },
            {
              "language": "en",
              "text": "The child fell down on the playground, but did not get hurt."
            },
            {
              "language": "fa",
              "text": "کودک در زمین بازی زمین خورد، اما آسیب ندید."
            },
            {
              "language": "kmr",
              "text": "Zarok li cihê lîstinê ket xwarê, lê birîndar nebû."
            },
            {
              "language": "pl",
              "text": "Dziecko przewróciło się na placu zabaw, ale się nie zraniło."
            },
            {
              "language": "ro",
              "text": "Copilul a căzut pe locul de joacă, dar nu s-a rănit."
            },
            {
              "language": "ru",
              "text": "Ребёнок упал на детской площадке, но не поранился."
            },
            {
              "language": "sq",
              "text": "Fëmija u rrëzua në këndin e lojërave, por nuk u lëndua."
            },
            {
              "language": "tr",
              "text": "Çocuk oyun parkında düştü ama yaralanmadı."
            }
          ]
        }
      ]
    },
    {
      "word": "hingegen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "hin-ge-gen",
      "topics": [
        "business-communication",
        "data-and-reporting",
        "education-and-training"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "contrastive adverb; often placed after the contrasted subject"
      ],
      "collocations": [
        {
          "text": "A ..., B hingegen ...",
          "meaning": "A ..., whereas B ..."
        },
        {
          "text": "im Gegensatz dazu hingegen",
          "meaning": "by contrast"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gegen",
          "relationLabel": "related preposition",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أما؛ في المقابل"
        },
        {
          "language": "ckb",
          "text": "بە پێچەوانەوە؛ لە لایەکی ترەوە"
        },
        {
          "language": "en",
          "text": "whereas; by contrast; however"
        },
        {
          "language": "fa",
          "text": "در مقابل؛ اما"
        },
        {
          "language": "kmr",
          "text": "li hember vê; lêbelê"
        },
        {
          "language": "pl",
          "text": "natomiast; z kolei"
        },
        {
          "language": "ro",
          "text": "în schimb; pe de altă parte"
        },
        {
          "language": "ru",
          "text": "напротив; тогда как"
        },
        {
          "language": "sq",
          "text": "ndërsa; përkundrazi"
        },
        {
          "language": "tr",
          "text": "buna karşılık; oysa"
        }
      ],
      "examples": [
        {
          "baseText": "Die Software ist günstig, die Einrichtung hingegen dauert mehrere Tage.",
          "translations": [
            {
              "language": "ar",
              "text": "البرنامج رخيص، أما الإعداد فيستغرق عدة أيام."
            },
            {
              "language": "ckb",
              "text": "نەرمەکاڵاکە هەرزانە، بەڵام دامەزراندنەکە چەند ڕۆژ دەخایەنێت."
            },
            {
              "language": "en",
              "text": "The software is inexpensive, whereas the setup takes several days."
            },
            {
              "language": "fa",
              "text": "نرم‌افزار ارزان است، اما راه‌اندازی آن چند روز طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Nermalav erzan e, lê saz kirina wê çend roj dom dike."
            },
            {
              "language": "pl",
              "text": "Oprogramowanie jest tanie, natomiast konfiguracja trwa kilka dni."
            },
            {
              "language": "ro",
              "text": "Software-ul este ieftin, în schimb configurarea durează câteva zile."
            },
            {
              "language": "ru",
              "text": "Программное обеспечение недорогое, а настройка занимает несколько дней."
            },
            {
              "language": "sq",
              "text": "Softueri është i lirë, ndërsa konfigurimi zgjat disa ditë."
            },
            {
              "language": "tr",
              "text": "Yazılım ucuz, buna karşılık kurulum birkaç gün sürüyor."
            }
          ]
        },
        {
          "baseText": "Morgens ist der Bus oft voll, abends hingegen findet man leichter einen Sitzplatz.",
          "translations": [
            {
              "language": "ar",
              "text": "في الصباح تكون الحافلة غالباً ممتلئة، أما في المساء فمن الأسهل إيجاد مقعد."
            },
            {
              "language": "ckb",
              "text": "بەیانیان پاسەکە زۆرجار پڕە، بەڵام ئێواران ئاسانتر کورسی دەدۆزرێتەوە."
            },
            {
              "language": "en",
              "text": "In the morning, the bus is often full, whereas in the evening it is easier to find a seat."
            },
            {
              "language": "fa",
              "text": "صبح‌ها اتوبوس اغلب شلوغ است، اما عصرها راحت‌تر می‌توان صندلی پیدا کرد."
            },
            {
              "language": "kmr",
              "text": "Serê sibehê otobûs pir caran tijî ye, lê êvaran cihê rûniştinê hêsantir tê dîtin."
            },
            {
              "language": "pl",
              "text": "Rano autobus jest często pełny, natomiast wieczorem łatwiej znaleźć miejsce."
            },
            {
              "language": "ro",
              "text": "Dimineața autobuzul este adesea plin, în schimb seara găsești mai ușor un loc."
            },
            {
              "language": "ru",
              "text": "Утром автобус часто полный, а вечером легче найти место."
            },
            {
              "language": "sq",
              "text": "Në mëngjes autobusi shpesh është plot, ndërsa në mbrëmje gjen më lehtë një vend."
            },
            {
              "language": "tr",
              "text": "Sabahları otobüs genellikle dolu olur, akşamları ise koltuk bulmak daha kolaydır."
            }
          ]
        }
      ]
    },
