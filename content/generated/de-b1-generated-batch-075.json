      "examples": [
        {
          "baseText": "Kommen Sie mit der Bahn gut zum Büro hin?",
          "translations": [
            {
              "language": "ar",
              "text": "هل تصلون بسهولة إلى المكتب بالقطار؟"
            },
            {
              "language": "ckb",
              "text": "ئایا بە شەمەندەفەر بە ئاسانی دەگەنە ئۆفیس؟"
            },
            {
              "language": "en",
              "text": "Can you get to the office easily by train?"
            },
            {
              "language": "fa",
              "text": "آیا با قطار راحت به دفتر می‌رسید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn bi trênê hêsan digihîjin nivîsgehê?"
            },
