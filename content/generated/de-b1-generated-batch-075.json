      "examples": [
        {
          "baseText": "Wenn die Karte nicht funktioniert, sollten Sie persönlich zur Servicestelle hingehen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا لم تعمل البطاقة، ينبغي أن تذهبوا شخصياً إلى مركز الخدمة."
            },
            {
              "language": "ckb",
              "text": "ئەگەر کارتەکە کار نەکات، دەبێت بە خۆتان بچنە شوێنی خزمەتگوزاری."
            },
            {
              "language": "en",
              "text": "If the card does not work, you should go to the service desk in person."
            },
            {
              "language": "fa",
              "text": "اگر کارت کار نمی‌کند، بهتر است شخصاً به مرکز خدمات بروید."
            },
            {
              "language": "kmr",
              "text": "Ger kart nexebite, divê hûn bi xwe biçin navenda xizmetê."
            },
            {
              "language": "pl",
              "text": "Jeśli karta nie działa, powinni Państwo osobiście pójść do punktu obsługi."
            },
            {
              "language": "ro",
              "text": "Dacă cardul nu funcționează, ar trebui să mergeți personal la ghișeul de servicii."
            },
            {
              "language": "ru",
              "text": "Если карта не работает, вам следует лично обратиться в сервисный пункт."
            },
            {
              "language": "sq",
              "text": "Nëse karta nuk funksionon, duhet të shkoni personalisht te pika e shërbimit."
            },
            {
              "language": "tr",
              "text": "Kart çalışmıyorsa hizmet noktasına şahsen gitmelisiniz."
            }
          ]
        },
        {
          "baseText": "Ich kann heute nicht zum Training hingehen, weil ich länger arbeiten muss.",
          "translations": [
            {
              "language": "ar",
              "text": "لا أستطيع الذهاب إلى التدريب اليوم لأن عليّ العمل لوقت أطول."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ ناتوانم بچمە ڕاهێنان، چونکە دەبێت زیاتر کار بکەم."
            },
            {
              "language": "en",
              "text": "I cannot go to training today because I have to work longer."
            },
            {
              "language": "fa",
              "text": "امروز نمی‌توانم به تمرین بروم چون باید بیشتر کار کنم."
            },
            {
              "language": "kmr",
              "text": "Ez îro nikarim biçim rahênanê, ji ber ku divê dirêjtir bixebitim."
            },
            {
              "language": "pl",
              "text": "Nie mogę dziś pójść na trening, bo muszę dłużej pracować."
            },
            {
              "language": "ro",
              "text": "Nu pot merge astăzi la antrenament, pentru că trebuie să lucrez mai mult."
            },
            {
              "language": "ru",
              "text": "Я сегодня не могу пойти на тренировку, потому что должен работать дольше."
            },
            {
              "language": "sq",
              "text": "Sot nuk mund të shkoj në stërvitje, sepse duhet të punoj më gjatë."
            },
            {
              "language": "tr",
              "text": "Bugün antrenmana gidemem çünkü daha uzun çalışmam gerekiyor."
            }
          ]
        }
