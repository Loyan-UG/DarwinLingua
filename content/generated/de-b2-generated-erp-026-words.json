  "entries": [
    {
      "word": "Telefoneinkauf",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Telefoneinkäufe",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Te-le-fon-ein-kauf",
      "topics": [
        "procurement-and-suppliers",
        "business-communication",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "polite"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; purchasing process handled by phone"
      ],
      "collocations": [
        {
          "text": "einen Telefoneinkauf erfassen",
          "meaning": "to record a phone purchase"
        },
        {
          "text": "per Telefoneinkauf bestellen",
          "meaning": "to order by phone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Telefon",
          "relationLabel": "component noun",
          "note": null
        },
        {
          "lemma": "der Einkauf",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شراء عبر الهاتف"
        },
        {
          "language": "ckb",
          "text": "کڕین بە تەلەفۆن"
        },
        {
          "language": "en",
          "text": "phone purchase; telephone purchasing"
        },
        {
          "language": "fa",
          "text": "خرید تلفنی"
        },
        {
          "language": "kmr",
          "text": "kirîna bi telefonê"
        },
        {
          "language": "pl",
          "text": "zakup telefoniczny"
        },
        {
          "language": "ro",
          "text": "achiziție telefonică"
        },
        {
          "language": "ru",
          "text": "покупка по телефону"
        },
        {
          "language": "sq",
          "text": "blerje me telefon"
        },
        {
          "language": "tr",
          "text": "telefonla satın alma"
        }
      ],
      "examples": [
        {
          "baseText": "Der Telefoneinkauf wird im ERP nach dem Gespräch mit dem Lieferanten erfasst.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تسجيل الشراء عبر الهاتف في ERP بعد المكالمة مع المورد."
            },
            {
              "language": "ckb",
              "text": "کڕینی بە تەلەفۆن دوای گفتوگۆ لەگەڵ دابینکەر لە ERP دا تۆمار دەکرێت."
            },
            {
              "language": "en",
              "text": "The phone purchase is recorded in the ERP after the call with the supplier."
            },
            {
              "language": "fa",
              "text": "خرید تلفنی پس از مکالمه با تأمین‌کننده در ERP ثبت می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kirîna bi telefonê piştî axaftina bi dabînker re di ERP de tê tomarkirin."
            },
            {
              "language": "pl",
              "text": "Zakup telefoniczny jest rejestrowany w ERP po rozmowie z dostawcą."
            },
            {
              "language": "ro",
              "text": "Achiziția telefonică este înregistrată în ERP după discuția cu furnizorul."
            },
            {
              "language": "ru",
              "text": "Покупка по телефону регистрируется в ERP после разговора с поставщиком."
            },
            {
              "language": "sq",
              "text": "Blerja me telefon regjistrohet në ERP pas bisedës me furnitorin."
            },
            {
              "language": "tr",
              "text": "Telefonla satın alma, tedarikçiyle görüşmeden sonra ERP’ye kaydedilir."
            }
          ]
        },
        {
          "baseText": "Bitte bestätigen Sie den Telefoneinkauf zusätzlich per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تأكيد الشراء عبر الهاتف أيضًا بالبريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "تکایە کڕینی بە تەلەفۆن بە ئیمەیڵیش پشتڕاست بکەنەوە."
            },
            {
              "language": "en",
              "text": "Please also confirm the phone purchase by email."
            },
            {
              "language": "fa",
              "text": "لطفاً خرید تلفنی را علاوه بر آن با ایمیل تأیید کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe kirîna bi telefonê bi e-nameyê jî piştrast bikin."
            },
            {
              "language": "pl",
              "text": "Proszę dodatkowo potwierdzić zakup telefoniczny e-mailem."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să confirmați achiziția telefonică și prin e-mail."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, дополнительно подтвердите покупку по телефону по электронной почте."
            },
            {
              "language": "sq",
              "text": "Ju lutemi konfirmoni blerjen me telefon edhe me email."
            },
            {
              "language": "tr",
              "text": "Lütfen telefonla satın almayı ayrıca e-posta ile onaylayın."
            }
          ]
        }
      ]
    },
    {
      "word": "Telefonverkauf",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Telefonverkäufe",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Te-le-fon-ver-kauf",
      "topics": [
        "sales-and-customers",
        "business-communication",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "polite"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; sales process handled by phone"
      ],
      "collocations": [
        {
          "text": "einen Telefonverkauf abschließen",
          "meaning": "to complete a sale by phone"
        },
        {
          "text": "Telefonverkauf dokumentieren",
          "meaning": "to document phone sales"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Telefon",
          "relationLabel": "component noun",
          "note": null
        },
        {
          "lemma": "der Verkauf",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بيع عبر الهاتف"
        },
        {
          "language": "ckb",
          "text": "فرۆشتن بە تەلەفۆن"
        },
        {
          "language": "en",
          "text": "phone sale; telephone sales"
        },
        {
          "language": "fa",
          "text": "فروش تلفنی"
        },
        {
          "language": "kmr",
          "text": "firotana bi telefonê"
        },
        {
          "language": "pl",
          "text": "sprzedaż telefoniczna"
        },
        {
          "language": "ro",
          "text": "vânzare telefonică"
        },
        {
          "language": "ru",
          "text": "продажа по телефону"
        },
        {
          "language": "sq",
          "text": "shitje me telefon"
        },
        {
          "language": "tr",
          "text": "telefonla satış"
        }
      ],
      "examples": [
        {
          "baseText": "Beim Telefonverkauf legt der Mitarbeiter den Auftrag direkt im ERP an.",
          "translations": [
            {
              "language": "ar",
              "text": "في البيع عبر الهاتف ينشئ الموظف الطلب مباشرة في ERP."
            },
            {
              "language": "ckb",
              "text": "لە فرۆشتنی بە تەلەفۆندا کارمەندەکە داواکارییەکە ڕاستەوخۆ لە ERP دا دروست دەکات."
            },
            {
              "language": "en",
              "text": "In a phone sale, the employee creates the order directly in the ERP."
            },
            {
              "language": "fa",
              "text": "در فروش تلفنی، کارمند سفارش را مستقیم در ERP ایجاد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di firotana bi telefonê de karmend fermanê rasterast di ERP de çêdike."
            },
            {
              "language": "pl",
              "text": "Przy sprzedaży telefonicznej pracownik tworzy zamówienie bezpośrednio w ERP."
            },
            {
              "language": "ro",
              "text": "În vânzarea telefonică, angajatul creează comanda direct în ERP."
            },
            {
              "language": "ru",
              "text": "При продаже по телефону сотрудник создает заказ прямо в ERP."
            },
            {
              "language": "sq",
              "text": "Në shitjen me telefon, punonjësi e krijon porosinë direkt në ERP."
            },
            {
              "language": "tr",
              "text": "Telefonla satışta çalışan siparişi doğrudan ERP’de oluşturur."
            }
          ]
        },
        {
          "baseText": "Der Kunde möchte nach dem Telefonverkauf eine schriftliche Auftragsbestätigung erhalten.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد العميل بعد البيع عبر الهاتف الحصول على تأكيد طلب مكتوب."
            },
            {
              "language": "ckb",
              "text": "کڕیار دوای فرۆشتنی بە تەلەفۆن دەیەوێت پشتڕاستکردنەوەی داواکاریی نووسراو وەربگرێت."
            },
            {
              "language": "en",
              "text": "After the phone sale, the customer wants to receive a written order confirmation."
            },
            {
              "language": "fa",
              "text": "مشتری پس از فروش تلفنی می‌خواهد تأییدیه سفارش کتبی دریافت کند."
            },
            {
              "language": "kmr",
              "text": "Mişterî piştî firotana bi telefonê dixwaze piştrastkirina nivîskî ya fermanê bistîne."
            },
            {
              "language": "pl",
              "text": "Po sprzedaży telefonicznej klient chce otrzymać pisemne potwierdzenie zamówienia."
            },
            {
              "language": "ro",
              "text": "După vânzarea telefonică, clientul dorește să primească o confirmare scrisă a comenzii."
            },
            {
              "language": "ru",
              "text": "После продажи по телефону клиент хочет получить письменное подтверждение заказа."
            },
            {
              "language": "sq",
              "text": "Pas shitjes me telefon, klienti dëshiron të marrë një konfirmim me shkrim të porosisë."
            },
            {
              "language": "tr",
              "text": "Müşteri telefonla satıştan sonra yazılı sipariş onayı almak istiyor."
            }
          ]
        }
      ]
    },
