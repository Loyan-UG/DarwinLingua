      ],
      "examples": [
        {
          "baseText": "Bitte geben Sie Ihre Bestellnummer an.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى ذكر رقم طلبكم."
            },
            {
              "language": "ckb",
              "text": "تکایە ژمارەی داواکارییەکەتان بنووسن."
            },
            {
              "language": "en",
              "text": "Please provide your order number."
            },
            {
              "language": "fa",
              "text": "لطفاً شماره سفارش خود را وارد کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe hejmara siparîşa xwe binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę podać numer zamówienia."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să indicați numărul comenzii."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, укажите номер заказа."
            },
            {
              "language": "sq",
              "text": "Ju lutem jepni numrin e porosisë suaj."
            },
            {
              "language": "tr",
              "text": "Lütfen sipariş numaranızı belirtin."
            }
          ]
        },
        {
          "baseText": "Die Bestellnummer steht auf der Rechnung.",
          "translations": [
            {
              "language": "ar",
              "text": "رقم الطلب موجود على الفاتورة."
            },
            {
              "language": "ckb",
              "text": "ژمارەی داواکاری لەسەر پسووڵەکەیە."
            },
            {
              "language": "en",
              "text": "The order number is on the invoice."
            },
            {
              "language": "fa",
              "text": "شماره سفارش روی فاکتور نوشته شده است."
            },
            {
              "language": "kmr",
              "text": "Hejmara siparîşê li ser fatûreyê ye."
            },
            {
              "language": "pl",
              "text": "Numer zamówienia jest na fakturze."
            },
            {
              "language": "ro",
              "text": "Numărul comenzii este pe factură."
            },
            {
              "language": "ru",
              "text": "Номер заказа указан в счете."
            },
            {
              "language": "sq",
              "text": "Numri i porosisë është në faturë."
            },
            {
              "language": "tr",
              "text": "Sipariş numarası faturada yazıyor."
            }
          ]
        }
