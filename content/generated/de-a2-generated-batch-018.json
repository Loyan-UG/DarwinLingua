      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تأكيد؛ إثبات"
        },
        {
          "language": "ckb",
          "text": "پشتڕاستکردنەوە؛ بەڵگەی پشتڕاستکردنەوە"
        },
        {
          "language": "en",
          "text": "confirmation"
        },
        {
          "language": "fa",
          "text": "تأییدیه؛ تأیید"
        },
        {
          "language": "kmr",
          "text": "piştrastkirin; belgeya piştrastkirinê"
        },
        {
          "language": "pl",
          "text": "potwierdzenie"
        },
        {
          "language": "ro",
          "text": "confirmare"
        },
        {
          "language": "ru",
          "text": "подтверждение"
        },
        {
          "language": "sq",
          "text": "konfirmim"
        },
        {
          "language": "tr",
          "text": "onay; teyit"
        }
      ],
      "examples": [
        {
          "baseText": "Sie bekommen die Bestätigung per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "ستحصلون على التأكيد عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "پشتڕاستکردنەوەکە بە ئیمەیڵ وەردەگرن."
            },
            {
              "language": "en",
              "text": "You will receive the confirmation by email."
            },
            {
              "language": "fa",
              "text": "تأییدیه را از طریق ایمیل دریافت می‌کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn ê piştrastkirinê bi e-nameyê wergirin."
            },
            {
              "language": "pl",
              "text": "Otrzyma Pan/Pani potwierdzenie e-mailem."
            },
            {
              "language": "ro",
              "text": "Veți primi confirmarea prin e-mail."
            },
            {
              "language": "ru",
              "text": "Вы получите подтверждение по электронной почте."
            },
            {
              "language": "sq",
              "text": "Do ta merrni konfirmimin me email."
            },
            {
              "language": "tr",
              "text": "Onayı e-posta ile alacaksınız."
            }
          ]
        },
        {
          "baseText": "Für den Termin brauche ich eine Bestätigung.",
          "translations": [
            {
              "language": "ar",
              "text": "أحتاج إلى تأكيد للموعد."
            },
            {
              "language": "ckb",
              "text": "بۆ کاتەکە پێویستم بە پشتڕاستکردنەوەیەکە."
            },
            {
              "language": "en",
              "text": "I need a confirmation for the appointment."
            },
            {
              "language": "fa",
              "text": "برای وقت ملاقات به تأییدیه نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ji bo wextê ez hewceyê piştrastkirinê me."
            },
            {
              "language": "pl",
              "text": "Potrzebuję potwierdzenia terminu."
            },
            {
              "language": "ro",
              "text": "Am nevoie de o confirmare pentru programare."
            },
            {
              "language": "ru",
              "text": "Мне нужно подтверждение записи."
            },
            {
              "language": "sq",
              "text": "Më duhet një konfirmim për takimin."
            },
            {
              "language": "tr",
              "text": "Randevu için bir onaya ihtiyacım var."
            }
          ]
        }
      ]
    },
