      "examples": [
        {
          "baseText": "Ich möchte ein Konto eröffnen.",
          "translations": [
            {
              "language": "ar",
              "text": "أود فتح حساب."
            },
            {
              "language": "ckb",
              "text": "دەمەوێ هەژمارێک بکەمەوە."
            },
            {
              "language": "en",
              "text": "I would like to open an account."
            },
            {
              "language": "fa",
              "text": "می‌خواهم یک حساب باز کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim hesabekê vekim."
            },
            {
              "language": "pl",
              "text": "Chciałbym otworzyć konto."
            },
            {
              "language": "ro",
              "text": "Aș dori să deschid un cont."
            },
            {
              "language": "ru",
              "text": "Я хотел бы открыть счет."
            },
            {
              "language": "sq",
              "text": "Dua të hap një llogari."
            },
            {
              "language": "tr",
              "text": "Bir hesap açmak istiyorum."
            }
          ]
        },
        {
          "baseText": "Ist Geld auf dem Konto?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يوجد مال في الحساب؟"
            },
            {
              "language": "ckb",
              "text": "پارە لە هەژمارەکەدا هەیە؟"
            },
            {
              "language": "en",
              "text": "Is there money in the account?"
            },
            {
              "language": "fa",
              "text": "آیا در حساب پول هست؟"
            },
            {
              "language": "kmr",
              "text": "Di hesabê de pere heye?"
            },
            {
              "language": "pl",
              "text": "Czy na koncie są pieniądze?"
            },
            {
              "language": "ro",
              "text": "Sunt bani în cont?"
            },
            {
              "language": "ru",
              "text": "На счете есть деньги?"
            },
            {
              "language": "sq",
              "text": "A ka para në llogari?"
            },
            {
              "language": "tr",
              "text": "Hesapta para var mı?"
            }
          ]
        }
