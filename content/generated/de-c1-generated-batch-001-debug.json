  "entries": [
    {
      "word": "abberufen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abberufen",
      "pronunciationIpa": null,
      "syllableBreak": "ab-be-ru-fen",
      "topics": [
        "management-and-leadership",
        "law-and-compliance",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business",
        "administrative",
        "advanced"
      ],
      "contextLabels": [
        "management",
        "legal",
        "administration"
      ],
      "grammarNotes": [
        "separable verb; often used in official or corporate contexts"
      ],
      "collocations": [
        {
          "text": "jemanden aus dem Amt abberufen",
          "meaning": "to remove someone from an office or position"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Abberufung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعزل؛ يستدعي من المنصب"
        },
        {
          "language": "ckb",
          "text": "لە پۆستێک لابردن؛ بانگکردنەوە"
        },
        {
          "language": "en",
          "text": "to recall; to remove from office"
        },
        {
          "language": "fa",
          "text": "برکنار کردن؛ فراخواندن از سمت"
        },
        {
          "language": "kmr",
          "text": "ji peywirê rakirin; gazî vegerandin"
        },
        {
          "language": "pl",
          "text": "odwołać ze stanowiska"
        },
        {
          "language": "ro",
          "text": "a revoca; a retrage din funcție"
        },
        {
          "language": "ru",
          "text": "отозвать; снять с должности"
        },
        {
          "language": "sq",
          "text": "të shkarkojë; të thërrasë mbrapsht"
        },
        {
          "language": "tr",
          "text": "görevden almak; geri çağırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Aufsichtsrat kann den Vorstand bei schweren Pflichtverletzungen abberufen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن لمجلس الرقابة عزل مجلس الإدارة عند حدوث انتهاكات جسيمة للواجبات."
            },
            {
              "language": "ckb",
              "text": "ئەنجومەنی چاودێری دەتوانێت بەهۆی پێشێلکاریی گەورەی ئەرکەکان بەڕێوەبەرایەتی لاببات."
            },
            {
              "language": "en",
              "text": "The supervisory board can remove the executive board in cases of serious breaches of duty."
            },
            {
              "language": "fa",
              "text": "هیئت نظارت می‌تواند در صورت نقض جدی وظایف، هیئت مدیره را برکنار کند."
            },
            {
              "language": "kmr",
              "text": "Encûmena çavdêriyê dikare di binpêkirinên giran ên erkê de rêveberiyê ji peywirê rake."
            },
            {
              "language": "pl",
              "text": "Rada nadzorcza może odwołać zarząd w przypadku poważnego naruszenia obowiązków."
            },
            {
              "language": "ro",
              "text": "Consiliul de supraveghere poate revoca directoratul în cazul unor încălcări grave ale obligațiilor."
            },
            {
              "language": "ru",
              "text": "Наблюдательный совет может отстранить правление при серьёзных нарушениях обязанностей."
            },
            {
              "language": "sq",
              "text": "Këshilli mbikëqyrës mund ta shkarkojë bordin drejtues në rast shkeljesh të rënda të detyrave."
            },
            {
              "language": "tr",
              "text": "Denetim kurulu, ciddi görev ihlallerinde yönetim kurulunu görevden alabilir."
            }
          ]
        },
        {
          "baseText": "Die Botschafterin wurde nach den politischen Spannungen aus dem Ausland abberufen.",
          "translations": [
            {
              "language": "ar",
              "text": "تم استدعاء السفيرة من الخارج بعد التوترات السياسية."
            },
            {
              "language": "ckb",
              "text": "باڵیۆزەکە دوای گرژییە سیاسییەکان لە دەرەوە بانگکرایەوە."
            },
            {
              "language": "en",
              "text": "The ambassador was recalled from abroad after the political tensions."
            },
            {
              "language": "fa",
              "text": "سفیر پس از تنش‌های سیاسی از کشور خارجی فراخوانده شد."
            },
            {
              "language": "kmr",
              "text": "Balyoz piştî tengasiyên siyasî ji derveyî welat hat vegerandin."
            },
            {
              "language": "pl",
              "text": "Ambasadorka została odwołana z zagranicy po napięciach politycznych."
            },
            {
              "language": "ro",
              "text": "Ambasadoarea a fost rechemată din străinătate după tensiunile politice."
            },
            {
              "language": "ru",
              "text": "Посол была отозвана из-за рубежа после политической напряжённости."
            },
            {
              "language": "sq",
              "text": "Ambasadorja u thirr mbrapsht nga jashtë pas tensioneve politike."
            },
            {
              "language": "tr",
              "text": "Büyükelçi, siyasi gerilimlerden sonra yurt dışından geri çağrıldı."
            }
          ]
        }
      ]
    },
    {
      "word": "abbitten",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abbitten",
      "pronunciationIpa": null,
      "syllableBreak": "ab-bit-ten",
      "topics": [
        "business-communication",
        "law-and-compliance",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "written",
        "polite",
        "advanced"
      ],
      "contextLabels": [
        "legal",
        "administration",
        "customer-service"
      ],
      "grammarNotes": [
        "formal verb; commonly used as etwas jemandem abbitten"
      ],
      "collocations": [
        {
          "text": "jemandem eine Äußerung abbitten",
          "meaning": "to apologize to someone for a statement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Abbitte",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعتذر عن؛ يطلب الصفح عن"
        },
        {
          "language": "ckb",
          "text": "داوای لێبوردن کردن بۆ شتێک"
        },
        {
          "language": "en",
          "text": "to apologize for; to ask forgiveness for"
        },
        {
          "language": "fa",
          "text": "پوزش خواستن بابت؛ طلب بخشش کردن"
        },
        {
          "language": "kmr",
          "text": "lêborîn xwestin ji bo tiştekê"
        },
        {
          "language": "pl",
          "text": "przeprosić za coś"
        },
        {
          "language": "ro",
          "text": "a-și cere iertare pentru"
        },
        {
          "language": "ru",
          "text": "просить прощения за"
        },
        {
          "language": "sq",
          "text": "të kërkojë falje për"
        },
        {
          "language": "tr",
          "text": "özür dilemek; af dilemek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Geschäftsführer musste der Kundin die unzutreffende Behauptung öffentlich abbitten.",
          "translations": [
            {
              "language": "ar",
              "text": "اضطر المدير العام إلى الاعتذار علنًا للعميلة عن الادعاء غير الصحيح."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری گشتی ناچار بوو بە ئاشکرا داوای لێبوردن لە کڕیارە ژنەکە بکات بۆ بانگەشەی نادروست."
            },
            {
              "language": "en",
              "text": "The managing director had to publicly apologize to the customer for the inaccurate claim."
            },
            {
              "language": "fa",
              "text": "مدیرعامل مجبور شد بابت ادعای نادرست به‌صورت عمومی از مشتری عذرخواهی کند."
            },
            {
              "language": "kmr",
              "text": "Rêveberê giştî neçar bû ji xerîdarê jin re ji bo îdiaya ne rast bi eşkereyî lêborîn bixwaze."
            },
            {
              "language": "pl",
              "text": "Dyrektor zarządzający musiał publicznie przeprosić klientkę za nieprawdziwe twierdzenie."
            },
            {
              "language": "ro",
