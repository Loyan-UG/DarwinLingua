            {
              "language": "ru",
              "text": "Без чёткой модерации предметная дискуссия может быстро скатиться к личным обвинениям."
            },
            {
              "language": "sq",
              "text": "Pa moderim të qartë, një diskutim faktik mund të rrëshqasë shpejt në akuza personale."
            },
            {
              "language": "tr",
              "text": "Net bir moderasyon olmadan nesnel bir tartışma hızla kişisel suçlamalara kayabilir."
            }
          ]
        },
        {
          "baseText": "Der Fahrer geriet auf nasser Straße ins Schleudern und wäre fast in den Graben abgeglitten.",
          "translations": [
