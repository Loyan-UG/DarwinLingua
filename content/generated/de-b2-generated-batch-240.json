  "entries": [
    {
      "word": "überschneiden",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "überschneiden",
      "pronunciationIpa": null,
      "syllableBreak": "ü-ber-schnei-den",
      "topics": [
        "planning-and-projects",
        "business-communication",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "spoken"
      ],
      "contextLabels": [
        "management",
        "analytics",
        "administration"
      ],
      "grammarNotes": [
        "reflexive use common: sich überschneiden; means to overlap"
      ],
      "collocations": [
        {
          "text": "sich zeitlich überschneiden",
          "meaning": "to overlap in time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Überschneidung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "schneiden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتداخل؛ يتقاطع"
        },
        {
          "language": "ckb",
          "text": "یەکدەگرن؛ هاوکات دەبن"
        },
        {
          "language": "en",
          "text": "to overlap; to intersect"
        },
        {
          "language": "fa",
          "text": "هم‌پوشانی داشتن؛ تداخل داشتن"
        },
        {
          "language": "kmr",
          "text": "li hev ketin; hevdem bûn"
        },
        {
          "language": "pl",
          "text": "nakładać się; krzyżować się"
        },
        {
          "language": "ro",
          "text": "a se suprapune; a se intersecta"
        },
        {
          "language": "ru",
          "text": "пересекаться; накладываться"
        },
        {
          "language": "sq",
          "text": "të mbivendosen; të përputhen pjesërisht"
        },
        {
          "language": "tr",
          "text": "çakışmak; örtüşmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die beiden Termine überschneiden sich, deshalb muss ich einen davon verschieben.",
          "translations": [
            {
              "language": "ar",
              "text": "يتداخل الموعدان، لذلك يجب أن أؤجل أحدهما."
            },
            {
              "language": "ckb",
              "text": "هەردوو کاتەکە هاوکات دەبن، بۆیە دەبێت یەکێکیان دوا بخەم."
            },
            {
              "language": "en",
              "text": "The two appointments overlap, so I have to move one of them."
            },
            {
              "language": "fa",
              "text": "این دو قرار با هم تداخل دارند، بنابراین باید یکی از آن‌ها را جابه‌جا کنم."
            },
            {
              "language": "kmr",
              "text": "Her du hevdîtin li hev dikevin, ji ber vê yekê divê yekê wan veguhezînim."
            },
            {
              "language": "pl",
              "text": "Te dwa terminy się nakładają, dlatego muszę jeden z nich przesunąć."
            },
            {
              "language": "ro",
              "text": "Cele două întâlniri se suprapun, de aceea trebuie să mut una dintre ele."
            },
            {
              "language": "ru",
              "text": "Эти две встречи пересекаются, поэтому мне нужно перенести одну из них."
            },
            {
              "language": "sq",
              "text": "Dy takimet mbivendosen, prandaj duhet ta zhvendos njërin prej tyre."
            },
            {
              "language": "tr",
              "text": "İki randevu çakışıyor, bu yüzden birini ertelemem gerekiyor."
            }
          ]
        },
        {
          "baseText": "In der Analyse überschneiden sich die Kundengruppen stärker als erwartet.",
          "translations": [
            {
              "language": "ar",
