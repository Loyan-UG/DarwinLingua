  "entries": [
    {
      "word": "gebrechen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "gebrechen",
      "pronunciationIpa": null,
      "syllableBreak": "ge-bre-chen",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "formal/archaic verb; common impersonal pattern: es gebricht an etwas"
      ],
      "collocations": [
        {
          "text": "es gebricht an Transparenz",
          "meaning": "there is a lack of transparency"
        },
        {
          "text": "an Belegen gebrechen",
          "meaning": "to lack evidence or documents"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Gebrechen",
          "relationLabel": "noun",
          "note": "ailment or defect; different usage"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينقص؛ يفتقر إلى"
        },
        {
          "language": "ckb",
          "text": "کەمە؛ پێویستی بە شتێک هەیە"
        },
        {
          "language": "en",
          "text": "to be lacking; to be deficient in"
        },
        {
          "language": "fa",
          "text": "کم داشتن؛ فاقد بودن"
        },
        {
          "language": "kmr",
          "text": "kêm bûn; bêpar bûn ji tiştekî"
        },
        {
          "language": "pl",
          "text": "brakować; niedostawać"
        },
        {
          "language": "ro",
          "text": "a lipsi; a fi deficitar"
        },
        {
          "language": "ru",
          "text": "недоставать; не хватать"
        },
        {
          "language": "sq",
          "text": "të mungojë; të ketë mungesë"
        },
        {
          "language": "tr",
          "text": "eksik olmak; yetersiz olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Dem Bericht gebricht es an konkreten Belegen für die behaupteten Einsparungen.",
          "translations": [
            {
              "language": "ar",
              "text": "يفتقر التقرير إلى أدلة ملموسة على الوفورات المزعومة."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتەکە بەڵگەی دیاریکراوی بۆ ئەو کەمکردنەوەی خەرجییانەی بانگەشە کراون کەمە."
            },
            {
              "language": "en",
              "text": "The report lacks concrete evidence for the claimed savings."
            },
            {
              "language": "fa",
              "text": "گزارش برای صرفه‌جویی‌های ادعاشده فاقد شواهد مشخص است."
            },
            {
              "language": "kmr",
              "text": "Rapor ji bo teserûfên hatine îdîakirin bê delîlên konkret e."
            },
            {
              "language": "pl",
              "text": "Raportowi brakuje konkretnych dowodów na deklarowane oszczędności."
            },
            {
              "language": "ro",
              "text": "Raportului îi lipsesc dovezi concrete pentru economiile pretinse."
            },
            {
              "language": "ru",
              "text": "В отчете не хватает конкретных доказательств заявленной экономии."
            },
            {
              "language": "sq",
              "text": "Raportit i mungojnë prova konkrete për kursimet e pretenduara."
            },
            {
              "language": "tr",
              "text": "Raporda iddia edilen tasarruflara ilişkin somut kanıt eksik."
            }
          ]
        },
        {
          "baseText": "In der Diskussion gebrach es weniger an Ideen als an einer klaren Priorisierung.",
          "translations": [
            {
              "language": "ar",
              "text": "في النقاش لم تكن الأفكار هي الناقصة بقدر ما كان ينقص ترتيب واضح للأولويات."
            },
            {
              "language": "ckb",
              "text": "لە گفتوگۆکەدا کەمتر بیرۆکە کەم بوو، زیاتر ئەولەویەتدانێکی ڕوون کەم بوو."
            },
            {
              "language": "en",
              "text": "In the discussion, there was less a lack of ideas than a lack of clear prioritization."
            },
            {
              "language": "fa",
              "text": "در بحث، کمبود بیشتر از جنس اولویت‌بندی روشن بود تا کمبود ایده."
            },
            {
              "language": "kmr",
              "text": "Di nîqaşê de kêmtiya fikirên nû nebû, lê kêmtiya rêzkirina pêşengiyan a zelal hebû."
            },
            {
              "language": "pl",
              "text": "W dyskusji brakowało mniej pomysłów, a bardziej jasnej priorytetyzacji."
            },
            {
              "language": "ro",
              "text": "În discuție lipseau mai puțin ideile și mai mult o prioritizare clară."
            },
            {
              "language": "ru",
              "text": "В обсуждении не столько не хватало идей, сколько четкой расстановки приоритетов."
            },
            {
              "language": "sq",
              "text": "Në diskutim mungonin më pak idetë sesa një prioritizim i qartë."
            },
            {
              "language": "tr",
              "text": "Tartışmada fikirden çok net bir önceliklendirme eksikti."
            }
          ]
        }
      ]
    },
    {
      "word": "gedeihen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "gedeihen",
      "pronunciationIpa": null,
      "syllableBreak": "ge-dei-hen",
      "topics": [
        "environment-and-sustainability",
        "management-and-leadership",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: gedeiht, gedieh, ist gediehen; used literally and figuratively"
      ],
      "collocations": [
        {
          "text": "unter guten Bedingungen gedeihen",
          "meaning": "to thrive under good conditions"
        },
        {
          "text": "eine Kultur gedeiht",
          "meaning": "a culture flourishes"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Gedeihen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يزدهر؛ ينمو جيدًا"
        },
        {
          "language": "ckb",
          "text": "گەشە دەکات؛ باش پەرە دەسێنێت"
        },
        {
          "language": "en",
          "text": "to thrive; to flourish"
        },
        {
          "language": "fa",
          "text": "رشد کردن؛ شکوفا شدن"
        },
        {
          "language": "kmr",
          "text": "geş bûn; baş pêş ketin"
        },
        {
          "language": "pl",
          "text": "rozwijać się; rozkwitać"
        },
        {
          "language": "ro",
          "text": "a prospera; a se dezvolta bine"
        },
        {
          "language": "ru",
          "text": "процветать; хорошо развиваться"
        },
        {
          "language": "sq",
          "text": "të lulëzosh; të zhvillohesh mirë"
        },
        {
          "language": "tr",
          "text": "gelişmek; serpilmek"
        }
      ],
      "examples": [
        {
          "baseText": "Eine offene Fehlerkultur gedeiht nur, wenn Führungskräfte Kritik nicht bestrafen.",
          "translations": [
            {
              "language": "ar",
              "text": "لا تزدهر ثقافة أخطاء منفتحة إلا إذا لم يعاقب القادة النقد."
            },
            {
              "language": "ckb",
              "text": "کولتوری هەڵەی کراوە تەنها کاتێک گەشە دەکات کە بەڕێوەبەرەکان ڕەخنە سزا نەدەن."
            },
            {
              "language": "en",
              "text": "An open error culture thrives only when managers do not punish criticism."
            },
            {
              "language": "fa",
              "text": "فرهنگ باز برخورد با خطا فقط وقتی شکوفا می‌شود که مدیران انتقاد را تنبیه نکنند."
            },
            {
              "language": "kmr",
              "text": "Kultura xeletiyên vekirî tenê hingê geş dibe ku rêveber rexneyê ceza nekin."
            },
            {
              "language": "pl",
              "text": "Otwarta kultura błędów rozwija się tylko wtedy, gdy menedżerowie nie karzą krytyki."
            },
            {
              "language": "ro",
              "text": "O cultură deschisă a erorilor prosperă doar dacă managerii nu pedepsesc critica."
            },
            {
              "language": "ru",
              "text": "Открытая культура ошибок процветает только тогда, когда руководители не наказывают критику."
            },
            {
              "language": "sq",
              "text": "Një kulturë e hapur gabimesh lulëzon vetëm kur drejtuesit nuk e ndëshkojnë kritikën."
            },
            {
              "language": "tr",
              "text": "Açık bir hata kültürü ancak yöneticiler eleştiriyi cezalandırmadığında gelişir."
            }
          ]
        },
        {
          "baseText": "Die jungen Pflanzen gedeihen in dem schattigen Innenhof überraschend gut.",
          "translations": [
            {
              "language": "ar",
              "text": "تنمو النباتات الصغيرة في الفناء الظليل بشكل جيد على نحو مفاجئ."
            },
            {
              "language": "ckb",
              "text": "ڕووەکە گەنجەکان لە حەوشەی سێبەرداردا بە شێوەیەکی سەرسوڕهێنەر باش گەشە دەکەن."
            },
            {
              "language": "en",
              "text": "The young plants are thriving surprisingly well in the shady courtyard."
            },
            {
              "language": "fa",
              "text": "گیاهان جوان در حیاط سایه‌دار به‌طرز شگفت‌آوری خوب رشد می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Şînên ciwan di hewşa siya de bi awayekî ecêb baş geş dibin."
            },
            {
              "language": "pl",
              "text": "Młode rośliny zaskakująco dobrze rosną na zacienionym dziedzińcu."
            },
            {
              "language": "ro",
              "text": "Plantele tinere se dezvoltă surprinzător de bine în curtea umbrită."
            },
            {
              "language": "ru",
              "text": "Молодые растения удивительно хорошо растут в тенистом дворе."
            },
            {
              "language": "sq",
              "text": "Bimët e reja po zhvillohen çuditërisht mirë në oborrin me hije."
            },
            {
              "language": "tr",
              "text": "Genç bitkiler gölgeli avluda şaşırtıcı derecede iyi gelişiyor."
            }
          ]
        }
      ]
    },
    {
      "word": "gegenläufig",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ge-gen-läu-fig",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes opposite or contrary movements/developments"
      ],
      "collocations": [
        {
          "text": "gegenläufige Trends",
          "meaning": "opposing trends"
        },
        {
          "text": "gegenläufige Effekte",
          "meaning": "counteracting effects"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gegenlaufen",
          "relationLabel": "verb",
          "note": "less common related verb"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متعاكس؛ يسير في اتجاه مخالف"
        },
        {
          "language": "ckb",
          "text": "پێچەوانە؛ لە ئاراستەی دژدا"
        },
        {
          "language": "en",
          "text": "opposing; contrary; moving in the opposite direction"
        },
        {
          "language": "fa",
          "text": "متضاد؛ خلاف‌جهت؛ معکوس"
        },
        {
          "language": "kmr",
          "text": "berovajî; di arasteya dijber de"
        },
        {
          "language": "pl",
          "text": "przeciwny; rozbieżny"
        },
        {
          "language": "ro",
          "text": "contrar; divergent"
        },
        {
          "language": "ru",
          "text": "противоположный; разнонаправленный"
        },
        {
          "language": "sq",
          "text": "i kundërt; në drejtim të kundërt"
        },
        {
          "language": "tr",
          "text": "ters yönlü; karşıt"
        }
      ],
      "examples": [
        {
          "baseText": "Die Daten zeigen zwei gegenläufige Trends: mehr Bestellungen, aber sinkende Warenkörbe.",
          "translations": [
            {
              "language": "ar",
              "text": "تُظهر البيانات اتجاهين متعاكسين: طلبات أكثر، لكن سلال شراء أصغر."
            },
            {
              "language": "ckb",
              "text": "داتاکان دوو ئاراستەی پێچەوانە پیشان دەدەن: داواکاری زیاتر، بەڵام سەبەتەی کڕینی کەمتر."
            },
            {
              "language": "en",
              "text": "The data show two opposing trends: more orders but smaller baskets."
            },
            {
              "language": "fa",
              "text": "داده‌ها دو روند متضاد را نشان می‌دهند: سفارش‌های بیشتر، اما سبد خرید کوچک‌تر."
            },
            {
              "language": "kmr",
              "text": "Dane du rêgezên dijber nîşan didin: fermanên zêdetir, lê sepetên kirînê biçûktir."
            },
            {
              "language": "pl",
              "text": "Dane pokazują dwa przeciwstawne trendy: więcej zamówień, ale mniejsze koszyki."
            },
            {
              "language": "ro",
              "text": "Datele arată două tendințe contrare: mai multe comenzi, dar coșuri mai mici."
            },
            {
              "language": "ru",
              "text": "Данные показывают два противоположных тренда: больше заказов, но меньшие корзины."
            },
            {
              "language": "sq",
              "text": "Të dhënat tregojnë dy prirje të kundërta: më shumë porosi, por shporta më të vogla."
            },
            {
              "language": "tr",
              "text": "Veriler iki ters yönlü eğilim gösteriyor: daha fazla sipariş, ancak daha küçük sepetler."
            }
          ]
        },
        {
