      "meanings": [
        {
          "language": "ar",
          "text": "إضافة أو خصم"
        },
        {
          "language": "ckb",
          "text": "زیادکردن یان کەمکردنەوە"
        },
        {
          "language": "en",
          "text": "surcharge or deduction"
        },
        {
          "language": "fa",
          "text": "افزایش یا کسر قیمت"
        },
        {
          "language": "kmr",
          "text": "zêdekirin an kêmkirin"
        },
        {
          "language": "pl",
          "text": "dopłata lub potrącenie"
        },
        {
          "language": "ro",
          "text": "supliment sau reducere"
        },
        {
          "language": "ru",
          "text": "надбавка или вычет"
        },
        {
          "language": "sq",
          "text": "shtesë ose zbritje"
        },
        {
          "language": "tr",
          "text": "ek ücret veya indirim"
        }
      ],
      "examples": [
        {
          "baseText": "Der Zu-/Abschlag wird im ERP auf der Rechnungsposition separat ausgewiesen.",
          "translations": [
            {
              "language": "ar",
              "text": "تُعرض الإضافة أو الخصم في ERP بشكل منفصل في بند الفاتورة."
            },
            {
              "language": "ckb",
              "text": "زیادکردن یان کەمکردنەوە لە ERP دا لەسەر بڕگەی فاکتورە بە جیا نیشان دەدرێت."
            },
            {
              "language": "en",
              "text": "The surcharge or deduction is shown separately in the ERP on the invoice line item."
            },
            {
              "language": "fa",
              "text": "افزایش یا کسر قیمت در ERP روی ردیف فاکتور جداگانه نمایش داده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Zêdekirin an kêmkirin di ERP de li ser hêla fatûreyê cuda tê nîşandan."
            },
            {
              "language": "pl",
              "text": "Dopłata lub potrącenie jest w ERP wykazywane osobno na pozycji faktury."
            },
            {
              "language": "ro",
              "text": "Suplimentul sau reducerea este afișat separat în ERP pe poziția facturii."
            },
            {
              "language": "ru",
              "text": "Надбавка или вычет отдельно отображается в ERP в позиции счета."
            },
            {
              "language": "sq",
              "text": "Shtesa ose zbritja shfaqet veçmas në ERP në pozicionin e faturës."
            },
            {
              "language": "tr",
              "text": "Ek ücret veya indirim ERP’de fatura kaleminde ayrı gösterilir."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie den Zu-/Abschlag, bevor das Angebot an den Kunden gesendet wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى فحص الإضافة أو الخصم قبل إرسال العرض إلى العميل."
            },
            {
              "language": "ckb",
              "text": "تکایە زیادکردن یان کەمکردنەوەکە بپشکنن پێش ئەوەی پێشنیارەکە بۆ کڕیار بنێردرێت."
            },
            {
              "language": "en",
              "text": "Please check the surcharge or deduction before the quotation is sent to the customer."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از ارسال پیشنهاد قیمت برای مشتری، افزایش یا کسر قیمت را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe zêdekirin an kêmkirinê kontrol bikin berî ku pêşniyar ji mişterî re were şandin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić dopłatę lub potrącenie przed wysłaniem oferty do klienta."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați suplimentul sau reducerea înainte ca oferta să fie trimisă clientului."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте надбавку или вычет до отправки предложения клиенту."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni shtesën ose zbritjen para se oferta t’i dërgohet klientit."
            },
            {
              "language": "tr",
              "text": "Teklif müşteriye gönderilmeden önce lütfen ek ücreti veya indirimi kontrol edin."
            }
          ]
        }
      ]
    }
  ],
