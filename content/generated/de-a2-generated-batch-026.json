            {
              "language": "en",
              "text": "The doctor gives me a prescription."
            },
            {
              "language": "fa",
              "text": "دکتر به من نسخه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Doktor reçeteyekê dide min."
            },
            {
              "language": "pl",
              "text": "Doktor daje mi receptę."
            },
            {
              "language": "ro",
