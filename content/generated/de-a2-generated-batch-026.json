    {
      "word": "die Direktorin",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Direktorinnen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Di-rek-to-rin",
      "topics": [
        "education-and-training",
        "work-and-jobs",
        "management-and-leadership"
      ],
      "usageLabels": [
        "written",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun: die Direktorin, die Direktorinnen"
      ],
      "collocations": [
        {
          "text": "die Direktorin der Schule",
          "meaning": "the school principal"
        },
        {
          "text": "mit der Direktorin sprechen",
          "meaning": "to speak with the director"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Direktor",
          "relationLabel": "noun",
          "note": "male director/principal"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مديرة؛ مديرة المدرسة"
        },
        {
          "language": "ckb",
          "text": "بەڕێوەبەری ژن؛ سەرۆکی قوتابخانە"
        },
        {
          "language": "en",
          "text": "female director; principal"
        },
        {
          "language": "fa",
          "text": "مدیر زن؛ رئیس مدرسه زن"
        },
        {
          "language": "kmr",
          "text": "rêvebera jin; müdîra jin"
        },
        {
          "language": "pl",
          "text": "dyrektorka"
        },
        {
          "language": "ro",
          "text": "directoare"
        },
        {
          "language": "ru",
          "text": "директор-женщина"
        },
        {
          "language": "sq",
          "text": "drejtoreshë"
        },
        {
          "language": "tr",
          "text": "kadın müdür; direktör"
        }
      ],
      "examples": [
        {
          "baseText": "Die Direktorin begrüßt die neuen Schüler.",
          "translations": [
            {
              "language": "ar",
              "text": "ترحب المديرة بالطلاب الجدد."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەرە ژنەکە بەخێرهاتنی قوتابییە نوێیەکان دەکات."
            },
            {
              "language": "en",
              "text": "The principal welcomes the new students."
            },
            {
              "language": "fa",
              "text": "مدیر از دانش‌آموزان جدید استقبال می‌کند."
            },
            {
              "language": "kmr",
              "text": "Müdîr xêrhatina xwendekarên nû dike."
            },
            {
              "language": "pl",
              "text": "Dyrektorka wita nowych uczniów."
            },
            {
              "language": "ro",
              "text": "Directoarea îi întâmpină pe noii elevi."
            },
            {
              "language": "ru",
              "text": "Директор приветствует новых учеников."
            },
            {
              "language": "sq",
              "text": "Drejtoresha mirëpret nxënësit e rinj."
            },
            {
              "language": "tr",
              "text": "Kadın müdür yeni öğrencileri karşılıyor."
            }
          ]
        },
        {
          "baseText": "Meine Mutter hat einen Termin bei der Direktorin.",
          "translations": [
            {
              "language": "ar",
              "text": "لدى أمي موعد مع المديرة."
            },
            {
              "language": "ckb",
              "text": "دایکم کاتی لەگەڵ بەڕێوەبەرە ژنەکە هەیە."
            },
            {
              "language": "en",
              "text": "My mother has an appointment with the principal."
            },
            {
              "language": "fa",
              "text": "مادرم با مدیر وقت ملاقات دارد."
            },
            {
              "language": "kmr",
              "text": "Dayika min bi müdîrê re wext heye."
            },
            {
              "language": "pl",
              "text": "Moja mama ma spotkanie z dyrektorką."
            },
            {
              "language": "ro",
              "text": "Mama mea are o programare la directoare."
            },
            {
              "language": "ru",
              "text": "У моей мамы встреча с директором."
            },
            {
              "language": "sq",
              "text": "Nëna ime ka takim me drejtoreshën."
            },
            {
              "language": "tr",
              "text": "Annemin kadın müdürle randevusu var."
            }
          ]
        }
      ]
    },
    {
      "word": "der Discounter",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Discounter",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Dis-coun-ter",
      "topics": [
        "shopping-and-services",
        "everyday-life",
