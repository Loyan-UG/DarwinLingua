      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun: der Discounter, die Discounter"
      ],
      "collocations": [
        {
          "text": "beim Discounter einkaufen",
          "meaning": "to shop at the discount store"
        },
        {
          "text": "ein günstiger Discounter",
          "meaning": "a cheap discount store"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Discount",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متجر تخفيضات؛ سوبرماركت رخيص"
        },
        {
          "language": "ckb",
          "text": "فرۆشگای هەرزان"
        },
        {
          "language": "en",
          "text": "discount store; discounter"
        },
        {
          "language": "fa",
          "text": "فروشگاه تخفیفی؛ فروشگاه ارزان"
        },
        {
          "language": "kmr",
          "text": "firoşgeha erzankirinê"
        },
        {
          "language": "pl",
          "text": "dyskont"
        },
        {
          "language": "ro",
          "text": "magazin discount"
        },
        {
          "language": "ru",
          "text": "дискаунтер; магазин низких цен"
        },
        {
          "language": "sq",
          "text": "dyqan me çmime të ulëta"
        },
        {
          "language": "tr",
          "text": "indirim marketi"
        }
      ],
      "examples": [
        {
          "baseText": "Wir kaufen oft beim Discounter ein.",
          "translations": [
            {
              "language": "ar",
              "text": "نتسوق كثيراً من متجر التخفيضات."
            },
            {
              "language": "ckb",
              "text": "زۆرجار لە فرۆشگای هەرزان دەکڕین."
            },
            {
              "language": "en",
              "text": "We often shop at the discount store."
            },
            {
              "language": "fa",
              "text": "ما اغلب از فروشگاه تخفیفی خرید می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em gelek caran ji firoşgeha erzankirinê dikirin."
            },
            {
              "language": "pl",
              "text": "Często robimy zakupy w dyskoncie."
            },
            {
              "language": "ro",
              "text": "Facem des cumpărături la magazinul discount."
            },
            {
              "language": "ru",
              "text": "Мы часто покупаем в дискаунтере."
            },
            {
              "language": "sq",
              "text": "Shpesh blejmë në dyqanin me çmime të ulëta."
            },
            {
              "language": "tr",
              "text": "Sık sık indirim marketinden alışveriş yaparız."
            }
          ]
        },
        {
          "baseText": "Der Discounter hat diese Woche Obst im Angebot.",
          "translations": [
            {
              "language": "ar",
              "text": "لدى متجر التخفيضات هذا الأسبوع عرض على الفواكه."
            },
            {
              "language": "ckb",
              "text": "فرۆشگای هەرزان ئەم هەفتەیە میوەی بە داشکاندن هەیە."
            },
            {
              "language": "en",
              "text": "The discount store has fruit on offer this week."
            },
            {
              "language": "fa",
              "text": "فروشگاه تخفیفی این هفته میوه در پیشنهاد ویژه دارد."
            },
            {
              "language": "kmr",
              "text": "Firoşgeha erzankirinê vê hefteyê fêkî di pêşniyarê de heye."
            },
            {
              "language": "pl",
              "text": "Dyskont ma w tym tygodniu owoce w promocji."
            },
            {
              "language": "ro",
              "text": "Magazinul discount are fructe la ofertă săptămâna aceasta."
            },
            {
              "language": "ru",
              "text": "В дискаунтере на этой неделе фрукты по акции."
            },
            {
              "language": "sq",
              "text": "Dyqani me çmime të ulëta ka fruta në ofertë këtë javë."
            },
            {
              "language": "tr",
              "text": "İndirim marketinde bu hafta meyve kampanyası var."
            }
          ]
        }
      ]
    },
