      "examples": [
        {
          "baseText": "Ich gehe morgen zum Doktor.",
          "translations": [
            {
              "language": "ar",
              "text": "سأذهب غداً إلى الطبيب."
            },
            {
              "language": "ckb",
              "text": "سبەی دەچم بۆ لای دکتۆر."
            },
            {
              "language": "en",
              "text": "I am going to the doctor tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا به دکتر می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez sibê diçim ba doktor."
            },
            {
              "language": "pl",
