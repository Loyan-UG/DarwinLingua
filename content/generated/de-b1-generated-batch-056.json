        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "طبيبة اختصاصية"
        },
        {
          "language": "ckb",
          "text": "پزیشکی پسپۆڕی ژن"
        },
        {
          "language": "en",
          "text": "female specialist doctor"
        },
        {
          "language": "fa",
          "text": "پزشک متخصص زن"
        },
        {
          "language": "kmr",
          "text": "bijîşka pispor"
        },
        {
          "language": "pl",
          "text": "lekarka specjalistka"
        },
        {
          "language": "ro",
          "text": "medic specialist femeie"
        },
        {
          "language": "ru",
          "text": "врач-специалистка"
        },
        {
          "language": "sq",
          "text": "mjeke specialiste"
        },
        {
          "language": "tr",
          "text": "kadın uzman doktor"
        }
      ],
      "examples": [
        {
          "baseText": "Meine Hausärztin hat mich zu einer Fachärztin überwiesen.",
          "translations": [
            {
              "language": "ar",
              "text": "أحالَتني طبيبة العائلة إلى طبيبة اختصاصية."
            },
            {
              "language": "ckb",
              "text": "پزیشکی خێزانەکەم منی نارد بۆ پزیشکی پسپۆڕی ژن."
            },
            {
              "language": "en",
              "text": "My family doctor referred me to a female specialist."
            },
            {
              "language": "fa",
              "text": "پزشک عمومی‌ام مرا به یک پزشک متخصص زن ارجاع داد."
            },
            {
              "language": "kmr",
              "text": "Bijîşka malbatê min şand cem bijîşkeke pispor."
            },
            {
              "language": "pl",
              "text": "Moja lekarka rodzinna skierowała mnie do lekarki specjalistki."
            },
            {
              "language": "ro",
              "text": "Medicul meu de familie m-a trimis la o medică specialistă."
            },
            {
              "language": "ru",
              "text": "Мой семейный врач направила меня к специалистке."
            },
            {
              "language": "sq",
              "text": "Mjekja ime e familjes më referoi te një mjeke specialiste."
            },
            {
              "language": "tr",
              "text": "Aile doktorum beni kadın bir uzmana sevk etti."
            }
          ]
        },
        {
          "baseText": "Die Fachärztin erklärt die Ergebnisse ruhig und verständlich.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح الطبيبة الاختصاصية النتائج بهدوء وبشكل مفهوم."
            },
            {
              "language": "ckb",
              "text": "پزیشکی پسپۆڕە ژنەکە ئەنجامەکان بە ئارامی و تێگەیشتووانە ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The specialist explains the results calmly and clearly."
            },
            {
              "language": "fa",
              "text": "پزشک متخصص زن نتایج را آرام و قابل فهم توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Bijîşka pispor encaman bi aramî û zelalî şirove dike."
            },
            {
              "language": "pl",
              "text": "Lekarka specjalistka spokojnie i zrozumiale wyjaśnia wyniki."
            },
            {
              "language": "ro",
              "text": "Medica specialistă explică rezultatele calm și clar."
            },
            {
              "language": "ru",
              "text": "Врач-специалистка спокойно и понятно объясняет результаты."
            },
            {
              "language": "sq",
              "text": "Mjekja specialiste i shpjegon rezultatet qetë dhe qartë."
            },
            {
              "language": "tr",
              "text": "Kadın uzman doktor sonuçları sakin ve anlaşılır şekilde açıklar."
            }
          ]
        }
      ]
    },
