  "entries": [
    {
      "word": "anfahren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anfahren",
      "pronunciationIpa": null,
      "syllableBreak": "an-fah-ren",
      "topics": [
        "transport-and-travel",
        "work-and-jobs"
      ],
      "usageLabels": [
        "workplace"
      ],
      "contextLabels": [
        "software"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "الانطلاق؛ الاقتراب"
        },
        {
          "language": "ckb",
          "text": "دەستپێکردن؛ دژوگایەوە"
        },
        {
          "language": "en",
          "text": "to set off; to approach"
        },
        {
          "language": "fa",
          "text": "راه افتادن؛ نزدیک شدن"
        },
        {
          "language": "kmr",
          "text": "dest pêkirin; dur dikirin"
        },
        {
          "language": "pl",
          "text": "wyruszać; podchodzić"
        },
        {
          "language": "ro",
          "text": "a porni; a se apropia"
        },
        {
          "language": "ru",
          "text": "выезжать; подходить"
        },
        {
          "language": "sq",
          "text": "të niset; të afrohet"
        },
        {
          "language": "tr",
          "text": "harekete geçmek; yaklaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Fahrer darf vor dem Werksportal erst anfahren, wenn die Schranke geöffnet ist.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يحق للسائق أن يبدأ بالتحرك أمام بوابة المصنع إلا بعد فتح الحاجز."
            },
            {
              "language": "ckb",
              "text": "شوێنگەران هیچ کات نابێت پێش کردنەوەی دەرگاکە پێشبەکەیەک دەست پێبکات."
            },
            {
              "language": "en",
              "text": "The driver may only start moving forward before the factory gate when the barrier is open."
            },
            {
              "language": "fa",
              "text": "راننده فقط وقتی مانع باز باشد می‌تواند جلوی دروازه کارخانه حرکت کند."
            },
            {
              "language": "kmr",
              "text": "Ajokar tenê dema dergê vexteye piştî vê derket, êdî dibe ku dest pê bike."
            },
            {
              "language": "pl",
              "text": "Kierowca może ruszyć dopiero przed bramą zakładu, gdy zapora jest otwarta."
            },
            {
              "language": "ro",
              "text": "Șoferul poate porni numai înainte de poarta fabricii, când bariera este deschisă."
            },
            {
              "language": "ru",
              "text": "Водитель может начать движение только перед воротами завода, когда шлагбаум открыт."
            },
            {
              "language": "sq",
              "text": "Shoferi mund të nisë para portës së fabrikës vetëm pasi pengesa është hapur."
            },
            {
              "language": "tr",
              "text": "Şoför, fabrika kapısının önünde bariyer açıldığında ancak ilerlemeye başlayabilir."
            }
          ]
        },
        {
          "baseText": "Nach einem Stromausfall fuhr der Server nach dem Neustart sofort erneut an.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد انقطاع الكهرباء، بدأ الخادم بالعمل مرة أخرى فور إعادة التشغيل."
            },
            {
              "language": "ckb",
              "text": "دوای قوڵدانی کارەگا خزمەتگوزاری پاشەکەوتەوەی نوێ دووبارە خاستەکارە."
            },
            {
              "language": "en",
              "text": "After a power outage, the server started up again immediately after rebooting."
            },
            {
              "language": "fa",
              "text": "بعد از قطع برق، پس از راه‌اندازی مجدد، سرور دوباره روشن شد."
            },
            {
              "language": "kmr",
              "text": "Piştî kêmkirina elektrikê, server piştî destpêkirina nû zû vegerî çalak bû."
            },
            {
              "language": "pl",
              "text": "Po zaniku prądu, serwer ponownie uruchomił się natychmiast po restarcie."
            },
            {
              "language": "ro",
              "text": "După o pană de curent, serverul a pornit din nou imediat după repornire."
            },
            {
              "language": "ru",
              "text": "После отключения электричества сервер сразу же снова запустился после перезапуска."
            },
            {
              "language": "sq",
              "text": "Pas ndërprerjes së energjisë, serveri u riaktivizua menjëherë pas rinisjes."
            },
            {
              "language": "tr",
              "text": "Elektrik kesintisinden sonra sunucu, yeniden başlatma sonrası hemen tekrar açıldı."
            }
          ]
        }
      ]
    },
    {
      "word": "anfallen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anfallen",
      "pronunciationIpa": null,
      "syllableBreak": "an-fal-len",
      "topics": [
        "finance-and-accounting",
        "work-and-jobs",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business"
      ],
      "contextLabels": [
        "risk"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ينشأ، يسبب إضافية"
        },
        {
          "language": "ckb",
          "text": "هەنگاوەوە دەبێت؛ زیادە دەکات"
        },
        {
          "language": "en",
          "text": "to arise; to be incurred"
        },
        {
          "language": "fa",
          "text": "به‌وجود آمدن؛ تحمیل شدن/تحمیل هزینه"
        },
        {
          "language": "kmr",
          "text": "berdewam dibe; zêde bibe"
        },
        {
          "language": "pl",
          "text": "powstać; pojawić się"
        },
        {
          "language": "ro",
          "text": "a surveni; a apărea"
        },
        {
          "language": "ru",
          "text": "возникать; возникать дополнительные затраты"
        },
        {
          "language": "sq",
          "text": "të ndodhë; të shtohet"
        },
        {
          "language": "tr",
          "text": "ortaya çıkmak; ek maliyetin doğması"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn der Scope nicht exakt stimmt, fallen zusätzliche Tests und Kosten an.",
          "translations": [
            {
              "language": "ar",
              "text": "اگر دامنه کار دقیق نباشد، آزمون‌ها و هزینه‌های اضافی به‌وجود می‌آیند."
            },
            {
              "language": "ckb",
              "text": "ئەگەر سنوڕەکە بە دروشمی نەبێت، تاقیکردنەوە و توێژینەوەی زیادە دەرئەچێت."
            },
            {
              "language": "en",
              "text": "If the scope is not exact, additional testing and costs are incurred."
            },
            {
              "language": "fa",
              "text": "اگر دامنه کار دقیق نباشد، تست‌ و هزینه‌های اضافه متحمل می‌شویم."
            },
            {
              "language": "kmr",
              "text": "Heke qada kar ne bi awayek qelew nebe, ceribandin û mesûliyetên zêde derbînin."
            },
            {
              "language": "pl",
              "text": "Jeśli zakres nie jest precyzyjny, pojawiają się dodatkowe testy i koszty."
            },
            {
              "language": "ro",
              "text": "Dacă domeniul de lucru nu este precis, apar teste și costuri suplimentare."
            },
            {
              "language": "ru",
              "text": "Если объем работ не определен точно, возникают дополнительные тесты и расходы."
            },
            {
              "language": "sq",
              "text": "Nëse fushëveprimi nuk është i saktë, dalin jashtë teste dhe kosto shtesë."
            },
            {
              "language": "tr",
              "text": "Kapsam net değilse, ek testler ve maliyetler ortaya çıkar."
            }
          ]
        },
        {
          "baseText": "Aufgrund der kurzfristigen Änderung fallen im Projekt zwei zusätzliche Review-Tage an.",
          "translations": [
            {
              "language": "ar",
              "text": "به دلیل تغییرات فوری، در پروژه دو روز بازبینی اضافه لازم می‌شود."
            },
            {
              "language": "ckb",
              "text": "به‌هۆی گۆڕانی کورتەکانەوە لە پرۆژەدا دوو ڕۆژی پێداویستی زیادە دەبەستێت."
            },
            {
              "language": "en",
              "text": "Due to the short-notice change, two additional review days are incurred in the project."
            },
            {
              "language": "fa",
              "text": "به دلیل تغییر فوری، در پروژه دو روز بازبینی اضافه می‌افتد."
            },
            {
              "language": "kmr",
              "text": "Ji ber guhertina berkem de di projeyan de du rojekî binkarî zêde dibin."
            },
            {
              "language": "pl",
              "text": "Z powodu nagłej zmiany w projekcie powstaną dwa dodatkowe dni przeglądu."
            },
            {
              "language": "ro",
              "text": "Din cauza modificării de ultim moment, în proiect apar două zile suplimentare de revizuire."
            },
            {
              "language": "ru",
              "text": "Из-за срочного изменения в проекте возникают два дополнительных дня проверки."
            },
            {
              "language": "sq",
              "text": "Për shkak të ndryshimit afatshkurt, në projekt dalin dy ditë shtesë kontrolli."
            },
            {
              "language": "tr",
              "text": "Kısa sürede yapılan değişiklik nedeniyle projede iki ek inceleme günü doğar."
            }
          ]
        }
      ]
    },
