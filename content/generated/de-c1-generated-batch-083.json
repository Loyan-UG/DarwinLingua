  "entries": [
    {
      "word": "die Partizipationsform",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Partizipationsformen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Par-ti-zi-pa-ti-ons-form",
      "topics": [
        "public-services",
        "management-and-leadership",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "geeignete Partizipationsformen auswählen",
          "meaning": "to choose suitable forms of participation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Partizipation",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Form",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شكل من أشكال المشاركة"
        },
        {
          "language": "ckb",
          "text": "شێوەی بەشداری"
        },
        {
          "language": "en",
          "text": "form of participation"
        },
        {
          "language": "fa",
          "text": "شکل مشارکت"
        },
        {
          "language": "kmr",
          "text": "forma beşdariyê"
        },
        {
          "language": "pl",
          "text": "forma partycypacji"
        },
        {
          "language": "ro",
          "text": "formă de participare"
        },
        {
          "language": "ru",
          "text": "форма участия"
        },
        {
          "language": "sq",
          "text": "formë pjesëmarrjeje"
        },
        {
          "language": "tr",
          "text": "katılım biçimi"
        }
      ],
      "examples": [
        {
          "baseText": "Für Jugendliche sind digitale Partizipationsformen oft zugänglicher als klassische Bürgerversammlungen.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة إلى الشباب تكون أشكال المشاركة الرقمية غالباً أسهل وصولاً من اجتماعات المواطنين التقليدية."
            },
            {
              "language": "ckb",
              "text": "بۆ گەنجان شێوە دیجیتاڵەکانی بەشداری زۆرجار دەستپێگەیشتوتروون لە کۆبوونەوەی هاووڵاتیانی کلاسیکی."
            },
            {
              "language": "en",
              "text": "For young people, digital forms of participation are often more accessible than traditional citizens’ meetings."
            },
            {
              "language": "fa",
              "text": "برای جوانان، شکل‌های دیجیتال مشارکت اغلب از نشست‌های سنتی شهروندان دسترس‌پذیرترند."
            },
            {
              "language": "kmr",
              "text": "Ji bo ciwanan formên dîjîtal ên beşdariyê gelek caran ji civînên klasîk ên welatiyan hêsantir têne gihîştin."
            },
            {
              "language": "pl",
              "text": "Dla młodzieży cyfrowe formy partycypacji są często bardziej dostępne niż tradycyjne zebrania obywatelskie."
            },
            {
              "language": "ro",
              "text": "Pentru tineri, formele digitale de participare sunt adesea mai accesibile decât adunările cetățenești clasice."
            },
            {
              "language": "ru",
              "text": "Для молодежи цифровые формы участия часто доступнее традиционных собраний граждан."
            },
            {
              "language": "sq",
              "text": "Për të rinjtë, format digjitale të pjesëmarrjes janë shpesh më të arritshme se mbledhjet klasike qytetare."
            },
            {
              "language": "tr",
              "text": "Gençler için dijital katılım biçimleri çoğu zaman klasik yurttaş toplantılarından daha erişilebilirdir."
            }
          ]
        },
        {
          "baseText": "Im Unternehmen wurde eine neue Partizipationsform getestet, bei der Mitarbeitende anonym Vorschläge priorisieren.",
          "translations": [
            {
              "language": "ar",
              "text": "في الشركة جُرّب شكل جديد من المشاركة يحدد فيه الموظفون أولويات المقترحات بشكل مجهول."
            },
            {
              "language": "ckb",
              "text": "لە کۆمپانیاکەدا شێوەیەکی نوێی بەشداری تاقیکرایەوە کە تێیدا کارمەندان بە ناونەناس پێشنیارەکان پێشخستن."
            },
            {
              "language": "en",
              "text": "The company tested a new form of participation in which employees anonymously prioritize proposals."
            },
            {
              "language": "fa",
              "text": "در شرکت شکل جدیدی از مشارکت آزمایش شد که در آن کارکنان پیشنهادها را ناشناس اولویت‌بندی می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Di şîrketê de forma nû ya beşdariyê hate ceribandin ku tê de karmend bi nenav pêşniyaran pêş dixin."
            },
            {
              "language": "pl",
              "text": "W firmie przetestowano nową formę partycypacji, w której pracownicy anonimowo priorytetyzują propozycje."
            },
            {
              "language": "ro",
              "text": "În companie a fost testată o nouă formă de participare în care angajații prioritizează anonim propunerile."
            },
            {
              "language": "ru",
              "text": "В компании протестировали новую форму участия, при которой сотрудники анонимно приоритизируют предложения."
            },
            {
              "language": "sq",
              "text": "Në kompani u testua një formë e re pjesëmarrjeje ku punonjësit i japin përparësi propozimeve në mënyrë anonime."
            },
            {
              "language": "tr",
              "text": "Şirkette çalışanların önerileri anonim olarak önceliklendirdiği yeni bir katılım biçimi test edildi."
            }
          ]
        }
      ]
    },
    {
      "word": "die Pathogenese",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Pathogenesen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Pa-tho-ge-ne-se",
      "topics": [
        "healthcare-and-appointments",
        "advanced-analysis",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; medical term"
      ],
      "collocations": [
        {
          "text": "die Pathogenese einer Erkrankung untersuchen",
          "meaning": "to investigate the pathogenesis of a disease"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "pathogen",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نشوء المرض؛ تطور المرض"
        },
        {
          "language": "ckb",
          "text": "دروستبوونی نەخۆشی؛ گەشەی نەخۆشی"
        },
        {
          "language": "en",
          "text": "pathogenesis; development of a disease"
        },
        {
          "language": "fa",
          "text": "بیماری‌زایی؛ روند پیدایش بیماری"
        },
        {
          "language": "kmr",
          "text": "pathogenez; pêşketina nexweşiyê"
        },
        {
          "language": "pl",
          "text": "patogeneza"
        },
        {
          "language": "ro",
          "text": "patogeneză"
        },
        {
          "language": "ru",
          "text": "патогенез"
        },
        {
          "language": "sq",
          "text": "patogjenezë"
        },
        {
          "language": "tr",
          "text": "patogenez"
        }
      ],
      "examples": [
        {
          "baseText": "Die Pathogenese der Erkrankung ist komplex und bisher nur teilweise verstanden.",
          "translations": [
            {
              "language": "ar",
              "text": "نشوء المرض معقد ولم يُفهم حتى الآن إلا جزئياً."
            },
            {
              "language": "ckb",
              "text": "دروستبوونی نەخۆشییەکە ئاڵۆزە و تا ئێستا تەنها بەشێکی تێگەیشتراوە."
            },
            {
              "language": "en",
              "text": "The pathogenesis of the disease is complex and so far only partly understood."
            },
            {
              "language": "fa",
              "text": "روند پیدایش این بیماری پیچیده است و تاکنون فقط بخشی از آن فهمیده شده است."
            },
            {
              "language": "kmr",
              "text": "Pathogeneza nexweşiyê tevlihev e û heta niha tenê beşek jê hatiye fêmkirin."
            },
            {
              "language": "pl",
              "text": "Patogeneza choroby jest złożona i jak dotąd tylko częściowo poznana."
            },
            {
              "language": "ro",
              "text": "Patogeneza bolii este complexă și până acum doar parțial înțeleasă."
            },
            {
              "language": "ru",
              "text": "Патогенез заболевания сложен и пока понят лишь частично."
            },
            {
              "language": "sq",
              "text": "Patogjeneza e sëmundjes është komplekse dhe deri tani vetëm pjesërisht e kuptuar."
            },
            {
              "language": "tr",
              "text": "Hastalığın patogenezi karmaşıktır ve şu ana kadar yalnızca kısmen anlaşılmıştır."
            }
          ]
        },
        {
          "baseText": "Im Seminar wurde die Pathogenese anhand eines klinischen Fallbeispiels erklärt.",
          "translations": [
            {
              "language": "ar",
              "text": "في الندوة شُرح نشوء المرض باستخدام مثال سريري."
            },
            {
              "language": "ckb",
              "text": "لە سیمینارەکەدا دروستبوونی نەخۆشی بە نموونەیەکی کلینیکی ڕوونکرایەوە."
            },
            {
              "language": "en",
              "text": "In the seminar, the pathogenesis was explained using a clinical case example."
            },
            {
              "language": "fa",
              "text": "در سمینار، بیماری‌زایی با استفاده از یک نمونه بالینی توضیح داده شد."
            },
            {
              "language": "kmr",
              "text": "Di semînerê de pathogenez bi mînakeke klînîkî hate ravekirin."
            },
            {
              "language": "pl",
              "text": "Na seminarium patogenezę wyjaśniono na podstawie przykładu klinicznego."
            },
            {
              "language": "ro",
              "text": "La seminar, patogeneza a fost explicată printr-un exemplu clinic."
            },
            {
              "language": "ru",
              "text": "На семинаре патогенез объяснили на клиническом примере."
            },
            {
              "language": "sq",
              "text": "Në seminar, patogjeneza u shpjegua me një shembull klinik."
            },
            {
              "language": "tr",
              "text": "Seminerde patogenez klinik bir vaka örneğiyle açıklandı."
            }
          ]
        }
      ]
    },
