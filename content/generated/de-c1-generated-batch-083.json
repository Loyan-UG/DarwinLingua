        }
      ],
      "examples": [
        {
          "baseText": "Der Artikel wurde erst nach einer anonymen Peer-Review zur Veröffentlichung angenommen.",
          "translations": [
            {
              "language": "ar",
              "text": "قُبل المقال للنشر فقط بعد مراجعة أقران مجهولة."
            },
            {
              "language": "ckb",
              "text": "وتارەکە تەنها دوای پێداچوونەوەی هاوتای ناونەناس بۆ بڵاوکردنەوە پەسەند کرا."
            },
            {
              "language": "en",
              "text": "The article was accepted for publication only after an anonymous peer review."
            },
