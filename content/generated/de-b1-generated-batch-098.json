  "entries": [
    {
      "word": "näherkommen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "näherkommen",
      "pronunciationIpa": null,
      "syllableBreak": "nä-her-kom-men",
      "topics": [
        "social-and-relationships",
        "business-communication",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: kommt näher, kam näher, nähergekommen"
      ],
      "collocations": [
        {
          "text": "dem Ziel näherkommen",
          "meaning": "to get closer to the goal"
        },
        {
          "text": "sich langsam näherkommen",
          "meaning": "to slowly get closer to each other"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "nah",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "kommen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقترب؛ يصبح أقرب"
        },
        {
          "language": "ckb",
          "text": "نزیکتر دەبێتەوە"
        },
        {
          "language": "en",
          "text": "to get closer; to approach"
        },
        {
          "language": "fa",
          "text": "نزدیک‌تر شدن؛ نزدیک شدن"
        },
        {
          "language": "kmr",
          "text": "nêzîktir bûn"
        },
        {
          "language": "pl",
          "text": "zbliżać się"
        },
        {
          "language": "ro",
          "text": "a se apropia"
        },
        {
          "language": "ru",
          "text": "приближаться; становиться ближе"
        },
        {
          "language": "sq",
          "text": "të afrohesh"
        },
        {
          "language": "tr",
          "text": "yaklaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Mit jedem Test kommen wir der Lösung näher.",
          "translations": [
            {
              "language": "ar",
              "text": "مع كل اختبار نقترب أكثر من الحل."
            },
            {
              "language": "ckb",
              "text": "بە هەر تاقیکردنەوەیەک زیاتر لە چارەسەرەکە نزیک دەبینەوە."
            },
            {
              "language": "en",
              "text": "With every test, we get closer to the solution."
            },
            {
              "language": "fa",
              "text": "با هر تست، به راه‌حل نزدیک‌تر می‌شویم."
            },
            {
              "language": "kmr",
              "text": "Bi her testê em zêdetir nêzî çareseriyê dibin."
            },
            {
              "language": "pl",
              "text": "Z każdym testem zbliżamy się do rozwiązania."
            },
            {
              "language": "ro",
              "text": "Cu fiecare test ne apropiem de soluție."
            },
            {
              "language": "ru",
              "text": "С каждым тестом мы приближаемся к решению."
            },
            {
              "language": "sq",
              "text": "Me çdo test afrohemi më shumë me zgjidhjen."
            },
            {
              "language": "tr",
              "text": "Her testle çözüme daha çok yaklaşıyoruz."
            }
          ]
        },
        {
          "baseText": "Nach ein paar Gesprächen sind sich die Nachbarn nähergekommen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد عدة أحاديث أصبح الجيران أقرب إلى بعضهم."
            },
            {
              "language": "ckb",
              "text": "دوای چەند گفتوگۆیەک دراوسێکان لە یەکتر نزیکتر بوونەوە."
            },
            {
              "language": "en",
              "text": "After a few conversations, the neighbors became closer."
            },
            {
              "language": "fa",
              "text": "بعد از چند گفت‌وگو، همسایه‌ها به هم نزدیک‌تر شدند."
            },
            {
              "language": "kmr",
              "text": "Piştî çend axaftinan cîran nêzî hev bûn."
            },
            {
              "language": "pl",
              "text": "Po kilku rozmowach sąsiedzi zbliżyli się do siebie."
            },
            {
              "language": "ro",
              "text": "După câteva discuții, vecinii s-au apropiat."
            },
            {
              "language": "ru",
              "text": "После нескольких разговоров соседи стали ближе друг к другу."
            },
            {
              "language": "sq",
              "text": "Pas disa bisedave, fqinjët u afruan më shumë."
            },
            {
              "language": "tr",
              "text": "Birkaç konuşmadan sonra komşular birbirine daha yakın oldu."
            }
          ]
        }
      ]
    },
    {
      "word": "nähertreten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "nähertreten",
      "pronunciationIpa": null,
      "syllableBreak": "nä-her-tre-ten",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "polite",
        "spoken",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: tritt näher, trat näher, nähergetreten; often formal in the phrase einer Person oder Sache näher treten"
      ],
      "collocations": [
        {
          "text": "dem Vorschlag nähertreten",
          "meaning": "to consider the proposal more closely"
        },
        {
          "text": "bitte näher treten",
          "meaning": "please step closer"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "nah",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "treten",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقترب؛ يتناول أمرًا بجدية أكبر"
        },
        {
          "language": "ckb",
          "text": "نزیکتر دەبێتەوە؛ بە بابەتێک زیاتر دەچێتە ناوەوە"
        },
        {
          "language": "en",
          "text": "to step closer; to consider something more closely"
        },
        {
          "language": "fa",
          "text": "نزدیک‌تر شدن؛ جدی‌تر بررسی کردن"
        },
        {
          "language": "kmr",
          "text": "nêzîktir hatin; tiştekî hûrtir nirxandin"
        },
        {
          "language": "pl",
          "text": "podejść bliżej; rozważyć coś bliżej"
        },
        {
          "language": "ro",
          "text": "a se apropia; a analiza mai atent"
        },
        {
          "language": "ru",
          "text": "подойти ближе; рассмотреть подробнее"
        },
        {
          "language": "sq",
          "text": "të afrohesh; ta shqyrtosh më nga afër"
        },
        {
          "language": "tr",
          "text": "yaklaşmak; bir şeyi daha yakından değerlendirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte treten Sie näher, damit ich Ihre Nummer besser lesen kann.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الاقتراب لكي أستطيع قراءة رقمك بشكل أفضل."
            },
            {
              "language": "ckb",
              "text": "تکایە نزیکتر ببنەوە بۆ ئەوەی ژمارەکەتان باشتر بخوێنم."
            },
            {
              "language": "en",
              "text": "Please step closer so I can read your number better."
            },
            {
              "language": "fa",
              "text": "لطفاً نزدیک‌تر بیایید تا شماره شما را بهتر بخوانم."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe nêzîktir werin da ku ez hejmara we baştir bixwînim."
            },
            {
              "language": "pl",
              "text": "Proszę podejść bliżej, żebym mógł lepiej odczytać państwa numer."
            },
            {
              "language": "ro",
              "text": "Vă rog să vă apropiați ca să pot citi mai bine numărul."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, подойдите ближе, чтобы я мог лучше прочитать ваш номер."
            },
            {
              "language": "sq",
              "text": "Ju lutem afrohuni që ta lexoj më mirë numrin tuaj."
            },
            {
              "language": "tr",
              "text": "Numaranızı daha iyi okuyabilmem için lütfen yaklaşın."
            }
          ]
        },
        {
          "baseText": "Wir können dem Vorschlag näher treten, wenn die Kosten klar sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكننا النظر في الاقتراح بجدية أكبر عندما تكون التكاليف واضحة."
            },
            {
              "language": "ckb",
              "text": "دەتوانین زیاتر بچینە ناو پێشنیارەکە کاتێک تێچوونەکان ڕوون بن."
            },
            {
              "language": "en",
              "text": "We can consider the proposal more closely once the costs are clear."
            },
            {
              "language": "fa",
              "text": "وقتی هزینه‌ها روشن شد، می‌توانیم پیشنهاد را جدی‌تر بررسی کنیم."
            },
            {
              "language": "kmr",
              "text": "Heke lêçûn zelal bin, em dikarin pêşniyarê hûrtir binirxînin."
            },
            {
              "language": "pl",
              "text": "Możemy bliżej rozważyć propozycję, gdy koszty będą jasne."
            },
            {
              "language": "ro",
              "text": "Putem analiza propunerea mai atent când costurile sunt clare."
            },
            {
              "language": "ru",
              "text": "Мы можем подробнее рассмотреть предложение, когда будут ясны расходы."
            },
            {
              "language": "sq",
              "text": "Mund ta shqyrtojmë propozimin më nga afër kur kostot të jenë të qarta."
            },
            {
              "language": "tr",
              "text": "Maliyetler netleştiğinde teklifi daha yakından değerlendirebiliriz."
            }
          ]
        }
      ]
    },
    {
      "word": "nämlich",
