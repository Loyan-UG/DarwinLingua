  "entries": [
    {
      "word": "das Gespräch",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Gespräche",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ge-spräch",
      "topics": [
        "business-communication",
        "work-and-jobs",
