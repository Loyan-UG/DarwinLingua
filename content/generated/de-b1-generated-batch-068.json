      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مذكرة محادثة؛ ملاحظة عن Gespräch"
        },
        {
          "language": "ckb",
          "text": "تێبینی گفتوگۆ؛ یادداشتی گفتوگۆ"
        },
        {
          "language": "en",
          "text": "conversation note; call note"
        },
        {
          "language": "fa",
          "text": "یادداشت گفت‌وگو؛ صورت‌جلسه کوتاه مکالمه"
        },
        {
          "language": "kmr",
          "text": "têbîniya axaftinê; notên gotûbêjê"
        },
        {
          "language": "pl",
          "text": "notatka z rozmowy"
        },
        {
          "language": "ro",
          "text": "notă de discuție; notă de conversație"
        },
        {
          "language": "ru",
          "text": "заметка о разговоре; запись беседы"
        },
        {
          "language": "sq",
          "text": "shënim bisede"
        },
        {
          "language": "tr",
          "text": "görüşme notu; konuşma notu"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte legen Sie nach dem Telefonat eine Gesprächsnotiz im CRM an.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إنشاء مذكرة محادثة في نظام CRM بعد المكالمة."
            },
            {
              "language": "ckb",
              "text": "تکایە دوای تەلەفۆنەکە تێبینی گفتوگۆیەک لە CRM زیاد بکەن."
            },
            {
              "language": "en",
              "text": "Please create a conversation note in the CRM after the phone call."
            },
            {
              "language": "fa",
              "text": "لطفاً بعد از تماس تلفنی یک یادداشت گفت‌وگو در CRM ثبت کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe piştî telefonê têbîniyek axaftinê di CRM de çêkin."
            },
            {
              "language": "pl",
              "text": "Proszę po rozmowie telefonicznej utworzyć notatkę z rozmowy w CRM."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să creați după apel o notă de discuție în CRM."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, после звонка создайте заметку о разговоре в CRM."
            },
            {
              "language": "sq",
              "text": "Ju lutemi, pas telefonatës krijoni një shënim bisede në CRM."
            },
            {
              "language": "tr",
              "text": "Lütfen telefon görüşmesinden sonra CRM’de bir görüşme notu oluşturun."
            }
          ]
        },
        {
          "baseText": "Die Gesprächsnotiz hilft uns, die nächste Beratung gut vorzubereiten.",
          "translations": [
            {
              "language": "ar",
              "text": "تساعدنا مذكرة المحادثة على التحضير الجيد للاستشارة التالية."
            },
            {
              "language": "ckb",
              "text": "تێبینی گفتوگۆکە یارمەتیمان دەدات ڕاوێژکاریی داهاتوو باش ئامادە بکەین."
            },
            {
              "language": "en",
              "text": "The conversation note helps us prepare the next consultation well."
            },
            {
              "language": "fa",
              "text": "یادداشت گفت‌وگو به ما کمک می‌کند مشاوره بعدی را خوب آماده کنیم."
            },
            {
              "language": "kmr",
              "text": "Têbîniya axaftinê alî me dike ku şêwirmendiya din baş amade bikin."
            },
            {
              "language": "pl",
              "text": "Notatka z rozmowy pomaga nam dobrze przygotować kolejną konsultację."
