      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; a conversation or discussion"
      ],
      "collocations": [
        {
          "text": "ein Gespräch führen",
          "meaning": "to have a conversation"
        },
        {
          "text": "ein vertrauliches Gespräch",
          "meaning": "a confidential conversation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sprechen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Gesprächsnotiz",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "محادثة؛ نقاش"
        },
        {
          "language": "ckb",
          "text": "گفتوگۆ؛ قسەکردن"
        },
        {
          "language": "en",
          "text": "conversation; discussion"
        },
        {
          "language": "fa",
          "text": "گفت‌وگو؛ مکالمه"
        },
        {
          "language": "kmr",
          "text": "axaftin; gotûbêj"
        },
        {
          "language": "pl",
          "text": "rozmowa; dyskusja"
        },
        {
          "language": "ro",
          "text": "conversație; discuție"
        },
        {
          "language": "ru",
          "text": "разговор; беседа"
        },
        {
          "language": "sq",
          "text": "bisedë; diskutim"
        },
        {
          "language": "tr",
          "text": "görüşme; konuşma"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Gespräch mit dem Kunden kennen wir seine Anforderungen besser.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد المحادثة مع العميل نعرف متطلباته بشكل أفضل."
            },
            {
              "language": "ckb",
              "text": "دوای گفتوگۆ لەگەڵ کڕیارەکە، داواکارییەکانی باشتر دەزانین."
            },
            {
              "language": "en",
              "text": "After the conversation with the customer, we understand his requirements better."
            },
            {
              "language": "fa",
              "text": "بعد از گفت‌وگو با مشتری، نیازهای او را بهتر می‌شناسیم."
            },
            {
              "language": "kmr",
              "text": "Piştî axaftina bi xerîdar re, em daxwazên wî çêtir nas dikin."
            },
            {
              "language": "pl",
              "text": "Po rozmowie z klientem lepiej znamy jego wymagania."
            },
            {
              "language": "ro",
              "text": "După discuția cu clientul, îi cunoaștem mai bine cerințele."
            },
            {
              "language": "ru",
              "text": "После разговора с клиентом мы лучше понимаем его требования."
            },
            {
              "language": "sq",
              "text": "Pas bisedës me klientin, i njohim më mirë kërkesat e tij."
            },
            {
              "language": "tr",
              "text": "Müşteriyle görüşmeden sonra gereksinimlerini daha iyi biliyoruz."
            }
          ]
        },
        {
          "baseText": "Ich möchte das Gespräch lieber persönlich führen.",
          "translations": [
            {
              "language": "ar",
              "text": "أفضل أن أجري المحادثة شخصياً."
            },
            {
              "language": "ckb",
              "text": "پێم باشترە گفتوگۆکە ڕووبەڕوو بکەم."
            },
            {
              "language": "en",
              "text": "I would rather have the conversation in person."
            },
            {
              "language": "fa",
              "text": "ترجیح می‌دهم این گفت‌وگو را حضوری انجام دهم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim vê axaftinê çêtir rû bi rû bikim."
            },
            {
              "language": "pl",
              "text": "Wolałbym przeprowadzić tę rozmowę osobiście."
            },
            {
              "language": "ro",
              "text": "Aș prefera să port această discuție personal."
            },
            {
              "language": "ru",
              "text": "Я бы предпочёл провести этот разговор лично."
            },
            {
              "language": "sq",
              "text": "Do të preferoja ta bëja këtë bisedë personalisht."
            },
            {
              "language": "tr",
              "text": "Bu görüşmeyi yüz yüze yapmayı tercih ederim."
            }
          ]
        }
      ]
    },
