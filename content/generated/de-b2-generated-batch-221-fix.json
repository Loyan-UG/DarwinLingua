      "meanings": [
        {
          "language": "ar",
          "text": "مدى؛ نطاق الوصول؛ مسافة التشغيل"
        },
        {
          "language": "ckb",
          "text": "مەودا؛ گەیشتن؛ توانای گەیشتن"
        },
        {
          "language": "en",
          "text": "reach; range"
        },
        {
          "language": "fa",
          "text": "برد؛ دامنه دسترسی؛ میزان دسترسی"
        },
        {
          "language": "kmr",
          "text": "gihîştin; mesafe; berfirehî"
        },
        {
          "language": "pl",
          "text": "zasięg; zasięg działania"
        },
        {
          "language": "ro",
          "text": "rază de acțiune; acoperire"
        },
        {
          "language": "ru",
          "text": "охват; дальность; радиус действия"
        },
        {
          "language": "sq",
          "text": "shtrirje; rreze veprimi; arritje"
        },
        {
          "language": "tr",
          "text": "erişim; menzil; kapsama"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kampagne hatte eine hohe Reichweite, aber nur wenige Nutzer haben sich registriert.",
          "translations": [
            {
              "language": "ar",
              "text": "حققت الحملة وصولاً واسعاً، لكن عدداً قليلاً فقط من المستخدمين سجّلوا."
            },
            {
              "language": "ckb",
              "text": "کەمپەینەکە گەیشتنێکی بەرزی هەبوو، بەڵام تەنها بەکارهێنەرێکی کەم خۆیان تۆمار کرد."
            },
            {
              "language": "en",
              "text": "The campaign had a high reach, but only a few users registered."
            },
            {
              "language": "fa",
              "text": "کمپین دسترسی بالایی داشت، اما فقط تعداد کمی از کاربران ثبت‌نام کردند."
            },
            {
              "language": "kmr",
              "text": "Kampanyayê gihîştineke bilind hebû, lê tenê çend bikarhêneran xwe qeyd kirin."
            },
            {
              "language": "pl",
              "text": "Kampania miała duży zasięg, ale tylko niewielu użytkowników się zarejestrowało."
            },
            {
              "language": "ro",
              "text": "Campania a avut o acoperire mare, dar doar puțini utilizatori s-au înregistrat."
            },
            {
              "language": "ru",
              "text": "У кампании был большой охват, но зарегистрировались лишь немногие пользователи."
            },
            {
              "language": "sq",
              "text": "Fushata pati shtrirje të madhe, por vetëm pak përdorues u regjistruan."
            },
            {
              "language": "tr",
              "text": "Kampanyanın erişimi yüksekti, ancak yalnızca az sayıda kullanıcı kayıt oldu."
            }
          ]
        },
        {
          "baseText": "Bei kaltem Wetter sinkt die Reichweite des Elektroautos oft spürbar.",
          "translations": [
            {
              "language": "ar",
              "text": "في الطقس البارد ينخفض مدى السيارة الكهربائية غالباً بشكل ملحوظ."
            },
            {
              "language": "ckb",
              "text": "لە کەشی سارددا مەودای ئۆتۆمبێلی کارەبایی زۆرجار بە شێوەیەکی هەستپێکراو کەم دەبێتەوە."
            },
            {
              "language": "en",
              "text": "In cold weather, the range of an electric car often drops noticeably."
            },
            {
              "language": "fa",
              "text": "در هوای سرد، برد خودروی برقی اغلب به‌طور محسوس کاهش می‌یابد."
            },
            {
              "language": "kmr",
              "text": "Di hewaya sar de, mesafeya erebeya elektrîkê gelek caran bi awayekî xuya kêm dibe."
            },
            {
              "language": "pl",
              "text": "W zimną pogodę zasięg samochodu elektrycznego często wyraźnie spada."
            },
            {
              "language": "ro",
              "text": "Pe vreme rece, autonomia mașinii electrice scade adesea vizibil."
            },
            {
              "language": "ru",
              "text": "В холодную погоду запас хода электромобиля часто заметно снижается."
            },
            {
              "language": "sq",
              "text": "Në mot të ftohtë, autonomia e makinës elektrike shpesh bie dukshëm."
            },
            {
              "language": "tr",
              "text": "Soğuk havada elektrikli aracın menzili çoğu zaman belirgin şekilde düşer."
            }
          ]
        }
      ]
    }
