      "grammarNotes": [
        "past participle used as adjective"
      ],
      "collocations": [
        {
          "text": "der Auftrag ist abgeschlossen",
          "meaning": "the order is completed"
        },
        {
          "text": "abgeschlossene Aufgabe",
          "meaning": "completed task"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "abschließen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "مكتمل؛ منتهٍ"
        },
        {
          "language": "ckb",
          "text": "تەواوبوو؛ داخراو"
        },
        {
          "language": "en",
          "text": "completed; finished"
        },
        {
          "language": "fa",
          "text": "کامل‌شده؛ تمام‌شده"
        },
        {
          "language": "kmr",
          "text": "qediya; temam bûyî"
        },
        {
          "language": "pl",
          "text": "zakończony; ukończony"
        },
        {
          "language": "ro",
          "text": "finalizat; încheiat"
        },
        {
          "language": "ru",
          "text": "завершенный"
        },
        {
          "language": "sq",
          "text": "i përfunduar"
        },
        {
          "language": "tr",
          "text": "tamamlanmış; bitmiş"
        }
      ],
      "examples": [
        {
          "baseText": "Der Auftrag ist im ERP-System abgeschlossen.",
          "translations": [
            {
              "language": "ar",
              "text": "الطلب مكتمل في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "داواکارییەکە لە سیستەمی ERPدا تەواوبووە."
            },
            {
              "language": "en",
              "text": "The order is completed in the ERP system."
            },
            {
              "language": "fa",
              "text": "سفارش در سیستم ERP تکمیل شده است."
            },
            {
              "language": "kmr",
              "text": "Fermariş di pergala ERP de qediya ye."
            },
            {
              "language": "pl",
              "text": "Zamówienie jest zakończone w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Comanda este finalizată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Заказ завершен в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Porosia është përfunduar në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Sipariş ERP sisteminde tamamlandı."
            }
          ]
        },
        {
          "baseText": "Der Kurs ist jetzt abgeschlossen.",
          "translations": [
            {
              "language": "ar",
              "text": "الدورة انتهت الآن."
            },
            {
              "language": "ckb",
              "text": "کۆرسەکە ئێستا تەواو بووە."
            },
            {
              "language": "en",
              "text": "The course is finished now."
            },
            {
              "language": "fa",
              "text": "دوره اکنون تمام شده است."
            },
            {
              "language": "kmr",
              "text": "Kurs niha qediya ye."
            },
            {
              "language": "pl",
              "text": "Kurs jest teraz zakończony."
            },
            {
              "language": "ro",
              "text": "Cursul este acum finalizat."
            },
            {
              "language": "ru",
              "text": "Курс теперь завершен."
            },
            {
              "language": "sq",
              "text": "Kursi tani ka përfunduar."
            },
            {
              "language": "tr",
              "text": "Kurs artık tamamlandı."
            }
          ]
        }
      ]
    },
