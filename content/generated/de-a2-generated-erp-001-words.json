      "examples": [
        {
          "baseText": "Die Ware ist im Lager bereitgestellt.",
          "translations": [
            {
              "language": "ar",
              "text": "البضاعة جاهزة في المستودع."
            },
            {
              "language": "ckb",
              "text": "کاڵاکە لە کۆگادا ئامادەکراوە."
