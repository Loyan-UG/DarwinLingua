      ],
      "usageLabels": [
        "business",
        "technical"
      ],
      "grammarNotes": [
        "prepositional phrase"
      ],
      "collocations": [
        {
          "text": "auf Karte anzeigen",
          "meaning": "to show on a map"
        },
        {
          "text": "auf der Karte suchen",
          "meaning": "to search on the map"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Karte",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "على الخريطة"
        },
        {
          "language": "ckb",
          "text": "لەسەر نەخشە"
        },
        {
          "language": "en",
          "text": "on the map"
        },
        {
          "language": "fa",
          "text": "روی نقشه"
        },
        {
          "language": "kmr",
          "text": "li ser nexşeyê"
        },
        {
          "language": "pl",
          "text": "na mapie"
        },
        {
          "language": "ro",
          "text": "pe hartă"
        },
        {
          "language": "ru",
          "text": "на карте"
        },
        {
          "language": "sq",
          "text": "në hartë"
        },
        {
          "language": "tr",
          "text": "haritada"
        }
      ],
      "examples": [
        {
          "baseText": "Die Adresse wird im ERP-System auf Karte angezeigt.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم عرض العنوان في نظام تخطيط موارد المؤسسة على الخريطة."
            },
            {
              "language": "ckb",
              "text": "ناونیشانەکە لە سیستەمی ERPدا لەسەر نەخشە پیشان دەدرێت."
            },
            {
              "language": "en",
              "text": "The address is shown on the map in the ERP system."
            },
            {
              "language": "fa",
              "text": "آدرس در سیستم ERP روی نقشه نمایش داده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Navnîşan di pergala ERP de li ser nexşeyê tê nîşandan."
            },
            {
              "language": "pl",
              "text": "Adres jest pokazany na mapie w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Adresa este afișată pe hartă în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Адрес отображается на карте в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Adresa shfaqet në hartë në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Adres ERP sisteminde haritada gösterilir."
            }
          ]
        },
        {
          "baseText": "Kannst du das Hotel auf Karte zeigen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك إظهار الفندق على الخريطة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت هۆتێلەکە لەسەر نەخشە پیشان بدەیت؟"
            },
            {
              "language": "en",
              "text": "Can you show the hotel on the map?"
            },
            {
              "language": "fa",
              "text": "می‌توانی هتل را روی نقشه نشان بدهی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî hotelê li ser nexşeyê nîşan bidî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz pokazać hotel na mapie?"
            },
            {
              "language": "ro",
              "text": "Poți arăta hotelul pe hartă?"
            },
            {
              "language": "ru",
              "text": "Можешь показать отель на карте?"
            },
            {
              "language": "sq",
              "text": "A mund ta tregosh hotelin në hartë?"
            },
            {
              "language": "tr",
              "text": "Oteli haritada gösterebilir misin?"
            }
          ]
        }
      ]
    },
