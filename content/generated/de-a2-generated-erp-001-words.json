            {
              "language": "en",
              "text": "The goods are ready in the warehouse."
            },
            {
              "language": "fa",
              "text": "کالا در انبار آماده شده است."
            },
            {
              "language": "kmr",
              "text": "Mal di embarê de amade ye."
            },
            {
              "language": "pl",
