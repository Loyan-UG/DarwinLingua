            {
              "language": "en",
              "text": "The file is now available for everyone."
            },
            {
              "language": "fa",
              "text": "فایل اکنون برای همه فراهم شده است."
            },
            {
              "language": "kmr",
              "text": "Pel niha ji bo hemûyan amade ye."
            },
            {
              "language": "pl",
              "text": "Plik jest teraz udostępniony wszystkim."
            },
            {
              "language": "ro",
              "text": "Fișierul este acum disponibil pentru toți."
            },
            {
              "language": "ru",
              "text": "Файл теперь доступен всем."
            },
            {
              "language": "sq",
              "text": "Skedari tani është i disponueshëm për të gjithë."
