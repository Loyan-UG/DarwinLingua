          "text": "مراقب بودن؛ توجه کردن"
        },
        {
          "language": "kmr",
          "text": "baldar bûn; miqate bûn"
        },
        {
          "language": "pl",
          "text": "uważać; pilnować"
        },
        {
          "language": "ro",
          "text": "a fi atent; a avea grijă"
        },
        {
          "language": "ru",
          "text": "быть внимательным; присматривать"
        },
        {
          "language": "sq",
          "text": "të kesh kujdes; të vëzhgosh"
        },
        {
          "language": "tr",
          "text": "dikkat etmek; göz kulak olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte passen Sie auf der Treppe auf.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الانتباه على الدرج."
            },
            {
              "language": "ckb",
              "text": "تکایە لەسەر پلەکان ئاگادار بن."
            },
            {
              "language": "en",
              "text": "Please be careful on the stairs."
            },
            {
              "language": "fa",
              "text": "لطفاً روی پله‌ها مراقب باشید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li ser derenceyan baldar bin."
            },
            {
              "language": "pl",
              "text": "Proszę uważać na schodach."
            },
            {
              "language": "ro",
              "text": "Vă rog să fiți atent pe scări."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, будьте осторожны на лестнице."
            },
            {
              "language": "sq",
              "text": "Ju lutem kini kujdes në shkallë."
            },
            {
              "language": "tr",
              "text": "Lütfen merdivenlerde dikkat edin."
            }
          ]
        },
        {
          "baseText": "Kannst du kurz auf mein Kind aufpassen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك الاعتناء بطفلي قليلاً؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت کەمێک چاودێری منداڵەکەم بکەیت؟"
            },
            {
              "language": "en",
              "text": "Can you watch my child for a moment?"
            },
            {
              "language": "fa",
              "text": "می‌توانی کمی مراقب بچه‌ام باشی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî demek kurt miqateyê zarokê min bî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz chwilę popilnować mojego dziecka?"
            },
            {
              "language": "ro",
              "text": "Poți să ai grijă puțin de copilul meu?"
            },
            {
              "language": "ru",
              "text": "Можешь немного присмотреть за моим ребенком?"
            },
            {
              "language": "sq",
              "text": "A mund të kujdesesh pak për fëmijën tim?"
            },
            {
              "language": "tr",
              "text": "Biraz çocuğuma göz kulak olabilir misin?"
            }
          ]
        }
      ]
