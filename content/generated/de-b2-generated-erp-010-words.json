  "entries": [
    {
      "word": "Folgeartikel",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Folgeartikel",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fol-ge-ar-ti-kel",
      "topics": [
        "erp-and-business-systems",
        "warehouse-and-logistics",
        "sales-and-customers"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical",
        "process"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; article that follows or replaces another item in a process"
      ],
      "collocations": [
        {
          "text": "einen Folgeartikel hinterlegen",
          "meaning": "to store a follow-up item"
        },
        {
          "text": "den Folgeartikel vorschlagen",
          "meaning": "to suggest the follow-up item"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "folgen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Artikel",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "صنف لاحق؛ بديل لاحق"
        },
        {
          "language": "ckb",
          "text": "ماددەی دواتر؛ کاڵای جێگرەوە"
        },
        {
          "language": "en",
          "text": "follow-up item; successor item"
        },
        {
          "language": "fa",
          "text": "کالای بعدی؛ کالای جایگزین بعدی"
        },
        {
          "language": "kmr",
          "text": "babetê şopîner"
        },
        {
          "language": "pl",
          "text": "artykuł następczy"
        },
        {
          "language": "ro",
          "text": "articol următor; articol succesor"
        },
        {
          "language": "ru",
          "text": "последующий товар; товар-заменитель"
        },
        {
          "language": "sq",
          "text": "artikull pasues"
        },
        {
          "language": "tr",
          "text": "takip ürün; ardıl ürün"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn der alte Artikel ausläuft, schlägt das ERP automatisch den Folgeartikel vor.",
          "translations": [
            {
              "language": "ar",
              "text": "عندما يتوقف الصنف القديم، يقترح ERP تلقائيًا الصنف اللاحق."
            },
            {
              "language": "ckb",
              "text": "کاتێک ماددەی کۆن کۆتایی دێت، ERP خۆکارانە ماددەی دواتر پێشنیار دەکات."
            },
            {
              "language": "en",
              "text": "When the old item is discontinued, the ERP automatically suggests the follow-up item."
            },
            {
              "language": "fa",
              "text": "وقتی کالای قدیمی از رده خارج شود، ERP به‌صورت خودکار کالای بعدی را پیشنهاد می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Dema babetê kevn bidawî bibe, ERP xweber babetê şopîner pêşniyar dike."
            },
            {
              "language": "pl",
              "text": "Gdy stary artykuł zostaje wycofany, ERP automatycznie proponuje artykuł następczy."
            },
            {
              "language": "ro",
              "text": "Când articolul vechi este scos din uz, ERP propune automat articolul succesor."
            },
            {
              "language": "ru",
              "text": "Когда старый товар снимается с продажи, ERP автоматически предлагает последующий товар."
            },
            {
              "language": "sq",
              "text": "Kur artikulli i vjetër del nga përdorimi, ERP sugjeron automatikisht artikullin pasues."
            },
            {
              "language": "tr",
              "text": "Eski ürün kullanımdan kalktığında ERP otomatik olarak takip ürünü önerir."
            }
          ]
        },
        {
          "baseText": "Der Vertrieb informierte den Kunden, dass der Folgeartikel dieselbe Funktion hat.",
          "translations": [
            {
              "language": "ar",
              "text": "أبلغ قسم المبيعات العميل بأن الصنف اللاحق له الوظيفة نفسها."
            },
            {
              "language": "ckb",
              "text": "بەشی فرۆشتن کڕیاری ئاگادار کردەوە کە ماددەی دواتر هەمان کارایی هەیە."
            },
            {
              "language": "en",
              "text": "Sales informed the customer that the follow-up item has the same function."
            },
            {
              "language": "fa",
              "text": "واحد فروش به مشتری اطلاع داد که کالای بعدی همان عملکرد را دارد."
            },
            {
              "language": "kmr",
              "text": "Firotanê mişterî agahdar kir ku babetê şopîner heman fonksiyonê heye."
            },
            {
              "language": "pl",
              "text": "Dział sprzedaży poinformował klienta, że artykuł następczy ma tę samą funkcję."
            },
            {
              "language": "ro",
              "text": "Vânzările au informat clientul că articolul succesor are aceeași funcție."
            },
            {
              "language": "ru",
              "text": "Отдел продаж сообщил клиенту, что последующий товар выполняет ту же функцию."
            },
            {
              "language": "sq",
              "text": "Shitjet e informuan klientin se artikulli pasues ka të njëjtin funksion."
            },
            {
              "language": "tr",
              "text": "Satış ekibi müşteriye takip ürünün aynı işleve sahip olduğunu bildirdi."
            }
          ]
        }
      ]
    },
    {
      "word": "Fremdkonto",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Fremdkonten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fremd-kon-to",
      "topics": [
        "finance-and-accounting",
        "erp-and-business-systems",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "administrative",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter compound noun; external or third-party account, often in accounting interfaces"
      ],
      "collocations": [
        {
          "text": "ein Fremdkonto zuordnen",
          "meaning": "to assign an external account"
        },
        {
          "text": "das Fremdkonto prüfen",
          "meaning": "to check the external account"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fremd",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "das Konto",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "حساب خارجي"
        },
        {
          "language": "ckb",
          "text": "هەژماری دەرەکی"
        },
        {
          "language": "en",
          "text": "external account; third-party account"
        },
        {
          "language": "fa",
          "text": "حساب خارجی؛ حساب طرف دیگر"
        },
        {
          "language": "kmr",
          "text": "hesabê derveyî"
        },
        {
          "language": "pl",
          "text": "konto zewnętrzne"
        },
        {
          "language": "ro",
          "text": "cont extern"
        },
        {
          "language": "ru",
          "text": "внешний счет"
        },
        {
          "language": "sq",
          "text": "llogari e jashtme"
        },
        {
          "language": "tr",
          "text": "harici hesap"
        }
      ],
      "examples": [
        {
          "baseText": "Das Fremdkonto muss im ERP korrekt zugeordnet sein, sonst schlägt die Schnittstelle fehl.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب تعيين الحساب الخارجي بشكل صحيح في ERP، وإلا ستفشل الواجهة."
            },
            {
              "language": "ckb",
              "text": "پێویستە هەژماری دەرەکی لە ERP دا بە دروستی دابنرێت، ئەگەر نا ڕووکاری پەیوەندی شکست دەهێنێت."
            },
            {
              "language": "en",
              "text": "The external account must be assigned correctly in the ERP, otherwise the interface fails."
            },
            {
              "language": "fa",
              "text": "حساب خارجی باید در ERP درست تخصیص داده شود، وگرنه رابط سیستم خطا می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Hesabê derveyî divê di ERP de rast were girêdan, wekî din navbeynkar têk diçe."
            },
            {
              "language": "pl",
              "text": "Konto zewnętrzne musi być poprawnie przypisane w ERP, inaczej interfejs zakończy się błędem."
            },
            {
              "language": "ro",
              "text": "Contul extern trebuie alocat corect în ERP, altfel interfața eșuează."
            },
            {
              "language": "ru",
              "text": "Внешний счет должен быть правильно сопоставлен в ERP, иначе интерфейс завершится ошибкой."
            },
            {
              "language": "sq",
              "text": "Llogaria e jashtme duhet të caktohet saktë në ERP, përndryshe ndërfaqja dështon."
            },
            {
              "language": "tr",
              "text": "Harici hesap ERP’de doğru atanmalıdır, aksi halde arayüz hata verir."
            }
          ]
        },
        {
          "baseText": "Die Buchhaltung klärt mit der Bank, warum das Fremdkonto nicht mehr aktiv ist.",
          "translations": [
            {
              "language": "ar",
              "text": "توضح المحاسبة مع البنك سبب عدم نشاط الحساب الخارجي بعد الآن."
            },
            {
              "language": "ckb",
              "text": "ژمێریاری لەگەڵ بانک ڕوون دەکاتەوە بۆچی هەژماری دەرەکی چیتر چالاک نییە."
            },
            {
              "language": "en",
              "text": "Accounting clarifies with the bank why the external account is no longer active."
            },
            {
              "language": "fa",
              "text": "حسابداری با بانک بررسی می‌کند چرا حساب خارجی دیگر فعال نیست."
            },
            {
              "language": "kmr",
              "text": "Hesabdarî bi bankê re zelal dike çima hesabê derveyî êdî neçalak e."
            },
            {
              "language": "pl",
              "text": "Księgowość wyjaśnia z bankiem, dlaczego konto zewnętrzne nie jest już aktywne."
            },
            {
              "language": "ro",
              "text": "Contabilitatea clarifică cu banca de ce contul extern nu mai este activ."
            },
            {
              "language": "ru",
              "text": "Бухгалтерия выясняет с банком, почему внешний счет больше не активен."
            },
            {
              "language": "sq",
              "text": "Kontabiliteti sqaron me bankën pse llogaria e jashtme nuk është më aktive."
            },
            {
              "language": "tr",
              "text": "Muhasebe, harici hesabın neden artık aktif olmadığını bankayla netleştiriyor."
            }
          ]
        }
      ]
    },
