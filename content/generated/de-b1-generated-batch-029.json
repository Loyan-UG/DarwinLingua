      ],
      "grammarNotes": [
        "masculine noun",
        "means area, field, department, or section"
      ],
      "collocations": [
        {
          "text": "im technischen Bereich",
          "meaning": "in the technical field"
        },
        {
          "text": "für diesen Bereich zuständig sein",
          "meaning": "to be responsible for this area"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bereichsübergreifend",
          "relationLabel": "adjective",
          "note": "cross-departmental"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مجال؛ قسم؛ منطقة"
        },
        {
          "language": "ckb",
          "text": "بوار؛ بەش؛ ناوچە"
        },
        {
          "language": "en",
          "text": "area; field; section"
        },
        {
          "language": "fa",
          "text": "حوزه؛ بخش؛ محدوده"
        },
        {
          "language": "kmr",
          "text": "qad; war; beş"
        },
        {
          "language": "pl",
          "text": "obszar; dziedzina"
        },
        {
          "language": "ro",
          "text": "domeniu; zonă; secțiune"
        },
        {
          "language": "ru",
          "text": "область; сфера; раздел"
        },
        {
          "language": "sq",
          "text": "fushë; sektor; zonë"
        },
        {
          "language": "tr",
          "text": "alan; bölüm; saha"
        }
      ],
      "examples": [
        {
          "baseText": "Für diesen Bereich ist unsere Kollegin aus dem Support zuständig.",
          "translations": [
            {
              "language": "ar",
              "text": "زميلتنا من الدعم مسؤولة عن هذا المجال."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم بوارە هاوکارەکەمان لە پاڵپشتی بەرپرسیارە."
            },
            {
              "language": "en",
              "text": "Our colleague from support is responsible for this area."
            },
            {
              "language": "fa",
              "text": "همکار ما از بخش پشتیبانی مسئول این حوزه است."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê qadê hevkara me ya ji piştgiriyê berpirsiyar e."
            },
            {
              "language": "pl",
              "text": "Za ten obszar odpowiada nasza koleżanka z działu wsparcia."
            },
            {
              "language": "ro",
              "text": "Pentru acest domeniu este responsabilă colega noastră de la suport."
            },
            {
              "language": "ru",
              "text": "За эту область отвечает наша коллега из поддержки."
            },
            {
              "language": "sq",
              "text": "Për këtë fushë është përgjegjëse kolegia jonë nga mbështetja."
            },
            {
              "language": "tr",
              "text": "Bu alandan destek bölümündeki çalışma arkadaşımız sorumlu."
            }
          ]
        },
        {
          "baseText": "Im Bereich Gesundheit gibt es in der Stadt viele neue Angebote.",
          "translations": [
            {
              "language": "ar",
              "text": "في مجال الصحة توجد في المدينة عروض جديدة كثيرة."
            },
            {
              "language": "ckb",
              "text": "لە بواری تەندروستیدا لە شارەکەدا زۆر پێشنیاری نوێ هەیە."
            },
            {
              "language": "en",
              "text": "In the area of health, there are many new services in the city."
            },
            {
              "language": "fa",
              "text": "در حوزه سلامت، خدمات جدید زیادی در شهر وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Di warê tenduristiyê de li bajêr gelek pêşniyarên nû hene."
            },
            {
              "language": "pl",
              "text": "W obszarze zdrowia w mieście jest wiele nowych ofert."
            },
            {
              "language": "ro",
              "text": "În domeniul sănătății există multe servicii noi în oraș."
            },
            {
              "language": "ru",
              "text": "В сфере здоровья в городе есть много новых предложений."
            },
            {
              "language": "sq",
              "text": "Në fushën e shëndetit ka shumë oferta të reja në qytet."
            },
            {
              "language": "tr",
              "text": "Sağlık alanında şehirde birçok yeni hizmet var."
            }
          ]
        }
      ]
    },
