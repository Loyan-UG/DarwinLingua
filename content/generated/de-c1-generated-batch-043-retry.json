      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: erlässt, erließ, hat erlassen; means to issue a rule or waive a debt or fee"
      ],
      "collocations": [
        {
          "text": "eine Verordnung erlassen",
          "meaning": "to issue a regulation"
        },
        {
          "text": "eine Gebühr erlassen",
          "meaning": "to waive a fee"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Erlass",
          "relationLabel": "noun",
          "note": "decree or waiver depending on context"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصدر قانونًا أو قرارًا؛ يعفي من دفع"
        },
        {
          "language": "ckb",
          "text": "بڕیار یان ڕێنمایی دەردەکات؛ پارەدانێک لێ خۆش دەکات"
        },
        {
          "language": "en",
          "text": "to issue; to enact; to waive"
        },
        {
          "language": "fa",
          "text": "صادر کردن؛ وضع کردن؛ بخشیدن بدهی یا هزینه"
        },
        {
          "language": "kmr",
          "text": "derxistin; pejirandin; lêborîn ji dayînê"
        },
        {
          "language": "pl",
          "text": "wydać; uchwalić; umorzyć"
        },
        {
          "language": "ro",
          "text": "a emite; a adopta; a scuti"
        },
        {
          "language": "ru",
          "text": "издавать; принимать; освобождать от уплаты"
        },
        {
          "language": "sq",
          "text": "të nxjerrësh; të miratosh; të falësh pagesë"
        },
        {
          "language": "tr",
          "text": "çıkarmak; yürürlüğe koymak; muaf tutmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Behörde erließ eine neue Richtlinie für die digitale Antragstellung.",
          "translations": [
            {
              "language": "ar",
              "text": "أصدرت الجهة الرسمية توجيهًا جديدًا لتقديم الطلبات رقميًا."
            },
            {
              "language": "ckb",
              "text": "دەزگای فەرمی ڕێنماییەکی نوێی بۆ پێشکەشکردنی داواکاری بە شێوەی دیجیتاڵی دەركرد."
            },
            {
              "language": "en",
              "text": "The authority issued a new guideline for digital applications."
            },
            {
              "language": "fa",
              "text": "اداره دستورالعمل جدیدی برای ثبت درخواست دیجیتال صادر کرد."
            },
            {
              "language": "kmr",
              "text": "Dezgeh rêbernameyeke nû ji bo daxwazên dîjîtal derxist."
            },
            {
              "language": "pl",
              "text": "Urząd wydał nową wytyczną dotyczącą składania wniosków cyfrowo."
            },
            {
              "language": "ro",
              "text": "Autoritatea a emis o nouă directivă pentru depunerea digitală a cererilor."
            },
            {
              "language": "ru",
              "text": "Ведомство издало новое руководство для цифровой подачи заявлений."
            },
            {
              "language": "sq",
              "text": "Autoriteti nxori një udhëzim të ri për paraqitjen digjitale të kërkesave."
            },
            {
              "language": "tr",
              "text": "Kurum dijital başvuru için yeni bir yönerge yayımladı."
            }
          ]
        },
        {
          "baseText": "Bei nachgewiesener Bedürftigkeit kann die Stadt die Verwaltungsgebühr erlassen.",
          "translations": [
            {
              "language": "ar",
              "text": "عند إثبات الحاجة يمكن للمدينة أن تعفي من الرسوم الإدارية."
            },
            {
              "language": "ckb",
              "text": "لە کاتی سەلماندنی پێویستی دارایی، شارەوانی دەتوانێت باجی کارگێڕی لێ خۆش بکات."
            },
            {
              "language": "en",
              "text": "If need is proven, the city can waive the administrative fee."
            },
            {
              "language": "fa",
              "text": "در صورت اثبات نیازمندی، شهر می‌تواند هزینه اداری را ببخشد."
            },
            {
              "language": "kmr",
              "text": "Heke hewcedarî were belgekirin, bajar dikare xerca rêveberiyê bibexşîne."
            },
            {
              "language": "pl",
              "text": "W przypadku udokumentowanej potrzeby miasto może umorzyć opłatę administracyjną."
            },
            {
              "language": "ro",
              "text": "În caz de nevoie dovedită, orașul poate scuti taxa administrativă."
            },
            {
              "language": "ru",
              "text": "При подтвержденной нуждаемости город может освободить от административного сбора."
            },
            {
              "language": "sq",
              "text": "Në rast nevoje të provuar, qyteti mund ta falë tarifën administrative."
            },
            {
              "language": "tr",
              "text": "Kanıtlanmış ihtiyaç durumunda belediye idari ücreti kaldırabilir."
            }
          ]
        }
      ]
    }
  ],
