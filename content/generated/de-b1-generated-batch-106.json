  "entries": [
    {
      "word": "die Preissteigerung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Preissteigerungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Preis-stei-ge-rung",
      "topics": [
        "finance-and-accounting",
        "shopping-and-services",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine starke Preissteigerung",
          "meaning": "a sharp price increase"
        },
        {
          "text": "Preissteigerungen erklären",
          "meaning": "to explain price increases"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Preis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "steigen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ارتفاع الأسعار؛ زيادة السعر"
        },
        {
          "language": "ckb",
          "text": "بەرزبوونەوەی نرخ"
        },
        {
          "language": "en",
          "text": "price increase; rise in prices"
        },
        {
          "language": "fa",
          "text": "افزایش قیمت؛ رشد قیمت‌ها"
        },
        {
          "language": "kmr",
          "text": "bilindbûna bihayê"
        },
        {
          "language": "pl",
          "text": "wzrost cen; podwyżka cen"
        },
        {
          "language": "ro",
          "text": "creștere de preț; scumpire"
        },
        {
          "language": "ru",
          "text": "повышение цен; рост цен"
        },
        {
          "language": "sq",
          "text": "rritje çmimesh"
        },
        {
          "language": "tr",
          "text": "fiyat artışı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Preissteigerung bei Energie macht vielen Firmen Probleme.",
          "translations": [
            {
              "language": "ar",
              "text": "ارتفاع أسعار الطاقة يسبب مشاكل لكثير من الشركات."
            },
            {
              "language": "ckb",
              "text": "بەرزبوونەوەی نرخی وزە کێشە بۆ زۆر کۆمپانیا دروست دەکات."
            },
            {
              "language": "en",
              "text": "The price increase for energy is causing problems for many companies."
            },
            {
              "language": "fa",
              "text": "افزایش قیمت انرژی برای بسیاری از شرکت‌ها مشکل ایجاد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Bilindbûna bihayê enerjiyê ji bo gelek şîrketan pirsgirêk çêdike."
            },
            {
              "language": "pl",
              "text": "Wzrost cen energii sprawia problemy wielu firmom."
            },
            {
              "language": "ro",
              "text": "Creșterea prețurilor la energie creează probleme multor firme."
            },
            {
              "language": "ru",
              "text": "Рост цен на энергию создаёт проблемы многим компаниям."
            },
            {
              "language": "sq",
              "text": "Rritja e çmimit të energjisë u krijon probleme shumë firmave."
            },
            {
              "language": "tr",
              "text": "Enerji fiyatlarındaki artış birçok şirkete sorun yaratıyor."
            }
          ]
        },
        {
          "baseText": "Der Supermarkt erklärt die Preissteigerung mit höheren Transportkosten.",
          "translations": [
            {
              "language": "ar",
              "text": "يفسر السوبرماركت ارتفاع الأسعار بزيادة تكاليف النقل."
            },
            {
              "language": "ckb",
              "text": "سوپەرمارکێتەکە بەرزبوونەوەی نرخ بە تێچووی بەرزی گواستنەوە ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The supermarket explains the price increase with higher transport costs."
            },
            {
              "language": "fa",
              "text": "سوپرمارکت افزایش قیمت را با هزینه‌های بالاتر حمل‌ونقل توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Supermarket bilindbûna bihayê bi lêçûnên bilind ên veguhestinê rave dike."
            },
            {
              "language": "pl",
              "text": "Supermarket tłumaczy wzrost cen wyższymi kosztami transportu."
            },
            {
              "language": "ro",
              "text": "Supermarketul explică scumpirea prin costuri mai mari de transport."
            },
            {
              "language": "ru",
              "text": "Супермаркет объясняет повышение цен более высокими транспортными расходами."
            },
            {
              "language": "sq",
              "text": "Supermarketi e shpjegon rritjen e çmimeve me kosto më të larta transporti."
            },
            {
              "language": "tr",
              "text": "Süpermarket fiyat artışını daha yüksek nakliye maliyetleriyle açıklıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "der Preisvergleich",
      "language": "de",
      "cefrLevel": "B1",
