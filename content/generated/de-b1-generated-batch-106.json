      ],
      "collocations": [
        {
          "text": "einen Preisvergleich machen",
          "meaning": "to compare prices"
        },
        {
          "text": "ein schneller Preisvergleich",
          "meaning": "a quick price comparison"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Preis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "vergleichen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مقارنة الأسعار"
        },
        {
          "language": "ckb",
          "text": "بەراوردی نرخ"
        },
        {
          "language": "en",
          "text": "price comparison"
        },
        {
          "language": "fa",
          "text": "مقایسه قیمت"
        },
        {
          "language": "kmr",
          "text": "berawirdkirina bihayan"
        },
        {
          "language": "pl",
          "text": "porównanie cen"
        },
        {
          "language": "ro",
          "text": "comparație de prețuri"
        },
        {
          "language": "ru",
          "text": "сравнение цен"
        },
        {
          "language": "sq",
          "text": "krahasim çmimesh"
        },
        {
          "language": "tr",
          "text": "fiyat karşılaştırması"
        }
      ],
      "examples": [
        {
          "baseText": "Vor dem Kauf lohnt sich ein Preisvergleich im Internet.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الشراء تستحق مقارنة الأسعار على الإنترنت."
            },
            {
              "language": "ckb",
              "text": "پێش کڕین بەراوردی نرخ لە ئینتەرنێت سوودی هەیە."
            },
            {
              "language": "en",
              "text": "Before buying, a price comparison on the internet is worthwhile."
            },
            {
              "language": "fa",
              "text": "قبل از خرید، مقایسه قیمت در اینترنت ارزش دارد."
            },
            {
              "language": "kmr",
              "text": "Berî kirînê berawirdkirina bihayan li internetê hêjayî ye."
            },
            {
              "language": "pl",
              "text": "Przed zakupem warto zrobić porównanie cen w internecie."
            },
            {
              "language": "ro",
              "text": "Înainte de cumpărare merită o comparație de prețuri pe internet."
            },
            {
              "language": "ru",
              "text": "Перед покупкой стоит сравнить цены в интернете."
            },
            {
              "language": "sq",
              "text": "Para blerjes ia vlen të bësh një krahasim çmimesh në internet."
            },
            {
              "language": "tr",
              "text": "Satın almadan önce internette fiyat karşılaştırması yapmak faydalıdır."
            }
          ]
        },
        {
          "baseText": "Der Einkauf macht einen Preisvergleich zwischen drei Lieferanten.",
          "translations": [
            {
              "language": "ar",
              "text": "يقوم قسم المشتريات بمقارنة أسعار بين ثلاثة مورّدين."
            },
            {
              "language": "ckb",
              "text": "بەشی کڕین بەراوردی نرخ لە نێوان سێ دابینکەر دەکات."
            },
            {
              "language": "en",
              "text": "Purchasing compares prices between three suppliers."
            },
            {
              "language": "fa",
              "text": "بخش خرید بین سه تأمین‌کننده مقایسه قیمت انجام می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Beşa kirînê di navbera sê dabînkeran de berawirdkirina bihayan dike."
            },
            {
              "language": "pl",
              "text": "Dział zakupów porównuje ceny u trzech dostawców."
            },
            {
              "language": "ro",
              "text": "Departamentul de achiziții face o comparație de prețuri între trei furnizori."
            },
            {
              "language": "ru",
              "text": "Отдел закупок сравнивает цены у трёх поставщиков."
            },
            {
              "language": "sq",
              "text": "Departamenti i blerjes bën krahasim çmimesh mes tre furnizuesve."
            },
            {
              "language": "tr",
              "text": "Satın alma bölümü üç tedarikçi arasında fiyat karşılaştırması yapıyor."
            }
          ]
        }
      ]
    },
