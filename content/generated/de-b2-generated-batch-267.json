  "entries": [
    {
      "word": "zugutekommen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zugutekommen",
      "pronunciationIpa": null,
      "syllableBreak": "zu-gu-te-kom-men",
      "topics": [
        "business-communication",
        "management-and-leadership",
        "public-services"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "public-services",
        "customer-service"
      ],
      "grammarNotes": [
        "separable irregular verb: kommt zugute, kam zugute, ist zugutegekommen; usually with dative"
      ],
      "collocations": [
        {
          "text": "den Kunden zugutekommen",
          "meaning": "to benefit the customers"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gut",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "kommen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفيد؛ يعود بالنفع على"
        },
        {
          "language": "ckb",
          "text": "سوودی بە کەسێک دەگەیەنێت"
        },
        {
          "language": "en",
          "text": "to benefit; to be of use to"
        },
        {
          "language": "fa",
          "text": "به نفع کسی بودن؛ سود رساندن"
        },
        {
          "language": "kmr",
          "text": "sûd gihandin"
        },
        {
          "language": "pl",
          "text": "przynieść korzyść"
        },
        {
          "language": "ro",
          "text": "a fi în beneficiul"
        },
        {
          "language": "ru",
          "text": "пойти на пользу"
        },
        {
          "language": "sq",
          "text": "t’i sjellë dobi"
        },
        {
          "language": "tr",
          "text": "yararına olmak; fayda sağlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Verbesserungen im Portal kommen vor allem den Kunden mit vielen Bestellungen zugute.",
          "translations": [
            {
              "language": "ar",
              "text": "تفيد التحسينات في البوابة خصوصًا العملاء الذين لديهم طلبات كثيرة."
            },
            {
              "language": "ckb",
              "text": "چاکسازییەکانی پۆرتاڵەکە بە تایبەتی سوود بە کڕیارانی خاوەن داواکاریی زۆر دەگەیەنێت."
            },
            {
              "language": "en",
              "text": "The improvements in the portal mainly benefit customers with many orders."
            },
            {
              "language": "fa",
              "text": "بهبودهای پورتال بیش از همه به نفع مشتریانی است که سفارش‌های زیادی دارند."
            },
            {
              "language": "kmr",
              "text": "Başkirinên di portalê de bi taybetî sûdê digihînin xerîdarên bi fermanên zêde."
            },
            {
              "language": "pl",
              "text": "Usprawnienia w portalu przynoszą korzyść przede wszystkim klientom z wieloma zamówieniami."
            },
            {
              "language": "ro",
              "text": "Îmbunătățirile din portal sunt în beneficiul mai ales al clienților cu multe comenzi."
            },
            {
              "language": "ru",
              "text": "Улучшения портала прежде всего идут на пользу клиентам с большим числом заказов."
            },
            {
              "language": "sq",
              "text": "Përmirësimet në portal u sjellin dobi kryesisht klientëve me shumë porosi."
            },
            {
              "language": "tr",
              "text": "Portaldaki iyileştirmeler özellikle çok siparişi olan müşterilerin yararına olur."
            }
          ]
        },
        {
          "baseText": "Die zusätzlichen Pausen kommen dem Wohlbefinden der Mitarbeiter zugute.",
          "translations": [
            {
              "language": "ar",
              "text": "تعود فترات الراحة الإضافية بالنفع على رفاه الموظفين."
            },
            {
              "language": "ckb",
              "text": "پشووی زیادە سوود بە خۆشگوزەرانی کارمەندان دەگەیەنێت."
            },
            {
              "language": "en",
              "text": "The additional breaks benefit employees’ well-being."
            },
            {
              "language": "fa",
              "text": "استراحت‌های اضافی به رفاه کارکنان کمک می‌کند."
            },
            {
              "language": "kmr",
              "text": "Navberên zêde sûdê digihînin başbûna karmendan."
            },
            {
              "language": "pl",
              "text": "Dodatkowe przerwy korzystnie wpływają na dobrostan pracowników."
            },
            {
              "language": "ro",
              "text": "Pauzele suplimentare sunt în beneficiul stării de bine a angajaților."
            },
            {
              "language": "ru",
              "text": "Дополнительные перерывы идут на пользу благополучию сотрудников."
            },
            {
              "language": "sq",
              "text": "Pushimet shtesë i sjellin dobi mirëqenies së punonjësve."
            },
            {
              "language": "tr",
              "text": "Ek molalar çalışanların iyi olma haline fayda sağlar."
            }
          ]
        }
      ]
    },
