      "wordFamilies": [
        {
          "lemma": "der Aufenthalt",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يؤخر؛ يوقف؛ يقيم أو يبقى في مكان"
        },
        {
          "language": "ckb",
          "text": "دواخستن؛ وەستاندن؛ لە شوێنێک مانەوە"
        },
        {
          "language": "en",
          "text": "to delay; to stop; to stay somewhere"
        },
        {
          "language": "fa",
          "text": "معطل کردن؛ نگه داشتن؛ در جایی ماندن"
        },
        {
          "language": "kmr",
          "text": "dereng xistin; rawestandin; li cihêkê man"
        },
        {
          "language": "pl",
          "text": "zatrzymać; opóźnić; przebywać"
        },
        {
          "language": "ro",
          "text": "a întârzia; a opri; a se afla"
        },
        {
          "language": "ru",
          "text": "задержать; остановить; находиться"
