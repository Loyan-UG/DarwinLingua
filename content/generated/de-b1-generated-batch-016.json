  "entries": [
    {
      "word": "aufgehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufgehen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-ge-hen",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "planning-and-projects"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "management",
        "training"
      ],
      "grammarNotes": [
        "separable verb",
        "can mean to rise, open, work out, or be absorbed in something"
      ],
      "collocations": [
        {
          "text": "die Sonne geht auf",
          "meaning": "the sun rises"
        },
        {
          "text": "der Plan geht auf",
          "meaning": "the plan works out"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gehen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يشرق؛ يفتح؛ ينجح؛ ينغمس في شيء"
        },
        {
          "language": "ckb",
          "text": "هەڵاتن؛ کردنەوە؛ سەرکەوتن؛ خۆ تێدا ونکردن"
        },
        {
          "language": "en",
          "text": "to rise; to open; to work out; to be absorbed in"
        },
        {
          "language": "fa",
          "text": "طلوع کردن؛ باز شدن؛ نتیجه دادن؛ غرق چیزی شدن"
        },
        {
          "language": "kmr",
          "text": "derketin; vekirin; serketin"
        },
        {
          "language": "pl",
          "text": "wschodzić; otwierać się; udać się"
        },
        {
          "language": "ro",
          "text": "a răsări; a se deschide; a reuși"
        },
        {
          "language": "ru",
          "text": "всходить; открываться; сработать"
        },
        {
          "language": "sq",
          "text": "të lindë; të hapet; të funksionojë"
        },
        {
          "language": "tr",
          "text": "doğmak; açılmak; işe yaramak"
        }
      ],
      "examples": [
        {
          "baseText": "Unser Plan ist aufgegangen, und der Kunde hat den Vertrag unterschrieben.",
          "translations": [
            {
              "language": "ar",
              "text": "نجحت خطتنا ووقّع العميل العقد."
            },
            {
              "language": "ckb",
              "text": "پلانەکەمان سەرکەوت و کڕیار گرێبەستەکەی واژۆ کرد."
            },
            {
              "language": "en",
              "text": "Our plan worked out, and the customer signed the contract."
            },
            {
              "language": "fa",
              "text": "برنامه ما نتیجه داد و مشتری قرارداد را امضا کرد."
            },
            {
              "language": "kmr",
              "text": "Plana me serket û xerîdar peyman îmze kir."
            },
            {
              "language": "pl",
              "text": "Nasz plan się udał i klient podpisał umowę."
            },
            {
              "language": "ro",
              "text": "Planul nostru a reușit, iar clientul a semnat contractul."
            },
            {
              "language": "ru",
              "text": "Наш план сработал, и клиент подписал договор."
            },
            {
              "language": "sq",
              "text": "Plani ynë funksionoi dhe klienti nënshkroi kontratën."
            },
            {
              "language": "tr",
              "text": "Planımız işe yaradı ve müşteri sözleşmeyi imzaladı."
            }
          ]
        },
        {
          "baseText": "Im Sommer geht die Sonne sehr früh auf.",
          "translations": [
            {
              "language": "ar",
              "text": "في الصيف تشرق الشمس مبكرًا جدًا."
            },
            {
              "language": "ckb",
              "text": "لە هاویندا خۆر زۆر زوو هەڵدێت."
            },
            {
              "language": "en",
              "text": "In summer, the sun rises very early."
            },
            {
              "language": "fa",
              "text": "در تابستان خورشید خیلی زود طلوع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di havînê de roj pir zû derdikeve."
            },
            {
              "language": "pl",
              "text": "Latem słońce wschodzi bardzo wcześnie."
            },
            {
              "language": "ro",
              "text": "Vara, soarele răsare foarte devreme."
            },
            {
              "language": "ru",
              "text": "Летом солнце встаёт очень рано."
            },
            {
              "language": "sq",
              "text": "Në verë dielli lind shumë herët."
            },
            {
              "language": "tr",
              "text": "Yazın güneş çok erken doğar."
            }
          ]
        }
      ]
    },
