      "plural": "Zuweisungen",
      "infinitive": null,
      "syllableBreak": "Zu-wei-sung",
      "topics": [
        "erp-and-business-systems",
        "documents-and-administration",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business",
        "administrative",
