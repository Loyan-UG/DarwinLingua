      "word": "das Zahlungsmittel",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Zahlungsmittel",
      "infinitive": null,
      "syllableBreak": "Zah-lungs-mit-tel",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "customer-facing"
      ],
      "grammarNotes": [
        "neuter noun; plural is usually the same as singular"
      ],
      "collocations": [
        {
          "text": "ein Zahlungsmittel auswählen",
          "meaning": "to select a payment instrument"
        },
        {
          "text": "zulässige Zahlungsmittel",
          "meaning": "accepted payment instruments"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zahlung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "das Mittel",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "وسيلة دفع"
        },
        {
          "language": "ckb",
          "text": "ئامرازی پارەدان"
        },
        {
          "language": "en",
          "text": "means of payment; payment instrument"
        },
        {
          "language": "fa",
          "text": "وسیله پرداخت"
        },
        {
          "language": "kmr",
          "text": "amûra pere dayînê"
        },
        {
          "language": "pl",
          "text": "środek płatniczy"
        },
        {
          "language": "ro",
          "text": "mijloc de plată"
        },
        {
          "language": "ru",
          "text": "платежное средство"
        },
        {
          "language": "sq",
          "text": "mjet pagese"
        },
        {
          "language": "tr",
          "text": "ödeme aracı"
        }
      ],
      "examples": [
        {
          "baseText": "Das Zahlungsmittel muss im ERP-System vor der Rechnung hinterlegt sein.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب حفظ وسيلة الدفع في نظام تخطيط موارد المؤسسة قبل الفاتورة."
            },
            {
              "language": "ckb",
              "text": "ئامرازی پارەدان پێویستە پێش فاکتورەکە لە سیستەمی ERPدا تۆمارکرابێت."
            },
            {
              "language": "en",
              "text": "The payment instrument must be stored in the ERP system before the invoice."
            },
            {
              "language": "fa",
              "text": "وسیله پرداخت باید قبل از فاکتور در سیستم ERP ثبت شده باشد."
            },
            {
              "language": "kmr",
              "text": "Amûra pere dayînê divê berî fatûreyê di pergala ERP de hatibe tomarkirin."
            },
            {
              "language": "pl",
              "text": "Środek płatniczy musi być zapisany w systemie ERP przed fakturą."
            },
            {
              "language": "ro",
              "text": "Mijlocul de plată trebuie salvat în sistemul ERP înainte de factură."
            },
            {
              "language": "ru",
              "text": "Платежное средство должно быть сохранено в ERP-системе до выставления счета."
            },
            {
              "language": "sq",
              "text": "Mjeti i pagesës duhet të jetë i ruajtur në sistemin ERP para faturës."
            },
            {
              "language": "tr",
              "text": "Ödeme aracı faturadan önce ERP sisteminde kayıtlı olmalıdır."
            }
          ]
        },
        {
          "baseText": "Karte und Überweisung sind bei uns die häufigsten Zahlungsmittel.",
          "translations": [
            {
              "language": "ar",
              "text": "البطاقة والتحويل البنكي هما أكثر وسائل الدفع استخدامًا لدينا."
            },
            {
              "language": "ckb",
              "text": "کارت و گواستنەوەی بانکی لەلای ئێمە باوترين ئامرازەکانی پارەدانن."
            },
            {
              "language": "en",
              "text": "Card and bank transfer are our most common means of payment."
            },
            {
              "language": "fa",
              "text": "کارت و حواله بانکی رایج‌ترین وسیله‌های پرداخت نزد ما هستند."
            },
            {
              "language": "kmr",
              "text": "Kart û veguhastina bankî li cem me amûrên pere dayînê yên herî gelemperî ne."
            },
            {
              "language": "pl",
              "text": "Karta i przelew to u nas najczęstsze środki płatnicze."
            },
            {
              "language": "ro",
              "text": "Cardul și transferul bancar sunt cele mai frecvente mijloace de plată la noi."
            },
            {
              "language": "ru",
              "text": "Карта и банковский перевод — самые частые платежные средства у нас."
            },
            {
              "language": "sq",
              "text": "Karta dhe transferta bankare janë mjetet më të zakonshme të pagesës te ne."
            },
            {
              "language": "tr",
              "text": "Kart ve banka havalesi bizde en yaygın ödeme araçlarıdır."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
