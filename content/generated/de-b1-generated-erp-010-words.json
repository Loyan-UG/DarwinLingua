      "word": "das Zeitfenster",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Zeitfenster",
      "infinitive": null,
      "syllableBreak": "Zeit-fens-ter",
      "topics": [
        "warehouse-and-logistics",
        "planning-and-projects",
        "customer-service"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "customer-facing"
      ],
      "grammarNotes": [
        "neuter noun; plural is usually the same as singular"
      ],
      "collocations": [
        {
          "text": "ein Zeitfenster buchen",
          "meaning": "to book a time slot"
        },
        {
          "text": "das Zeitfenster einhalten",
          "meaning": "to keep the time window"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zeit",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "das Fenster",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "نافذة زمنية؛ فترة محددة"
        },
        {
          "language": "ckb",
          "text": "کاتی دیاریکراو؛ پەنجەرەی کات"
        },
        {
          "language": "en",
          "text": "time window; time slot"
        },
        {
          "language": "fa",
          "text": "بازه زمانی؛ پنجره زمانی"
        },
        {
          "language": "kmr",
          "text": "navbera demê"
        },
        {
          "language": "pl",
          "text": "okno czasowe"
        },
        {
          "language": "ro",
          "text": "interval orar"
        },
        {
          "language": "ru",
          "text": "временное окно"
        },
        {
          "language": "sq",
          "text": "dritare kohore"
        },
        {
          "language": "tr",
          "text": "zaman aralığı"
        }
      ],
      "examples": [
        {
          "baseText": "Das Zeitfenster für die Anlieferung ist im ERP-System von 8 bis 10 Uhr gebucht.",
          "translations": [
            {
              "language": "ar",
              "text": "تم حجز نافذة تسليم البضاعة في نظام تخطيط موارد المؤسسة من الساعة 8 إلى 10."
            },
            {
              "language": "ckb",
              "text": "کاتی دیاریکراوی گەیاندن لە سیستەمی ERPدا لە 8 تا 10 حجزکراوە."
            },
            {
              "language": "en",
              "text": "The time window for the delivery is booked in the ERP system from 8 to 10."
            },
            {
              "language": "fa",
              "text": "بازه زمانی تحویل در سیستم ERP از ساعت ۸ تا ۱۰ رزرو شده است."
            },
            {
              "language": "kmr",
              "text": "Navbera demê ya radestkirinê di pergala ERP de ji 8 heta 10 hatiye veqetandin."
            },
            {
              "language": "pl",
              "text": "Okno czasowe dla dostawy jest zarezerwowane w systemie ERP od 8 do 10."
            },
            {
              "language": "ro",
              "text": "Intervalul orar pentru livrare este rezervat în sistemul ERP de la 8 la 10."
            },
            {
              "language": "ru",
              "text": "Временное окно для поставки забронировано в ERP-системе с 8 до 10."
            },
            {
              "language": "sq",
              "text": "Dritarja kohore për dorëzimin është rezervuar në sistemin ERP nga ora 8 deri në 10."
            },
            {
              "language": "tr",
              "text": "Teslimat için zaman aralığı ERP sisteminde 8 ile 10 arası olarak rezerve edildi."
            }
          ]
        },
        {
          "baseText": "Passt Ihnen morgen ein Zeitfenster zwischen 14 und 16 Uhr?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يناسبك غدًا وقت بين الساعة 14 و16؟"
            },
            {
              "language": "ckb",
              "text": "سبەی کاتێکی نێوان 14 و 16 بۆتان گونجاوە؟"
            },
            {
              "language": "en",
              "text": "Would a time window between 2 and 4 p.m. work for you tomorrow?"
            },
            {
              "language": "fa",
              "text": "آیا فردا بازه زمانی بین ساعت ۱۴ تا ۱۶ برای شما مناسب است؟"
            },
            {
              "language": "kmr",
              "text": "Ma sibê navbera demê ya di navbera 14 û 16 de ji we re guncan e?"
            },
            {
              "language": "pl",
              "text": "Czy jutro pasuje Państwu okno czasowe między 14 a 16?"
            },
            {
              "language": "ro",
              "text": "Vă convine mâine un interval orar între 14 și 16?"
            },
            {
              "language": "ru",
              "text": "Вам подойдет завтра временное окно с 14 до 16?"
            },
            {
              "language": "sq",
              "text": "A ju përshtatet nesër një dritare kohore midis orës 14 dhe 16?"
            },
            {
              "language": "tr",
              "text": "Yarın 14 ile 16 arası bir zaman aralığı size uygun mu?"
            }
          ]
        }
      ]
    },
    {
