      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Zuweisung ändern",
          "meaning": "to change an assignment"
        },
        {
          "text": "die Zuweisung prüfen",
          "meaning": "to check the assignment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zuweisen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تخصيص؛ إسناد"
        },
        {
          "language": "ckb",
          "text": "تەرخانکردن؛ سپاردن"
        },
        {
          "language": "en",
          "text": "assignment; allocation"
        },
        {
          "language": "fa",
          "text": "تخصیص؛ ارجاع"
        },
        {
          "language": "kmr",
          "text": "veqetandin; erkdarkirin"
        },
        {
          "language": "pl",
          "text": "przypisanie; przydział"
        },
        {
          "language": "ro",
          "text": "alocare; atribuire"
        },
        {
          "language": "ru",
          "text": "назначение; распределение"
        },
        {
          "language": "sq",
          "text": "caktim; alokim"
        },
        {
          "language": "tr",
          "text": "atama; tahsis"
        }
      ],
      "examples": [
        {
          "baseText": "Die Zuweisung des Auftrags an das Lagerteam wurde im ERP-System geändert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تغيير إسناد الطلب إلى فريق المستودع في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "سپاردنی داواکارییەکە بە تیمی کۆگا لە سیستەمی ERPدا گۆڕدرا."
            },
            {
              "language": "en",
              "text": "The assignment of the order to the warehouse team was changed in the ERP system."
            },
            {
              "language": "fa",
              "text": "تخصیص سفارش به تیم انبار در سیستم ERP تغییر کرد."
            },
            {
              "language": "kmr",
              "text": "Erkdarkirina fermarişê ji tîma embarê re di pergala ERP de hate guhertin."
            },
            {
              "language": "pl",
              "text": "Przypisanie zamówienia do zespołu magazynu zostało zmienione w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Alocarea comenzii către echipa din depozit a fost schimbată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Назначение заказа складской команде было изменено в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Caktimi i porosisë te ekipi i magazinës u ndryshua në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Siparişin depo ekibine atanması ERP sisteminde değiştirildi."
            }
          ]
        },
        {
          "baseText": "Ohne klare Zuweisung weiß niemand, wer die Aufgabe übernimmt.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون إسناد واضح لا يعرف أحد من يتولى المهمة."
            },
            {
              "language": "ckb",
              "text": "بێ سپاردنی ڕوون، هیچ کەس نازانێت کێ ئەرکەکە وەردەگرێت."
            },
            {
              "language": "en",
              "text": "Without a clear assignment, nobody knows who will take over the task."
            },
            {
              "language": "fa",
              "text": "بدون تخصیص روشن، هیچ‌کس نمی‌داند چه کسی کار را بر عهده می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Bê erkdarkirineke zelal, kes nizane ka kî erkê digire."
            },
            {
              "language": "pl",
              "text": "Bez jasnego przypisania nikt nie wie, kto przejmie zadanie."
            },
            {
              "language": "ro",
              "text": "Fără o atribuire clară, nimeni nu știe cine preia sarcina."
            },
            {
              "language": "ru",
              "text": "Без четкого назначения никто не знает, кто возьмет задачу."
            },
            {
              "language": "sq",
              "text": "Pa një caktim të qartë, askush nuk e di kush e merr detyrën."
            },
            {
              "language": "tr",
              "text": "Net bir atama olmadan görevi kimin üstleneceğini kimse bilmez."
            }
          ]
        }
      ]
    }
  ],
