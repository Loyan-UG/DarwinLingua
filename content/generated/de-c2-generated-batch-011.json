      "contextLabels": [],
      "grammarNotes": [
        "separable verb; schilt aus, schalt aus, hat ausgescholten; elevated/older: to scold severely"
      ],
      "collocations": [
        {
          "text": "jemanden heftig ausschelten",
          "meaning": "to scold someone severely"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schelten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يوبّخ بشدة؛ يقرّع"
        },
        {
          "language": "ckb",
          "text": "بە توندی سەرزەنشت بکات"
        },
        {
          "language": "en",
          "text": "to scold severely; to reprimand harshly"
        },
        {
          "language": "fa",
          "text": "به‌شدت سرزنش کردن؛ توبیخ کردن"
        },
        {
          "language": "kmr",
          "text": "bi tundî serzeneşt kirin"
        },
        {
          "language": "pl",
          "text": "surowo zwymyślać; ostro zganić"
        },
        {
          "language": "ro",
          "text": "a certa aspru; a mustra sever"
        },
        {
          "language": "ru",
          "text": "строго отчитать; резко бранить"
        },
        {
          "language": "sq",
          "text": "ta qortosh ashpër"
        },
        {
          "language": "tr",
          "text": "sertçe azarlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Der alte Abteilungsleiter schalt den Praktikanten vor versammeltem Team aus, was später als Führungsfehler galt.",
          "translations": [
            {
              "language": "ar",
