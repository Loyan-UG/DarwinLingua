  "entries": [
    {
      "word": "ausringen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ausringen",
      "pronunciationIpa": null,
      "syllableBreak": "aus-rin-gen",
      "topics": [
        "contracts-and-negotiation",
        "management-and-leadership",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; ringt aus, rang aus, hat ausgerungen; often means to wrest or obtain something after great effort"
      ],
      "collocations": [
        {
          "text": "jemandem ein Zugeständnis ausringen",
          "meaning": "to wrest a concession from someone"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينتزع بصعوبة؛ يحصل بعد جهد"
        },
        {
          "language": "ckb",
          "text": "بە زەحمەت دەستەبەر بکات؛ بە ململاێ وەربگرێت"
        },
        {
          "language": "en",
          "text": "to wrest; to obtain with difficulty"
        },
        {
          "language": "fa",
          "text": "به‌سختی به دست آوردن؛ با کشمکش گرفتن"
        },
        {
          "language": "kmr",
          "text": "bi dijwarî bi dest xistin; bi şer wergirtin"
        },
        {
          "language": "pl",
          "text": "wydrzeć; uzyskać z trudem"
        },
        {
          "language": "ro",
          "text": "a smulge; a obține cu greu"
        },
        {
          "language": "ru",
          "text": "вырвать; добиться с трудом"
        },
        {
          "language": "sq",
          "text": "ta nxjerrësh me vështirësi; ta fitosh me mund"
        },
        {
          "language": "tr",
          "text": "zorla koparmak; güçlükle elde etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nach stundenlangen Verhandlungen rang das Team dem Lieferanten eine verbindliche Preisgarantie ab.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد ساعات من المفاوضات انتزع الفريق من المورد ضمان سعر ملزماً."
            },
            {
              "language": "ckb",
              "text": "دوای چەند کاتژمێر دانوسان، تیمەکە گەرەنتییەکی نرخی پابەندی بە زەحمەت لە دابینکەرەکە وەرگرت."
            },
            {
              "language": "en",
              "text": "After hours of negotiations, the team wrested a binding price guarantee from the supplier."
            },
            {
              "language": "fa",
              "text": "پس از ساعت‌ها مذاکره، تیم به‌سختی یک تضمین قیمت الزام‌آور از تأمین‌کننده گرفت."
            },
            {
              "language": "kmr",
              "text": "Piştî saetan danûstandinê, tîmê garantiyeke bihayê girêdayî ji dabînker bi dest xist."
            },
            {
              "language": "pl",
              "text": "Po wielogodzinnych negocjacjach zespół wydobył od dostawcy wiążącą gwarancję ceny."
            },
            {
              "language": "ro",
              "text": "După ore de negocieri, echipa a smuls furnizorului o garanție de preț obligatorie."
            },
            {
              "language": "ru",
              "text": "После многочасовых переговоров команда добилась от поставщика обязательной гарантии цены."
            },
            {
              "language": "sq",
              "text": "Pas orësh negociata, ekipi i nxori furnitorit një garanci detyruese çmimi."
            },
            {
              "language": "tr",
              "text": "Saatler süren müzakerelerden sonra ekip tedarikçiden bağlayıcı bir fiyat garantisi kopardı."
            }
          ]
        },
        {
          "baseText": "Der Autor rang der spröden Aktenlage eine erstaunlich lebendige Darstellung ab.",
          "translations": [
            {
              "language": "ar",
              "text": "استخرج الكاتب من مادة الملفات الجافة عرضاً حياً على نحو مدهش."
            },
            {
              "language": "ckb",
              "text": "نووسەرەکە لە بارودۆخی وشکی بەڵگەنامەکان وێنەیەکی بە شێوەیەکی سەرسوڕهێنەر زیندووی دەرهێنا."
            },
            {
              "language": "en",
              "text": "The author wrested a surprisingly vivid account from the dry file material."
            },
            {
              "language": "fa",
              "text": "نویسنده از مواد خشک پرونده‌ها روایتی شگفت‌انگیز زنده بیرون کشید."
            },
            {
              "language": "kmr",
              "text": "Nivîskar ji belgeyên hişk vegotineke bi şaşwaz zindî derxist."
            },
            {
              "language": "pl",
              "text": "Autor wydobył z suchego materiału akt zadziwiająco żywy opis."
            },
            {
              "language": "ro",
              "text": "Autorul a smuls din materialul sec al dosarelor o prezentare surprinzător de vie."
            },
            {
              "language": "ru",
              "text": "Автор извлёк из сухих материалов дела удивительно живое изложение."
            },
            {
              "language": "sq",
              "text": "Autori nxori nga materiali i thatë i dosjeve një paraqitje çuditërisht të gjallë."
            },
            {
              "language": "tr",
              "text": "Yazar kuru dosya malzemesinden şaşırtıcı derecede canlı bir anlatım çıkardı."
            }
          ]
        }
      ]
    },
    {
      "word": "ausscheiden",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ausscheiden",
      "pronunciationIpa": null,
      "syllableBreak": "aus-schei-den",
      "topics": [
        "human-resources",
        "work-and-jobs",
        "healthcare-and-appointments"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; scheidet aus, schied aus, ist ausgeschieden; can mean to leave a role, be eliminated, or excrete biologically"
      ],
      "collocations": [
        {
          "text": "aus dem Unternehmen ausscheiden",
          "meaning": "to leave the company"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Ausscheiden",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يغادر؛ يُستبعد؛ يفرز"
        },
        {
          "language": "ckb",
          "text": "دەرچوون؛ لادان؛ جیاکردنەوەی ماددە لە جەستە"
        },
        {
          "language": "en",
          "text": "to leave; to be eliminated; to excrete"
        },
        {
          "language": "fa",
          "text": "خارج شدن؛ حذف شدن؛ دفع کردن"
        },
        {
          "language": "kmr",
          "text": "derketin; ji pêşbaziyê derketin; derxistin"
        },
        {
          "language": "pl",
          "text": "odejść; odpaść; wydalać"
        },
        {
          "language": "ro",
          "text": "a ieși; a fi eliminat; a excreta"
        },
        {
          "language": "ru",
          "text": "выбывать; уходить; выделять"
        },
        {
          "language": "sq",
          "text": "të largohesh; të eliminohesh; të nxjerrësh"
        },
        {
          "language": "tr",
          "text": "ayrılmak; elenmek; salgılamak/atmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Bereichsleiterin scheidet zum Jahresende aus dem Unternehmen aus.",
          "translations": [
            {
              "language": "ar",
              "text": "ستغادر مديرة القسم الشركة في نهاية العام."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری بەشەکە لە کۆتایی ساڵدا لە کۆمپانیا دەردەچێت."
            },
            {
              "language": "en",
              "text": "The division manager will leave the company at the end of the year."
            },
            {
              "language": "fa",
              "text": "مدیر بخش در پایان سال از شرکت خارج می‌شود."
            },
            {
              "language": "kmr",
              "text": "Rêvebera beşê di dawiya salê de ji şirketê derdikeve."
            },
            {
              "language": "pl",
              "text": "Kierowniczka działu odchodzi z firmy z końcem roku."
            },
            {
              "language": "ro",
              "text": "Directoarea de departament va părăsi compania la sfârșitul anului."
            },
            {
              "language": "ru",
              "text": "Руководительница подразделения покинет компанию в конце года."
            },
            {
              "language": "sq",
              "text": "Drejtuesja e sektorit largohet nga kompania në fund të vitit."
            },
            {
              "language": "tr",
              "text": "Bölüm yöneticisi yıl sonunda şirketten ayrılacak."
            }
          ]
        },
        {
          "baseText": "Der Wirkstoff wird überwiegend über die Nieren ausgeschieden.",
          "translations": [
            {
              "language": "ar",
              "text": "تُطرح المادة الفعالة أساساً عبر الكلى."
            },
            {
              "language": "ckb",
              "text": "ماددە کاریگەرەکە بە زۆری لە ڕێگەی گورچیلەکانەوە دەر دەکرێت."
            },
            {
              "language": "en",
              "text": "The active substance is excreted mainly through the kidneys."
            },
            {
              "language": "fa",
              "text": "ماده مؤثر عمدتاً از طریق کلیه‌ها دفع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Madeya çalak bi piranî bi gurçikan tê derxistin."
            },
            {
              "language": "pl",
              "text": "Substancja czynna jest wydalana głównie przez nerki."
            },
            {
              "language": "ro",
              "text": "Substanța activă este eliminată în principal prin rinichi."
            },
            {
              "language": "ru",
              "text": "Действующее вещество выводится преимущественно через почки."
            },
            {
              "language": "sq",
              "text": "Substanca aktive nxirret kryesisht përmes veshkave."
            },
            {
              "language": "tr",
              "text": "Etken madde ağırlıklı olarak böbrekler yoluyla atılır."
            }
          ]
        }
      ]
    },
    {
      "word": "ausschelten",
