  "entries": [
    {
      "word": "losschießen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "losschießen",
      "pronunciationIpa": null,
      "syllableBreak": "los-schie-ßen",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "culture-and-media"
      ],
      "usageLabels": [
        "spoken",
        "informal"
      ],
      "contextLabels": [
        "management",
        "support",
        "customer-service"
      ],
      "grammarNotes": [
        "separable strong verb: schießt los, schoss los, ist/hat losgeschossen",
        "colloquial: to start suddenly with questions, criticism, or speech; literal: to start shooting"
      ],
      "collocations": [
        {
          "text": "mit Fragen losschießen",
          "meaning": "to fire off questions"
        },
        {
          "text": "sofort losschießen",
          "meaning": "to start right away"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schießen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "los",
          "relationLabel": "adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينطلق فجأة بالكلام أو الأسئلة؛ يبدأ بإطلاق النار"
        },
        {
          "language": "ckb",
          "text": "لەناکاو دەست پێدەکات بە قسە/پرسیار؛ تەقە دەست پێدەکات"
        },
        {
          "language": "en",
          "text": "to start suddenly; to fire off; to begin shooting"
        },
        {
          "language": "fa",
          "text": "ناگهان شروع کردن؛ سؤال‌باران کردن؛ شلیک را آغاز کردن"
        },
        {
          "language": "kmr",
          "text": "ji nişka ve dest pê kirin; pirsan barandin"
        },
        {
          "language": "pl",
          "text": "ruszyć z pytaniami; wypalić; zacząć strzelać"
        },
        {
          "language": "ro",
          "text": "a începe brusc; a trage întrebări; a începe să tragă"
        },
        {
          "language": "ru",
          "text": "внезапно начать; засыпать вопросами; начать стрелять"
        },
        {
          "language": "sq",
          "text": "të fillosh papritur; të qëllosh me pyetje"
        },
        {
          "language": "tr",
          "text": "birden başlamak; soru yağmuruna tutmak; ateş etmeye başlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Kaum war die Präsentation vorbei, schoss der Kunde mit sehr detaillierten Fragen los.",
          "translations": [
            {
              "language": "ar",
              "text": "ما إن انتهى العرض حتى بدأ العميل بسيل من الأسئلة المفصلة جدًا."
            },
            {
              "language": "ckb",
              "text": "هەر کە پێشکەشکردنەکە تەواو بوو، کڕیارەکە بە پرسیاری زۆر ورد دەستی پێکرد."
            },
            {
              "language": "en",
              "text": "As soon as the presentation was over, the customer fired off very detailed questions."
            },
            {
              "language": "fa",
              "text": "به‌محض پایان ارائه، مشتری شروع کرد به پرسیدن سؤال‌های بسیار جزئی."
            },
            {
              "language": "kmr",
              "text": "Hema ku pêşkêşkirin qedî, xerîdar bi pirsên pir hûrgilî dest pê kir."
            },
            {
              "language": "pl",
              "text": "Gdy tylko prezentacja się skończyła, klient zasypał nas bardzo szczegółowymi pytaniami."
            },
            {
              "language": "ro",
              "text": "Imediat ce prezentarea s-a terminat, clientul a început cu întrebări foarte detaliate."
            },
            {
              "language": "ru",
              "text": "Как только презентация закончилась, клиент засыпал нас очень подробными вопросами."
            },
            {
              "language": "sq",
              "text": "Sapo përfundoi prezantimi, klienti filloi me pyetje shumë të hollësishme."
            },
            {
              "language": "tr",
              "text": "Sunum biter bitmez müşteri çok ayrıntılı sorularla başladı."
            }
          ]
        },
        {
          "baseText": "Bitte schieß nicht gleich los, sondern hör dir erst die ganze Geschichte an.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك لا تبدأ فورًا، بل استمع أولًا إلى القصة كاملة."
            },
            {
              "language": "ckb",
              "text": "تکایە دەستبەجێ دەست پێمەکە، سەرەتا هەموو چیرۆکەکە گوێ بگرە."
            },
            {
              "language": "en",
              "text": "Please don’t jump in right away; listen to the whole story first."
            },
            {
              "language": "fa",
              "text": "لطفاً فوراً شروع نکن، اول کل ماجرا را گوش کن."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe tavilê dest pê neke, pêşî hemû çîrokê bibihîze."
            },
            {
              "language": "pl",
              "text": "Proszę, nie zaczynaj od razu, tylko najpierw wysłuchaj całej historii."
            },
            {
              "language": "ro",
              "text": "Te rog să nu începi imediat, ci ascultă mai întâi toată povestea."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не начинай сразу, сначала выслушай всю историю."
            },
            {
              "language": "sq",
              "text": "Të lutem mos fillo menjëherë, por dëgjo fillimisht gjithë historinë."
            },
            {
              "language": "tr",
              "text": "Lütfen hemen atlama, önce tüm hikâyeyi dinle."
            }
          ]
        }
      ]
    }
  ],
