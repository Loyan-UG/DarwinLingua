        }
      ],
      "wordFamilies": [
        {
          "lemma": "vereinbaren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اتفاق؛ ترتيبات"
        },
        {
          "language": "ckb",
          "text": "ڕێککەوتن؛ ڕێکخستن"
        },
        {
          "language": "en",
          "text": "agreement; arrangement"
        },
        {
          "language": "fa",
          "text": "توافق؛ قرار"
        },
        {
          "language": "kmr",
          "text": "lihevhatin; rêkeftin"
        },
        {
          "language": "pl",
          "text": "uzgodnienie; porozumienie"
        },
        {
          "language": "ro",
          "text": "acord; înțelegere"
        },
        {
          "language": "ru",
          "text": "соглашение; договоренность"
        },
        {
          "language": "sq",
          "text": "marrëveshje"
        },
        {
          "language": "tr",
          "text": "anlaşma; düzenleme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Vereinbarung steht im Vertrag auf Seite drei.",
          "translations": [
            {
              "language": "ar",
              "text": "الاتفاق موجود في العقد في الصفحة الثالثة."
            },
            {
              "language": "ckb",
              "text": "ڕێککەوتنەکە لە گرێبەستدا لە لاپەڕەی سێیەمە."
            },
            {
              "language": "en",
              "text": "The agreement is in the contract on page three."
            },
            {
              "language": "fa",
              "text": "توافق در قرارداد در صفحه سه آمده است."
            },
            {
              "language": "kmr",
              "text": "Lihevhatin di peymanê de li rûpela sêyem e."
            },
            {
              "language": "pl",
              "text": "Uzgodnienie znajduje się w umowie na stronie trzeciej."
            },
            {
              "language": "ro",
              "text": "Acordul se află în contract la pagina trei."
            },
            {
              "language": "ru",
              "text": "Договоренность указана в договоре на третьей странице."
            },
            {
              "language": "sq",
              "text": "Marrëveshja është në kontratë në faqen tre."
            },
            {
              "language": "tr",
              "text": "Anlaşma sözleşmenin üçüncü sayfasında yer alıyor."
            }
          ]
        },
        {
          "baseText": "Ohne klare Vereinbarung gibt es später oft Missverständnisse.",
          "translations": [
            {
              "language": "ar",
              "text": "بدون اتفاق واضح تحدث لاحقًا غالبًا سوء تفاهم."
            },
            {
              "language": "ckb",
              "text": "بێ ڕێککەوتنێکی ڕوون، دواتر زۆرجار تێنەگەیشتن دروست دەبێت."
            },
            {
              "language": "en",
              "text": "Without a clear agreement, misunderstandings often arise later."
            },
            {
              "language": "fa",
              "text": "بدون توافق روشن، بعداً اغلب سوءتفاهم پیش می‌آید."
            },
            {
              "language": "kmr",
              "text": "Bê lihevhatineke zelal, paşê gelek caran şaşfêmkirin çêdibin."
            },
            {
