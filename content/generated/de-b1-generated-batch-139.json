  "entries": [
    {
      "word": "verbringen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verbringen",
      "pronunciationIpa": null,
      "syllableBreak": "ver-brin-gen",
      "topics": [
        "everyday-life",
        "social-and-relationships",
        "work-and-jobs"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: verbringt, verbrachte, hat verbracht"
      ],
      "collocations": [
        {
          "text": "Zeit verbringen",
          "meaning": "to spend time"
        },
        {
          "text": "den Urlaub verbringen",
          "meaning": "to spend the vacation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bringen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقضي وقتًا"
        },
        {
          "language": "ckb",
          "text": "کات بەسەربردن"
        },
        {
          "language": "en",
          "text": "to spend time"
        },
        {
          "language": "fa",
          "text": "گذراندن وقت"
        },
        {
          "language": "kmr",
          "text": "dem derbas kirin"
        },
        {
          "language": "pl",
          "text": "spędzać czas"
        },
        {
          "language": "ro",
          "text": "a petrece timp"
        },
        {
          "language": "ru",
          "text": "проводить время"
        },
        {
          "language": "sq",
          "text": "të kalosh kohë"
        },
        {
          "language": "tr",
          "text": "zaman geçirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Am Wochenende verbringen wir viel Zeit mit der Familie.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع نقضي وقتًا كثيرًا مع العائلة."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا کاتی زۆر لەگەڵ خێزان بەسەر دەبەین."
            },
            {
              "language": "en",
              "text": "At the weekend, we spend a lot of time with the family."
            },
            {
              "language": "fa",
              "text": "آخر هفته وقت زیادی را با خانواده می‌گذرانیم."
            },
            {
              "language": "kmr",
              "text": "Dawiya hefteyê em gelek dem bi malbatê re derbas dikin."
            },
            {
              "language": "pl",
              "text": "W weekend spędzamy dużo czasu z rodziną."
            },
            {
              "language": "ro",
              "text": "În weekend petrecem mult timp cu familia."
            },
            {
              "language": "ru",
              "text": "На выходных мы проводим много времени с семьей."
            },
            {
              "language": "sq",
              "text": "Në fundjavë kalojmë shumë kohë me familjen."
            },
            {
              "language": "tr",
              "text": "Hafta sonu aileyle çok zaman geçiriyoruz."
            }
          ]
        },
        {
          "baseText": "Viele Entwickler verbringen den Vormittag mit der Fehlersuche.",
          "translations": [
            {
              "language": "ar",
              "text": "يقضي كثير من المطورين فترة الصباح في البحث عن الأخطاء."
            },
            {
              "language": "ckb",
              "text": "زۆر پەرەپێدەر بەیانییەکە بە گەڕان بەدوای هەڵەکاندا بەسەر دەبەن."
            },
            {
              "language": "en",
              "text": "Many developers spend the morning looking for bugs."
            },
            {
              "language": "fa",
              "text": "بسیاری از توسعه‌دهندگان صبح را صرف پیدا کردن خطاها می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Gelek pêşvebir sibehê bi lêgerîna şaşiyan derbas dikin."
            },
            {
              "language": "pl",
              "text": "Wielu programistów spędza przedpołudnie na szukaniu błędów."
            },
            {
              "language": "ro",
              "text": "Mulți dezvoltatori își petrec dimineața căutând erori."
            },
            {
              "language": "ru",
              "text": "Многие разработчики проводят утро в поиске ошибок."
            },
            {
              "language": "sq",
              "text": "Shumë zhvillues e kalojnë paraditen duke kërkuar gabime."
            },
            {
              "language": "tr",
              "text": "Birçok geliştirici sabahı hata arayarak geçirir."
            }
          ]
        }
      ]
    },
    {
      "word": "vereinbaren",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vereinbaren",
      "pronunciationIpa": null,
      "syllableBreak": "ver-ein-ba-ren",
      "topics": [
        "business-communication",
        "customer-service",
        "meetings-and-presentations"
      ],
      "usageLabels": [
        "formal",
        "polite",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb; often used for appointments and agreements"
      ],
      "collocations": [
        {
          "text": "einen Termin vereinbaren",
          "meaning": "to arrange an appointment"
        },
        {
          "text": "eine Lösung vereinbaren",
          "meaning": "to agree on a solution"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Vereinbarung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتفق على؛ يحدد موعدًا"
        },
        {
          "language": "ckb",
          "text": "ڕێککەوتن؛ کات دانان"
        },
        {
          "language": "en",
          "text": "to agree; to arrange"
        },
        {
          "language": "fa",
          "text": "هماهنگ کردن؛ توافق کردن"
        },
        {
          "language": "kmr",
          "text": "li hev kirin; randevû danîn"
        },
        {
          "language": "pl",
          "text": "uzgodnić; umówić"
        },
        {
          "language": "ro",
          "text": "a conveni; a stabili"
        },
        {
          "language": "ru",
          "text": "согласовать; договориться"
        },
        {
          "language": "sq",
          "text": "të biesh dakord; të caktosh"
        },
        {
          "language": "tr",
          "text": "kararlaştırmak; randevu ayarlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir möchten einen Termin für die Beratung vereinbaren.",
          "translations": [
            {
              "language": "ar",
              "text": "نود تحديد موعد للاستشارة."
            },
            {
              "language": "ckb",
              "text": "دەمانەوێت کاتێک بۆ ڕاوێژکاری ڕێکبخەین."
            },
            {
              "language": "en",
              "text": "We would like to arrange an appointment for the consultation."
            },
            {
              "language": "fa",
              "text": "می‌خواهیم برای مشاوره وقت بگیریم."
            },
            {
              "language": "kmr",
              "text": "Em dixwazin ji bo şêwirmendiyê randevûyekê danîn."
            },
            {
              "language": "pl",
              "text": "Chcielibyśmy umówić termin konsultacji."
            },
            {
              "language": "ro",
              "text": "Dorim să stabilim o programare pentru consultanță."
            },
            {
              "language": "ru",
              "text": "Мы хотели бы договориться о времени консультации."
            },
            {
              "language": "sq",
              "text": "Dëshirojmë të caktojmë një takim për këshillim."
            },
            {
              "language": "tr",
              "text": "Danışmanlık için bir randevu ayarlamak istiyoruz."
            }
          ]
        },
        {
          "baseText": "Im Gespräch haben beide Seiten eine faire Lösung vereinbart.",
          "translations": [
            {
              "language": "ar",
              "text": "في المحادثة اتفق الطرفان على حل عادل."
            },
            {
              "language": "ckb",
              "text": "لە گفتوگۆکەدا هەردوو لا ڕێچارەیەکی دادپەروەرانەیان ڕێککەوت."
            },
            {
              "language": "en",
              "text": "In the discussion, both sides agreed on a fair solution."
            },
            {
              "language": "fa",
              "text": "در گفت‌وگو، هر دو طرف بر سر یک راه‌حل منصفانه توافق کردند."
            },
            {
              "language": "kmr",
              "text": "Di axaftinê de her du alî li ser çareseriyeke dadperwer li hev kirin."
            },
            {
              "language": "pl",
              "text": "W rozmowie obie strony uzgodniły uczciwe rozwiązanie."
            },
            {
              "language": "ro",
              "text": "În discuție, ambele părți au convenit asupra unei soluții corecte."
            },
            {
              "language": "ru",
              "text": "В разговоре обе стороны согласовали справедливое решение."
            },
            {
              "language": "sq",
              "text": "Në bisedë të dyja palët ranë dakord për një zgjidhje të drejtë."
            },
            {
              "language": "tr",
              "text": "Görüşmede iki taraf adil bir çözüm üzerinde anlaştı."
            }
          ]
        }
      ]
    },
    {
      "word": "die Vereinbarung",
      "language": "de",
      "cefrLevel": "B1",
