        }
      ],
      "examples": [
        {
          "baseText": "Der neue Dienstplan hängt seit heute im Pausenraum.",
          "translations": [
            {
              "language": "ar",
              "text": "جدول العمل الجديد معلق منذ اليوم في غرفة الاستراحة."
            },
            {
              "language": "ckb",
              "text": "خشتەی دەوامی نوێ لە ئەمڕۆوە لە ژووری پشوودا هەڵواسراوە."
            },
            {
              "language": "en",
              "text": "The new duty roster has been posted in the break room since today."
            },
