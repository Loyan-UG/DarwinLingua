  "entries": [
    {
      "word": "die Dienstleistung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Dienstleistungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Dienst-leis-tung",
      "topics": [
        "shopping-and-services",
        "customer-service",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "formal",
        "written"
      ],
      "contextLabels": [
        "customer-service",
        "support",
        "administration"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Dienstleistung anbieten",
          "meaning": "to offer a service"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Dienstleister",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "leisten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خدمة"
        },
        {
          "language": "ckb",
          "text": "خزمەتگوزاری"
        },
        {
          "language": "en",
          "text": "service"
        },
        {
          "language": "fa",
          "text": "خدمت؛ خدمات"
        },
        {
          "language": "kmr",
          "text": "xizmet"
        },
        {
          "language": "pl",
          "text": "usługa"
        },
        {
          "language": "ro",
          "text": "serviciu"
        },
        {
          "language": "ru",
          "text": "услуга"
        },
        {
          "language": "sq",
          "text": "shërbim"
        },
        {
          "language": "tr",
          "text": "hizmet"
        }
      ],
      "examples": [
        {
          "baseText": "Unsere Firma bietet diese Dienstleistung auch für kleine Unternehmen an.",
          "translations": [
            {
              "language": "ar",
              "text": "تقدم شركتنا هذه الخدمة أيضًا للشركات الصغيرة."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکەمان ئەم خزمەتگوزارییەش بۆ کۆمپانیا بچووکەکان پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "Our company also offers this service for small businesses."
            },
            {
              "language": "fa",
              "text": "شرکت ما این خدمت را برای شرکت‌های کوچک هم ارائه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Şirketa me vê xizmetê ji bo karsaziyên biçûk jî pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Nasza firma oferuje tę usługę także małym przedsiębiorstwom."
            },
            {
              "language": "ro",
              "text": "Firma noastră oferă acest serviciu și firmelor mici."
            },
            {
              "language": "ru",
              "text": "Наша компания предлагает эту услугу и малым предприятиям."
            },
            {
              "language": "sq",
              "text": "Kompania jonë e ofron këtë shërbim edhe për bizneset e vogla."
            },
            {
              "language": "tr",
              "text": "Şirketimiz bu hizmeti küçük işletmelere de sunuyor."
            }
          ]
        },
        {
          "baseText": "Wenn Sie mit der Dienstleistung nicht zufrieden sind, melden Sie sich bitte beim Support.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا لم تكن راضيًا عن الخدمة، يرجى التواصل مع الدعم."
            },
            {
              "language": "ckb",
              "text": "ئەگەر لە خزمەتگوزارییەکە ڕازی نیت، تکایە پەیوەندی بە پاڵپشتییەوە بکە."
            },
            {
              "language": "en",
              "text": "If you are not satisfied with the service, please contact support."
            },
            {
              "language": "fa",
              "text": "اگر از خدمت راضی نیستید، لطفاً با پشتیبانی تماس بگیرید."
            },
            {
              "language": "kmr",
              "text": "Heke hûn ji xizmetê razî nîn, ji kerema xwe bi piştgiriyê re têkilî daynin."
            },
            {
              "language": "pl",
              "text": "Jeśli nie są Państwo zadowoleni z usługi, prosimy skontaktować się ze wsparciem."
            },
            {
              "language": "ro",
              "text": "Dacă nu sunteți mulțumit de serviciu, vă rugăm să contactați suportul."
            },
            {
              "language": "ru",
              "text": "Если вы недовольны услугой, пожалуйста, обратитесь в поддержку."
            },
            {
              "language": "sq",
              "text": "Nëse nuk jeni të kënaqur me shërbimin, ju lutemi kontaktoni mbështetjen."
            },
            {
              "language": "tr",
              "text": "Hizmetten memnun değilseniz lütfen destek birimiyle iletişime geçin."
            }
          ]
        }
      ]
    },
