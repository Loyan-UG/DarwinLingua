  "entries": [
    {
      "word": "die Kontrollvariable",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kontrollvariablen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kon-troll-va-ri-a-ble",
      "topics": [
        "data-and-reporting",
        "advanced-analysis",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; statistical term"
      ],
      "collocations": [
        {
          "text": "eine Kontrollvariable in das Modell aufnehmen",
          "meaning": "to include a control variable in the model"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kontrollieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Variable",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متغير ضابط"
        },
        {
          "language": "ckb",
          "text": "گۆڕاوی کۆنترۆڵ"
        },
        {
          "language": "en",
          "text": "control variable"
        },
        {
          "language": "fa",
          "text": "متغیر کنترل"
        },
        {
          "language": "kmr",
          "text": "guherbara kontrolê"
        },
        {
          "language": "pl",
          "text": "zmienna kontrolna"
        },
        {
          "language": "ro",
          "text": "variabilă de control"
        },
        {
          "language": "ru",
          "text": "контрольная переменная"
        },
        {
          "language": "sq",
          "text": "variabël kontrolli"
        },
        {
          "language": "tr",
          "text": "kontrol değişkeni"
        }
      ],
      "examples": [
        {
          "baseText": "Als Kontrollvariable wurde das Alter der Befragten in die Analyse aufgenommen.",
          "translations": [
            {
              "language": "ar",
              "text": "أُدرج عمر المشاركين كمتغير ضابط في التحليل."
            },
            {
              "language": "ckb",
              "text": "تەمەنی بەشداربووان وەک گۆڕاوی کۆنترۆڵ خرایە ناو شیکردنەوەکە."
            },
            {
              "language": "en",
              "text": "The respondents’ age was included in the analysis as a control variable."
            },
            {
              "language": "fa",
              "text": "سن پاسخ‌دهندگان به عنوان متغیر کنترل وارد تحلیل شد."
            },
            {
              "language": "kmr",
              "text": "Temenê bersivderan wek guherbara kontrolê ket nav analîzê."
            },
            {
              "language": "pl",
              "text": "Wiek respondentów uwzględniono w analizie jako zmienną kontrolną."
            },
            {
              "language": "ro",
              "text": "Vârsta respondenților a fost inclusă în analiză ca variabilă de control."
            },
            {
              "language": "ru",
              "text": "Возраст респондентов был включен в анализ как контрольная переменная."
            },
            {
              "language": "sq",
              "text": "Mosha e të anketuarve u përfshi në analizë si variabël kontrolli."
            },
            {
              "language": "tr",
              "text": "Katılımcıların yaşı analize kontrol değişkeni olarak dahil edildi."
            }
          ]
        },
        {
          "baseText": "Im Vertriebsmodell dient die Region als Kontrollvariable, damit saisonale Effekte nicht überschätzt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "في نموذج المبيعات تُستخدم المنطقة كمتغير ضابط حتى لا تُبالغ التقديرات في أثر الموسم."
            },
            {
              "language": "ckb",
              "text": "لە مۆدێلی فرۆشتندا ناوچە وەک گۆڕاوی کۆنترۆڵ بەکاردێت بۆ ئەوەی کاریگەریی وەرز زیاد لە ڕاستی هەژمار نەکرێت."
            },
            {
              "language": "en",
              "text": "In the sales model, region serves as a control variable so seasonal effects are not overestimated."
            },
            {
              "language": "fa",
              "text": "در مدل فروش، منطقه نقش متغیر کنترل دارد تا اثرهای فصلی بیش از حد برآورد نشوند."
            },
            {
              "language": "kmr",
              "text": "Di modela firotanê de herêm wek guherbara kontrolê tê bikaranîn da ku bandorên demsalî zêde neyên nirxandin."
            },
            {
              "language": "pl",
              "text": "W modelu sprzedaży region służy jako zmienna kontrolna, aby nie przeszacować efektów sezonowych."
            },
            {
              "language": "ro",
              "text": "În modelul de vânzări, regiunea servește ca variabilă de control pentru ca efectele sezoniere să nu fie supraestimate."
            },
            {
              "language": "ru",
              "text": "В модели продаж регион служит контрольной переменной, чтобы сезонные эффекты не переоценивались."
            },
            {
              "language": "sq",
              "text": "Në modelin e shitjeve, rajoni shërben si variabël kontrolli që efektet sezonale të mos mbivlerësohen."
            },
            {
              "language": "tr",
              "text": "Satış modelinde bölge, mevsimsel etkilerin abartılmaması için kontrol değişkeni olarak kullanılır."
            }
          ]
        }
      ]
    },
    {
      "word": "kontrovers",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "kon-tro-vers",
      "topics": [
        "business-communication",
        "culture-and-media",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes something strongly debated"
      ],
      "collocations": [
        {
          "text": "kontrovers diskutiert werden",
          "meaning": "to be controversially discussed"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kontroverse",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مثير للجدل؛ خلافي"
        },
        {
          "language": "ckb",
          "text": "جێی مشتومڕ؛ ناکۆکیکەر"
        },
        {
          "language": "en",
          "text": "controversial; disputed"
        },
        {
          "language": "fa",
          "text": "بحث‌برانگیز؛ مورد اختلاف"
        },
        {
          "language": "kmr",
          "text": "nakokîdar; cihê nîqaşê"
        },
        {
          "language": "pl",
          "text": "kontrowersyjny; sporny"
        },
        {
          "language": "ro",
          "text": "controversat; disputat"
        },
        {
          "language": "ru",
          "text": "спорный; противоречивый"
        },
        {
          "language": "sq",
          "text": "kontrovers; i diskutueshëm"
        },
        {
          "language": "tr",
          "text": "tartışmalı; ihtilaflı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Vorschlag ist fachlich nachvollziehbar, bleibt aber politisch kontrovers.",
          "translations": [
            {
              "language": "ar",
              "text": "الاقتراح مفهوم من الناحية التخصصية، لكنه يبقى مثيراً للجدل سياسياً."
            },
            {
              "language": "ckb",
              "text": "پێشنیارەکە لە ڕووی پسپۆڕییەوە تێگەیشتنی هەیە، بەڵام لە ڕووی سیاسییەوە هێشتا جێی مشتومڕە."
            },
            {
              "language": "en",
              "text": "The proposal is professionally understandable but remains politically controversial."
            },
            {
              "language": "fa",
              "text": "این پیشنهاد از نظر تخصصی قابل فهم است، اما از نظر سیاسی همچنان بحث‌برانگیز می‌ماند."
            },
            {
              "language": "kmr",
              "text": "Pêşniyar ji aliyê pisporî ve têgihiştbar e, lê siyasî hîn nakokîdar dimîne."
            },
            {
              "language": "pl",
              "text": "Propozycja jest merytorycznie zrozumiała, ale politycznie pozostaje kontrowersyjna."
            },
            {
              "language": "ro",
              "text": "Propunerea este justificabilă profesional, dar rămâne controversată politic."
            },
            {
              "language": "ru",
              "text": "Предложение понятно с профессиональной точки зрения, но политически остается спорным."
            },
            {
              "language": "sq",
              "text": "Propozimi është i kuptueshëm profesionalisht, por mbetet politikisht kontrovers."
            },
            {
              "language": "tr",
              "text": "Öneri mesleki açıdan anlaşılır, ancak siyasi olarak tartışmalı kalıyor."
            }
          ]
        },
        {
          "baseText": "Die Änderung der Datenschutzregeln wurde im Unternehmen kontrovers diskutiert.",
          "translations": [
            {
              "language": "ar",
              "text": "نوقش تغيير قواعد حماية البيانات داخل الشركة بشكل مثير للجدل."
            },
            {
              "language": "ckb",
              "text": "گۆڕینی یاساکانی پاراستنی داتا لە کۆمپانیاکەدا بە شێوەیەکی جێی مشتومڕ گفتوگۆ کرا."
            },
            {
              "language": "en",
              "text": "The change to the data protection rules was discussed controversially within the company."
            },
            {
              "language": "fa",
              "text": "تغییر قوانین حفاظت از داده در شرکت بحث‌برانگیز مورد گفت‌وگو قرار گرفت."
            },
            {
              "language": "kmr",
              "text": "Guhertina rêzikên parastina daneyan di şîrketê de bi awayekî nakokîdar hat nîqaş kirin."
            },
            {
              "language": "pl",
              "text": "Zmiana zasad ochrony danych była w firmie dyskutowana kontrowersyjnie."
            },
            {
              "language": "ro",
              "text": "Modificarea regulilor de protecție a datelor a fost discutată controversat în companie."
            },
            {
              "language": "ru",
              "text": "Изменение правил защиты данных вызвало спорное обсуждение в компании."
            },
            {
              "language": "sq",
              "text": "Ndryshimi i rregullave për mbrojtjen e të dhënave u diskutua në mënyrë kontroverse në kompani."
            },
            {
              "language": "tr",
              "text": "Veri koruma kurallarındaki değişiklik şirkette tartışmalı biçimde ele alındı."
            }
          ]
        }
      ]
    },
