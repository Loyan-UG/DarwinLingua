        }
      ],
      "examples": [
        {
          "baseText": "Die Kontroverse entstand, weil die Entscheidung ohne vorherige Anhörung getroffen wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "نشأ الجدل لأن القرار اتُخذ من دون استماع مسبق للمعنيين."
            },
            {
              "language": "ckb",
              "text": "مشتومڕەکە دروست بوو چونکە بڕیارەکە بەبێ گوێگرتنی پێشوەختە لە پەیوەندیداران درا."
            },
            {
              "language": "en",
              "text": "The controversy arose because the decision was made without prior consultation."
            },
            {
              "language": "fa",
              "text": "این مناقشه از آنجا شکل گرفت که تصمیم بدون شنیدن نظر ذی‌نفعان گرفته شد."
            },
            {
              "language": "kmr",
              "text": "Nakokî çêbû ji ber ku biryar bê şêwirîna pêşîn hat dayîn."
            },
            {
              "language": "pl",
