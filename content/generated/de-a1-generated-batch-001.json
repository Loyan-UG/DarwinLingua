      "examples": [
        {
          "baseText": "Ich komme gern, aber ich habe wenig Zeit.",
          "translations": [
            {
              "language": "ar",
              "text": "أحب أن آتي، لكن لدي وقت قليل."
            },
            {
              "language": "ckb",
              "text": "بە خۆشی دێم، بەڵام کاتی کەمم هەیە."
            },
            {
              "language": "en",
              "text": "I would like to come, but I have little time."
            },
            {
              "language": "fa",
              "text": "دوست دارم بیایم، اما وقت کمی دارم."
            },
            {
              "language": "kmr",
              "text": "Ez bi kêfxweşî têm, lê demê min kêm e."
            },
            {
              "language": "pl",
              "text": "Chętnie przyjdę, ale mam mało czasu."
            },
            {
              "language": "ro",
              "text": "Vin cu plăcere, dar am puțin timp."
            },
            {
              "language": "ru",
              "text": "Я охотно приду, но у меня мало времени."
            },
            {
              "language": "sq",
              "text": "Vij me dëshirë, por kam pak kohë."
            },
            {
              "language": "tr",
              "text": "Memnuniyetle gelirim ama az zamanım var."
            }
          ]
        },
        {
          "baseText": "Das Zimmer ist klein, aber sauber.",
          "translations": [
