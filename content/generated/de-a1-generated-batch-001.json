        },
        {
          "language": "pl",
          "text": "od"
        },
        {
          "language": "ro",
          "text": "de la; începând cu"
        },
        {
          "language": "ru",
          "text": "с; начиная с"
        },
        {
          "language": "sq",
          "text": "nga; prej"
        },
        {
          "language": "tr",
          "text": "-den itibaren; -den"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kurs beginnt ab Montag.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدأ الدورة من يوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "خولەکە لە دووشەممەوە دەست پێدەکات."
            },
            {
              "language": "en",
              "text": "The course starts from Monday."
            },
            {
              "language": "fa",
              "text": "دوره از دوشنبه شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kurs ji duşemê ve dest pê dike."
            },
            {
              "language": "pl",
              "text": "Kurs zaczyna się od poniedziałku."
            },
            {
              "language": "ro",
              "text": "Cursul începe de luni."
            },
            {
              "language": "ru",
              "text": "Курс начинается с понедельника."
            },
            {
              "language": "sq",
              "text": "Kursi fillon nga e hëna."
            },
            {
              "language": "tr",
              "text": "Kurs pazartesiden itibaren başlıyor."
            }
          ]
        },
        {
          "baseText": "Ab acht Uhr ist das Büro offen.",
          "translations": [
            {
              "language": "ar",
              "text": "المكتب مفتوح من الساعة الثامنة."
            },
            {
              "language": "ckb",
              "text": "لە کاتژمێر هەشتەوە نووسینگە کراوەیە."
            },
            {
              "language": "en",
              "text": "The office is open from eight o’clock."
            },
            {
              "language": "fa",
              "text": "دفتر از ساعت هشت باز است."
            },
            {
              "language": "kmr",
              "text": "Nivîsgeh ji saet heştan ve vekirî ye."
            },
            {
              "language": "pl",
              "text": "Biuro jest otwarte od ósmej."
            },
            {
              "language": "ro",
              "text": "Biroul este deschis de la ora opt."
            },
            {
              "language": "ru",
              "text": "Офис открыт с восьми часов."
            },
            {
              "language": "sq",
              "text": "Zyra është e hapur nga ora tetë."
            },
            {
              "language": "tr",
              "text": "Ofis saat sekizden itibaren açık."
            }
          ]
        }
      ]
    },
