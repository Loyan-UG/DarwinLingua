      "meanings": [
        {
          "language": "ar",
          "text": "من؛ ابتداءً من"
        },
        {
          "language": "ckb",
          "text": "لە؛ لە ...ەوە"
        },
        {
          "language": "en",
          "text": "from; starting at"
        },
        {
