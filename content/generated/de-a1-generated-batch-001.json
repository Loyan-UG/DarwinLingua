      "examples": [
        {
          "baseText": "Am Abend bin ich zu Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "في المساء أكون في البيت."
            },
            {
              "language": "ckb",
              "text": "ئێوارە لە ماڵەوەم."
            },
            {
              "language": "en",
              "text": "In the evening, I am at home."
            },
            {
              "language": "fa",
              "text": "عصر در خانه هستم."
            },
            {
              "language": "kmr",
              "text": "Êvar ez li malê me."
            },
            {
              "language": "pl",
              "text": "Wieczorem jestem w domu."
            },
            {
              "language": "ro",
              "text": "Seara sunt acasă."
            },
            {
              "language": "ru",
              "text": "Вечером я дома."
            },
            {
              "language": "sq",
              "text": "Në mbrëmje jam në shtëpi."
            },
            {
              "language": "tr",
              "text": "Akşam evdeyim."
            }
          ]
        },
        {
          "baseText": "Ich wünsche Ihnen einen schönen Abend.",
          "translations": [
            {
              "language": "ar",
              "text": "أتمنى لكم مساءً جميلاً."
            },
            {
              "language": "ckb",
              "text": "ئێوارەیەکی خۆشتان بۆ ئارەزوو دەکەم."
            },
            {
              "language": "en",
              "text": "I wish you a nice evening."
            },
            {
              "language": "fa",
              "text": "عصر خوبی برای شما آرزو می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez êvareke xweş ji we re dixwazim."
            },
            {
              "language": "pl",
              "text": "Życzę państwu miłego wieczoru."
            },
            {
              "language": "ro",
              "text": "Vă doresc o seară frumoasă."
            },
            {
              "language": "ru",
              "text": "Желаю вам хорошего вечера."
            },
            {
              "language": "sq",
              "text": "Ju uroj një mbrëmje të bukur."
            },
            {
              "language": "tr",
              "text": "Size iyi akşamlar dilerim."
            }
          ]
        }
