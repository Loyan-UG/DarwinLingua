              "language": "ar",
              "text": "الغرفة صغيرة، لكنها نظيفة."
            },
            {
              "language": "ckb",
              "text": "ژوورەکە بچووکە، بەڵام پاکە."
            },
            {
              "language": "en",
              "text": "The room is small, but clean."
            },
            {
              "language": "fa",
              "text": "اتاق کوچک است، اما تمیز است."
            },
            {
              "language": "kmr",
              "text": "Ode biçûk e, lê paqij e."
            },
            {
              "language": "pl",
              "text": "Pokój jest mały, ale czysty."
            },
            {
              "language": "ro",
              "text": "Camera este mică, dar curată."
            },
            {
              "language": "ru",
              "text": "Комната маленькая, но чистая."
            },
            {
              "language": "sq",
              "text": "Dhoma është e vogël, por e pastër."
            },
            {
              "language": "tr",
              "text": "Oda küçük ama temiz."
            }
          ]
        }
