  "entries": [
    {
      "word": "zuschließen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zuschließen",
      "pronunciationIpa": null,
      "syllableBreak": "zu-schlie-ßen",
      "topics": [
        "everyday-life",
        "housing-and-real-estate",
        "work-and-jobs"
      ],
      "usageLabels": [
        "spoken",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: ich schließe zu, ich schloss zu, ich habe zugeschlossen"
      ],
      "collocations": [
        {
          "text": "die Tür zuschließen",
          "meaning": "to lock the door"
        },
        {
          "text": "das Büro zuschließen",
          "meaning": "to lock the office"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schließen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Schlüssel",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يغلق بالمفتاح"
        },
        {
          "language": "ckb",
          "text": "بە کلیل داخستن"
        },
        {
          "language": "en",
          "text": "to lock"
        },
        {
          "language": "fa",
          "text": "قفل کردن"
        },
        {
          "language": "kmr",
          "text": "bi mifte girtin"
        },
        {
          "language": "pl",
          "text": "zamknąć na klucz"
        },
        {
          "language": "ro",
          "text": "a încuia"
        },
        {
          "language": "ru",
          "text": "запирать на ключ"
        },
        {
          "language": "sq",
          "text": "të kyçësh"
        },
        {
          "language": "tr",
          "text": "kilitlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schließen Sie die Eingangstür abends immer zu.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى دائماً قفل باب المدخل مساءً."
            },
            {
              "language": "ckb",
              "text": "تکایە ئێواران هەمیشە دەرگای چوونەژوورەوە بە کلیل دابخەن."
            },
            {
              "language": "en",
              "text": "Please always lock the entrance door in the evening."
            },
            {
              "language": "fa",
              "text": "لطفاً عصرها همیشه در ورودی را قفل کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe êvaran her dem deriyê ketinê bi mifte bigirin."
            },
            {
              "language": "pl",
              "text": "Proszę zawsze zamykać drzwi wejściowe wieczorem na klucz."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să încuiați întotdeauna ușa de la intrare seara."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, всегда запирайте входную дверь вечером."
            },
            {
              "language": "sq",
              "text": "Ju lutem kyçeni gjithmonë derën e hyrjes në mbrëmje."
            },
            {
              "language": "tr",
              "text": "Lütfen akşamları giriş kapısını her zaman kilitleyin."
            }
          ]
        },
        {
          "baseText": "Ich habe das Büro zugeschlossen und den Schlüssel an der Rezeption abgegeben.",
          "translations": [
            {
              "language": "ar",
              "text": "أغلقت المكتب بالمفتاح وسلّمت المفتاح في الاستقبال."
            },
            {
              "language": "ckb",
              "text": "ئۆفیسەکەم بە کلیل داخست و کلیلەکەم لە پێشوازی دامەوە."
            },
            {
              "language": "en",
              "text": "I locked the office and left the key at reception."
            },
            {
              "language": "fa",
              "text": "دفتر را قفل کردم و کلید را به پذیرش تحویل دادم."
            },
            {
              "language": "kmr",
              "text": "Min nivîsgeh bi mifte girt û mifte li resepsiyonê da."
            },
            {
              "language": "pl",
              "text": "Zamknąłem biuro na klucz i zostawiłem klucz w recepcji."
            },
            {
              "language": "ro",
              "text": "Am încuiat biroul și am lăsat cheia la recepție."
            },
            {
              "language": "ru",
              "text": "Я запер офис и оставил ключ на ресепшене."
            },
            {
              "language": "sq",
              "text": "E kyça zyrën dhe e lashë çelësin te recepsioni."
            },
            {
              "language": "tr",
              "text": "Ofisi kilitledim ve anahtarı resepsiyona bıraktım."
            }
          ]
        }
      ]
    },
    {
      "word": "der Zuschuss",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Zuschüsse",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Zu-schuss",
      "topics": [
        "finance-and-accounting",
        "public-services",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun: der Zuschuss, die Zuschüsse"
      ],
      "collocations": [
        {
          "text": "einen Zuschuss beantragen",
          "meaning": "to apply for a subsidy"
        },
        {
          "text": "einen Zuschuss bekommen",
          "meaning": "to receive a grant"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bezuschussen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دعم مالي؛ منحة"
        },
        {
          "language": "ckb",
          "text": "یارمەتی دارایی؛ پاڵپشتی پارەیی"
        },
        {
          "language": "en",
          "text": "subsidy; grant; financial support"
        },
        {
          "language": "fa",
          "text": "کمک‌هزینه؛ یارانه؛ حمایت مالی"
        },
        {
          "language": "kmr",
          "text": "piştgiriya darayî; alîkariya pereyî"
        },
        {
          "language": "pl",
          "text": "dotacja; dofinansowanie"
        },
        {
          "language": "ro",
          "text": "subvenție; sprijin financiar"
        },
        {
          "language": "ru",
          "text": "субсидия; дотация; финансовая помощь"
        },
        {
          "language": "sq",
          "text": "subvencion; grant; mbështetje financiare"
        },
        {
          "language": "tr",
          "text": "hibe; destek ödemesi; mali destek"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Weiterbildung können Sie einen Zuschuss beantragen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم التقدم بطلب للحصول على دعم مالي للتدريب الإضافي."
            },
            {
              "language": "ckb",
              "text": "بۆ فێربوونی زیاتر دەتوانن داوای یارمەتی دارایی بکەن."
            },
            {
              "language": "en",
              "text": "You can apply for a subsidy for the further training."
            },
            {
              "language": "fa",
              "text": "برای دوره آموزشی تکمیلی می‌توانید درخواست کمک‌هزینه بدهید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji bo perwerdeya zêde daxwaza piştgiriya darayî bikin."
            },
            {
              "language": "pl",
              "text": "Na szkolenie można złożyć wniosek o dofinansowanie."
            },
            {
              "language": "ro",
              "text": "Pentru cursul de perfecționare puteți solicita o subvenție."
            },
            {
              "language": "ru",
              "text": "На повышение квалификации можно подать заявку на субсидию."
            },
            {
              "language": "sq",
              "text": "Për trajnimin e mëtejshëm mund të aplikoni për mbështetje financiare."
            },
            {
              "language": "tr",
              "text": "İleri eğitim için destek ödemesine başvurabilirsiniz."
            }
          ]
        },
        {
          "baseText": "Die Stadt zahlt Familien mit geringem Einkommen einen Zuschuss zur Miete.",
          "translations": [
            {
              "language": "ar",
              "text": "تدفع المدينة للأسر ذات الدخل المنخفض دعماً مالياً للإيجار."
            },
            {
              "language": "ckb",
              "text": "شارەوانی یارمەتی کرێی خانوو بە خێزانە کەم داهاتەکان دەدات."
            },
            {
              "language": "en",
              "text": "The city pays families with low income a rent subsidy."
            },
            {
              "language": "fa",
              "text": "شهر به خانواده‌های کم‌درآمد کمک‌هزینه اجاره می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Şaredarî ji malbatên kêm-dahat re piştgiriya kirê dide."
            },
            {
              "language": "pl",
              "text": "Miasto wypłaca rodzinom o niskich dochodach dodatek do czynszu."
            },
            {
              "language": "ro",
              "text": "Orașul plătește familiilor cu venituri mici o subvenție pentru chirie."
            },
            {
              "language": "ru",
              "text": "Город выплачивает семьям с низким доходом субсидию на аренду."
            },
            {
              "language": "sq",
              "text": "Qyteti u paguan familjeve me të ardhura të ulëta një subvencion për qiranë."
            },
            {
              "language": "tr",
              "text": "Belediye düşük gelirli ailelere kira desteği ödüyor."
            }
          ]
        }
      ]
    },
