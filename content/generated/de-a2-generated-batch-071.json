          ]
        },
        {
          "baseText": "Ich darf keine Nüsse essen.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يُسمح لي بأكل المكسرات."
            },
            {
              "language": "ckb",
              "text": "ناتوانم گوێز بخۆم."
            },
            {
              "language": "en",
              "text": "I am not allowed to eat nuts."
            },
            {
              "language": "fa",
              "text": "من نباید آجیل بخورم."
            },
            {
              "language": "kmr",
              "text": "Ez nikarim gûzan bixwim."
            },
            {
              "language": "pl",
              "text": "Nie wolno mi jeść orzechów."
            },
            {
              "language": "ro",
              "text": "Nu am voie să mănânc nuci."
            },
            {
              "language": "ru",
              "text": "Мне нельзя есть орехи."
            },
            {
              "language": "sq",
              "text": "Nuk më lejohet të ha arra."
            },
            {
              "language": "tr",
              "text": "Kuruyemiş yemem yasak."
