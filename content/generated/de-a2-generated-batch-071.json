      "meanings": [
        {
          "language": "ar",
          "text": "معكرونة؛ نودلز"
        },
        {
          "language": "ckb",
          "text": "نیوودڵ؛ ماکارۆنی"
        },
        {
          "language": "en",
          "text": "noodles; pasta"
        },
        {
          "language": "fa",
          "text": "ماکارونی؛ نودل"
        },
        {
          "language": "kmr",
          "text": "makarona; noodle"
        },
        {
          "language": "pl",
          "text": "makaron; kluski"
        },
        {
          "language": "ro",
          "text": "paste; tăiței"
        },
        {
          "language": "ru",
          "text": "лапша; макароны"
        },
        {
          "language": "sq",
          "text": "makarona; petë"
        },
        {
          "language": "tr",
          "text": "makarna; erişte"
        }
      ],
      "examples": [
        {
          "baseText": "Heute koche ich Nudeln mit Tomatensoße.",
          "translations": [
            {
              "language": "ar",
              "text": "اليوم أطبخ معكرونة مع صلصة الطماطم."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ نیوودڵ لەگەڵ سۆسی تەماتە دەکوڵێنم."
            },
            {
              "language": "en",
              "text": "Today I am cooking pasta with tomato sauce."
            },
            {
              "language": "fa",
              "text": "امروز ماکارونی با سس گوجه می‌پزم."
            },
            {
              "language": "kmr",
              "text": "Ez îro makarona bi sosa firingî çêdikim."
            },
            {
              "language": "pl",
              "text": "Dzisiaj gotuję makaron z sosem pomidorowym."
            },
            {
              "language": "ro",
              "text": "Astăzi gătesc paste cu sos de roșii."
            },
            {
              "language": "ru",
              "text": "Сегодня я готовлю макароны с томатным соусом."
            },
            {
              "language": "sq",
              "text": "Sot gatuaj makarona me salcë domatesh."
            },
            {
              "language": "tr",
              "text": "Bugün domates soslu makarna pişiriyorum."
            }
          ]
        },
        {
          "baseText": "Die Nudeln sind noch zu heiß.",
          "translations": [
            {
              "language": "ar",
              "text": "المعكرونة لا تزال ساخنة جداً."
            },
            {
              "language": "ckb",
              "text": "نیوودڵەکان هێشتا زۆر گەرمن."
            },
            {
              "language": "en",
              "text": "The noodles are still too hot."
            },
            {
              "language": "fa",
              "text": "ماکارونی هنوز خیلی داغ است."
            },
            {
              "language": "kmr",
              "text": "Makarona hêj pir germ e."
            },
            {
              "language": "pl",
              "text": "Makaron jest jeszcze za gorący."
            },
            {
              "language": "ro",
              "text": "Pastele sunt încă prea fierbinți."
            },
            {
              "language": "ru",
              "text": "Макароны ещё слишком горячие."
            },
            {
              "language": "sq",
              "text": "Makaronat janë ende shumë të nxehta."
            },
            {
              "language": "tr",
              "text": "Makarna hâlâ çok sıcak."
            }
          ]
        }
      ]
