            {
              "language": "en",
              "text": "Can I pay in cash here?"
            },
            {
              "language": "fa",
              "text": "می‌توانم اینجا نقدی پرداخت کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim li vir bi pereyê destan bidim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę tu zapłacić gotówką?"
            },
            {
              "language": "ro",
              "text": "Pot plăti aici în numerar?"
            },
            {
              "language": "ru",
              "text": "Могу я здесь заплатить наличными?"
            },
            {
              "language": "sq",
              "text": "A mund të paguaj këtu me para në dorë?"
            },
