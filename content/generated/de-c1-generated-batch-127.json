      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong verb; means to raise a glass to someone or drink in someone’s honor; alcohol-related context"
      ],
      "collocations": [
        {
          "text": "jemandem zutrinken",
          "meaning": "to raise a glass to someone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "trinken",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Trinkspruch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يشرب نخب شخص؛ يرفع كأسه له"
        },
        {
          "language": "ckb",
          "text": "بۆ کەسێک جام هەڵدەبڕێت؛ بە ناوی کەسێک دەخواتەوە"
        },
        {
          "language": "en",
          "text": "to raise a glass to someone; to drink a toast"
        },
        {
          "language": "fa",
          "text": "به سلامتی کسی نوشیدن؛ جام به افتخار کسی بلند کردن"
        },
        {
          "language": "kmr",
          "text": "ji bo kesekî qedeh hildan; toast kirin"
        },
        {
          "language": "pl",
          "text": "wznieść toast za kogoś"
        },
        {
          "language": "ro",
          "text": "a ciocni în cinstea cuiva; a bea un toast"
        },
        {
          "language": "ru",
          "text": "пить за кого-либо; поднимать тост"
        },
        {
          "language": "sq",
          "text": "të ngresh gotën për dikë; të bësh dolli"
        },
        {
          "language": "tr",
          "text": "birinin şerefine kadeh kaldırmak"
        }
      ],
      "examples": [
