  "entries": [
    {
      "word": "zusprechen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zusprechen",
      "pronunciationIpa": null,
      "syllableBreak": "zu-spre-chen",
      "topics": [
        "law-and-compliance",
        "documents-and-administration",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong verb; means to award, grant, or attribute something to someone; also to encourage someone in direct speech"
      ],
      "collocations": [
        {
          "text": "jemandem Schadensersatz zusprechen",
          "meaning": "to award damages to someone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sprechen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Zuspruch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يمنح؛ يحكم بشيء لشخص؛ يشجع"
        },
        {
          "language": "ckb",
          "text": "پێی دەدات؛ بە بڕیار بۆ کەسێک دەستنیشان دەکات؛ هاندەدات"
        },
        {
          "language": "en",
          "text": "to award; to grant; to encourage"
        },
        {
          "language": "fa",
          "text": "اعطا کردن؛ حکم به تعلق چیزی دادن؛ دلگرمی دادن"
        },
        {
          "language": "kmr",
          "text": "dayîn; bi biryar pê dan; dilxweş kirin"
        },
        {
          "language": "pl",
          "text": "przyznać; zasądzić; dodać otuchy"
        },
        {
          "language": "ro",
          "text": "a acorda; a atribui; a încuraja"
        },
        {
          "language": "ru",
          "text": "присуждать; предоставлять; подбадривать"
        },
        {
          "language": "sq",
          "text": "të japësh; të akordosh; të inkurajosh"
        },
        {
          "language": "tr",
          "text": "vermek; hükmetmek; cesaretlendirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Gericht sprach dem Kläger eine Entschädigung zu, weil die Kündigung formale Fehler enthielt.",
          "translations": [
            {
              "language": "ar",
              "text": "حكمت المحكمة للمدعي بتعويض لأن الفصل احتوى على أخطاء شكلية."
            },
            {
              "language": "ckb",
              "text": "دادگا قەرەبوویەکی بۆ داواکەر دەستنیشان کرد، چونکە کۆتاییهێنانەکە هەڵەی فەرمی تێدابوو."
            },
            {
              "language": "en",
              "text": "The court awarded the plaintiff compensation because the dismissal contained formal errors."
            },
            {
              "language": "fa",
              "text": "دادگاه به خواهان غرامت داد، چون اخراج دارای خطاهای شکلی بود."
            },
            {
              "language": "kmr",
              "text": "Dadgehê ji dozger re tezmînat da, ji ber ku derxistina ji kar çewtiyên fermî tê de hebûn."
            },
            {
              "language": "pl",
              "text": "Sąd przyznał powodowi odszkodowanie, ponieważ wypowiedzenie zawierało błędy formalne."
            },
            {
              "language": "ro",
              "text": "Instanța i-a acordat reclamantului despăgubiri deoarece concedierea conținea erori formale."
            },
            {
              "language": "ru",
              "text": "Суд присудил истцу компенсацию, поскольку увольнение содержало формальные ошибки."
            },
            {
              "language": "sq",
              "text": "Gjykata i akordoi paditësit kompensim sepse largimi nga puna përmbante gabime formale."
            },
            {
              "language": "tr",
              "text": "Mahkeme, fesihte şekli hatalar bulunduğu için davacıya tazminat verdi."
            }
          ]
        },
        {
          "baseText": "Die Mentorin sprach ihr Mut zu, obwohl die erste Präsentation nicht wie geplant verlaufen war.",
          "translations": [
            {
              "language": "ar",
              "text": "شجعتها المرشدة رغم أن العرض الأول لم يسر كما كان مخططاً."
            },
            {
              "language": "ckb",
              "text": "ڕاوێژکارەکە هانی دا، هەرچەندە یەکەم پێشکەشکردن وەک پلانکراو نەڕۆیشتبوو."
            },
            {
              "language": "en",
              "text": "The mentor encouraged her, even though the first presentation had not gone as planned."
            },
            {
              "language": "fa",
              "text": "منتور به او دلگرمی داد، هرچند ارائه اول طبق برنامه پیش نرفته بود."
            },
            {
              "language": "kmr",
              "text": "Mentorê wê dilxweş kir, her çend pêşkêşiya yekem li gor planê neçûbû."
            },
            {
              "language": "pl",
              "text": "Mentorka dodała jej otuchy, choć pierwsza prezentacja nie przebiegła zgodnie z planem."
            },
            {
              "language": "ro",
              "text": "Mentora a încurajat-o, deși prima prezentare nu decursese conform planului."
            },
            {
              "language": "ru",
              "text": "Наставница подбодрила ее, хотя первая презентация прошла не по плану."
            },
            {
              "language": "sq",
              "text": "Mentorja e inkurajoi, edhe pse prezantimi i parë nuk shkoi sipas planit."
            },
            {
              "language": "tr",
              "text": "Mentor, ilk sunum planlandığı gibi gitmemiş olsa da ona cesaret verdi."
            }
          ]
        }
      ]
    },
    {
      "word": "die Zuständigkeit",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Zuständigkeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Zu-stän-dig-keit",
      "topics": [
        "documents-and-administration",
        "work-and-jobs",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; responsibility or legal/organizational competence for a matter"
      ],
      "collocations": [
        {
          "text": "die Zuständigkeit klären",
          "meaning": "to clarify responsibility or jurisdiction"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zuständig",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "zuständig sein",
          "relationLabel": "verb phrase",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اختصاص؛ مسؤولية؛ صلاحية"
        },
        {
          "language": "ckb",
          "text": "بەرپرسیارێتی؛ دەسەڵاتی کارگێڕی یان یاسایی"
        },
        {
          "language": "en",
          "text": "responsibility; competence; jurisdiction"
        },
        {
          "language": "fa",
          "text": "مسئولیت؛ صلاحیت؛ حوزه اختیار"
        },
        {
          "language": "kmr",
          "text": "berpirsiyarî; desthilat; kompetans"
        },
        {
          "language": "pl",
          "text": "właściwość; odpowiedzialność; kompetencja"
        },
        {
          "language": "ro",
          "text": "competență; responsabilitate; jurisdicție"
        },
        {
          "language": "ru",
          "text": "компетенция; ответственность; подведомственность"
        },
        {
          "language": "sq",
          "text": "kompetencë; përgjegjësi; juridiksion"
        },
        {
          "language": "tr",
          "text": "yetki; sorumluluk; görev alanı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Zuständigkeit für Beschwerden aus dem Ausland wurde nach der Umstrukturierung neu geregelt.",
          "translations": [
            {
              "language": "ar",
              "text": "أعيد تنظيم الاختصاص بالشكاوى الواردة من الخارج بعد إعادة الهيكلة."
            },
            {
              "language": "ckb",
              "text": "دوای دووبارە ڕێکخستن، بەرپرسیارێتی سکاڵاکانی دەرەوەی وڵات بە نوێیی ڕێکخرا."
            },
            {
              "language": "en",
              "text": "Responsibility for complaints from abroad was reorganized after the restructuring."
            },
            {
              "language": "fa",
              "text": "مسئولیت رسیدگی به شکایت‌های خارج از کشور پس از بازسازی سازمانی دوباره تنظیم شد."
            },
            {
              "language": "kmr",
              "text": "Berpirsiyariya gilîyên ji derveyî welêt piştî ji nû ve rêxistinkirinê nû hate rêzkirin."
            },
            {
              "language": "pl",
              "text": "Właściwość w sprawie skarg z zagranicy została po restrukturyzacji uregulowana na nowo."
            },
            {
              "language": "ro",
              "text": "Competența pentru reclamațiile din străinătate a fost reorganizată după restructurare."
            },
            {
              "language": "ru",
              "text": "Компетенция по жалобам из-за рубежа была заново урегулирована после реструктуризации."
            },
            {
              "language": "sq",
              "text": "Kompetenca për ankesat nga jashtë vendit u riorganizua pas ristrukturimit."
            },
            {
              "language": "tr",
              "text": "Yurt dışından gelen şikayetlere ilişkin sorumluluk yeniden yapılandırmadan sonra yeniden düzenlendi."
            }
          ]
        },
        {
          "baseText": "Solange die Zuständigkeit ungeklärt bleibt, verzögert sich jede verbindliche Entscheidung.",
          "translations": [
            {
              "language": "ar",
              "text": "ما دامت الصلاحية غير واضحة، يتأخر كل قرار ملزم."
            },
            {
              "language": "ckb",
              "text": "تا بەرپرسیارێتی ناڕوون بمێنێتەوە، هەر بڕیارێکی پابەندکەر دوا دەکەوێت."
            },
            {
              "language": "en",
              "text": "As long as responsibility remains unclear, every binding decision is delayed."
            },
            {
              "language": "fa",
              "text": "تا زمانی که مسئولیت روشن نباشد، هر تصمیم الزام‌آوری به تأخیر می‌افتد."
            },
            {
              "language": "kmr",
              "text": "Heta ku berpirsiyarî nezelal bimîne, her biryara girêdayî dereng dikeve."
            },
            {
              "language": "pl",
              "text": "Dopóki właściwość pozostaje niejasna, każda wiążąca decyzja się opóźnia."
            },
            {
              "language": "ro",
              "text": "Atât timp cât competența rămâne neclară, orice decizie obligatorie este întârziată."
            },
            {
              "language": "ru",
              "text": "Пока компетенция остается неясной, любое обязательное решение задерживается."
            },
            {
              "language": "sq",
              "text": "Për sa kohë kompetenca mbetet e paqartë, çdo vendim i detyrueshëm vonohet."
            },
            {
              "language": "tr",
              "text": "Sorumluluk belirsiz kaldığı sürece her bağlayıcı karar gecikir."
            }
          ]
        }
      ]
    },
    {
      "word": "zutrinken",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
