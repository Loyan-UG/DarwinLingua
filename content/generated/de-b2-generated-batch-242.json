        },
        {
          "language": "fa",
          "text": "دور زدن؛ با ماشین زدن و انداختن"
        },
        {
          "language": "kmr",
          "text": "li dora ajotin; lêdan û xistin"
        },
        {
          "language": "pl",
          "text": "ominąć; potrącić i przewrócić"
        },
        {
          "language": "ro",
          "text": "a ocoli; a doborî cu vehiculul"
        },
        {
          "language": "ru",
          "text": "объехать; сбить"
        },
