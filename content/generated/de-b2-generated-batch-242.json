  "entries": [
    {
      "word": "umbenennen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "umbenennen",
      "pronunciationIpa": null,
      "syllableBreak": "um-be-nen-nen",
      "topics": [
        "technology-and-it",
        "documents-and-administration",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "software",
        "documents",
        "administration"
      ],
      "grammarNotes": [
        "separable verb: benennt um, benannte um, hat umbenannt"
      ],
      "collocations": [
        {
          "text": "eine Datei umbenennen",
          "meaning": "to rename a file"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "benennen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Name",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعيد تسمية"
        },
        {
          "language": "ckb",
          "text": "ناو دەگۆڕێت"
        },
        {
          "language": "en",
          "text": "to rename"
        },
        {
          "language": "fa",
          "text": "تغییر نام دادن"
        },
        {
          "language": "kmr",
          "text": "navê nû lê dan"
        },
        {
          "language": "pl",
          "text": "zmienić nazwę"
        },
        {
          "language": "ro",
          "text": "a redenumi"
        },
        {
          "language": "ru",
          "text": "переименовать"
        },
        {
          "language": "sq",
          "text": "të riemërtosh"
        },
        {
          "language": "tr",
          "text": "yeniden adlandırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte benennen Sie die Datei um, damit wir die Versionen besser unterscheiden können.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إعادة تسمية الملف حتى نتمكن من تمييز النسخ بشكل أفضل."
            },
            {
              "language": "ckb",
              "text": "تکایە ناوی فایلەکە بگۆڕن بۆ ئەوەی بتوانین وەشانەکان باشتر جیا بکەینەوە."
            },
            {
              "language": "en",
              "text": "Please rename the file so we can distinguish the versions more easily."
            },
            {
              "language": "fa",
              "text": "لطفاً نام فایل را تغییر دهید تا بتوانیم نسخه‌ها را بهتر از هم تشخیص دهیم."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe navê pelê biguherînin, da ku em guhertoyan baştir ji hev cuda bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zmienić nazwę pliku, żebyśmy mogli lepiej rozróżniać wersje."
            },
            {
              "language": "ro",
              "text": "Vă rog să redenumiți fișierul ca să putem distinge mai bine versiunile."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, переименуйте файл, чтобы мы могли лучше различать версии."
            },
            {
              "language": "sq",
              "text": "Ju lutem riemërtoni skedarin që t’i dallojmë më mirë versionet."
            },
            {
              "language": "tr",
              "text": "Sürümleri daha iyi ayırt edebilmemiz için lütfen dosyanın adını değiştirin."
            }
          ]
        },
        {
          "baseText": "Nach der Fusion wurde die Abteilung offiziell umbenannt.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الاندماج تم تغيير اسم القسم رسميًا."
            },
            {
              "language": "ckb",
              "text": "دوای یەکگرتنەکە ناوی بەشەکە بە فەرمی گۆڕدرا."
            },
            {
              "language": "en",
              "text": "After the merger, the department was officially renamed."
            },
            {
              "language": "fa",
              "text": "بعد از ادغام، نام بخش به‌طور رسمی تغییر کرد."
            },
            {
              "language": "kmr",
              "text": "Piştî yekbûnê, navê beşê bi fermî hate guhertin."
            },
            {
              "language": "pl",
              "text": "Po fuzji dział został oficjalnie przemianowany."
            },
            {
              "language": "ro",
              "text": "După fuziune, departamentul a fost redenumit oficial."
            },
            {
              "language": "ru",
              "text": "После слияния отдел был официально переименован."
            },
            {
              "language": "sq",
              "text": "Pas bashkimit, departamenti u riemërtua zyrtarisht."
            },
            {
              "language": "tr",
              "text": "Birleşmeden sonra bölümün adı resmi olarak değiştirildi."
            }
          ]
        }
      ]
    },
    {
