    {
      "word": "jedenfalls",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "je-den-falls",
      "topics": [
        "everyday-life",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb; often used to return to the main point or mean in any case"
      ],
      "collocations": [
        {
          "text": "jedenfalls jetzt",
          "meaning": "at least now; in any case now"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "jeder Fall",
          "relationLabel": "phrase",
          "note": "literal components"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "على أي حال؛ jedenfalls"
        },
        {
          "language": "ckb",
          "text": "بەهەر حاڵ؛ لە هەر بارێکدا"
        },
        {
          "language": "en",
          "text": "anyway; in any case"
        },
        {
          "language": "fa",
          "text": "به هر حال؛ در هر صورت"
        },
        {
          "language": "kmr",
          "text": "bi her awayî"
        },
        {
          "language": "pl",
          "text": "w każdym razie; tak czy inaczej"
        },
        {
          "language": "ro",
          "text": "în orice caz; oricum"
        },
        {
          "language": "ru",
          "text": "во всяком случае; в любом случае"
        },
        {
          "language": "sq",
          "text": "sidoqoftë; në çdo rast"
        },
        {
          "language": "tr",
          "text": "her durumda; neyse"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin jedenfalls pünktlich da.",
          "translations": [
            {
              "language": "ar",
              "text": "على أي حال، سأكون هناك في الوقت المحدد."
            },
            {
              "language": "ckb",
              "text": "بەهەر حاڵ من لە کاتی خۆیدا لەوێ دەبم."
            },
            {
              "language": "en",
              "text": "In any case, I will be there on time."
            },
            {
              "language": "fa",
              "text": "به هر حال من سر وقت آنجا هستم."
            },
            {
              "language": "kmr",
              "text": "Bi her awayî ez di wextê xwe de li wir im."
            },
            {
              "language": "pl",
              "text": "W każdym razie będę tam punktualnie."
            },
            {
              "language": "ro",
              "text": "În orice caz, voi fi acolo la timp."
            },
            {
              "language": "ru",
              "text": "Во всяком случае, я буду там вовремя."
            },
            {
              "language": "sq",
              "text": "Sidoqoftë, do të jem atje në kohë."
            },
            {
              "language": "tr",
              "text": "Her durumda zamanında orada olacağım."
            }
          ]
        },
        {
          "baseText": "Es regnet, aber wir gehen jedenfalls los.",
          "translations": [
            {
              "language": "ar",
              "text": "إنها تمطر، لكننا سننطلق على أي حال."
            },
            {
              "language": "ckb",
              "text": "باران دەبارێت، بەڵام بەهەر حاڵ دەڕۆین."
            },
            {
              "language": "en",
              "text": "It is raining, but we are going anyway."
            },
            {
              "language": "fa",
              "text": "باران می‌بارد، اما به هر حال راه می‌افتیم."
            },
            {
              "language": "kmr",
              "text": "Baran dibare, lê em bi her awayî diçin."
            },
            {
              "language": "pl",
              "text": "Pada deszcz, ale i tak idziemy."
            },
            {
              "language": "ro",
              "text": "Plouă, dar plecăm oricum."
            },
            {
              "language": "ru",
              "text": "Идёт дождь, но мы всё равно пойдём."
            },
            {
              "language": "sq",
              "text": "Po bie shi, por ne do të nisemi sidoqoftë."
            },
            {
              "language": "tr",
              "text": "Yağmur yağıyor ama yine de gidiyoruz."
            }
          ]
        }
      ]
    },
