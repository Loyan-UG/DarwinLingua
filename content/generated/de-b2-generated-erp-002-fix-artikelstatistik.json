      "meanings": [
        {
          "language": "ar",
          "text": "إحصاءات الصنف أو المنتج"
        },
        {
          "language": "ckb",
          "text": "ئاماری بابەت یان بەرهەم"
        },
        {
          "language": "en",
          "text": "item statistics; product statistics"
        },
        {
          "language": "fa",
          "text": "آمار کالا؛ آمار محصول"
        },
        {
          "language": "kmr",
          "text": "statîstîka malê; statîstîka hilberê"
        },
        {
          "language": "pl",
          "text": "statystyka artykułu"
        },
        {
          "language": "ro",
          "text": "statistică articol"
        },
        {
          "language": "ru",
          "text": "статистика товара"
        },
        {
          "language": "sq",
          "text": "statistikë artikulli"
        },
        {
          "language": "tr",
          "text": "ürün istatistiği; kalem istatistiği"
        }
      ],
      "examples": [
        {
          "baseText": "Die Artikelstatistik zeigt, dass dieser Artikel im Lager häufig gesucht, aber selten verkauft wird.",
          "translations": [
            {
              "language": "ar",
              "text": "تُظهر إحصاءات الصنف أن هذا الصنف يُبحث عنه كثيرًا في المستودع لكنه يُباع نادرًا."
            },
            {
              "language": "ckb",
              "text": "ئاماری بابەت نیشان دەدات ئەم بابەتە لە کۆگادا زۆر دەگەڕێنرێت، بەڵام کەم دەفرۆشرێت."
            },
            {
              "language": "en",
              "text": "The item statistics show that this item is often searched for in the warehouse but rarely sold."
            },
            {
              "language": "fa",
              "text": "آمار کالا نشان می‌دهد این کالا در انبار زیاد جست‌وجو می‌شود اما به‌ندرت فروخته می‌شود."
            },
            {
              "language": "kmr",
              "text": "Statîstîka malê nîşan dide ku ev mal li embarê pir tê gerandin lê kêm tê firotin."
            },
            {
              "language": "pl",
              "text": "Statystyka artykułu pokazuje, że ten artykuł jest często szukany w magazynie, ale rzadko sprzedawany."
            },
            {
              "language": "ro",
              "text": "Statistica articolului arată că acest articol este căutat des în depozit, dar se vinde rar."
            },
            {
              "language": "ru",
              "text": "Статистика товара показывает, что эту позицию часто ищут на складе, но редко продают."
            },
            {
              "language": "sq",
              "text": "Statistika e artikullit tregon se ky artikull kërkohet shpesh në magazinë, por shitet rrallë."
            },
            {
              "language": "tr",
              "text": "Ürün istatistiği, bu kalemin depoda sık arandığını ama nadiren satıldığını gösteriyor."
            }
          ]
        },
        {
          "baseText": "Für das Monatsmeeting brauche ich eine Artikelstatistik nach Umsatz, Marge und Retouren.",
          "translations": [
            {
              "language": "ar",
              "text": "لاجتماع الشهر أحتاج إلى إحصاءات المنتجات حسب الإيراد والهامش والمرتجعات."
            },
            {
              "language": "ckb",
              "text": "بۆ کۆبوونەوەی مانگانە پێویستم بە ئاماری بابەت بە پێی داهات، مارژ و گەڕاوەکان هەیە."
            },
            {
              "language": "en",
              "text": "For the monthly meeting, I need item statistics by revenue, margin, and returns."
            },
            {
              "language": "fa",
              "text": "برای جلسه ماهانه به آمار کالا بر اساس درآمد، حاشیه سود و مرجوعی‌ها نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ji bo civîna mehane ez hewceyê statîstîka malê li gor dahat, marj û vegeran im."
            },
            {
              "language": "pl",
              "text": "Na spotkanie miesięczne potrzebuję statystyki artykułów według przychodu, marży i zwrotów."
            },
            {
              "language": "ro",
              "text": "Pentru ședința lunară am nevoie de o statistică a articolelor după venit, marjă și retururi."
            },
            {
              "language": "ru",
              "text": "Для ежемесячного совещания мне нужна статистика товаров по выручке, марже и возвратам."
            },
            {
              "language": "sq",
              "text": "Për takimin mujor më duhet një statistikë artikujsh sipas të ardhurave, marzhit dhe kthimeve."
            },
            {
              "language": "tr",
              "text": "Aylık toplantı için ciro, marj ve iadeye göre ürün istatistiğine ihtiyacım var."
            }
          ]
        }
      ]
    }
  ],
