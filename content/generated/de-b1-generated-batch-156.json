  "entries": [
    {
      "word": "zurücknehmen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zurücknehmen",
      "pronunciationIpa": null,
      "syllableBreak": "zu-rück-neh-men",
      "topics": [
        "shopping-and-services",
        "business-communication",
        "customer-service"
      ],
      "usageLabels": [
        "customer-facing",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: ich nehme zurück, ich nahm zurück, ich habe zurückgenommen"
      ],
      "collocations": [
        {
          "text": "eine Aussage zurücknehmen",
          "meaning": "to take back a statement"
        },
        {
          "text": "eine Ware zurücknehmen",
          "meaning": "to take back an item"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "nehmen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Rücknahme",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسترجع؛ يسحب كلاماً أو قراراً"
        },
        {
          "language": "ckb",
          "text": "وەرگرتنەوە؛ کشاندنەوەی قسە یان بڕیار"
        },
        {
          "language": "en",
          "text": "to take back; to withdraw"
        },
        {
          "language": "fa",
          "text": "پس گرفتن؛ حرف یا تصمیمی را پس گرفتن"
        },
        {
          "language": "kmr",
          "text": "paş ve standin; gotinek an biryarek paş ve kişandin"
        },
        {
          "language": "pl",
          "text": "cofnąć; przyjąć z powrotem"
        },
        {
          "language": "ro",
          "text": "a retrage; a primi înapoi"
        },
        {
          "language": "ru",
          "text": "забирать обратно; отзывать"
        },
        {
          "language": "sq",
          "text": "të marrësh mbrapsht; të tërheqësh"
        },
        {
          "language": "tr",
          "text": "geri almak; geri çekmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Händler nimmt das Gerät zurück, wenn Sie den Kassenbon haben.",
          "translations": [
            {
              "language": "ar",
              "text": "يسترجع التاجر الجهاز إذا كان لديكم إيصال الشراء."
            },
            {
              "language": "ckb",
              "text": "فرۆشیارەکە ئامێرەکە وەردەگرێتەوە ئەگەر پسووڵەتان هەبێت."
            },
            {
              "language": "en",
              "text": "The dealer will take the device back if you have the receipt."
            },
            {
              "language": "fa",
              "text": "فروشنده دستگاه را پس می‌گیرد، اگر رسید خرید داشته باشید."
            },
            {
              "language": "kmr",
              "text": "Firoşkar dê amûrê paş ve bistîne ger belgeya kirînê hebe."
            },
            {
              "language": "pl",
              "text": "Sprzedawca przyjmie urządzenie z powrotem, jeśli ma Pan/Pani paragon."
            },
            {
              "language": "ro",
              "text": "Comerciantul primește aparatul înapoi dacă aveți bonul."
            },
            {
              "language": "ru",
              "text": "Продавец примет устройство обратно, если у вас есть чек."
            },
            {
              "language": "sq",
              "text": "Shitësi e merr pajisjen mbrapsht nëse keni kuponin."
            },
            {
              "language": "tr",
              "text": "Satıcı, fişiniz varsa cihazı geri alır."
            }
          ]
        },
        {
          "baseText": "Nach dem Gespräch nahm sie ihre Kritik teilweise zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الحديث سحبت جزءاً من انتقادها."
            },
            {
              "language": "ckb",
              "text": "دوای گفتوگۆکە، بەشێک لە ڕەخنەکەی کشاندەوە."
            },
            {
              "language": "en",
              "text": "After the conversation, she partly took back her criticism."
            },
            {
              "language": "fa",
              "text": "بعد از گفتگو، او بخشی از انتقادش را پس گرفت."
            },
            {
              "language": "kmr",
              "text": "Piştî axaftinê, wê rexneya xwe hinek paş ve kişand."
            },
            {
              "language": "pl",
              "text": "Po rozmowie częściowo wycofała swoją krytykę."
            },
            {
              "language": "ro",
              "text": "După discuție, ea și-a retras parțial critica."
            },
            {
              "language": "ru",
              "text": "После разговора она частично взяла свою критику обратно."
            },
            {
              "language": "sq",
              "text": "Pas bisedës, ajo e tërhoqi pjesërisht kritikën e saj."
            },
            {
              "language": "tr",
              "text": "Görüşmeden sonra eleştirisini kısmen geri aldı."
            }
          ]
        }
      ]
    },
    {
      "word": "zurückreiten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zurückreiten",
      "pronunciationIpa": null,
      "syllableBreak": "zu-rück-rei-ten",
      "topics": [
        "transport-and-travel",
        "everyday-life",
        "culture-and-media"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "everyday"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: ich reite zurück, ich ritt zurück, ich bin zurückgeritten"
      ],
      "collocations": [
        {
          "text": "zum Stall zurückreiten",
          "meaning": "to ride back to the stable"
        },
        {
          "text": "langsam zurückreiten",
          "meaning": "to ride back slowly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "reiten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Reiter",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يركب عائداً على حصان"
        },
        {
          "language": "ckb",
          "text": "گەڕانەوە بە سواری ئەسپ"
        },
        {
          "language": "en",
          "text": "to ride back on horseback"
        },
        {
          "language": "fa",
          "text": "با اسب برگشتن"
        },
        {
          "language": "kmr",
          "text": "bi hespan vegerîn"
        },
        {
          "language": "pl",
          "text": "wracać konno"
        },
        {
          "language": "ro",
          "text": "a se întoarce călare"
        },
        {
          "language": "ru",
          "text": "возвращаться верхом"
        },
        {
          "language": "sq",
          "text": "të kthehesh me kalë"
        },
        {
          "language": "tr",
          "text": "atla geri dönmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Ausflug sind wir langsam zum Hof zurückgeritten.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الرحلة عدنا ببطء إلى المزرعة على ظهور الخيل."
            },
            {
              "language": "ckb",
              "text": "دوای گەشتەکە، بە هێواشی بە سواری ئەسپ گەڕاینەوە بۆ حەوشەکە."
            },
            {
              "language": "en",
              "text": "After the outing, we slowly rode back to the farm."
            },
            {
              "language": "fa",
              "text": "بعد از گردش، آرام با اسب به مزرعه برگشتیم."
            },
            {
              "language": "kmr",
              "text": "Piştî gerê, em hêdî hêdî bi hespan vegeriyan cotkarîyê."
            },
            {
              "language": "pl",
              "text": "Po wycieczce powoli wróciliśmy konno do gospodarstwa."
            },
            {
              "language": "ro",
              "text": "După excursie, ne-am întors încet călare la fermă."
            },
            {
              "language": "ru",
              "text": "После прогулки мы медленно вернулись верхом на ферму."
            },
            {
              "language": "sq",
              "text": "Pas shëtitjes u kthyem ngadalë me kalë në fermë."
            },
            {
              "language": "tr",
              "text": "Geziden sonra çiftliğe yavaşça atla geri döndük."
            }
          ]
        },
        {
          "baseText": "Im Film reitet der Junge allein ins Dorf zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "في الفيلم يعود الصبي وحده إلى القرية على حصان."
            },
            {
              "language": "ckb",
              "text": "لە فیلمەکەدا کوڕەکە بە تەنیا بە سواری ئەسپ دەگەڕێتەوە بۆ گوندەکە."
            },
            {
              "language": "en",
              "text": "In the film, the boy rides back to the village alone."
            },
            {
              "language": "fa",
              "text": "در فیلم، پسر تنها با اسب به روستا برمی‌گردد."
            },
            {
              "language": "kmr",
              "text": "Di fîlmê de, xort bi tenê bi hespê xwe vedigere gund."
            },
            {
              "language": "pl",
              "text": "W filmie chłopiec sam wraca konno do wioski."
            },
            {
              "language": "ro",
              "text": "În film, băiatul se întoarce singur călare în sat."
            },
            {
              "language": "ru",
              "text": "В фильме мальчик один возвращается верхом в деревню."
            },
            {
              "language": "sq",
              "text": "Në film, djali kthehet vetëm me kalë në fshat."
            },
            {
              "language": "tr",
              "text": "Filmde çocuk köye tek başına atla geri döner."
            }
          ]
        }
      ]
    },
