      "examples": [
        {
          "baseText": "Die Auswahl der Stichprobe wirkte arbiträr, weil keine nachvollziehbaren Kriterien dokumentiert waren.",
          "translations": [
            {
              "language": "ar",
              "text": "بدا اختيار العينة اعتباطيًا لأنه لم تُوثق أي معايير مفهومة."
            },
