  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "antizipieren",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "antizipieren",
      "syllableBreak": "an-ti-zi-pie-ren",
      "topics": [
        "planning-and-projects",
        "management-and-leadership",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "business",
        "analysis",
        "advanced"
      ],
      "grammarNotes": [
        "regular verb; common in planning and analytical contexts"
      ],
      "collocations": [
        {
          "text": "Risiken antizipieren",
          "meaning": "to anticipate risks"
        },
        {
          "text": "Entwicklungen antizipieren",
          "meaning": "to anticipate developments"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Antizipation",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يتوقع مسبقًا؛ يستبق"
        },
        {
          "language": "ckb",
          "text": "پێشبینی دەکات؛ پێش وەختە دەبینێت"
        },
        {
          "language": "en",
          "text": "to anticipate; to foresee"
        },
        {
          "language": "fa",
          "text": "پیش‌بینی کردن؛ جلوتر دیدن"
        },
        {
          "language": "kmr",
          "text": "pêşbînî kirin; berê dîtin"
        },
        {
          "language": "pl",
          "text": "antycypować; przewidywać"
        },
        {
          "language": "ro",
          "text": "a anticipa; a prevedea"
        },
        {
          "language": "ru",
          "text": "предвидеть; antecipировать"
        },
        {
          "language": "sq",
          "text": "të parashikosh; të anticiposh"
        },
        {
          "language": "tr",
          "text": "öngörmek; önceden tahmin etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Projektteam antizipierte die Einwände des Kunden und bereitete belastbare Antworten vor.",
          "translations": [
            {
              "language": "ar",
              "text": "توقع فريق المشروع اعتراضات العميل مسبقًا وأعدّ إجابات موثوقة."
            },
            {
              "language": "ckb",
              "text": "تیمی پڕۆژەکە ناڕەزاییەکانی کڕیاری پێشبینی کرد و وەڵامی بەهێزی ئامادە کرد."
            },
            {
              "language": "en",
              "text": "The project team anticipated the customer’s objections and prepared robust answers."
            },
            {
              "language": "fa",
              "text": "تیم پروژه اعتراض‌های مشتری را پیش‌بینی کرد و پاسخ‌های قابل اتکا آماده ساخت."
            },
            {
              "language": "kmr",
              "text": "Tîma projeyê nerazîbûnên xerîdar pêşbînî kir û bersivên xurt amade kir."
            },
            {
              "language": "pl",
              "text": "Zespół projektowy przewidział zastrzeżenia klienta i przygotował solidne odpowiedzi."
            },
            {
              "language": "ro",
              "text": "Echipa de proiect a anticipat obiecțiile clientului și a pregătit răspunsuri solide."
            },
            {
              "language": "ru",
              "text": "Проектная команда предвидела возражения клиента и подготовила убедительные ответы."
            },
            {
              "language": "sq",
              "text": "Ekipi i projektit i parashikoi kundërshtimet e klientit dhe përgatiti përgjigje të qëndrueshme."
            },
            {
              "language": "tr",
              "text": "Proje ekibi müşterinin itirazlarını öngördü ve sağlam yanıtlar hazırladı."
            }
          ]
        },
        {
          "baseText": "Wer regulatorische Veränderungen früh antizipiert, kann teure Nacharbeiten vermeiden.",
          "translations": [
            {
              "language": "ar",
              "text": "من يتوقع التغييرات التنظيمية مبكرًا يستطيع تجنب أعمال تصحيح مكلفة."
            },
            {
              "language": "ckb",
              "text": "ئەوەی گۆڕانکارییە ڕێکخستنییەکان زوو پێشبینی بکات، دەتوانێت دووبارەکاریی گران دوور بخاتەوە."
            },
            {
              "language": "en",
              "text": "Those who anticipate regulatory changes early can avoid expensive rework."
            },
            {
              "language": "fa",
              "text": "کسی که تغییرات مقرراتی را زود پیش‌بینی کند، می‌تواند از بازکاری پرهزینه جلوگیری کند."
            },
            {
              "language": "kmr",
              "text": "Kesê ku guherînên rêziknameyî zû pêşbînî bike, dikare ji dubare-karîya biha dûr bikeve."
            },
            {
              "language": "pl",
              "text": "Kto wcześnie przewidzi zmiany regulacyjne, może uniknąć kosztownych poprawek."
            },
            {
              "language": "ro",
              "text": "Cine anticipează devreme schimbările de reglementare poate evita refaceri costisitoare."
            },
            {
              "language": "ru",
              "text": "Тот, кто заранее предвидит регуляторные изменения, может избежать дорогих доработок."
            },
            {
              "language": "sq",
              "text": "Kush i parashikon herët ndryshimet rregullatore mund të shmangë ripunime të kushtueshme."
            },
            {
              "language": "tr",
              "text": "Düzenleyici değişiklikleri erken öngörenler pahalı yeniden çalışmalardan kaçınabilir."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "antragen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "antragen",
      "syllableBreak": "an-tra-gen",
      "topics": [
        "management-and-leadership",
        "contracts-and-negotiation",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; often means to offer or propose formally to someone"
      ],
      "collocations": [
        {
          "text": "jemandem ein Amt antragen",
          "meaning": "to offer someone an office"
        },
        {
          "text": "eine Aufgabe antragen",
          "meaning": "to assign or offer a task"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "tragen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يعرض رسميًا؛ يقترح إسناد شيء"
        },
        {
          "language": "ckb",
          "text": "بە فەرمی پێشکەش دەکات؛ ئەرکێک پێ دەسپێرێت"
        },
        {
          "language": "en",
          "text": "to offer formally; to propose assigning"
        },
        {
          "language": "fa",
          "text": "رسماً پیشنهاد دادن؛ واگذار کردن"
        },
        {
          "language": "kmr",
          "text": "bi fermî pêşkêş kirin; peywirek pê dayîn"
        },
        {
          "language": "pl",
          "text": "zaproponować; powierzyć"
        },
        {
          "language": "ro",
          "text": "a propune formal; a încredința"
        },
        {
          "language": "ru",
          "text": "предлагать; поручать"
        },
        {
          "language": "sq",
          "text": "të ofrosh zyrtarisht; të ngarkosh"
        },
        {
          "language": "tr",
          "text": "resmen teklif etmek; görev vermek"
        }
      ],
      "examples": [
        {
          "baseText": "Dem erfahrenen Ingenieur wurde die Leitung des neuen Standorts angetragen.",
          "translations": [
            {
              "language": "ar",
              "text": "عُرضت على المهندس الخبير قيادة الموقع الجديد."
            },
            {
              "language": "ckb",
              "text": "بە ئەندازیاری شارەزا بەڕێوەبردنی شوێنی نوێ پێشکەش کرا."
            },
            {
              "language": "en",
              "text": "The experienced engineer was offered the management of the new site."
            },
            {
              "language": "fa",
              "text": "به مهندس باتجربه مدیریت محل جدید پیشنهاد شد."
            },
            {
              "language": "kmr",
              "text": "Ji endezyarê bi ezmûn re rêveberiya cihê nû hate pêşkêşkirin."
            },
            {
              "language": "pl",
              "text": "Doświadczonemu inżynierowi zaproponowano kierowanie nową lokalizacją."
            },
            {
              "language": "ro",
              "text": "Inginerului experimentat i s-a propus conducerea noului amplasament."
            },
            {
              "language": "ru",
              "text": "Опытному инженеру предложили руководство новой площадкой."
            },
            {
              "language": "sq",
              "text": "Inxhinierit me përvojë iu ofrua drejtimi i lokacionit të ri."
            },
            {
              "language": "tr",
              "text": "Deneyimli mühendise yeni tesisin yönetimi teklif edildi."
            }
          ]
        },
        {
          "baseText": "Die Stiftung trug ihr ein Mandat im wissenschaftlichen Beirat an.",
          "translations": [
            {
              "language": "ar",
              "text": "قدمت لها المؤسسة عرضًا لشغل مقعد في المجلس العلمي الاستشاري."
            },
            {
              "language": "ckb",
              "text": "دامەزراوەکە ئەندامێتی لە ئەنجومەنی زانستی ڕاوێژکاری پێشکەش پێ کرد."
            },
            {
              "language": "en",
              "text": "The foundation offered her a mandate on the scientific advisory board."
            },
            {
              "language": "fa",
              "text": "بنیاد به او عضویتی در شورای مشورتی علمی پیشنهاد کرد."
            },
            {
              "language": "kmr",
              "text": "Weqfê ji wê re endamtiyek di şûreya zanistî ya şêwirmendiyê de pêşkêş kir."
            },
            {
              "language": "pl",
              "text": "Fundacja zaproponowała jej mandat w naukowej radzie doradczej."
            },
            {
              "language": "ro",
              "text": "Fundația i-a propus un mandat în consiliul consultativ științific."
            },
            {
              "language": "ru",
              "text": "Фонд предложил ей мандат в научном консультативном совете."
            },
            {
              "language": "sq",
