      "examples": [
        {
          "baseText": "Für die Stelle braucht man gute Deutschkenntnisse.",
          "translations": [
            {
              "language": "ar",
              "text": "لهذه الوظيفة يحتاج المرء إلى معرفة جيدة بالألمانية."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم کارە پێویست بە شارەزایی باشی ئەڵمانییە."
            },
            {
              "language": "en",
              "text": "For the job, you need good German skills."
            },
            {
              "language": "fa",
              "text": "برای این شغل به دانش خوب آلمانی نیاز است."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê karê zanîna almanî ya baş pêwîst e."
            },
            {
              "language": "pl",
              "text": "Na to stanowisko potrzebna jest dobra znajomość niemieckiego."
            },
            {
              "language": "ro",
              "text": "Pentru postul acesta ai nevoie de cunoștințe bune de germană."
            },
            {
              "language": "ru",
              "text": "Для этой должности нужны хорошие знания немецкого."
            },
            {
              "language": "sq",
              "text": "Për këtë vend pune duhen njohuri të mira të gjermanishtes."
            },
            {
              "language": "tr",
              "text": "Bu pozisyon için iyi Almanca bilgisi gerekir."
            }
          ]
        },
        {
          "baseText": "Meine Kenntnisse in Mathematik sind besser geworden.",
          "translations": [
            {
              "language": "ar",
              "text": "معرفتي بالرياضيات أصبحت أفضل."
            },
            {
              "language": "ckb",
              "text": "شارەزاییم لە بیرکاری باشتر بووە."
            },
            {
              "language": "en",
              "text": "My knowledge of math has improved."
            },
            {
              "language": "fa",
              "text": "دانشم در ریاضی بهتر شده است."
            },
            {
              "language": "kmr",
              "text": "Zanîna min di matematîkê de baştir bûye."
            },
            {
              "language": "pl",
              "text": "Moja wiedza z matematyki się poprawiła."
            },
            {
              "language": "ro",
              "text": "Cunoștințele mele la matematică s-au îmbunătățit."
            },
            {
              "language": "ru",
              "text": "Мои знания по математике стали лучше."
            },
            {
              "language": "sq",
              "text": "Njohuritë e mia në matematikë janë përmirësuar."
            },
            {
              "language": "tr",
              "text": "Matematik bilgim daha iyi oldu."
            }
          ]
        }
      ]
    },
