      "examples": [
        {
          "baseText": "Der Kellner bringt die Rechnung.",
          "translations": [
            {
              "language": "ar",
              "text": "النادل يحضر الفاتورة."
            },
            {
              "language": "ckb",
              "text": "گەرسۆنەکە پسووڵەکە دێنێت."
            },
            {
              "language": "en",
              "text": "The waiter brings the bill."
            },
            {
              "language": "fa",
              "text": "گارسون صورت‌حساب را می‌آورد."
            },
            {
              "language": "kmr",
              "text": "Garson hesabê tîne."
            },
            {
              "language": "pl",
              "text": "Kelner przynosi rachunek."
            },
            {
              "language": "ro",
              "text": "Chelnerul aduce nota."
            },
            {
              "language": "ru",
              "text": "Официант приносит счёт."
            },
            {
              "language": "sq",
              "text": "Kamerieri sjell faturën."
            },
            {
              "language": "tr",
              "text": "Garson hesabı getiriyor."
            }
          ]
        },
        {
          "baseText": "Wir fragen den Kellner nach Wasser.",
          "translations": [
            {
              "language": "ar",
              "text": "نسأل النادل عن الماء."
            },
            {
              "language": "ckb",
              "text": "پرسیاری ئاو لە گەرسۆنەکە دەکەین."
            },
            {
              "language": "en",
              "text": "We ask the waiter for water."
            },
            {
              "language": "fa",
              "text": "از گارسون آب می‌خواهیم."
            },
            {
              "language": "kmr",
              "text": "Em ji garsonê avê dipirsin."
            },
            {
              "language": "pl",
              "text": "Prosimy kelnera o wodę."
            },
            {
              "language": "ro",
              "text": "Îl întrebăm pe chelner de apă."
            },
            {
              "language": "ru",
              "text": "Мы просим у официанта воды."
            },
            {
              "language": "sq",
              "text": "I kërkojmë kamerierit ujë."
            },
            {
              "language": "tr",
              "text": "Garsondan su istiyoruz."
            }
          ]
        }
      ]
