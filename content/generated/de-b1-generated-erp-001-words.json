      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "معالجة؛ متابعة"
        },
        {
          "language": "ckb",
          "text": "چارەسەرکردن؛ کارکردن لەسەر"
        },
        {
          "language": "en",
          "text": "processing; handling"
        },
        {
          "language": "fa",
          "text": "پردازش؛ رسیدگی"
        },
        {
          "language": "kmr",
          "text": "xebitandin; rêvebirin"
        },
        {
          "language": "pl",
          "text": "przetwarzanie; obsługa"
        },
        {
          "language": "ro",
          "text": "procesare; gestionare"
        },
        {
          "language": "ru",
          "text": "обработка"
        },
        {
          "language": "sq",
          "text": "përpunim; trajtim"
        },
        {
          "language": "tr",
          "text": "işleme; ele alma"
        }
      ],
      "examples": [
        {
          "baseText": "Der Auftrag ist seit heute Morgen in Bearbeitung.",
          "translations": [
            {
              "language": "ar",
              "text": "الطلب قيد المعالجة منذ صباح اليوم."
            },
            {
              "language": "ckb",
              "text": "داواکارییەکە لە ئەم بەیانییەوە لە ژێر چارەسەرکردندایە."
            },
            {
              "language": "en",
              "text": "The order has been in progress since this morning."
            },
            {
              "language": "fa",
              "text": "سفارش از امروز صبح در حال رسیدگی است."
            },
            {
              "language": "kmr",
              "text": "Ferman ji vê sibehê ve di xebitandinê de ye."
            },
            {
              "language": "pl",
              "text": "Zamówienie jest w trakcie obsługi od dzisiejszego rana."
            },
            {
              "language": "ro",
              "text": "Comanda este în procesare de azi dimineață."
            },
            {
              "language": "ru",
              "text": "Заказ находится в обработке с сегодняшнего утра."
            },
            {
              "language": "sq",
              "text": "Porosia është në përpunim që nga mëngjesi i sotëm."
            },
            {
              "language": "tr",
              "text": "Sipariş bu sabahtan beri işleme alındı."
            }
          ]
        },
        {
          "baseText": "Die Bearbeitung der Reklamation dauert zwei Tage.",
          "translations": [
            {
              "language": "ar",
              "text": "تستغرق معالجة الشكوى يومين."
            },
            {
              "language": "ckb",
              "text": "چارەسەرکردنی سکاڵاکە دوو ڕۆژ دەخایەنێت."
            },
            {
              "language": "en",
              "text": "Processing the complaint takes two days."
            },
            {
              "language": "fa",
              "text": "رسیدگی به شکایت دو روز طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Xebitandina gilîkirinê du roj dirêj dike."
            },
            {
              "language": "pl",
              "text": "Obsługa reklamacji trwa dwa dni."
            },
            {
              "language": "ro",
              "text": "Procesarea reclamației durează două zile."
            },
            {
              "language": "ru",
              "text": "Обработка претензии занимает два дня."
            },
            {
              "language": "sq",
              "text": "Përpunimi i ankesës zgjat dy ditë."
            },
            {
              "language": "tr",
              "text": "Şikayetin işlenmesi iki gün sürer."
            }
          ]
        }
      ]
    },
