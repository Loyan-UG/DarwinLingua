    {
      "word": "Anfrage",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Anfragen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-fra-ge",
      "topics": [
        "business-communication",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; request or inquiry from a customer, supplier, or colleague"
      ],
      "collocations": [
        {
          "text": "eine Anfrage senden",
          "meaning": "to send an inquiry"
        },
        {
          "text": "eine Anfrage beantworten",
          "meaning": "to answer an inquiry"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "anfragen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استفسار؛ طلب معلومات"
        },
        {
          "language": "ckb",
          "text": "پرسیار؛ داواکاریی زانیاری"
        },
        {
          "language": "en",
          "text": "inquiry; request"
        },
        {
          "language": "fa",
          "text": "استعلام؛ درخواست اطلاعات"
        },
        {
          "language": "kmr",
          "text": "pirs; daxwaz"
        },
        {
          "language": "pl",
          "text": "zapytanie"
        },
        {
          "language": "ro",
          "text": "cerere; solicitare"
        },
        {
          "language": "ru",
          "text": "запрос"
        },
        {
          "language": "sq",
          "text": "kërkesë; pyetje"
        },
        {
          "language": "tr",
          "text": "talep; sorgu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Anfrage des Kunden ist im ERP gespeichert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم حفظ استفسار العميل في ERP."
            },
            {
              "language": "ckb",
              "text": "پرسیاری کڕیار لە ERP دا پاشەکەوت کراوە."
            },
            {
              "language": "en",
              "text": "The customer inquiry is saved in the ERP."
            },
            {
              "language": "fa",
              "text": "استعلام مشتری در ERP ذخیره شده است."
            },
            {
              "language": "kmr",
              "text": "Pirsa mişterî di ERP de hatiye tomarkirin."
            },
            {
              "language": "pl",
              "text": "Zapytanie klienta jest zapisane w ERP."
            },
            {
              "language": "ro",
              "text": "Cererea clientului este salvată în ERP."
            },
            {
              "language": "ru",
              "text": "Запрос клиента сохранен в ERP."
            },
            {
              "language": "sq",
              "text": "Kërkesa e klientit është ruajtur në ERP."
            },
            {
              "language": "tr",
              "text": "Müşteri talebi ERP’de kaydedildi."
            }
          ]
        },
        {
          "baseText": "Bitte beantworten Sie die Anfrage bis morgen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الرد على الاستفسار حتى الغد."
            },
            {
              "language": "ckb",
              "text": "تکایە تا سبەی وەڵامی پرسیارەکە بدەنەوە."
            },
            {
              "language": "en",
              "text": "Please answer the inquiry by tomorrow."
            },
            {
              "language": "fa",
              "text": "لطفاً تا فردا به درخواست پاسخ دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe heta sibê bersiva pirsê bidin."
            },
            {
              "language": "pl",
              "text": "Proszę odpowiedzieć na zapytanie do jutra."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să răspundeți la cerere până mâine."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, ответьте на запрос до завтра."
            },
            {
              "language": "sq",
              "text": "Ju lutemi përgjigjuni kërkesës deri nesër."
            },
            {
              "language": "tr",
              "text": "Lütfen talebi yarına kadar cevaplayın."
            }
          ]
        }
      ]
    },
    {
      "word": "Auftraggeber",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Auftraggeber",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Auf-trag-ge-ber",
      "topics": [
        "work-and-jobs",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; person or company that gives an order"
      ],
      "collocations": [
        {
          "text": "der Auftraggeber des Projekts",
          "meaning": "the client of the project"
        },
        {
          "text": "den Auftraggeber informieren",
          "meaning": "to inform the client"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Auftrag",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "geben",
          "relationLabel": "verb root",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "صاحب الطلب؛ العميل"
        },
        {
          "language": "ckb",
          "text": "داواکار؛ خاوەنی داواکاری"
        },
        {
          "language": "en",
          "text": "client; ordering party"
        },
        {
          "language": "fa",
          "text": "کارفرما؛ سفارش‌دهنده"
        },
        {
          "language": "kmr",
          "text": "fermandar; mişterî"
        },
        {
          "language": "pl",
          "text": "zleceniodawca"
        },
        {
          "language": "ro",
          "text": "client; beneficiar"
        },
        {
          "language": "ru",
          "text": "заказчик"
        },
        {
          "language": "sq",
          "text": "porositës; klient"
        },
        {
          "language": "tr",
          "text": "işveren; sipariş veren"
        }
      ],
      "examples": [
        {
          "baseText": "Der Auftraggeber möchte den Liefertermin ändern.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد صاحب الطلب تغيير موعد التسليم."
            },
            {
              "language": "ckb",
              "text": "داواکار دەیەوێت کاتی گەیاندن بگۆڕێت."
            },
            {
              "language": "en",
              "text": "The client wants to change the delivery date."
            },
            {
              "language": "fa",
              "text": "سفارش‌دهنده می‌خواهد تاریخ تحویل را تغییر دهد."
            },
            {
              "language": "kmr",
              "text": "Fermandar dixwaze roja radestkirinê biguherîne."
            },
            {
              "language": "pl",
              "text": "Zleceniodawca chce zmienić termin dostawy."
            },
            {
              "language": "ro",
              "text": "Clientul dorește să schimbe termenul de livrare."
            },
            {
              "language": "ru",
              "text": "Заказчик хочет изменить дату поставки."
            },
            {
              "language": "sq",
              "text": "Porositësi dëshiron të ndryshojë datën e dorëzimit."
            },
            {
              "language": "tr",
              "text": "Sipariş veren teslim tarihini değiştirmek istiyor."
            }
          ]
        },
        {
          "baseText": "Im ERP steht der Auftraggeber oben im Auftrag.",
          "translations": [
            {
              "language": "ar",
              "text": "في ERP يظهر صاحب الطلب في أعلى الطلب."
            },
            {
              "language": "ckb",
              "text": "لە ERP دا داواکار لە سەرەوەی داواکارییەکەدا نووسراوە."
            },
            {
              "language": "en",
              "text": "In the ERP, the client is shown at the top of the order."
            },
            {
              "language": "fa",
              "text": "در ERP سفارش‌دهنده در بالای سفارش نوشته شده است."
            },
            {
              "language": "kmr",
              "text": "Di ERP de fermandar li jorê fermanê xuya ye."
            },
            {
              "language": "pl",
              "text": "W ERP zleceniodawca jest widoczny na górze zamówienia."
            },
            {
              "language": "ro",
              "text": "În ERP, clientul apare sus în comandă."
            },
            {
              "language": "ru",
              "text": "В ERP заказчик указан в верхней части заказа."
            },
            {
              "language": "sq",
              "text": "Në ERP, porositësi shfaqet lart në porosi."
            },
            {
              "language": "tr",
              "text": "ERP’de sipariş veren siparişin üst kısmında görünür."
            }
          ]
        }
      ]
    },
