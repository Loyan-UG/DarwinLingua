  "entries": [
    {
      "word": "hinziehen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hinziehen",
      "pronunciationIpa": null,
      "syllableBreak": "hin-zie-hen",
      "topics": [
        "planning-and-projects",
        "business-communication",
        "everyday-life"
      ],
      "usageLabels": [
        "spoken",
        "business",
        "process"
      ],
      "contextLabels": [
        "management",
        "strategy",
        "support"
      ],
      "grammarNotes": [
        "separable strong verb: zieht hin, zog hin, hat/ist hingezogen",
        "can mean to drag something out, move toward a place, or be attracted to a place"
      ],
      "collocations": [
        {
          "text": "sich lange hinziehen",
          "meaning": "to drag on for a long time"
        },
        {
          "text": "sich zu einem Ort hingezogen fühlen",
          "meaning": "to feel drawn to a place"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "ziehen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "hin",
          "relationLabel": "adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يطول؛ يمتد؛ ينجذب إلى"
        },
        {
          "language": "ckb",
          "text": "درێژ دەبێتەوە؛ بەرەو شوێنێک دەکێشرێت"
        },
        {
          "language": "en",
          "text": "to drag on; to extend; to be drawn to"
        },
        {
          "language": "fa",
          "text": "طول کشیدن؛ کشیده شدن به سوی چیزی"
        },
        {
          "language": "kmr",
          "text": "dirêj bûn; ber bi cihekî ve kişandin"
        },
        {
          "language": "pl",
          "text": "przeciągać się; ciągnąć się"
        },
        {
          "language": "ro",
          "text": "a se prelungi; a fi atras spre"
        },
        {
          "language": "ru",
          "text": "затягиваться; тянуться к"
        },
        {
          "language": "sq",
          "text": "të zgjatet; të tërhiqesh drejt"
        },
        {
          "language": "tr",
          "text": "uzamak; çekilmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Abstimmung über das neue Design hat sich über mehrere Wochen hingezogen.",
          "translations": [
            {
              "language": "ar",
              "text": "امتد التصويت على التصميم الجديد لعدة أسابيع."
            },
            {
              "language": "ckb",
              "text": "دەنگدان لەسەر دیزاینی نوێ چەند هەفتەیەک درێژ بووەوە."
            },
            {
              "language": "en",
              "text": "The vote on the new design dragged on for several weeks."
            },
            {
              "language": "fa",
              "text": "رأی‌گیری درباره طراحی جدید چند هفته طول کشید."
            },
            {
              "language": "kmr",
              "text": "Dengdan li ser sêwirana nû çend hefteyan dirêj bû."
            },
            {
              "language": "pl",
              "text": "Głosowanie nad nowym projektem przeciągnęło się na kilka tygodni."
            },
            {
              "language": "ro",
              "text": "Votul asupra noului design s-a prelungit pe mai multe săptămâni."
            },
            {
              "language": "ru",
              "text": "Голосование по новому дизайну затянулось на несколько недель."
            },
            {
              "language": "sq",
              "text": "Votimi për dizajnin e ri u zgjat për disa javë."
            },
            {
              "language": "tr",
              "text": "Yeni tasarımla ilgili oylama birkaç hafta sürdü."
            }
          ]
        },
        {
          "baseText": "Seit ihrem Austauschsemester fühlt sie sich stark nach Wien hingezogen.",
          "translations": [
            {
              "language": "ar",
              "text": "منذ فصلها الدراسي التبادلي تشعر بانجذاب قوي إلى فيينا."
            },
            {
              "language": "ckb",
              "text": "لە دوای وەرزی خوێندنی ئاڵوگۆڕەکەیەوە، بەهێزی خۆی بەرەو ڤییەنا دەکێشرێت."
            },
            {
              "language": "en",
              "text": "Since her exchange semester, she has felt strongly drawn to Vienna."
            },
            {
              "language": "fa",
              "text": "از زمان ترم تبادلی‌اش، احساس کشش زیادی به وین دارد."
            },
            {
              "language": "kmr",
              "text": "Ji dema semestera guherandinê ve ew xwe pir ber bi Viyanayê ve kişandî dibîne."
            },
            {
              "language": "pl",
              "text": "Od semestru wymiennego czuje silne przyciąganie do Wiednia."
            },
            {
              "language": "ro",
              "text": "De la semestrul de schimb, se simte puternic atrasă de Viena."
            },
            {
              "language": "ru",
              "text": "После семестра по обмену ее сильно тянет в Вену."
            },
            {
              "language": "sq",
              "text": "Që nga semestri i shkëmbimit, ajo ndihet shumë e tërhequr drejt Vjenës."
            },
            {
              "language": "tr",
              "text": "Değişim döneminden beri kendini Viyana’ya güçlü şekilde çekilmiş hissediyor."
            }
          ]
        }
      ]
    }
  ],
