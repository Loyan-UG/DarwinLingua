  "entries": [
    {
      "word": "elektronisch",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "e-lek-tro-nisch",
      "topics": [
        "technology-and-it",
        "documents-and-administration",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "it",
        "software",
        "documents"
      ],
      "grammarNotes": [
        "adjective; often used for digital documents, messages, or devices"
      ],
      "collocations": [
        {
          "text": "elektronisch unterschreiben",
          "meaning": "to sign electronically"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Elektronik",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إلكتروني"
        },
        {
          "language": "ckb",
          "text": "ئەلیکترۆنی"
        },
        {
          "language": "en",
          "text": "electronic; digital"
        },
        {
          "language": "fa",
          "text": "الکترونیکی؛ دیجیتال"
        },
        {
          "language": "kmr",
          "text": "elektronîkî"
        },
        {
          "language": "pl",
          "text": "elektroniczny"
        },
        {
          "language": "ro",
          "text": "electronic"
        },
        {
          "language": "ru",
          "text": "электронный"
        },
        {
          "language": "sq",
          "text": "elektronik"
        },
        {
          "language": "tr",
          "text": "elektronik; dijital"
        }
      ],
      "examples": [
        {
          "baseText": "Sie können die Rechnung elektronisch erhalten.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنك استلام الفاتورة إلكترونيًا."
            },
            {
              "language": "ckb",
              "text": "دەتوانن پسوولەکە بە شێوەی ئەلیکترۆنی وەربگرن."
            },
            {
              "language": "en",
              "text": "You can receive the invoice electronically."
            },
            {
              "language": "fa",
              "text": "می‌توانید فاکتور را به صورت الکترونیکی دریافت کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin fatûreyê bi awayekî elektronîkî bistînin."
            },
            {
              "language": "pl",
              "text": "Mogą Państwo otrzymać fakturę elektronicznie."
            },
            {
              "language": "ro",
              "text": "Puteți primi factura în format electronic."
            },
            {
              "language": "ru",
              "text": "Вы можете получить счет в электронном виде."
            },
            {
              "language": "sq",
              "text": "Mund ta merrni faturën në mënyrë elektronike."
            },
            {
              "language": "tr",
              "text": "Faturayı elektronik olarak alabilirsiniz."
            }
          ]
        },
        {
          "baseText": "Der Antrag muss nicht per Post geschickt werden; er kann elektronisch eingereicht werden.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يجب إرسال الطلب بالبريد؛ يمكن تقديمه إلكترونيًا."
            },
            {
              "language": "ckb",
              "text": "داواکارییەکە پێویست نییە بە پۆست بنێردرێت؛ دەتوانرێت بە ئەلیکترۆنی پێشکەش بکرێت."
            },
            {
              "language": "en",
              "text": "The application does not have to be sent by post; it can be submitted electronically."
            },
            {
              "language": "fa",
              "text": "درخواست لازم نیست با پست ارسال شود؛ می‌توان آن را الکترونیکی ارائه کرد."
            },
            {
              "language": "kmr",
              "text": "Daxwaz ne pêwîst e bi postê were şandin; dikare elektronîkî were radestkirin."
            },
            {
              "language": "pl",
              "text": "Wniosek nie musi być wysyłany pocztą; można go złożyć elektronicznie."
            },
            {
              "language": "ro",
              "text": "Cererea nu trebuie trimisă prin poștă; poate fi depusă electronic."
            },
            {
              "language": "ru",
              "text": "Заявление не нужно отправлять по почте; его можно подать электронно."
            },
            {
              "language": "sq",
              "text": "Kërkesa nuk duhet të dërgohet me postë; mund të dorëzohet elektronikisht."
            },
            {
              "language": "tr",
              "text": "Başvurunun postayla gönderilmesi gerekmez; elektronik olarak sunulabilir."
            }
          ]
        }
      ]
    },
    {
      "word": "der Empfänger",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Empfänger",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Emp-fän-ger",
      "topics": [
        "documents-and-administration",
        "business-communication",
        "warehouse-and-logistics"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "documents",
