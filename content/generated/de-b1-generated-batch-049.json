        "customer-service"
      ],
      "grammarNotes": [
        "masculine noun; singular and plural often have the same form"
      ],
      "collocations": [
        {
          "text": "den Empfänger einer E-Mail prüfen",
          "meaning": "to check the recipient of an email"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "empfangen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "المستلم؛ المتلقي"
        },
        {
          "language": "ckb",
          "text": "وەرگر"
        },
        {
          "language": "en",
          "text": "recipient; receiver"
        },
        {
          "language": "fa",
          "text": "گیرنده؛ دریافت‌کننده"
        },
        {
          "language": "kmr",
          "text": "wergir"
        },
        {
          "language": "pl",
          "text": "odbiorca"
        },
        {
          "language": "ro",
          "text": "destinatar; receptor"
        },
        {
          "language": "ru",
          "text": "получатель"
        },
        {
          "language": "sq",
          "text": "marrës"
        },
        {
          "language": "tr",
          "text": "alıcı"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte prüfen Sie den Empfänger, bevor Sie die E-Mail senden.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق من المستلم قبل إرسال البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش ناردنی ئیمەیڵەکە وەرگرەکە بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the recipient before you send the email."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از ارسال ایمیل، گیرنده را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî şandina e-nameyê wergir kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić odbiorcę przed wysłaniem e-maila."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați destinatarul înainte de a trimite e-mailul."
            },
