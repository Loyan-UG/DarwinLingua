  "entries": [
    {
      "word": "schlagen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "schlagen",
      "pronunciationIpa": null,
      "syllableBreak": "schla-gen",
      "topics": [
        "everyday-life",
        "social-and-relationships",
        "work-and-jobs"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: schlägt, schlug, geschlagen; can mean to hit or to beat/defeat"
      ],
      "collocations": [
        {
          "text": "jemanden schlagen",
          "meaning": "to hit someone"
        },
        {
          "text": "einen Gegner schlagen",
          "meaning": "to beat an opponent"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Schlag",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "geschlagen",
          "relationLabel": "participle/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يضرب؛ يهزم"
        },
        {
          "language": "ckb",
          "text": "لێ دەدات؛ دەیبەزێنێت"
        },
        {
          "language": "en",
          "text": "to hit; to beat; to defeat"
        },
        {
          "language": "fa",
          "text": "زدن؛ شکست دادن"
        },
        {
          "language": "kmr",
          "text": "lêdan; têk birin"
        },
        {
          "language": "pl",
          "text": "bić; pokonać"
        },
        {
          "language": "ro",
          "text": "a lovi; a învinge"
        },
        {
          "language": "ru",
          "text": "бить; побеждать"
        },
        {
          "language": "sq",
          "text": "të godasësh; të mundësh"
        },
        {
          "language": "tr",
          "text": "vurmak; yenmek"
        }
      ],
      "examples": [
        {
          "baseText": "In der Schule darf niemand ein anderes Kind schlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "في المدرسة لا يجوز لأحد أن يضرب طفلًا آخر."
            },
            {
              "language": "ckb",
              "text": "لە قوتابخانە هیچ کەسێک نابێت منداڵێکی تر لێ بدات."
            },
            {
              "language": "en",
              "text": "At school, no one is allowed to hit another child."
            },
            {
              "language": "fa",
              "text": "در مدرسه هیچ‌کس نباید کودک دیگری را بزند."
            },
            {
              "language": "kmr",
              "text": "Li dibistanê kesek nikare zarokekî din lê bide."
            },
            {
              "language": "pl",
              "text": "W szkole nikomu nie wolno bić innego dziecka."
            },
            {
              "language": "ro",
              "text": "La școală nimeni nu are voie să lovească alt copil."
            },
            {
              "language": "ru",
              "text": "В школе никому нельзя бить другого ребёнка."
            },
            {
              "language": "sq",
              "text": "Në shkollë askush nuk lejohet të godasë një fëmijë tjetër."
            },
            {
              "language": "tr",
              "text": "Okulda kimse başka bir çocuğa vuramaz."
            }
          ]
        },
        {
          "baseText": "Unser Team hat den stärkeren Gegner knapp geschlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "فاز فريقنا على الخصم الأقوى بفارق بسيط."
            },
            {
              "language": "ckb",
              "text": "تیمەکەمان بە جیاوازییەکی کەم ڕکابەری بەهێزتری بردەوە."
            },
            {
              "language": "en",
              "text": "Our team narrowly beat the stronger opponent."
            },
            {
              "language": "fa",
              "text": "تیم ما حریف قوی‌تر را با اختلاف کمی شکست داد."
            },
            {
              "language": "kmr",
              "text": "Tîma me dijberê bihêztir bi kêmasiyek kêm têk bir."
            },
            {
              "language": "pl",
              "text": "Nasz zespół minimalnie pokonał silniejszego przeciwnika."
            },
            {
              "language": "ro",
              "text": "Echipa noastră a învins la limită adversarul mai puternic."
            },
            {
              "language": "ru",
              "text": "Наша команда с небольшим перевесом победила более сильного соперника."
            },
            {
              "language": "sq",
              "text": "Ekipi ynë e mundi ngushtë kundërshtarin më të fortë."
            },
            {
              "language": "tr",
              "text": "Takımımız daha güçlü rakibi az farkla yendi."
            }
          ]
        }
      ]
    },
    {
      "word": "die Schlagzeile",
      "language": "de",
