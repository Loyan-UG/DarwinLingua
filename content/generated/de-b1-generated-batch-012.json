      ],
      "collocations": [
        {
          "text": "die neue Arbeitgeberin",
          "meaning": "the new female employer"
        },
        {
          "text": "Pflichten der Arbeitgeberin",
          "meaning": "obligations of the employer"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Arbeitgeber",
          "relationLabel": "masculine form",
          "note": null
        },
        {
          "lemma": "der Arbeitnehmer",
          "relationLabel": "opposite noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "صاحبة العمل؛ جهة العمل"
        },
        {
          "language": "ckb",
          "text": "خاوەنکاری ژن؛ دامەزرێنەرە ژن"
        },
        {
          "language": "en",
          "text": "female employer; employer"
        },
        {
          "language": "fa",
          "text": "کارفرمای زن؛ کارفرما"
        },
        {
          "language": "kmr",
          "text": "kardêra jin; xwedîkara kar"
        },
        {
          "language": "pl",
          "text": "pracodawczyni"
        },
        {
          "language": "ro",
          "text": "angajatoare"
        },
        {
          "language": "ru",
          "text": "работодательница; работодатель"
        },
        {
          "language": "sq",
          "text": "punëdhënëse"
        },
        {
          "language": "tr",
          "text": "kadın işveren; işveren"
        }
      ],
      "examples": [
        {
          "baseText": "Die Arbeitgeberin muss den Arbeitsvertrag vor dem ersten Arbeitstag schicken.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على صاحبة العمل إرسال عقد العمل قبل أول يوم عمل."
            },
            {
              "language": "ckb",
              "text": "خاوەنکارە ژنەکە دەبێت پێش یەکەم ڕۆژی کار گرێبەستی کار بنێرێت."
            },
            {
              "language": "en",
              "text": "The employer must send the employment contract before the first working day."
            },
            {
              "language": "fa",
              "text": "کارفرما باید قرارداد کار را قبل از اولین روز کاری ارسال کند."
            },
            {
              "language": "kmr",
              "text": "Kardêra jin divê berî roja yekem a kar peymana karê bişîne."
            },
            {
              "language": "pl",
              "text": "Pracodawczyni musi wysłać umowę o pracę przed pierwszym dniem pracy."
            },
            {
              "language": "ro",
              "text": "Angajatoarea trebuie să trimită contractul de muncă înainte de prima zi de lucru."
            },
            {
              "language": "ru",
              "text": "Работодательница должна отправить трудовой договор до первого рабочего дня."
            },
            {
              "language": "sq",
              "text": "Punëdhënësja duhet ta dërgojë kontratën e punës para ditës së parë të punës."
            },
            {
              "language": "tr",
              "text": "İşveren, iş sözleşmesini ilk iş gününden önce göndermelidir."
            }
          ]
        },
        {
          "baseText": "Nach dem Gespräch wirkte die Arbeitgeberin sehr offen für flexible Arbeitszeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد المقابلة بدت صاحبة العمل منفتحة جدًا على ساعات العمل المرنة."
            },
            {
              "language": "ckb",
              "text": "دوای گفتوگۆکە خاوەنکارە ژنەکە زۆر کراوە بوو بۆ کاتی کاری نەرم."
            },
            {
              "language": "en",
              "text": "After the interview, the employer seemed very open to flexible working hours."
            },
            {
              "language": "fa",
              "text": "بعد از گفتگو، کارفرما نسبت به ساعات کاری منعطف بسیار باز به نظر می‌رسید."
            },
            {
              "language": "kmr",
              "text": "Piştî hevpeyvînê, kardêr ji bo demên karê yên nerm pir vekirî xuya bû."
            },
            {
              "language": "pl",
              "text": "Po rozmowie pracodawczyni wydawała się bardzo otwarta na elastyczne godziny pracy."
            },
            {
              "language": "ro",
              "text": "După discuție, angajatoarea părea foarte deschisă la program flexibil."
            },
            {
              "language": "ru",
              "text": "После разговора работодательница казалась очень открытой к гибкому графику."
            },
            {
              "language": "sq",
              "text": "Pas bisedës, punëdhënësja dukej shumë e hapur ndaj orareve fleksibël."
            },
            {
              "language": "tr",
              "text": "Görüşmeden sonra işveren esnek çalışma saatlerine oldukça açık görünüyordu."
            }
          ]
        }
      ]
    },
