      "word": "die Produktion",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Produktionen",
      "infinitive": null,
      "syllableBreak": "Pro-duk-ti-on",
      "topics": [
        "production-and-maintenance",
        "planning-and-projects",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Produktion planen",
          "meaning": "to plan production"
        },
        {
          "text": "die Produktion starten",
          "meaning": "to start production"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "produzieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "das Produkt",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "إنتاج"
        },
        {
          "language": "ckb",
          "text": "بەرهەمهێنان"
        },
        {
          "language": "en",
          "text": "production"
        },
        {
          "language": "fa",
          "text": "تولید"
        },
        {
          "language": "kmr",
          "text": "hilberîn"
        },
        {
          "language": "pl",
          "text": "produkcja"
        },
        {
          "language": "ro",
          "text": "producție"
        },
        {
          "language": "ru",
          "text": "производство"
        },
        {
          "language": "sq",
          "text": "prodhim"
        },
        {
          "language": "tr",
          "text": "üretim"
        }
      ],
      "examples": [
        {
          "baseText": "Die Produktion für den Auftrag ist im ERP-System für Montag geplant.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تخطيط إنتاج الطلب في نظام تخطيط موارد المؤسسة ليوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "بەرهەمهێنانی داواکارییەکە لە سیستەمی ERPدا بۆ دووشەممە پلاندانراوە."
            },
            {
              "language": "en",
              "text": "Production for the order is planned for Monday in the ERP system."
            },
            {
              "language": "fa",
              "text": "تولید این سفارش در سیستم ERP برای دوشنبه برنامه‌ریزی شده است."
            },
            {
              "language": "kmr",
              "text": "Hilberîna ji bo fermarişê di pergala ERP de ji bo duşemê hatiye plansazkirin."
            },
            {
              "language": "pl",
              "text": "Produkcja dla zamówienia jest zaplanowana w systemie ERP na poniedziałek."
            },
            {
              "language": "ro",
              "text": "Producția pentru comandă este planificată în sistemul ERP pentru luni."
            },
            {
              "language": "ru",
              "text": "Производство по заказу запланировано в ERP-системе на понедельник."
            },
            {
              "language": "sq",
              "text": "Prodhimi për porosinë është planifikuar në sistemin ERP për të hënën."
            },
            {
              "language": "tr",
              "text": "Siparişin üretimi ERP sisteminde pazartesi için planlandı."
            }
          ]
        },
        {
          "baseText": "In der Produktion arbeiten heute zwei Teams.",
          "translations": [
            {
              "language": "ar",
              "text": "اليوم يعمل فريقان في الإنتاج."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ دوو تیم لە بەرهەمهێناندا کار دەکەن."
            },
            {
              "language": "en",
              "text": "Two teams are working in production today."
            },
            {
              "language": "fa",
              "text": "امروز دو تیم در بخش تولید کار می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Îro du tîm di hilberînê de dixebitin."
            },
            {
              "language": "pl",
              "text": "Dziś w produkcji pracują dwa zespoły."
            },
            {
              "language": "ro",
              "text": "Astăzi lucrează două echipe în producție."
            },
            {
              "language": "ru",
              "text": "Сегодня на производстве работают две команды."
            },
            {
              "language": "sq",
              "text": "Sot në prodhim punojnë dy ekipe."
            },
            {
              "language": "tr",
              "text": "Bugün üretimde iki ekip çalışıyor."
            }
          ]
        }
      ]
    },
