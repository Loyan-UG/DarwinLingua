      "examples": [
        {
          "baseText": "Das ERP-System erstellt am Monatsende eine Sammelrechnung für den Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "ينشئ نظام تخطيط موارد المؤسسة في نهاية الشهر فاتورة مجمعة للعميل."
            },
            {
              "language": "ckb",
              "text": "سیستەمی ERP لە کۆتایی مانگدا فاکتورێکی کۆکراوە بۆ کڕیارەکە دروست دەکات."
            },
            {
              "language": "en",
              "text": "At the end of the month, the ERP system creates a consolidated invoice for the customer."
            },
            {
              "language": "fa",
              "text": "سیستم ERP در پایان ماه برای مشتری یک فاکتور تجمیعی ایجاد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pergala ERP di dawiya mehê de ji bo xerîdar fatûreyeke komkirî çêdike."
            },
            {
              "language": "pl",
              "text": "System ERP tworzy na koniec miesiąca fakturę zbiorczą dla klienta."
            },
            {
              "language": "ro",
              "text": "Sistemul ERP creează la sfârșitul lunii o factură centralizată pentru client."
            },
            {
              "language": "ru",
              "text": "В конце месяца ERP-система создает сводный счет для клиента."
            },
            {
              "language": "sq",
              "text": "Në fund të muajit, sistemi ERP krijon një faturë të përmbledhur për klientin."
            },
            {
              "language": "tr",
              "text": "ERP sistemi ay sonunda müşteri için toplu fatura oluşturur."
            }
          ]
        },
        {
          "baseText": "Bitte schicken Sie uns keine Einzelrechnung, sondern eine Sammelrechnung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى عدم إرسال فاتورة منفردة إلينا، بل فاتورة مجمعة."
            },
            {
              "language": "ckb",
              "text": "تکایە فاکتوری تاکمان بۆ مەبنێرن، بەڵکو فاکتوری کۆکراوە بنێرن."
            },
            {
              "language": "en",
              "text": "Please do not send us a single invoice, but a consolidated invoice."
            },
            {
              "language": "fa",
              "text": "لطفاً برای ما فاکتور تکی نفرستید، بلکه فاکتور تجمیعی ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fatûreya yekane ji me re neşînin, lê fatûreya komkirî bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę nie wysyłać nam pojedynczej faktury, tylko fakturę zbiorczą."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să nu ne trimiteți o factură separată, ci o factură centralizată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам не отдельный счет, а сводный счет."
            },
            {
              "language": "sq",
              "text": "Ju lutemi mos na dërgoni faturë të veçantë, por faturë të përmbledhur."
            },
            {
              "language": "tr",
              "text": "Lütfen bize tek fatura değil, toplu fatura gönderin."
            }
          ]
        }
