        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "مادة خام"
        },
        {
          "language": "ckb",
          "text": "ماددەی خاو"
        },
        {
          "language": "en",
          "text": "raw material"
        },
        {
          "language": "fa",
          "text": "مواد اولیه"
        },
        {
          "language": "kmr",
          "text": "maddeya xav"
        },
        {
          "language": "pl",
          "text": "surowiec"
        },
        {
          "language": "ro",
          "text": "materie primă"
        },
        {
          "language": "ru",
          "text": "сырье"
        },
        {
          "language": "sq",
          "text": "material i papërpunuar"
        },
        {
          "language": "tr",
          "text": "ham madde"
        }
      ],
      "examples": [
        {
          "baseText": "Das Rohmaterial ist im ERP-System für die Produktion reserviert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم حجز المادة الخام للإنتاج في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "ماددەی خاو لە سیستەمی ERPدا بۆ بەرهەمهێنان حجزکراوە."
            },
            {
              "language": "en",
              "text": "The raw material is reserved for production in the ERP system."
            },
            {
              "language": "fa",
              "text": "مواد اولیه در سیستم ERP برای تولید رزرو شده است."
            },
            {
              "language": "kmr",
              "text": "Maddeya xav di pergala ERP de ji bo hilberînê hatiye veqetandin."
            },
            {
              "language": "pl",
              "text": "Surowiec jest zarezerwowany do produkcji w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Materia primă este rezervată pentru producție în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Сырье зарезервировано для производства в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Materiali i papërpunuar është rezervuar për prodhim në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Ham madde ERP sisteminde üretim için rezerve edildi."
            }
          ]
        },
        {
          "baseText": "Ohne Rohmaterial kann die Maschine morgen nicht laufen.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون مادة خام لا يمكن للآلة أن تعمل غدًا."
            },
            {
              "language": "ckb",
              "text": "بێ ماددەی خاو مەکینەکە سبەی ناتوانێت کار بکات."
            },
            {
              "language": "en",
              "text": "Without raw material, the machine cannot run tomorrow."
            },
            {
              "language": "fa",
              "text": "بدون مواد اولیه، دستگاه فردا نمی‌تواند کار کند."
            },
            {
              "language": "kmr",
              "text": "Bê maddeya xav, makîne nikare sibê bixebite."
            },
            {
              "language": "pl",
              "text": "Bez surowca maszyna nie może jutro pracować."
            },
            {
              "language": "ro",
              "text": "Fără materie primă, mașina nu poate funcționa mâine."
            },
            {
              "language": "ru",
              "text": "Без сырья станок завтра не сможет работать."
            },
            {
              "language": "sq",
              "text": "Pa material të papërpunuar, makina nuk mund të punojë nesër."
            },
            {
              "language": "tr",
              "text": "Ham madde olmadan makine yarın çalışamaz."
            }
          ]
        }
      ]
    },
