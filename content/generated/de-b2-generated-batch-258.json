  "entries": [
    {
      "word": "vollziehen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vollziehen",
      "pronunciationIpa": null,
      "syllableBreak": "voll-zie-hen",
      "topics": [
        "management-and-leadership",
        "law-and-compliance",
        "planning-and-projects"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "legal",
        "administration"
      ],
      "grammarNotes": [
        "irregular verb: vollzieht, vollzog, hat vollzogen; often formal; also reflexive: sich vollziehen"
      ],
      "collocations": [
        {
          "text": "einen Schritt vollziehen",
          "meaning": "to carry out a step"
        },
        {
          "text": "eine Veränderung vollziehen",
          "meaning": "to undergo or carry out a change"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Vollzug",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "ziehen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينفّذ؛ يحدث أو يتم"
        },
        {
          "language": "ckb",
          "text": "جێبەجێ دەکات؛ ڕوودەدات"
        },
        {
          "language": "en",
          "text": "to carry out; to take place; to undergo"
        },
        {
          "language": "fa",
          "text": "انجام دادن؛ رخ دادن؛ طی کردن"
        },
        {
          "language": "kmr",
          "text": "cîbicî kirin; pêk hatin"
        },
        {
          "language": "pl",
          "text": "dokonać; odbywać się"
        },
        {
          "language": "ro",
          "text": "a realiza; a se produce"
        },
        {
          "language": "ru",
          "text": "совершить; происходить"
        },
        {
          "language": "sq",
          "text": "të kryesh; të ndodhë"
        },
        {
          "language": "tr",
          "text": "gerçekleştirmek; meydana gelmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Umstellung auf das neue System wird in mehreren Schritten vollzogen.",
          "translations": [
            {
              "language": "ar",
              "text": "سيتم الانتقال إلى النظام الجديد على عدة مراحل."
            },
            {
              "language": "ckb",
              "text": "گۆڕانکاری بۆ سیستەمی نوێ بە چەند هەنگاوێک جێبەجێ دەکرێت."
            },
            {
              "language": "en",
              "text": "The transition to the new system will be carried out in several steps."
            },
            {
              "language": "fa",
              "text": "تغییر به سیستم جدید در چند مرحله انجام می‌شود."
            },
            {
              "language": "kmr",
              "text": "Veguhertina bo pergala nû bi çend gavan tê cîbicîkirin."
            },
            {
              "language": "pl",
              "text": "Przejście na nowy system zostanie dokonane w kilku krokach."
            },
            {
              "language": "ro",
              "text": "Trecerea la noul sistem va fi realizată în mai mulți pași."
            },
            {
              "language": "ru",
              "text": "Переход на новую систему будет осуществлен в несколько этапов."
            },
            {
              "language": "sq",
              "text": "Kalimi në sistemin e ri do të kryhet në disa hapa."
            },
            {
              "language": "tr",
              "text": "Yeni sisteme geçiş birkaç adımda gerçekleştirilecek."
            }
          ]
        },
        {
          "baseText": "Der Wandel in der Abteilung hat sich schneller vollzogen als erwartet.",
          "translations": [
            {
              "language": "ar",
              "text": "حدث التغيير في القسم أسرع مما كان متوقعًا."
            },
            {
              "language": "ckb",
              "text": "گۆڕانکاری لە بەشەکەدا خێراتر لە چاوەڕوانکراو ڕوویدا."
            },
            {
              "language": "en",
              "text": "The change in the department took place faster than expected."
            },
            {
              "language": "fa",
              "text": "تغییر در بخش سریع‌تر از حد انتظار رخ داد."
            },
            {
              "language": "kmr",
              "text": "Guhertina di beşê de zûtir ji ya hêvîkirî pêk hat."
            },
            {
              "language": "pl",
              "text": "Zmiana w dziale dokonała się szybciej, niż oczekiwano."
            },
            {
              "language": "ro",
              "text": "Schimbarea din departament s-a produs mai repede decât se aștepta."
            },
            {
              "language": "ru",
              "text": "Изменение в отделе произошло быстрее, чем ожидалось."
            },
            {
              "language": "sq",
              "text": "Ndryshimi në departament ndodhi më shpejt se sa pritej."
            },
            {
              "language": "tr",
              "text": "Bölümdeki değişim beklenenden daha hızlı gerçekleşti."
            }
          ]
        }
      ]
    },
    {
      "word": "vor diesem Hintergrund",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "vor die-sem Hin-ter-grund",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "analytics",
        "documents"
      ],
      "grammarNotes": [
        "fixed phrase used to introduce a conclusion based on context; means against this background"
      ],
      "collocations": [
        {
          "text": "vor diesem Hintergrund entscheiden",
          "meaning": "to decide against this background"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Hintergrund",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "في هذا السياق؛ على هذه الخلفية"
        },
        {
          "language": "ckb",
          "text": "لەسەر ئەم بنەمایە؛ لەم پاشخانەدا"
        },
        {
          "language": "en",
          "text": "against this background; in this context"
        },
        {
          "language": "fa",
          "text": "در این زمینه؛ با توجه به این شرایط"
        },
        {
          "language": "kmr",
          "text": "li gorî vê paşxanê; di vê çarçoveyê de"
        },
        {
          "language": "pl",
          "text": "w tym kontekście; na tym tle"
        },
        {
          "language": "ro",
          "text": "în acest context"
        },
        {
          "language": "ru",
          "text": "на этом фоне; в этом контексте"
        },
        {
          "language": "sq",
          "text": "në këtë kontekst"
        },
        {
          "language": "tr",
          "text": "bu bağlamda; bu arka plan ışığında"
        }
      ],
      "examples": [
        {
          "baseText": "Vor diesem Hintergrund empfehlen wir, den Start des Projekts um zwei Wochen zu verschieben.",
          "translations": [
            {
              "language": "ar",
              "text": "في هذا السياق نوصي بتأجيل بدء المشروع أسبوعين."
            },
            {
              "language": "ckb",
              "text": "لەسەر ئەم بنەمایە پێشنیار دەکەین دەستپێکی پڕۆژەکە دوو هەفتە دوا بخەین."
            },
            {
              "language": "en",
              "text": "Against this background, we recommend postponing the project start by two weeks."
            },
            {
              "language": "fa",
              "text": "با توجه به این شرایط، توصیه می‌کنیم شروع پروژه دو هفته به تعویق بیفتد."
            },
            {
