      "meanings": [
        {
          "language": "ar",
          "text": "حي؛ منطقة في المدينة"
        },
        {
          "language": "ckb",
          "text": "گەڕەک؛ بەشێکی شار"
        },
        {
          "language": "en",
          "text": "district; part of a city"
        },
        {
          "language": "fa",
          "text": "محله؛ منطقه شهری"
        },
        {
          "language": "kmr",
          "text": "taxa bajêr; beşa bajêr"
        },
        {
          "language": "pl",
          "text": "dzielnica"
        },
        {
          "language": "ro",
          "text": "cartier; sector al orașului"
        },
        {
          "language": "ru",
          "text": "район города"
        },
        {
          "language": "sq",
          "text": "lagje; pjesë e qytetit"
        },
        {
          "language": "tr",
          "text": "semt; şehir bölgesi"
        }
      ],
      "examples": [
        {
          "baseText": "Wir wohnen in einem ruhigen Stadtteil.",
          "translations": [
            {
              "language": "ar",
              "text": "نحن نسكن في حي هادئ."
            },
            {
              "language": "ckb",
              "text": "ئێمە لە گەڕەکێکی ئارام دەژین."
            },
            {
              "language": "en",
              "text": "We live in a quiet district."
            },
            {
              "language": "fa",
              "text": "ما در یک محله آرام زندگی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em li taxeke aram dijîn."
            },
            {
              "language": "pl",
              "text": "Mieszkamy w spokojnej dzielnicy."
            },
            {
              "language": "ro",
              "text": "Locuim într-un cartier liniștit."
            },
            {
              "language": "ru",
              "text": "Мы живем в тихом районе."
            },
            {
              "language": "sq",
              "text": "Ne jetojmë në një lagje të qetë."
            },
            {
              "language": "tr",
              "text": "Sakin bir semtte oturuyoruz."
            }
          ]
        },
        {
          "baseText": "Dieser Stadtteil hat viele kleine Geschäfte.",
          "translations": [
            {
              "language": "ar",
              "text": "يوجد في هذا الحي كثير من المتاجر الصغيرة."
            },
            {
              "language": "ckb",
              "text": "ئەم گەڕەکە دوکانی بچووک زۆری هەیە."
            },
            {
              "language": "en",
              "text": "This district has many small shops."
            },
            {
              "language": "fa",
              "text": "این محله مغازه‌های کوچک زیادی دارد."
            },
            {
              "language": "kmr",
              "text": "Di vê taxê de gelek dikanên biçûk hene."
            },
            {
              "language": "pl",
              "text": "Ta dzielnica ma wiele małych sklepów."
            },
            {
              "language": "ro",
              "text": "Acest cartier are multe magazine mici."
            },
            {
              "language": "ru",
              "text": "В этом районе много маленьких магазинов."
            },
            {
              "language": "sq",
              "text": "Kjo lagje ka shumë dyqane të vogla."
            },
            {
              "language": "tr",
              "text": "Bu semtte birçok küçük dükkân var."
            }
          ]
        }
      ]
    },
