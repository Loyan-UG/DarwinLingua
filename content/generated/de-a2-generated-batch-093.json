          "lemma": "die Stadt",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Plan",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خريطة المدينة"
        },
        {
          "language": "ckb",
          "text": "نەخشەی شار"
        },
        {
          "language": "en",
          "text": "city map"
        },
        {
          "language": "fa",
          "text": "نقشه شهر"
        },
        {
          "language": "kmr",
          "text": "nexşeya bajêr"
        },
        {
          "language": "pl",
          "text": "plan miasta"
        },
        {
          "language": "ro",
          "text": "hartă a orașului"
        },
        {
          "language": "ru",
          "text": "карта города"
        },
        {
          "language": "sq",
          "text": "hartë qyteti"
        },
        {
          "language": "tr",
          "text": "şehir haritası"
        }
      ],
      "examples": [
        {
          "baseText": "Haben Sie einen Stadtplan für Touristen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل لديكم خريطة مدينة للسياح؟"
            },
            {
              "language": "ckb",
              "text": "ئایا نەخشەی شار بۆ گەشتیاران هەتانە؟"
            },
            {
              "language": "en",
              "text": "Do you have a city map for tourists?"
            },
            {
              "language": "fa",
              "text": "آیا نقشه شهر برای گردشگران دارید؟"
            },
            {
              "language": "kmr",
              "text": "Ma nexşeya bajêr ji bo geştiyaran heye?"
            },
            {
              "language": "pl",
              "text": "Czy mają państwo plan miasta dla turystów?"
            },
            {
              "language": "ro",
              "text": "Aveți o hartă a orașului pentru turiști?"
            },
            {
              "language": "ru",
              "text": "У вас есть карта города для туристов?"
            },
            {
              "language": "sq",
              "text": "A keni një hartë qyteti për turistët?"
            },
            {
              "language": "tr",
              "text": "Turistler için şehir haritanız var mı?"
            }
          ]
        },
        {
          "baseText": "Ich finde die Straße auf dem Stadtplan nicht.",
          "translations": [
            {
              "language": "ar",
              "text": "لا أجد الشارع على خريطة المدينة."
            },
            {
              "language": "ckb",
              "text": "من ئەو شەقامە لەسەر نەخشەی شار نادۆزمەوە."
            },
            {
              "language": "en",
              "text": "I cannot find the street on the city map."
            },
            {
              "language": "fa",
              "text": "من خیابان را روی نقشه شهر پیدا نمی‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez kolanê li ser nexşeya bajêr nabînim."
            },
            {
              "language": "pl",
              "text": "Nie znajduję tej ulicy na planie miasta."
            },
            {
              "language": "ro",
              "text": "Nu găsesc strada pe harta orașului."
            },
            {
              "language": "ru",
              "text": "Я не нахожу улицу на карте города."
            },
            {
              "language": "sq",
              "text": "Nuk e gjej rrugën në hartën e qytetit."
            },
            {
              "language": "tr",
              "text": "Sokağı şehir haritasında bulamıyorum."
            }
          ]
        }
      ]
    },
