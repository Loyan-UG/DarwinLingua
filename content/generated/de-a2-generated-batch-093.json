      ],
      "collocations": [
        {
          "text": "an einer Stadtführung teilnehmen",
          "meaning": "to take part in a city tour"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Stadt",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "führen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جولة في المدينة"
        },
        {
          "language": "ckb",
          "text": "گەشتێکی ناساندنی شار"
        },
        {
          "language": "en",
          "text": "city tour; guided city walk"
        },
        {
          "language": "fa",
          "text": "تور شهری؛ راهنمایی در شهر"
        },
        {
          "language": "kmr",
          "text": "gera bajêr; gera bi rêber"
        },
        {
          "language": "pl",
          "text": "zwiedzanie miasta z przewodnikiem"
        },
        {
          "language": "ro",
          "text": "tur ghidat al orașului"
        },
        {
          "language": "ru",
          "text": "экскурсия по городу"
        },
        {
          "language": "sq",
          "text": "tur qyteti me guidë"
        },
        {
          "language": "tr",
          "text": "şehir turu; rehberli şehir gezisi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Stadtführung beginnt um zehn Uhr am Rathaus.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدأ جولة المدينة في الساعة العاشرة عند البلدية."
            },
            {
              "language": "ckb",
              "text": "گەشتەکەی شار کاتژمێر دە لە لای شارەوانی دەست پێدەکات."
            },
            {
              "language": "en",
              "text": "The city tour starts at ten o’clock at the town hall."
            },
            {
              "language": "fa",
              "text": "تور شهری ساعت ده از جلوی شهرداری شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Gera bajêr di saet dehan de li ber şaredariyê dest pê dike."
            },
            {
              "language": "pl",
              "text": "Zwiedzanie miasta zaczyna się o dziesiątej przy ratuszu."
            },
            {
              "language": "ro",
              "text": "Turul ghidat al orașului începe la ora zece la primărie."
            },
            {
              "language": "ru",
              "text": "Экскурсия по городу начинается в десять у ратуши."
            },
            {
              "language": "sq",
              "text": "Turi i qytetit fillon në orën dhjetë te bashkia."
            },
            {
              "language": "tr",
              "text": "Şehir turu saat onda belediye binasında başlıyor."
            }
          ]
        },
        {
          "baseText": "Kann ich die Stadtführung auch auf Englisch buchen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني حجز جولة المدينة أيضاً باللغة الإنجليزية؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم گەشتەکەی شار بە ئینگلیزیش حجز بکەم؟"
            },
            {
              "language": "en",
              "text": "Can I also book the city tour in English?"
            },
            {
              "language": "fa",
              "text": "آیا می‌توانم تور شهری را به انگلیسی هم رزرو کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim gera bajêr bi îngilîzî jî veqetînim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę zarezerwować zwiedzanie miasta także po angielsku?"
            },
            {
              "language": "ro",
              "text": "Pot rezerva turul orașului și în engleză?"
            },
            {
              "language": "ru",
              "text": "Могу я забронировать экскурсию по городу также на английском?"
            },
            {
              "language": "sq",
              "text": "A mund ta rezervoj turin e qytetit edhe në anglisht?"
            },
            {
              "language": "tr",
              "text": "Şehir turunu İngilizce olarak da rezerve edebilir miyim?"
            }
          ]
        }
      ]
    },
    {
