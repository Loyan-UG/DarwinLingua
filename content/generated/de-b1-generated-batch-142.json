  "entries": [
    {
      "word": "vermuten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vermuten",
      "pronunciationIpa": null,
      "syllableBreak": "ver-mu-ten",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "einen Fehler vermuten",
          "meaning": "to suspect an error"
        },
        {
          "text": "ich vermute, dass...",
          "meaning": "I assume that..."
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Vermutung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يظن؛ يفترض؛ يشتبه"
        },
        {
          "language": "ckb",
          "text": "گومان کردن؛ پێشبینی کردن"
        },
        {
          "language": "en",
          "text": "to assume; to suspect"
        },
        {
          "language": "fa",
          "text": "حدس زدن؛ گمان کردن"
        },
        {
          "language": "kmr",
          "text": "guman kirin; texmîn kirin"
        },
        {
          "language": "pl",
          "text": "przypuszczać; podejrzewać"
        },
        {
          "language": "ro",
          "text": "a presupune; a suspecta"
        },
        {
          "language": "ru",
          "text": "предполагать; подозревать"
        },
        {
          "language": "sq",
          "text": "të supozosh; të dyshosh"
        },
        {
          "language": "tr",
          "text": "tahmin etmek; şüphelenmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir vermuten, dass der Fehler nach dem letzten Update entstanden ist.",
          "translations": [
            {
              "language": "ar",
              "text": "نظن أن الخطأ ظهر بعد آخر تحديث."
            },
            {
              "language": "ckb",
              "text": "گومان دەکەین هەڵەکە دوای نوێکردنەوەی کۆتایی دروست بووبێت."
            },
            {
              "language": "en",
              "text": "We suspect that the error occurred after the last update."
            },
            {
              "language": "fa",
              "text": "حدس می‌زنیم خطا بعد از آخرین به‌روزرسانی ایجاد شده باشد."
            },
            {
              "language": "kmr",
              "text": "Em guman dikin ku şaşî piştî nûkirina dawî çêbûye."
            },
            {
              "language": "pl",
              "text": "Przypuszczamy, że błąd pojawił się po ostatniej aktualizacji."
            },
            {
              "language": "ro",
              "text": "Presupunem că eroarea a apărut după ultima actualizare."
            },
            {
              "language": "ru",
              "text": "Мы предполагаем, что ошибка возникла после последнего обновления."
            },
            {
              "language": "sq",
              "text": "Ne supozojmë se gabimi ka ndodhur pas përditësimit të fundit."
            },
            {
              "language": "tr",
              "text": "Hatanın son güncellemeden sonra oluştuğunu tahmin ediyoruz."
            }
          ]
        },
        {
          "baseText": "Ich vermute, dass der Zug heute wegen des Wetters später kommt.",
          "translations": [
            {
              "language": "ar",
              "text": "أظن أن القطار سيأتي اليوم متأخرًا بسبب الطقس."
            },
            {
              "language": "ckb",
              "text": "پێم وایە ئەمڕۆ شەمەندەفەرەکە بەهۆی کەشەوە درەنگتر دێت."
            },
            {
              "language": "en",
              "text": "I assume the train will arrive later today because of the weather."
            },
            {
              "language": "fa",
              "text": "حدس می‌زنم قطار امروز به دلیل هوا دیرتر برسد."
            },
            {
              "language": "kmr",
              "text": "Ez texmîn dikim ku trên îro ji ber hewayê derengtir bê."
            },
            {
              "language": "pl",
              "text": "Przypuszczam, że pociąg przyjedzie dziś później z powodu pogody."
            },
            {
              "language": "ro",
              "text": "Presupun că trenul va veni azi mai târziu din cauza vremii."
            },
            {
              "language": "ru",
              "text": "Я предполагаю, что поезд сегодня придет позже из-за погоды."
            },
            {
              "language": "sq",
              "text": "Supozoj se treni sot do të vijë më vonë për shkak të motit."
            },
            {
              "language": "tr",
              "text": "Bugün trenin hava nedeniyle daha geç geleceğini tahmin ediyorum."
            }
          ]
        }
      ]
    },
    {
      "word": "die Vermutung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Vermutungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-mu-tung",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Vermutung bestätigen",
          "meaning": "to confirm an assumption"
        },
        {
          "text": "eine Vermutung äußern",
          "meaning": "to express an assumption"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vermuten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "افتراض؛ ظن؛ شبهة"
        },
        {
          "language": "ckb",
          "text": "گومان؛ پێشبینی"
        },
        {
          "language": "en",
          "text": "assumption; suspicion"
        },
        {
          "language": "fa",
          "text": "حدس؛ گمان؛ فرض"
        },
        {
          "language": "kmr",
          "text": "guman; texmîn"
        },
        {
          "language": "pl",
          "text": "przypuszczenie; podejrzenie"
        },
        {
          "language": "ro",
          "text": "presupunere; suspiciune"
        },
        {
          "language": "ru",
          "text": "предположение; подозрение"
        },
        {
          "language": "sq",
          "text": "supozim; dyshim"
        },
        {
          "language": "tr",
          "text": "varsayım; şüphe"
        }
      ],
      "examples": [
        {
          "baseText": "Die Logdateien bestätigen unsere Vermutung nicht.",
          "translations": [
            {
              "language": "ar",
              "text": "ملفات السجل لا تؤكد افتراضنا."
            },
            {
              "language": "ckb",
              "text": "فایلەکانی لۆگ گومانەکەمان پشتڕاست ناکەنەوە."
            },
            {
              "language": "en",
              "text": "The log files do not confirm our assumption."
            },
            {
              "language": "fa",
              "text": "فایل‌های لاگ حدس ما را تأیید نمی‌کنند."
            },
            {
              "language": "kmr",
              "text": "Pelên logê gumanê me piştrast nakin."
            },
            {
              "language": "pl",
              "text": "Pliki logów nie potwierdzają naszego przypuszczenia."
            },
            {
              "language": "ro",
              "text": "Fișierele jurnal nu confirmă presupunerea noastră."
            },
            {
              "language": "ru",
              "text": "Файлы журналов не подтверждают наше предположение."
            },
            {
              "language": "sq",
              "text": "Skedarët log nuk e konfirmojnë supozimin tonë."
            },
            {
              "language": "tr",
              "text": "Log dosyaları varsayımımızı doğrulamıyor."
            }
          ]
        },
        {
          "baseText": "Das ist nur eine Vermutung; wir brauchen noch genaue Zahlen.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا مجرد افتراض؛ ما زلنا نحتاج إلى أرقام دقيقة."
            },
            {
              "language": "ckb",
              "text": "ئەمە تەنها گومانە؛ هێشتا پێویستمان بە ژمارەی ورد هەیە."
            },
            {
              "language": "en",
              "text": "That is only an assumption; we still need exact figures."
            },
            {
              "language": "fa",
              "text": "این فقط یک حدس است؛ هنوز به ارقام دقیق نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ev tenê gumanek e; em hîn hewceyê hejmarên rast in."
            },
            {
              "language": "pl",
              "text": "To tylko przypuszczenie; potrzebujemy jeszcze dokładnych danych."
            },
            {
              "language": "ro",
              "text": "Este doar o presupunere; avem încă nevoie de cifre exacte."
            },
            {
              "language": "ru",
              "text": "Это только предположение; нам еще нужны точные цифры."
            },
            {
              "language": "sq",
              "text": "Ky është vetëm një supozim; na duhen ende shifra të sakta."
            },
            {
              "language": "tr",
              "text": "Bu sadece bir varsayım; hâlâ kesin rakamlara ihtiyacımız var."
            }
          ]
        }
      ]
    },
    {
      "word": "die Verpackung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Verpackungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-pa-ckung",
      "topics": [
        "shopping-and-services",
        "warehouse-and-logistics",
        "environment-and-sustainability"
      ],
      "usageLabels": [
        "everyday",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Verpackung öffnen",
          "meaning": "to open the packaging"
        },
        {
          "text": "umweltfreundliche Verpackung",
          "meaning": "environmentally friendly packaging"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verpacken",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تغليف؛ عبوة"
        },
        {
          "language": "ckb",
          "text": "پاکەتکردن؛ بەرگ/قاپ"
        },
        {
          "language": "en",
          "text": "packaging"
        },
        {
          "language": "fa",
          "text": "بسته‌بندی"
        },
        {
          "language": "kmr",
          "text": "pakêtkirin; berg"
        },
        {
          "language": "pl",
          "text": "opakowanie"
        },
        {
          "language": "ro",
          "text": "ambalaj"
        },
        {
          "language": "ru",
          "text": "упаковка"
        },
        {
          "language": "sq",
          "text": "paketim; ambalazh"
        },
        {
          "language": "tr",
          "text": "ambalaj; paketleme"
        }
      ],
      "examples": [
        {
          "baseText": "Die Verpackung war beschädigt, aber das Gerät funktioniert.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت العبوة متضررة، لكن الجهاز يعمل."
            },
            {
              "language": "ckb",
              "text": "بەرگی کاڵاکە زیانمەن بوو، بەڵام ئامێرەکە کار دەکات."
            },
            {
              "language": "en",
              "text": "The packaging was damaged, but the device works."
            },
            {
              "language": "fa",
              "text": "بسته‌بندی آسیب دیده بود، اما دستگاه کار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pakêt zirar dîtibû, lê amûr dixebite."
            },
            {
              "language": "pl",
              "text": "Opakowanie było uszkodzone, ale urządzenie działa."
            },
            {
              "language": "ro",
              "text": "Ambalajul era deteriorat, dar dispozitivul funcționează."
            },
            {
              "language": "ru",
              "text": "Упаковка была повреждена, но устройство работает."
            },
            {
              "language": "sq",
              "text": "Paketimi ishte i dëmtuar, por pajisja funksionon."
            },
            {
              "language": "tr",
              "text": "Ambalaj hasarlıydı ama cihaz çalışıyor."
            }
          ]
        },
        {
          "baseText": "Unsere Firma möchte weniger Plastik in der Verpackung verwenden.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد شركتنا استخدام كمية أقل من البلاستيك في التغليف."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکەمان دەیەوێت پلاستیکی کەمتر لە پاکەتکردندا بەکاربهێنێت."
            },
            {
              "language": "en",
              "text": "Our company wants to use less plastic in the packaging."
            },
            {
              "language": "fa",
              "text": "شرکت ما می‌خواهد در بسته‌بندی پلاستیک کمتری استفاده کند."
            },
            {
              "language": "kmr",
