      "examples": [
        {
          "baseText": "Ich nehme das Medikament nach dem Essen.",
          "translations": [
            {
              "language": "ar",
              "text": "أتناول الدواء بعد الطعام."
            },
            {
              "language": "ckb",
              "text": "دەرمانەکە دوای خواردن دەخۆم."
            },
            {
              "language": "en",
              "text": "I take the medicine after eating."
            },
            {
              "language": "fa",
              "text": "دارو را بعد از غذا می‌خورم."
            },
            {
              "language": "kmr",
              "text": "Ez dermanê piştî xwarinê dixwim."
            },
            {
              "language": "pl",
              "text": "Biorę lek po jedzeniu."
            },
            {
              "language": "ro",
              "text": "Iau medicamentul după masă."
            },
            {
              "language": "ru",
              "text": "Я принимаю лекарство после еды."
            },
            {
              "language": "sq",
              "text": "E marr ilaçin pas ushqimit."
            },
            {
              "language": "tr",
              "text": "İlacı yemekten sonra alıyorum."
            }
          ]
        },
        {
          "baseText": "Das Medikament bekomme ich in der Apotheke.",
          "translations": [
            {
              "language": "ar",
              "text": "أحصل على الدواء من الصيدلية."
            },
            {
              "language": "ckb",
              "text": "دەرمانەکە لە دەرمانخانە وەردەگرم."
            },
            {
              "language": "en",
              "text": "I get the medicine at the pharmacy."
            },
            {
              "language": "fa",
              "text": "دارو را از داروخانه می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez dermanê ji dermanxaneyê distînim."
            },
            {
              "language": "pl",
              "text": "Dostaję lek w aptece."
            },
            {
              "language": "ro",
              "text": "Primesc medicamentul de la farmacie."
            },
            {
              "language": "ru",
              "text": "Я получаю лекарство в аптеке."
            },
            {
              "language": "sq",
              "text": "Ilaçin e marr në farmaci."
            },
            {
              "language": "tr",
              "text": "İlacı eczaneden alıyorum."
            }
          ]
        }
