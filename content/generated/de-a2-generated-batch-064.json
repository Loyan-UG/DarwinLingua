        },
        {
          "language": "sq",
          "text": "mendim"
        },
        {
          "language": "tr",
          "text": "fikir; görüş"
        }
      ],
      "examples": [
        {
          "baseText": "Was ist deine Meinung zu dem Plan?",
          "translations": [
            {
              "language": "ar",
              "text": "ما رأيك في الخطة؟"
            },
            {
              "language": "ckb",
              "text": "بۆچوونت دەربارەی پلانەکە چییە؟"
            },
            {
              "language": "en",
              "text": "What is your opinion about the plan?"
            },
            {
              "language": "fa",
              "text": "نظر تو درباره برنامه چیست؟"
            },
            {
              "language": "kmr",
              "text": "Rêya te li ser planê çi ye?"
            },
            {
              "language": "pl",
              "text": "Jaka jest twoja opinia o planie?"
            },
            {
              "language": "ro",
              "text": "Care este opinia ta despre plan?"
            },
            {
              "language": "ru",
              "text": "Какое твоё мнение о плане?"
            },
            {
              "language": "sq",
              "text": "Cili është mendimi yt për planin?"
            },
            {
              "language": "tr",
              "text": "Plan hakkındaki fikrin nedir?"
            }
          ]
        },
        {
          "baseText": "Im Kurs darf jeder seine Meinung sagen.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدورة يمكن لكل شخص أن يقول رأيه."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسەکەدا هەموو کەس دەتوانێت بۆچوونی خۆی بڵێت."
            },
            {
              "language": "en",
              "text": "In the course, everyone may say their opinion."
            },
            {
              "language": "fa",
              "text": "در کلاس هر کس می‌تواند نظرش را بگوید."
            },
            {
              "language": "kmr",
              "text": "Di kursê de her kes dikare raya xwe bibêje."
            },
            {
              "language": "pl",
              "text": "Na kursie każdy może powiedzieć swoją opinię."
            },
            {
              "language": "ro",
              "text": "La curs fiecare poate să își spună opinia."
            },
            {
              "language": "ru",
              "text": "На курсе каждый может высказать своё мнение."
            },
            {
              "language": "sq",
              "text": "Në kurs secili mund të thotë mendimin e vet."
            },
            {
              "language": "tr",
              "text": "Kursta herkes fikrini söyleyebilir."
            }
          ]
        }
      ]
    },
