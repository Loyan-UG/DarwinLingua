      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: hinterzieht, hinterzog, hat hinterzogen; mainly used with taxes or duties"
      ],
      "collocations": [
        {
          "text": "Steuern hinterziehen",
          "meaning": "to evade taxes"
        },
        {
          "text": "Abgaben hinterziehen",
          "meaning": "to evade charges or duties"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Steuerhinterziehung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتهرب من الضرائب؛ يتهرب من دفع مستحقات"
        },
        {
          "language": "ckb",
          "text": "باج دەدزێت؛ خۆی لە پارەدانی یاسایی دەدزێتەوە"
        },
        {
          "language": "en",
          "text": "to evade taxes; to evade duties"
        },
        {
          "language": "fa",
          "text": "فرار مالیاتی کردن؛ از پرداخت قانونی گریختن"
        },
        {
          "language": "kmr",
          "text": "bac dizîn; ji dayîna qanûnî dûrketin"
        },
        {
          "language": "pl",
          "text": "uchylać się od podatków; zatajać należności"
        },
        {
          "language": "ro",
          "text": "a evada taxe; a se sustrage de la plăți"
        },
        {
          "language": "ru",
          "text": "уклоняться от налогов; скрывать платежи"
        },
        {
          "language": "sq",
          "text": "të shmangësh taksat; të fshehësh detyrime"
        },
