  "entries": [
    {
      "word": "hintergehen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hintergehen",
      "pronunciationIpa": null,
      "syllableBreak": "hin-ter-ge-hen",
      "topics": [
        "social-and-relationships",
        "contracts-and-negotiation",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: hintergeht, hinterging, hat hintergangen"
      ],
      "collocations": [
        {
          "text": "jemandes Vertrauen hintergehen",
          "meaning": "to betray someone’s trust"
        },
        {
          "text": "einen Partner hintergehen",
          "meaning": "to deceive a partner"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Hintergang",
          "relationLabel": "noun",
          "note": "rare noun"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يخون؛ يخدع"
        },
        {
          "language": "ckb",
          "text": "خیانەت دەکات؛ فێڵ دەکات"
        },
        {
          "language": "en",
          "text": "to betray; to deceive"
        },
        {
          "language": "fa",
          "text": "خیانت کردن؛ فریب دادن"
        },
        {
          "language": "kmr",
          "text": "xiyanet kirin; xapandin"
        },
        {
          "language": "pl",
          "text": "zdradzić; oszukać"
        },
        {
          "language": "ro",
          "text": "a trăda; a înșela"
        },
        {
          "language": "ru",
          "text": "предавать; обманывать"
        },
        {
          "language": "sq",
          "text": "të tradhtosh; të mashtrosh"
        },
        {
          "language": "tr",
          "text": "ihanet etmek; aldatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wer vertrauliche Informationen weitergibt, hintergeht das Vertrauen des Teams.",
          "translations": [
            {
              "language": "ar",
              "text": "من يمرر معلومات سرية يخون ثقة الفريق."
            },
            {
              "language": "ckb",
              "text": "ئەوەی زانیاری نهێنی دەگوازێتەوە، متمانەی تیمەکە دەشکێنێت."
            },
            {
              "language": "en",
              "text": "Anyone who passes on confidential information betrays the team’s trust."
            },
            {
              "language": "fa",
              "text": "کسی که اطلاعات محرمانه را منتقل کند، به اعتماد تیم خیانت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Kesê agahiyên nepenî derbas bike, baweriya tîmê dixapîne."
            },
            {
              "language": "pl",
              "text": "Kto przekazuje poufne informacje, zdradza zaufanie zespołu."
            },
            {
              "language": "ro",
              "text": "Cine transmite informații confidențiale trădează încrederea echipei."
            },
            {
              "language": "ru",
              "text": "Тот, кто передает конфиденциальную информацию, предает доверие команды."
            },
            {
              "language": "sq",
              "text": "Kush përcjell informacione konfidenciale tradhton besimin e ekipit."
            },
            {
              "language": "tr",
              "text": "Gizli bilgileri aktaran kişi ekibin güvenine ihanet eder."
            }
          ]
        },
        {
          "baseText": "Sie fühlte sich hintergangen, weil die Entscheidung ohne sie vorbereitet worden war.",
          "translations": [
            {
              "language": "ar",
              "text": "شعرت بأنها خُدعت لأن القرار أُعد من دونها."
            },
            {
              "language": "ckb",
              "text": "هەستی کرد فێڵی لێکراوە چونکە بڕیارەکە بەبێ ئەو ئامادەکرابوو."
            },
            {
              "language": "en",
              "text": "She felt deceived because the decision had been prepared without her."
            },
            {
              "language": "fa",
              "text": "او احساس کرد فریب خورده است، چون تصمیم بدون حضور او آماده شده بود."
            },
            {
              "language": "kmr",
              "text": "Wê hest kir hatî xapandin, ji ber ku biryar bê wê hatibû amadekirin."
            },
            {
              "language": "pl",
              "text": "Czuła się oszukana, ponieważ decyzję przygotowano bez niej."
            },
            {
              "language": "ro",
              "text": "Ea s-a simțit trădată, deoarece decizia fusese pregătită fără ea."
            },
            {
              "language": "ru",
              "text": "Она почувствовала себя обманутой, потому что решение подготовили без нее."
            },
            {
              "language": "sq",
              "text": "Ajo u ndje e tradhtuar sepse vendimi ishte përgatitur pa të."
            },
            {
              "language": "tr",
              "text": "Karar onsuz hazırlandığı için aldatılmış hissetti."
            }
          ]
        }
      ]
    },
    {
      "word": "hintertreiben",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hintertreiben",
      "pronunciationIpa": null,
      "syllableBreak": "hin-ter-trei-ben",
      "topics": [
        "management-and-leadership",
        "contracts-and-negotiation",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: hintertreibt, hintertrieb, hat hintertrieben"
      ],
      "collocations": [
        {
          "text": "eine Einigung hintertreiben",
          "meaning": "to sabotage an agreement"
        },
        {
          "text": "Verhandlungen hintertreiben",
          "meaning": "to undermine negotiations"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "treiben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعرقل؛ يفسد عمدًا؛ يقوّض"
        },
        {
          "language": "ckb",
          "text": "ڕێگری دەکات؛ بە مەبەست تێک دەدات"
        },
        {
          "language": "en",
          "text": "to obstruct; to sabotage; to undermine"
        },
        {
          "language": "fa",
          "text": "کارشکنی کردن؛ عمداً مختل کردن"
        },
        {
          "language": "kmr",
          "text": "asteng kirin; bi mebest têkdan"
        },
        {
          "language": "pl",
          "text": "udaremniać; sabotować"
        },
        {
          "language": "ro",
          "text": "a zădărnici; a sabota"
        },
        {
          "language": "ru",
          "text": "срывать; саботировать"
        },
        {
          "language": "sq",
          "text": "të pengosh; të sabotosh"
        },
        {
          "language": "tr",
          "text": "sabote etmek; engellemek"
        }
      ],
      "examples": [
        {
          "baseText": "Interne Machtkämpfe hintertrieben die geplante Einigung mit dem Lieferanten.",
          "translations": [
            {
              "language": "ar",
              "text": "أحبطت صراعات السلطة الداخلية الاتفاق المخطط مع المورد."
            },
            {
              "language": "ckb",
              "text": "ململانێی دەسەڵاتی ناوخۆ ڕێگری لە ڕێککەوتنی پلانکراو لەگەڵ دابینکەر کرد."
            },
            {
              "language": "en",
              "text": "Internal power struggles undermined the planned agreement with the supplier."
            },
            {
              "language": "fa",
              "text": "کشمکش‌های قدرت داخلی توافق برنامه‌ریزی‌شده با تأمین‌کننده را مختل کرد."
            },
            {
              "language": "kmr",
              "text": "Şerên hêzê yên navxweyî lihevhatina plankirî bi dabînker re têk dan."
            },
            {
              "language": "pl",
              "text": "Wewnętrzne walki o władzę udaremniły planowane porozumienie z dostawcą."
            },
            {
              "language": "ro",
              "text": "Luptele interne pentru putere au zădărnicit acordul planificat cu furnizorul."
            },
            {
              "language": "ru",
              "text": "Внутренние борьба за власть сорвала запланированное соглашение с поставщиком."
            },
            {
              "language": "sq",
              "text": "Luftërat e brendshme për pushtet e sabotuan marrëveshjen e planifikuar me furnizuesin."
            },
            {
              "language": "tr",
              "text": "İç güç mücadeleleri tedarikçiyle planlanan anlaşmayı baltaladı."
            }
          ]
        },
        {
          "baseText": "Die Verzögerung wirkte, als wolle jemand die Reform bewusst hintertreiben.",
          "translations": [
            {
              "language": "ar",
              "text": "بدا التأخير كما لو أن شخصًا ما يريد عرقلة الإصلاح عمدًا."
            },
            {
              "language": "ckb",
              "text": "دواكەوتنەکە وا دەردەکەوت وەک ئەوەی کەسێک بە ئاگایی دەیەوێت چاکسازییەکە تێک بدات."
            },
            {
              "language": "en",
              "text": "The delay seemed as if someone wanted to deliberately obstruct the reform."
            },
            {
              "language": "fa",
              "text": "تأخیر طوری به نظر می‌رسید که انگار کسی می‌خواهد آگاهانه اصلاحات را کارشکنی کند."
            },
            {
              "language": "kmr",
              "text": "Derengmayîn wisa xuya bû ku kesek dixwaze bi zanebûn reformê asteng bike."
            },
            {
              "language": "pl",
              "text": "Opóźnienie wyglądało tak, jakby ktoś celowo chciał sabotować reformę."
            },
            {
              "language": "ro",
              "text": "Întârzierea părea ca și cum cineva ar fi vrut să zădărnicească reforma în mod deliberat."
            },
            {
              "language": "ru",
              "text": "Задержка выглядела так, будто кто-то сознательно хотел сорвать реформу."
            },
            {
              "language": "sq",
              "text": "Vonesa dukej sikur dikush donte ta pengonte qëllimisht reformën."
            },
            {
              "language": "tr",
              "text": "Gecikme, birinin reformu bilinçli olarak engellemek istediği izlenimini verdi."
            }
          ]
        }
      ]
    },
    {
      "word": "hinterziehen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
