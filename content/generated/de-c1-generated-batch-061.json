  "entries": [
    {
      "word": "die Inflation",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Inflationen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "In-fla-ti-on",
      "topics": [
        "finance-and-accounting",
        "public-services",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; plural rare, used for different inflationary episodes"
      ],
      "collocations": [
        {
          "text": "hohe Inflation",
          "meaning": "high inflation"
        },
        {
          "text": "Inflation bekämpfen",
          "meaning": "to fight inflation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "inflationär",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Inflationsrate",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تضخم؛ ارتفاع عام في الأسعار"
        },
        {
          "language": "ckb",
          "text": "هەڵئاوسان؛ بەرزبوونەوەی گشتی نرخەکان"
        },
        {
          "language": "en",
          "text": "inflation; general rise in prices"
        },
        {
          "language": "fa",
          "text": "تورم؛ افزایش عمومی قیمت‌ها"
        },
        {
          "language": "kmr",
          "text": "enflasyon; bilindbûna giştî ya bihayan"
        },
        {
          "language": "pl",
          "text": "inflacja; ogólny wzrost cen"
        },
        {
          "language": "ro",
          "text": "inflație; creștere generală a prețurilor"
        },
        {
          "language": "ru",
          "text": "инфляция; общий рост цен"
        },
        {
          "language": "sq",
          "text": "inflacion; rritje e përgjithshme e çmimeve"
        },
        {
          "language": "tr",
          "text": "enflasyon; genel fiyat artışı"
        }
      ],
      "examples": [
        {
          "baseText": "Die hohe Inflation belastet besonders Haushalte mit niedrigen Einkommen.",
          "translations": [
            {
              "language": "ar",
              "text": "يثقل التضخم المرتفع خصوصًا كاهل الأسر ذات الدخل المنخفض."
            },
            {
              "language": "ckb",
              "text": "هەڵئاوسانی بەرز بە تایبەتی بار دەخاتە سەر خێزانە کەم‌داهاتەکان."
            },
            {
              "language": "en",
              "text": "High inflation particularly burdens households with low incomes."
            },
            {
              "language": "fa",
              "text": "تورم بالا به‌ویژه به خانوارهای کم‌درآمد فشار وارد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Enflasyona bilind bi taybetî malbatên dahata kêm bar dike."
            },
            {
              "language": "pl",
              "text": "Wysoka inflacja szczególnie obciąża gospodarstwa domowe o niskich dochodach."
            },
            {
              "language": "ro",
              "text": "Inflația ridicată afectează în special gospodăriile cu venituri mici."
            },
            {
              "language": "ru",
              "text": "Высокая инфляция особенно обременяет домохозяйства с низкими доходами."
            },
            {
              "language": "sq",
              "text": "Inflacioni i lartë rëndon veçanërisht familjet me të ardhura të ulëta."
            },
            {
              "language": "tr",
              "text": "Yüksek enflasyon özellikle düşük gelirli haneleri zorlar."
            }
          ]
        },
        {
          "baseText": "Im Jahresbericht wird erklärt, wie sich die Inflation auf unsere Einkaufspreise ausgewirkt hat.",
          "translations": [
            {
              "language": "ar",
              "text": "يوضح التقرير السنوي كيف أثّر التضخم في أسعار الشراء لدينا."
            },
            {
              "language": "ckb",
              "text": "لە ڕاپۆرتی ساڵانەدا ڕوونکراوەتەوە هەڵئاوسان چۆن کاریگەری لەسەر نرخی کڕینەکانمان کردووە."
            },
            {
              "language": "en",
              "text": "The annual report explains how inflation affected our purchase prices."
            },
            {
              "language": "fa",
              "text": "در گزارش سالانه توضیح داده شده که تورم چگونه بر قیمت‌های خرید ما اثر گذاشته است."
            },
            {
              "language": "kmr",
              "text": "Di raporta salane de tê ravekirin ka enflasyon çawa bandor li bihayên kirîna me kir."
            },
            {
              "language": "pl",
              "text": "Raport roczny wyjaśnia, jak inflacja wpłynęła na nasze ceny zakupu."
            },
            {
              "language": "ro",
              "text": "Raportul anual explică modul în care inflația a afectat prețurile noastre de achiziție."
            },
            {
              "language": "ru",
              "text": "В годовом отчете объясняется, как инфляция повлияла на наши закупочные цены."
            },
            {
              "language": "sq",
              "text": "Raporti vjetor shpjegon si ndikoi inflacioni në çmimet tona të blerjes."
            },
            {
              "language": "tr",
              "text": "Yıllık rapor enflasyonun satın alma fiyatlarımızı nasıl etkilediğini açıklıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Inflationsrate",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Inflationsraten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "In-fla-ti-ons-ra-te",
      "topics": [
        "finance-and-accounting",
        "data-and-reporting",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Inflationsraten"
      ],
      "collocations": [
        {
          "text": "sinkende Inflationsrate",
          "meaning": "falling inflation rate"
        },
        {
          "text": "Inflationsrate berechnen",
          "meaning": "to calculate inflation rate"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Inflation",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Rate",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "معدل التضخم"
        },
        {
          "language": "ckb",
          "text": "ڕێژەی هەڵئاوسان"
        },
        {
          "language": "en",
          "text": "inflation rate"
        },
        {
          "language": "fa",
          "text": "نرخ تورم"
        },
        {
          "language": "kmr",
          "text": "rêjeya enflasyonê"
        },
        {
          "language": "pl",
          "text": "stopa inflacji"
        },
        {
          "language": "ro",
          "text": "rată a inflației"
        },
        {
          "language": "ru",
          "text": "уровень инфляции"
        },
        {
          "language": "sq",
          "text": "normë inflacioni"
        },
        {
          "language": "tr",
          "text": "enflasyon oranı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Inflationsrate sank im letzten Quartal, blieb aber über dem Zielwert der Zentralbank.",
          "translations": [
            {
              "language": "ar",
              "text": "انخفض معدل التضخم في الربع الأخير، لكنه بقي فوق هدف البنك المركزي."
            },
            {
              "language": "ckb",
              "text": "ڕێژەی هەڵئاوسان لە چارەکی کۆتاییدا دابەزی، بەڵام لەسەر ئامانجی بانکی ناوەندییەوە مایەوە."
            },
            {
              "language": "en",
              "text": "The inflation rate fell in the last quarter but remained above the central bank’s target."
            },
            {
              "language": "fa",
              "text": "نرخ تورم در فصل گذشته کاهش یافت، اما بالاتر از هدف بانک مرکزی باقی ماند."
            },
            {
              "language": "kmr",
              "text": "Rêjeya enflasyonê di çaryeka dawî de daket, lê li ser armanca banka navendî ma."
            },
            {
              "language": "pl",
              "text": "Stopa inflacji spadła w ostatnim kwartale, ale pozostała powyżej celu banku centralnego."
            },
            {
              "language": "ro",
              "text": "Rata inflației a scăzut în ultimul trimestru, dar a rămas peste ținta băncii centrale."
            },
            {
              "language": "ru",
              "text": "Уровень инфляции снизился в последнем квартале, но остался выше цели центрального банка."
            },
            {
              "language": "sq",
              "text": "Norma e inflacionit ra në tremujorin e fundit, por mbeti mbi objektivin e bankës qendrore."
            },
            {
              "language": "tr",
              "text": "Enflasyon oranı son çeyrekte düştü, ancak merkez bankasının hedefinin üzerinde kaldı."
            }
          ]
        },
        {
          "baseText": "Für die Preisanpassung im Vertrag ist die offiziell veröffentlichte Inflationsrate maßgeblich.",
          "translations": [
            {
              "language": "ar",
              "text": "تُعد نسبة التضخم المنشورة رسميًا حاسمة لتعديل الأسعار في العقد."
            },
            {
              "language": "ckb",
              "text": "بۆ گونجاندنی نرخ لە گرێبەستەکەدا ڕێژەی هەڵئاوسانی بە فەرمی بڵاوکراوە گرنگە."
            },
            {
              "language": "en",
              "text": "The officially published inflation rate is decisive for the price adjustment in the contract."
            },
            {
              "language": "fa",
              "text": "برای تعدیل قیمت در قرارداد، نرخ تورم رسمی منتشرشده ملاک است."
            },
            {
              "language": "kmr",
              "text": "Ji bo lihevkirina bihayê di peymanê de rêjeya enflasyona fermî weşandî girîng e."
            },
            {
              "language": "pl",
              "text": "Dla korekty cen w umowie decydująca jest oficjalnie opublikowana stopa inflacji."
            },
            {
              "language": "ro",
              "text": "Pentru ajustarea prețurilor din contract este decisivă rata inflației publicată oficial."
            },
            {
              "language": "ru",
              "text": "Для корректировки цен в договоре решающим является официально опубликованный уровень инфляции."
            },
            {
              "language": "sq",
              "text": "Për rregullimin e çmimeve në kontratë është vendimtare norma zyrtare e publikuar e inflacionit."
            },
            {
              "language": "tr",
              "text": "Sözleşmedeki fiyat ayarlaması için resmi yayımlanan enflasyon oranı belirleyicidir."
            }
          ]
        }
      ]
    },
