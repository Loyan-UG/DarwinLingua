  "entries": [
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "erklingen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "erklingen",
      "syllableBreak": "er-klin-gen",
      "topics": [
        "culture-and-media",
        "everyday-life",
        "business-communication"
      ],
      "usageLabels": [
        "written",
        "formal"
      ],
      "contextLabels": [
        "documents"
      ],
      "grammarNotes": [
        "inseparable strong verb; means that a sound is heard"
      ],
      "collocations": [
        {
          "text": "Musik erklingt",
          "meaning": "music sounds/is heard"
        },
        {
          "text": "ein Signal erklingt",
          "meaning": "a signal sounds"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "klingen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يَصدح؛ يُسمع صوت"
        },
        {
          "language": "ckb",
          "text": "دەنگ دەدات؛ دەبیسترێت"
        },
        {
          "language": "en",
          "text": "to sound; to be heard"
        },
        {
          "language": "fa",
          "text": "به صدا درآمدن؛ شنیده شدن"
        },
        {
          "language": "kmr",
          "text": "deng dan; bihîstin"
        },
        {
          "language": "pl",
          "text": "rozbrzmiewać"
        },
        {
          "language": "ro",
          "text": "a răsuna"
        },
        {
          "language": "ru",
          "text": "звучать; раздаваться"
        },
        {
          "language": "sq",
          "text": "të tingëllojë"
        },
        {
          "language": "tr",
          "text": "ses çıkmak; duyulmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn der Warnton erklingt, müssen alle Mitarbeitenden das Gebäude verlassen.",
          "translations": [
            {
              "language": "ar",
              "text": "عندما يُسمع صوت التحذير يجب على جميع الموظفين مغادرة المبنى."
            },
            {
              "language": "ckb",
              "text": "کاتێک دەنگی ئاگادارکردنەوە دەبیسترێت، دەبێت هەموو کارمەندان باڵەخانەکە جێبهێڵن."
            },
            {
              "language": "en",
              "text": "When the warning tone sounds, all employees must leave the building."
            },
            {
              "language": "fa",
              "text": "وقتی صدای هشدار به صدا درمی‌آید، همه کارکنان باید ساختمان را ترک کنند."
            },
            {
              "language": "kmr",
              "text": "Dema dengê hişyariyê tê bihîstin, divê hemû karmend avahiyê bihêlin."
            },
            {
              "language": "pl",
              "text": "Gdy rozlegnie się sygnał ostrzegawczy, wszyscy pracownicy muszą opuścić budynek."
            },
            {
              "language": "ro",
              "text": "Când răsună semnalul de avertizare, toți angajații trebuie să părăsească clădirea."
            },
            {
              "language": "ru",
              "text": "Когда звучит предупредительный сигнал, все сотрудники должны покинуть здание."
            },
            {
              "language": "sq",
              "text": "Kur dëgjohet sinjali paralajmërues, të gjithë punonjësit duhet të largohen nga ndërtesa."
            },
            {
              "language": "tr",
              "text": "Uyarı sesi duyulduğunda tüm çalışanlar binayı terk etmelidir."
            }
          ]
        },
        {
          "baseText": "Am Abend erklingt oft Musik aus dem kleinen Café an der Ecke.",
          "translations": [
            {
              "language": "ar",
              "text": "في المساء غالبًا ما تُسمع الموسيقى من المقهى الصغير عند الزاوية."
            },
            {
              "language": "ckb",
              "text": "ئێواران زۆرجار مۆسیقا لە کافێ بچووکەکەی گۆشەکە دەبیسترێت."
            },
            {
              "language": "en",
              "text": "In the evening, music is often heard from the small café on the corner."
            },
            {
              "language": "fa",
              "text": "عصرها اغلب از کافه کوچک سر کوچه موسیقی به گوش می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Êvaran gelek caran muzîk ji kafeya biçûk a li goşeyê tê bihîstin."
            },
            {
              "language": "pl",
              "text": "Wieczorem często rozbrzmiewa muzyka z małej kawiarni na rogu."
            },
            {
              "language": "ro",
              "text": "Seara se aude adesea muzică din mica cafenea de la colț."
            },
            {
              "language": "ru",
              "text": "Вечером из маленького кафе на углу часто звучит музыка."
            },
            {
              "language": "sq",
              "text": "Në mbrëmje shpesh dëgjohet muzikë nga kafeneja e vogël në qoshe."
            },
            {
              "language": "tr",
              "text": "Akşamları köşedeki küçük kafeden sık sık müzik sesi gelir."
            }
          ]
        }
      ]
    },
