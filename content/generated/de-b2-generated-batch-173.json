      "meanings": [
        {
          "language": "ar",
          "text": "مرض؛ إصابة بمرض"
        },
        {
          "language": "ckb",
          "text": "نەخۆشی"
        },
        {
          "language": "en",
          "text": "illness; disease"
        },
        {
          "language": "fa",
          "text": "بیماری"
        },
        {
          "language": "kmr",
          "text": "nexweşî"
        },
        {
          "language": "pl",
          "text": "choroba; zachorowanie"
        },
        {
          "language": "ro",
          "text": "boală; îmbolnăvire"
        },
        {
          "language": "ru",
          "text": "заболевание"
        },
        {
          "language": "sq",
          "text": "sëmundje"
        },
        {
          "language": "tr",
          "text": "hastalık"
        }
      ],
      "examples": [
        {
          "baseText": "Bei einer ansteckenden Erkrankung sollen Mitarbeitende nicht ins Büro kommen.",
          "translations": [
            {
              "language": "ar",
              "text": "في حالة مرض معدٍ يجب ألا يأتي الموظفون إلى المكتب."
            },
            {
              "language": "ckb",
              "text": "لە کاتی نەخۆشییەکی گوازراوەدا نابێت کارمەندان بێنە ئۆفیس."
            },
            {
              "language": "en",
              "text": "In the case of a contagious illness, employees should not come to the office."
            },
            {
              "language": "fa",
              "text": "در صورت بیماری واگیردار، کارکنان نباید به دفتر بیایند."
            },
            {
              "language": "kmr",
              "text": "Di rewşa nexweşiyeke veguhezbar de, divê karmend neyên ofîsê."
            },
            {
              "language": "pl",
              "text": "W przypadku choroby zakaźnej pracownicy nie powinni przychodzić do biura."
            },
            {
              "language": "ro",
              "text": "În cazul unei boli contagioase, angajații nu ar trebui să vină la birou."
            },
            {
              "language": "ru",
              "text": "При заразном заболевании сотрудникам не следует приходить в офис."
            },
            {
              "language": "sq",
              "text": "Në rast të një sëmundjeje ngjitëse, punonjësit nuk duhet të vijnë në zyrë."
            },
            {
              "language": "tr",
