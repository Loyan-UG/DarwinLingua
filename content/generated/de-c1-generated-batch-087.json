    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "prozesshaft",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "syllableBreak": "pro-zess-haft",
      "topics": [
        "advanced-analysis",
        "planning-and-projects",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "adjective; means unfolding as a process"
      ],
      "collocations": [
        {
          "text": "prozesshaft verstehen",
          "meaning": "to understand as a process"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Prozess",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Prozesshaftigkeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ذو طابع عمليّاتي/مساري؛ يحدث كعملية"
        },
        {
          "language": "ckb",
          "text": "پرۆسەیی؛ وەک پرۆسە ڕوودەدات"
        },
        {
          "language": "en",
          "text": "processual; unfolding as a process"
        },
        {
          "language": "fa",
          "text": "فرایندی؛ در قالب یک فرایند"
        },
        {
          "language": "kmr",
          "text": "pêvajoyî"
        },
        {
          "language": "pl",
          "text": "procesowy; mający charakter procesu"
        },
        {
          "language": "ro",
          "text": "procesual; desfășurat ca proces"
        },
        {
          "language": "ru",
          "text": "процессуальный; разворачивающийся как процесс"
        },
        {
          "language": "sq",
          "text": "procesual; si proces"
        },
        {
          "language": "tr",
          "text": "süreçsel; süreç halinde gelişen"
        }
      ],
      "examples": [
        {
          "baseText": "Die Einführung der neuen Arbeitsweise ist prozesshaft und lässt sich nicht mit einem einzigen Workshop abschließen.",
          "translations": [
            {
              "language": "ar",
              "text": "إدخال طريقة العمل الجديدة ذو طابع تدريجي ولا يمكن إنهاؤه بورشة واحدة."
            },
            {
              "language": "ckb",
              "text": "جێبەجێکردنی شێوازی کاری نوێ پرۆسەییە و بە یەک وۆرکشۆپ کۆتایی نایەت."
            },
            {
              "language": "en",
              "text": "The introduction of the new way of working is processual and cannot be completed with a single workshop."
            },
            {
              "language": "fa",
              "text": "معرفی شیوه کاری جدید فرایندی است و با یک کارگاه به پایان نمی‌رسد."
            },
            {
              "language": "kmr",
              "text": "Danasîna awayê karê nû pêvajoyî ye û bi yek atolyeyê naqede."
            },
            {
              "language": "pl",
              "text": "Wprowadzenie nowego sposobu pracy ma charakter procesowy i nie kończy się jednym warsztatem."
            },
            {
              "language": "ro",
              "text": "Introducerea noului mod de lucru este procesuală și nu se poate încheia cu un singur atelier."
            },
            {
              "language": "ru",
              "text": "Внедрение нового способа работы является процессом и не завершается одним семинаром."
            },
            {
              "language": "sq",
              "text": "Futja e mënyrës së re të punës është procesuale dhe nuk përfundon me një punëtori të vetme."
            },
            {
              "language": "tr",
              "text": "Yeni çalışma biçiminin uygulanması süreçseldir ve tek bir atölyeyle tamamlanamaz."
            }
          ]
        },
        {
          "baseText": "Der Film zeigt Trauer nicht als Zustand, sondern als prozesshafte Veränderung.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض الفيلم الحزن لا كحالة، بل كتغير يحدث عبر عملية."
            },
            {
              "language": "ckb",
              "text": "فیلمەکە خەم وەک دۆخ پیشان نادات، بەڵکو وەک گۆڕانێکی پرۆسەیی پیشانی دەدات."
            },
            {
              "language": "en",
              "text": "The film presents grief not as a state, but as a processual change."
            },
            {
              "language": "fa",
              "text": "فیلم سوگ را نه به عنوان یک حالت، بلکه به عنوان تغییری فرایندی نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Fîlm xemgîniyê ne wek rewş, lê wek guherîneke pêvajoyî nîşan dide."
            },
            {
              "language": "pl",
              "text": "Film pokazuje żałobę nie jako stan, lecz jako procesową zmianę."
            },
            {
              "language": "ro",
              "text": "Filmul arată doliul nu ca stare, ci ca schimbare procesuală."
            },
            {
              "language": "ru",
              "text": "Фильм показывает горе не как состояние, а как процессуальное изменение."
            },
            {
              "language": "sq",
              "text": "Filmi e paraqet pikëllimin jo si gjendje, por si ndryshim procesual."
            },
            {
              "language": "tr",
              "text": "Film yası bir durum olarak değil, süreçsel bir değişim olarak gösterir."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
