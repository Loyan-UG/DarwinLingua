      "word": "die Prozesshaftigkeit",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "syllableBreak": "Pro-zess-haf-tig-keit",
      "topics": [
        "advanced-analysis",
        "planning-and-projects",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "die Prozesshaftigkeit betonen",
          "meaning": "to emphasize the processual character"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "prozesshaft",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "der Prozess",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "الطابع العمليّاتي؛ كونه عملية"
        },
        {
          "language": "ckb",
          "text": "پرۆسەییبوون؛ خاسیەتی پرۆسەبوون"
        },
        {
          "language": "en",
          "text": "processuality; process character"
        },
        {
          "language": "fa",
          "text": "فرایندی‌بودن؛ ماهیت فرایندی"
        },
        {
          "language": "kmr",
          "text": "pêvajoyîbûn"
        },
        {
          "language": "pl",
          "text": "procesowość"
        },
        {
          "language": "ro",
          "text": "procesualitate"
        },
        {
          "language": "ru",
          "text": "процессуальность"
        },
        {
          "language": "sq",
          "text": "procesualitet"
        },
        {
          "language": "tr",
          "text": "süreçsellik"
        }
      ],
      "examples": [
        {
          "baseText": "Die Prozesshaftigkeit der Transformation wird unterschätzt, wenn nur Meilensteine betrachtet werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يُستهان بالطابع العمليّاتي للتحول عندما تُنظر فقط إلى المعالم المرحلية."
            },
            {
              "language": "ckb",
              "text": "پرۆسەییبوونی گۆڕانکارییەکە کەم هەژمار دەکرێت ئەگەر تەنها مایلستۆنەکان ببینرێن."
            },
            {
              "language": "en",
              "text": "The processuality of the transformation is underestimated when only milestones are considered."
            },
            {
              "language": "fa",
              "text": "فرایندی‌بودن تحول زمانی دست‌کم گرفته می‌شود که فقط نقاط عطف دیده شوند."
            },
            {
              "language": "kmr",
              "text": "Pêvajoyîbûna veguherînê kêm tê nirxandin heke tenê qonaxên sereke bên dîtin."
            },
            {
              "language": "pl",
              "text": "Procesowość transformacji jest niedoceniana, gdy patrzy się tylko na kamienie milowe."
            },
            {
              "language": "ro",
              "text": "Procesualitatea transformării este subestimată când sunt privite doar reperele."
            },
            {
              "language": "ru",
              "text": "Процессуальность трансформации недооценивается, если рассматривать только этапные вехи."
            },
            {
              "language": "sq",
              "text": "Procesualiteti i transformimit nënvlerësohet kur shihen vetëm piketat."
            },
            {
              "language": "tr",
              "text": "Dönüşümün süreçselliği yalnızca kilometre taşlarına bakıldığında küçümsenir."
            }
          ]
        },
        {
          "baseText": "In der Ausbildung hilft das Verständnis von Prozesshaftigkeit, Lernfehler nicht vorschnell zu bewerten.",
          "translations": [
            {
              "language": "ar",
              "text": "في التدريب يساعد فهم الطابع العمليّاتي على عدم تقييم أخطاء التعلم بتسرع."
            },
            {
              "language": "ckb",
              "text": "لە ڕاهێناندا تێگەیشتن لە پرۆسەییبوون یارمەتی دەدات هەڵەکانی فێربوون بە پەلە هەڵنەسەنگێنرێن."
            },
            {
              "language": "en",
              "text": "In training, understanding processuality helps avoid judging learning errors too quickly."
            },
            {
              "language": "fa",
              "text": "در آموزش، فهم فرایندی‌بودن کمک می‌کند خطاهای یادگیری شتاب‌زده ارزیابی نشوند."
            },
            {
              "language": "kmr",
              "text": "Di perwerdeyê de têgihiştina pêvajoyîbûnê alîkar e ku şaşiyên fêrbûnê zû neyên nirxandin."
            },
            {
              "language": "pl",
              "text": "W kształceniu rozumienie procesowości pomaga nie oceniać błędów uczenia się zbyt pochopnie."
            },
            {
              "language": "ro",
              "text": "În formare, înțelegerea procesualității ajută la evitarea evaluării prea rapide a erorilor de învățare."
            },
            {
              "language": "ru",
              "text": "В обучении понимание процессуальности помогает не оценивать учебные ошибки поспешно."
            },
            {
              "language": "sq",
              "text": "Në trajnim, kuptimi i procesualitetit ndihmon që gabimet e të nxënit të mos vlerësohen me nxitim."
            },
            {
              "language": "tr",
              "text": "Eğitimde süreçselliği anlamak, öğrenme hatalarını aceleyle değerlendirmemeye yardımcı olur."
            }
          ]
        }
      ]
    },
