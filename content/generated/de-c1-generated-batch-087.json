      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ينتفخ؛ يتدفق/ينزّ"
        },
        {
          "language": "ckb",
          "text": "هەڵدەئاوسێت؛ دەردەچێت"
        },
        {
          "language": "en",
          "text": "to swell; to ooze; to gush"
        },
        {
          "language": "fa",
          "text": "ورم کردن؛ بیرون زدن/تراوش کردن"
        },
        {
          "language": "kmr",
          "text": "werimîn; derketin"
        },
        {
          "language": "pl",
          "text": "puchnąć; sączyć się"
        },
        {
          "language": "ro",
          "text": "a se umfla; a izvorî/a se scurge"
        },
        {
          "language": "ru",
          "text": "набухать; сочиться"
        },
        {
          "language": "sq",
          "text": "të fryhet; të rrjedhë"
        },
        {
          "language": "tr",
          "text": "şişmek; sızmak/fışkırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Wasserschaden quoll Feuchtigkeit aus mehreren Fugen im Boden.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد ضرر المياه بدأت الرطوبة تتسرب من عدة فواصل في الأرضية."
            },
            {
              "language": "ckb",
              "text": "دوای زیانی ئاو، شێ لە چەند درزی زەویەکەوە دەردەچوو."
            },
            {
              "language": "en",
              "text": "After the water damage, moisture oozed from several joints in the floor."
