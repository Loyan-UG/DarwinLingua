  "entries": [
    {
      "word": "zwecks",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Preposition",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "zwecks",
      "topics": [
