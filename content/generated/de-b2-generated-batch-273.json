        "business"
      ],
      "contextLabels": [
        "documents",
        "legal",
        "administration"
      ],
      "grammarNotes": [
        "preposition with genitive",
        "formal; common in administrative and legal writing"
      ],
      "collocations": [
        {
          "text": "zwecks Prüfung",
          "meaning": "for the purpose of review"
        },
        {
          "text": "zwecks Klärung",
          "meaning": "for the purpose of clarification"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Zweck",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "zweckmäßig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بغرض؛ من أجل؛ لغرض"
        },
        {
          "language": "ckb",
          "text": "بە مەبەستی؛ بۆ مەبەستی"
        },
        {
          "language": "en",
          "text": "for the purpose of; in order to"
        },
        {
          "language": "fa",
          "text": "به منظور؛ برای هدفِ"
        },
        {
          "language": "kmr",
          "text": "ji bo armanca; bi mebesta"
        },
        {
          "language": "pl",
          "text": "w celu; celem"
        },
        {
          "language": "ro",
          "text": "în scopul; pentru"
        },
        {
          "language": "ru",
          "text": "с целью; для"
        },
        {
          "language": "sq",
          "text": "me qëllim; për qëllimin e"
        },
        {
          "language": "tr",
          "text": "amacıyla; maksadıyla"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte senden Sie uns die Unterlagen zwecks Prüfung bis Freitag zu.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال المستندات إلينا بحلول الجمعة لغرض المراجعة."
            },
            {
              "language": "ckb",
              "text": "تکایە بەڵگەنامەکان بە مەبەستی پشکنین تا هەینی بۆمان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us the documents by Friday for review."
            },
            {
              "language": "fa",
              "text": "لطفاً مدارک را برای بررسی تا جمعه برای ما ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeyan ji bo kontrolê heta înê ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać nam dokumenty do piątku w celu sprawdzenia."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți documentele până vineri pentru verificare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам документы до пятницы для проверки."
            },
            {
              "language": "sq",
              "text": "Ju lutem na dërgoni dokumentet deri të premten për shqyrtim."
            },
            {
              "language": "tr",
              "text": "Lütfen belgeleri inceleme amacıyla cumaya kadar bize gönderin."
            }
          ]
        },
        {
          "baseText": "Zwecks besserer Planung melden Sie sich bitte spätestens eine Woche vor dem Termin an.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل تخطيط أفضل، يرجى التسجيل قبل الموعد بأسبوع على أقصى تقدير."
            },
            {
              "language": "ckb",
              "text": "بە مەبەستی پلانکردنی باشتر، تکایە بە لایەنی کەمەوە هەفتەیەک پێش کاتەکە خۆتان تۆمار بکەن."
            },
            {
              "language": "en",
              "text": "For better planning, please register no later than one week before the appointment."
            },
            {
              "language": "fa",
              "text": "به منظور برنامه‌ریزی بهتر، لطفاً حداکثر یک هفته قبل از موعد ثبت‌نام کنید."
            },
            {
              "language": "kmr",
              "text": "Ji bo plansaziyeke baştir, ji kerema xwe herî dereng hefteyek berî randevûyê xwe tomar bikin."
            },
            {
              "language": "pl",
              "text": "W celu lepszego planowania proszę zarejestrować się najpóźniej tydzień przed terminem."
            },
            {
              "language": "ro",
              "text": "Pentru o planificare mai bună, vă rugăm să vă înscrieți cel târziu cu o săptămână înainte de termen."
            },
            {
              "language": "ru",
              "text": "Для лучшего планирования, пожалуйста, зарегистрируйтесь не позднее чем за неделю до даты."
            },
            {
              "language": "sq",
              "text": "Për planifikim më të mirë, ju lutem regjistrohuni jo më vonë se një javë para takimit."
            },
            {
              "language": "tr",
              "text": "Daha iyi planlama amacıyla lütfen randevudan en geç bir hafta önce kayıt olun."
            }
          ]
        }
      ]
    },
    {
      "word": "zweifellos",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "zwei-fel-los",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "meetings-and-presentations"
      ],
      "usageLabels": [
        "formal",
        "written",
        "spoken"
      ],
      "contextLabels": [
        "management",
        "analytics",
        "research"
      ],
      "grammarNotes": [
        "adverb",
        "used to express certainty; often in presentations, reports, and evaluations"
      ],
      "collocations": [
        {
          "text": "zweifellos richtig",
          "meaning": "undoubtedly correct"
        },
        {
          "text": "zweifellos ein Vorteil",
          "meaning": "undoubtedly an advantage"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Zweifel",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "zweifeln",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بلا شك؛ دون أدنى شك"
        },
        {
          "language": "ckb",
          "text": "بێگومان؛ بە دڵنیاییەوە"
        },
        {
          "language": "en",
          "text": "undoubtedly; without a doubt"
        },
        {
          "language": "fa",
          "text": "بی‌تردید؛ بدون شک"
        },
        {
          "language": "kmr",
          "text": "bê guman; bê şik"
        },
        {
          "language": "pl",
          "text": "niewątpliwie; bez wątpienia"
        },
        {
          "language": "ro",
          "text": "fără îndoială; neîndoielnic"
        },
        {
          "language": "ru",
          "text": "несомненно; без сомнения"
        },
        {
          "language": "sq",
          "text": "pa dyshim; padyshim"
        },
        {
          "language": "tr",
          "text": "kuşkusuz; şüphesiz"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Suchfunktion ist zweifellos ein Vorteil für Kunden, die viele Dokumente verwalten.",
          "translations": [
            {
              "language": "ar",
              "text": "ميزة البحث الجديدة بلا شك فائدة للعملاء الذين يديرون كثيرًا من المستندات."
            },
            {
              "language": "ckb",
              "text": "فەنکشنی گەڕانی نوێ بێگومان سوودێکە بۆ ئەو کڕیارانەی بەڵگەنامەی زۆر بەڕێوەدەبەن."
            },
            {
              "language": "en",
              "text": "The new search function is undoubtedly an advantage for customers who manage many documents."
            },
            {
              "language": "fa",
              "text": "قابلیت جستجوی جدید بی‌تردید برای مشتریانی که اسناد زیادی را مدیریت می‌کنند یک مزیت است."
            },
            {
              "language": "kmr",
              "text": "Fonksiyona lêgerîna nû bê guman avantajek e ji bo xerîdarên ku gelek belgeyan rêve dibin."
            },
            {
              "language": "pl",
              "text": "Nowa funkcja wyszukiwania jest niewątpliwie zaletą dla klientów, którzy zarządzają wieloma dokumentami."
            },
            {
              "language": "ro",
              "text": "Noua funcție de căutare este fără îndoială un avantaj pentru clienții care gestionează multe documente."
            },
            {
              "language": "ru",
              "text": "Новая функция поиска, несомненно, является преимуществом для клиентов, которые управляют большим количеством документов."
            },
            {
              "language": "sq",
              "text": "Funksioni i ri i kërkimit është pa dyshim një avantazh për klientët që menaxhojnë shumë dokumente."
            },
            {
              "language": "tr",
              "text": "Yeni arama işlevi, çok sayıda belge yöneten müşteriler için kuşkusuz bir avantajdır."
            }
          ]
        },
        {
          "baseText": "Er hat zweifellos viel Erfahrung, aber für diese Entscheidung brauchen wir trotzdem aktuelle Zahlen.",
          "translations": [
            {
              "language": "ar",
              "text": "لديه بلا شك خبرة كبيرة، لكننا مع ذلك نحتاج إلى أرقام حديثة لهذا القرار."
