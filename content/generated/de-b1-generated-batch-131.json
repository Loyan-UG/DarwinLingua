      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يغفل عن؛ لا يلاحظ"
        },
        {
          "language": "ckb",
          "text": "نەبینین؛ لەبیرکردنەوە؛ تێنەگەیشتن"
        },
        {
          "language": "en",
          "text": "to overlook; to miss"
        },
        {
          "language": "fa",
          "text": "نادیده گرفتن؛ متوجه نشدن"
        },
        {
          "language": "kmr",
          "text": "nebînîn; ji ber çavan derxistin"
        },
        {
          "language": "pl",
          "text": "przeoczyć; nie zauważyć"
        },
        {
          "language": "ro",
          "text": "a trece cu vederea; a nu observa"
        },
        {
          "language": "ru",
          "text": "не заметить; упустить"
        },
        {
          "language": "sq",
          "text": "të mos vësh re; të anashkalosh"
        },
        {
          "language": "tr",
          "text": "gözden kaçırmak; fark etmemek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe in der Rechnung leider einen kleinen Fehler übersehen.",
          "translations": [
            {
              "language": "ar",
              "text": "للأسف لم ألاحظ خطأً صغيرًا في الفاتورة."
            },
            {
              "language": "ckb",
              "text": "بەداخەوە لە پسووڵەکەدا هەڵەیەکی بچووکم نەبینی."
