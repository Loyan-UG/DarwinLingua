          "text": "einen Fehler übersehen",
          "meaning": "to overlook a mistake"
        },
        {
          "text": "eine E-Mail übersehen",
          "meaning": "to miss an email"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sehen",
