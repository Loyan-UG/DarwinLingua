  "entries": [
    {
      "word": "übernehmen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "übernehmen",
      "pronunciationIpa": null,
      "syllableBreak": "ü-ber-neh-men",
      "topics": [
        "work-and-jobs",
        "planning-and-projects",
        "technology-and-it"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: übernimmt, übernahm, hat übernommen"
      ],
      "collocations": [
        {
          "text": "eine Aufgabe übernehmen",
          "meaning": "to take over a task"
        },
        {
          "text": "Verantwortung übernehmen",
          "meaning": "to take responsibility"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Übernahme",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتولى؛ يستلم؛ يتحمل"
        },
        {
          "language": "ckb",
          "text": "وەرگرتنەوە؛ پێشکەوتن؛ بەرپرسیاری گرتن"
        },
        {
          "language": "en",
          "text": "to take over; to assume; to accept responsibility"
        },
        {
          "language": "fa",
          "text": "به عهده گرفتن؛ تحویل گرفتن؛ پذیرفتن"
        },
        {
          "language": "kmr",
          "text": "wer girtin; berpirsiyarî hildan"
        },
        {
          "language": "pl",
          "text": "przejąć; wziąć na siebie"
        },
        {
          "language": "ro",
          "text": "a prelua; a-și asuma"
        },
        {
          "language": "ru",
          "text": "перенимать; брать на себя"
        },
        {
          "language": "sq",
          "text": "të marrësh përsipër; të marrësh në dorëzim"
        },
        {
          "language": "tr",
          "text": "devralmak; üstlenmek"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du das Ticket übernehmen, während ich im Kundentermin bin?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك تولي التذكرة بينما أكون في موعد مع العميل؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت ئەو تیکەتە وەربگریت کاتێک من لە دیداری کڕیاردام؟"
            },
            {
              "language": "en",
              "text": "Can you take over the ticket while I am in the customer appointment?"
            },
            {
              "language": "fa",
              "text": "می‌توانی این تیکت را به عهده بگیری وقتی من در جلسه با مشتری هستم؟"
            },
            {
              "language": "kmr",
              "text": "Dikarî vê ticketê werbigirî dema ez di hevdîtina xerîdar de me?"
            },
            {
              "language": "pl",
              "text": "Czy możesz przejąć to zgłoszenie, kiedy jestem na spotkaniu z klientem?"
            },
            {
              "language": "ro",
              "text": "Poți prelua tichetul cât timp sunt la întâlnirea cu clientul?"
            },
            {
              "language": "ru",
              "text": "Можешь взять этот тикет, пока я на встрече с клиентом?"
            },
            {
              "language": "sq",
              "text": "A mund ta marrësh këtë tiketë ndërsa jam në takim me klientin?"
            },
            {
              "language": "tr",
              "text": "Ben müşteri toplantısındayken bu ticketı devralabilir misin?"
            }
          ]
        },
        {
          "baseText": "Nach dem Urlaub übernimmt er wieder die Verantwortung für das Team.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الإجازة يتولى مرة أخرى المسؤولية عن الفريق."
            },
            {
              "language": "ckb",
              "text": "دوای پشوویەکە دووبارە بەرپرسیاریی تیمەکە وەردەگرێتەوە."
            },
            {
              "language": "en",
              "text": "After the vacation, he takes responsibility for the team again."
            },
            {
              "language": "fa",
              "text": "بعد از مرخصی، او دوباره مسئولیت تیم را به عهده می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Piştî betlaneyê ew dîsa berpirsiyariya tîmê hildide."
            },
            {
              "language": "pl",
              "text": "Po urlopie ponownie przejmuje odpowiedzialność za zespół."
            },
            {
              "language": "ro",
              "text": "După concediu preia din nou responsabilitatea pentru echipă."
            },
            {
              "language": "ru",
              "text": "После отпуска он снова берет на себя ответственность за команду."
            },
            {
              "language": "sq",
              "text": "Pas pushimit ai merr përsëri përgjegjësinë për ekipin."
            },
            {
              "language": "tr",
              "text": "İzinden sonra ekip sorumluluğunu tekrar üstlenir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Überprüfung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Überprüfungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ü-ber-prü-fung",
      "topics": [
        "quality-and-risk",
        "documents-and-administration",
        "technology-and-it"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Überprüfung durchführen",
          "meaning": "to carry out a review/check"
        },
        {
          "text": "nach der Überprüfung",
          "meaning": "after the check"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "überprüfen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فحص؛ مراجعة؛ تحقق"
        },
        {
          "language": "ckb",
          "text": "پشکنین؛ پێداچوونەوە"
        },
        {
          "language": "en",
          "text": "review; check; verification"
        },
        {
          "language": "fa",
          "text": "بررسی؛ بازبینی؛ راستی‌آزمایی"
        },
        {
          "language": "kmr",
          "text": "kontrol; vekolîn; piştrastkirin"
        },
        {
          "language": "pl",
          "text": "sprawdzenie; kontrola; weryfikacja"
        },
        {
          "language": "ro",
          "text": "verificare; control"
        },
        {
          "language": "ru",
          "text": "проверка; контроль"
        },
        {
          "language": "sq",
          "text": "kontroll; verifikim"
        },
        {
          "language": "tr",
          "text": "kontrol; inceleme; doğrulama"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Überprüfung der Daten können wir den Bericht freigeben.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد مراجعة البيانات يمكننا إصدار التقرير."
            },
            {
              "language": "ckb",
              "text": "دوای پشکنینی داتاکان دەتوانین ڕاپۆرتەکە بڵاو بکەینەوە."
            },
            {
              "language": "en",
              "text": "After reviewing the data, we can release the report."
            },
            {
              "language": "fa",
              "text": "بعد از بررسی داده‌ها می‌توانیم گزارش را تأیید و منتشر کنیم."
            },
            {
              "language": "kmr",
              "text": "Piştî kontrolkirina daneyan em dikarin raporê serbest bikin."
            },
            {
              "language": "pl",
              "text": "Po sprawdzeniu danych możemy zatwierdzić raport."
            },
            {
              "language": "ro",
              "text": "După verificarea datelor putem aproba raportul."
            },
            {
              "language": "ru",
              "text": "После проверки данных мы можем выпустить отчет."
            },
            {
              "language": "sq",
              "text": "Pas kontrollit të të dhënave mund ta miratojmë raportin."
            },
            {
              "language": "tr",
              "text": "Verileri kontrol ettikten sonra raporu yayınlayabiliriz."
            }
          ]
        },
        {
          "baseText": "Die regelmäßige Überprüfung der Geräte ist aus Sicherheitsgründen wichtig.",
          "translations": [
            {
              "language": "ar",
              "text": "الفحص المنتظم للأجهزة مهم لأسباب تتعلق بالسلامة."
            },
            {
              "language": "ckb",
              "text": "پشکنینی بەردەوامی ئامێرەکان بەهۆی ئاسایشەوە گرنگە."
            },
            {
              "language": "en",
              "text": "Regular checking of the devices is important for safety reasons."
            },
            {
              "language": "fa",
              "text": "بررسی منظم دستگاه‌ها به دلایل ایمنی مهم است."
            },
            {
              "language": "kmr",
              "text": "Kontrola bi rêkûpêk a amûran ji ber sedemên ewlehiyê girîng e."
            },
            {
              "language": "pl",
              "text": "Regularna kontrola urządzeń jest ważna ze względów bezpieczeństwa."
            },
            {
              "language": "ro",
              "text": "Verificarea regulată a dispozitivelor este importantă din motive de siguranță."
            },
            {
              "language": "ru",
              "text": "Регулярная проверка устройств важна по соображениям безопасности."
            },
            {
              "language": "sq",
              "text": "Kontrolli i rregullt i pajisjeve është i rëndësishëm për arsye sigurie."
            },
            {
              "language": "tr",
              "text": "Cihazların düzenli kontrolü güvenlik nedeniyle önemlidir."
            }
          ]
        }
      ]
    },
    {
      "word": "übersehen",
