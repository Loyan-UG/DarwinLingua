        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يموّل"
        },
        {
          "language": "ckb",
          "text": "دارایی کردن؛ پارە دابین کردن"
        },
        {
          "language": "en",
          "text": "to finance; to fund"
        },
        {
          "language": "fa",
          "text": "تأمین مالی کردن"
        },
        {
          "language": "kmr",
          "text": "fînanse kirin"
        },
        {
          "language": "pl",
          "text": "finansować"
        },
        {
          "language": "ro",
          "text": "a finanța"
        },
        {
          "language": "ru",
          "text": "финансировать"
        },
        {
          "language": "sq",
          "text": "të financosh"
        },
        {
          "language": "tr",
          "text": "finanse etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Bank finanziert den Kauf des Firmenwagens.",
          "translations": [
            {
              "language": "ar",
              "text": "يموّل البنك شراء سيارة الشركة."
            },
            {
              "language": "ckb",
              "text": "بانکەکە کڕینی ئۆتۆمبێلی کۆمپانیا دارایی دەکات."
            },
            {
              "language": "en",
              "text": "The bank finances the purchase of the company car."
            },
            {
              "language": "fa",
              "text": "بانک خرید خودروی شرکتی را تأمین مالی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Bank kirîna erebeya şirketê fînanse dike."
            },
            {
              "language": "pl",
              "text": "Bank finansuje zakup samochodu firmowego."
            },
            {
              "language": "ro",
              "text": "Banca finanțează cumpărarea mașinii de firmă."
            },
            {
              "language": "ru",
              "text": "Банк финансирует покупку служебного автомобиля."
            },
            {
              "language": "sq",
              "text": "Banka financon blerjen e makinës së kompanisë."
            },
            {
              "language": "tr",
              "text": "Banka şirket aracının satın alınmasını finanse ediyor."
            }
          ]
        },
        {
          "baseText": "Das Projekt wird teilweise durch öffentliche Fördermittel finanziert.",
          "translations": [
            {
              "language": "ar",
              "text": "يُموّل المشروع جزئيًا من خلال دعم عام."
            },
            {
              "language": "ckb",
              "text": "پرۆژەکە بەشێکی بە پارەی پاڵپشتی گشتی دارایی دەکرێت."
            },
            {
              "language": "en",
              "text": "The project is partly funded by public grants."
            },
            {
              "language": "fa",
              "text": "این پروژه بخشی از طریق کمک‌هزینه‌های دولتی تأمین مالی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Proje beşek bi alîkariyên giştî tê fînansekirin."
            },
            {
              "language": "pl",
              "text": "Projekt jest częściowo finansowany ze środków publicznych."
            },
            {
              "language": "ro",
              "text": "Proiectul este finanțat parțial din fonduri publice."
            },
            {
              "language": "ru",
              "text": "Проект частично финансируется за счет государственных субсидий."
            },
            {
              "language": "sq",
              "text": "Projekti financohet pjesërisht nga fondet publike."
            },
            {
              "language": "tr",
              "text": "Proje kısmen kamu destekleriyle finanse ediliyor."
            }
          ]
        }
      ]
    },
