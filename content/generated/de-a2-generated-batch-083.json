      "meanings": [
        {
          "language": "ar",
          "text": "شباك الخدمة؛ كاونتر"
        },
        {
          "language": "ckb",
          "text": "پەنجەرەی خزمەتگوزاری؛ کاونتەر"
        },
        {
          "language": "en",
          "text": "counter; service desk"
        },
        {
          "language": "fa",
          "text": "باجه؛ پیشخوان"
        },
        {
          "language": "kmr",
          "text": "gişe; maseya xizmetê"
        },
        {
          "language": "pl",
          "text": "okienko; lada"
        },
        {
          "language": "ro",
          "text": "ghișeu; tejghea"
        },
        {
          "language": "ru",
          "text": "стойка; окно обслуживания"
        },
        {
          "language": "sq",
          "text": "sportel; banak shërbimi"
        },
        {
          "language": "tr",
          "text": "gişe; hizmet bankosu"
        }
      ],
      "examples": [
        {
          "baseText": "Ich kaufe die Fahrkarte am Schalter.",
          "translations": [
            {
              "language": "ar",
              "text": "أشتري التذكرة من شباك الخدمة."
            },
            {
              "language": "ckb",
              "text": "من بلیتەکە لە پەنجەرەی خزمەتگوزاری دەکڕم."
            },
            {
              "language": "en",
              "text": "I buy the ticket at the counter."
            },
            {
              "language": "fa",
              "text": "من بلیت را از باجه می‌خرم."
            },
            {
              "language": "kmr",
              "text": "Ez bilêtê li gişeyê dikirim."
            },
            {
              "language": "pl",
              "text": "Kupuję bilet w okienku."
            },
            {
              "language": "ro",
              "text": "Cumpăr biletul de la ghișeu."
            },
            {
              "language": "ru",
              "text": "Я покупаю билет в кассе."
            },
            {
              "language": "sq",
              "text": "Unë e blej biletën te sporteli."
            },
            {
              "language": "tr",
              "text": "Bileti gişeden alıyorum."
            }
          ]
        },
        {
          "baseText": "Bitte warten Sie am Schalter drei.",
          "translations": [
            {
              "language": "ar",
              "text": "لطفاً انتظروا عند الشباك رقم ثلاثة."
            },
            {
              "language": "ckb",
              "text": "تکایە لە پەنجەرەی سێ چاوەڕێ بکەن."
            },
            {
              "language": "en",
              "text": "Please wait at counter three."
            },
            {
              "language": "fa",
              "text": "لطفاً در باجه سه منتظر بمانید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li gişeya sê bisekinin."
            },
            {
              "language": "pl",
              "text": "Proszę czekać przy okienku numer trzy."
            },
            {
              "language": "ro",
              "text": "Vă rog să așteptați la ghișeul trei."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, ждите у окна номер три."
            },
            {
              "language": "sq",
              "text": "Ju lutem prisni te sporteli tre."
            },
            {
              "language": "tr",
              "text": "Lütfen üçüncü gişede bekleyin."
            }
          ]
        }
      ]
    },
