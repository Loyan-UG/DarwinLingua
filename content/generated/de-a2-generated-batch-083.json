        {
          "language": "sq",
          "text": "nëpunës sporteli"
        },
        {
          "language": "tr",
          "text": "gişe memuru"
        }
      ],
      "examples": [
        {
          "baseText": "Der Schalterbeamte hilft mir mit dem Formular.",
          "translations": [
            {
              "language": "ar",
              "text": "يساعدني موظف الشباك في الاستمارة."
            },
            {
              "language": "ckb",
              "text": "کارمەندی پەنجەرەکە یارمەتیم دەدات لە فۆرمەکەدا."
            },
            {
              "language": "en",
              "text": "The counter clerk helps me with the form."
            },
            {
              "language": "fa",
              "text": "کارمند باجه در مورد فرم به من کمک می‌کند."
            },
            {
              "language": "kmr",
              "text": "Karmendê gişeyê bi formê alîkariya min dike."
            },
            {
              "language": "pl",
              "text": "Urzędnik w okienku pomaga mi z formularzem."
            },
            {
              "language": "ro",
              "text": "Funcționarul de la ghișeu mă ajută cu formularul."
            },
            {
              "language": "ru",
              "text": "Служащий в окне помогает мне с формой."
            },
            {
              "language": "sq",
              "text": "Nëpunësi i sportelit më ndihmon me formularin."
            },
            {
              "language": "tr",
              "text": "Gişe memuru form konusunda bana yardım ediyor."
            }
          ]
        },
        {
          "baseText": "Fragen Sie bitte den Schalterbeamten nach dem Gleis.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك اسأل موظف الشباك عن الرصيف."
            },
            {
              "language": "ckb",
              "text": "تکایە پرسیاری سەکۆکە لە کارمەندی پەنجەرەکە بکەن."
            },
            {
              "language": "en",
              "text": "Please ask the counter clerk about the platform."
            },
            {
              "language": "fa",
              "text": "لطفاً درباره سکو از کارمند باجه بپرسید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li ser platformê ji karmendê gişeyê bipirsin."
            },
            {
              "language": "pl",
              "text": "Proszę zapytać urzędnika w okienku o peron."
            },
            {
              "language": "ro",
              "text": "Vă rog să întrebați funcționarul de la ghișeu despre peron."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, спросите у служащего в окне о платформе."
            },
            {
              "language": "sq",
              "text": "Ju lutem pyesni nëpunësin e sportelit për peronin."
            },
            {
              "language": "tr",
              "text": "Lütfen peronu gişe memuruna sorun."
            }
          ]
        }
      ]
    },
