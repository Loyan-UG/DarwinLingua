      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مشترك؛ معاً"
        },
        {
          "language": "ckb",
          "text": "هاوبەش؛ پێکەوە"
        },
        {
          "language": "en",
          "text": "together; shared; common"
        },
        {
          "language": "fa",
          "text": "مشترک؛ با هم"
        },
        {
          "language": "kmr",
          "text": "hevpar; bi hev re"
        },
        {
          "language": "pl",
          "text": "wspólny; razem"
        },
        {
          "language": "ro",
          "text": "comun; împreună"
        },
        {
          "language": "ru",
          "text": "совместный; вместе; общий"
        },
        {
          "language": "sq",
          "text": "i përbashkët; së bashku"
        },
        {
          "language": "tr",
          "text": "ortak; birlikte"
        }
      ],
      "examples": [
        {
          "baseText": "Wir suchen gemeinsam eine Lösung, die für beide Seiten passt.",
          "translations": [
            {
              "language": "ar",
              "text": "نبحث معاً عن حل يناسب الطرفين."
            },
            {
              "language": "ckb",
              "text": "ئێمە پێکەوە بەدوای چارەسەرێک دەگەڕێین کە بۆ هەردوو لا گونجاو بێت."
            },
            {
              "language": "en",
              "text": "We are looking together for a solution that works for both sides."
            },
            {
              "language": "fa",
              "text": "ما با هم به دنبال راه‌حلی هستیم که برای هر دو طرف مناسب باشد."
            },
            {
              "language": "kmr",
              "text": "Em bi hev re li çareseriyekê digerin ku ji bo her du aliyan guncaw be."
            },
            {
              "language": "pl",
              "text": "Wspólnie szukamy rozwiązania, które pasuje obu stronom."
            },
            {
              "language": "ro",
              "text": "Căutăm împreună o soluție care să fie potrivită pentru ambele părți."
            },
            {
              "language": "ru",
              "text": "Мы вместе ищем решение, которое подходит обеим сторонам."
            },
            {
              "language": "sq",
