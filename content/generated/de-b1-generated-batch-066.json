  "entries": [
    {
      "word": "die Gemeinde",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Gemeinden",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ge-mein-de",
      "topics": [
        "public-services",
        "everyday-life",
        "documents-and-administration"
      ],
      "usageLabels": [
        "everyday",
        "formal",
        "administrative"
      ],
      "contextLabels": [
        "public-services"
      ],
      "grammarNotes": [
        "feminine noun; refers to a municipality or local community"
      ],
      "collocations": [
        {
          "text": "bei der Gemeinde anmelden",
          "meaning": "to register with the municipality"
        },
        {
          "text": "die Gemeinde informieren",
          "meaning": "to inform the municipality"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gemeinsam",
          "relationLabel": "adjective/adverb",
          "note": null
        },
        {
          "lemma": "die Gemeinschaft",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بلدية؛ مجتمع محلي"
        },
        {
          "language": "ckb",
          "text": "شارەوانی؛ کۆمەڵگەی ناوخۆیی"
        },
        {
          "language": "en",
          "text": "municipality; local community"
        },
        {
          "language": "fa",
          "text": "شهرداری؛ جامعه محلی"
        },
        {
          "language": "kmr",
          "text": "şaredarî; civaka herêmî"
        },
        {
          "language": "pl",
          "text": "gmina; społeczność lokalna"
        },
        {
          "language": "ro",
          "text": "comună; comunitate locală"
        },
        {
          "language": "ru",
          "text": "муниципалитет; местная община"
        },
        {
          "language": "sq",
          "text": "komunë; bashkësi lokale"
        },
        {
          "language": "tr",
          "text": "belediye; yerel topluluk"
        }
      ],
      "examples": [
        {
          "baseText": "Die Gemeinde informiert die Bewohner über die neuen Mülltermine.",
          "translations": [
            {
              "language": "ar",
              "text": "تُبلغ البلدية السكان بمواعيد جمع النفايات الجديدة."
            },
            {
              "language": "ckb",
              "text": "شارەوانی دانیشتووان لە کاتە نوێیەکانی خاشاک ئاگادار دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The municipality informs residents about the new waste collection dates."
            },
            {
              "language": "fa",
              "text": "شهرداری ساکنان را درباره زمان‌های جدید جمع‌آوری زباله مطلع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Şaredarî niştecihan li ser demên nû yên berhevkirina zibilê agahdar dike."
            },
            {
              "language": "pl",
              "text": "Gmina informuje mieszkańców o nowych terminach odbioru śmieci."
            },
            {
              "language": "ro",
              "text": "Primăria îi informează pe locuitori despre noile date de colectare a gunoiului."
            },
            {
              "language": "ru",
              "text": "Муниципалитет информирует жителей о новых датах вывоза мусора."
            },
            {
              "language": "sq",
              "text": "Komuna i informon banorët për datat e reja të mbledhjes së mbeturinave."
            },
            {
              "language": "tr",
              "text": "Belediye sakinleri yeni çöp toplama tarihleri hakkında bilgilendiriyor."
            }
          ]
        },
        {
          "baseText": "Für den Antrag brauchen wir eine Bestätigung von der Gemeinde.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج إلى تأكيد من البلدية من أجل الطلب."
            },
            {
              "language": "ckb",
              "text": "بۆ داواکارییەکە پێویستمان بە پشتڕاستکردنەوەیەک لە شارەوانی هەیە."
            },
            {
              "language": "en",
              "text": "For the application, we need a confirmation from the municipality."
            },
            {
              "language": "fa",
              "text": "برای درخواست به تأییدیه‌ای از شهرداری نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo daxwaznameyê em hewceyê pejirandinekê ji şaredariyê ne."
            },
            {
              "language": "pl",
              "text": "Do wniosku potrzebujemy potwierdzenia z gminy."
            },
            {
              "language": "ro",
              "text": "Pentru cerere avem nevoie de o confirmare de la primărie."
            },
            {
              "language": "ru",
              "text": "Для заявления нам нужно подтверждение от муниципалитета."
            },
            {
              "language": "sq",
              "text": "Për aplikimin na duhet një konfirmim nga komuna."
            },
            {
              "language": "tr",
              "text": "Başvuru için belediyeden bir onaya ihtiyacımız var."
            }
          ]
        }
      ]
    },
