  "entries": [
    {
      "word": "beitreten",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beitreten",
      "pronunciationIpa": null,
      "syllableBreak": "bei-tre-ten",
      "topics": [
        "meetings-and-presentations",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "spoken"
      ],
      "contextLabels": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الانضمام؛ انضمام"
        },
        {
          "language": "ckb",
          "text": "پەیوەستبوون؛ دەستەوەردان"
        },
        {
          "language": "en",
          "text": "to join (a group, team, meeting, team)"
        },
        {
          "language": "fa",
          "text": "پیوستن؛ الحاق شدن"
        },
        {
          "language": "kmr",
          "text": "beşdar bûn; tevlî bûn"
        },
        {
          "language": "pl",
          "text": "dołączać; przystępować"
        },
        {
          "language": "ro",
          "text": "a se alătura; a adera"
        },
        {
          "language": "ru",
          "text": "присоединяться; вступать"
        },
        {
          "language": "sq",
          "text": "të bashkangjesh; të përfshihesh"
        },
        {
          "language": "tr",
          "text": "katılmak; dahil olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Fünf neue Entwickler sind gestern dem Projektteam beigetreten.",
          "translations": [
            {
              "language": "ar",
              "text": "پنج برنامه‌نویس جدید دیروز به تیم پروژه پیوستند."
            },
            {
              "language": "ckb",
              "text": "پێنج پەرەپێدەر دوێنەی کۆتایەوە پەیوەستبوون بە تیمی پڕۆژەکە."
            },
            {
              "language": "en",
              "text": "Five new developers joined the project team yesterday."
            },
            {
              "language": "fa",
              "text": "پنج توسعه‌دهنده جدید دیروز به تیم پروژه پیوستند."
            },
            {
              "language": "kmr",
              "text": "Pênc pêşangehvanên nû di do şeva dawiyê de tevlî tīma projeyê bûn."
            },
            {
              "language": "pl",
              "text": "Wczoraj dołączyło do zespołu projektowego pięciu programistów."
            },
            {
              "language": "ro",
              "text": "Ieri, cinci dezvoltatori noi s-au alăturat echipei de proiect."
            },
            {
              "language": "ru",
              "text": "Вчера к команде проекта присоединилось пять новых разработчиков."
            },
            {
              "language": "sq",
              "text": "Pesë zhvillues të rinj iu bashkuan ekipit të projektit dje."
            },
            {
              "language": "tr",
              "text": "Dün, projeye beş yeni geliştirici katıldı."
            }
          ]
        },
        {
          "baseText": "Die neue Abteilungsleiterin ist der Qualitätsgruppe beigetreten.",
          "translations": [
            {
              "language": "ar",
              "text": "مديرة القسم الجديدة انضمت إلى مجموعة الجودة."
            },
            {
              "language": "ckb",
              "text": "بەڕێوبەری نوێی بەشەکە پەیوەستبوو بە گروپی کوالێتیەکە."
            },
            {
              "language": "en",
              "text": "The new department head has joined the quality group."
            },
            {
              "language": "fa",
              "text": "مدیر جدید بخش به گروه کیفیت پیوست."
            },
            {
              "language": "kmr",
              "text": "Serkarê nû ya beşa bi vê dema qrupê kaliteyê re yê beşdarî kiriye."
            },
            {
              "language": "pl",
              "text": "Nowa kierowniczka działu dołączyła do zespołu jakości."
            },
            {
              "language": "ro",
              "text": "Șefa de departament nouă s-a alăturat echipei de calitate."
            },
            {
              "language": "ru",
              "text": "Новая руководительница отдела присоединилась к группе по качеству."
            },
            {
              "language": "sq",
              "text": "Kryeshërbyesja e re e departamentit iu bashkua ekipit të cilësisë."
            },
            {
              "language": "tr",
              "text": "Yeni bölüm lideri kalite ekibine katıldı."
            }
          ]
        }
      ]
    },
    {
      "word": "beken­nen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beken­nen",
      "pronunciationIpa": null,
      "syllableBreak": "be-ken-nen",
      "topics": [
        "documents-and-administration",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written"
      ],
      "contextLabels": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اعتراف کردن؛ اذعان کردن"
        },
        {
          "language": "ckb",
          "text": "پەسەندکردن؛ ڕاگیربوونەوە"
        },
        {
          "language": "en",
          "text": "to admit or acknowledge"
        },
        {
          "language": "fa",
          "text": "اعتراف کردن؛ اذعان کردن"
        },
        {
          "language": "kmr",
          "text": "rastî kirin; qebûl kirin"
        },
        {
          "language": "pl",
          "text": "przyznać; uznać"
        },
        {
          "language": "ro",
          "text": "a recunoaște; a-și asuma răspunderea"
        },
        {
          "language": "ru",
          "text": "признаваться; признавать"
        },
        {
          "language": "sq",
          "text": "të pranosh; të pranohet"
        },
        {
          "language": "tr",
          "text": "itiraf etmek; kabul etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Support-Mitarbeiter hat sich in der Retrospektive zur falschen Ticket-Klassifizierung bekannt.",
          "translations": [
            {
              "language": "ar",
              "text": "کارشناس پشتیبانی در بازنگری اعتراف کرد که دسته‌بندی تیکت‌ها اشتباه بوده است."
            },
            {
              "language": "ckb",
              "text": "کارمەندی پشتگیری لە هەمووەری پەیوەستەوە ئەوە پەسەندکرد کە درووستە لە پەڕگەدانی تیکتەکانەکان نەگونجاوە."
            },
            {
              "language": "en",
              "text": "The support engineer admitted in the retrospective that the ticket classification was wrong."
            },
            {
              "language": "fa",
              "text": "کارشناس پشتیبانی در بازنگری اعتراف کرد که دسته‌بندی تیکت‌ها اشتباه بوده است."
            },
            {
              "language": "kmr",
              "text": "Injinera piştgiriya di retrospektîvê de qebûl kir ku rêza têketinê şaş bû."
            },
            {
              "language": "pl",
              "text": "Inżynier wsparcia przyznał się podczas retrospektywy, że klasyfikacja ticketów była błędna."
            },
            {
              "language": "ro",
              "text": "Inginerul de suport a recunoscut la revizuire că clasificarea tichetelor a fost greșită."
            },
            {
              "language": "ru",
              "text": "مهندس پشتیبانی در بازبینی اعتراف کرد که دسته‌بندی تیکت‌ها اشتباه بوده است."
            },
            {
              "language": "sq",
              "text": "Inxhinieri i suportit e pranoi në mbikëqyrje se klasifikimi i biletave ishte i gabuar."
            },
            {
              "language": "tr",
              "text": "Destek mühendisi geribildirimde bilet sınıflandırmasının yanlış olduğunu itiraf etti."
            }
          ]
        },
        {
          "baseText": "Die Abteilung hat sich in ihrer Richtlinie zur Datensicherheit zu den neuen Regeln bekannt.",
          "translations": [
            {
              "language": "ar",
              "text": "بخش در چارچوب خط مشی امنیت داده‌های خود به قوانین جدید اذعان کرده است."
            },
            {
              "language": "ckb",
              "text": "بەشەکە لە ڕاپۆرتەکەی خۆی دوای یاساکانی نوێی پاراستنی دراوەکان داناوەتەوە."
            },
            {
              "language": "en",
              "text": "The department acknowledged the new data-safety rules in its internal policy."
            },
            {
              "language": "fa",
              "text": "بخش مربوطه در سیاست داخلی خود به قوانین جدید ایمنی داده‌ها اذعان کرد."
            },
            {
              "language": "kmr",
              "text": "Beşê kompanîyê di polîtîkaya xwe de rêbazên nû yên ewlehiya daneyan qebûl kir."
            },
            {
              "language": "pl",
              "text": "Dział potwierdził w swojej polityce wewnętrznej nowe zasady bezpieczeństwa danych."
            },
            {
              "language": "ro",
              "text": "Departamentul a recunoscut în politica sa internă noile reguli de siguranță a datelor."
            },
            {
              "language": "ru",
              "text": "Отдел подтвердил в своей внутренней политике новые правила безопасности данных."
            },
            {
              "language": "sq",
              "text": "Departamenti e ka pranuar në politikën e brendshme rregullat e reja për sigurinë e të dhënave."
            },
            {
              "language": "tr",
              "text": "Departman, iç politika belgesinde yeni veri güvenliği kurallarını kabul etti."
            }
          ]
        }
      ]
    },
    {
      "word": "beladen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beladen",
      "pronunciationIpa": null,
      "syllableBreak": "be-la-den",
      "topics": [
        "warehouse-and-logistics",
        "production-and-maintenance",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بارگذاری کردن؛ پر کردن"
        },
        {
          "language": "ckb",
          "text": "بارکردن؛ پڕکردن"
        },
        {
          "language": "en",
          "text": "to load (cargo, tasks)"
        },
        {
          "language": "fa",
          "text": "بار کردن؛ پر کردن"
        },
        {
          "language": "kmr",
          "text": "barkirin; dagirtin"
        },
        {
          "language": "pl",
          "text": "ładować; napełniać"
        },
        {
          "language": "ro",
          "text": "a încărca; a împovăra"
        },
        {
          "language": "ru",
          "text": "грузить; перегружать"
        },
        {
          "language": "sq",
          "text": "të ngarkosh; të mbingarkosh"
        },
        {
          "language": "tr",
          "text": "yüklemek; yük taşımak"
        }
      ],
      "examples": [
        {
          "baseText": "Das Lagerteam hat heute alle Paletten innerhalb von zwei Stunden beladen.",
          "translations": [
            {
              "language": "ar",
              "text": "تیم انبار امروز همه پالت‌ها را ظرف دو ساعت بارگذاری کرد."
            },
            {
              "language": "ckb",
              "text": "تیمی گەردەخانیان ئەمڕۆ هەموو پەلەتەکان لە دوو کاتژمێردا بارکرد."
            },
            {
              "language": "en",
              "text": "The warehouse team loaded all pallets within two hours today."
            },
            {
              "language": "fa",
              "text": "تیم انبار امروز همه پالت‌ها را ظرف دو ساعت بارگیری کرد."
            },
            {
              "language": "kmr",
              "text": "Tîma depoyê îro hemû paletan di dema du saetan de barkir."
            },
            {
              "language": "pl",
              "text": "Zespół magazynu załadował dziś wszystkie palety w ciągu dwóch godzin."
            },
            {
              "language": "ro",
              "text": "Echipa depozitului a încărcat toate paleții azi în două ore."
            },
            {
              "language": "ru",
              "text": "Сейчас تیم انبار همه паллеты за два часа загрузил."
            },
            {
              "language": "sq",
              "text": "Ekipi i magazinës i ngarkoi të gjitha paletat brenda dy orëve sot."
            },
            {
              "language": "tr",
              "text": "Depo ekibi bugün tüm paletleri iki saat içinde yükledi."
            }
          ]
        },
        {
          "baseText": "Wir dürfen den Wochenplan nicht mit zusätzlichen Aufgaben beladen.",
          "translations": [
            {
              "language": "ar",
              "text": "نمی‌توانیم برنامه هفتگی را با کارهای اضافی شلوغ کنیم."
            },
            {
              "language": "ckb",
              "text": "ناتوانینەمانە پلانی ھەفتەیی بە ئەرکە زیادەیەکدا مێشکە بکەین."
            },
            {
              "language": "en",
              "text": "We must not overload the weekly plan with extra tasks."
            },
            {
              "language": "fa",
              "text": "نباید برنامه هفتگی را با کارهای اضافی بارگذاری کنیم."
            },
            {
              "language": "kmr",
              "text": "Nehêle em plana heftiyê bi karên zêdeyan bi giranî bar bikin."
            },
            {
              "language": "pl",
              "text": "Nie możemy przeciążyć tygodniowego planu dodatkowym zadaniami."
            },
            {
              "language": "ro",
              "text": "Nu putem încărca programul săptămânal cu sarcini suplimentare."
            },
            {
              "language": "ru",
              "text": "Мы не можем перегрузить недельный план дополнительными задачами."
            },
            {
              "language": "sq",
              "text": "Nuk mund ta mbingarkojmë planin javor me detyra shtesë."
            },
            {
              "language": "tr",
              "text": "Haftalık planı ek işlerle aşırı yükleyemeyiz."
            }
          ]
        }
      ]
    },
    {
      "word": "belastbar",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "be-las-tbar",
      "topics": [
        "quality-and-risk",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written"
      ],
      "contextLabels": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مقاوم؛ قابل اعتماد"
        },
        {
          "language": "ckb",
          "text": "بەهێز؛ ئێستەبەند"
        },
        {
          "language": "en",
          "text": "robust; reliable under load"
        },
        {
          "language": "fa",
          "text": "مقاوم؛ قابل اتکا"
        },
        {
          "language": "kmr",
          "text": "dirêjbûn; bi bawerî derbasdar"
        },
        {
          "language": "pl",
          "text": "odporny; niezawodny"
        },
        {
          "language": "ro",
          "text": "rezistent; de încredere"
        },
        {
          "language": "ru",
          "text": "надежный; устойчивый"
        },
        {
          "language": "sq",
          "text": "i qëndrueshëm; i besueshëm"
        },
        {
          "language": "tr",
          "text": "dayanıklı; güvenilir"
        }
      ],
      "examples": [
        {
          "baseText": "Unsere Infrastruktur ist belastbar genug für Lastspitzen im Jahresende.",
          "translations": [
            {
              "language": "ar",
              "text": "زیرساخت ما برای اوج مصرف در پایان سال قابل اتکا و مقاوم است."
            },
            {
              "language": "ckb",
              "text": "بەرواریسەکردنی ئێمە بۆ پەڕاەوەی قەبارەی کۆتایی ساڵە بە هەموو وزەیەکە تەواوە."
            },
            {
              "language": "en",
              "text": "Our infrastructure is robust enough for end-of-year traffic peaks."
            },
            {
              "language": "fa",
              "text": "زیرساخت ما برای اوج مصرف پایان سال کافی و قابل اعتماد است."
            },
