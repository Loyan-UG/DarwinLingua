  "entries": [
    {
      "word": "die Erwartungshaltung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Erwartungshaltungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Er-war-tungs-hal-tung",
      "topics": [
        "business-communication",
        "management-and-leadership",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "business",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Erwartungshaltungen"
      ],
      "collocations": [
        {
          "text": "eine unrealistische Erwartungshaltung",
          "meaning": "an unrealistic expectation mindset"
        },
        {
          "text": "Erwartungshaltungen klären",
          "meaning": "to clarify expectations"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erwartung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "erwarten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "توقعات ذهنية؛ موقف توقعي"
        },
        {
          "language": "ckb",
          "text": "هەڵوێستی چاوەڕوانی؛ شێوازی چاوەڕوانبوون"
        },
        {
          "language": "en",
          "text": "expectation mindset; attitude of expectation"
        },
        {
          "language": "fa",
          "text": "نگرش انتظاری؛ نوع توقع داشتن"
        },
        {
          "language": "kmr",
          "text": "helwesta hêviyê; şêwaza çaverêkirinê"
        },
        {
          "language": "pl",
          "text": "postawa oczekiwań; nastawienie oczekujące"
        },
        {
          "language": "ro",
          "text": "atitudine de așteptare; set de așteptări"
        },
        {
          "language": "ru",
          "text": "установка ожиданий; ожидательная позиция"
        },
        {
          "language": "sq",
          "text": "qëndrim pritjeje; mendësi pritshmërish"
        },
        {
          "language": "tr",
          "text": "beklenti tutumu; beklenti zihniyeti"
        }
      ],
      "examples": [
        {
          "baseText": "Vor Projektbeginn sollten wir die Erwartungshaltung des Kunden ausdrücklich klären.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل بدء المشروع ينبغي أن نوضح صراحة توقعات العميل."
            },
            {
              "language": "ckb",
              "text": "پێش دەستپێکردنی پڕۆژەکە دەبێت هەڵوێستی چاوەڕوانی کڕیار بە ڕوونی ڕوون بکەینەوە."
            },
            {
              "language": "en",
              "text": "Before the project starts, we should explicitly clarify the customer’s expectations."
            },
            {
              "language": "fa",
              "text": "پیش از شروع پروژه باید نگرش و انتظار مشتری را صریحاً روشن کنیم."
            },
            {
              "language": "kmr",
              "text": "Berî destpêka projeyê divê em helwesta hêviyê ya xerîdar bi eşkere zelal bikin."
            },
            {
              "language": "pl",
              "text": "Przed rozpoczęciem projektu powinniśmy wyraźnie wyjaśnić oczekiwania klienta."
            },
            {
              "language": "ro",
              "text": "Înainte de începerea proiectului ar trebui să clarificăm explicit așteptările clientului."
            },
            {
              "language": "ru",
              "text": "Перед началом проекта нам следует прямо прояснить ожидания клиента."
            },
            {
              "language": "sq",
              "text": "Para fillimit të projektit duhet të sqarojmë qartë pritshmëritë e klientit."
            },
            {
              "language": "tr",
              "text": "Proje başlamadan önce müşterinin beklenti tutumunu açıkça netleştirmeliyiz."
            }
          ]
        },
        {
          "baseText": "Eine überzogene Erwartungshaltung im Team führt schnell zu Enttäuschung und Konflikten.",
          "translations": [
            {
              "language": "ar",
              "text": "تؤدي التوقعات المبالغ فيها داخل الفريق بسرعة إلى خيبة أمل ونزاعات."
            },
            {
              "language": "ckb",
              "text": "هەڵوێستی چاوەڕوانی زۆر زیاد لە تیمدا زوو دەبێتە هۆی نائومێدی و ناکۆکی."
            },
            {
              "language": "en",
              "text": "An excessive expectation mindset in the team quickly leads to disappointment and conflict."
            },
            {
              "language": "fa",
              "text": "انتظارات بیش از حد در تیم خیلی زود به ناامیدی و تعارض منجر می‌شود."
            },
            {
              "language": "kmr",
              "text": "Helwesta hêviyê ya zêde di tîmê de zû dibe sedema bêhêvîbûn û nakokiyan."
            },
            {
              "language": "pl",
              "text": "Wygórowane oczekiwania w zespole szybko prowadzą do rozczarowania i konfliktów."
            },
            {
              "language": "ro",
              "text": "O atitudine de așteptare exagerată în echipă duce rapid la dezamăgire și conflicte."
            },
            {
              "language": "ru",
              "text": "Завышенные ожидания в команде быстро приводят к разочарованию и конфликтам."
            },
            {
              "language": "sq",
              "text": "Një mendësi pritshmërish e tepruar në ekip çon shpejt në zhgënjim dhe konflikte."
            },
            {
              "language": "tr",
              "text": "Ekipte aşırı beklenti tutumu hızla hayal kırıklığına ve çatışmalara yol açar."
            }
          ]
        }
      ]
    },
    {
      "word": "die Erwerbstätigkeit",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Erwerbstätigkeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Er-werbs-tä-tig-keit",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; plural is possible when referring to different forms of gainful work"
      ],
      "collocations": [
        {
          "text": "eine Erwerbstätigkeit aufnehmen",
          "meaning": "to take up gainful employment"
        },
        {
          "text": "abhängige Erwerbstätigkeit",
          "meaning": "dependent employment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "erwerbstätig",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "der Erwerb",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عمل مدفوع؛ نشاط مهني لكسب الرزق"
        },
        {
          "language": "ckb",
          "text": "کاری بەپارە؛ چالاکی پیشەیی بۆ داهات"
        },
        {
          "language": "en",
          "text": "gainful employment; paid work"
        },
        {
          "language": "fa",
          "text": "اشتغال؛ فعالیت شغلی درآمدزا"
        },
        {
          "language": "kmr",
          "text": "karê bi pere; xebata dahatê"
        },
        {
          "language": "pl",
          "text": "aktywność zawodowa; praca zarobkowa"
        },
        {
          "language": "ro",
          "text": "activitate profesională remunerată; muncă plătită"
        },
        {
          "language": "ru",
          "text": "трудовая деятельность; оплачиваемая занятость"
        },
        {
          "language": "sq",
          "text": "punësim me pagesë; aktivitet fitimprurës"
        },
        {
          "language": "tr",
          "text": "gelir getirici çalışma; ücretli istihdam"
        }
      ],
      "examples": [
        {
          "baseText": "Nach längerer Krankheit nahm sie ihre Erwerbstätigkeit schrittweise wieder auf.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد مرض طويل استأنفت عملها المدفوع تدريجيًا."
            },
            {
              "language": "ckb",
              "text": "دوای نەخۆشییەکی درێژخایەن، کاری بەپارەی خۆی بە هەنگاو هەنگاو دەستپێکردەوە."
            },
            {
              "language": "en",
              "text": "After a long illness, she gradually resumed her gainful employment."
            },
            {
              "language": "fa",
              "text": "پس از بیماری طولانی، او به‌تدریج دوباره فعالیت شغلی خود را آغاز کرد."
            },
            {
              "language": "kmr",
              "text": "Piştî nexweşiyeke dirêj, wê xebata xwe ya bi pere gav bi gav ji nû ve dest pê kir."
            },
            {
              "language": "pl",
              "text": "Po dłuższej chorobie stopniowo wznowiła aktywność zawodową."
            },
            {
              "language": "ro",
              "text": "După o boală mai lungă, ea și-a reluat treptat activitatea profesională."
            },
            {
              "language": "ru",
              "text": "После длительной болезни она постепенно возобновила трудовую деятельность."
            },
            {
              "language": "sq",
              "text": "Pas një sëmundjeje të gjatë, ajo rifilloi gradualisht punësimin e saj."
            },
            {
              "language": "tr",
              "text": "Uzun bir hastalıktan sonra gelir getirici çalışmasına kademeli olarak yeniden başladı."
            }
          ]
        },
        {
          "baseText": "Für den Antrag muss jede Erwerbstätigkeit der letzten fünf Jahre angegeben werden.",
          "translations": [
            {
              "language": "ar",
              "text": "للطلب يجب ذكر كل نشاط مهني مدفوع خلال السنوات الخمس الأخيرة."
            },
            {
              "language": "ckb",
              "text": "بۆ داواکارییەکە دەبێت هەر کاری بەپارەی پێنج ساڵی ڕابردوو تۆمار بکرێت."
            },
            {
              "language": "en",
              "text": "For the application, every gainful activity in the last five years must be stated."
            },
            {
              "language": "fa",
              "text": "برای درخواست باید هر فعالیت شغلی درآمدزا در پنج سال گذشته ذکر شود."
            },
            {
              "language": "kmr",
              "text": "Ji bo daxwazê divê her xebata dahatê ya pênc salên borî were nivîsîn."
            },
            {
              "language": "pl",
              "text": "We wniosku trzeba podać każdą aktywność zawodową z ostatnich pięciu lat."
            },
            {
              "language": "ro",
              "text": "Pentru cerere trebuie menționată fiecare activitate remunerată din ultimii cinci ani."
            },
            {
              "language": "ru",
              "text": "В заявлении нужно указать каждую оплачиваемую деятельность за последние пять лет."
            },
            {
              "language": "sq",
              "text": "Për aplikimin duhet të shënohet çdo aktivitet fitimprurës i pesë viteve të fundit."
            },
            {
              "language": "tr",
              "text": "Başvuru için son beş yıldaki her gelir getirici faaliyet belirtilmelidir."
            }
          ]
        }
      ]
    },
