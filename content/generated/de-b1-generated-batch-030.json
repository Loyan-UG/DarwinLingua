  "entries": [
    {
      "word": "die Berufsberatung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Berufsberatungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-rufs-be-ra-tung",
      "topics": [
        "work-and-jobs",
        "education-and-training",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "spoken"
      ],
      "contextLabels": [
        "education",
        "training",
        "administration"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "einen Termin bei der Berufsberatung vereinbaren",
          "meaning": "to make an appointment with career guidance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Beruf",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "beraten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الإرشاد المهني"
        },
        {
          "language": "ckb",
          "text": "ڕاوێژکاری پیشەیی"
        },
        {
          "language": "en",
          "text": "career guidance; vocational counseling"
        },
        {
          "language": "fa",
          "text": "مشاوره شغلی؛ راهنمایی حرفه‌ای"
        },
        {
          "language": "kmr",
          "text": "şêwirmendiya pîşeyî"
        },
        {
          "language": "pl",
          "text": "doradztwo zawodowe"
        },
        {
          "language": "ro",
          "text": "consiliere profesională"
        },
        {
          "language": "ru",
          "text": "профориентация; карьерная консультация"
        },
        {
          "language": "sq",
          "text": "këshillim profesional"
        },
        {
          "language": "tr",
          "text": "mesleki danışmanlık"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe nächste Woche einen Termin bei der Berufsberatung.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي موعد الأسبوع القادم في الإرشاد المهني."
            },
            {
              "language": "ckb",
              "text": "هەفتەی داهاتوو کاتێکم لە ڕاوێژکاری پیشەیی هەیە."
            },
            {
              "language": "en",
              "text": "I have an appointment with career guidance next week."
            },
            {
              "language": "fa",
              "text": "هفته آینده یک وقت برای مشاوره شغلی دارم."
            },
            {
              "language": "kmr",
              "text": "Hefteya bê ez wextê şêwirmendiya pîşeyî heye."
            },
            {
              "language": "pl",
              "text": "W przyszłym tygodniu mam termin w poradni zawodowej."
            },
            {
              "language": "ro",
              "text": "Săptămâna viitoare am o programare la consilierea profesională."
            },
            {
              "language": "ru",
              "text": "На следующей неделе у меня встреча в службе профориентации."
            },
            {
              "language": "sq",
              "text": "Javën tjetër kam një takim për këshillim profesional."
            },
            {
              "language": "tr",
              "text": "Gelecek hafta mesleki danışmanlık için randevum var."
            }
          ]
        },
        {
          "baseText": "Die Berufsberatung hat mir geholfen, eine passende Ausbildung zu finden.",
          "translations": [
            {
              "language": "ar",
              "text": "ساعدني الإرشاد المهني في العثور على تدريب مهني مناسب."
            },
            {
              "language": "ckb",
              "text": "ڕاوێژکاری پیشەیی یارمەتیم دا فێربوونی پیشەیی گونجاو بدۆزمەوە."
            },
            {
              "language": "en",
              "text": "Career guidance helped me find suitable vocational training."
            },
            {
              "language": "fa",
              "text": "مشاوره شغلی به من کمک کرد یک دوره آموزش حرفه‌ای مناسب پیدا کنم."
            },
            {
              "language": "kmr",
              "text": "Şêwirmendiya pîşeyî alîkariya min kir ku perwerdeyeke pîşeyî ya guncaw bibînim."
            },
            {
              "language": "pl",
              "text": "Doradztwo zawodowe pomogło mi znaleźć odpowiednie szkolenie zawodowe."
            },
            {
              "language": "ro",
              "text": "Consilierea profesională m-a ajutat să găsesc o formare potrivită."
            },
            {
              "language": "ru",
              "text": "Профориентация помогла мне найти подходящее профессиональное обучение."
            },
            {
              "language": "sq",
              "text": "Këshillimi profesional më ndihmoi të gjej një trajnim të përshtatshëm."
            },
            {
              "language": "tr",
              "text": "Mesleki danışmanlık uygun bir mesleki eğitim bulmama yardımcı oldu."
            }
          ]
        }
      ]
    },
    {
      "word": "die Berufserfahrung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Berufserfahrungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-rufs-er-fah-rung",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "formal",
        "written"
      ],
      "contextLabels": [
        "hr",
        "documents"
      ],
      "grammarNotes": [
        "feminine noun; often used in job applications"
      ],
      "collocations": [
        {
          "text": "Berufserfahrung sammeln",
          "meaning": "to gain work experience"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Beruf",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Erfahrung",
          "relationLabel": "compound part",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خبرة مهنية"
        },
        {
          "language": "ckb",
          "text": "ئەزموونی پیشەیی"
        },
        {
          "language": "en",
          "text": "work experience; professional experience"
        },
        {
          "language": "fa",
          "text": "سابقه کاری؛ تجربه حرفه‌ای"
        },
        {
          "language": "kmr",
          "text": "ezmûna pîşeyî"
        },
        {
          "language": "pl",
          "text": "doświadczenie zawodowe"
        },
        {
          "language": "ro",
          "text": "experiență profesională"
        },
        {
          "language": "ru",
          "text": "профессиональный опыт; стаж работы"
        },
        {
          "language": "sq",
          "text": "përvojë pune; përvojë profesionale"
        },
        {
          "language": "tr",
          "text": "iş deneyimi; mesleki deneyim"
        }
      ],
      "examples": [
        {
          "baseText": "Für diese Stelle brauchen Sie mindestens zwei Jahre Berufserfahrung.",
          "translations": [
            {
              "language": "ar",
              "text": "لهذه الوظيفة تحتاج إلى خبرة مهنية لا تقل عن سنتين."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم پۆستە پێویستتان بە لانیکەم دوو ساڵ ئەزموونی پیشەیی هەیە."
            },
            {
              "language": "en",
              "text": "For this position, you need at least two years of work experience."
            },
            {
              "language": "fa",
              "text": "برای این موقعیت شغلی حداقل به دو سال سابقه کاری نیاز دارید."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê pozîsyonê herî kêm du sal ezmûna pîşeyî divê."
            },
            {
              "language": "pl",
              "text": "Na tym stanowisku potrzebne są co najmniej dwa lata doświadczenia zawodowego."
            },
            {
              "language": "ro",
              "text": "Pentru acest post aveți nevoie de cel puțin doi ani de experiență profesională."
            },
            {
              "language": "ru",
              "text": "Для этой должности нужен как минимум двухлетний опыт работы."
            },
            {
              "language": "sq",
              "text": "Për këtë pozicion ju duhen të paktën dy vjet përvojë pune."
            },
            {
              "language": "tr",
              "text": "Bu pozisyon için en az iki yıl iş deneyimine ihtiyacınız var."
            }
          ]
        },
        {
          "baseText": "Während des Praktikums konnte ich erste Berufserfahrung sammeln.",
          "translations": [
            {
              "language": "ar",
              "text": "خلال التدريب العملي تمكنت من اكتساب أول خبرة مهنية."
            },
            {
              "language": "ckb",
              "text": "لە ماوەی پراکتیکدا توانیم یەکەم ئەزموونی پیشەیی کۆبکەمەوە."
            },
            {
              "language": "en",
              "text": "During the internship, I was able to gain my first work experience."
            },
            {
              "language": "fa",
              "text": "در طول کارآموزی توانستم اولین تجربه کاری خود را کسب کنم."
            },
            {
              "language": "kmr",
              "text": "Di dema stajê de min karî ezmûna xwe ya yekem a pîşeyî bi dest bixim."
            },
            {
              "language": "pl",
              "text": "Podczas praktyki mogłem zdobyć pierwsze doświadczenie zawodowe."
            },
            {
              "language": "ro",
              "text": "În timpul stagiului am putut acumula prima experiență profesională."
            },
            {
              "language": "ru",
              "text": "Во время практики я смог получить первый профессиональный опыт."
            },
            {
              "language": "sq",
              "text": "Gjatë praktikës munda të fitoj përvojën time të parë të punës."
            },
            {
              "language": "tr",
              "text": "Staj sırasında ilk iş deneyimimi kazanabildim."
            }
          ]
        }
      ]
    },
