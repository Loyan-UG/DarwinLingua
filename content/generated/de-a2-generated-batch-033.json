        }
      ],
      "examples": [
        {
          "baseText": "Ich erkenne dich auf dem Foto kaum.",
          "translations": [
            {
              "language": "ar",
              "text": "بالكاد أتعرف عليك في الصورة."
            },
            {
              "language": "ckb",
              "text": "لە وێنەکەدا بە زەحمەت دەتناسمەوە."
            },
            {
              "language": "en",
              "text": "I can hardly recognize you in the photo."
            },
            {
              "language": "fa",
              "text": "در عکس به سختی تو را می‌شناسم."
            },
            {
              "language": "kmr",
              "text": "Ez di wêneyê de bi zor te nas dikim."
            },
            {
              "language": "pl",
              "text": "Ledwo rozpoznaję cię na zdjęciu."
            },
            {
              "language": "ro",
              "text": "Abia te recunosc în fotografie."
            },
            {
              "language": "ru",
              "text": "Я едва узнаю тебя на фотографии."
            },
            {
              "language": "sq",
              "text": "Mezi të njoh në foto."
            },
            {
              "language": "tr",
              "text": "Fotoğrafta seni zor tanıyorum."
            }
          ]
        },
        {
          "baseText": "Das Programm erkennt den Fehler nicht.",
          "translations": [
            {
              "language": "ar",
              "text": "البرنامج لا يكتشف الخطأ."
            },
            {
              "language": "ckb",
              "text": "بەرنامەکە هەڵەکە ناناسێتەوە."
            },
            {
              "language": "en",
              "text": "The program does not detect the error."
            },
            {
              "language": "fa",
              "text": "برنامه خطا را تشخیص نمی‌دهد."
            },
            {
              "language": "kmr",
              "text": "Bername xeletiyê nas nake."
            },
            {
              "language": "pl",
              "text": "Program nie wykrywa błędu."
            },
            {
              "language": "ro",
              "text": "Programul nu detectează eroarea."
            },
            {
              "language": "ru",
              "text": "Программа не распознает ошибку."
            },
            {
              "language": "sq",
              "text": "Programi nuk e dallon gabimin."
            },
            {
              "language": "tr",
              "text": "Program hatayı algılamıyor."
            }
          ]
        }
      ]
