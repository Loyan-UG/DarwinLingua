      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb; often reflexive: sich erinnern; also jemand(en) an etwas erinnern"
      ],
      "collocations": [
        {
          "text": "sich an etwas erinnern",
          "meaning": "to remember something"
        },
        {
          "text": "jemanden an einen Termin erinnern",
          "meaning": "to remind someone of an appointment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erinnerung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتذكر؛ يذكّر"
        },
        {
          "language": "ckb",
          "text": "بیرهاتنەوە؛ بیرخستنەوە"
        },
        {
          "language": "en",
          "text": "to remember; to remind"
        },
        {
          "language": "fa",
          "text": "به یاد آوردن؛ یادآوری کردن"
        },
        {
          "language": "kmr",
          "text": "bîr anîn; bîr xistin"
        },
        {
          "language": "pl",
          "text": "pamiętać; przypominać"
        },
        {
          "language": "ro",
          "text": "a-și aminti; a reaminti"
        },
        {
          "language": "ru",
          "text": "помнить; напоминать"
        },
        {
          "language": "sq",
          "text": "të kujtosh; të rikujtosh"
        },
        {
          "language": "tr",
          "text": "hatırlamak; hatırlatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du mich morgen an den Termin erinnern?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن تذكرني بالموعد غداً؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت سبەی کاتەکەم بیر بخەیتەوە؟"
            },
            {
              "language": "en",
              "text": "Can you remind me of the appointment tomorrow?"
            },
            {
              "language": "fa",
              "text": "می‌توانی فردا وقت ملاقات را به من یادآوری کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî sibê wextê bîne bîra min?"
            },
            {
              "language": "pl",
              "text": "Czy możesz mi jutro przypomnieć o terminie?"
            },
            {
              "language": "ro",
              "text": "Poți să îmi amintești mâine de programare?"
            },
            {
              "language": "ru",
              "text": "Можешь завтра напомнить мне о встрече?"
            },
            {
              "language": "sq",
              "text": "A mund të më kujtosh nesër për takimin?"
            },
            {
              "language": "tr",
              "text": "Yarın bana randevuyu hatırlatabilir misin?"
            }
          ]
        },
        {
          "baseText": "Ich erinnere mich gut an meinen ersten Deutschkurs.",
          "translations": [
            {
              "language": "ar",
              "text": "أتذكر جيداً أول دورة ألمانية لي."
            },
            {
              "language": "ckb",
              "text": "کۆرسی یەکەمی ئەڵمانیم باش بیرە."
            },
            {
              "language": "en",
              "text": "I remember my first German course well."
            },
            {
              "language": "fa",
              "text": "اولین کلاس آلمانی‌ام را خوب به یاد دارم."
            },
            {
              "language": "kmr",
              "text": "Ez kursa xwe ya yekem a Almanî baş tînim bîra xwe."
            },
            {
              "language": "pl",
              "text": "Dobrze pamiętam mój pierwszy kurs niemieckiego."
            },
            {
              "language": "ro",
              "text": "Îmi amintesc bine primul meu curs de germană."
            },
            {
              "language": "ru",
              "text": "Я хорошо помню свой первый курс немецкого."
            },
            {
              "language": "sq",
              "text": "E kujtoj mirë kursin tim të parë të gjermanishtes."
            },
            {
              "language": "tr",
              "text": "İlk Almanca kursumu iyi hatırlıyorum."
            }
          ]
        }
      ]
    },
