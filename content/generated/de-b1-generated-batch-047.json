  "entries": [
    {
      "word": "einreiben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "einreiben",
      "pronunciationIpa": null,
      "syllableBreak": "ein-rei-ben",
      "topics": [
        "healthcare-and-appointments",
        "everyday-life",
        "customer-service"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "healthcare",
        "appointments",
        "customer-service"
      ],
      "grammarNotes": [
        "separable strong verb: reibt ein, rieb ein, hat eingerieben"
      ],
      "collocations": [
        {
          "text": "eine Salbe einreiben",
          "meaning": "to rub in an ointment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "reiben",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدهن؛ يفرك بمرهم"
        },
        {
          "language": "ckb",
          "text": "سوورکردن؛ چەورکردن بە کرێم"
        },
        {
          "language": "en",
          "text": "to rub in; to apply by rubbing"
        },
        {
          "language": "fa",
          "text": "مالیدن؛ با پماد ماساژ دادن"
        },
        {
          "language": "kmr",
          "text": "lê xistin; bi kremê masaj kirin"
        },
        {
          "language": "pl",
          "text": "wcierać; nacierać"
        },
        {
          "language": "ro",
          "text": "a freca; a aplica prin masaj"
        },
        {
          "language": "ru",
          "text": "втирать; натирать"
        },
        {
          "language": "sq",
          "text": "të fërkosh; të lyesh duke fërkuar"
        },
        {
          "language": "tr",
          "text": "sürmek; ovarak uygulamak"
        }
      ],
      "examples": [
        {
          "baseText": "Reiben Sie die Salbe zweimal täglich auf die schmerzende Stelle ein.",
          "translations": [
            {
              "language": "ar",
              "text": "ادهن المرهم مرتين يوميًا على الموضع المؤلم."
            },
            {
              "language": "ckb",
              "text": "کرێمەکە ڕۆژانە دوو جار لە شوێنی ئازاردار بسوورن."
            },
            {
              "language": "en",
              "text": "Rub the ointment into the painful area twice a day."
            },
            {
              "language": "fa",
              "text": "پماد را روزی دو بار روی محل دردناک بمالید."
            },
            {
              "language": "kmr",
              "text": "Kremê rojê du caran li cihê êşê bixin û masaj bikin."
            },
            {
              "language": "pl",
              "text": "Proszę wcierać maść dwa razy dziennie w bolące miejsce."
            },
            {
              "language": "ro",
              "text": "Frecați unguentul de două ori pe zi pe zona dureroasă."
            },
            {
              "language": "ru",
              "text": "Втирайте мазь в болезненное место два раза в день."
            },
            {
              "language": "sq",
              "text": "Fërkojeni pomadën dy herë në ditë në vendin që dhemb."
            },
            {
              "language": "tr",
              "text": "Merhemi ağrıyan bölgeye günde iki kez sürün."
            }
          ]
        },
        {
          "baseText": "Vor der Arbeit im Garten reibt sie ihre Hände mit Schutzcreme ein.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل العمل في الحديقة تدهن يديها بكريم حماية."
            },
            {
              "language": "ckb",
              "text": "پێش کارکردن لە باخچەدا دەستەکانی بە کرێمی پاراستن چەور دەکات."
            },
            {
              "language": "en",
              "text": "Before working in the garden, she rubs protective cream into her hands."
            },
            {
              "language": "fa",
              "text": "قبل از کار در باغ، دست‌هایش را با کرم محافظ می‌پوشاند."
            },
            {
              "language": "kmr",
              "text": "Berî xebata li baxçe, ew destên xwe bi krema parastinê dixemilîne."
            },
            {
              "language": "pl",
              "text": "Przed pracą w ogrodzie wciera w ręce krem ochronny."
            },
            {
              "language": "ro",
              "text": "Înainte de munca în grădină își unge mâinile cu cremă de protecție."
            },
            {
              "language": "ru",
              "text": "Перед работой в саду она натирает руки защитным кремом."
            },
            {
              "language": "sq",
              "text": "Para punës në kopsht ajo lyen duart me krem mbrojtës."
            },
            {
              "language": "tr",
              "text": "Bahçede çalışmadan önce ellerine koruyucu krem sürer."
            }
          ]
        }
      ]
    },
