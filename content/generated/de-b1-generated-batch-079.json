  "entries": [
    {
      "word": "die Jahreskarte",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Jahreskarten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Jah-res-kar-te",
      "topics": [
        "transport-and-travel",
        "shopping-and-services",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "customer-facing",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; ticket or pass valid for one year"
      ],
      "collocations": [
        {
          "text": "eine Jahreskarte kaufen",
          "meaning": "to buy an annual pass"
        },
        {
          "text": "die Jahreskarte verlängern",
          "meaning": "to renew the annual pass"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Jahr",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Karte",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بطاقة سنوية؛ تذكرة سنوية"
        },
        {
          "language": "ckb",
          "text": "کارتی ساڵانە"
        },
        {
          "language": "en",
          "text": "annual pass; yearly ticket"
        },
        {
          "language": "fa",
          "text": "کارت سالانه؛ بلیت سالانه"
        },
        {
          "language": "kmr",
          "text": "karta salane; bilêta salane"
        },
        {
          "language": "pl",
          "text": "karta roczna; bilet roczny"
        },
        {
          "language": "ro",
          "text": "abonament anual; card anual"
        },
        {
          "language": "ru",
          "text": "годовой абонемент; годовой билет"
        },
        {
          "language": "sq",
          "text": "kartë vjetore; biletë vjetore"
        },
        {
          "language": "tr",
          "text": "yıllık kart; yıllık bilet"
        }
      ],
      "examples": [
        {
          "baseText": "Für den täglichen Weg zur Arbeit lohnt sich eine Jahreskarte.",
          "translations": [
            {
              "language": "ar",
              "text": "للطريق اليومي إلى العمل تستحق البطاقة السنوية الشراء."
            },
            {
              "language": "ckb",
              "text": "بۆ ڕێگای ڕۆژانە بۆ کار، کارتی ساڵانە بەسوودە."
            },
            {
              "language": "en",
              "text": "For the daily commute to work, an annual pass is worthwhile."
            },
            {
              "language": "fa",
              "text": "برای رفت‌وآمد روزانه به محل کار، کارت سالانه به‌صرفه است."
            },
            {
              "language": "kmr",
              "text": "Ji bo rêya rojane ya karê, karta salane hêja ye."
            },
            {
              "language": "pl",
              "text": "Na codzienny dojazd do pracy karta roczna się opłaca."
            },
            {
              "language": "ro",
              "text": "Pentru drumul zilnic la serviciu, un abonament anual merită."
            },
            {
              "language": "ru",
              "text": "Для ежедневной поездки на работу годовой абонемент выгоден."
            },
            {
              "language": "sq",
              "text": "Për udhëtimin e përditshëm në punë ia vlen një kartë vjetore."
            },
            {
              "language": "tr",
              "text": "İşe günlük gidiş geliş için yıllık kart avantajlıdır."
            }
          ]
        },
        {
          "baseText": "Die Jahreskarte für das Schwimmbad kann online verlängert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن تمديد البطاقة السنوية للمسبح عبر الإنترنت."
            },
            {
              "language": "ckb",
              "text": "کارتی ساڵانەی مەلەوانگەکە دەتوانرێت ئۆنلاین درێژ بکرێتەوە."
            },
            {
              "language": "en",
              "text": "The annual pass for the swimming pool can be renewed online."
            },
            {
              "language": "fa",
              "text": "کارت سالانه استخر را می‌توان آنلاین تمدید کرد."
            },
            {
              "language": "kmr",
              "text": "Karta salane ya hewza avjeniyê dikare serhêl bê dirêjkirin."
            },
            {
              "language": "pl",
              "text": "Kartę roczną na basen można przedłużyć online."
            },
            {
              "language": "ro",
              "text": "Abonamentul anual pentru piscină poate fi prelungit online."
            },
            {
              "language": "ru",
              "text": "Годовой абонемент в бассейн можно продлить онлайн."
            },
            {
              "language": "sq",
              "text": "Karta vjetore për pishinën mund të zgjatet online."
            },
            {
              "language": "tr",
              "text": "Yüzme havuzu yıllık kartı çevrim içi uzatılabilir."
            }
          ]
        }
      ]
    },
    {
      "word": "das Jobcenter",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Jobcenter",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Job-cen-ter",
      "topics": [
        "public-services",
        "work-and-jobs",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "everyday"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; public office for employment support and benefits in Germany"
      ],
      "collocations": [
        {
          "text": "beim Jobcenter einen Antrag stellen",
          "meaning": "to submit an application at the job center"
        },
        {
          "text": "einen Termin beim Jobcenter haben",
          "meaning": "to have an appointment at the job center"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Job",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "das Center",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مركز العمل؛ مكتب دعم العمل"
        },
        {
          "language": "ckb",
          "text": "سەنتەری کار؛ جۆبسەنتەر"
        },
        {
          "language": "en",
          "text": "job center; employment support office"
        },
        {
          "language": "fa",
          "text": "مرکز کار؛ اداره حمایت شغلی"
        },
        {
          "language": "kmr",
          "text": "navenda kar; Jobcenter"
        },
        {
          "language": "pl",
          "text": "urząd pracy; Jobcenter"
        },
        {
          "language": "ro",
          "text": "centru pentru ocuparea forței de muncă; Jobcenter"
        },
        {
          "language": "ru",
          "text": "центр занятости; Jobcenter"
        },
        {
          "language": "sq",
          "text": "qendër pune; zyrë mbështetjeje për punësim"
        },
        {
          "language": "tr",
          "text": "iş merkezi; iş destek kurumu"
        }
      ],
      "examples": [
        {
          "baseText": "Das Jobcenter braucht noch eine Kopie des Mietvertrags.",
          "translations": [
            {
              "language": "ar",
              "text": "يحتاج مركز العمل إلى نسخة من عقد الإيجار أيضاً."
            },
            {
              "language": "ckb",
              "text": "جۆبسەنتەرەکە هێشتا پێویستی بە کۆپییەکی گرێبەستی کرێ هەیە."
            },
            {
              "language": "en",
              "text": "The job center still needs a copy of the rental contract."
            },
            {
              "language": "fa",
              "text": "مرکز کار هنوز به یک کپی از قرارداد اجاره نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Jobcenter hîn hewceyê kopiyek ji peymana kirê ye."
            },
            {
              "language": "pl",
              "text": "Jobcenter potrzebuje jeszcze kopii umowy najmu."
            },
            {
              "language": "ro",
              "text": "Jobcenterul mai are nevoie de o copie a contractului de închiriere."
            },
            {
              "language": "ru",
              "text": "Центру занятости ещё нужна копия договора аренды."
            },
            {
              "language": "sq",
              "text": "Qendrës së punës i duhet ende një kopje e kontratës së qirasë."
            },
            {
              "language": "tr",
              "text": "Jobcenter hâlâ kira sözleşmesinin bir kopyasına ihtiyaç duyuyor."
            }
          ]
        },
        {
          "baseText": "Sie hat nächste Woche einen Termin beim Jobcenter wegen der Weiterbildung.",
          "translations": [
            {
              "language": "ar",
              "text": "لديها موعد في مركز العمل الأسبوع القادم بسبب التدريب المهني."
            },
            {
              "language": "ckb",
              "text": "هەفتەی داهاتوو لە جۆبسەنتەر کاتی هەیە بۆ فێربوونی زیاتر."
            },
            {
              "language": "en",
              "text": "She has an appointment at the job center next week about further training."
            },
            {
              "language": "fa",
              "text": "او هفته آینده به خاطر آموزش تکمیلی در مرکز کار وقت دارد."
            },
            {
              "language": "kmr",
              "text": "Hefteya bê ew ji bo perwerdeya pêşketî li Jobcenter randevû heye."
            },
            {
              "language": "pl",
