      "word": "die Faktura",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Fakturen",
      "infinitive": null,
      "syllableBreak": "Fak-tu-ra",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "written"
      ],
      "grammarNotes": [
        "feminine noun; mainly business/accounting language"
      ],
      "collocations": [
        {
          "text": "eine Faktura erstellen",
          "meaning": "to create an invoice"
        },
        {
          "text": "die Faktura prüfen",
          "meaning": "to check the invoice"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fakturieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Fakturierung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "فاتورة"
        },
        {
          "language": "ckb",
          "text": "فاکتورە"
        },
        {
          "language": "en",
          "text": "invoice"
        },
        {
          "language": "fa",
          "text": "فاکتور"
        },
        {
          "language": "kmr",
          "text": "fatûre"
        },
        {
          "language": "pl",
          "text": "faktura"
        },
        {
          "language": "ro",
          "text": "factură"
        },
        {
          "language": "ru",
          "text": "счет-фактура"
        },
        {
          "language": "sq",
          "text": "faturë"
        },
        {
          "language": "tr",
          "text": "fatura"
        }
      ],
      "examples": [
        {
          "baseText": "Die Faktura wurde automatisch aus dem ERP-System erstellt.",
          "translations": [
            {
              "language": "ar",
              "text": "تم إنشاء الفاتورة تلقائيًا من نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "فاکتورەکە خۆکارانە لە سیستەمی ERP دروست کرا."
            },
            {
              "language": "en",
              "text": "The invoice was created automatically from the ERP system."
            },
            {
              "language": "fa",
              "text": "فاکتور به صورت خودکار از سیستم ERP ایجاد شد."
            },
            {
              "language": "kmr",
              "text": "Fatûre bixweber ji pergala ERP hate çêkirin."
            },
            {
              "language": "pl",
              "text": "Faktura została automatycznie utworzona w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Factura a fost creată automat din sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Счет-фактура был автоматически создан из ERP-системы."
            },
            {
              "language": "sq",
              "text": "Fatura u krijua automatikisht nga sistemi ERP."
            },
            {
              "language": "tr",
              "text": "Fatura ERP sisteminden otomatik olarak oluşturuldu."
            }
          ]
        },
        {
          "baseText": "Bitte senden Sie uns die Faktura noch einmal als PDF.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال الفاتورة إلينا مرة أخرى بصيغة PDF."
            },
            {
              "language": "ckb",
              "text": "تکایە فاکتورەکە جارێکی تر وەک PDF بۆمان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us the invoice again as a PDF."
            },
            {
              "language": "fa",
              "text": "لطفاً فاکتور را دوباره به صورت PDF برای ما ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fatûreyê careke din wekî PDF ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać nam fakturę jeszcze raz jako PDF."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți factura încă o dată ca PDF."
            },
            {
              "language": "ru",
