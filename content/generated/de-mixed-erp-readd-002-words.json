      "word": "das Depot",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Depots",
      "infinitive": null,
      "syllableBreak": "De-pot",
      "topics": [
        "warehouse-and-logistics",
        "finance-and-accounting",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "technical"
      ],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "ein Depot verwalten",
          "meaning": "to manage a depot or securities account"
        },
        {
          "text": "im Depot lagern",
          "meaning": "to store in the depot"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مستودع؛ حساب أوراق مالية"
        },
        {
          "language": "ckb",
          "text": "کۆگا؛ ئەکاونتی وەبەرهێنان"
        },
        {
          "language": "en",
          "text": "depot; securities account"
        },
        {
          "language": "fa",
          "text": "انبار؛ حساب سرمایه‌گذاری"
        },
        {
          "language": "kmr",
          "text": "depo; hesabê sermayeyê"
        },
        {
          "language": "pl",
          "text": "depozyt; magazyn; rachunek papierów wartościowych"
        },
        {
          "language": "ro",
          "text": "depozit; cont de valori mobiliare"
        },
        {
          "language": "ru",
          "text": "депо; склад; счет ценных бумаг"
        },
        {
          "language": "sq",
          "text": "depo; llogari letrash me vlerë"
        },
        {
          "language": "tr",
          "text": "depo; menkul kıymet hesabı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Ersatzteile liegen im Depot und sind im ERP-System reserviert.",
          "translations": [
            {
              "language": "ar",
              "text": "قطع الغيار موجودة في المستودع ومحجوزة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "پارچەی یەدەگەکان لە کۆگادان و لە سیستەمی ERPدا حجزکراون."
            },
            {
              "language": "en",
              "text": "The spare parts are in the depot and reserved in the ERP system."
            },
            {
              "language": "fa",
              "text": "قطعات یدکی در انبار هستند و در سیستم ERP رزرو شده‌اند."
            },
            {
              "language": "kmr",
              "text": "Parçeyên yedek di depoyê de ne û di pergala ERP de hatine veqetandin."
            },
            {
              "language": "pl",
              "text": "Części zamienne są w magazynie i są zarezerwowane w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Piesele de schimb sunt în depozit și sunt rezervate în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Запчасти находятся на складе и зарезервированы в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Pjesët rezervë janë në depo dhe janë të rezervuara në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Yedek parçalar depoda ve ERP sisteminde rezerve edilmiş durumda."
            }
          ]
        },
        {
          "baseText": "Meine Bank zeigt den aktuellen Wert meines Depots an.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض بنكي القيمة الحالية لحسابي الاستثماري."
            },
            {
              "language": "ckb",
              "text": "بانکەکەم بەهای ئێستای ئەکاونتی وەبەرهێنانەکەم پیشان دەدات."
            },
            {
              "language": "en",
              "text": "My bank shows the current value of my securities account."
            },
            {
              "language": "fa",
              "text": "بانکم ارزش فعلی حساب سرمایه‌گذاری‌ام را نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Banka min nirxê niha yê hesabê sermayeyê min nîşan dide."
            },
            {
              "language": "pl",
              "text": "Mój bank pokazuje aktualną wartość mojego rachunku papierów wartościowych."
            },
            {
              "language": "ro",
              "text": "Banca mea arată valoarea actuală a portofoliului meu."
            },
            {
              "language": "ru",
              "text": "Мой банк показывает текущую стоимость моего инвестиционного счета."
            },
            {
              "language": "sq",
              "text": "Banka ime tregon vlerën aktuale të llogarisë sime të investimeve."
            },
            {
              "language": "tr",
              "text": "Bankam yatırım hesabımın güncel değerini gösteriyor."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "der Einkäufer",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Einkäufer",
      "infinitive": null,
      "syllableBreak": "Ein-käu-fer",
      "topics": [
        "procurement-and-suppliers",
        "work-and-jobs",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace"
      ],
      "grammarNotes": [
        "masculine noun; feminine form: die Einkäuferin"
      ],
      "collocations": [
        {
          "text": "mit dem Einkäufer sprechen",
          "meaning": "to speak with the buyer or purchaser"
        },
        {
          "text": "der zuständige Einkäufer",
          "meaning": "the responsible purchaser"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "einkaufen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Einkäuferin",
          "relationLabel": "feminine form",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "المشتري؛ موظف المشتريات"
        },
        {
          "language": "ckb",
          "text": "کڕیار؛ کارمەندی کڕین"
        },
        {
          "language": "en",
          "text": "buyer; purchaser"
        },
        {
          "language": "fa",
          "text": "خریدار؛ کارشناس خرید"
        },
        {
          "language": "kmr",
          "text": "kirrîner; berpirsê kirînê"
        },
        {
          "language": "pl",
          "text": "kupiec; pracownik działu zakupów"
        },
        {
          "language": "ro",
          "text": "cumpărător; responsabil achiziții"
        },
        {
          "language": "ru",
          "text": "закупщик; специалист по закупкам"
        },
        {
          "language": "sq",
          "text": "blerës; punonjës i blerjeve"
        },
        {
          "language": "tr",
          "text": "satın almacı; alıcı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Einkäufer prüft im ERP-System, ob der Lieferant freigegeben ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يتحقق موظف المشتريات في نظام تخطيط موارد المؤسسة مما إذا كان المورد معتمدًا."
            },
            {
              "language": "ckb",
              "text": "کارمەندی کڕین لە سیستەمی ERPدا دەبینێت ئایا دابینکەرەکە ڕێگەپێدراوە."
            },
            {
              "language": "en",
              "text": "The purchaser checks in the ERP system whether the supplier is approved."
            },
            {
              "language": "fa",
              "text": "کارشناس خرید در سیستم ERP بررسی می‌کند که آیا تأمین‌کننده تأیید شده است یا نه."
            },
            {
              "language": "kmr",
              "text": "Berpirsê kirînê di pergala ERP de kontrol dike ka dabînker pejirandî ye an na."
            },
            {
              "language": "pl",
              "text": "Kupiec sprawdza w systemie ERP, czy dostawca jest zatwierdzony."
            },
            {
              "language": "ro",
              "text": "Responsabilul de achiziții verifică în sistemul ERP dacă furnizorul este aprobat."
            },
            {
              "language": "ru",
              "text": "Закупщик проверяет в ERP-системе, одобрен ли поставщик."
            },
            {
              "language": "sq",
              "text": "Punonjësi i blerjeve kontrollon në sistemin ERP nëse furnizuesi është miratuar."
            },
            {
              "language": "tr",
              "text": "Satın almacı, tedarikçinin onaylı olup olmadığını ERP sisteminde kontrol eder."
            }
          ]
        },
        {
          "baseText": "Bitte schicken Sie das Angebot direkt an unseren Einkäufer.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال العرض مباشرة إلى موظف المشتريات لدينا."
            },
            {
              "language": "ckb",
              "text": "تکایە پێشنیارەکە ڕاستەوخۆ بۆ کارمەندی کڕینی ئێمە بنێرن."
            },
            {
              "language": "en",
              "text": "Please send the offer directly to our purchaser."
            },
            {
              "language": "fa",
              "text": "لطفاً پیشنهاد قیمت را مستقیم برای کارشناس خرید ما بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pêşniyarê rasterast ji berpirsê kirînê me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę wysłać ofertę bezpośrednio do naszego kupca."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să trimiteți oferta direct responsabilului nostru de achiziții."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте предложение напрямую нашему закупщику."
            },
            {
              "language": "sq",
              "text": "Ju lutemi dërgojani ofertën drejtpërdrejt punonjësit tonë të blerjeve."
            },
            {
              "language": "tr",
              "text": "Lütfen teklifi doğrudan satın almacımıza gönderin."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
