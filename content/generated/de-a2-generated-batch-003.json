      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable irregular verb: ich nehme ab, ich habe abgenommen"
      ],
      "collocations": [
        {
          "text": "drei Kilo abnehmen",
          "meaning": "to lose three kilos"
        },
        {
          "text": "den Hut abnehmen",
          "meaning": "to take off the hat"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "nehmen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفقد وزناً؛ يخلع/ينزع"
        },
        {
          "language": "ckb",
          "text": "کێش کەمکردن؛ لابردن"
        },
        {
          "language": "en",
          "text": "to lose weight; to take off"
        },
        {
          "language": "fa",
          "text": "وزن کم کردن؛ برداشتن/درآوردن"
        },
        {
          "language": "kmr",
          "text": "kêş kêm kirin; rakirin"
        },
        {
          "language": "pl",
          "text": "schudnąć; zdjąć"
        },
        {
          "language": "ro",
          "text": "a slăbi; a da jos"
        },
        {
          "language": "ru",
          "text": "худеть; снимать"
        },
        {
          "language": "sq",
          "text": "të dobësohesh; të heqësh"
        },
        {
          "language": "tr",
          "text": "kilo vermek; çıkarmak"
        }
      ],
      "examples": [
        {
          "baseText": "Er möchte fünf Kilo abnehmen.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد أن ينقص خمسة كيلوغرامات."
            },
            {
              "language": "ckb",
              "text": "دەیەوێت پێنج کیلۆ کێشی کەم بکات."
            },
            {
              "language": "en",
              "text": "He wants to lose five kilos."
            },
            {
              "language": "fa",
              "text": "او می‌خواهد پنج کیلو وزن کم کند."
            },
            {
              "language": "kmr",
              "text": "Ew dixwaze pênc kîlo kêm bike."
            },
            {
              "language": "pl",
              "text": "On chce schudnąć pięć kilo."
            },
            {
              "language": "ro",
              "text": "El vrea să slăbească cinci kilograme."
            },
            {
              "language": "ru",
              "text": "Он хочет похудеть на пять килограммов."
            },
            {
              "language": "sq",
              "text": "Ai dëshiron të humbasë pesë kilogramë."
            },
            {
              "language": "tr",
              "text": "Beş kilo vermek istiyor."
            }
          ]
        },
        {
          "baseText": "Bitte nehmen Sie im Wartezimmer die Mütze ab.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى خلع القبعة في غرفة الانتظار."
            },
            {
              "language": "ckb",
              "text": "تکایە لە ژووری چاوەڕوانی کڵاوەکەت لاببە."
            },
            {
              "language": "en",
              "text": "Please take off your cap in the waiting room."
            },
            {
              "language": "fa",
              "text": "لطفاً در اتاق انتظار کلاهتان را بردارید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li odeya bendê kulîlkê ji serê xwe rakin."
            },
            {
              "language": "pl",
              "text": "Proszę zdjąć czapkę w poczekalni."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să vă dați jos căciula în sala de așteptare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, снимите шапку в зале ожидания."
            },
            {
              "language": "sq",
              "text": "Ju lutem hiqni kapelën në dhomën e pritjes."
            },
            {
              "language": "tr",
              "text": "Lütfen bekleme odasında şapkanızı çıkarın."
            }
          ]
        }
      ]
    },
