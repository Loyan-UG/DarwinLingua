      "meanings": [
        {
          "language": "ar",
          "text": "كشف حساب؛ تسوية حساب"
        },
        {
          "language": "ckb",
          "text": "لێکدانەوەی پارە؛ حسابکردن"
        },
        {
          "language": "en",
          "text": "statement; billing; settlement"
        },
        {
          "language": "fa",
          "text": "صورت‌حساب؛ تسویه حساب"
        },
        {
          "language": "kmr",
          "text": "hesabname; hesabkirin"
        },
        {
          "language": "pl",
          "text": "rozliczenie; rachunek"
        },
        {
          "language": "ro",
          "text": "decont; calcul final"
        },
        {
          "language": "ru",
          "text": "расчет; счет; выписка"
        },
        {
          "language": "sq",
          "text": "llogaritje; faturim"
        },
        {
          "language": "tr",
          "text": "hesap dökümü; hesaplaşma"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe die Abrechnung per E-Mail bekommen.",
          "translations": [
            {
              "language": "ar",
              "text": "تلقيت كشف الحساب عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "لێکدانەوەی پارەکەم بە ئیمەیڵ وەرگرت."
            },
            {
              "language": "en",
              "text": "I received the statement by email."
            },
            {
              "language": "fa",
              "text": "صورت‌حساب را با ایمیل دریافت کردم."
            },
            {
              "language": "kmr",
              "text": "Min hesabname bi e-name wergirt."
            },
            {
              "language": "pl",
              "text": "Otrzymałem rozliczenie e-mailem."
            },
            {
              "language": "ro",
              "text": "Am primit decontul prin e-mail."
            },
            {
              "language": "ru",
              "text": "Я получил расчет по электронной почте."
            },
            {
              "language": "sq",
              "text": "E mora llogaritjen me email."
            },
            {
              "language": "tr",
              "text": "Hesap dökümünü e-posta ile aldım."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie die Abrechnung bis Freitag.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى فحص كشف الحساب حتى يوم الجمعة."
            },
            {
              "language": "ckb",
              "text": "تکایە تا هەینی لێکدانەوەی پارەکە بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the statement by Friday."
            },
            {
              "language": "fa",
              "text": "لطفاً تا جمعه صورت‌حساب را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe heta înê hesabnameyê kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić rozliczenie do piątku."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați decontul până vineri."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте расчет до пятницы."
            },
            {
              "language": "sq",
              "text": "Ju lutem kontrolloni llogaritjen deri të premten."
            },
            {
              "language": "tr",
              "text": "Lütfen hesap dökümünü cumaya kadar kontrol edin."
            }
          ]
        }
      ]
    },
