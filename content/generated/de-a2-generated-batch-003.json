    {
      "word": "abmelden",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abmelden",
      "pronunciationIpa": null,
      "syllableBreak": "ab-mel-den",
      "topics": [
        "documents-and-administration",
        "everyday-life",
        "public-services"
      ],
      "usageLabels": [
        "written",
        "polite",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: ich melde ab, ich habe abgemeldet"
      ],
      "collocations": [
        {
          "text": "sich vom Kurs abmelden",
          "meaning": "to deregister from the course"
        },
        {
          "text": "das Auto abmelden",
          "meaning": "to deregister the car"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "anmelden",
          "relationLabel": "verb",
          "note": "opposite in many contexts"
        },
        {
          "lemma": "die Abmeldung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يلغي التسجيل؛ يسجل الخروج"
        },
        {
          "language": "ckb",
          "text": "ناونووسین هەڵوەشاندنەوە؛ دەرچوون لە هەژمار"
        },
        {
          "language": "en",
          "text": "to deregister; to log out"
        },
        {
          "language": "fa",
          "text": "لغو ثبت‌نام کردن؛ خارج شدن از حساب"
        },
        {
          "language": "kmr",
          "text": "tomarkirin betal kirin; derketin"
        },
        {
          "language": "pl",
          "text": "wymeldować; wyrejestrować; wylogować"
        },
        {
          "language": "ro",
          "text": "a dezabona; a radia; a se deloga"
        },
        {
          "language": "ru",
          "text": "снимать с регистрации; выходить из аккаунта"
        },
        {
          "language": "sq",
          "text": "të çregjistrohesh; të dalësh nga llogaria"
        },
        {
          "language": "tr",
          "text": "kaydını sildirmek; çıkış yapmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich muss mich vom Deutschkurs abmelden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن ألغي تسجيلي في دورة الألمانية."
            },
            {
              "language": "ckb",
              "text": "دەبێت لە کۆرسی ئەڵمانی خۆم بسڕمەوە."
            },
            {
              "language": "en",
              "text": "I have to deregister from the German course."
            },
            {
              "language": "fa",
              "text": "باید از کلاس آلمانی انصراف بدهم."
            },
            {
              "language": "kmr",
              "text": "Divê ez ji kursa Almanî xwe betal bikim."
            },
            {
              "language": "pl",
              "text": "Muszę wypisać się z kursu niemieckiego."
            },
            {
              "language": "ro",
              "text": "Trebuie să mă retrag de la cursul de germană."
            },
            {
              "language": "ru",
              "text": "Мне нужно сняться с курса немецкого языка."
            },
            {
              "language": "sq",
              "text": "Duhet të çregjistrohem nga kursi i gjermanishtes."
            },
            {
              "language": "tr",
              "text": "Almanca kursundan kaydımı sildirmeliyim."
            }
          ]
        },
        {
          "baseText": "Bitte melden Sie sich nach der Arbeit am Computer ab.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تسجيل الخروج من الكمبيوتر بعد العمل."
            },
            {
              "language": "ckb",
              "text": "تکایە دوای کار لە کۆمپیوتەرەکە دەرچن."
            },
            {
              "language": "en",
              "text": "Please log out of the computer after work."
            },
            {
              "language": "fa",
              "text": "لطفاً بعد از کار از کامپیوتر خارج شوید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe piştî kar ji komputerê derkevin."
            },
            {
              "language": "pl",
              "text": "Proszę wylogować się z komputera po pracy."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să vă delogați de la computer după muncă."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, выйдите из компьютера после работы."
            },
            {
              "language": "sq",
              "text": "Ju lutem dilni nga kompjuteri pas punës."
            },
            {
              "language": "tr",
              "text": "Lütfen işten sonra bilgisayardan çıkış yapın."
            }
          ]
        }
      ]
    },
    {
      "word": "abnehmen",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
