  "entries": [
    {
      "word": "die Vertragsbedingung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Vertragsbedingungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-trags-be-din-gung",
      "topics": [
        "contracts-and-negotiation",
        "documents-and-administration",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually plural in contracts"
      ],
      "collocations": [
        {
          "text": "Vertragsbedingungen prüfen",
          "meaning": "to check contract terms"
        },
        {
          "text": "neue Vertragsbedingungen akzeptieren",
          "meaning": "to accept new contract terms"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Vertrag",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شرط العقد؛ شروط العقد"
        },
        {
          "language": "ckb",
          "text": "مەرجی گرێبەست؛ مەرجەکانی گرێبەست"
        },
        {
          "language": "en",
          "text": "contract term; contract condition"
        },
        {
          "language": "fa",
          "text": "شرط قرارداد؛ شرایط قرارداد"
        },
        {
          "language": "kmr",
          "text": "mercê peymanê; şertên peymanê"
        },
        {
          "language": "pl",
          "text": "warunek umowy; warunki umowne"
        },
        {
          "language": "ro",
          "text": "condiție contractuală"
        },
        {
          "language": "ru",
          "text": "условие договора"
        },
        {
          "language": "sq",
          "text": "kusht kontrate"
        },
        {
          "language": "tr",
          "text": "sözleşme şartı"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte lesen Sie die Vertragsbedingungen, bevor Sie das Angebot bestätigen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى قراءة شروط العقد قبل تأكيد العرض."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش پشتڕاستکردنەوەی پێشنیارەکە مەرجەکانی گرێبەست بخوێننەوە."
            },
            {
              "language": "en",
              "text": "Please read the contract terms before confirming the offer."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از تأیید پیشنهاد، شرایط قرارداد را بخوانید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî piştrastkirina pêşniyarê şertên peymanê bixwînin."
            },
            {
              "language": "pl",
              "text": "Proszę przeczytać warunki umowy przed potwierdzeniem oferty."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să citiți condițiile contractuale înainte de a confirma oferta."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, прочитайте условия договора перед подтверждением предложения."
            },
            {
              "language": "sq",
              "text": "Ju lutemi lexoni kushtet e kontratës para se të konfirmoni ofertën."
            },
            {
              "language": "tr",
              "text": "Teklifi onaylamadan önce lütfen sözleşme şartlarını okuyun."
            }
          ]
        },
        {
          "baseText": "Eine Vertragsbedingung zur Kündigungsfrist war für den Kunden unklar.",
          "translations": [
            {
              "language": "ar",
              "text": "كان أحد شروط العقد حول مهلة الإلغاء غير واضح للعميل."
            },
            {
              "language": "ckb",
              "text": "مەرجێکی گرێبەست دەربارەی وادەی هەڵوەشاندنەوە بۆ کڕیارەکە ناڕوون بوو."
            },
            {
              "language": "en",
              "text": "One contract term about the notice period was unclear to the customer."
            },
            {
              "language": "fa",
              "text": "یکی از شرایط قرارداد درباره مهلت فسخ برای مشتری نامشخص بود."
            },
            {
              "language": "kmr",
              "text": "Mercê peymanê li ser dema betalkirinê ji bo xerîdar nezelal bû."
            },
            {
              "language": "pl",
              "text": "Jeden warunek umowy dotyczący okresu wypowiedzenia był dla klienta niejasny."
            },
            {
              "language": "ro",
              "text": "O condiție contractuală privind termenul de reziliere era neclară pentru client."
            },
            {
              "language": "ru",
              "text": "Одно условие договора о сроке уведомления было непонятно клиенту."
            },
            {
              "language": "sq",
              "text": "Një kusht kontrate për afatin e anulimit ishte i paqartë për klientin."
            },
            {
              "language": "tr",
              "text": "Fesih süresiyle ilgili bir sözleşme şartı müşteri için belirsizdi."
            }
          ]
        }
      ]
    },
    {
      "word": "die Vertragslaufzeit",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Vertragslaufzeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-trags-lauf-zeit",
      "topics": [
        "contracts-and-negotiation",
        "shopping-and-services",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Vertragslaufzeit von zwölf Monaten",
          "meaning": "a contract term of twelve months"
        },
        {
          "text": "die Vertragslaufzeit endet",
          "meaning": "the contract term ends"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Vertrag",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مدة العقد"
        },
        {
          "language": "ckb",
          "text": "ماوەی گرێبەست"
        },
        {
          "language": "en",
          "text": "contract duration; contract term"
        },
        {
          "language": "fa",
          "text": "مدت قرارداد"
        },
        {
          "language": "kmr",
          "text": "dirêjahiya peymanê"
        },
        {
          "language": "pl",
          "text": "czas trwania umowy"
        },
        {
          "language": "ro",
          "text": "durata contractului"
        },
        {
          "language": "ru",
          "text": "срок действия договора"
        },
        {
          "language": "sq",
          "text": "kohëzgjatja e kontratës"
        },
        {
          "language": "tr",
          "text": "sözleşme süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Vertragslaufzeit beträgt mindestens zwölf Monate.",
          "translations": [
            {
              "language": "ar",
              "text": "تبلغ مدة العقد اثني عشر شهرًا على الأقل."
            },
            {
              "language": "ckb",
              "text": "ماوەی گرێبەستەکە بە لایەنی کەمەوە دوازدە مانگە."
            },
            {
              "language": "en",
              "text": "The contract term is at least twelve months."
            },
            {
              "language": "fa",
              "text": "مدت قرارداد حداقل دوازده ماه است."
            },
            {
              "language": "kmr",
              "text": "Dirêjahiya peymanê herî kêm diwanzdeh meh e."
            },
            {
              "language": "pl",
              "text": "Czas trwania umowy wynosi co najmniej dwanaście miesięcy."
            },
            {
              "language": "ro",
              "text": "Durata contractului este de cel puțin douăsprezece luni."
            },
            {
              "language": "ru",
              "text": "Срок договора составляет минимум двенадцать месяцев."
            },
            {
              "language": "sq",
              "text": "Kohëzgjatja e kontratës është të paktën dymbëdhjetë muaj."
            },
            {
              "language": "tr",
              "text": "Sözleşme süresi en az on iki aydır."
            }
          ]
        },
        {
          "baseText": "Vor Ende der Vertragslaufzeit erhalten Sie eine Erinnerung per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل انتهاء مدة العقد ستتلقى تذكيرًا عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "پێش کۆتایی ماوەی گرێبەستەکە، بیرخستنەوەیەک بە ئیمەیڵ وەردەگرن."
            },
            {
              "language": "en",
              "text": "Before the contract term ends, you will receive a reminder by email."
            },
            {
              "language": "fa",
              "text": "قبل از پایان مدت قرارداد، یک یادآوری از طریق ایمیل دریافت می‌کنید."
            },
            {
              "language": "kmr",
              "text": "Berî dawîbûna dirêjahiya peymanê, hûn bibîrxistineke bi e-nameyê werdigirin."
            },
            {
              "language": "pl",
              "text": "Przed końcem okresu umowy otrzymają Państwo przypomnienie e-mailem."
            },
            {
              "language": "ro",
              "text": "Înainte de sfârșitul duratei contractului veți primi un memento prin e-mail."
            },
            {
              "language": "ru",
              "text": "Перед окончанием срока договора вы получите напоминание по электронной почте."
            },
            {
              "language": "sq",
              "text": "Para përfundimit të kohëzgjatjes së kontratës do të merrni një kujtesë me email."
            },
            {
              "language": "tr",
              "text": "Sözleşme süresi bitmeden önce e-posta ile bir hatırlatma alacaksınız."
            }
          ]
        }
      ]
    },
    {
      "word": "vertrauen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vertrauen",
      "pronunciationIpa": null,
      "syllableBreak": "ver-trau-en",
      "topics": [
        "social-and-relationships",
        "work-and-jobs",
        "customer-service"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb with dative: jemandem vertrauen"
      ],
      "collocations": [
        {
          "text": "einem Kollegen vertrauen",
          "meaning": "to trust a colleague"
        },
        {
          "text": "auf Erfahrung vertrauen",
          "meaning": "to rely on experience"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Vertrauen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يثق بـ"
        },
        {
          "language": "ckb",
          "text": "متمانە کردن بە"
        },
        {
          "language": "en",
          "text": "to trust"
        },
        {
          "language": "fa",
          "text": "اعتماد کردن به"
        },
        {
          "language": "kmr",
          "text": "bawer kirin bi"
        },
        {
          "language": "pl",
          "text": "ufać"
        },
        {
          "language": "ro",
          "text": "a avea încredere în"
        },
        {
          "language": "ru",
          "text": "доверять"
        },
        {
          "language": "sq",
          "text": "të besosh"
        },
        {
          "language": "tr",
          "text": "güvenmek"
        }
      ],
      "examples": [
        {
          "baseText": "Unsere Kunden vertrauen uns, weil wir Probleme offen ansprechen.",
          "translations": [
            {
              "language": "ar",
              "text": "يثق بنا عملاؤنا لأننا نتحدث عن المشاكل بصراحة."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکانمان متمانەمان پێ دەکەن چونکە بە کراوەیی باس لە کێشەکان دەکەین."
            },
            {
              "language": "en",
              "text": "Our customers trust us because we address problems openly."
            },
            {
              "language": "fa",
              "text": "مشتریان به ما اعتماد می‌کنند چون مشکلات را شفاف مطرح می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Xerîdarên me bi me bawer dikin ji ber ku em pirsgirêkan vekirî dibêjin."
            },
            {
              "language": "pl",
              "text": "Klienci nam ufają, ponieważ otwarcie mówimy o problemach."
            },
            {
              "language": "ro",
              "text": "Clienții au încredere în noi pentru că discutăm deschis problemele."
            },
            {
              "language": "ru",
              "text": "Клиенты доверяют нам, потому что мы открыто говорим о проблемах."
            },
            {
              "language": "sq",
              "text": "Klientët na besojnë sepse i trajtojmë hapur problemet."
            },
            {
              "language": "tr",
              "text": "Müşteriler bize güveniyor çünkü sorunları açıkça ele alıyoruz."
            }
          ]
        },
        {
          "baseText": "Ich vertraue meiner Nachbarin und gebe ihr den Ersatzschlüssel.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا أثق بجارتي وأعطيها المفتاح الاحتياطي."
            },
            {
              "language": "ckb",
              "text": "متمانەم بە دراوسێ ژنەکەم هەیە و کلیلی یەدەگی پێ دەدەم."
            },
            {
              "language": "en",
              "text": "I trust my neighbor and give her the spare key."
            },
            {
              "language": "fa",
              "text": "به همسایه‌ام اعتماد دارم و کلید یدک را به او می‌دهم."
            },
            {
              "language": "kmr",
              "text": "Ez bi cîrana xwe bawer dikim û kilîta cîgir didimê."
            },
            {
              "language": "pl",
              "text": "Ufam mojej sąsiadce i daję jej zapasowy klucz."
            },
            {
              "language": "ro",
              "text": "Am încredere în vecina mea și îi dau cheia de rezervă."
            },
            {
              "language": "ru",
