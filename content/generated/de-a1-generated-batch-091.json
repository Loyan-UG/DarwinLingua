      "examples": [
        {
          "baseText": "Sprechen Sie Deutsch?",
          "translations": [
            {
              "language": "ar",
              "text": "هل تتحدث الألمانية؟"
            },
            {
              "language": "ckb",
              "text": "ئایا بە ئەڵمانی قسە دەکەیت؟"
            },
            {
              "language": "en",
              "text": "Do you speak German?"
            },
            {
              "language": "fa",
              "text": "آیا آلمانی صحبت می‌کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn almanî diaxivin?"
            },
            {
              "language": "pl",
              "text": "Czy mówi pan/pani po niemiecku?"
            },
            {
              "language": "ro",
              "text": "Vorbiți germană?"
            },
            {
              "language": "ru",
              "text": "Вы говорите по-немецки?"
            },
            {
              "language": "sq",
              "text": "A flisni gjermanisht?"
            },
            {
              "language": "tr",
              "text": "Almanca konuşuyor musunuz?"
            }
          ]
        },
        {
          "baseText": "Ich spreche mit dem Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا أتحدث مع العميل."
            },
            {
              "language": "ckb",
              "text": "من لەگەڵ کڕیارەکە قسە دەکەم."
            },
            {
              "language": "en",
              "text": "I am speaking with the customer."
            },
            {
              "language": "fa",
              "text": "من با مشتری صحبت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez bi xerîdar re diaxivim."
            },
            {
              "language": "pl",
              "text": "Rozmawiam z klientem."
            },
            {
              "language": "ro",
              "text": "Vorbesc cu clientul."
            },
            {
              "language": "ru",
              "text": "Я говорю с клиентом."
            },
            {
              "language": "sq",
              "text": "Po flas me klientin."
            },
            {
              "language": "tr",
              "text": "Müşteriyle konuşuyorum."
            }
          ]
        }
      ]
