  "entries": [
    {
      "word": "das Publikum",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Pu-bli-kum",
      "topics": [
        "meetings-and-presentations",
        "culture-and-media",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "written",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; usually singular as collective noun"
      ],
      "collocations": [
        {
          "text": "vor Publikum sprechen",
          "meaning": "to speak in front of an audience"
        },
        {
          "text": "das Publikum begrüßen",
          "meaning": "to welcome the audience"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "öffentlich",
          "relationLabel": "related adjective",
          "note": null
        },
        {
          "lemma": "die Öffentlichkeit",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الجمهور؛ الحضور"
        },
        {
          "language": "ckb",
          "text": "بینەران؛ ئامادەبووان"
        },
        {
          "language": "en",
          "text": "audience; public"
        },
        {
          "language": "fa",
          "text": "مخاطبان؛ حضار؛ تماشاگران"
        },
        {
          "language": "kmr",
          "text": "temaşevan; guhdar; gel"
        },
        {
          "language": "pl",
          "text": "publiczność; widownia"
        },
        {
          "language": "ro",
          "text": "public; audiență"
        },
        {
          "language": "ru",
          "text": "публика; аудитория"
        },
        {
          "language": "sq",
          "text": "publiku; audienca"
        },
        {
          "language": "tr",
          "text": "seyirci; izleyici; dinleyici kitlesi"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Präsentation stellte das Publikum viele Fragen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد العرض التقديمي طرح الجمهور أسئلة كثيرة."
            },
            {
              "language": "ckb",
              "text": "دوای پێشکەشکارییەکە ئامادەبووان زۆر پرسیاریان کرد."
            },
            {
              "language": "en",
              "text": "After the presentation, the audience asked many questions."
            },
            {
              "language": "fa",
              "text": "بعد از ارائه، حضار سؤال‌های زیادی پرسیدند."
            },
            {
              "language": "kmr",
              "text": "Piştî prezentasyonê temaşevanan gelek pirs kirin."
            },
            {
              "language": "pl",
              "text": "Po prezentacji publiczność zadała wiele pytań."
            },
            {
              "language": "ro",
              "text": "După prezentare, publicul a pus multe întrebări."
            },
            {
              "language": "ru",
              "text": "После презентации аудитория задала много вопросов."
            },
            {
              "language": "sq",
              "text": "Pas prezantimit, publiku bëri shumë pyetje."
            },
            {
              "language": "tr",
              "text": "Sunumdan sonra izleyiciler birçok soru sordu."
            }
          ]
        },
        {
          "baseText": "Der Musiker bedankte sich beim Publikum für den langen Applaus.",
          "translations": [
            {
              "language": "ar",
              "text": "شكر الموسيقي الجمهور على التصفيق الطويل."
            },
            {
              "language": "ckb",
              "text": "مۆسیقارەکە سوپاسی بینەرانی کرد بۆ چەپڵەی درێژ."
            },
            {
              "language": "en",
              "text": "The musician thanked the audience for the long applause."
            },
            {
              "language": "fa",
              "text": "موسیقی‌دان از تماشاگران برای تشویق طولانی تشکر کرد."
            },
            {
              "language": "kmr",
              "text": "Muzîkvan ji temaşevanan ji bo çepikên dirêj spas kir."
            },
            {
              "language": "pl",
              "text": "Muzyk podziękował publiczności za długie oklaski."
            },
            {
              "language": "ro",
              "text": "Muzicianul a mulțumit publicului pentru aplauzele lungi."
            },
            {
              "language": "ru",
              "text": "Музыкант поблагодарил публику за долгие аплодисменты."
            },
            {
              "language": "sq",
              "text": "Muzikanti e falënderoi publikun për duartrokitjet e gjata."
            },
            {
              "language": "tr",
              "text": "Müzisyen uzun alkış için seyircilere teşekkür etti."
            }
          ]
        }
      ]
    },
    {
      "word": "die Qualifizierung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Qualifizierungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Qua-li-fi-zie-rung",
      "topics": [
        "education-and-training",
        "work-and-jobs",
        "human-resources"
      ],
      "usageLabels": [
        "formal",
        "workplace",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "berufliche Qualifizierung",
          "meaning": "professional qualification/training"
        },
        {
          "text": "eine Qualifizierung absolvieren",
          "meaning": "to complete a qualification program"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "qualifizieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "qualifiziert",
          "relationLabel": "adjective/participle",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تأهيل؛ تدريب مهني"
        },
        {
          "language": "ckb",
          "text": "لێهاتوویی؛ ڕاهێنانی پیشەیی"
        },
        {
          "language": "en",
          "text": "qualification; professional training"
        },
        {
          "language": "fa",
          "text": "صلاحیت‌آموزی؛ آموزش تخصصی؛ واجد شرایط شدن"
        },
        {
          "language": "kmr",
          "text": "pisporî; perwerdeya pîşeyî"
        },
        {
          "language": "pl",
          "text": "kwalifikacja; doszkolenie zawodowe"
        },
        {
          "language": "ro",
          "text": "calificare; formare profesională"
        },
        {
          "language": "ru",
          "text": "квалификация; профессиональная подготовка"
        },
        {
          "language": "sq",
          "text": "kualifikim; trajnim profesional"
        },
        {
          "language": "tr",
          "text": "nitelik kazandırma; mesleki eğitim"
        }
      ],
      "examples": [
        {
          "baseText": "Für diese Stelle ist eine technische Qualifizierung von Vorteil.",
          "translations": [
            {
              "language": "ar",
              "text": "لهذه الوظيفة يكون التأهيل التقني ميزة."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم پۆستە لێهاتووییەکی تەکنیکی سوودبەخشە."
            },
            {
              "language": "en",
              "text": "For this position, a technical qualification is an advantage."
            },
            {
              "language": "fa",
              "text": "برای این موقعیت شغلی، داشتن آموزش تخصصی فنی مزیت است."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê pozîsyonê pisporiyeke teknîkî avantaj e."
            },
            {
              "language": "pl",
              "text": "Na tym stanowisku kwalifikacje techniczne są zaletą."
            },
            {
              "language": "ro",
              "text": "Pentru acest post, o calificare tehnică este un avantaj."
            },
            {
              "language": "ru",
              "text": "Для этой должности техническая квалификация является преимуществом."
            },
            {
              "language": "sq",
              "text": "Për këtë pozicion, një kualifikim teknik është përparësi."
            },
            {
              "language": "tr",
              "text": "Bu pozisyon için teknik bir yeterlilik avantajdır."
            }
          ]
        },
        {
          "baseText": "Die Agentur bezahlt die Qualifizierung, wenn sie für den Beruf nötig ist.",
          "translations": [
            {
              "language": "ar",
              "text": "تدفع الوكالة تكاليف التأهيل إذا كان ضروريًا للمهنة."
            },
            {
              "language": "ckb",
              "text": "ئاژانسەکە پارەی ڕاهێنانەکە دەدات ئەگەر بۆ پیشەکە پێویست بێت."
            },
            {
              "language": "en",
              "text": "The agency pays for the qualification if it is necessary for the job."
            },
            {
              "language": "fa",
              "text": "اگر این آموزش برای شغل لازم باشد، اداره هزینه آن را پرداخت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Heke ew ji bo pîşeyê pêwîst be, ajans lêçûna pisporiyê dide."
            },
            {
              "language": "pl",
              "text": "Agencja płaci za kwalifikację, jeśli jest potrzebna do zawodu."
            },
            {
              "language": "ro",
              "text": "Agenția plătește calificarea dacă este necesară pentru profesie."
            },
            {
              "language": "ru",
              "text": "Агентство оплачивает квалификацию, если она нужна для профессии."
            },
            {
              "language": "sq",
              "text": "Agjencia e paguan kualifikimin nëse është i nevojshëm për profesionin."
            },
            {
              "language": "tr",
              "text": "Kurum, meslek için gerekliyse eğitimin ücretini öder."
            }
          ]
        }
      ]
    },
