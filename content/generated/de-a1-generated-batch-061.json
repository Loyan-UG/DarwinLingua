          "text": "громкий; громко"
        },
        {
          "language": "sq",
          "text": "i lartë; me zë të lartë"
        },
        {
          "language": "tr",
          "text": "yüksek sesli; yüksek sesle"
        }
      ],
      "examples": [
        {
          "baseText": "Die Musik ist zu laut.",
          "translations": [
            {
              "language": "ar",
              "text": "الموسيقى عالية جداً."
            },
            {
              "language": "ckb",
              "text": "مۆسیقاکە زۆر بەرزە."
            },
            {
              "language": "en",
              "text": "The music is too loud."
            },
            {
              "language": "fa",
              "text": "موسیقی خیلی بلند است."
            },
            {
              "language": "kmr",
              "text": "Mûzîk pir bi deng e."
            },
            {
              "language": "pl",
              "text": "Muzyka jest za głośna."
            },
            {
              "language": "ro",
              "text": "Muzica este prea tare."
            },
            {
              "language": "ru",
              "text": "Музыка слишком громкая."
            },
            {
              "language": "sq",
              "text": "Muzika është shumë e lartë."
            },
            {
              "language": "tr",
              "text": "Müzik çok yüksek."
            }
          ]
        },
        {
          "baseText": "Bitte sprechen Sie nicht so laut.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك لا تتحدث بصوت عالٍ هكذا."
            },
            {
              "language": "ckb",
              "text": "تکایە بەو جۆرە بە دەنگی بەرز قسە مەکەن."
            },
            {
              "language": "en",
              "text": "Please do not speak so loudly."
            },
            {
              "language": "fa",
              "text": "لطفاً این‌قدر بلند صحبت نکنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe ewqas bi dengê bilind neaxivin."
            },
            {
              "language": "pl",
              "text": "Proszę nie mówić tak głośno."
            },
            {
              "language": "ro",
              "text": "Vă rog să nu vorbiți atât de tare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не говорите так громко."
            },
            {
              "language": "sq",
              "text": "Ju lutem mos flisni kaq me zë të lartë."
            },
            {
              "language": "tr",
              "text": "Lütfen bu kadar yüksek sesle konuşmayın."
            }
          ]
        }
      ]
