      "examples": [
        {
          "baseText": "Die Grafik zeigt, wie sich die Support-Anfragen im letzten Monat entwickelt haben.",
          "translations": [
            {
              "language": "ar",
              "text": "يوضح الرسم البياني كيف تطورت طلبات الدعم في الشهر الماضي."
            },
            {
              "language": "ckb",
              "text": "گرافیکەکە نیشان دەدات داواکارییەکانی پشتگیری لە مانگی ڕابردوودا چۆن گۆڕاون."
            },
            {
              "language": "en",
              "text": "The chart shows how support requests developed last month."
            },
            {
              "language": "fa",
              "text": "این نمودار نشان می‌دهد درخواست‌های پشتیبانی در ماه گذشته چگونه تغییر کرده‌اند."
            },
            {
              "language": "kmr",
              "text": "Grafîk nîşan dide ku daxwazên piştgiriyê di meha borî de çawa pêş ketine."
            },
            {
              "language": "pl",
              "text": "Wykres pokazuje, jak zmieniała się liczba zgłoszeń do wsparcia w zeszłym miesiącu."
            },
            {
              "language": "ro",
              "text": "Graficul arată cum au evoluat cererile de suport luna trecută."
            },
            {
              "language": "ru",
              "text": "График показывает, как менялись обращения в поддержку за прошлый месяц."
            },
            {
              "language": "sq",
              "text": "Grafiku tregon si janë zhvilluar kërkesat për mbështetje muajin e kaluar."
            },
            {
              "language": "tr",
              "text": "Grafik, destek taleplerinin geçen ay nasıl geliştiğini gösteriyor."
            }
          ]
        },
        {
          "baseText": "Für den Flyer brauchen wir noch eine einfache Grafik mit den Öffnungszeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج للمنشور إلى رسم توضيحي بسيط مع أوقات العمل."
            },
            {
              "language": "ckb",
              "text": "بۆ فڵایەرەکە هێشتا پێویستمان بە گرافیکێکی سادەیە لەگەڵ کاتەکانی کردنەوە."
            },
            {
              "language": "en",
              "text": "For the flyer, we still need a simple graphic with the opening hours."
            },
            {
              "language": "fa",
              "text": "برای بروشور هنوز به یک گرافیک ساده با ساعات کاری نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo belavokê em hîn hewceyê grafîkeke sade bi demên vekirinê ne."
            },
            {
              "language": "pl",
              "text": "Do ulotki potrzebujemy jeszcze prostej grafiki z godzinami otwarcia."
            },
            {
              "language": "ro",
              "text": "Pentru pliant mai avem nevoie de un grafic simplu cu programul."
            },
            {
              "language": "ru",
              "text": "Для листовки нам ещё нужна простая графика с часами работы."
            },
            {
              "language": "sq",
              "text": "Për fletëpalosjen na duhet ende një grafikë e thjeshtë me orarin."
            },
            {
              "language": "tr",
              "text": "Broşür için açılış saatlerini gösteren basit bir grafiğe daha ihtiyacımız var."
            }
          ]
        }
      ]
    }
