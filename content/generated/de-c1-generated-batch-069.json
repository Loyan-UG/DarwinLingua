      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; means dependent on a specific context"
      ],
      "collocations": [
        {
          "text": "eine kontextgebundene Bedeutung",
          "meaning": "a meaning tied to context"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Kontext",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "gebunden",
          "relationLabel": "participle/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مرتبط بالسياق؛ مقيد بالسياق"
        },
        {
          "language": "ckb",
          "text": "وابەستە بە کۆنتێکست؛ گرێدراو بە بارودۆخ"
        },
        {
          "language": "en",
          "text": "context-bound; tied to context"
        },
        {
          "language": "fa",
          "text": "وابسته به بافت؛ محدود به زمینه"
        },
        {
          "language": "kmr",
          "text": "girêdayî kontekstê"
        },
        {
          "language": "pl",
          "text": "związany z kontekstem"
        },
        {
          "language": "ro",
          "text": "legat de context"
        },
        {
          "language": "ru",
          "text": "зависящий от контекста"
        },
        {
          "language": "sq",
          "text": "i lidhur me kontekstin"
        },
        {
          "language": "tr",
          "text": "bağlama bağlı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Aussage ist stark kontextgebunden und sollte nicht isoliert zitiert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "العبارة مرتبطة جداً بالسياق ولا ينبغي اقتباسها بمعزل عنه."
            },
            {
              "language": "ckb",
              "text": "وتەکە زۆر وابەستە بە کۆنتێکستە و نابێت بە جیاوازی وەربگیرێت."
            },
            {
              "language": "en",
              "text": "The statement is strongly context-bound and should not be quoted in isolation."
            },
            {
              "language": "fa",
              "text": "این گفته به‌شدت وابسته به بافت است و نباید جدا از زمینه نقل شود."
            },
            {
              "language": "kmr",
              "text": "Gotin pir girêdayî kontekstê ye û divê bi tenê neyê vegotin."
            },
            {
              "language": "pl",
              "text": "Wypowiedź jest silnie związana z kontekstem i nie powinna być cytowana w oderwaniu."
            },
            {
              "language": "ro",
              "text": "Afirmația este puternic legată de context și nu ar trebui citată izolat."
            },
            {
              "language": "ru",
              "text": "Высказывание сильно зависит от контекста, и его не следует цитировать изолированно."
            },
            {
              "language": "sq",
              "text": "Deklarata është shumë e lidhur me kontekstin dhe nuk duhet cituar e izoluar."
            },
            {
              "language": "tr",
              "text": "İfade güçlü biçimde bağlama bağlıdır ve bağlamından koparılarak alıntılanmamalıdır."
            }
          ]
        },
        {
          "baseText": "Bei Kundengesprächen sind viele Formulierungen kontextgebunden und wirken nicht in jeder Branche gleich.",
          "translations": [
            {
              "language": "ar",
              "text": "في محادثات العملاء ترتبط كثير من الصياغات بالسياق ولا تؤثر بالطريقة نفسها في كل قطاع."
            },
            {
              "language": "ckb",
              "text": "لە گفتوگۆی کڕیاردا زۆر دەربڕین وابەستە بە کۆنتێکستن و لە هەموو پیشەیەکدا وەک یەک کاریگەر نابن."
            },
            {
              "language": "en",
              "text": "In customer conversations, many phrases are context-bound and do not have the same effect in every industry."
            },
            {
              "language": "fa",
              "text": "در گفت‌وگو با مشتری، بسیاری از عبارت‌ها وابسته به زمینه‌اند و در هر صنعت اثر یکسانی ندارند."
            },
            {
              "language": "kmr",
              "text": "Di axaftinên bi xerîdaran re gelek gotin girêdayî kontekstê ne û di her sektorekê de wek hev bandor nakin."
            },
            {
              "language": "pl",
              "text": "W rozmowach z klientami wiele sformułowań zależy od kontekstu i nie działa tak samo w każdej branży."
            },
            {
              "language": "ro",
              "text": "În discuțiile cu clienții, multe formulări sunt legate de context și nu au același efect în fiecare domeniu."
            },
            {
              "language": "ru",
              "text": "В разговорах с клиентами многие формулировки зависят от контекста и не работают одинаково в каждой отрасли."
            },
            {
              "language": "sq",
              "text": "Në bisedat me klientët, shumë formulime janë të lidhura me kontekstin dhe nuk veprojnë njësoj në çdo industri."
            },
            {
              "language": "tr",
              "text": "Müşteri görüşmelerinde birçok ifade bağlama bağlıdır ve her sektörde aynı etkiyi yaratmaz."
            }
          ]
        }
      ]
    },
    {
      "word": "kontextualisieren",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "kontextualisieren",
      "pronunciationIpa": null,
      "syllableBreak": "kon-text-u-a-li-sie-ren",
      "topics": [
