      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "Daten historisch kontextualisieren",
          "meaning": "to contextualize data historically"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kontextualisierung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Kontext",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يضع في سياقه؛ يفسر ضمن السياق"
        },
        {
          "language": "ckb",
          "text": "لە کۆنتێکستدا دانان؛ بە بارودۆخ ڕوونکردنەوە"
        },
        {
          "language": "en",
          "text": "to contextualize; to place in context"
        },
        {
          "language": "fa",
          "text": "در بافت قرار دادن؛ زمینه‌مند کردن"
        },
        {
          "language": "kmr",
          "text": "di kontekstê de danîn"
        },
        {
          "language": "pl",
          "text": "kontekstualizować; osadzać w kontekście"
        },
        {
          "language": "ro",
          "text": "a contextualiza"
        },
        {
          "language": "ru",
          "text": "контекстуализировать; помещать в контекст"
        },
        {
          "language": "sq",
          "text": "të kontekstualizosh"
        },
        {
          "language": "tr",
          "text": "bağlamına oturtmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bericht muss die Zahlen stärker kontextualisieren, sonst wirken sie dramatischer, als sie sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن يضع التقرير الأرقام في سياقها بشكل أوضح، وإلا ستبدو أكثر درامية مما هي عليه."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتەکە دەبێت ژمارەکان زیاتر لە کۆنتێکستدا دابنێت، ئەگەرنا لە ڕاستی دراماتیکی‌تر دەردەکەون."
            },
            {
              "language": "en",
              "text": "The report needs to contextualize the figures more strongly; otherwise they appear more dramatic than they are."
            },
            {
              "language": "fa",
              "text": "گزارش باید اعداد را بیشتر در بافت قرار دهد، وگرنه بیش از واقعیت دراماتیک به نظر می‌رسند."
            },
            {
              "language": "kmr",
              "text": "Divê rapor hejmaran bêtir di kontekstê de deyne, nexwe ew ji ya rastîn dramatîktir xuya dikin."
            },
            {
              "language": "pl",
              "text": "Raport musi mocniej osadzić liczby w kontekście, inaczej będą wyglądały bardziej dramatycznie niż w rzeczywistości."
            },
            {
              "language": "ro",
              "text": "Raportul trebuie să contextualizeze mai bine cifrele, altfel par mai dramatice decât sunt."
            },
            {
              "language": "ru",
              "text": "Отчет должен сильнее контекстуализировать цифры, иначе они выглядят драматичнее, чем есть на самом деле."
            },
            {
              "language": "sq",
              "text": "Raporti duhet t’i kontekstualizojë më shumë shifrat, përndryshe duken më dramatike sesa janë."
            },
            {
              "language": "tr",
              "text": "Rapor rakamları daha güçlü biçimde bağlamına oturtmalı; aksi halde olduklarından daha dramatik görünürler."
            }
          ]
        },
        {
          "baseText": "Im Seminar lernen die Teilnehmenden, historische Quellen kritisch zu kontextualisieren.",
          "translations": [
            {
              "language": "ar",
              "text": "يتعلم المشاركون في الندوة وضع المصادر التاريخية في سياقها بشكل نقدي."
            },
            {
              "language": "ckb",
              "text": "لە سیمینارەکەدا بەشداربووان فێر دەبن سەرچاوە مێژووییەکان بە ڕەخنەیی لە کۆنتێکستدا دابنێن."
            },
            {
              "language": "en",
              "text": "In the seminar, participants learn to critically contextualize historical sources."
            },
            {
              "language": "fa",
              "text": "در سمینار، شرکت‌کنندگان یاد می‌گیرند منابع تاریخی را با نگاه انتقادی زمینه‌مند کنند."
            },
            {
              "language": "kmr",
              "text": "Di semînerê de beşdarvan fêr dibin ku çavkaniyên dîrokî bi rexneyî di kontekstê de deyne."
            },
            {
              "language": "pl",
              "text": "Na seminarium uczestnicy uczą się krytycznie kontekstualizować źródła historyczne."
            },
            {
              "language": "ro",
              "text": "La seminar, participanții învață să contextualizeze critic sursele istorice."
            },
            {
              "language": "ru",
              "text": "На семинаре участники учатся критически контекстуализировать исторические источники."
            },
            {
              "language": "sq",
              "text": "Në seminar, pjesëmarrësit mësojnë të kontekstualizojnë në mënyrë kritike burimet historike."
            },
            {
              "language": "tr",
              "text": "Seminerde katılımcılar tarihsel kaynakları eleştirel biçimde bağlamına oturtmayı öğrenir."
            }
          ]
        }
      ]
    },
