      ],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "die Arbeit erschweren",
          "meaning": "to make the work more difficult"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schwer",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصعّب؛ يجعل الأمر أصعب"
        },
        {
          "language": "ckb",
          "text": "قورسکردن؛ زەحمەتتر کردن"
        },
        {
          "language": "en",
          "text": "to make more difficult; to complicate"
        },
        {
          "language": "fa",
          "text": "دشوار کردن؛ سخت‌تر کردن"
        },
        {
          "language": "kmr",
          "text": "zehmettir kirin; girantir kirin"
        },
        {
          "language": "pl",
          "text": "utrudniać"
        },
        {
          "language": "ro",
          "text": "a îngreuna; a complica"
        },
        {
          "language": "ru",
          "text": "затруднять; усложнять"
        },
        {
          "language": "sq",
          "text": "të vështirësosh"
        },
        {
          "language": "tr",
          "text": "zorlaştırmak; güçleştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Fehlende Informationen erschweren die Bearbeitung der Anfrage.",
          "translations": [
            {
              "language": "ar",
              "text": "المعلومات الناقصة تصعّب معالجة الطلب."
            },
            {
              "language": "ckb",
              "text": "زانیارییە کەمەکان چارەسەرکردنی داواکارییەکە قورس دەکەن."
            },
            {
              "language": "en",
              "text": "Missing information makes processing the request more difficult."
            },
            {
              "language": "fa",
              "text": "اطلاعات ناقص رسیدگی به درخواست را دشوار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Agahiyên kêm xebitandina daxwazê zehmettir dikin."
            },
            {
              "language": "pl",
              "text": "Brakujące informacje utrudniają obsługę zapytania."
            },
            {
              "language": "ro",
              "text": "Informațiile lipsă îngreunează procesarea cererii."
            },
            {
              "language": "ru",
              "text": "Отсутствующая информация затрудняет обработку запроса."
            },
            {
              "language": "sq",
              "text": "Informacionet që mungojnë e vështirësojnë përpunimin e kërkesës."
            },
            {
              "language": "tr",
              "text": "Eksik bilgiler talebin işlenmesini zorlaştırıyor."
            }
          ]
        },
        {
          "baseText": "Der starke Regen erschwert die Fahrt zur Arbeit.",
          "translations": [
            {
              "language": "ar",
              "text": "المطر الغزير يصعّب الطريق إلى العمل."
            },
            {
              "language": "ckb",
              "text": "بارانی توند ڕێگای چوون بۆ کار قورس دەکات."
            },
            {
              "language": "en",
              "text": "The heavy rain makes the commute to work more difficult."
            },
            {
              "language": "fa",
              "text": "باران شدید رفتن به محل کار را سخت‌تر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Barana giran rêya çûna karê zehmettir dike."
            },
            {
              "language": "pl",
              "text": "Silny deszcz utrudnia dojazd do pracy."
            },
            {
              "language": "ro",
              "text": "Ploaia puternică îngreunează drumul spre serviciu."
            },
            {
              "language": "ru",
              "text": "Сильный дождь затрудняет дорогу на работу."
            },
            {
              "language": "sq",
              "text": "Shiu i fortë e vështirëson udhëtimin për në punë."
            },
            {
              "language": "tr",
              "text": "Şiddetli yağmur işe gitmeyi zorlaştırıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "erwarten",
      "language": "de",
      "cefrLevel": "B1",
