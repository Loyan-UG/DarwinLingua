      ],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "eine Antwort erwarten",
          "meaning": "to expect an answer"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erwartung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتوقع؛ ينتظر"
        },
        {
          "language": "ckb",
          "text": "چاوەڕوانبوون؛ پێشبینی کردن"
        },
        {
          "language": "en",
          "text": "to expect; to await"
        },
        {
          "language": "fa",
          "text": "انتظار داشتن؛ توقع داشتن"
        },
        {
          "language": "kmr",
          "text": "bendewar bûn; hêvî kirin"
        },
        {
          "language": "pl",
          "text": "oczekiwać"
        },
        {
          "language": "ro",
          "text": "a aștepta; a se aștepta"
        },
        {
          "language": "ru",
          "text": "ожидать"
        },
        {
          "language": "sq",
          "text": "të presësh; të pritësh"
        },
        {
          "language": "tr",
          "text": "beklemek; ummak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir erwarten Ihre Rückmeldung bis spätestens morgen Mittag.",
          "translations": [
            {
              "language": "ar",
              "text": "نتوقع ردك في موعد أقصاه ظهر الغد."
            },
            {
              "language": "ckb",
              "text": "چاوەڕوانی وەڵامتانین تا دوا کات نیوەڕۆی سبەی."
            },
            {
              "language": "en",
              "text": "We expect your response by tomorrow noon at the latest."
            },
            {
              "language": "fa",
              "text": "ما حداکثر تا ظهر فردا منتظر پاسخ شما هستیم."
            },
            {
              "language": "kmr",
              "text": "Em bersiva we heta herî dereng nîvroya sibê bendewar in."
            },
            {
              "language": "pl",
              "text": "Oczekujemy Państwa odpowiedzi najpóźniej do jutra w południe."
            },
            {
              "language": "ro",
              "text": "Așteptăm răspunsul dumneavoastră cel târziu până mâine la prânz."
            },
            {
              "language": "ru",
              "text": "Мы ожидаем ваш ответ не позднее завтрашнего полудня."
            },
            {
              "language": "sq",
              "text": "Presim përgjigjen tuaj më së voni deri nesër në mesditë."
            },
            {
              "language": "tr",
              "text": "Yanıtınızı en geç yarın öğlene kadar bekliyoruz."
            }
          ]
        },
        {
          "baseText": "Am Wochenende erwarten wir Besuch von Freunden.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع ننتظر زيارة من أصدقاء."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا چاوەڕوانی سەردانی هاوڕێکانمانین."
            },
            {
              "language": "en",
              "text": "At the weekend, we are expecting a visit from friends."
            },
            {
              "language": "fa",
              "text": "آخر هفته منتظر دیدار دوستان هستیم."
            },
            {
              "language": "kmr",
              "text": "Dawiya hefteyê em serdana hevalan bendewar in."
            },
            {
              "language": "pl",
              "text": "W weekend spodziewamy się wizyty przyjaciół."
            },
            {
              "language": "ro",
              "text": "În weekend așteptăm vizita unor prieteni."
            },
            {
              "language": "ru",
              "text": "На выходных мы ждем друзей в гости."
            },
            {
              "language": "sq",
              "text": "Në fundjavë presim vizitë nga miqtë."
            },
            {
              "language": "tr",
              "text": "Hafta sonu arkadaşlarımızın ziyaretini bekliyoruz."
            }
          ]
        }
      ]
    }
  ],
