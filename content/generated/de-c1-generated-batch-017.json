    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "ausersehen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ausersehen",
      "syllableBreak": "aus-er-se-hen",
      "topics": [
        "management-and-leadership",
        "planning-and-projects",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong verb; often used in passive: für etwas ausersehen sein"
      ],
      "collocations": [
        {
          "text": "für eine Aufgabe ausersehen sein",
          "meaning": "to be chosen for a task"
        },
        {
          "text": "als Nachfolger ausersehen",
          "meaning": "chosen as successor"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sehen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يختار خصيصًا؛ يعيّن مسبقًا"
        },
        {
          "language": "ckb",
          "text": "بە تایبەتی هەڵدەبژێرێت؛ بۆ ئەرکێک دیاری دەکات"
        },
        {
          "language": "en",
          "text": "to single out; to designate for something"
        },
        {
          "language": "fa",
          "text": "برگزیدن؛ برای کاری در نظر گرفتن"
        },
        {
          "language": "kmr",
          "text": "taybet hilbijartin; ji bo tiştek diyar kirin"
        },
        {
          "language": "pl",
          "text": "wyznaczyć; upatrzyć"
        },
        {
          "language": "ro",
          "text": "a desemna; a alege special"
        },
        {
          "language": "ru",
          "text": "предназначать; выбирать"
        },
        {
          "language": "sq",
          "text": "të përzgjedhësh; të caktosh"
        },
        {
          "language": "tr",
          "text": "özel olarak seçmek; uygun görmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die erfahrene Controllerin war für die Leitung des Transformationsprogramms ausersehen.",
          "translations": [
            {
              "language": "ar",
              "text": "تم اختيار خبيرة المراقبة المالية لقيادة برنامج التحول."
            },
            {
              "language": "ckb",
              "text": "کۆنترۆڵەری شارەزا بۆ بەڕێوەبردنی بەرنامەی گۆڕانکاری دیاری کرابوو."
            },
            {
              "language": "en",
              "text": "The experienced controller was selected to lead the transformation program."
            },
            {
              "language": "fa",
              "text": "کنترلر باتجربه برای رهبری برنامه تحول در نظر گرفته شده بود."
            },
            {
              "language": "kmr",
              "text": "Kontrolkera bi ezmûn ji bo rêveberiya bernameya veguherînê hatibû hilbijartin."
            },
            {
              "language": "pl",
              "text": "Doświadczona kontrolerka została wyznaczona do kierowania programem transformacji."
            },
            {
              "language": "ro",
              "text": "Controllera experimentată fusese desemnată să conducă programul de transformare."
            },
            {
              "language": "ru",
              "text": "Опытного контролера выбрали для руководства программой трансформации."
            },
            {
              "language": "sq",
              "text": "Kontrollorja me përvojë ishte caktuar për drejtimin e programit të transformimit."
            },
            {
              "language": "tr",
              "text": "Deneyimli kontrolör dönüşüm programını yönetmek üzere seçilmişti."
            }
          ]
        },
        {
          "baseText": "Der alte Bahnhof ist als Standort für ein neues Kulturzentrum ausersehen.",
          "translations": [
            {
              "language": "ar",
              "text": "تم اختيار محطة القطار القديمة موقعًا لمركز ثقافي جديد."
            },
            {
              "language": "ckb",
              "text": "وێستگەی کۆنی شەمەندەفەرەکە وەک شوێنی ناوەندێکی نوێی کەلتووری دیاری کراوە."
            },
            {
              "language": "en",
              "text": "The old railway station has been designated as the site for a new cultural center."
            },
            {
              "language": "fa",
              "text": "ایستگاه قدیمی قطار به‌عنوان محل یک مرکز فرهنگی جدید در نظر گرفته شده است."
            },
            {
              "language": "kmr",
              "text": "Stasyona trênê ya kevn wek cihê navendeke nû ya çandî hatiye diyar kirin."
            },
            {
              "language": "pl",
              "text": "Stary dworzec został wyznaczony jako lokalizacja nowego centrum kultury."
            },
            {
              "language": "ro",
              "text": "Vechea gară este desemnată ca amplasament pentru un nou centru cultural."
            },
            {
              "language": "ru",
              "text": "Старый вокзал выбран как место для нового культурного центра."
            },
            {
              "language": "sq",
              "text": "Stacioni i vjetër hekurudhor është caktuar si vend për një qendër të re kulturore."
            },
            {
              "language": "tr",
              "text": "Eski tren istasyonu yeni bir kültür merkezi için yer olarak seçildi."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "ausfliegen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ausfliegen",
      "syllableBreak": "aus-flie-gen",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "everyday-life"
      ],
      "usageLabels": [
        "written",
        "technical",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; means to fly out, transport by air, or young birds leaving the nest"
      ],
      "collocations": [
        {
          "text": "Passagiere ausfliegen",
          "meaning": "to fly passengers out"
        },
        {
          "text": "Jungvögel fliegen aus",
          "meaning": "young birds leave the nest"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fliegen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ينقل جوًا إلى الخارج؛ يغادر طائرًا"
        },
        {
          "language": "ckb",
          "text": "بە فڕۆکە دەردەهێنێت؛ باڵندە لە هێلانە دەردەفڕێت"
        },
        {
          "language": "en",
          "text": "to fly out; to evacuate or transport by air"
        },
        {
          "language": "fa",
          "text": "با هواپیما خارج کردن؛ از آشیانه پریدن"
        },
        {
          "language": "kmr",
          "text": "bi balafirê derxistin; ji hêlînê firîn"
        },
        {
          "language": "pl",
          "text": "ewakuować/wywieźć samolotem; wylecieć"
        },
        {
          "language": "ro",
          "text": "a evacua sau transporta cu avionul; a zbura afară"
        },
        {
          "language": "ru",
          "text": "вывозить самолетом; вылетать из гнезда"
        },
        {
          "language": "sq",
          "text": "të nxjerrësh me avion; të fluturosh jashtë"
        },
        {
          "language": "tr",
          "text": "uçakla tahliye etmek; yuvadan uçmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Grenzschließung mussten mehrere Mitarbeitende kurzfristig ausgeflogen werden.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد إغلاق الحدود كان لا بد من إخراج عدة موظفين جوًا في وقت قصير."
            },
            {
              "language": "ckb",
              "text": "دوای داخستنی سنوور، پێویست بوو چەند کارمەندێک بە خێرایی بە فڕۆکە دەربهێنرێن."
            },
            {
              "language": "en",
              "text": "After the border closure, several employees had to be flown out at short notice."
            },
            {
              "language": "fa",
              "text": "پس از بسته شدن مرز، چند کارمند باید در مدت کوتاهی با هواپیما خارج می‌شدند."
            },
            {
              "language": "kmr",
              "text": "Piştî girtina sînorê, diviya çend karmend bi lez bi balafirê werin derxistin."
            },
            {
              "language": "pl",
              "text": "Po zamknięciu granicy kilku pracowników trzeba było pilnie ewakuować samolotem."
            },
            {
              "language": "ro",
              "text": "După închiderea frontierei, mai mulți angajați au trebuit evacuați cu avionul în scurt timp."
            },
            {
              "language": "ru",
              "text": "После закрытия границы нескольких сотрудников пришлось срочно вывезти самолетом."
            },
            {
              "language": "sq",
              "text": "Pas mbylljes së kufirit, disa punonjës duhej të nxirreshin me avion me afat të shkurtër."
            },
            {
              "language": "tr",
              "text": "Sınır kapatıldıktan sonra birkaç çalışanın kısa sürede uçakla tahliye edilmesi gerekti."
            }
          ]
        },
        {
          "baseText": "Im Juni fliegen die jungen Störche aus und kehren nur noch selten zum Nest zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "في يونيو تطير صغار اللقالق من العش ولا تعود إليه إلا نادرًا."
            },
            {
              "language": "ckb",
              "text": "لە حوزەیراندا قوتابییە بچووکەکانی لەقلەق لە هێلانە دەردەفڕن و تەنها بە دەگمەن دەگەڕێنەوە."
            },
            {
              "language": "en",
              "text": "In June, the young storks leave the nest and only rarely return to it."
            },
            {
              "language": "fa",
              "text": "در ماه ژوئن، لک‌لک‌های جوان از آشیانه می‌پرند و فقط به‌ندرت برمی‌گردند."
            },
            {
              "language": "kmr",
              "text": "Di hezîranê de leglegên ciwan ji hêlînê difirin û tenê kêm caran vedigerin."
            },
            {
              "language": "pl",
              "text": "W czerwcu młode bociany wylatują z gniazda i rzadko do niego wracają."
            },
            {
              "language": "ro",
              "text": "În iunie, berzele tinere zboară din cuib și se mai întorc rar."
            },
            {
              "language": "ru",
              "text": "В июне молодые аисты вылетают из гнезда и возвращаются туда лишь редко."
            },
            {
              "language": "sq",
              "text": "Në qershor, lejlekët e rinj fluturojnë nga foleja dhe kthehen rrallë."
            },
            {
              "language": "tr",
              "text": "Haziranda genç leylekler yuvadan uçar ve oraya ancak nadiren döner."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "ausgleiten",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ausgleiten",
      "syllableBreak": "aus-glei-ten",
      "topics": [
        "quality-and-risk",
        "healthcare-and-appointments",
        "everyday-life"
      ],
      "usageLabels": [
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; often used for slipping accidentally"
      ],
      "collocations": [
        {
          "text": "auf nassem Boden ausgleiten",
          "meaning": "to slip on a wet floor"
        },
        {
          "text": "mit dem Fuß ausgleiten",
          "meaning": "to slip with one foot"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gleiten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ينزلق؛ يفقد الثبات"
        },
        {
          "language": "ckb",
          "text": "دەخلیسکێت؛ هاوسەنگی لەدەست دەدات"
        },
        {
          "language": "en",
          "text": "to slip; to lose footing"
        },
        {
          "language": "fa",
          "text": "لغزیدن؛ سر خوردن"
        },
        {
          "language": "kmr",
          "text": "şemitîn; hevsengî winda kirin"
        },
        {
          "language": "pl",
          "text": "poślizgnąć się"
        },
        {
          "language": "ro",
          "text": "a aluneca"
        },
        {
          "language": "ru",
          "text": "поскользнуться"
        },
        {
          "language": "sq",
          "text": "të rrëshqasësh"
        },
        {
          "language": "tr",
          "text": "kaymak; ayağı kaymak"
        }
      ],
      "examples": [
        {
          "baseText": "Ein Besucher glitt auf dem frisch gewischten Boden aus und verletzte sich leicht.",
          "translations": [
            {
              "language": "ar",
              "text": "انزلق زائر على الأرضية الممسوحة حديثًا وأصيب إصابة طفيفة."
            },
            {
              "language": "ckb",
              "text": "سەردانکەرێک لەسەر زەویی تازە سڕاوەکە خلیسکا و کەمێک بریندار بوو."
            },
            {
              "language": "en",
              "text": "A visitor slipped on the freshly mopped floor and was slightly injured."
            },
            {
              "language": "fa",
              "text": "یک بازدیدکننده روی زمین تازه تی‌کشیده سر خورد و کمی آسیب دید."
            },
            {
              "language": "kmr",
              "text": "Serdanvanek li ser erda nû paqijkirî şemitî û hinek birîndar bû."
            },
            {
              "language": "pl",
              "text": "Gość poślizgnął się na świeżo umytej podłodze i lekko się zranił."
            },
            {
              "language": "ro",
              "text": "Un vizitator a alunecat pe podeaua proaspăt spălată și s-a rănit ușor."
            },
            {
              "language": "ru",
              "text": "Посетитель поскользнулся на свежевымытом полу и слегка травмировался."
            },
            {
              "language": "sq",
              "text": "Një vizitor rrëshqiti në dyshemenë e sapolarë dhe u lëndua lehtë."
            },
            {
              "language": "tr",
              "text": "Bir ziyaretçi yeni silinmiş zeminde kaydı ve hafif yaralandı."
            }
          ]
        },
        {
          "baseText": "Beim Abstieg glitt ihr der Fuß auf einem losen Stein aus.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء النزول انزلقت قدمها على حجر غير ثابت."
            },
            {
              "language": "ckb",
              "text": "لە کاتی دابەزینەکەدا پێی لەسەر بەردێکی شل خلیسکا."
            },
            {
              "language": "en",
              "text": "During the descent, her foot slipped on a loose stone."
            },
            {
              "language": "fa",
              "text": "هنگام پایین آمدن، پایش روی سنگی لق سر خورد."
            },
            {
              "language": "kmr",
              "text": "Dema daketinê, lingê wê li ser kevirekî sist şemitî."
            },
            {
              "language": "pl",
              "text": "Podczas schodzenia stopa poślizgnęła się jej na luźnym kamieniu."
