  "entries": [
    {
      "word": "typisch",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ty-pisch",
      "topics": [
        "everyday-life",
        "culture-and-media",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; often used with für + accusative"
      ],
      "collocations": [
        {
          "text": "typisch für die Region",
          "meaning": "typical for the region"
        },
        {
          "text": "ein typisches Problem",
          "meaning": "a typical problem"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Typ",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نموذجي؛ معتاد"
        },
        {
          "language": "ckb",
          "text": "تایبەتمەند؛ ئاسایی بۆ شتێک"
        },
        {
          "language": "en",
          "text": "typical; characteristic"
        },
        {
          "language": "fa",
          "text": "معمول؛ نمونه‌وار؛ مشخصه"
        },
        {
          "language": "kmr",
          "text": "tîpîk; taybetmend"
        },
        {
          "language": "pl",
          "text": "typowy; charakterystyczny"
        },
        {
          "language": "ro",
          "text": "tipic; caracteristic"
        },
        {
          "language": "ru",
          "text": "типичный; характерный"
        },
        {
          "language": "sq",
          "text": "tipik; karakteristik"
        },
        {
          "language": "tr",
          "text": "tipik; karakteristik"
        }
      ],
      "examples": [
        {
          "baseText": "Das ist ein typisches Problem, wenn mehrere Personen dieselbe Datei bearbeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "هذه مشكلة نموذجية عندما يعمل عدة أشخاص على الملف نفسه."
            },
            {
              "language": "ckb",
              "text": "ئەمە کێشەیەکی ئاساییە کاتێک چەند کەسێک هەمان فایل دەستکاری دەکەن."
            },
            {
              "language": "en",
              "text": "That is a typical problem when several people edit the same file."
            },
            {
              "language": "fa",
              "text": "این یک مشکل معمول است وقتی چند نفر یک فایل را ویرایش می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Ev pirsgirêkeke tîpîk e dema çend kes heman pelê diguherînin."
            },
            {
              "language": "pl",
              "text": "To typowy problem, gdy kilka osób edytuje ten sam plik."
            },
            {
              "language": "ro",
              "text": "Aceasta este o problemă tipică atunci când mai multe persoane editează același fișier."
            },
            {
              "language": "ru",
              "text": "Это типичная проблема, когда несколько человек редактируют один и тот же файл."
            },
            {
              "language": "sq",
              "text": "Ky është një problem tipik kur disa persona redaktojnë të njëjtin skedar."
            },
            {
              "language": "tr",
              "text": "Birden fazla kişi aynı dosyayı düzenlediğinde bu tipik bir sorundur."
            }
          ]
        },
        {
          "baseText": "Für diese Stadt ist es typisch, dass die Geschäfte früh schließen.",
          "translations": [
            {
              "language": "ar",
              "text": "من المعتاد في هذه المدينة أن تغلق المتاجر مبكرًا."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم شارە ئاساییە کە دوکانەکان زوو دادەخرێن."
            },
            {
              "language": "en",
              "text": "It is typical for this city that the shops close early."
            },
            {
              "language": "fa",
              "text": "برای این شهر معمول است که مغازه‌ها زود بسته شوند."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê bajêrê tîpîk e ku firoşgeh zû tên girtin."
            },
            {
              "language": "pl",
              "text": "Dla tego miasta typowe jest to, że sklepy zamykają się wcześnie."
            },
            {
              "language": "ro",
              "text": "Pentru acest oraș este tipic ca magazinele să se închidă devreme."
            },
            {
              "language": "ru",
              "text": "Для этого города типично, что магазины закрываются рано."
            },
            {
              "language": "sq",
              "text": "Për këtë qytet është tipike që dyqanet mbyllen herët."
            },
            {
              "language": "tr",
              "text": "Bu şehir için mağazaların erken kapanması tipiktir."
            }
          ]
        }
      ]
    },
    {
      "word": "übelnehmen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "übelnehmen",
      "pronunciationIpa": null,
      "syllableBreak": "ü-bel-neh-men",
      "topics": [
        "social-and-relationships",
        "business-communication",
        "work-and-jobs"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "polite"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; often: jemandem etwas übelnehmen"
      ],
      "collocations": [
        {
          "text": "jemandem etwas übelnehmen",
          "meaning": "to take something amiss"
        },
        {
          "text": "es nicht übelnehmen",
          "meaning": "not to take it personally"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "übel",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يزعل من؛ يأخذ الأمر على محمل شخصي"
        },
        {
          "language": "ckb",
          "text": "لە دڵ گرتن؛ بە خراپی وەرگرتن"
        },
        {
          "language": "en",
          "text": "to take something amiss; to resent"
        },
        {
          "language": "fa",
          "text": "به دل گرفتن؛ ناراحت شدن از چیزی"
        },
        {
          "language": "kmr",
          "text": "ji tiştekî aciz bûn; li dil girtin"
        },
        {
          "language": "pl",
          "text": "mieć komuś coś za złe"
        },
        {
          "language": "ro",
          "text": "a lua ceva în nume de rău"
        },
        {
          "language": "ru",
          "text": "обижаться на что-либо; принимать близко к сердцу"
        },
        {
          "language": "sq",
          "text": "ta marrësh për keq; të mbash inat"
        },
        {
          "language": "tr",
          "text": "gücenmek; içerlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Nimm es mir bitte nicht übel, aber ich muss den Termin verschieben.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك لا تزعل مني، لكن يجب أن أؤجل الموعد."
            },
            {
              "language": "ckb",
              "text": "تکایە لێم مەگرە، بەڵام دەبێت کاتەکە بگوازمەوە."
            },
            {
              "language": "en",
              "text": "Please do not take it personally, but I have to reschedule the appointment."
            },
            {
              "language": "fa",
              "text": "لطفاً به دل نگیر، اما باید قرار را جابه‌جا کنم."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li dil negire, lê divê ez randevûyê biguherînim."
            },
            {
              "language": "pl",
              "text": "Proszę nie mieć mi tego za złe, ale muszę przesunąć termin."
            },
            {
              "language": "ro",
              "text": "Te rog să nu o iei în nume de rău, dar trebuie să reprogramez întâlnirea."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не обижайтесь, но мне нужно перенести встречу."
            },
            {
              "language": "sq",
              "text": "Të lutem mos e merr për keq, por duhet ta shtyj takimin."
            },
            {
              "language": "tr",
              "text": "Lütfen yanlış anlama, ama randevuyu ertelemem gerekiyor."
            }
          ]
        },
        {
          "baseText": "Der Kunde hat uns die lange Wartezeit zum Glück nicht übelgenommen.",
          "translations": [
            {
              "language": "ar",
              "text": "لحسن الحظ لم يأخذ العميل وقت الانتظار الطويل علينا."
            },
            {
              "language": "ckb",
              "text": "بە خۆشبەختی کڕیارەکە ماوەی چاوەڕوانی درێژی لێمان لە دڵ نەگرت."
            },
            {
              "language": "en",
              "text": "Fortunately, the customer did not hold the long waiting time against us."
            },
            {
              "language": "fa",
              "text": "خوشبختانه مشتری انتظار طولانی را از ما به دل نگرفت."
            },
            {
              "language": "kmr",
              "text": "Bi bextewarî xerîdar demeke dirêj a bendê li me negirt."
            },
            {
              "language": "pl",
              "text": "Na szczęście klient nie miał nam za złe długiego czasu oczekiwania."
            },
            {
              "language": "ro",
              "text": "Din fericire, clientul nu ne-a reproșat timpul lung de așteptare."
            },
            {
              "language": "ru",
              "text": "К счастью, клиент не обиделся на нас из-за долгого ожидания."
            },
            {
              "language": "sq",
              "text": "Fatmirësisht klienti nuk na e mori për keq pritjen e gjatë."
            },
            {
              "language": "tr",
              "text": "Neyse ki müşteri uzun bekleme süresini bize karşı kullanmadı."
            }
          ]
        }
      ]
    },
    {
      "word": "überdenken",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "überdenken",
      "pronunciationIpa": null,
      "syllableBreak": "ü-ber-den-ken",
      "topics": [
        "planning-and-projects",
        "business-communication",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "inseparable verb; überdenkt, überdachte, hat überdacht"
      ],
      "collocations": [
        {
          "text": "eine Entscheidung überdenken",
          "meaning": "to reconsider a decision"
        },
        {
          "text": "den Plan überdenken",
          "meaning": "to rethink the plan"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "denken",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعيد التفكير في؛ يراجع"
        },
        {
          "language": "ckb",
          "text": "دووبارە بیرکردنەوە لە؛ پێداچوونەوە"
        },
        {
          "language": "en",
          "text": "to reconsider; to rethink"
        },
        {
          "language": "fa",
          "text": "بازنگری کردن؛ دوباره بررسی کردن"
        },
        {
          "language": "kmr",
          "text": "ji nû ve fikirîn; ji nû ve nirxandin"
        },
        {
          "language": "pl",
          "text": "przemyśleć ponownie; rozważyć na nowo"
        },
        {
          "language": "ro",
          "text": "a reconsidera; a regândi"
        },
        {
          "language": "ru",
          "text": "переосмыслить; пересмотреть"
        },
        {
          "language": "sq",
          "text": "ta rimendosh; ta rishqyrtosh"
        },
        {
          "language": "tr",
          "text": "yeniden düşünmek; gözden geçirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Feedback der Kunden müssen wir unser Angebot überdenken.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد ملاحظات العملاء يجب أن نعيد التفكير في عرضنا."
            },
            {
              "language": "ckb",
              "text": "دوای فیدباکی کڕیاران دەبێت پێداچوونەوە بە پێشنیارەکەمان بکەین."
            },
            {
              "language": "en",
