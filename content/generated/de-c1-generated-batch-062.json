      ],
      "examples": [
        {
          "baseText": "Die Integrationserfahrung neuer Mitarbeitender hängt stark von informellen Kontakten im Team ab.",
          "translations": [
            {
              "language": "ar",
              "text": "تعتمد تجربة اندماج الموظفين الجدد بدرجة كبيرة على العلاقات غير الرسمية داخل الفريق."
