  "entries": [
    {
      "word": "die Institution",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Institutionen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "In-sti-tu-ti-on",
      "topics": [
        "public-services",
        "documents-and-administration",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "academic",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; plural: die Institutionen"
      ],
      "collocations": [
        {
          "text": "eine öffentliche Institution",
          "meaning": "a public institution"
        },
        {
          "text": "Institutionen stärken",
          "meaning": "to strengthen institutions"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "institutionell",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "institutionalisieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مؤسسة؛ جهة رسمية أو اجتماعية"
        },
        {
          "language": "ckb",
          "text": "دامەزراوە؛ لایەنی فەرمی یان کۆمەڵایەتی"
        },
        {
          "language": "en",
          "text": "institution; formal or social organization"
        },
        {
          "language": "fa",
          "text": "نهاد؛ مؤسسه رسمی یا اجتماعی"
        },
        {
          "language": "kmr",
          "text": "sazî; dezgeh"
        },
        {
          "language": "pl",
          "text": "instytucja"
        },
        {
          "language": "ro",
          "text": "instituție"
        },
        {
          "language": "ru",
          "text": "институт; учреждение"
        },
        {
          "language": "sq",
          "text": "institucion"
        },
        {
          "language": "tr",
          "text": "kurum; müessese"
        }
      ],
      "examples": [
        {
          "baseText": "Die Institution muss nachvollziehbar erklären, warum der Antrag abgelehnt wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على المؤسسة أن تشرح بشكل قابل للتتبع لماذا رُفض الطلب."
            },
            {
              "language": "ckb",
              "text": "دامەزراوەکە دەبێت بە شێوەی بەدواداچوونپێکراو ڕوون بکاتەوە بۆچی داواکارییەکە ڕەتکراوەتەوە."
            },
            {
              "language": "en",
              "text": "The institution must explain in a traceable way why the application was rejected."
            },
            {
              "language": "fa",
              "text": "نهاد باید به‌صورت قابل پیگیری توضیح دهد چرا درخواست رد شده است."
            },
            {
              "language": "kmr",
              "text": "Sazî divê bi awayekî şopandinbar rave bike çima daxwaz hat redkirin."
            },
            {
              "language": "pl",
              "text": "Instytucja musi w sposób możliwy do prześledzenia wyjaśnić, dlaczego wniosek odrzucono."
            },
            {
              "language": "ro",
              "text": "Instituția trebuie să explice trasabil de ce cererea a fost respinsă."
            },
            {
              "language": "ru",
              "text": "Учреждение должно прослеживаемо объяснить, почему заявление было отклонено."
            },
            {
              "language": "sq",
              "text": "Institucioni duhet të shpjegojë në mënyrë të gjurmueshme pse u refuzua kërkesa."
            },
            {
              "language": "tr",
              "text": "Kurum başvurunun neden reddedildiğini izlenebilir şekilde açıklamalıdır."
            }
          ]
        },
        {
          "baseText": "Vertrauen in eine Institution entsteht nicht durch Werbung, sondern durch verlässliches Handeln.",
          "translations": [
            {
              "language": "ar",
              "text": "تنشأ الثقة في مؤسسة ما لا من خلال الإعلان، بل من خلال تصرف موثوق."
            },
            {
              "language": "ckb",
              "text": "متمانە بە دامەزراوەیەک نە بە ڕیکلام، بەڵکو بە کردارێکی پشتپێبەستوو دروست دەبێت."
            },
            {
              "language": "en",
              "text": "Trust in an institution is created not by advertising but by reliable action."
            },
            {
              "language": "fa",
              "text": "اعتماد به یک نهاد نه از طریق تبلیغات، بلکه با عمل قابل اتکا شکل می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Bawerî bi saziyê ne bi reklamê, lê bi kiryara pêbawer çêdibe."
            },
            {
              "language": "pl",
              "text": "Zaufanie do instytucji powstaje nie przez reklamę, lecz przez niezawodne działanie."
            },
            {
              "language": "ro",
              "text": "Încrederea într-o instituție apare nu prin publicitate, ci prin acțiune fiabilă."
            },
            {
              "language": "ru",
              "text": "Доверие к институту возникает не через рекламу, а через надежные действия."
            },
            {
              "language": "sq",
              "text": "Besimi në një institucion krijohet jo nga reklama, por nga veprimi i besueshëm."
            },
            {
              "language": "tr",
              "text": "Bir kuruma güven reklamla değil, güvenilir eylemle oluşur."
            }
          ]
        }
      ]
    },
    {
      "word": "institutionalisieren",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "institutionalisieren",
      "pronunciationIpa": null,
      "syllableBreak": "in-sti-tu-ti-o-na-li-sie-ren",
      "topics": [
        "management-and-leadership",
        "public-services",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "academic",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb: institutionalisiert, institutionalisierte, hat institutionalisiert"
      ],
      "collocations": [
        {
          "text": "einen Prozess institutionalisieren",
          "meaning": "to institutionalize a process"
        },
        {
          "text": "Beteiligung institutionalisieren",
          "meaning": "to institutionalize participation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Institution",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "institutionell",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يؤسس مؤسسيًا؛ يجعل شيئًا جزءًا ثابتًا من نظام"
        },
        {
          "language": "ckb",
          "text": "دامەزراوەیی دەکات؛ دەکاتە بەشێکی جێگیر لە سیستەم"
        },
        {
          "language": "en",
          "text": "to institutionalize; to make part of a formal system"
        },
        {
          "language": "fa",
          "text": "نهادینه کردن؛ رسمی و پایدار کردن"
        },
        {
          "language": "kmr",
          "text": "sazîkirin; cihgir kirin di pergalê de"
        },
        {
          "language": "pl",
          "text": "instytucjonalizować"
        },
        {
          "language": "ro",
          "text": "a instituționaliza"
        },
        {
          "language": "ru",
          "text": "институционализировать"
        },
        {
          "language": "sq",
          "text": "të institucionalizosh"
        },
        {
          "language": "tr",
          "text": "kurumsallaştırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Das Unternehmen will regelmäßige Sicherheitsreviews institutionalisieren.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد الشركة أن تجعل مراجعات الأمن المنتظمة جزءًا مؤسسيًا ثابتًا."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە دەیەوێت پێداچوونەوەی ئاسایشی بەردەوام دامەزراوەیی بکات."
            },
            {
              "language": "en",
              "text": "The company wants to institutionalize regular security reviews."
            },
            {
              "language": "fa",
              "text": "شرکت می‌خواهد بازبینی‌های منظم امنیتی را نهادینه کند."
            },
            {
              "language": "kmr",
              "text": "Şîrket dixwaze reviewên ewlehiyê yên rêkûpêk sazî bike."
            },
            {
              "language": "pl",
              "text": "Firma chce zinstytucjonalizować regularne przeglądy bezpieczeństwa."
            },
            {
              "language": "ro",
              "text": "Compania vrea să instituționalizeze revizuirile regulate de securitate."
            },
            {
              "language": "ru",
              "text": "Компания хочет институционализировать регулярные проверки безопасности."
            },
            {
              "language": "sq",
              "text": "Kompania dëshiron të institucionalizojë rishikimet e rregullta të sigurisë."
            },
            {
              "language": "tr",
              "text": "Şirket düzenli güvenlik incelemelerini kurumsallaştırmak istiyor."
            }
          ]
        },
        {
          "baseText": "Die Stadt hat Bürgerbeteiligung nicht nur angeboten, sondern dauerhaft institutionalisiert.",
          "translations": [
            {
              "language": "ar",
              "text": "لم تكتفِ المدينة بعرض مشاركة المواطنين، بل جعلتها مؤسسة دائمة."
            },
            {
              "language": "ckb",
              "text": "شارەکە تەنها بەشداری هاوڵاتیانی پێشکەش نەکرد، بەڵکو بەردەوام دامەزراوەیی کرد."
            },
            {
              "language": "en",
              "text": "The city not only offered citizen participation but institutionalized it permanently."
            },
            {
              "language": "fa",
              "text": "شهر فقط مشارکت شهروندان را پیشنهاد نکرد، بلکه آن را به‌طور پایدار نهادینه کرد."
            },
            {
              "language": "kmr",
              "text": "Bajar ne tenê beşdariya welatiyan pêşkêş kir, lê wê bi domdarî sazî kir."
            },
            {
              "language": "pl",
              "text": "Miasto nie tylko zaoferowało udział obywateli, lecz trwale go zinstytucjonalizowało."
            },
            {
              "language": "ro",
              "text": "Orașul nu doar a oferit participarea cetățenilor, ci a instituționalizat-o permanent."
            },
            {
              "language": "ru",
              "text": "Город не только предложил участие граждан, но и постоянно институционализировал его."
            },
            {
              "language": "sq",
              "text": "Qyteti jo vetëm ofroi pjesëmarrjen qytetare, por e institucionalizoi atë përherë."
            },
            {
              "language": "tr",
              "text": "Şehir vatandaş katılımını sadece sunmakla kalmadı, kalıcı olarak kurumsallaştırdı."
            }
          ]
        }
      ]
    },
