      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "eine Zusatzinformation geben",
          "meaning": "to give additional information"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zusätzlich",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Information",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "معلومة إضافية"
        },
        {
          "language": "ckb",
          "text": "زانیاریی زیادە"
        },
        {
          "language": "en",
          "text": "additional information"
        },
        {
          "language": "fa",
          "text": "اطلاعات اضافی"
        },
        {
          "language": "kmr",
          "text": "agahiya zêde"
        },
        {
          "language": "pl",
          "text": "dodatkowa informacja"
        },
        {
          "language": "ro",
          "text": "informație suplimentară"
        },
        {
          "language": "ru",
          "text": "дополнительная информация"
        },
        {
          "language": "sq",
          "text": "informacion shtesë"
        },
        {
          "language": "tr",
          "text": "ek bilgi"
        }
      ],
      "examples": [
        {
          "baseText": "Auf dem Formular fehlt eine Zusatzinformation.",
          "translations": [
            {
              "language": "ar",
              "text": "في الاستمارة تنقص معلومة إضافية."
            },
            {
              "language": "ckb",
              "text": "لە فۆرمەکەدا زانیارییەکی زیادە کەمە."
            },
            {
              "language": "en",
              "text": "An additional piece of information is missing on the form."
            },
            {
              "language": "fa",
              "text": "در فرم یک اطلاعات اضافی کم است."
            },
            {
              "language": "kmr",
              "text": "Li ser formê agahiyeke zêde kêm e."
            },
            {
              "language": "pl",
              "text": "W formularzu brakuje dodatkowej informacji."
            },
            {
              "language": "ro",
              "text": "Pe formular lipsește o informație suplimentară."
            },
            {
              "language": "ru",
              "text": "В форме отсутствует дополнительная информация."
            },
            {
              "language": "sq",
              "text": "Në formular mungon një informacion shtesë."
            },
            {
              "language": "tr",
              "text": "Formda bir ek bilgi eksik."
            }
          ]
        },
        {
          "baseText": "Bitte lesen Sie die Zusatzinformation zur Buchung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى قراءة المعلومة الإضافية الخاصة بالحجز."
            },
            {
              "language": "ckb",
              "text": "تکایە زانیاریی زیادەی حجزەکە بخوێننەوە."
            },
            {
              "language": "en",
              "text": "Please read the additional information about the booking."
            },
            {
              "language": "fa",
              "text": "لطفاً اطلاعات اضافی مربوط به رزرو را بخوانید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe agahiya zêde ya veqetandinê bixwînin."
            },
            {
              "language": "pl",
              "text": "Proszę przeczytać dodatkową informację do rezerwacji."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să citiți informația suplimentară despre rezervare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, прочитайте дополнительную информацию о бронировании."
            },
            {
              "language": "sq",
              "text": "Ju lutem lexoni informacionin shtesë për rezervimin."
            },
            {
              "language": "tr",
              "text": "Lütfen rezervasyonla ilgili ek bilgiyi okuyun."
            }
          ]
        }
      ]
    },
    {
      "word": "zuverlässig",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "zu-ver-läs-sig",
      "topics": [
        "work-and-jobs",
        "customer-service",
        "social-and-relationships"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective"
      ],
      "collocations": [
        {
          "text": "zuverlässig arbeiten",
          "meaning": "to work reliably"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Zuverlässigkeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موثوق؛ يعتمد عليه"
        },
        {
          "language": "ckb",
          "text": "جێی متمانە؛ پشتپێبەستراو"
        },
        {
          "language": "en",
          "text": "reliable; dependable"
        },
        {
          "language": "fa",
          "text": "قابل اعتماد؛ مطمئن"
        },
        {
          "language": "kmr",
          "text": "bawerbar; pêbawer"
        },
        {
          "language": "pl",
          "text": "niezawodny; godny zaufania"
        },
        {
          "language": "ro",
          "text": "de încredere; fiabil"
        },
        {
          "language": "ru",
          "text": "надежный"
        },
        {
          "language": "sq",
          "text": "i besueshëm"
        },
        {
          "language": "tr",
          "text": "güvenilir"
        }
      ],
      "examples": [
        {
          "baseText": "Unser neuer Kollege ist sehr zuverlässig.",
          "translations": [
            {
              "language": "ar",
              "text": "زميلنا الجديد موثوق جداً."
            },
            {
              "language": "ckb",
              "text": "هاوکارە نوێیەکەمان زۆر جێی متمانەیە."
            },
            {
              "language": "en",
              "text": "Our new colleague is very reliable."
            },
            {
              "language": "fa",
              "text": "همکار جدید ما خیلی قابل اعتماد است."
            },
            {
              "language": "kmr",
              "text": "Hevkarê me yê nû pir bawerbar e."
            },
            {
              "language": "pl",
              "text": "Nasz nowy kolega jest bardzo niezawodny."
            },
            {
              "language": "ro",
              "text": "Noul nostru coleg este foarte de încredere."
            },
            {
              "language": "ru",
              "text": "Наш новый коллега очень надежный."
            },
            {
              "language": "sq",
              "text": "Kolegu ynë i ri është shumë i besueshëm."
            },
            {
              "language": "tr",
              "text": "Yeni iş arkadaşımız çok güvenilir."
            }
          ]
        },
        {
          "baseText": "Der Bus ist hier leider nicht sehr zuverlässig.",
          "translations": [
            {
              "language": "ar",
              "text": "الحافلة هنا للأسف ليست موثوقة جداً."
            },
            {
              "language": "ckb",
              "text": "پاسەکە لێرە بەداخەوە زۆر پشتپێبەستراو نییە."
            },
            {
              "language": "en",
              "text": "Unfortunately, the bus here is not very reliable."
            },
            {
              "language": "fa",
              "text": "متأسفانه اتوبوس اینجا خیلی قابل اعتماد نیست."
            },
            {
              "language": "kmr",
              "text": "Mixabin otobûs li vir ne pir bawerbar e."
            },
            {
              "language": "pl",
              "text": "Autobus tutaj niestety nie jest bardzo niezawodny."
            },
            {
              "language": "ro",
              "text": "Din păcate, autobuzul aici nu este foarte fiabil."
            },
            {
              "language": "ru",
              "text": "К сожалению, автобус здесь не очень надежный."
            },
            {
              "language": "sq",
              "text": "Fatkeqësisht autobusi këtu nuk është shumë i besueshëm."
            },
            {
              "language": "tr",
              "text": "Buradaki otobüs maalesef çok güvenilir değil."
            }
          ]
        }
      ]
    },
