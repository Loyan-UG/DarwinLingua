          "meaning": "to change the route"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "طريق؛ مسار"
        },
        {
          "language": "ckb",
          "text": "ڕێگا؛ ڕێڕەو"
        },
        {
          "language": "en",
          "text": "route"
        },
        {
          "language": "fa",
          "text": "مسیر"
        },
        {
          "language": "kmr",
          "text": "rê"
        },
        {
          "language": "pl",
          "text": "trasa"
        },
        {
          "language": "ro",
          "text": "rută"
        },
        {
          "language": "ru",
          "text": "маршрут"
        },
        {
          "language": "sq",
          "text": "rrugë; itinerar"
        },
        {
          "language": "tr",
          "text": "rota"
        }
      ],
      "examples": [
        {
          "baseText": "Die Route für die Lieferung ist im ERP-System geplant.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تخطيط مسار التسليم في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "ڕێڕەوی گەیاندنەکە لە سیستەمی ERPدا پلاندانراوە."
            },
            {
              "language": "en",
              "text": "The route for the delivery is planned in the ERP system."
            },
            {
              "language": "fa",
              "text": "مسیر تحویل در سیستم ERP برنامه‌ریزی شده است."
            },
            {
              "language": "kmr",
              "text": "Rêya radestkirinê di pergala ERP de hatiye plansazkirin."
            },
            {
              "language": "pl",
              "text": "Trasa dostawy jest zaplanowana w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Ruta pentru livrare este planificată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Маршрут доставки запланирован в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Rruga për dorëzimin është planifikuar në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Teslimat rotası ERP sisteminde planlandı."
            }
          ]
        },
        {
          "baseText": "Diese Route ist kurz und einfach.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا المسار قصير وسهل."
            },
            {
              "language": "ckb",
              "text": "ئەم ڕێگایە کورت و ئاسانە."
            },
            {
              "language": "en",
              "text": "This route is short and easy."
            },
            {
              "language": "fa",
              "text": "این مسیر کوتاه و ساده است."
            },
            {
              "language": "kmr",
              "text": "Ev rê kurt û hêsan e."
            },
            {
              "language": "pl",
              "text": "Ta trasa jest krótka i prosta."
            },
            {
              "language": "ro",
              "text": "Această rută este scurtă și simplă."
            },
            {
              "language": "ru",
              "text": "Этот маршрут короткий и простой."
            },
            {
              "language": "sq",
              "text": "Kjo rrugë është e shkurtër dhe e thjeshtë."
            },
            {
              "language": "tr",
              "text": "Bu rota kısa ve kolay."
            }
          ]
        }
      ]
    },
