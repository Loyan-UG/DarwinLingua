      "word": "die Position",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Positionen",
      "infinitive": null,
      "syllableBreak": "Po-si-ti-on",
      "topics": [
        "documents-and-administration",
        "erp-and-business-systems",
        "warehouse-and-logistics"
      ],
      "usageLabels": [
        "business",
        "written",
        "technical"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Position prüfen",
          "meaning": "to check an item/line"
        },
        {
          "text": "Position im Auftrag",
          "meaning": "line item in the order"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بند؛ موضع"
        },
        {
          "language": "ckb",
          "text": "پۆزیشەن؛ خاڵ"
        },
        {
          "language": "en",
          "text": "position; line item"
        },
        {
          "language": "fa",
          "text": "ردیف؛ موقعیت"
        },
        {
          "language": "kmr",
          "text": "pozîsyon; xeta fermanê"
        },
        {
          "language": "pl",
          "text": "pozycja"
        },
        {
          "language": "ro",
          "text": "poziție"
        },
        {
          "language": "ru",
          "text": "позиция; строка"
        },
        {
          "language": "sq",
          "text": "pozicion; zë"
        },
        {
          "language": "tr",
          "text": "pozisyon; kalem"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte prüfen Sie die erste Position im Auftrag.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق من البند الأول في الطلب."
            },
            {
              "language": "ckb",
              "text": "تکایە یەکەم پۆزیشەن لە داواکارییەکەدا بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the first line item in the order."
            },
            {
              "language": "fa",
              "text": "لطفاً ردیف اول سفارش را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pozîsyona yekem di fermarişê de kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić pierwszą pozycję w zamówieniu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați prima poziție din comandă."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте первую позицию в заказе."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni pozicionin e parë në porosi."
            },
            {
              "language": "tr",
              "text": "Lütfen siparişteki ilk kalemi kontrol edin."
            }
          ]
        },
        {
          "baseText": "Meine Position auf der Karte ist richtig.",
          "translations": [
            {
              "language": "ar",
              "text": "موقعي على الخريطة صحيح."
            },
            {
              "language": "ckb",
              "text": "شوێنەکەم لەسەر نەخشە دروستە."
            },
            {
              "language": "en",
              "text": "My position on the map is correct."
            },
            {
              "language": "fa",
              "text": "موقعیت من روی نقشه درست است."
            },
            {
              "language": "kmr",
              "text": "Pozîsyona min li ser nexşeyê rast e."
            },
            {
              "language": "pl",
              "text": "Moja pozycja na mapie jest prawidłowa."
            },
            {
              "language": "ro",
              "text": "Poziția mea pe hartă este corectă."
            },
            {
              "language": "ru",
              "text": "Моя позиция на карте правильная."
            },
            {
              "language": "sq",
              "text": "Pozicioni im në hartë është i saktë."
            },
            {
              "language": "tr",
              "text": "Haritadaki konumum doğru."
            }
          ]
        }
      ]
    },
