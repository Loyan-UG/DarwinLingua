  "entries": [
    {
      "word": "der Ansatz",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Ansätze",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-satz",
      "topics": [
        "planning-and-projects",
        "management-and-leadership"
      ],
      "usageLabels": [
        "analysis",
        "workplace",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "نهج؛ روش"
        },
        {
          "language": "ckb",
          "text": "ڕێگا؛ مەودا"
        },
        {
          "language": "en",
          "text": "approach; angle of attack"
        },
        {
          "language": "fa",
          "text": "روش؛ رویکرد"
        },
        {
          "language": "kmr",
          "text": "bavêjî; şêwaz"
        },
        {
          "language": "pl",
          "text": "podejście; metoda"
        },
        {
          "language": "ro",
          "text": "abordare; metodă"
        },
        {
          "language": "ru",
          "text": "подход; метод"
        },
        {
          "language": "sq",
          "text": "qasje; mënyrë"
        },
        {
          "language": "tr",
          "text": "yaklaşım; yöntem"
        }
      ],
      "examples": [
        {
          "baseText": "Wir haben für den Rollout des neuen ERP-Systems einen risikoarmen Ansatz gewählt.",
          "translations": [
            {
              "language": "ar",
              "text": "برای راه اندازی سیستم ERP جدید، یک رویکرد کم‌ریسک انتخاب کردیم."
            },
            {
              "language": "ckb",
              "text": "بۆ ڕۆڵاوتی سیستەمی نوێی ERP شانەیەکی کەم مەترسی هەڵبژاردین."
            },
            {
              "language": "en",
              "text": "We chose a low-risk approach for the rollout of the new ERP system."
            },
            {
              "language": "fa",
              "text": "برای راه‌اندازی سیستم جدید ERP، یک رویکرد کم‌خطر انتخاب کردیم."
            },
            {
              "language": "kmr",
              "text": "Ji bo xebatê wê ya pergala nû ya ERP, em rêbaza kêm-risq hilbijart."
            },
            {
              "language": "pl",
              "text": "Na wdrożenie nowego systemu ERP wybraliśmy podejście niskiego ryzyka."
            },
            {
              "language": "ro",
              "text": "Am ales o abordare cu risc redus pentru implementarea noului sistem ERP."
            },
            {
              "language": "ru",
              "text": "Для внедрения новой ERP-системы мы выбрали малорисковый подход."
            },
            {
              "language": "sq",
              "text": "Ne për vendosjen e sistemit të ri ERP zgjodhëm një qasje me rrezik të ulët."
            },
            {
              "language": "tr",
              "text": "Yeni ERP sisteminin devreye alınması için düşük riskli bir yaklaşım seçtik."
            }
          ]
        },
        {
          "baseText": "Der Projektleiter bat darum, bei der Kapazitätsplanung einen klaren Ansatz festzulegen.",
          "translations": [
            {
              "language": "ar",
              "text": "مدیر پروژه درخواست کرد تا در برنامه‌ریزی ظرفیت، یک رویکرد روشن تعیین شود."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری پڕۆژە داوای کردەوە کە لە پلاندنی تواناییەکان ڕێکەوەیەکی ڕونەق دیاری بکرێت."
            },
            {
              "language": "en",
              "text": "The project lead asked to set a clear approach for capacity planning."
            },
            {
              "language": "fa",
              "text": "مدیر پروژه خواستار تعیین یک رویکرد روشن برای برنامه‌ریزی ظرفیت شد."
            },
            {
              "language": "kmr",
              "text": "Serkarê projeyê xwest ku ji bo planîna kapasîteyê qeseyekî zelal were dayîn."
            },
            {
              "language": "pl",
              "text": "Kierownik projektu poprosił o ustalenie jasnego podejścia do planowania pojemności."
            },
            {
              "language": "ro",
              "text": "Șeful de proiect a cerut stabilirea unei abordări clare pentru planificarea capacității."
            },
            {
              "language": "ru",
              "text": "Руководитель проекта попросил определить четкий подход к планированию мощности."
            },
            {
              "language": "sq",
              "text": "Drejtori i projektit kërkoi vendosjen e një qasjeje të qartë për planifikimin e kapacitetit."
            },
            {
              "language": "tr",
              "text": "Proje yöneticisi, kapasite planlaması için net bir yaklaşım belirlenmesini istedi."
            }
          ]
        }
      ]
    },
    {
      "word": "anschieben",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anschieben",
      "pronunciationIpa": null,
      "syllableBreak": "an-schie-ben",
      "topics": [
        "work-and-jobs",
        "management-and-leadership"
      ],
      "usageLabels": [
        "workplace",
        "business",
        "spoken"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable prefix with past participle: angeschoben"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "فشار دادن؛ محرک کردن"
        },
        {
          "language": "ckb",
          "text": "بەزەبوونەوە; پشت دەستن"
        },
        {
          "language": "en",
          "text": "to push; to urge forward"
        },
        {
          "language": "fa",
          "text": "فشار دادن؛ جلو انداختن"
        },
        {
          "language": "kmr",
          "text": "bêjêrkirin; pêşxistin"
        },
        {
          "language": "pl",
          "text": "popychać; teşvik etmek"
        },
        {
          "language": "ro",
          "text": "a împinge; a impulsiona"
        },
        {
          "language": "ru",
          "text": "сдвигать/подталкивать; продвигать"
        },
        {
          "language": "sq",
          "text": "të shtyjë; të nxitë"
        },
        {
          "language": "tr",
          "text": "itmek; bir şeyi öne sürmek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Team hat den Produktstart angeschoben, damit wir die neue Roadmap einhalten können.",
          "translations": [
            {
              "language": "ar",
              "text": "تیم، راه اندازی محصول را جلو انداخت تا بتوانیم نقشه راه جدید را رعایت کنیم."
            },
            {
              "language": "ckb",
              "text": "تیمەکە ڕەخنەی بەرهەمەکەیەکی نوێیەکان بەرهەمییەوە، بۆ ئەوەی بتوانین نەخشەڕەهەڕەکە جێبەجێ بکەین."
            },
            {
              "language": "en",
              "text": "The team pushed the product launch forward so we can keep the new roadmap."
            },
            {
              "language": "fa",
              "text": "تیم، راه‌اندازی محصول را جلو کشید تا بتوانیم نقشه راه جدید را رعایت کنیم."
            },
            {
              "language": "kmr",
              "text": "Tîmê danîna berdestkirina berhemê ber bi pêş kir, da ku me rêbaznameya nû bisepîne."
            },
            {
              "language": "pl",
              "text": "Zespół przesunął i przyspieszył start produktu, aby dotrzymać nowego harmonogramu."
            },
            {
              "language": "ro",
              "text": "Echipa a împins lansarea produsului înainte pentru a respecta noua foaie de parcurs."
            },
            {
              "language": "ru",
              "text": "Команда подтолкнула запуск продукта вперед, чтобы соблюсти новую дорожную карту."
            },
            {
              "language": "sq",
              "text": "Ekipi e shtyu përpara nisjen e produktit që të respektojmë hartën e rrugës së re."
            },
            {
              "language": "tr",
              "text": "Ekip ürün lansmanını ileri itti, böylece yeni yol haritasına uyabildik."
            }
          ]
        },
        {
          "baseText": "Während der Umstellung haben wir den alten Prototypen angeschoben und durch den stabilen Baukasten ersetzt.",
          "translations": [
            {
              "language": "ar",
              "text": "در زمان تغییر، نمونه اولیه قدیمی را کنار زدییم و با یک چارچوب پایدار جایگزین کردیم."
            },
            {
              "language": "ckb",
              "text": "لە کاتی گۆڕانکاریەکەدا ماەڵەی پەڕینەکەی کۆنمان پیشەکەی کرد و بۆ چارچووبیەکی جێگرتووەوەیی گەڕاند."
            },
            {
              "language": "en",
              "text": "During the migration we moved away from the old prototype and replaced it with the stable framework."
            },
            {
              "language": "fa",
              "text": "در زمان جابه‌جایی، نمونه اولیه قدیمی را کنار گذاشتیم و با چارچوب پایدار جایگزین کردیم."
            },
            {
              "language": "kmr",
              "text": "Di dema veguhestinan de me prototîpa kevn paş kir û bi şanşîna xwerû ya bi hêz diguherîna."
            },
            {
              "language": "pl",
              "text": "Podczas migracji odstawiliśmy stary prototyp i go zastąpiliśmy stabilnym szablonem."
            },
            {
              "language": "ro",
              "text": "În timpul migrării am renunțat la prototipul vechi și l-am înlocuit cu un cadru stabil."
            },
            {
              "language": "ru",
              "text": "Во время миграции мы отступили от старого прототипа и заменили его надежным каркасом."
            },
            {
              "language": "sq",
              "text": "Gjatë migrimit ne e nxorëm prototipin e vjetër dhe e zëvendësuam me një kornizë të qëndrueshme."
            },
            {
              "language": "tr",
              "text": "Geçiş sırasında eski prototipi kenara itip yerine stabil bir şablonla değiştirdik."
            }
          ]
        }
      ]
    },
    {
      "word": "anschießen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "anschießen",
      "pronunciationIpa": null,
      "syllableBreak": "an-schie-ßen",
      "topics": [
        "documents-and-administration",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "past participle: angeschossen"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "شلیک کردن به طرف چیزی/کسی"
        },
        {
          "language": "ckb",
          "text": "فڕینەوە بۆ سەر شتێک"
        },
        {
          "language": "en",
          "text": "to shoot at"
        },
        {
          "language": "fa",
          "text": "به سمتی چیز/کسی شلیک کردن"
        },
        {
          "language": "kmr",
          "text": "li ser tiştek/kesek şewtandin"
        },
        {
          "language": "pl",
          "text": "strzelać do"
        },
        {
          "language": "ro",
          "text": "a trage spre"
        },
        {
          "language": "ru",
          "text": "стрелять по/в сторону"
        },
        {
          "language": "sq",
          "text": "qëllojnë në"
        },
        {
          "language": "tr",
          "text": "doğru ateş etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Sicherheitsbeauftragte untersagte es, in der Werkshalle auf Material zu schießen.",
          "translations": [
            {
              "language": "ar",
              "text": "مسئول ایمنی انجام داد که در سالن کارگاه شلیک به مصالح ممنوع است."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری سەرچاوەی سەلامەتی ئەوەی گفت کە لە هەڵەی کارگەدا نەبێت بەسەر خاوەنەری بڕیارەکە شەڕ بکرێ."
            },
            {
              "language": "en",
              "text": "The safety officer forbade shooting at materials in the workshop area."
            },
            {
              "language": "fa",
              "text": "مسئول ایمنی اعلام کرد که شلیک به مواد در سالن کارگاه ممنوع است."
            },
            {
              "language": "kmr",
              "text": "Mîhengdara ewlekarî şer kir ku di navxaneyê pêşandanê de lê li ser materyalê şewtîn bê."
            },
            {
              "language": "pl",
              "text": "Kierownik BHP zabronił strzelania do materiałów w hali produkcyjnej."
            },
            {
              "language": "ro",
              "text": "Responsabilul HSE a interzis tragerea înspre materiale în hala de producție."
            },
            {
              "language": "ru",
              "text": "Инженер по охране труда запретил стрельбу по материалам на производственном участке."
            },
            {
              "language": "sq",
              "text": "Zyrtari i sigurisë ndaloi të qëllohej në materialet në sallën e punës."
            },
            {
              "language": "tr",
              "text": "İş güvenliği sorumlusu, atölye alanında materyale doğru ateş etmeyi yasakladı."
            }
          ]
        },
        {
          "baseText": "In der Berichtserstellung erwähnte der Chef nur, dass der Vorfall ohne Anschuss eskaliert wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "در گزارش، رئیس فقط گفت که حادثه بدون تیراندازی پیشرفت کرده بود."
            },
            {
              "language": "ckb",
              "text": "لە تۆمارە ڕاپۆرتەکەدا سەرپرست تەنها وتی ڕووداوەکە بەبێ شۆکەی تێپەڕاندنەوە گەشەی پەیدا کرد."
            },
            {
              "language": "en",
              "text": "In the incident report, the manager only noted that the case escalated without any shots being fired."
            },
            {
              "language": "fa",
