  "entries": [
    {
      "word": "die Umfrage",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Umfragen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Um-fra-ge",
      "topics": [
        "data-and-reporting",
        "business-communication",
        "sales-and-customers"
      ],
      "usageLabels": [
        "business",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Umfrage durchführen",
          "meaning": "to conduct a survey"
        },
        {
          "text": "an einer Umfrage teilnehmen",
          "meaning": "to take part in a survey"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fragen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استطلاع؛ استبيان"
        },
        {
          "language": "ckb",
          "text": "ڕاپرسی؛ پرسیارنامە"
        },
        {
          "language": "en",
          "text": "survey; poll"
        },
        {
          "language": "fa",
          "text": "نظرسنجی؛ پرسشنامه"
        },
        {
          "language": "kmr",
          "text": "anket; lêpirsîn"
        },
        {
          "language": "pl",
          "text": "ankieta; sondaż"
        },
        {
          "language": "ro",
          "text": "sondaj; chestionar"
        },
        {
          "language": "ru",
          "text": "опрос; анкета"
        },
        {
          "language": "sq",
          "text": "anketë; sondazh"
        },
        {
          "language": "tr",
          "text": "anket; kamuoyu yoklaması"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Webinar schicken wir den Teilnehmern eine kurze Umfrage.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الندوة عبر الإنترنت نرسل للمشاركين استطلاعًا قصيرًا."
            },
            {
              "language": "ckb",
              "text": "دوای وێبینارەکە ڕاپرسییەکی کورت بۆ بەژداربووان دەنێرین."
            },
            {
              "language": "en",
              "text": "After the webinar, we send participants a short survey."
            },
            {
              "language": "fa",
              "text": "بعد از وبینار، یک نظرسنجی کوتاه برای شرکت‌کنندگان می‌فرستیم."
            },
            {
              "language": "kmr",
              "text": "Piştî webinarê em anketeke kurt ji beşdaran re dişînin."
            },
            {
              "language": "pl",
              "text": "Po webinarze wysyłamy uczestnikom krótką ankietę."
            },
            {
              "language": "ro",
              "text": "După webinar trimitem participanților un scurt chestionar."
            },
            {
              "language": "ru",
              "text": "После вебинара мы отправляем участникам короткий опрос."
            },
            {
              "language": "sq",
              "text": "Pas webinarit u dërgojmë pjesëmarrësve një anketë të shkurtër."
            },
            {
              "language": "tr",
              "text": "Webinardan sonra katılımcılara kısa bir anket gönderiyoruz."
            }
          ]
        },
        {
          "baseText": "Die Umfrage zeigt, dass viele Kunden längere Öffnungszeiten wünschen.",
          "translations": [
            {
              "language": "ar",
              "text": "يظهر الاستطلاع أن كثيرًا من العملاء يريدون ساعات عمل أطول."
            },
            {
              "language": "ckb",
              "text": "ڕاپرسییەکە نیشان دەدات زۆر کڕیار کاتی کردنەوەی درێژتر دەیانەوێت."
            },
            {
              "language": "en",
              "text": "The survey shows that many customers want longer opening hours."
            },
            {
              "language": "fa",
              "text": "نظرسنجی نشان می‌دهد بسیاری از مشتریان ساعت کاری طولانی‌تر می‌خواهند."
            },
            {
              "language": "kmr",
              "text": "Anket nîşan dide ku gelek xerîdar demên vekirina dirêjtir dixwazin."
            },
            {
              "language": "pl",
              "text": "Ankieta pokazuje, że wielu klientów chce dłuższych godzin otwarcia."
            },
            {
              "language": "ro",
              "text": "Sondajul arată că mulți clienți doresc un program mai lung."
            },
            {
              "language": "ru",
              "text": "Опрос показывает, что многие клиенты хотят более долгие часы работы."
            },
            {
              "language": "sq",
              "text": "Anketa tregon se shumë klientë duan orar më të gjatë pune."
            },
            {
              "language": "tr",
              "text": "Anket, birçok müşterinin daha uzun çalışma saatleri istediğini gösteriyor."
            }
          ]
        }
      ]
    },
    {
      "word": "der Umgang",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Um-gang",
      "topics": [
        "social-and-relationships",
        "work-and-jobs",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; usually singular in this meaning"
      ],
      "collocations": [
        {
          "text": "der Umgang mit Kunden",
          "meaning": "dealing with customers"
        },
        {
          "text": "ein freundlicher Umgang",
          "meaning": "a friendly manner"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "umgehen mit",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "التعامل؛ طريقة التعامل"
        },
        {
          "language": "ckb",
          "text": "مامەڵە؛ شێوازی هەڵسوکەوت"
        },
        {
          "language": "en",
          "text": "handling; dealing with; manner of interaction"
        },
        {
          "language": "fa",
          "text": "برخورد؛ نحوه تعامل؛ مدیریت"
        },
        {
          "language": "kmr",
          "text": "reftar; danûstandin; birêvebirin"
        },
        {
          "language": "pl",
          "text": "obchodzenie się; sposób traktowania"
        },
        {
          "language": "ro",
          "text": "mod de a trata; gestionare"
        },
        {
          "language": "ru",
          "text": "обращение; Umgang; способ взаимодействия"
        },
        {
          "language": "sq",
          "text": "sjellje; mënyrë trajtimi"
        },
        {
          "language": "tr",
          "text": "davranış; Umgang; başa çıkma biçimi"
        }
      ],
      "examples": [
        {
          "baseText": "Der höfliche Umgang mit Kunden ist in unserem Support sehr wichtig.",
          "translations": [
            {
              "language": "ar",
              "text": "التعامل المهذب مع العملاء مهم جدًا في قسم الدعم لدينا."
            },
            {
              "language": "ckb",
              "text": "مامەڵەی ڕێزدارانە لەگەڵ کڕیاران لە پاڵپشتییەکەماندا زۆر گرنگە."
            },
            {
              "language": "en",
              "text": "Polite interaction with customers is very important in our support team."
            },
            {
              "language": "fa",
              "text": "برخورد مودبانه با مشتریان در پشتیبانی ما بسیار مهم است."
            },
            {
              "language": "kmr",
              "text": "Reftara bi rêz bi xerîdaran re di piştgiriya me de pir girîng e."
            },
            {
              "language": "pl",
              "text": "Uprzejme traktowanie klientów jest bardzo ważne w naszym dziale wsparcia."
            },
            {
              "language": "ro",
              "text": "Comportamentul politicos față de clienți este foarte important în suportul nostru."
            },
            {
              "language": "ru",
              "text": "Вежливое обращение с клиентами очень важно в нашей поддержке."
            },
            {
              "language": "sq",
              "text": "Sjellja e sjellshme me klientët është shumë e rëndësishme në mbështetjen tonë."
            },
            {
              "language": "tr",
              "text": "Müşterilerle kibar iletişim destek ekibimizde çok önemlidir."
            }
          ]
        },
        {
          "baseText": "Im Kurs lernen die Teilnehmer den sicheren Umgang mit Werkzeugen.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدورة يتعلم المشاركون التعامل الآمن مع الأدوات."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسەکەدا بەژداربووان مامەڵەی سەلامەت لەگەڵ ئامرازەکان فێر دەبن."
            },
            {
              "language": "en",
              "text": "In the course, participants learn how to handle tools safely."
            },
            {
              "language": "fa",
              "text": "در دوره، شرکت‌کنندگان کار ایمن با ابزارها را یاد می‌گیرند."
            },
            {
              "language": "kmr",
              "text": "Di kursê de beşdar fêrî reftara ewle bi amûran re dibin."
            },
            {
              "language": "pl",
              "text": "Na kursie uczestnicy uczą się bezpiecznego obchodzenia się z narzędziami."
            },
            {
              "language": "ro",
              "text": "La curs, participanții învață utilizarea sigură a uneltelor."
            },
            {
              "language": "ru",
              "text": "На курсе участники учатся безопасному обращению с инструментами."
            },
            {
              "language": "sq",
              "text": "Në kurs pjesëmarrësit mësojnë përdorimin e sigurt të mjeteve."
            },
            {
              "language": "tr",
              "text": "Kursta katılımcılar aletlerle güvenli şekilde çalışmayı öğrenir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Ummeldung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Ummeldungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Um-mel-dung",
      "topics": [
        "public-services",
        "documents-and-administration",
        "housing-and-real-estate"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Ummeldung beantragen",
          "meaning": "to apply for address re-registration"
        },
        {
          "text": "nach dem Umzug die Ummeldung machen",
          "meaning": "to re-register after moving"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sich ummelden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تغيير التسجيل؛ إعادة تسجيل العنوان"
        },
        {
          "language": "ckb",
          "text": "گۆڕینی تۆمار؛ نوێکردنەوەی ناونیشان"
        },
        {
          "language": "en",
          "text": "re-registration; change of registered address"
        },
        {
          "language": "fa",
          "text": "تغییر ثبت‌نام؛ ثبت آدرس جدید"
        },
        {
          "language": "kmr",
          "text": "ji nû ve tomarkirin; guhertina navnîşana tomarî"
        },
        {
          "language": "pl",
          "text": "przemeldowanie"
        },
        {
          "language": "ro",
          "text": "schimbare de domiciliu înregistrată; reînregistrare"
        },
        {
          "language": "ru",
          "text": "перерегистрация; смена регистрации адреса"
        },
        {
          "language": "sq",
          "text": "riregjistrim; ndryshim adrese"
        },
        {
          "language": "tr",
          "text": "adres kaydı değişikliği; yeniden kayıt"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Umzug müssen wir die Ummeldung beim Bürgeramt erledigen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الانتقال يجب أن ننجز تغيير التسجيل في مكتب المواطنين."
            },
            {
              "language": "ckb",
              "text": "دوای گواستنەوە دەبێت گۆڕینی تۆمار لە فەرمانگەی هاوڵاتیان تەواو بکەین."
            },
            {
              "language": "en",
              "text": "After moving, we have to complete the re-registration at the citizens’ office."
            },
            {
              "language": "fa",
              "text": "بعد از اسباب‌کشی باید تغییر ثبت آدرس را در اداره شهروندان انجام دهیم."
            },
            {
              "language": "kmr",
              "text": "Piştî barkirinê divê em ji nû ve tomarkirinê li ofîsa welatiyan bikin."
            },
            {
              "language": "pl",
              "text": "Po przeprowadzce musimy załatwić przemeldowanie w urzędzie mieszkańców."
            },
            {
              "language": "ro",
              "text": "După mutare trebuie să rezolvăm reînregistrarea la biroul pentru cetățeni."
            },
            {
              "language": "ru",
              "text": "После переезда нам нужно оформить перерегистрацию в Bürgeramt."
            },
            {
              "language": "sq",
              "text": "Pas shpërnguljes duhet të kryejmë riregjistrimin në zyrën e qytetarëve."
            },
            {
              "language": "tr",
              "text": "Taşındıktan sonra vatandaşlık ofisinde adres kaydı değişikliğini yapmalıyız."
            }
          ]
        },
        {
          "baseText": "Für die Ummeldung brauchen Sie Ihren Ausweis und die Wohnungsgeberbestätigung.",
          "translations": [
            {
              "language": "ar",
              "text": "لتغيير التسجيل تحتاج إلى هويتك وتأكيد صاحب السكن."
            },
            {
              "language": "ckb",
              "text": "بۆ گۆڕینی تۆمار پێویستت بە ناسنامە و پشتڕاستکردنەوەی خاوەنی خانوو هەیە."
            },
            {
              "language": "en",
