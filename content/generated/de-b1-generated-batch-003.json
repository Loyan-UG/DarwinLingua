  "entries": [
    {
      "word": "abschließen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abschließen",
      "pronunciationIpa": null,
      "syllableBreak": "ab-schlie-ßen",
      "topics": [
        "work-and-jobs",
        "contracts-and-negotiation",
        "everyday-life"
      ],
      "usageLabels": [
        "spoken",
        "business",
        "formal"
      ],
      "contextLabels": [
        "contracts",
        "management",
        "security"
      ],
      "grammarNotes": [
        "separable verb",
        "past participle: abgeschlossen; can mean to lock, finish, or conclude a contract"
      ],
      "collocations": [
        {
          "text": "einen Vertrag abschließen",
          "meaning": "to conclude a contract"
        },
        {
          "text": "die Tür abschließen",
          "meaning": "to lock the door"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Abschluss",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينهي؛ يبرم؛ يقفل"
        },
        {
          "language": "ckb",
          "text": "تەواوکردن؛ گرێبەست کردن؛ قفڵکردن"
        },
        {
          "language": "en",
          "text": "to finish; to conclude; to lock"
        },
        {
          "language": "fa",
          "text": "تمام کردن؛ منعقد کردن؛ قفل کردن"
        },
        {
          "language": "kmr",
          "text": "qedandin; peyman girêdan; kilît kirin"
        },
        {
          "language": "pl",
          "text": "zakończyć; zawrzeć; zamknąć na klucz"
        },
        {
          "language": "ro",
          "text": "a încheia; a finaliza; a încuia"
        },
        {
          "language": "ru",
          "text": "завершить; заключить; запереть"
        },
        {
          "language": "sq",
          "text": "të përfundosh; të lidhësh; të kyçësh"
        },
        {
          "language": "tr",
          "text": "bitirmek; sonuçlandırmak; kilitlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir möchten den Vertrag noch diese Woche abschließen.",
          "translations": [
            {
              "language": "ar",
              "text": "نريد إبرام العقد هذا الأسبوع."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت گرێبەستەکە هەر ئەم هەفتەیە تەواو بکەین."
            },
            {
              "language": "en",
              "text": "We would like to conclude the contract this week."
            },
            {
              "language": "fa",
              "text": "می‌خواهیم قرارداد را همین هفته نهایی کنیم."
            },
            {
              "language": "kmr",
              "text": "Em dixwazin vê hefteyê peymanê biqedînin."
            },
            {
              "language": "pl",
              "text": "Chcemy zawrzeć umowę jeszcze w tym tygodniu."
            },
            {
              "language": "ro",
              "text": "Dorim să încheiem contractul chiar săptămâna aceasta."
            },
            {
              "language": "ru",
              "text": "Мы хотим заключить договор ещё на этой неделе."
            },
            {
              "language": "sq",
              "text": "Duam ta përfundojmë kontratën këtë javë."
            },
            {
              "language": "tr",
              "text": "Sözleşmeyi bu hafta içinde sonuçlandırmak istiyoruz."
            }
          ]
        },
        {
          "baseText": "Bitte schließen Sie abends das Büro ab, wenn Sie als Letzter gehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى قفل المكتب مساءً إذا كنتم آخر من يغادر."
            },
            {
              "language": "ckb",
              "text": "تکایە ئێواران نووسینگەکە قفڵ بکەن ئەگەر دوا کەس بوون کە دەڕۆن."
            },
            {
              "language": "en",
              "text": "Please lock the office in the evening if you are the last to leave."
            },
            {
              "language": "fa",
              "text": "اگر آخرین نفری هستید که می‌روید، لطفاً عصر دفتر را قفل کنید."
            },
            {
              "language": "kmr",
              "text": "Heke hûn êvarê herî dawî derkevin, ji kerema xwe nivîsgehê kilît bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zamknąć biuro wieczorem, jeśli wychodzi Pan/Pani jako ostatni/a."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să încuiați biroul seara dacă plecați ultimul."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, закрывайте офис вечером, если уходите последним."
            },
            {
              "language": "sq",
              "text": "Ju lutem mbylleni zyrën në mbrëmje nëse largoheni të fundit."
            },
            {
              "language": "tr",
              "text": "Akşam son çıkan kişi sizseniz lütfen ofisi kilitleyin."
            }
          ]
        }
      ]
    },
