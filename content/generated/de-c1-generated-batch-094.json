  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Schadensbegrenzung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "syllableBreak": "Scha-dens-be-gren-zung",
      "topics": [
        "quality-and-risk",
        "business-communication",
        "management-and-leadership"
      ],
      "usageLabels": [
        "business",
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine compound noun; usually singular"
      ],
      "collocations": [
        {
          "text": "Schadensbegrenzung betreiben",
          "meaning": "to limit damage"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Schaden",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "begrenzen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "الحد من الأضرار"
        },
        {
          "language": "ckb",
          "text": "سنووردارکردنی زیان"
        },
        {
          "language": "en",
          "text": "damage control; damage limitation"
        },
        {
          "language": "fa",
          "text": "کنترل خسارت؛ محدود کردن آسیب"
        },
        {
          "language": "kmr",
          "text": "sînordarkirina zirarê"
        },
        {
          "language": "pl",
          "text": "ograniczanie szkód"
        },
        {
          "language": "ro",
          "text": "limitarea daunelor"
        },
        {
          "language": "ru",
          "text": "ограничение ущерба"
        },
        {
          "language": "sq",
          "text": "kufizim dëmi"
        },
        {
          "language": "tr",
          "text": "hasar kontrolü; zararı sınırlama"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Datenleck konzentrierte sich das Management zunächst auf Schadensbegrenzung.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تسرب البيانات ركزت الإدارة أولاً على الحد من الأضرار."
            },
            {
              "language": "ckb",
              "text": "دوای داتالێکەکە بەڕێوەبەرایەتی سەرەتا گرنگی بە سنووردارکردنی زیان دا."
            },
            {
              "language": "en",
              "text": "After the data leak, management initially focused on damage control."
            },
            {
              "language": "fa",
              "text": "پس از نشت داده، مدیریت ابتدا بر کنترل خسارت تمرکز کرد."
            },
            {
              "language": "kmr",
              "text": "Piştî derketina daneyan, rêveberî di destpêkê de li sînordarkirina zirarê sekinî."
            },
            {
              "language": "pl",
              "text": "Po wycieku danych kierownictwo najpierw skupiło się na ograniczaniu szkód."
            },
            {
              "language": "ro",
              "text": "După scurgerea de date, managementul s-a concentrat inițial pe limitarea daunelor."
            },
            {
              "language": "ru",
              "text": "После утечки данных руководство сначала сосредоточилось на ограничении ущерба."
            },
            {
              "language": "sq",
              "text": "Pas rrjedhjes së të dhënave, menaxhmenti fillimisht u përqendrua te kufizimi i dëmit."
            },
            {
              "language": "tr",
              "text": "Veri sızıntısından sonra yönetim önce hasar kontrolüne odaklandı."
            }
          ]
        },
        {
          "baseText": "Bei der Überschwemmung ging es in den ersten Stunden nur um Schadensbegrenzung.",
          "translations": [
            {
              "language": "ar",
              "text": "خلال الفيضان كان الأمر في الساعات الأولى يتعلق فقط بالحد من الأضرار."
            },
            {
              "language": "ckb",
              "text": "لە لافاوەکەدا لە کاتژمێرە سەرەتاییەکاندا تەنها باس لە سنووردارکردنی زیان بوو."
            },
            {
              "language": "en",
              "text": "During the flood, the first hours were only about limiting the damage."
            },
            {
              "language": "fa",
              "text": "در ساعات نخست سیل، مسئله فقط محدود کردن خسارت بود."
            },
            {
              "language": "kmr",
              "text": "Di lehiyê de di demjimêrên destpêkê de tenê mijar sînordarkirina zirarê bû."
            },
            {
              "language": "pl",
              "text": "Podczas powodzi w pierwszych godzinach chodziło tylko o ograniczenie szkód."
            },
            {
              "language": "ro",
              "text": "În timpul inundației, în primele ore era vorba doar de limitarea daunelor."
            },
            {
              "language": "ru",
              "text": "Во время наводнения в первые часы речь шла только об ограничении ущерба."
            },
            {
              "language": "sq",
              "text": "Gjatë përmbytjes, në orët e para bëhej fjalë vetëm për kufizimin e dëmit."
            },
            {
              "language": "tr",
              "text": "Sel sırasında ilk saatlerde mesele yalnızca zararı sınırlamaktı."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "schleichen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "schleichen",
      "syllableBreak": "schlei-chen",
      "topics": [
        "everyday-life",
        "technology-and-it",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong verb; literal or figurative"
      ],
      "collocations": [
        {
          "text": "sich in ein System schleichen",
          "meaning": "to creep into a system"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Schleichweg",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يتسلل؛ يزحف بهدوء"
        },
        {
          "language": "ckb",
          "text": "بە نهێنی دەڕوات؛ هێواش دەخزێت"
        },
        {
          "language": "en",
          "text": "to sneak; to creep"
        },
        {
          "language": "fa",
          "text": "دزدکی رفتن؛ آرام خزیدن"
        },
        {
          "language": "kmr",
          "text": "bi dizî çûn; hêdî xizîn"
        },
        {
          "language": "pl",
          "text": "skradać się; wkradać się"
        },
        {
          "language": "ro",
          "text": "a se strecura; a se furișa"
        },
        {
          "language": "ru",
          "text": "красться; прокрадываться"
        },
        {
          "language": "sq",
          "text": "të vjedhësh; të futesh fshehurazi"
        },
        {
          "language": "tr",
          "text": "süzülmek; gizlice girmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ein kleiner Fehler schlich sich in die Berechnung ein und blieb lange unbemerkt.",
          "translations": [
            {
              "language": "ar",
              "text": "تسلل خطأ صغير إلى الحساب وبقي غير ملحوظ لفترة طويلة."
            },
            {
              "language": "ckb",
              "text": "هەڵەیەکی بچووک بە نهێنی چووە ناو هەژمارکردنەکە و ماوەیەکی زۆر تێبینی نەکرا."
            },
            {
              "language": "en",
              "text": "A small error crept into the calculation and went unnoticed for a long time."
            },
            {
              "language": "fa",
              "text": "یک خطای کوچک وارد محاسبه شد و مدت‌ها دیده نشد."
            },
            {
              "language": "kmr",
              "text": "Şaşiyeke biçûk ket nav hesabê û demeke dirêj nehat dîtin."
            },
            {
              "language": "pl",
              "text": "Mały błąd wkradł się do obliczeń i długo pozostał niezauważony."
            },
            {
              "language": "ro",
              "text": "O mică eroare s-a strecurat în calcul și a rămas mult timp neobservată."
            },
            {
              "language": "ru",
              "text": "Небольшая ошибка закралась в расчет и долго оставалась незамеченной."
            },
            {
              "language": "sq",
              "text": "Një gabim i vogël u fut në llogaritje dhe mbeti gjatë pa u vënë re."
            },
            {
              "language": "tr",
              "text": "Küçük bir hata hesaba sızdı ve uzun süre fark edilmedi."
            }
          ]
        },
        {
          "baseText": "Die Katze schlich durch den Garten, ohne die Vögel aufzuschrecken.",
          "translations": [
            {
              "language": "ar",
              "text": "تسللت القطة عبر الحديقة من دون أن تفزع الطيور."
            },
            {
              "language": "ckb",
              "text": "پشیلەکە بە هێمنی لە ناو باخچەدا ڕۆیشت بەبێ ئەوەی باڵندەکان بترسێنێت."
            },
            {
              "language": "en",
              "text": "The cat crept through the garden without startling the birds."
            },
            {
              "language": "fa",
              "text": "گربه آرام از باغ گذشت بدون اینکه پرندگان را بترساند."
            },
            {
              "language": "kmr",
              "text": "Pisîk bi hêdî di baxçe de çû bê ku çûkan bitirsîne."
            },
            {
              "language": "pl",
              "text": "Kot skradał się przez ogród, nie płosząc ptaków."
            },
            {
              "language": "ro",
              "text": "Pisica s-a strecurat prin grădină fără să sperie păsările."
            },
            {
              "language": "ru",
              "text": "Кошка кралась по саду, не пугая птиц."
            },
            {
              "language": "sq",
              "text": "Macja u fut ngadalë nëpër kopsht pa i trembur zogjtë."
            },
            {
              "language": "tr",
              "text": "Kedi kuşları ürkütmeden bahçede süzüldü."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "schleifen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "schleifen",
      "syllableBreak": "schlei-fen",
      "topics": [
        "production-and-maintenance",
        "everyday-life",
        "technology-and-it"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "verb; can mean to grind/polish or to drag"
      ],
      "collocations": [
        {
          "text": "eine Oberfläche schleifen",
          "meaning": "to sand or grind a surface"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Schliff",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يصقل؛ يطحن؛ يجرّ"
        },
        {
          "language": "ckb",
          "text": "دەسڕێت/دەسابێت؛ ڕادەکێشێت"
        },
        {
          "language": "en",
          "text": "to grind; to sand; to drag"
        },
        {
          "language": "fa",
          "text": "ساییدن؛ سنباده زدن؛ کشیدن"
        },
        {
          "language": "kmr",
          "text": "xişandin; kêşan"
        },
        {
          "language": "pl",
          "text": "szlifować; ciągnąć"
        },
        {
          "language": "ro",
          "text": "a șlefui; a târî"
        },
        {
          "language": "ru",
          "text": "шлифовать; тащить"
        },
        {
          "language": "sq",
          "text": "të lëmosh; të tërheqësh zvarrë"
        },
        {
          "language": "tr",
          "text": "zımparalamak; sürüklemek"
        }
      ],
      "examples": [
        {
          "baseText": "Vor dem Lackieren muss die Oberfläche sorgfältig geschliffen werden.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الطلاء يجب صقل السطح بعناية."
            },
            {
              "language": "ckb",
              "text": "پێش ڕەنگکردن دەبێت ڕووکەشەکە بە وریایی بسڕدرێت."
            },
            {
              "language": "en",
              "text": "Before painting, the surface must be sanded carefully."
            },
            {
              "language": "fa",
              "text": "پیش از رنگ‌آمیزی، سطح باید با دقت سنباده زده شود."
            },
            {
              "language": "kmr",
              "text": "Berî boyaxkirinê divê rû bi hişyariyê were xişandin."
            },
            {
              "language": "pl",
              "text": "Przed lakierowaniem powierzchnię trzeba starannie wyszlifować."
            },
            {
              "language": "ro",
              "text": "Înainte de vopsire, suprafața trebuie șlefuită cu grijă."
            },
            {
              "language": "ru",
              "text": "Перед покраской поверхность нужно тщательно отшлифовать."
            },
            {
              "language": "sq",
              "text": "Para lyerjes, sipërfaqja duhet lëmuar me kujdes."
            },
            {
              "language": "tr",
              "text": "Boyamadan önce yüzey dikkatlice zımparalanmalıdır."
            }
          ]
        },
        {
