        {
          "language": "ru",
          "text": "прием у врача"
        },
        {
          "language": "sq",
          "text": "takim te mjeku"
        },
        {
          "language": "tr",
          "text": "doktor randevusu"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe morgen einen Arzttermin.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي موعد طبيب غداً."
            },
            {
              "language": "ckb",
              "text": "سبەی کاتی پزیشکم هەیە."
            },
            {
              "language": "en",
              "text": "I have a doctor appointment tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا وقت دکتر دارم."
            },
            {
              "language": "kmr",
              "text": "Sibê wextê bijîşkê min heye."
            },
            {
              "language": "pl",
              "text": "Mam jutro wizytę u lekarza."
            },
            {
              "language": "ro",
              "text": "Am mâine o programare la medic."
            },
            {
              "language": "ru",
              "text": "У меня завтра прием у врача."
            },
            {
              "language": "sq",
              "text": "Nesër kam takim te mjeku."
            },
            {
              "language": "tr",
              "text": "Yarın doktor randevum var."
            }
          ]
        },
        {
          "baseText": "Kann ich den Arzttermin auf Freitag verschieben?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني نقل موعد الطبيب إلى يوم الجمعة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم کاتی پزیشکەکە بگوازمەوە بۆ هەینی؟"
            },
            {
              "language": "en",
              "text": "Can I move the doctor appointment to Friday?"
            },
            {
              "language": "fa",
              "text": "می‌توانم وقت دکتر را به جمعه منتقل کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim wextê bijîşkê bibim roja înê?"
            },
            {
              "language": "pl",
              "text": "Czy mogę przełożyć wizytę u lekarza na piątek?"
            },
            {
              "language": "ro",
              "text": "Pot să mut programarea la medic pe vineri?"
            },
            {
              "language": "ru",
              "text": "Могу я перенести прием у врача на пятницу?"
            },
            {
              "language": "sq",
              "text": "A mund ta shtyj takimin te mjeku për të premten?"
            },
            {
              "language": "tr",
              "text": "Doktor randevusunu cumaya alabilir miyim?"
            }
          ]
        }
      ]
