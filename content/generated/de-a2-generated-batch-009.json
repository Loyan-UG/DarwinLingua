            },
            {
              "language": "en",
              "text": "I am wearing the new shoes today."
            },
            {
              "language": "fa",
              "text": "امروز کفش‌های جدید را می‌پوشم."
            },
            {
              "language": "kmr",
              "text": "Ez îro pêlavên nû li xwe dikim."
            },
            {
              "language": "pl",
              "text": "Dzisiaj zakładam nowe buty."
            },
            {
              "language": "ro",
              "text": "Astăzi îmi pun pantofii noi."
            },
            {
              "language": "ru",
              "text": "Сегодня я надеваю новые туфли."
