  "entries": [
    {
      "word": "die Bildungsmaßnahme",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Bildungsmaßnahmen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Bil-dungs-maß-nah-me",
      "topics": [
        "education-and-training",
        "work-and-jobs",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "education",
        "training",
        "administration"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "an einer Bildungsmaßnahme teilnehmen",
          "meaning": "to take part in an educational measure or training program"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Bildung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Maßnahme",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إجراء تعليمي؛ برنامج تدريبي"
        },
        {
          "language": "ckb",
          "text": "ڕێکاری پەروەردەیی؛ بەرنامەی فێربوون"
        },
        {
          "language": "en",
          "text": "educational measure; training program"
        },
        {
          "language": "fa",
          "text": "اقدام آموزشی؛ برنامه آموزشی"
        },
        {
          "language": "kmr",
          "text": "pêngava perwerdeyî; bernameya perwerdeyê"
        },
        {
          "language": "pl",
          "text": "działanie edukacyjne; program szkoleniowy"
        },
        {
          "language": "ro",
          "text": "măsură educațională; program de formare"
        },
        {
          "language": "ru",
          "text": "образовательная мера; учебная программа"
        },
        {
          "language": "sq",
          "text": "masë arsimore; program trajnimi"
        },
        {
          "language": "tr",
          "text": "eğitim tedbiri; eğitim programı"
        }
      ],
      "examples": [
        {
          "baseText": "Das Jobcenter bezahlt die Bildungsmaßnahme, wenn sie beruflich sinnvoll ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يدفع مركز العمل تكاليف البرنامج التدريبي إذا كان مفيدًا مهنيًا."
            },
            {
              "language": "ckb",
              "text": "سەنتەری کار پارەی ڕێکاری پەروەردەیی دەدات ئەگەر لە ڕووی پیشەییەوە بەسوود بێت."
            },
            {
              "language": "en",
              "text": "The job center pays for the training program if it makes sense professionally."
            },
            {
              "language": "fa",
              "text": "اگر برنامه آموزشی از نظر شغلی مفید باشد، مرکز کار هزینه آن را پرداخت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Heke bernameya perwerdeyê ji aliyê pîşeyî ve watedar be, navenda kar pereyê wê dide."
            },
            {
              "language": "pl",
              "text": "Urząd pracy opłaca program szkoleniowy, jeśli ma on sens zawodowy."
            },
            {
              "language": "ro",
              "text": "Agenția pentru ocuparea forței de muncă plătește programul de formare dacă este util profesional."
            },
            {
              "language": "ru",
              "text": "Центр занятости оплачивает учебную программу, если она имеет профессиональный смысл."
            },
            {
              "language": "sq",
              "text": "Qendra e punës e paguan programin e trajnimit nëse është i dobishëm profesionalisht."
            },
            {
              "language": "tr",
              "text": "İş kurumu, mesleki açıdan yararlıysa eğitim programını öder."
            }
          ]
        },
        {
          "baseText": "Vor Beginn der Bildungsmaßnahme müssen alle Unterlagen eingereicht werden.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل بدء البرنامج التدريبي يجب تقديم جميع المستندات."
            },
            {
              "language": "ckb",
              "text": "پێش دەستپێکردنی ڕێکاری پەروەردەیی دەبێت هەموو بەڵگەنامەکان پێشکەش بکرێن."
            },
            {
              "language": "en",
              "text": "Before the training program begins, all documents must be submitted."
            },
            {
              "language": "fa",
              "text": "قبل از شروع برنامه آموزشی باید همه مدارک ارائه شوند."
            },
            {
              "language": "kmr",
              "text": "Berî destpêka pêngava perwerdeyî divê hemû belge werin radestkirin."
            },
            {
              "language": "pl",
              "text": "Przed rozpoczęciem programu szkoleniowego trzeba złożyć wszystkie dokumenty."
            },
            {
              "language": "ro",
              "text": "Înainte de începerea programului de formare, trebuie depuse toate documentele."
            },
            {
              "language": "ru",
              "text": "До начала учебной программы необходимо подать все документы."
            },
            {
              "language": "sq",
              "text": "Para fillimit të programit të trajnimit duhet të dorëzohen të gjitha dokumentet."
            },
            {
              "language": "tr",
              "text": "Eğitim programı başlamadan önce tüm belgeler teslim edilmelidir."
            }
          ]
        }
      ]
    },
