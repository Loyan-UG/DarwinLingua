  "entries": [
    {
      "word": "aufliegen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufliegen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-lie-gen",
      "topics": [
        "work-and-jobs",
        "technology-and-it",
        "human-resources"
      ],
      "usageLabels": [
        "spoken",
        "workplace",
        "technical"
      ],
      "contextLabels": [
        "documents",
        "it"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "بیرون آوردن/پیشنهاد دادن در مکانی بالا"
        },
        {
          "language": "ckb",
          "text": "لە سەرەوەدا هەڵگرتن"
        },
        {
          "language": "en",
          "text": "to rise; to float up"
        },
        {
          "language": "fa",
          "text": "آویزان شدن؛ بالا آمدن"
        },
        {
          "language": "kmr",
          "text": "joşbûn; bilind bûn"
        },
        {
          "language": "pl",
          "text": "wypłynąć; wzbić się"
        },
        {
          "language": "ro",
          "text": "a se ridica; a pluti"
        },
        {
          "language": "ru",
          "text": "подняться; взлетать"
        },
        {
          "language": "sq",
          "text": "ngrihet; dalë në sipërfaqe"
        },
        {
          "language": "tr",
          "text": "yükselmek; suyun üstüne çıkmak"
        }
      ],
      "examples": [
        {
          "baseText": "Das neue Modul ist auf der Produktivumgebung aufgelaufen und liegt jetzt in der Staging-Umgebung auf.",
          "translations": [
            {
              "language": "ar",
              "text": "ماژول جدید روی محیط عملیاتی بالا آمد و اکنون در محیط آزمایشی روی آن قرار گرفته است."
            },
            {
              "language": "ckb",
              "text": "مۆلێکی نوێ لە ژینگەی بەرەوە خستنە سەرەوە و ئێستا لە ژینگەی ستاژینگەوەدایە."
            },
            {
              "language": "en",
              "text": "The new module has been deployed and is now running in staging."
            },
            {
              "language": "fa",
              "text": "ماژول جدید در محیط عملیاتی بالا آمد و اکنون در محیط استیجینگ قرار دارد."
            },
            {
              "language": "kmr",
              "text": "Modula nû hate cihkirin û niha di cihê testê de têkildar e."
            },
            {
              "language": "pl",
              "text": "Nowy moduł został wdrożony i teraz działa w środowisku staging."
            },
            {
              "language": "ro",
              "text": "Noul modul a fost implementat și acum rulează în mediul de test."
            },
            {
              "language": "ru",
              "text": "Новый модуль развернули и теперь он работает в промежуточной среде."
            },
            {
              "language": "sq",
              "text": "Moduli i ri është shpërndarë dhe tani është në mjedisin staging."
            },
            {
              "language": "tr",
              "text": "Yeni modül üretime alındı ve şimdi staging ortamında çalışıyor."
            }
          ]
        },
        {
          "baseText": "Der Drohnenbericht ist aus der Konferenzhalle aufgetaucht und wurde sofort geteilt.",
          "translations": [
            {
              "language": "ar",
              "text": "گزارش پهپاد از سالن کنفرانس بیرون آمد و فوراً به اشتراک گذاشته شد."
            },
            {
              "language": "ckb",
              "text": "راپۆرتی درۆنە لە هۆڵی کۆنفرانسى درا و بەخێرایی هاوبەشی کرا."
            },
            {
              "language": "en",
              "text": "The drone report surfaced from the conference hall and was shared immediately."
            },
            {
              "language": "fa",
              "text": "گزارش پهپادی از سالن همایش بیرون زد و فوراً به اشتراک گذاشته شد."
            },
            {
              "language": "kmr",
              "text": "Raporê dronê ji halla civînê derket û bi lez hat parve kirin."
            },
            {
              "language": "pl",
              "text": "Raport drona wyskoczył z hali konferencyjnej i został od razu udostępniony."
            },
            {
              "language": "ro",
              "text": "Raportul dronei a apărut din sala de conferințe și a fost împărtășit imediat."
            },
            {
              "language": "ru",
              "text": "Отчет с дрона появился из конференц-зала и сразу был распространен."
            },
            {
              "language": "sq",
              "text": "Raporti i dronit doli nga salla e konferencës dhe u nda menjëherë."
            },
            {
              "language": "tr",
              "text": "Drone raporu konferans salonundan geldi ve hemen paylaşıldı."
            }
          ]
        }
      ]
    },
    {
      "word": "aufreißen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufreißen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-rei-ßen",
      "topics": [
        "work-and-jobs",
        "production-and-maintenance",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "workplace",
        "technical"
      ],
      "contextLabels": [
        "risk",
        "it"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "درب زدن؛ باز کردن به زور"
        },
        {
          "language": "ckb",
          "text": "بەهێز کردنەوە"
        },
        {
          "language": "en",
          "text": "to tear open; force open"
        },
        {
          "language": "fa",
          "text": "دربی یا چیزی را با زور باز کردن"
        },
        {
          "language": "kmr",
          "text": "şikandin bi zor"
        },
        {
          "language": "pl",
          "text": "rozciąć na siłę; otworzyć"
        },
        {
          "language": "ro",
          "text": "a deschide cu forța"
        },
        {
          "language": "ru",
          "text": "разорвать/раскрыть насильно"
        },
        {
          "language": "sq",
          "text": "ta hapësh me dhunë"
        },
        {
          "language": "tr",
          "text": "zorla yırtıp açmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Techniker musste die Leitung sicher aufreißen, um den Defekt zu finden.",
          "translations": [
            {
              "language": "ar",
              "text": "تکنسین برای پیدا کردن خطا باید لوله را ایمن جدا می‌کرد."
            },
            {
              "language": "ckb",
              "text": "تەکنیکەری سیستەم بە باشی هەریەک لە هەیەتیەوە ڕوویەکی پێچراوی گرتە."
            },
            {
              "language": "en",
              "text": "The technician had to open the line safely to locate the fault."
            },
            {
              "language": "fa",
              "text": "تکنسین برای پیدا کردن خطا باید لوله را به‌صورت ایمن گشود."
            },
            {
              "language": "kmr",
              "text": "Teknisîtek hewce bû rêzikar bi ewle bikar bîne ku xeletî bibîne."
            },
            {
              "language": "pl",
              "text": "Technik musiał bezpiecznie rozciąć przewód, aby zlokalizować usterkę."
            },
            {
              "language": "ro",
              "text": "Tehnicianul a trebuit să deschidă conducta în siguranță pentru a găsi defectul."
            },
            {
              "language": "ru",
              "text": "Технику пришлось безопасно раскрыть линию, чтобы найти неисправность."
            },
            {
              "language": "sq",
              "text": "Tekniku duhej ta hapte në mënyrë të sigurt linjën për të gjetur defektin."
            },
            {
              "language": "tr",
              "text": "Teknikçi arızayı bulmak için hattı güvenli şekilde açmak zorunda kaldı."
            }
          ]
        },
        {
          "baseText": "Wir können den Vertrag nur nach Freigabe durch die Rechtsabteilung aufreißen.",
          "translations": [
            {
              "language": "ar",
              "text": "ما تنها در صورت تأیید واحد حقوقی می‌توانیم قرارداد را باز کنیم."
            },
            {
              "language": "ckb",
              "text": "تەنها دواتر لە ڕێگەپێدانی بەشەی یاسایی توانین ڕاپۆرتەکە ئاگرینەوە."
            },
            {
              "language": "en",
              "text": "We can open the contract only after legal approval."
            },
            {
              "language": "fa",
              "text": "ما فقط پس از تایید واحد حقوقی می‌توانیم قرارداد را باز کنیم."
            },
            {
              "language": "kmr",
              "text": "Tenê piştî erêkirina beşa hukukê em dikarin peymanê vekin."
            },
            {
              "language": "pl",
              "text": "Kontrakt możemy otworzyć/zobaczyć dopiero po zatwierdzeniu przez dział prawny."
            },
            {
              "language": "ro",
              "text": "Putem deschide contractul doar după aprobarea departamentului juridic."
            },
            {
              "language": "ru",
              "text": "Мы можем раскрыть договор только после согласования с юридическим отделом."
            },
            {
              "language": "sq",
              "text": "Kontratin mund ta hapim vetëm pas miratimit nga departamenti juridik."
            },
            {
              "language": "tr",
              "text": "Sözleşmeyi sadece hukuk departmanının onayından sonra açabiliriz."
            }
          ]
