      "examples": [
        {
          "baseText": "Die Weiterbildung ist eine gute Chance, später eine bessere Stelle zu finden.",
          "translations": [
            {
              "language": "ar",
              "text": "التدريب الإضافي فرصة جيدة للعثور لاحقًا على وظيفة أفضل."
            },
            {
              "language": "ckb",
              "text": "فێربوونی زیاتر دەرفەتێکی باشە بۆ ئەوەی دواتر کارێکی باشتر بدۆزرێتەوە."
            },
            {
              "language": "en",
              "text": "The further training is a good opportunity to find a better job later."
            },
            {
              "language": "fa",
              "text": "آموزش تکمیلی فرصت خوبی است تا بعداً شغل بهتری پیدا کنید."
            },
            {
              "language": "kmr",
              "text": "Perwerdeya zêdetir derfeteke baş e ku paşê karekî baştir bibînin."
            },
            {
              "language": "pl",
              "text": "Szkolenie uzupełniające to dobra szansa na znalezienie później lepszej pracy."
            },
            {
              "language": "ro",
              "text": "Formarea suplimentară este o șansă bună de a găsi mai târziu un post mai bun."
            },
            {
              "language": "ru",
              "text": "Повышение квалификации — хороший шанс позже найти лучшую работу."
            },
            {
              "language": "sq",
              "text": "Trajnimi i mëtejshëm është një mundësi e mirë për të gjetur më vonë një punë më të mirë."
            },
            {
              "language": "tr",
              "text": "Ek eğitim daha sonra daha iyi bir iş bulmak için iyi bir fırsattır."
            }
          ]
        },
        {
          "baseText": "Wir geben dem Kunden noch eine Chance, die fehlenden Unterlagen nachzureichen.",
          "translations": [
            {
              "language": "ar",
              "text": "نعطي العميل فرصة أخرى لتقديم المستندات الناقصة."
            },
            {
              "language": "ckb",
              "text": "دەرفەتێکی تر بە کڕیارەکە دەدەین بۆ پێشکەشکردنی بەڵگەنامە کەمەکان."
            },
            {
              "language": "en",
              "text": "We give the customer another chance to submit the missing documents."
            },
            {
              "language": "fa",
              "text": "به مشتری یک فرصت دیگر می‌دهیم تا مدارک ناقص را ارائه کند."
            },
            {
              "language": "kmr",
              "text": "Em derfetek din didin xerîdar ku belgeyên kêm radest bike."
            },
            {
              "language": "pl",
              "text": "Dajemy klientowi jeszcze jedną szansę na dosłanie brakujących dokumentów."
            },
            {
              "language": "ro",
              "text": "Îi mai dăm clientului o șansă să trimită documentele lipsă."
            },
            {
              "language": "ru",
              "text": "Мы даем клиенту еще один шанс предоставить недостающие документы."
            },
            {
              "language": "sq",
              "text": "I japim klientit edhe një mundësi për të dorëzuar dokumentet që mungojnë."
            },
            {
              "language": "tr",
              "text": "Müşteriye eksik belgeleri tamamlaması için bir şans daha veriyoruz."
            }
          ]
        }
      ]
    }
