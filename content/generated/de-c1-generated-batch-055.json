        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes something that guides action"
      ],
      "collocations": [
        {
          "text": "handlungsleitende Prinzipien",
          "meaning": "principles guiding action"
        },
        {
          "text": "handlungsleitend sein",
          "meaning": "to guide action"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "handeln",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "leiten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موجّه للفعل؛ يرشد التصرف"
        },
        {
          "language": "ckb",
          "text": "ڕێبەری کردار؛ کردار ئاراستە دەکات"
        },
        {
          "language": "en",
          "text": "action-guiding; guiding behavior"
        },
        {
          "language": "fa",
          "text": "راهنمای عمل؛ جهت‌دهنده به کنش"
        },
        {
          "language": "kmr",
          "text": "rêberê kiryarê"
        },
        {
          "language": "pl",
          "text": "ukierunkowujący działanie"
        },
        {
          "language": "ro",
          "text": "care ghidează acțiunea"
        },
        {
          "language": "ru",
          "text": "направляющий действие"
        },
        {
          "language": "sq",
          "text": "udhëheqës për veprim"
        },
        {
          "language": "tr",
          "text": "eyleme yön veren"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Führungskräfte sollen drei handlungsleitende Prinzipien formuliert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي صياغة ثلاثة مبادئ موجهة للعمل للمديرين."
            },
            {
              "language": "ckb",
              "text": "بۆ بەڕێوەبەرەکان دەبێت سێ بنەمای ڕێبەری کردار داڕێژرێت."
            },
            {
              "language": "en",
              "text": "Three action-guiding principles are to be formulated for managers."
            },
            {
              "language": "fa",
