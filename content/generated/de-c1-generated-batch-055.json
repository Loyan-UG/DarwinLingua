  "entries": [
    {
      "word": "die Handlungsebene",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Handlungsebenen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Hand-lungs-e-be-ne",
      "topics": [
        "management-and-leadership",
        "planning-and-projects",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "business",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Handlungsebenen"
      ],
      "collocations": [
        {
          "text": "auf der operativen Handlungsebene",
          "meaning": "on the operational level of action"
        },
        {
          "text": "mehrere Handlungsebenen unterscheiden",
          "meaning": "to distinguish several levels of action"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "handeln",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Ebene",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مستوى العمل أو الفعل"
        },
        {
          "language": "ckb",
          "text": "ئاستی کردار؛ ئاستی جێبەجێکردن"
        },
        {
          "language": "en",
          "text": "level of action; operational level"
        },
        {
          "language": "fa",
          "text": "سطح اقدام؛ سطح کنش"
        },
        {
          "language": "kmr",
          "text": "asta kiryarê; asta xebatê"
        },
        {
          "language": "pl",
          "text": "poziom działania"
        },
        {
          "language": "ro",
          "text": "nivel de acțiune"
        },
        {
          "language": "ru",
          "text": "уровень действия"
        },
        {
          "language": "sq",
          "text": "nivel veprimi"
        },
        {
          "language": "tr",
          "text": "eylem düzeyi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Strategie bleibt abstrakt, solange keine konkrete Handlungsebene benannt wird.",
          "translations": [
            {
              "language": "ar",
              "text": "تبقى الاستراتيجية مجردة ما دام لم يُذكر مستوى عمل ملموس."
            },
            {
              "language": "ckb",
              "text": "ستراتیژییەکە ئەبستراکت دەمێنێتەوە تا ئاستێکی کرداری دیاریکراو ناونەبرێت."
            },
            {
              "language": "en",
              "text": "The strategy remains abstract as long as no concrete level of action is named."
            },
            {
              "language": "fa",
              "text": "استراتژی تا زمانی که سطح اقدام مشخصی نام برده نشود، انتزاعی می‌ماند."
            },
            {
              "language": "kmr",
              "text": "Stratejî razber dimîne heta ku asta kiryareke konkret neyê navkirin."
            },
            {
              "language": "pl",
              "text": "Strategia pozostaje abstrakcyjna, dopóki nie zostanie wskazany konkretny poziom działania."
            },
            {
              "language": "ro",
              "text": "Strategia rămâne abstractă cât timp nu este numit un nivel concret de acțiune."
            },
            {
              "language": "ru",
              "text": "Стратегия остается абстрактной, пока не назван конкретный уровень действия."
            },
            {
              "language": "sq",
              "text": "Strategjia mbetet abstrakte për sa kohë nuk përmendet një nivel konkret veprimi."
            },
            {
              "language": "tr",
              "text": "Somut bir eylem düzeyi belirtilmediği sürece strateji soyut kalır."
            }
          ]
        },
        {
          "baseText": "Auf der technischen Handlungsebene müssen zuerst die Schnittstellen stabilisiert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "على مستوى العمل التقني يجب أولًا تثبيت الواجهات."
            },
            {
              "language": "ckb",
              "text": "لە ئاستی کرداری تەکنیکیدا دەبێت سەرەتا ڕووکاره‌کان جێگیر بکرێن."
            },
            {
              "language": "en",
              "text": "At the technical level of action, the interfaces must be stabilized first."
            },
            {
              "language": "fa",
              "text": "در سطح اقدام فنی، ابتدا باید رابط‌ها پایدار شوند."
            },
            {
              "language": "kmr",
              "text": "Li asta kiryara teknîkî divê pêşî navrû bêne stabîlkirin."
            },
            {
              "language": "pl",
              "text": "Na technicznym poziomie działania trzeba najpierw ustabilizować interfejsy."
            },
            {
              "language": "ro",
              "text": "La nivelul tehnic de acțiune trebuie stabilizate mai întâi interfețele."
            },
            {
              "language": "ru",
              "text": "На техническом уровне действия сначала нужно стабилизировать интерфейсы."
            },
            {
              "language": "sq",
              "text": "Në nivelin teknik të veprimit, së pari duhet të stabilizohen ndërfaqet."
            },
            {
              "language": "tr",
              "text": "Teknik eylem düzeyinde önce arayüzler istikrara kavuşturulmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Handlungsfähigkeit",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Handlungsfähigkeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Hand-lungs-fä-hig-keit",
      "topics": [
        "management-and-leadership",
        "quality-and-risk",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "business",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine abstract noun; plural rare"
      ],
      "collocations": [
        {
          "text": "Handlungsfähigkeit sichern",
          "meaning": "to ensure ability to act"
        },
        {
          "text": "politische Handlungsfähigkeit",
          "meaning": "political capacity to act"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "handlungsfähig",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "handeln",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "القدرة على التصرف؛ قابلية اتخاذ إجراء"
        },
        {
          "language": "ckb",
          "text": "توانای کردار؛ توانای هەنگاو نان"
        },
        {
          "language": "en",
          "text": "capacity to act; ability to take action"
        },
        {
          "language": "fa",
          "text": "توان اقدام؛ قابلیت عمل"
        },
        {
          "language": "kmr",
          "text": "şiyana kiryarê"
        },
        {
          "language": "pl",
          "text": "zdolność do działania"
        },
        {
          "language": "ro",
          "text": "capacitate de acțiune"
        },
        {
          "language": "ru",
          "text": "дееспособность; способность действовать"
        },
        {
          "language": "sq",
          "text": "aftësi veprimi"
        },
        {
          "language": "tr",
          "text": "hareket edebilme kapasitesi"
        }
      ],
      "examples": [
        {
          "baseText": "Ein klarer Notfallplan sichert die Handlungsfähigkeit des Teams bei Systemausfällen.",
          "translations": [
            {
              "language": "ar",
              "text": "تضمن خطة طوارئ واضحة قدرة الفريق على التصرف عند تعطل الأنظمة."
            },
            {
              "language": "ckb",
              "text": "پلانی فریاکەوتنی ڕوون توانای کرداری تیم لە کاتی لەکارکەوتنی سیستەمەکاندا دەپارێزێت."
            },
            {
              "language": "en",
              "text": "A clear emergency plan ensures the team’s ability to act during system outages."
            },
            {
              "language": "fa",
              "text": "یک برنامه اضطراری روشن توان اقدام تیم را هنگام خرابی سیستم‌ها تضمین می‌کند."
            },
            {
              "language": "kmr",
              "text": "Planeke lezgîn a zelal şiyana kiryara tîmê di têkçûna pergalan de diparêze."
            },
            {
              "language": "pl",
              "text": "Jasny plan awaryjny zabezpiecza zdolność zespołu do działania przy awariach systemów."
            },
            {
              "language": "ro",
              "text": "Un plan de urgență clar asigură capacitatea echipei de acțiune în cazul căderilor de sistem."
            },
            {
              "language": "ru",
              "text": "Четкий аварийный план обеспечивает способность команды действовать при сбоях систем."
            },
            {
              "language": "sq",
              "text": "Një plan i qartë emergjence siguron aftësinë e ekipit për të vepruar gjatë ndërprerjeve të sistemeve."
            },
            {
              "language": "tr",
              "text": "Net bir acil durum planı sistem kesintilerinde ekibin hareket edebilme kapasitesini güvence altına alır."
            }
          ]
        },
        {
          "baseText": "Ohne verlässliche Mehrheiten verliert die Regierung schnell ihre Handlungsfähigkeit.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون أغلبيات موثوقة تفقد الحكومة بسرعة قدرتها على التصرف."
            },
            {
              "language": "ckb",
              "text": "بێ زۆرینەی پشتپێبەستوو حکومەت زوو توانای کرداری خۆی لەدەست دەدات."
            },
            {
              "language": "en",
              "text": "Without reliable majorities, the government quickly loses its ability to act."
            },
            {
              "language": "fa",
              "text": "بدون اکثریت‌های قابل اتکا، دولت سریع توان اقدام خود را از دست می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Bê piraniya pêbawer, hikûmet zû şiyana kiryarê ji dest dide."
            },
            {
              "language": "pl",
              "text": "Bez stabilnych większości rząd szybko traci zdolność do działania."
            },
            {
              "language": "ro",
              "text": "Fără majorități fiabile, guvernul își pierde rapid capacitatea de acțiune."
            },
            {
              "language": "ru",
              "text": "Без надежного большинства правительство быстро теряет способность действовать."
            },
            {
              "language": "sq",
              "text": "Pa shumica të besueshme, qeveria e humb shpejt aftësinë për të vepruar."
            },
            {
              "language": "tr",
              "text": "Güvenilir çoğunluklar olmadan hükümet hızla hareket kabiliyetini kaybeder."
            }
          ]
        }
      ]
    },
    {
      "word": "handlungsleitend",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
