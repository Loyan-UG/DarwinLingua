      "examples": [
        {
          "baseText": "Ich esse jeden Tag Obst.",
          "translations": [
            {
              "language": "ar",
              "text": "آكل الفاكهة كل يوم."
            },
            {
              "language": "ckb",
              "text": "هەموو ڕۆژێک میوە دەخۆم."
            },
            {
              "language": "en",
              "text": "I eat fruit every day."
            },
            {
              "language": "fa",
              "text": "من هر روز میوه می‌خورم."
            },
            {
              "language": "kmr",
              "text": "Ez her roj fêkî dixwim."
            },
            {
              "language": "pl",
              "text": "Codziennie jem owoce."
            },
            {
              "language": "ro",
              "text": "Mănânc fructe în fiecare zi."
            },
            {
              "language": "ru",
              "text": "Я ем фрукты каждый день."
            },
            {
              "language": "sq",
              "text": "Unë ha fruta çdo ditë."
            },
            {
              "language": "tr",
              "text": "Her gün meyve yerim."
            }
          ]
        },
        {
          "baseText": "Haben Sie frisches Obst?",
          "translations": [
            {
              "language": "ar",
              "text": "هل لديكم فاكهة طازجة؟"
            },
            {
              "language": "ckb",
              "text": "ئایا میوەی تازەتان هەیە؟"
            },
            {
              "language": "en",
              "text": "Do you have fresh fruit?"
            },
            {
              "language": "fa",
              "text": "آیا میوه تازه دارید؟"
            },
            {
              "language": "kmr",
              "text": "Fêkiyên fres hene ba we?"
            },
            {
              "language": "pl",
              "text": "Czy mają państwo świeże owoce?"
            },
            {
              "language": "ro",
              "text": "Aveți fructe proaspete?"
            },
            {
              "language": "ru",
              "text": "У вас есть свежие фрукты?"
            },
            {
              "language": "sq",
              "text": "A keni fruta të freskëta?"
            },
            {
              "language": "tr",
              "text": "Taze meyveniz var mı?"
            }
          ]
        }
      ]
