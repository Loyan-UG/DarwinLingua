            {
              "language": "en",
              "text": "I am waiting downstairs by the door."
            },
            {
              "language": "fa",
              "text": "پایین جلوی در منتظرم."
            },
            {
              "language": "kmr",
              "text": "Ez li jêr li ber derî li bendê me."
            },
            {
              "language": "pl",
              "text": "Czekam na dole przy drzwiach."
