      "word": "durchlaufen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "durchlaufen",
      "syllableBreak": "durch-lau-fen",
      "topics": [
        "planning-and-projects",
        "work-and-jobs",
        "technology-and-it"
      ],
      "usageLabels": [
        "business",
        "formal",
        "process"
      ],
      "contextLabels": [
        "management",
        "software"
      ],
      "grammarNotes": [
        "separable verb in many concrete uses; in business often means to pass through a process"
      ],
      "collocations": [
        {
          "text": "einen Prozess durchlaufen",
          "meaning": "to go through a process"
        },
        {
          "text": "mehrere Phasen durchlaufen",
          "meaning": "to go through several phases"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "laufen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يمر بعملية؛ يجتاز مراحل"
        },
        {
          "language": "ckb",
          "text": "پرۆسەیەک تێدەپەڕێنێت؛ چەند قۆناغ تێدەپەڕێت"
        },
        {
          "language": "en",
          "text": "to go through; to pass through a process"
        },
        {
          "language": "fa",
          "text": "طی کردن؛ گذراندن یک فرایند"
        },
        {
          "language": "kmr",
          "text": "pêvajoyek derbas kirin"
        },
        {
          "language": "pl",
          "text": "przejść przez; przejść proces"
        },
        {
          "language": "ro",
          "text": "a parcurge; a trece printr-un proces"
        },
        {
          "language": "ru",
          "text": "проходить; пройти процесс"
        },
        {
          "language": "sq",
          "text": "të kalosh nëpër; të përshkosh një proces"
        },
        {
          "language": "tr",
          "text": "bir süreçten geçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Jede Bestellung durchläuft im ERP-System automatisch mehrere Prüfschritte.",
          "translations": [
            {
              "language": "ar",
              "text": "يمر كل طلب في نظام ERP تلقائيًا بعدة خطوات فحص."
            },
            {
              "language": "ckb",
              "text": "هەر داواکارییەک لە سیستەمی ERP بە شێوەی ئۆتۆماتیکی چەند هەنگاوی پشکنین تێدەپەڕێنێت."
            },
            {
              "language": "en",
              "text": "Every order automatically goes through several approval steps in the ERP system."
            },
            {
              "language": "fa",
              "text": "هر سفارش در سیستم ERP به‌صورت خودکار چند مرحله بررسی را طی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Her ferman di pergala ERP de bi xweber çend gavên kontrolê derbas dike."
            },
            {
              "language": "pl",
              "text": "Każde zamówienie automatycznie przechodzi w systemie ERP przez kilka kroków kontroli."
            },
            {
              "language": "ro",
              "text": "Fiecare comandă parcurge automat mai mulți pași de verificare în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Каждый заказ автоматически проходит в ERP-системе несколько этапов проверки."
            },
            {
              "language": "sq",
              "text": "Çdo porosi kalon automatikisht në disa hapa kontrolli në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Her sipariş ERP sisteminde otomatik olarak birkaç kontrol adımından geçer."
            }
          ]
        },
        {
          "baseText": "Neue Mitarbeitende durchlaufen in den ersten Wochen ein festes Einarbeitungsprogramm.",
          "translations": [
            {
              "language": "ar",
              "text": "يمر الموظفون الجدد في الأسابيع الأولى ببرنامج تأهيل ثابت."
            },
            {
              "language": "ckb",
              "text": "کارمەندانی نوێ لە هەفتەکانی یەکەمدا بەرنامەیەکی دیاریکراوی ڕاهێنان تێدەپەڕێنن."
            },
            {
              "language": "en",
              "text": "New employees go through a fixed onboarding program in the first few weeks."
            },
            {
              "language": "fa",
              "text": "کارکنان جدید در هفته‌های اول یک برنامه مشخص آشنایی با کار را طی می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Karmendên nû di hefteyên yekem de bernameyeke sabît a destpêkirinê derbas dikin."
            },
            {
              "language": "pl",
              "text": "Nowi pracownicy w pierwszych tygodniach przechodzą stały program wdrożeniowy."
            },
            {
              "language": "ro",
              "text": "Noii angajați parcurg în primele săptămâni un program fix de integrare."
            },
            {
              "language": "ru",
              "text": "Новые сотрудники в первые недели проходят фиксированную программу адаптации."
            },
            {
              "language": "sq",
              "text": "Punonjësit e rinj kalojnë në javët e para një program të caktuar integrimi."
            },
            {
              "language": "tr",
              "text": "Yeni çalışanlar ilk haftalarda sabit bir işe alışma programından geçer."
            }
          ]
        }
      ]
    }
  ],
