  "entries": [
    {
      "word": "die Lieferung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Lieferungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Lie-fe-rung",
      "topics": [
        "warehouse-and-logistics",
        "customer-service",
        "procurement-and-suppliers"
      ],
      "usageLabels": [
        "business",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; delivery or shipment of goods"
      ],
      "collocations": [
        {
          "text": "eine Lieferung verfolgen",
          "meaning": "to track a delivery"
        },
        {
          "text": "eine Lieferung erhalten",
          "meaning": "to receive a delivery"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "liefern",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Lieferant",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تسليم؛ شحنة"
        },
        {
          "language": "ckb",
          "text": "گەیاندن؛ بار"
        },
        {
          "language": "en",
          "text": "delivery; shipment"
        },
        {
          "language": "fa",
          "text": "تحویل؛ ارسال کالا"
        },
        {
          "language": "kmr",
          "text": "radestkirin; şandin"
        },
        {
          "language": "pl",
          "text": "dostawa; przesyłka"
        },
        {
          "language": "ro",
          "text": "livrare; expediere"
        },
        {
          "language": "ru",
          "text": "доставка; поставка"
        },
        {
          "language": "sq",
          "text": "dorëzim; dërgesë"
        },
        {
          "language": "tr",
          "text": "teslimat; sevkiyat"
        }
      ],
      "examples": [
        {
          "baseText": "Die Lieferung der neuen Monitore kommt voraussichtlich am Donnerstag.",
          "translations": [
            {
              "language": "ar",
              "text": "من المتوقع أن تصل شحنة الشاشات الجديدة يوم الخميس."
            },
            {
              "language": "ckb",
              "text": "گەیاندنی مۆنیتەرە نوێیەکان بە پێی پێشبینی پێنجشەممە دەگات."
            },
            {
              "language": "en",
              "text": "The delivery of the new monitors is expected on Thursday."
            },
            {
              "language": "fa",
              "text": "تحویل مانیتورهای جدید احتمالاً پنجشنبه می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Radestkirina monitorên nû li gor texmînê roja pêncşemê tê."
            },
            {
              "language": "pl",
              "text": "Dostawa nowych monitorów ma przyjść w czwartek."
            },
            {
              "language": "ro",
              "text": "Livrarea noilor monitoare este așteptată joi."
            },
            {
              "language": "ru",
              "text": "Доставка новых мониторов ожидается в четверг."
            },
            {
              "language": "sq",
              "text": "Dorëzimi i monitorëve të rinj pritet të enjten."
            },
            {
              "language": "tr",
              "text": "Yeni monitörlerin teslimatının perşembe günü gelmesi bekleniyor."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie die Lieferung sofort, wenn das Paket ankommt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى فحص التسليم فور وصول الطرد."
            },
            {
              "language": "ckb",
              "text": "تکایە کاتێک پاکەتەکە دەگات، گەیاندنەکە دەستبەجێ بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the delivery immediately when the package arrives."
            },
            {
              "language": "fa",
              "text": "لطفاً وقتی بسته رسید، تحویل را فوراً بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe dema pakêt bigihîje, radestkirinê tavilê kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić dostawę od razu po przyjściu paczki."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați livrarea imediat ce ajunge coletul."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте доставку сразу, когда придёт посылка."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni dorëzimin menjëherë kur të arrijë pakoja."
            },
            {
              "language": "tr",
              "text": "Paket geldiğinde lütfen teslimatı hemen kontrol edin."
            }
          ]
        }
      ]
    },
    {
      "word": "logisch",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "lo-gisch",
      "topics": [
        "business-communication",
        "education-and-training",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective/adverb; means logical or reasonable"
      ],
      "collocations": [
        {
          "text": "logisch klingen",
          "meaning": "to sound logical"
        },
        {
          "text": "eine logische Erklärung",
          "meaning": "a logical explanation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Logik",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "منطقي"
        },
        {
          "language": "ckb",
          "text": "لۆژیکی؛ ژیرانە"
        },
        {
          "language": "en",
          "text": "logical; reasonable"
        },
        {
          "language": "fa",
          "text": "منطقی"
        },
        {
          "language": "kmr",
          "text": "lojîkî; maqûl"
        },
        {
          "language": "pl",
          "text": "logiczny; rozsądny"
        },
        {
          "language": "ro",
          "text": "logic; rezonabil"
        },
        {
          "language": "ru",
          "text": "логичный; разумный"
        },
        {
          "language": "sq",
          "text": "logjik; i arsyeshëm"
        },
        {
          "language": "tr",
          "text": "mantıklı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Erklärung des Entwicklers klingt logisch, aber wir testen den Fehler trotzdem.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدو توضيحات المطور منطقية، لكننا سنختبر الخطأ رغم ذلك."
            },
            {
              "language": "ckb",
              "text": "ڕوونکردنەوەی پەرەپێدەرەکە لۆژیکی دەنگ دەدات، بەڵام هەرچۆنێک بێت هەڵەکە تاقی دەکەینەوە."
            },
            {
              "language": "en",
              "text": "The developer’s explanation sounds logical, but we will test the bug anyway."
            },
            {
              "language": "fa",
              "text": "توضیح توسعه‌دهنده منطقی به نظر می‌رسد، اما با این حال خطا را تست می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Ravekirina pêşdebir lojîkî xuya dike, lê em dîsa jî şaşitiyê test dikin."
            },
            {
              "language": "pl",
              "text": "Wyjaśnienie programisty brzmi logicznie, ale mimo to przetestujemy błąd."
            },
            {
              "language": "ro",
              "text": "Explicația dezvoltatorului sună logic, dar vom testa totuși eroarea."
            },
            {
              "language": "ru",
              "text": "Объяснение разработчика звучит логично, но мы всё равно протестируем ошибку."
            },
            {
              "language": "sq",
              "text": "Shpjegimi i zhvilluesit tingëllon logjik, por prapë do ta testojmë gabimin."
            },
            {
              "language": "tr",
              "text": "Geliştiricinin açıklaması mantıklı geliyor, ama yine de hatayı test edeceğiz."
            }
          ]
        },
        {
          "baseText": "Es ist logisch, dass man bei Regen mehr Zeit für den Weg braucht.",
          "translations": [
            {
              "language": "ar",
              "text": "من المنطقي أن يحتاج المرء وقتاً أطول للطريق عند المطر."
            },
            {
              "language": "ckb",
              "text": "لۆژیکییە کە لە کاتی باراندا کەس پێویستی بە کاتی زیاتر بۆ ڕێگا هەیە."
            },
            {
              "language": "en",
              "text": "It is logical that you need more time for the route when it rains."
            },
            {
              "language": "fa",
              "text": "منطقی است که هنگام باران برای مسیر به زمان بیشتری نیاز داشته باشیم."
            },
            {
              "language": "kmr",
              "text": "Lojîkî ye ku dema baranê mirov ji bo rê demeke zêdetir hewce dike."
            },
            {
              "language": "pl",
              "text": "To logiczne, że podczas deszczu potrzeba więcej czasu na drogę."
            },
            {
              "language": "ro",
              "text": "Este logic că pe ploaie ai nevoie de mai mult timp pentru drum."
            },
            {
              "language": "ru",
              "text": "Логично, что в дождь нужно больше времени на дорогу."
            },
            {
              "language": "sq",
              "text": "Është logjike që kur bie shi të duhet më shumë kohë për rrugën."
            },
            {
              "language": "tr",
              "text": "Yağmurda yol için daha fazla zamana ihtiyaç duyulması mantıklıdır."
            }
          ]
        }
      ]
    },
