    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "das Lieferdatum",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Lieferdaten",
      "infinitive": null,
      "syllableBreak": "Lie-fer-da-tum",
      "topics": [
        "procurement-and-suppliers",
        "warehouse-and-logistics",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "written"
      ],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "das Lieferdatum ändern",
          "meaning": "to change the delivery date"
        },
        {
          "text": "ein neues Lieferdatum bestätigen",
          "meaning": "to confirm a new delivery date"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "liefern",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Lieferung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تاريخ التسليم"
        },
        {
          "language": "ckb",
          "text": "بەرواری گەیاندن"
        },
        {
          "language": "en",
          "text": "delivery date"
        },
        {
          "language": "fa",
          "text": "تاریخ تحویل"
        },
        {
          "language": "kmr",
          "text": "dîroka radestkirinê"
        },
        {
          "language": "pl",
          "text": "data dostawy"
        },
        {
          "language": "ro",
          "text": "dată de livrare"
        },
        {
          "language": "ru",
          "text": "дата поставки"
        },
        {
          "language": "sq",
          "text": "datë dorëzimi"
        },
        {
          "language": "tr",
          "text": "teslimat tarihi"
        }
      ],
      "examples": [
        {
          "baseText": "Das Lieferdatum wurde im ERP-System auf Freitag geändert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تغيير تاريخ التسليم في نظام تخطيط موارد المؤسسة إلى يوم الجمعة."
            },
            {
              "language": "ckb",
              "text": "بەرواری گەیاندنەکە لە سیستەمی ERPدا بۆ هەینی گۆڕدرا."
            },
            {
              "language": "en",
              "text": "The delivery date was changed to Friday in the ERP system."
            },
            {
              "language": "fa",
              "text": "تاریخ تحویل در سیستم ERP به جمعه تغییر داده شد."
            },
            {
              "language": "kmr",
              "text": "Dîroka radestkirinê di pergala ERP de bo Înê hate guhertin."
            },
            {
              "language": "pl",
              "text": "Data dostawy została zmieniona w systemie ERP na piątek."
            },
            {
              "language": "ro",
              "text": "Data de livrare a fost schimbată în sistemul ERP pentru vineri."
            },
            {
              "language": "ru",
              "text": "Дата поставки в ERP-системе была изменена на пятницу."
            },
            {
              "language": "sq",
              "text": "Data e dorëzimit u ndryshua në sistemin ERP për të premten."
            },
            {
              "language": "tr",
              "text": "Teslimat tarihi ERP sisteminde cuma olarak değiştirildi."
            }
          ]
        },
        {
          "baseText": "Können Sie uns das genaue Lieferdatum bitte bestätigen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم تأكيد تاريخ التسليم الدقيق لنا من فضلكم؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن تکایە بەرواری وردی گەیاندنمان بۆ پشتڕاست بکەنەوە؟"
            },
            {
              "language": "en",
              "text": "Could you please confirm the exact delivery date for us?"
            },
            {
              "language": "fa",
              "text": "ممکن است لطفاً تاریخ دقیق تحویل را برای ما تأیید کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji kerema xwe dîroka rast ya radestkirinê ji me re piştrast bikin?"
            },
            {
              "language": "pl",
              "text": "Czy mogą Państwo potwierdzić nam dokładną datę dostawy?"
            },
            {
              "language": "ro",
              "text": "Ne puteți confirma, vă rugăm, data exactă de livrare?"
            },
            {
              "language": "ru",
              "text": "Можете, пожалуйста, подтвердить нам точную дату поставки?"
            },
            {
              "language": "sq",
              "text": "A mund të na konfirmoni datën e saktë të dorëzimit?"
            },
            {
              "language": "tr",
              "text": "Bize kesin teslimat tarihini onaylayabilir misiniz?"
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "der Mandant",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Mandanten",
      "infinitive": null,
      "syllableBreak": "Man-dant",
      "topics": [
        "erp-and-business-systems",
        "law-and-compliance",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "technical",
        "administrative"
      ],
      "grammarNotes": [
        "masculine noun; in IT/ERP often means client or tenant"
      ],
      "collocations": [
        {
          "text": "einen Mandanten auswählen",
          "meaning": "to select a tenant/client"
        },
        {
          "text": "im richtigen Mandanten arbeiten",
          "meaning": "to work in the correct tenant"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "mandantenfähig",
          "relationLabel": "adjective",
          "note": "multi-tenant capable"
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "عميل؛ مستأجر نظام"
        },
        {
          "language": "ckb",
          "text": "موەککیل؛ کرێگری سیستەم"
        },
        {
          "language": "en",
          "text": "client; tenant"
        },
        {
          "language": "fa",
          "text": "موکل؛ tenant در سیستم"
        },
        {
          "language": "kmr",
          "text": "muwekîl; kirêdarê pergalê"
        },
        {
          "language": "pl",
          "text": "klient; tenant"
        },
        {
          "language": "ro",
          "text": "client; tenant"
        },
        {
          "language": "ru",
          "text": "клиент; мандант; тенант"
        },
        {
          "language": "sq",
          "text": "klient; tenant"
        },
        {
          "language": "tr",
          "text": "müşteri; tenant"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte wählen Sie im ERP-System den richtigen Mandanten aus.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى اختيار العميل الصحيح في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "تکایە لە سیستەمی ERPدا مانداەنتی دروست هەڵبژێرن."
            },
            {
              "language": "en",
              "text": "Please select the correct tenant in the ERP system."
            },
            {
              "language": "fa",
              "text": "لطفاً در سیستم ERP tenant درست را انتخاب کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe di pergala ERP de kirêdarê rast hilbijêrin."
            },
            {
              "language": "pl",
              "text": "Proszę wybrać właściwego klienta w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să selectați tenantul corect în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, выберите правильный мандант в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Ju lutemi zgjidhni tenantin e saktë në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Lütfen ERP sisteminde doğru tenantı seçin."
            }
          ]
        },
        {
          "baseText": "Der Mandant hat die Unterlagen heute per E-Mail geschickt.",
          "translations": [
            {
              "language": "ar",
              "text": "أرسل العميل المستندات اليوم عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "موەککیلەکە ئەمڕۆ بەڵگەنامەکانی بە ئیمەیڵ نارد."
            },
            {
              "language": "en",
              "text": "The client sent the documents by email today."
            },
            {
              "language": "fa",
              "text": "موکل امروز مدارک را با ایمیل فرستاد."
            },
            {
              "language": "kmr",
              "text": "Muwekîl îro belge bi e-nameyê şand."
            },
            {
              "language": "pl",
              "text": "Klient wysłał dziś dokumenty e-mailem."
            },
            {
              "language": "ro",
              "text": "Clientul a trimis astăzi documentele prin e-mail."
            },
            {
              "language": "ru",
              "text": "Клиент сегодня отправил документы по электронной почте."
            },
            {
              "language": "sq",
              "text": "Klienti i dërgoi dokumentet sot me email."
            },
            {
              "language": "tr",
              "text": "Müvekkil belgeleri bugün e-posta ile gönderdi."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
