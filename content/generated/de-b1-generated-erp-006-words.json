      "word": "der Mangel",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Mängel",
      "infinitive": null,
      "syllableBreak": "Man-gel",
      "topics": [
        "quality-and-risk",
        "customer-service",
        "warehouse-and-logistics"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written"
      ],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "einen Mangel melden",
          "meaning": "to report a defect"
        },
        {
          "text": "einen Mangel beheben",
          "meaning": "to fix a defect"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "mangelhaft",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "عيب؛ نقص"
        },
        {
          "language": "ckb",
          "text": "کەم و کوڕی؛ عەیب"
        },
        {
          "language": "en",
          "text": "defect; shortage"
        },
        {
          "language": "fa",
          "text": "نقص؛ ایراد"
        },
        {
          "language": "kmr",
          "text": "kêmasî; qüsûr"
        },
        {
          "language": "pl",
          "text": "brak; wada"
        },
        {
          "language": "ro",
          "text": "defect; lipsă"
        },
        {
          "language": "ru",
          "text": "недостаток; дефект"
        },
        {
          "language": "sq",
          "text": "mangësi; defekt"
        },
        {
          "language": "tr",
          "text": "eksik; kusur"
        }
      ],
      "examples": [
        {
          "baseText": "Der Mangel an der Lieferung wurde im ERP-System dokumentiert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم توثيق العيب في التسليم في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "کەم و کوڕییەکەی گەیاندنەکە لە سیستەمی ERPدا تۆمار کرا."
            },
            {
              "language": "en",
              "text": "The defect in the delivery was documented in the ERP system."
            },
            {
              "language": "fa",
              "text": "ایراد موجود در تحویل در سیستم ERP ثبت شد."
            },
            {
              "language": "kmr",
              "text": "Kêmasiya di radestkirinê de di pergala ERP de hate belgekirin."
            },
            {
              "language": "pl",
              "text": "Wada w dostawie została udokumentowana w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Defectul livrării a fost documentat în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Дефект в поставке был задокументирован в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Defekti në dërgesë u dokumentua në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Teslimattaki kusur ERP sisteminde belgelendi."
            }
          ]
        },
        {
          "baseText": "Bitte melden Sie jeden Mangel sofort beim Kundenservice.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إبلاغ خدمة العملاء فورًا عن أي عيب."
            },
            {
              "language": "ckb",
              "text": "تکایە هەر کەم و کوڕییەک دەستبەجێ بە خزمەتگوزاری کڕیار ڕابگەیەنن."
            },
            {
              "language": "en",
              "text": "Please report every defect to customer service immediately."
            },
            {
              "language": "fa",
              "text": "لطفاً هر ایرادی را فوراً به خدمات مشتریان گزارش دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe her kêmasiyekê tavilê ji xizmeta xerîdar re ragihînin."
            },
            {
              "language": "pl",
              "text": "Proszę natychmiast zgłaszać każdą wadę do obsługi klienta."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să raportați imediat orice defect la serviciul clienți."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, немедленно сообщайте о каждом дефекте в службу поддержки клиентов."
            },
            {
              "language": "sq",
              "text": "Ju lutemi raportoni çdo defekt menjëherë te shërbimi ndaj klientit."
            },
            {
              "language": "tr",
              "text": "Lütfen her kusuru hemen müşteri hizmetlerine bildirin."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
