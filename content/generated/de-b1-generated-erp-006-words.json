      "word": "das Merkmal",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Merkmale",
      "infinitive": null,
      "syllableBreak": "Merk-mal",
      "topics": [
        "data-and-reporting",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "ein Merkmal pflegen",
          "meaning": "to maintain an attribute"
        },
        {
          "text": "ein wichtiges Merkmal",
          "meaning": "an important feature"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "merken",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "خاصية؛ ميزة"
        },
        {
          "language": "ckb",
          "text": "تایبەتمەندی"
        },
        {
          "language": "en",
          "text": "feature; attribute"
        },
        {
          "language": "fa",
          "text": "ویژگی؛ مشخصه"
        },
        {
          "language": "kmr",
          "text": "taybetmendî"
        },
        {
          "language": "pl",
          "text": "cecha; atrybut"
        },
        {
          "language": "ro",
          "text": "caracteristică; atribut"
        },
        {
          "language": "ru",
          "text": "признак; характеристика"
        },
        {
          "language": "sq",
          "text": "veçori; atribut"
        },
        {
          "language": "tr",
          "text": "özellik; nitelik"
        }
      ],
      "examples": [
        {
          "baseText": "Dieses Merkmal muss im Artikelstamm des ERP-Systems gepflegt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب تحديث هذه الخاصية في بيانات الصنف الأساسية في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "ئەم تایبەتمەندییە پێویستە لە زانیاریی سەرەکی کاڵا لە سیستەمی ERPدا پارێزراو بێت."
            },
            {
              "language": "en",
              "text": "This attribute must be maintained in the item master data of the ERP system."
            },
            {
              "language": "fa",
              "text": "این ویژگی باید در اطلاعات پایه کالا در سیستم ERP ثبت و نگهداری شود."
            },
            {
              "language": "kmr",
              "text": "Ev taybetmendî divê di daneyên bingehîn ên tiştê di pergala ERP de were parastin."
            },
            {
              "language": "pl",
              "text": "Tę cechę trzeba utrzymywać w danych podstawowych artykułu w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Această caracteristică trebuie întreținută în datele de bază ale articolului din sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Этот признак нужно вести в основных данных товара в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Kjo veçori duhet të mbahet në të dhënat bazë të artikullit në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Bu özellik ERP sistemindeki ürün ana verilerinde tutulmalıdır."
            }
          ]
        },
        {
          "baseText": "Ein wichtiges Merkmal des Produkts ist das geringe Gewicht.",
          "translations": [
            {
              "language": "ar",
              "text": "ميزة مهمة في المنتج هي الوزن المنخفض."
            },
            {
              "language": "ckb",
              "text": "تایبەتمەندییەکی گرنگی بەرهەمەکە کێشی کەمە."
            },
            {
              "language": "en",
              "text": "An important feature of the product is its low weight."
            },
            {
              "language": "fa",
              "text": "یکی از ویژگی‌های مهم محصول وزن کم آن است."
            },
            {
              "language": "kmr",
              "text": "Taybetmendiyeke girîng a hilberê giraniya kêm e."
            },
            {
              "language": "pl",
              "text": "Ważną cechą produktu jest niska waga."
            },
            {
              "language": "ro",
              "text": "O caracteristică importantă a produsului este greutatea redusă."
            },
            {
              "language": "ru",
              "text": "Важная характеристика продукта — небольшой вес."
            },
            {
              "language": "sq",
              "text": "Një veçori e rëndësishme e produktit është pesha e ulët."
            },
            {
              "language": "tr",
              "text": "Ürünün önemli bir özelliği düşük ağırlığıdır."
            }
          ]
        }
      ]
    },
    {
