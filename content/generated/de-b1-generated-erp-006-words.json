      "plural": "Mitbewerber",
      "infinitive": null,
      "syllableBreak": "Mit-be-wer-ber",
      "topics": [
        "sales-and-customers",
        "contracts-and-negotiation",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written"
      ],
      "grammarNotes": [
        "masculine noun; feminine form: die Mitbewerberin"
      ],
      "collocations": [
        {
          "text": "ein starker Mitbewerber",
          "meaning": "a strong competitor"
        },
        {
          "text": "Preise der Mitbewerber vergleichen",
          "meaning": "to compare competitors prices"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bewerben",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Wettbewerb",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "منافس"
        },
        {
          "language": "ckb",
          "text": "ڕکابەر"
        },
        {
          "language": "en",
          "text": "competitor"
        },
        {
          "language": "fa",
          "text": "رقیب"
        },
        {
          "language": "kmr",
          "text": "reqîb"
        },
        {
          "language": "pl",
          "text": "konkurent"
        },
        {
          "language": "ro",
          "text": "concurent"
        },
        {
          "language": "ru",
          "text": "конкурент"
        },
        {
          "language": "sq",
          "text": "konkurrent"
        },
        {
          "language": "tr",
          "text": "rakip"
        }
      ],
      "examples": [
        {
          "baseText": "Im ERP-Bericht vergleichen wir unsere Preise mit den Mitbewerbern.",
          "translations": [
            {
              "language": "ar",
              "text": "في تقرير نظام تخطيط موارد المؤسسة نقارن أسعارنا مع المنافسين."
            },
            {
              "language": "ckb",
              "text": "لە ڕاپۆرتی ERPدا نرخەکانمان لەگەڵ ڕکابەرەکان بەراورد دەکەین."
            },
            {
              "language": "en",
              "text": "In the ERP report, we compare our prices with competitors."
            },
            {
              "language": "fa",
              "text": "در گزارش ERP قیمت‌های خود را با رقبا مقایسه می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di rapora ERP de em bihayên xwe bi reqîban re didin ber hev."
            },
            {
              "language": "pl",
              "text": "W raporcie ERP porównujemy nasze ceny z konkurentami."
            },
            {
              "language": "ro",
              "text": "În raportul ERP comparăm prețurile noastre cu cele ale concurenților."
            },
            {
              "language": "ru",
              "text": "В ERP-отчете мы сравниваем наши цены с конкурентами."
            },
            {
              "language": "sq",
              "text": "Në raportin ERP i krahasojmë çmimet tona me konkurrentët."
            },
            {
              "language": "tr",
              "text": "ERP raporunda fiyatlarımızı rakiplerle karşılaştırıyoruz."
            }
          ]
        },
        {
          "baseText": "Dieser Mitbewerber bietet im Moment sehr kurze Lieferzeiten an.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا المنافس يقدم حاليًا أوقات تسليم قصيرة جدًا."
            },
            {
              "language": "ckb",
              "text": "ئەم ڕکابەرە ئێستا کاتی گەیاندنی زۆر کورت پێشکەش دەکات."
