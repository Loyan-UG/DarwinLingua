  "entries": [
    {
      "word": "die Verbindung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Verbindungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-bin-dung",
      "topics": [
        "technology-and-it",
        "transport-and-travel",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine stabile Verbindung",
          "meaning": "a stable connection"
        },
        {
          "text": "eine direkte Verbindung",
          "meaning": "a direct connection"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verbinden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اتصال؛ ارتباط؛ وصلة"
        },
        {
          "language": "ckb",
          "text": "پەیوەندی؛ گرێدان"
        },
        {
          "language": "en",
          "text": "connection; link"
        },
        {
          "language": "fa",
          "text": "اتصال؛ ارتباط"
        },
        {
          "language": "kmr",
          "text": "girêdan; têkilî"
        },
        {
          "language": "pl",
          "text": "połączenie; związek"
        },
        {
          "language": "ro",
          "text": "conexiune; legătură"
        },
        {
          "language": "ru",
          "text": "соединение; связь"
        },
        {
          "language": "sq",
          "text": "lidhje; koneksion"
        },
        {
          "language": "tr",
          "text": "bağlantı; ilişki"
        }
      ],
      "examples": [
        {
          "baseText": "Während des Videoanrufs war die Verbindung leider sehr schlecht.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء مكالمة الفيديو كان الاتصال للأسف سيئًا جدًا."
            },
            {
              "language": "ckb",
              "text": "لە کاتی پەیوەندی ڤیدیۆییدا بەداخەوە پەیوەندییەکە زۆر خراپ بوو."
            },
            {
              "language": "en",
              "text": "During the video call, the connection was unfortunately very poor."
            },
            {
              "language": "fa",
              "text": "در طول تماس ویدیویی، متأسفانه اتصال خیلی بد بود."
            },
            {
              "language": "kmr",
              "text": "Di dema bangê vîdyoyê de girêdan mixabin pir xerab bû."
            },
            {
              "language": "pl",
              "text": "Podczas rozmowy wideo połączenie było niestety bardzo słabe."
            },
            {
              "language": "ro",
              "text": "În timpul apelului video, conexiunea a fost din păcate foarte slabă."
            },
            {
              "language": "ru",
              "text": "Во время видеозвонка связь, к сожалению, была очень плохой."
            },
            {
              "language": "sq",
              "text": "Gjatë telefonatës me video, lidhja ishte fatkeqësisht shumë e dobët."
            },
            {
              "language": "tr",
              "text": "Video görüşme sırasında bağlantı maalesef çok kötüydü."
            }
          ]
        },
        {
          "baseText": "Gibt es eine direkte Verbindung vom Bahnhof zum Flughafen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل توجد وصلة مباشرة من محطة القطار إلى المطار؟"
            },
            {
              "language": "ckb",
              "text": "ئایا پەیوەندییەکی ڕاستەوخۆ لە وێستگەی شەمەندەفەرەوە بۆ فڕۆکەخانە هەیە؟"
            },
            {
              "language": "en",
              "text": "Is there a direct connection from the train station to the airport?"
            },
            {
              "language": "fa",
              "text": "آیا ارتباط مستقیمی از ایستگاه قطار به فرودگاه وجود دارد؟"
            },
            {
              "language": "kmr",
              "text": "Ma girêdaneke rasterast ji rawestgeha trênê heta balafirgehê heye?"
            },
            {
              "language": "pl",
              "text": "Czy jest bezpośrednie połączenie z dworca na lotnisko?"
            },
            {
              "language": "ro",
              "text": "Există o legătură directă de la gară la aeroport?"
            },
            {
              "language": "ru",
              "text": "Есть ли прямое сообщение от вокзала до аэропорта?"
            },
            {
              "language": "sq",
              "text": "A ka lidhje direkte nga stacioni i trenit në aeroport?"
            },
            {
              "language": "tr",
              "text": "Tren istasyonundan havaalanına doğrudan bağlantı var mı?"
            }
          ]
        }
      ]
    },
    {
      "word": "der Verbrauch",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-brauch",
      "topics": [
        "finance-and-accounting",
        "environment-and-sustainability",
        "housing-and-real-estate"
      ],
      "usageLabels": [
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "den Verbrauch senken",
          "meaning": "to reduce consumption"
        },
        {
          "text": "hoher Verbrauch",
          "meaning": "high consumption"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verbrauchen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استهلاك"
        },
        {
          "language": "ckb",
          "text": "بەکارهێنان؛ خەرجکردن"
        },
        {
          "language": "en",
          "text": "consumption; usage"
        },
        {
          "language": "fa",
          "text": "مصرف"
        },
        {
          "language": "kmr",
          "text": "xerckirin; bikaranîn"
        },
        {
          "language": "pl",
          "text": "zużycie; konsumpcja"
        },
        {
          "language": "ro",
          "text": "consum"
        },
        {
          "language": "ru",
          "text": "потребление; расход"
        },
        {
          "language": "sq",
          "text": "konsum; përdorim"
        },
        {
          "language": "tr",
          "text": "tüketim; kullanım"
        }
      ],
      "examples": [
        {
          "baseText": "Der Verbrauch von Strom ist im Winter deutlich höher.",
          "translations": [
            {
              "language": "ar",
              "text": "استهلاك الكهرباء في الشتاء أعلى بكثير."
            },
            {
              "language": "ckb",
              "text": "بەکارهێنانی کارەبا لە زستاندا بە ڕوونی زیاترە."
            },
            {
              "language": "en",
              "text": "Electricity consumption is significantly higher in winter."
            },
            {
              "language": "fa",
              "text": "مصرف برق در زمستان به‌طور قابل توجهی بیشتر است."
            },
            {
              "language": "kmr",
              "text": "Xerckirina elektrîkê di zivistanê de bi awayekî eşkere bilindtir e."
            },
            {
              "language": "pl",
              "text": "Zużycie prądu zimą jest wyraźnie wyższe."
            },
            {
              "language": "ro",
              "text": "Consumul de energie electrică este mult mai mare iarna."
            },
            {
              "language": "ru",
              "text": "Потребление электроэнергии зимой значительно выше."
            },
            {
              "language": "sq",
              "text": "Konsumi i energjisë elektrike është dukshëm më i lartë në dimër."
            },
            {
              "language": "tr",
              "text": "Kışın elektrik tüketimi belirgin şekilde daha yüksektir."
            }
          ]
        },
        {
          "baseText": "Mit neuen Geräten kann die Firma den Verbrauch von Wasser reduzieren.",
          "translations": [
            {
              "language": "ar",
              "text": "باستخدام أجهزة جديدة تستطيع الشركة تقليل استهلاك الماء."
            },
            {
              "language": "ckb",
              "text": "بە ئامێری نوێ کۆمپانیاکە دەتوانێت بەکارهێنانی ئاو کەم بکاتەوە."
            },
            {
              "language": "en",
              "text": "With new devices, the company can reduce water consumption."
            },
            {
              "language": "fa",
              "text": "شرکت با دستگاه‌های جدید می‌تواند مصرف آب را کاهش دهد."
            },
            {
              "language": "kmr",
              "text": "Bi amûrên nû şirket dikare xerckirina avê kêm bike."
            },
            {
              "language": "pl",
              "text": "Dzięki nowym urządzeniom firma może zmniejszyć zużycie wody."
            },
            {
              "language": "ro",
              "text": "Cu echipamente noi, firma poate reduce consumul de apă."
            },
            {
              "language": "ru",
              "text": "С помощью новых устройств компания может снизить расход воды."
            },
            {
              "language": "sq",
              "text": "Me pajisje të reja kompania mund të ulë konsumin e ujit."
            },
            {
              "language": "tr",
              "text": "Yeni cihazlarla şirket su tüketimini azaltabilir."
            }
          ]
        }
      ]
    },
