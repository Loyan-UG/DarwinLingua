      ],
      "examples": [
        {
          "baseText": "Der Verbraucher hat das Recht, den Online-Kauf innerhalb von 14 Tagen zu widerrufen.",
          "translations": [
            {
              "language": "ar",
              "text": "للمستهلك الحق في إلغاء الشراء عبر الإنترنت خلال 14 يومًا."
            },
            {
              "language": "ckb",
              "text": "بەکارهێنەر مافی هەیە لە ماوەی ١٤ ڕۆژدا کڕینی ئۆنلاین هەڵبوەشێنێتەوە."
            },
            {
              "language": "en",
              "text": "The consumer has the right to cancel the online purchase within 14 days."
            },
            {
              "language": "fa",
              "text": "مصرف‌کننده حق دارد خرید آنلاین را ظرف ۱۴ روز لغو کند."
            },
            {
              "language": "kmr",
              "text": "Bikarhêner mafê wê heye ku kirîna online di nav 14 rojan de betal bike."
            },
            {
              "language": "pl",
              "text": "Konsument ma prawo odstąpić od zakupu online w ciągu 14 dni."
            },
