  "entries": [
    {
      "word": "begraben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "begraben",
      "pronunciationIpa": null,
      "syllableBreak": "be-gra-ben",
      "topics": [
        "social-and-relationships",
        "everyday-life",
        "planning-and-projects"
      ],
      "usageLabels": [
        "formal",
        "spoken"
      ],
      "contextLabels": [
        "management"
      ],
      "grammarNotes": [
        "irregular verb",
        "past: begrub; perfect: hat begraben; literal and figurative use"
      ],
      "collocations": [
        {
          "text": "einen Plan begraben",
          "meaning": "to abandon a plan"
        },
        {
          "text": "auf dem Friedhof begraben",
          "meaning": "to bury at the cemetery"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Grab",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "begraben sein",
          "relationLabel": "phrase",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدفن؛ يتخلى عن فكرة أو خطة"
        },
        {
          "language": "ckb",
          "text": "ناشتن؛ وازهێنان لە پلانێک"
        },
        {
          "language": "en",
          "text": "to bury; to abandon a plan"
        },
        {
          "language": "fa",
          "text": "دفن کردن؛ کنار گذاشتن یک برنامه"
        },
        {
          "language": "kmr",
          "text": "veşartin; planekê dev jê berdan"
        },
        {
          "language": "pl",
          "text": "pochować; pogrzebać plan"
        },
        {
          "language": "ro",
          "text": "a îngropa; a abandona un plan"
        },
        {
          "language": "ru",
          "text": "похоронить; отказаться от плана"
        },
        {
          "language": "sq",
          "text": "të varrosësh; të braktisësh një plan"
        },
        {
          "language": "tr",
          "text": "gömmek; bir plandan vazgeçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Kostenprüfung mussten wir die Idee für dieses Jahr begraben.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد فحص التكاليف اضطررنا إلى التخلي عن الفكرة لهذا العام."
            },
            {
              "language": "ckb",
              "text": "دوای پشکنینی تێچوونەکان ناچار بووین ئەم بیرۆکەیە بۆ ئەمساڵ واز لێبهێنین."
            },
            {
              "language": "en",
              "text": "After reviewing the costs, we had to abandon the idea for this year."
            },
            {
              "language": "fa",
              "text": "بعد از بررسی هزینه‌ها مجبور شدیم این ایده را برای امسال کنار بگذاریم."
            },
            {
              "language": "kmr",
              "text": "Piştî kontrolkirina lêçûnê, em neçar bûn vê ramanê ji bo îsal dev jê berdin."
            },
            {
              "language": "pl",
              "text": "Po sprawdzeniu kosztów musieliśmy pogrzebać ten pomysł na ten rok."
            },
            {
              "language": "ro",
              "text": "După verificarea costurilor, a trebuit să abandonăm ideea pentru anul acesta."
            },
            {
              "language": "ru",
              "text": "После проверки расходов нам пришлось отказаться от этой идеи на этот год."
            },
            {
              "language": "sq",
              "text": "Pas kontrollit të kostove, duhej ta braktisnim idenë për këtë vit."
            },
            {
              "language": "tr",
              "text": "Maliyetleri kontrol ettikten sonra bu yıl için bu fikirden vazgeçmek zorunda kaldık."
            }
          ]
        },
        {
          "baseText": "Die Familie hat den Hund im Garten begraben.",
          "translations": [
            {
              "language": "ar",
              "text": "دفنت العائلة الكلب في الحديقة."
            },
            {
              "language": "ckb",
              "text": "خێزانەکە سەگەکەیان لە باخچەکەدا ناشت."
            },
            {
              "language": "en",
              "text": "The family buried the dog in the garden."
            },
            {
              "language": "fa",
              "text": "خانواده سگ را در باغ دفن کرد."
            },
            {
              "language": "kmr",
              "text": "Malbatê kûçik li baxçe veşart."
            },
            {
              "language": "pl",
              "text": "Rodzina pochowała psa w ogrodzie."
            },
            {
              "language": "ro",
              "text": "Familia a îngropat câinele în grădină."
            },
            {
              "language": "ru",
              "text": "Семья похоронила собаку в саду."
            },
            {
              "language": "sq",
              "text": "Familja e varrosi qenin në kopsht."
            },
            {
              "language": "tr",
              "text": "Aile köpeği bahçeye gömdü."
            }
          ]
        }
      ]
    },
