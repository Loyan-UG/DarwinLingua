  "entries": [
    {
      "word": "scheiden",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "scheiden",
      "pronunciationIpa": null,
      "syllableBreak": "schei-den",
      "topics": [
        "social-and-relationships",
        "law-and-compliance",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "written",
        "everyday"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular/regular depending on use; common reflexive form: sich scheiden lassen"
      ],
      "collocations": [
        {
          "text": "sich scheiden lassen",
          "meaning": "to get divorced"
        },
        {
          "text": "beruflich scheiden",
          "meaning": "to leave formally; less common"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Scheidung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "geschieden",
          "relationLabel": "participle/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينفصل؛ يطلّق/يتطلّق"
        },
        {
          "language": "ckb",
          "text": "جیادەبێتەوە؛ تەڵاق دەدات/وەردەگرێت"
        },
        {
          "language": "en",
          "text": "to separate; to divorce"
        },
        {
          "language": "fa",
          "text": "جدا شدن؛ طلاق گرفتن/دادن"
        },
        {
          "language": "kmr",
          "text": "veqetîn; telaq dan/girtin"
        },
        {
          "language": "pl",
          "text": "rozwodzić się; rozdzielać"
        },
        {
          "language": "ro",
          "text": "a divorța; a separa"
        },
        {
          "language": "ru",
          "text": "разводиться; разделять"
        },
        {
          "language": "sq",
          "text": "të divorcohesh; të ndahesh"
        },
        {
          "language": "tr",
          "text": "boşanmak; ayırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach vielen Gesprächen haben sie beschlossen, sich scheiden zu lassen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد محادثات كثيرة قررا أن يتطلقا."
            },
            {
              "language": "ckb",
              "text": "دوای زۆر گفتوگۆ بڕیاریان دا لە یەکتر جیاببنەوە."
            },
            {
              "language": "en",
              "text": "After many conversations, they decided to get divorced."
            },
            {
              "language": "fa",
              "text": "بعد از گفت‌وگوهای زیاد تصمیم گرفتند طلاق بگیرند."
            },
            {
              "language": "kmr",
              "text": "Piştî gelek axaftinan wan biryar da ku ji hev veqetin."
            },
            {
              "language": "pl",
              "text": "Po wielu rozmowach zdecydowali się rozwieść."
            },
            {
              "language": "ro",
              "text": "După multe discuții au decis să divorțeze."
            },
            {
              "language": "ru",
              "text": "После многих разговоров они решили развестись."
            },
            {
              "language": "sq",
              "text": "Pas shumë bisedash vendosën të divorcohen."
            },
            {
              "language": "tr",
              "text": "Birçok konuşmadan sonra boşanmaya karar verdiler."
            }
          ]
        },
        {
          "baseText": "Für die Scheidung brauchen beide Seiten rechtliche Beratung.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل الطلاق يحتاج الطرفان إلى استشارة قانونية."
            },
            {
              "language": "ckb",
              "text": "بۆ تەڵاقەکە هەردوو لا پێویستیان بە ڕاوێژی یاسایی هەیە."
            },
            {
              "language": "en",
              "text": "For the divorce, both sides need legal advice."
            },
            {
              "language": "fa",
              "text": "برای طلاق، هر دو طرف به مشاوره حقوقی نیاز دارند."
            },
            {
              "language": "kmr",
              "text": "Ji bo telaqê her du alî hewceyê şêwirmendiya hiqûqî ne."
            },
            {
              "language": "pl",
              "text": "Do rozwodu obie strony potrzebują porady prawnej."
            },
            {
              "language": "ro",
              "text": "Pentru divorț, ambele părți au nevoie de consiliere juridică."
            },
            {
              "language": "ru",
              "text": "Для развода обеим сторонам нужна юридическая консультация."
            },
            {
              "language": "sq",
              "text": "Për divorcin, të dyja palët kanë nevojë për këshillim juridik."
            },
            {
              "language": "tr",
              "text": "Boşanma için iki tarafın da hukuki danışmanlığa ihtiyacı var."
            }
          ]
        }
      ]
    },
    {
      "word": "scheinen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
