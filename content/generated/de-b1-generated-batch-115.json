      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: scheint, schien, geschienen; also used with zu + infinitive: es scheint zu ..."
      ],
      "collocations": [
        {
          "text": "die Sonne scheint",
          "meaning": "the sun is shining"
        },
        {
          "text": "es scheint so",
          "meaning": "it seems so"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Schein",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "anscheinend",
          "relationLabel": "adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يبدو؛ يشرق/يضيء"
        },
        {
          "language": "ckb",
          "text": "وادیارە؛ دەدرەوشێتەوە"
        },
        {
          "language": "en",
          "text": "to seem; to shine"
        },
        {
          "language": "fa",
          "text": "به نظر رسیدن؛ تابیدن/درخشیدن"
        },
        {
          "language": "kmr",
          "text": "xuya kirin; şewq dan"
        },
        {
          "language": "pl",
          "text": "wydawać się; świecić"
        },
        {
          "language": "ro",
          "text": "a părea; a străluci"
        },
        {
          "language": "ru",
          "text": "казаться; светить"
        },
        {
          "language": "sq",
          "text": "të duket; të shkëlqesh"
        },
        {
          "language": "tr",
          "text": "görünmek; parlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Es scheint, dass der Kunde noch Fragen zum Angebot hat.",
          "translations": [
            {
              "language": "ar",
              "text": "يبدو أن العميل ما زالت لديه أسئلة حول العرض."
            },
            {
              "language": "ckb",
              "text": "وادیارە کڕیارەکە هێشتا پرسیاری دەربارەی پێشنیارەکە هەیە."
            },
            {
              "language": "en",
              "text": "It seems that the customer still has questions about the offer."
            },
            {
              "language": "fa",
              "text": "به نظر می‌رسد مشتری هنوز درباره پیشنهاد سؤال دارد."
            },
            {
              "language": "kmr",
              "text": "Wisa xuya dike ku mişterî hîn pirsên li ser pêşniyarê hene."
            },
            {
              "language": "pl",
              "text": "Wygląda na to, że klient ma jeszcze pytania dotyczące oferty."
            },
            {
              "language": "ro",
              "text": "Se pare că clientul mai are întrebări despre ofertă."
            },
            {
              "language": "ru",
              "text": "Кажется, у клиента ещё есть вопросы по предложению."
            },
            {
              "language": "sq",
              "text": "Duket se klienti ka ende pyetje për ofertën."
            },
            {
              "language": "tr",
              "text": "Müşterinin teklifle ilgili hâlâ soruları var gibi görünüyor."
            }
          ]
        },
        {
          "baseText": "Heute scheint die Sonne, also können wir draußen essen.",
          "translations": [
            {
              "language": "ar",
              "text": "اليوم تشرق الشمس، لذلك يمكننا أن نأكل في الخارج."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ خۆر دەدرەوشێتەوە، بۆیە دەتوانین لە دەرەوە نان بخۆین."
            },
            {
              "language": "en",
              "text": "The sun is shining today, so we can eat outside."
            },
            {
              "language": "fa",
              "text": "امروز آفتاب می‌تابد، پس می‌توانیم بیرون غذا بخوریم."
            },
            {
              "language": "kmr",
              "text": "Îro roj dişewite, ji ber vê em dikarin li derve bixwin."
            },
            {
              "language": "pl",
              "text": "Dziś świeci słońce, więc możemy zjeść na zewnątrz."
            },
            {
              "language": "ro",
              "text": "Astăzi strălucește soarele, deci putem mânca afară."
            },
            {
              "language": "ru",
              "text": "Сегодня светит солнце, так что мы можем поесть на улице."
            },
            {
              "language": "sq",
              "text": "Sot po shkëlqen dielli, prandaj mund të hamë jashtë."
            },
            {
              "language": "tr",
              "text": "Bugün güneş parlıyor, bu yüzden dışarıda yemek yiyebiliriz."
            }
          ]
        }
      ]
    },
