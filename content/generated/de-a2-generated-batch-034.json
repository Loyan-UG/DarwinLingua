            {
              "language": "ru",
              "text": "Есть скидка для школьников?"
            },
            {
              "language": "sq",
              "text": "A ka zbritje për nxënësit?"
            },
            {
              "language": "tr",
              "text": "Öğrenciler için indirim var mı?"
            }
          ]
        },
        {
          "baseText": "Mit dieser Karte bekommen Sie zehn Prozent Ermäßigung.",
