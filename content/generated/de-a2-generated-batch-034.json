              "language": "ckb",
              "text": "داشکاندن بۆ قوتابیان هەیە؟"
            },
            {
              "language": "en",
              "text": "Is there a discount for students?"
            },
            {
              "language": "fa",
              "text": "آیا برای دانش‌آموزان تخفیف وجود دارد؟"
            },
            {
              "language": "kmr",
              "text": "Ji bo xwendekaran dakêşandin heye?"
            },
            {
              "language": "pl",
              "text": "Czy jest zniżka dla uczniów?"
            },
            {
              "language": "ro",
              "text": "Există reducere pentru elevi?"
