  "entries": [
    {
      "word": "die Kinderbetreuung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kin-der-be-treu-ung",
      "topics": [
        "work-and-jobs",
        "public-services",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "everyday"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually used in singular"
      ],
      "collocations": [
        {
          "text": "Kinderbetreuung organisieren",
          "meaning": "to organize childcare"
        },
        {
          "text": "Kosten für Kinderbetreuung",
          "meaning": "childcare costs"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Kind",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "betreuen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "رعاية الأطفال"
        },
        {
          "language": "ckb",
          "text": "چاودێری منداڵان"
        },
        {
          "language": "en",
          "text": "childcare"
        },
        {
          "language": "fa",
          "text": "مراقبت از کودکان؛ نگهداری کودک"
        },
        {
          "language": "kmr",
          "text": "lênihêrîna zarokan"
        },
        {
          "language": "pl",
          "text": "opieka nad dziećmi"
        },
        {
          "language": "ro",
          "text": "îngrijirea copiilor"
        },
        {
          "language": "ru",
          "text": "уход за детьми; присмотр за детьми"
        },
        {
          "language": "sq",
          "text": "kujdes për fëmijët"
        },
        {
          "language": "tr",
          "text": "çocuk bakımı"
        }
      ],
      "examples": [
        {
          "baseText": "Viele Eltern brauchen eine zuverlässige Kinderbetreuung, damit sie arbeiten können.",
          "translations": [
            {
              "language": "ar",
              "text": "يحتاج كثير من الآباء إلى رعاية أطفال موثوقة حتى يتمكنوا من العمل."
            },
            {
              "language": "ckb",
              "text": "زۆر دایک و باوک پێویستیان بە چاودێرییەکی متمانەپێکراوی منداڵان هەیە تا بتوانن کار بکەن."
            },
            {
              "language": "en",
              "text": "Many parents need reliable childcare so they can work."
            },
            {
              "language": "fa",
              "text": "بسیاری از والدین به مراقبت قابل اعتماد از کودکان نیاز دارند تا بتوانند کار کنند."
            },
            {
              "language": "kmr",
              "text": "Gelek dê û bav hewceyê lênihêrîneke pêbawer a zarokan in da ku kar bikin."
            },
            {
              "language": "pl",
              "text": "Wielu rodziców potrzebuje niezawodnej opieki nad dziećmi, aby móc pracować."
            },
            {
              "language": "ro",
              "text": "Mulți părinți au nevoie de îngrijire sigură pentru copii ca să poată lucra."
            },
            {
              "language": "ru",
              "text": "Многим родителям нужен надёжный присмотр за детьми, чтобы они могли работать."
            },
            {
              "language": "sq",
              "text": "Shumë prindër kanë nevojë për kujdes të besueshëm për fëmijët që të mund të punojnë."
            },
            {
              "language": "tr",
              "text": "Birçok ebeveyn çalışabilmek için güvenilir çocuk bakımına ihtiyaç duyar."
            }
          ]
        },
        {
          "baseText": "Die Stadt bietet in den Ferien zusätzliche Kinderbetreuung an.",
          "translations": [
            {
              "language": "ar",
              "text": "تقدم المدينة رعاية إضافية للأطفال خلال العطلات."
            },
            {
              "language": "ckb",
              "text": "شارەکە لە پشوودا چاودێریی زیاتر بۆ منداڵان پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "The city offers additional childcare during the holidays."
            },
            {
              "language": "fa",
              "text": "شهر در تعطیلات مراقبت اضافی از کودکان ارائه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Bajar di betlaneyan de lênihêrîna zêde ya zarokan pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Miasto oferuje dodatkową opiekę nad dziećmi w czasie ferii."
            },
            {
              "language": "ro",
              "text": "Orașul oferă îngrijire suplimentară pentru copii în vacanțe."
            },
            {
              "language": "ru",
              "text": "Город предлагает дополнительный присмотр за детьми во время каникул."
            },
            {
              "language": "sq",
              "text": "Qyteti ofron kujdes shtesë për fëmijët gjatë pushimeve."
            },
            {
              "language": "tr",
              "text": "Belediye tatillerde ek çocuk bakımı sunuyor."
            }
          ]
        }
      ]
    },
    {
      "word": "klären",
