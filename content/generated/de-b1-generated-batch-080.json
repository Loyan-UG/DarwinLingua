        }
      ],
      "wordFamilies": [
        {
          "lemma": "klar",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Klärung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يوضح؛ يحلّ"
        },
        {
          "language": "ckb",
          "text": "ڕوونکردنەوە؛ چارەسەرکردن"
        },
        {
          "language": "en",
          "text": "to clarify; to resolve"
        },
        {
          "language": "fa",
          "text": "روشن کردن؛ حل کردن"
        },
        {
          "language": "kmr",
          "text": "zelal kirin; çareser kirin"
        },
        {
          "language": "pl",
          "text": "wyjaśnić; rozwiązać"
        },
        {
          "language": "ro",
          "text": "a clarifica; a rezolva"
        },
        {
          "language": "ru",
          "text": "выяснять; прояснять; решать"
        },
        {
          "language": "sq",
          "text": "të sqarosh; të zgjidhësh"
        },
        {
          "language": "tr",
          "text": "açıklığa kavuşturmak; çözmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir müssen vor dem Angebot noch die technischen Details klären.",
          "translations": [
            {
              "language": "ar",
              "text": "علينا قبل العرض أن نوضح التفاصيل التقنية."
            },
            {
              "language": "ckb",
              "text": "پێش پێشنیارەکە دەبێت وردەکارییە تەکنیکییەکان ڕوون بکەینەوە."
            },
            {
              "language": "en",
              "text": "Before the offer, we still need to clarify the technical details."
            },
            {
              "language": "fa",
              "text": "قبل از پیشنهاد باید جزئیات فنی را روشن کنیم."
            },
            {
              "language": "kmr",
              "text": "Berî pêşniyarê divê em hîn hûrgiliyên teknîkî zelal bikin."
            },
            {
              "language": "pl",
              "text": "Przed ofertą musimy jeszcze wyjaśnić szczegóły techniczne."
            },
            {
              "language": "ro",
              "text": "Înainte de ofertă trebuie să clarificăm detaliile tehnice."
            },
            {
              "language": "ru",
              "text": "Перед предложением нам нужно ещё уточнить технические детали."
            },
            {
              "language": "sq",
              "text": "Para ofertës duhet ende të sqarojmë detajet teknike."
            },
            {
              "language": "tr",
              "text": "Tekliften önce teknik ayrıntıları netleştirmemiz gerekiyor."
            }
          ]
        },
        {
          "baseText": "Bitte klären Sie mit der Hausverwaltung, wann die Reparatur beginnt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى توضيح الأمر مع إدارة المبنى: متى يبدأ الإصلاح؟"
            },
            {
              "language": "ckb",
              "text": "تکایە لەگەڵ بەڕێوەبەرایەتی خانوو ڕوون بکەنەوە کە چاکسازی کەی دەست پێ دەکات."
            },
            {
              "language": "en",
              "text": "Please clarify with property management when the repair will begin."
            },
            {
              "language": "fa",
