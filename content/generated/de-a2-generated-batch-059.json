            {
              "language": "sq",
              "text": "A ke një stilolaps për mua?"
            },
            {
              "language": "tr",
              "text": "Benim için bir kalemin var mı?"
            }
          ]
        },
        {
          "baseText": "Der Kuli schreibt nicht mehr.",
          "translations": [
            {
              "language": "ar",
              "text": "القلم لم يعد يكتب."
            },
            {
              "language": "ckb",
              "text": "پێنووسەکە چیتر نانووسێت."
            },
            {
              "language": "en",
              "text": "The pen no longer writes."
            },
            {
              "language": "fa",
              "text": "خودکار دیگر نمی‌نویسد."
            },
            {
              "language": "kmr",
              "text": "Qelem êdî nanivîse."
            },
            {
              "language": "pl",
              "text": "Długopis już nie pisze."
            },
            {
              "language": "ro",
              "text": "Pixul nu mai scrie."
