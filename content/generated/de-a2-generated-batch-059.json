      "examples": [
        {
          "baseText": "Die Künstlerin zeigt ihre Bilder im Museum.",
          "translations": [
            {
              "language": "ar",
              "text": "تعرض الفنانة صورها في المتحف."
            },
            {
              "language": "ckb",
              "text": "هونەرمەندە ژنەکە وێنەکانی لە مۆزەخانە پیشان دەدات."
            },
            {
              "language": "en",
              "text": "The artist shows her pictures in the museum."
            },
            {
              "language": "fa",
              "text": "هنرمند آثارش را در موزه نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Hunermenda jin wêneyên xwe li mûzeyê nîşan dide."
            },
            {
              "language": "pl",
              "text": "Artystka pokazuje swoje obrazy w muzeum."
            },
            {
              "language": "ro",
              "text": "Artista își arată tablourile la muzeu."
            },
            {
              "language": "ru",
              "text": "Художница показывает свои картины в музее."
            },
            {
              "language": "sq",
              "text": "Artistja tregon pikturat e saj në muze."
            },
            {
              "language": "tr",
              "text": "Kadın sanatçı resimlerini müzede gösteriyor."
            }
          ]
        },
        {
          "baseText": "Meine Nachbarin ist Künstlerin.",
          "translations": [
            {
              "language": "ar",
              "text": "جارتي فنانة."
            },
            {
              "language": "ckb",
              "text": "دراوسێیەکەم هونەرمەندە."
            },
            {
              "language": "en",
              "text": "My neighbor is an artist."
            },
            {
              "language": "fa",
              "text": "همسایه‌ام هنرمند است."
            },
            {
              "language": "kmr",
              "text": "Cîrana min hunermend e."
            },
            {
              "language": "pl",
              "text": "Moja sąsiadka jest artystką."
            },
            {
              "language": "ro",
              "text": "Vecina mea este artistă."
            },
            {
              "language": "ru",
              "text": "Моя соседка художница."
            },
            {
              "language": "sq",
              "text": "Fqinja ime është artiste."
