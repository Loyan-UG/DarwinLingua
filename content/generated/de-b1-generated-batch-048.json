  "entries": [
    {
      "word": "die Einspruchsfrist",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Einspruchsfristen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ein-spruchs-frist",
      "topics": [
        "law-and-compliance",
        "documents-and-administration",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "written"
      ],
      "contextLabels": [
        "documents",
        "administration",
        "compliance"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Einspruchsfrist beachten",
          "meaning": "to observe the objection period"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Einspruch",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Frist",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مهلة الاعتراض"
        },
        {
          "language": "ckb",
          "text": "ماوەی ناڕەزایی تۆمارکردن"
        },
        {
          "language": "en",
          "text": "objection period; appeal deadline"
        },
        {
          "language": "fa",
          "text": "مهلت اعتراض"
        },
        {
          "language": "kmr",
          "text": "demê îtîrazê"
        },
        {
          "language": "pl",
          "text": "termin na wniesienie sprzeciwu"
        },
        {
          "language": "ro",
          "text": "termen de contestație"
        },
        {
          "language": "ru",
          "text": "срок подачи возражения"
        },
        {
          "language": "sq",
          "text": "afati i kundërshtimit"
        },
        {
          "language": "tr",
          "text": "itiraz süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte beachten Sie die Einspruchsfrist auf dem Bescheid.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الانتباه إلى مهلة الاعتراض المذكورة في القرار."
            },
            {
              "language": "ckb",
              "text": "تکایە ماوەی ناڕەزایی تۆمارکردن لە بڕیارنامەکەدا لەبەرچاو بگرن."
            },
            {
              "language": "en",
              "text": "Please note the objection period on the notice."
            },
            {
              "language": "fa",
              "text": "لطفاً مهلت اعتراض روی ابلاغیه را در نظر بگیرید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe demê îtîrazê li ser biryarnameyê binêrin."
            },
            {
              "language": "pl",
              "text": "Proszę zwrócić uwagę na termin wniesienia sprzeciwu podany w decyzji."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să respectați termenul de contestație de pe decizie."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, обратите внимание на срок подачи возражения в уведомлении."
            },
            {
              "language": "sq",
              "text": "Ju lutemi vini re afatin e kundërshtimit në vendim."
            },
            {
              "language": "tr",
              "text": "Lütfen bildirideki itiraz süresine dikkat edin."
            }
          ]
        },
        {
          "baseText": "Wenn die Einspruchsfrist abläuft, kann der Antrag nicht mehr geändert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا انتهت مهلة الاعتراض، فلا يمكن تعديل الطلب بعد ذلك."
            },
            {
              "language": "ckb",
              "text": "ئەگەر ماوەی ناڕەزایی کۆتایی بێت، داواکارییەکە چیتر ناگۆڕدرێت."
            },
            {
              "language": "en",
              "text": "If the objection period expires, the application can no longer be changed."
            },
            {
              "language": "fa",
              "text": "اگر مهلت اعتراض تمام شود، درخواست دیگر قابل تغییر نیست."
            },
            {
              "language": "kmr",
              "text": "Heke demê îtîrazê biqede, daxwaz êdî nayê guhertin."
            },
            {
              "language": "pl",
              "text": "Jeśli termin na sprzeciw upłynie, wniosku nie można już zmienić."
            },
            {
              "language": "ro",
              "text": "Dacă termenul de contestație expiră, cererea nu mai poate fi modificată."
            },
            {
              "language": "ru",
              "text": "Если срок подачи возражения истечет, заявление уже нельзя будет изменить."
            },
            {
              "language": "sq",
              "text": "Nëse afati i kundërshtimit skadon, kërkesa nuk mund të ndryshohet më."
            },
            {
              "language": "tr",
              "text": "İtiraz süresi dolarsa başvuru artık değiştirilemez."
            }
          ]
        }
      ]
    },
