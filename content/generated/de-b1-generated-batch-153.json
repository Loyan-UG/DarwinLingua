  "entries": [
    {
      "word": "die Wohnberechtigung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Wohnberechtigungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Wohn-be-rech-ti-gung",
      "topics": [
        "housing-and-real-estate",
        "public-services",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Wohnberechtigung beantragen",
          "meaning": "to apply for housing eligibility"
        },
        {
          "text": "Nachweis der Wohnberechtigung",
          "meaning": "proof of housing eligibility"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "berechtigt",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أهلية السكن؛ تصريح السكن"
        },
        {
          "language": "ckb",
          "text": "مافی نیشتەجێبوون؛ مۆڵەتی خانووبوون"
        },
        {
          "language": "en",
          "text": "housing eligibility; housing entitlement"
        },
        {
          "language": "fa",
          "text": "حق سکونت؛ مجوز واجد شرایط بودن برای مسکن"
        },
        {
          "language": "kmr",
          "text": "mafê rûniştinê; destûra xanî"
        },
        {
          "language": "pl",
          "text": "uprawnienie do mieszkania"
        },
        {
          "language": "ro",
          "text": "drept de locuire; eligibilitate pentru locuință"
        },
        {
          "language": "ru",
          "text": "право на жилье; жилищное разрешение"
        },
        {
          "language": "sq",
          "text": "e drejtë banimi; kualifikim për banesë"
        },
        {
          "language": "tr",
          "text": "konut hakkı; oturma/konut uygunluğu"
        }
      ],
      "examples": [
        {
          "baseText": "Für diese geförderte Wohnung brauchen Sie eine Wohnberechtigung.",
          "translations": [
            {
              "language": "ar",
              "text": "لهذه الشقة المدعومة تحتاج إلى أهلية سكن."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم خانووە پشتگیریکراوە پێویستت بە مافی نیشتەجێبوون هەیە."
            },
            {
              "language": "en",
              "text": "For this subsidized apartment, you need housing eligibility."
            },
            {
              "language": "fa",
              "text": "برای این آپارتمان حمایتی به مجوز واجد شرایط بودن برای مسکن نیاز دارید."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê xanîya piştgirîkirî hûn hewceyê mafê rûniştinê ne."
            },
            {
              "language": "pl",
              "text": "Do tego mieszkania dotowanego potrzebne jest uprawnienie do mieszkania."
            },
            {
              "language": "ro",
              "text": "Pentru această locuință subvenționată aveți nevoie de drept de locuire."
            },
            {
              "language": "ru",
              "text": "Для этой субсидируемой квартиры нужно право на жилье."
            },
            {
              "language": "sq",
              "text": "Për këtë banesë të subvencionuar ju duhet e drejta e banimit."
            },
            {
              "language": "tr",
              "text": "Bu destekli daire için konut uygunluk belgesine ihtiyacınız var."
            }
          ]
        },
        {
          "baseText": "Die Wohnberechtigung muss beim Amt schriftlich beantragt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب طلب أهلية السكن كتابيًا من الدائرة."
            },
            {
              "language": "ckb",
              "text": "مافی نیشتەجێبوون دەبێت بە نووسراوە لە فەرمانگە داوا بکرێت."
            },
            {
              "language": "en",
              "text": "Housing eligibility must be applied for in writing at the office."
            },
            {
              "language": "fa",
              "text": "مجوز سکونت باید به‌صورت کتبی از اداره درخواست شود."
            },
            {
              "language": "kmr",
              "text": "Mafê rûniştinê divê li ofîsê bi nivîskî were daxwazkirin."
            },
            {
              "language": "pl",
              "text": "O uprawnienie do mieszkania trzeba wystąpić pisemnie w urzędzie."
            },
            {
              "language": "ro",
              "text": "Dreptul de locuire trebuie solicitat în scris la instituție."
            },
            {
              "language": "ru",
              "text": "Право на жилье нужно письменно запросить в ведомстве."
            },
            {
              "language": "sq",
              "text": "E drejta e banimit duhet të kërkohet me shkrim në zyrë."
            },
            {
              "language": "tr",
              "text": "Konut uygunluğu kuruma yazılı olarak başvurulmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Wohnfläche",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Wohnflächen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Wohn-flä-che",
      "topics": [
        "housing-and-real-estate",
        "finance-and-accounting",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Wohnfläche berechnen",
          "meaning": "to calculate living space"
        },
        {
          "text": "80 Quadratmeter Wohnfläche",
          "meaning": "80 square meters of living space"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "wohnen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مساحة السكن"
        },
        {
          "language": "ckb",
          "text": "ڕووبەری نیشتەجێبوون"
        },
        {
          "language": "en",
          "text": "living space; residential floor area"
        },
        {
          "language": "fa",
          "text": "مساحت قابل سکونت؛ زیربنای مسکونی"
        },
        {
          "language": "kmr",
          "text": "rûbera rûniştinê"
        },
        {
          "language": "pl",
          "text": "powierzchnia mieszkalna"
        },
        {
          "language": "ro",
          "text": "suprafață locuibilă"
        },
        {
          "language": "ru",
          "text": "жилая площадь"
        },
        {
          "language": "sq",
          "text": "sipërfaqe banimi"
        },
        {
          "language": "tr",
          "text": "yaşam alanı; konut alanı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Wohnung hat eine Wohnfläche von 72 Quadratmetern.",
          "translations": [
            {
              "language": "ar",
              "text": "تبلغ مساحة السكن في الشقة 72 مترًا مربعًا."
            },
            {
              "language": "ckb",
              "text": "خانووەکە ڕووبەری نیشتەجێبوونی ٧٢ مەتر دووجایە."
            },
            {
              "language": "en",
              "text": "The apartment has a living space of 72 square meters."
            },
            {
              "language": "fa",
              "text": "آپارتمان ۷۲ متر مربع مساحت قابل سکونت دارد."
            },
            {
              "language": "kmr",
              "text": "Xanî 72 metre çargoşe rûbera rûniştinê heye."
            },
            {
              "language": "pl",
              "text": "Mieszkanie ma powierzchnię mieszkalną 72 metrów kwadratowych."
            },
            {
              "language": "ro",
              "text": "Apartamentul are o suprafață locuibilă de 72 de metri pătrați."
            },
            {
              "language": "ru",
              "text": "Квартира имеет жилую площадь 72 квадратных метра."
            },
            {
              "language": "sq",
              "text": "Banesa ka sipërfaqe banimi prej 72 metrash katrorë."
            },
            {
              "language": "tr",
              "text": "Dairenin yaşam alanı 72 metrekaredir."
            }
          ]
        },
        {
          "baseText": "Die Wohnfläche ist wichtig für die Berechnung der Miete.",
          "translations": [
            {
              "language": "ar",
              "text": "مساحة السكن مهمة لحساب الإيجار."
            },
            {
              "language": "ckb",
              "text": "ڕووبەری نیشتەجێبوون بۆ حیسابکردنی کرێ گرنگە."
            },
            {
              "language": "en",
              "text": "The living space is important for calculating the rent."
            },
            {
              "language": "fa",
              "text": "مساحت قابل سکونت برای محاسبه اجاره مهم است."
            },
            {
              "language": "kmr",
              "text": "Rûbera rûniştinê ji bo hesabkirina kirê girîng e."
            },
            {
              "language": "pl",
              "text": "Powierzchnia mieszkalna jest ważna przy obliczaniu czynszu."
            },
            {
              "language": "ro",
              "text": "Suprafața locuibilă este importantă pentru calcularea chiriei."
            },
            {
              "language": "ru",
              "text": "Жилая площадь важна для расчета аренды."
            },
            {
              "language": "sq",
              "text": "Sipërfaqja e banimit është e rëndësishme për llogaritjen e qirasë."
            },
            {
              "language": "tr",
              "text": "Yaşam alanı kira hesaplaması için önemlidir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Wohnungsanzeige",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Wohnungsanzeigen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Woh-nungs-an-zei-ge",
      "topics": [
        "housing-and-real-estate",
        "shopping-and-services",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Wohnungsanzeige lesen",
          "meaning": "to read a housing ad"
        },
        {
          "text": "auf eine Wohnungsanzeige antworten",
          "meaning": "to respond to a housing ad"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Anzeige",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إعلان شقة؛ إعلان سكن"
        },
        {
          "language": "ckb",
          "text": "ئاگاداری خانوو/شوقە"
        },
        {
          "language": "en",
          "text": "apartment listing; housing ad"
        },
        {
          "language": "fa",
          "text": "آگهی آپارتمان؛ آگهی مسکن"
        },
        {
          "language": "kmr",
          "text": "îlana xanî; îlana apartmanê"
        },
        {
          "language": "pl",
          "text": "ogłoszenie mieszkaniowe"
        },
        {
          "language": "ro",
          "text": "anunț de locuință"
        },
        {
          "language": "ru",
          "text": "объявление о квартире"
        },
        {
          "language": "sq",
          "text": "shpallje banese"
        },
        {
          "language": "tr",
          "text": "ev ilanı; daire ilanı"
        }
      ],
      "examples": [
        {
          "baseText": "In der Wohnungsanzeige steht, dass die Warmmiete 950 Euro beträgt.",
          "translations": [
            {
              "language": "ar",
              "text": "يذكر إعلان الشقة أن الإيجار الشامل يبلغ 950 يورو."
            },
            {
              "language": "ckb",
              "text": "لە ئاگاداری خانووەکەدا نووسراوە کرێی گشتی ٩٥٠ یۆرۆیە."
            },
            {
              "language": "en",
              "text": "The apartment listing says that the rent including utilities is 950 euros."
            },
            {
              "language": "fa",
              "text": "در آگهی آپارتمان نوشته شده اجاره گرم ۹۵۰ یورو است."
            },
            {
              "language": "kmr",
              "text": "Di îlana xanî de nivîsandî ye ku kirêya bi lêçûnan 950 euro ye."
            },
            {
              "language": "pl",
              "text": "W ogłoszeniu mieszkaniowym napisano, że czynsz z opłatami wynosi 950 euro."
            },
            {
              "language": "ro",
              "text": "În anunțul de locuință scrie că chiria cu utilități este 950 de euro."
            },
            {
              "language": "ru",
              "text": "В объявлении о квартире указано, что аренда с коммунальными расходами составляет 950 евро."
            },
            {
              "language": "sq",
              "text": "Në shpalljen e banesës shkruhet se qiraja me shpenzime është 950 euro."
            },
            {
              "language": "tr",
              "text": "Daire ilanında yan giderler dahil kiranın 950 avro olduğu yazıyor."
            }
          ]
        },
        {
          "baseText": "Sie hat auf die Wohnungsanzeige sofort eine freundliche Nachricht geschrieben.",
          "translations": [
            {
              "language": "ar",
              "text": "كتبت فورًا رسالة لطيفة ردًا على إعلان الشقة."
            },
            {
              "language": "ckb",
              "text": "ئەو دەستبەجێ پەیامێکی دۆستانەی بۆ ئاگاداری خانووەکە نووسی."
            },
            {
              "language": "en",
              "text": "She immediately wrote a friendly message in response to the apartment listing."
            },
            {
              "language": "fa",
              "text": "او بلافاصله در پاسخ به آگهی آپارتمان یک پیام دوستانه نوشت."
            },
            {
              "language": "kmr",
              "text": "Wê tavilê ji bo îlana xanî peyameke dostane nivîsand."
            },
            {
              "language": "pl",
              "text": "Od razu napisała uprzejmą wiadomość w odpowiedzi na ogłoszenie mieszkaniowe."
            },
            {
              "language": "ro",
