      ],
      "examples": [
        {
          "baseText": "Ich habe einen ausländischen Pass.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي جواز سفر أجنبي."
            },
            {
              "language": "ckb",
              "text": "پاسپۆرتێکی بیانیم هەیە."
            },
            {
              "language": "en",
              "text": "I have a foreign passport."
            },
            {
              "language": "fa",
              "text": "من پاسپورت خارجی دارم."
            },
            {
              "language": "kmr",
              "text": "Pasaportek biyanî ya min heye."
            },
            {
              "language": "pl",
              "text": "Mam zagraniczny paszport."
            },
            {
              "language": "ro",
              "text": "Am un pașaport străin."
            },
            {
              "language": "ru",
              "text": "У меня иностранный паспорт."
            },
            {
              "language": "sq",
              "text": "Kam një pasaportë të huaj."
            },
            {
              "language": "tr",
              "text": "Yabancı bir pasaportum var."
            }
          ]
        },
        {
          "baseText": "Die Firma arbeitet mit ausländischen Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "تعمل الشركة مع عملاء أجانب."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە لەگەڵ کڕیارانی بیانی کار دەکات."
            },
            {
              "language": "en",
              "text": "The company works with foreign customers."
            },
            {
              "language": "fa",
              "text": "شرکت با مشتریان خارجی کار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Şîrket bi xerîdarên biyanî re dixebite."
            },
            {
              "language": "pl",
              "text": "Firma pracuje z zagranicznymi klientami."
            },
            {
              "language": "ro",
              "text": "Firma lucrează cu clienți străini."
            },
            {
              "language": "ru",
              "text": "Компания работает с иностранными клиентами."
            },
            {
              "language": "sq",
              "text": "Kompania punon me klientë të huaj."
            },
            {
              "language": "tr",
              "text": "Şirket yabancı müşterilerle çalışıyor."
            }
          ]
        }
      ]
