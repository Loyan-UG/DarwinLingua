          "language": "sq",
          "text": "të fikësh; të caktosh"
        },
        {
          "language": "tr",
          "text": "kapatmak; kararlaştırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du bitte das Licht ausmachen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك إطفاء الضوء من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت تکایە ڕووناکییەکە بکوژێنیتەوە؟"
            },
            {
              "language": "en",
              "text": "Can you please turn off the light?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً چراغ را خاموش کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî ji kerema xwe ronahiyê vemirînî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz wyłączyć światło?"
            },
            {
              "language": "ro",
              "text": "Poți, te rog, să stingi lumina?"
            },
            {
              "language": "ru",
              "text": "Можешь, пожалуйста, выключить свет?"
            },
            {
              "language": "sq",
              "text": "A mund ta fikësh dritën, të lutem?"
            },
            {
              "language": "tr",
              "text": "Lütfen ışığı kapatabilir misin?"
            }
          ]
        },
        {
          "baseText": "Wir machen einen Termin für Montag aus.",
          "translations": [
            {
              "language": "ar",
              "text": "نحدد موعداً ليوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "کاتێک بۆ دووشەممە ڕێکدەخەین."
            },
            {
              "language": "en",
              "text": "We arrange an appointment for Monday."
            },
            {
              "language": "fa",
              "text": "برای دوشنبه یک وقت تعیین می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em ji bo duşemê wextekê li hev dikin."
            },
            {
              "language": "pl",
              "text": "Ustalamy termin na poniedziałek."
            },
            {
              "language": "ro",
              "text": "Stabilim o programare pentru luni."
            },
            {
              "language": "ru",
              "text": "Мы договариваемся о встрече на понедельник."
            },
            {
              "language": "sq",
              "text": "Caktojmë një takim për të hënën."
            },
            {
              "language": "tr",
              "text": "Pazartesi için bir randevu ayarlıyoruz."
            }
          ]
        }
      ]
    },
