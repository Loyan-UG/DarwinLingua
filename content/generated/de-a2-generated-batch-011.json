        {
          "language": "ar",
          "text": "يطفئ؛ يتفق على موعد"
        },
        {
          "language": "ckb",
          "text": "کوژاندنەوە؛ ڕێککەوتن لەسەر کاتێک"
        },
        {
          "language": "en",
          "text": "to switch off; to arrange"
        },
        {
          "language": "fa",
          "text": "خاموش کردن؛ قرار گذاشتن"
        },
        {
          "language": "kmr",
          "text": "vemirandin; li hev kirin"
        },
        {
          "language": "pl",
          "text": "wyłączyć; ustalić"
        },
        {
          "language": "ro",
          "text": "a opri; a stabili"
        },
        {
          "language": "ru",
          "text": "выключать; договариваться"
