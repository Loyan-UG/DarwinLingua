      "examples": [
        {
          "baseText": "Wer die Gebühr nicht zahlen kann, kann eine Härtefallregelung beantragen.",
          "translations": [
            {
              "language": "ar",
              "text": "من لا يستطيع دفع الرسوم يمكنه طلب استثناء للحالات الصعبة."
            },
            {
              "language": "ckb",
              "text": "ئەوەی ناتوانێت کرێیەکە بدات، دەتوانێت داوای ڕێسای حاڵەتی قورس بکات."
            },
            {
              "language": "en",
              "text": "Anyone who cannot pay the fee can apply for a hardship provision."
            },
            {
              "language": "fa",
              "text": "کسی که نمی‌تواند هزینه را بپردازد، می‌تواند برای مقررات موارد سخت درخواست بدهد."
            },
            {
              "language": "kmr",
              "text": "Kesê nikare heqê bide, dikare ji bo rêziknameya rewşên dijwar daxwaz bike."
            },
            {
              "language": "pl",
              "text": "Kto nie może zapłacić opłaty, może złożyć wniosek o zastosowanie regulacji dla trudnych przypadków."
            },
            {
              "language": "ro",
              "text": "Cine nu poate plăti taxa poate solicita aplicarea reglementării pentru cazuri dificile."
            },
            {
              "language": "ru",
              "text": "Тот, кто не может оплатить сбор, может подать заявление на применение правила для трудных случаев."
            },
            {
              "language": "sq",
              "text": "Kush nuk mund ta paguajë tarifën, mund të aplikojë për rregulloren e rasteve të vështira."
            },
            {
              "language": "tr",
              "text": "Ücreti ödeyemeyen kişi zor durum düzenlemesi için başvurabilir."
            }
          ]
        },
        {
          "baseText": "Die Härtefallregelung gilt nur, wenn die persönliche Situation gut erklärt wird.",
          "translations": [
            {
              "language": "ar",
              "text": "تسري قاعدة الحالات الصعبة فقط إذا تم شرح الوضع الشخصي جيداً."
            },
            {
              "language": "ckb",
              "text": "ڕێسای حاڵەتی قورس تەنها کاتێک کارپێدەکرێت کە بارودۆخی کەسی بە باشی ڕوون بکرێتەوە."
            },
            {
              "language": "en",
              "text": "The hardship provision applies only if the personal situation is explained well."
            },
            {
              "language": "fa",
              "text": "مقررات موارد سخت فقط وقتی اعمال می‌شود که وضعیت شخصی خوب توضیح داده شود."
            },
            {
              "language": "kmr",
              "text": "Ev rêzikname tenê hingê derbas dibe ku rewşa kesane baş bê ravekirin."
            },
            {
              "language": "pl",
              "text": "Regulacja dla trudnych przypadków obowiązuje tylko wtedy, gdy sytuacja osobista jest dobrze wyjaśniona."
            },
            {
              "language": "ro",
              "text": "Reglementarea pentru cazuri dificile se aplică doar dacă situația personală este bine explicată."
            },
            {
              "language": "ru",
              "text": "Положение о трудных случаях применяется только если личная ситуация хорошо объяснена."
            },
            {
              "language": "sq",
              "text": "Rregullorja për rastet e vështira vlen vetëm nëse situata personale shpjegohet mirë."
            },
            {
              "language": "tr",
              "text": "Zor durum düzenlemesi yalnızca kişisel durum iyi açıklanırsa geçerlidir."
            }
          ]
        }
