  "entries": [
    {
      "word": "die Gruppe",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Gruppen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Grup-pe",
      "topics": [
        "work-and-jobs",
        "education-and-training",
        "social-and-relationships"
      ],
      "usageLabels": [
        "everyday",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; a set of people or things"
      ],
      "collocations": [
        {
          "text": "in einer Gruppe arbeiten",
          "meaning": "to work in a group"
        },
        {
          "text": "eine Gruppe bilden",
          "meaning": "to form a group"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gruppieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Gruppierung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مجموعة؛ فريق"
        },
        {
          "language": "ckb",
          "text": "گرووپ؛ کۆمەڵە"
        },
        {
          "language": "en",
          "text": "group; team"
        },
        {
          "language": "fa",
          "text": "گروه؛ دسته"
        },
        {
          "language": "kmr",
          "text": "kom; grup"
        },
        {
          "language": "pl",
          "text": "grupa"
        },
        {
          "language": "ro",
          "text": "grup"
        },
        {
          "language": "ru",
          "text": "группа"
        },
        {
          "language": "sq",
          "text": "grup"
        },
        {
          "language": "tr",
          "text": "grup"
        }
      ],
      "examples": [
        {
          "baseText": "Die Gruppe trifft sich jeden Dienstag zur Projektbesprechung.",
          "translations": [
            {
              "language": "ar",
              "text": "تلتقي المجموعة كل يوم ثلاثاء لمناقشة المشروع."
            },
            {
              "language": "ckb",
              "text": "گرووپەکە هەموو سێشەممەیەک بۆ گفتوگۆی پڕۆژەکە کۆدەبێتەوە."
            },
            {
              "language": "en",
              "text": "The group meets every Tuesday for the project discussion."
            },
            {
              "language": "fa",
              "text": "گروه هر سه‌شنبه برای جلسه پروژه دور هم جمع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Grup her sêşemê ji bo gotûbêja projeyê dicive."
            },
            {
              "language": "pl",
              "text": "Grupa spotyka się w każdy wtorek na omówienie projektu."
            },
            {
              "language": "ro",
              "text": "Grupul se întâlnește în fiecare marți pentru discuția despre proiect."
            },
            {
              "language": "ru",
              "text": "Группа встречается каждый вторник для обсуждения проекта."
            },
            {
              "language": "sq",
              "text": "Grupi takohet çdo të martë për diskutimin e projektit."
            },
            {
              "language": "tr",
              "text": "Grup her salı proje görüşmesi için buluşur."
            }
          ]
        },
        {
          "baseText": "Im Sprachkurs arbeitet jede Gruppe an einer kurzen Präsentation.",
          "translations": [
            {
              "language": "ar",
              "text": "في دورة اللغة تعمل كل مجموعة على عرض تقديمي قصير."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسی زماندا هەر گرووپێک لەسەر پێشکەشکارییەکی کورت کار دەکات."
            },
            {
              "language": "en",
              "text": "In the language course, each group works on a short presentation."
            },
            {
              "language": "fa",
              "text": "در کلاس زبان، هر گروه روی یک ارائه کوتاه کار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di kursa ziman de her grup li ser pêşkêşkirineke kurt dixebite."
            },
            {
              "language": "pl",
              "text": "Na kursie językowym każda grupa pracuje nad krótką prezentacją."
            },
            {
              "language": "ro",
              "text": "La cursul de limbă, fiecare grup lucrează la o prezentare scurtă."
            },
            {
              "language": "ru",
              "text": "На языковом курсе каждая группа работает над короткой презентацией."
            },
            {
              "language": "sq",
              "text": "Në kursin e gjuhës çdo grup punon për një prezantim të shkurtër."
            },
            {
              "language": "tr",
              "text": "Dil kursunda her grup kısa bir sunum üzerinde çalışır."
            }
          ]
        }
      ]
    },
    {
      "word": "hängen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "hängen",
      "pronunciationIpa": null,
      "syllableBreak": "hän-gen",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "technology-and-it"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb; can mean to hang or to be stuck, depending on context"
      ],
      "collocations": [
        {
          "text": "an der Wand hängen",
          "meaning": "to hang on the wall"
        },
        {
          "text": "im System hängen",
          "meaning": "to be stuck in the system"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "aufhängen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "abhängen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعلّق؛ يكون عالقاً"
        },
        {
          "language": "ckb",
          "text": "هەڵواسان؛ گیر بوون"
        },
        {
          "language": "en",
          "text": "to hang; to be stuck"
        },
        {
          "language": "fa",
          "text": "آویزان بودن؛ گیر کردن"
        },
        {
          "language": "kmr",
          "text": "daleqandin; asê mayîn"
        },
        {
          "language": "pl",
          "text": "wisieć; zawiesić się"
        },
        {
          "language": "ro",
          "text": "a atârna; a se bloca"
        },
        {
          "language": "ru",
          "text": "висеть; зависать"
        },
        {
          "language": "sq",
          "text": "të varet; të ngecë"
        },
        {
          "language": "tr",
          "text": "asılı olmak; takılı kalmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Antrag hängt noch im System, weil eine Unterschrift fehlt.",
          "translations": [
            {
              "language": "ar",
              "text": "ما زال الطلب عالقاً في النظام لأن توقيعاً ينقصه."
            },
            {
              "language": "ckb",
              "text": "داواکارییەکە هێشتا لە سیستەمەکەدا گیرە، چونکە واژۆیەک کەمە."
            },
            {
              "language": "en",
              "text": "The application is still stuck in the system because a signature is missing."
            },
            {
              "language": "fa",
              "text": "درخواست هنوز در سیستم گیر کرده، چون یک امضا کم است."
            },
            {
              "language": "kmr",
              "text": "Daxwazname hîn di pergalê de asê maye, ji ber ku îmzayek kêm e."
            },
            {
              "language": "pl",
              "text": "Wniosek nadal utknął w systemie, ponieważ brakuje podpisu."
            },
            {
              "language": "ro",
              "text": "Cererea este încă blocată în sistem, deoarece lipsește o semnătură."
            },
            {
              "language": "ru",
              "text": "Заявка всё ещё зависла в системе, потому что не хватает подписи."
            },
            {
              "language": "sq",
              "text": "Aplikimi është ende i bllokuar në sistem, sepse mungon një nënshkrim."
            },
            {
              "language": "tr",
              "text": "Başvuru, bir imza eksik olduğu için hâlâ sistemde takılı kaldı."
            }
          ]
        },
        {
          "baseText": "Im Flur hängt ein Plan mit allen wichtigen Telefonnummern.",
          "translations": [
            {
              "language": "ar",
              "text": "في الممر معلّقة خطة تحتوي على كل أرقام الهاتف المهمة."
            },
            {
              "language": "ckb",
              "text": "لە ڕاڕەوەکەدا پلانیەک هەڵواسراوە کە هەموو ژمارە تەلەفۆنە گرنگەکانی تێدایە."
            },
            {
              "language": "en",
              "text": "In the hallway, there is a plan hanging with all important phone numbers."
            },
            {
              "language": "fa",
              "text": "در راهرو یک برنامه با همه شماره‌های تلفن مهم آویزان است."
            },
            {
              "language": "kmr",
              "text": "Di korîdorê de planek bi hemû hejmarên telefonê yên girîng daleqandî ye."
            },
            {
              "language": "pl",
              "text": "Na korytarzu wisi plan ze wszystkimi ważnymi numerami telefonów."
            },
            {
              "language": "ro",
              "text": "Pe hol atârnă un plan cu toate numerele de telefon importante."
            },
            {
              "language": "ru",
              "text": "В коридоре висит план со всеми важными телефонными номерами."
            },
            {
              "language": "sq",
              "text": "Në korridor varet një plan me të gjithë numrat e rëndësishëm të telefonit."
            },
            {
              "language": "tr",
              "text": "Koridorda tüm önemli telefon numaralarını içeren bir plan asılı."
            }
          ]
        }
      ]
    },
