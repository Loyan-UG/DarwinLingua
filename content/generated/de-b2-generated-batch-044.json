  "entries": [
    {
      "word": "angleichen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "angleichen",
      "pronunciationIpa": null,
      "syllableBreak": "an-glei-chen",
      "topics": [
        "work-and-jobs",
        "quality-and-risk",
        "management-and-leadership"
      ],
      "usageLabels": [
        "workplace",
        "written",
        "technical"
      ],
      "contextLabels": [
        "management",
        "quality"
      ],
      "grammarNotes": [
        "separable verb"
      ],
      "collocations": [
        {
          "text": "die Datenmodelle angleichen",
          "meaning": "to align data models"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعدّل/يحاذي"
        },
        {
          "language": "ckb",
          "text": "هاوکاتکردن"
        },
        {
          "language": "en",
          "text": "to align; to adjust"
        },
        {
          "language": "fa",
          "text": "هماهنگ کردن؛ تنظیم کردن"
        },
        {
          "language": "kmr",
          "text": "hevxistin"
        },
        {
          "language": "pl",
          "text": "wyrównywać; dostosować"
        },
        {
          "language": "ro",
          "text": "a alinia; a ajusta"
        },
        {
          "language": "ru",
          "text": "согласовывать; выравнивать"
        },
        {
          "language": "sq",
          "text": "përputhje; rregullim"
        },
        {
          "language": "tr",
          "text": "uyumlaştırmak; ayarlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir angleichen die Datenmodelle der API mit den Anforderungen der Bank vor dem nächsten Release.",
          "translations": [
            {
              "language": "ar",
              "text": "نقوم بضبط نماذج بيانات الواجهة البرمجية لتتوافق مع متطلبات البنك قبل الإصدار القادم."
            },
            {
              "language": "ckb",
              "text": "پێش بەرهەمهێنانی دووەمەوە، ئێمە وەستانی داتاکەی API لەگەڵ پێویستەکانی بانکەکە هاوکات دەکەین."
            },
            {
              "language": "en",
              "text": "We align the API data models with the bank's requirements before the next release."
            },
            {
              "language": "fa",
              "text": "پیش از انتشار بعدی، مدل‌های داده API را با الزامات بانک هم‌راستا می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Pêş azadkirina ya pêşîn em modelên daneyê API bi pêdiviyên bankê re hevxistin."
            },
            {
              "language": "pl",
              "text": "Dopasowujemy modele danych API do wymagań banku przed kolejnym wydaniem."
            },
            {
              "language": "ro",
              "text": "Aliniem modelele de date ale API-ului cu cerințele băncii înainte de următorul release."
            },
            {
              "language": "ru",
              "text": "Перед следующим релизом согласуем модели данных API с требованиями банка."
            },
            {
              "language": "sq",
              "text": "Modelet e të dhënave të API-t i përshtatim me kërkesat e bankës para publikimit të radhës."
            },
            {
              "language": "tr",
              "text": "Bir sonraki sürümden önce API veri modellerini bankanın gereksinimleriyle uyumlu hâle getiriyoruz."
            }
          ]
        },
        {
          "baseText": "Wir haben die Projektziele angeglichen, damit alle Teams denselben Qualitätsstandard haben.",
          "translations": [
            {
              "language": "ar",
              "text": "قمنا بمحاذاة أهداف المشروع حتى يكون لدى جميع الفرق نفس معيار الجودة."
            },
            {
              "language": "ckb",
              "text": "ئامانجی پڕۆژەکە هاوكرداوە تا هەموو تیمەکان هەمان ستانداردی کوالێتی هەبێت."
            },
            {
              "language": "en",
              "text": "We aligned project goals so all teams share the same quality standard."
            },
            {
              "language": "fa",
              "text": "اهداف پروژه را هماهنگ کردیم تا همه تیم‌ها استاندارد کیفیت یکسانی داشته باشند."
            },
            {
              "language": "kmr",
              "text": "Em armancên projeyê bi hevxistin da ku hemû tîman standardek yekam a kalîteyê hebin."
            },
            {
              "language": "pl",
              "text": "Wyrównaliśmy cele projektu, aby wszystkie zespoły miały ten sam standard jakości."
            },
            {
              "language": "ro",
              "text": "Am aliniat obiectivele proiectului astfel încât toate echipele să aibă același standard de calitate."
            },
            {
              "language": "ru",
              "text": "Мы согласовали цели проекта, чтобы все команды имели единый стандарт качества."
            },
            {
              "language": "sq",
              "text": "Ne objektivat e projektit i kemi përshtatur që të gjitha ekipet të kenë të njëjtin standard cilësie."
            },
            {
              "language": "tr",
              "text": "Tüm ekiplerin aynı kalite standardına sahip olması için proje hedeflerini uyumlaştırdık."
            }
          ]
        }
      ]
    },
    {
      "word": "die Annahme",
      "language": "de",
      "cefrLevel": "B2",
