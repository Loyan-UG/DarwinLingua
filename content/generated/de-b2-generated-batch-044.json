      "collocations": [
        {
          "text": "die Annahme prüfen",
          "meaning": "to test an assumption"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "القبول؛ الافتراض"
        },
        {
          "language": "ckb",
          "text": "پەسەندکردن / وەها"
        },
        {
          "language": "en",
          "text": "acceptance; assumption"
        },
        {
          "language": "fa",
          "text": "پذیرش؛ فرض"
        },
        {
          "language": "kmr",
          "text": "qebûl; têgehînî"
        },
        {
          "language": "pl",
          "text": "akceptacja; założenie"
        },
        {
          "language": "ro",
          "text": "acceptare; presupunere"
        },
        {
          "language": "ru",
          "text": "принятие; допущение"
        },
        {
          "language": "sq",
          "text": "pranim; supozim"
        },
        {
          "language": "tr",
          "text": "kabul; varsayım"
        }
      ],
      "examples": [
        {
          "baseText": "Die Annahme im Vertrag müssen beide Parteien schriftlich bestätigen.",
          "translations": [
            {
              "language": "ar",
              "text": "تتوجب على الطرفين تأكيد الافتراضات في العقد كتابيًا."
            },
            {
              "language": "ckb",
              "text": "پێشەنگەکانی ڕەزامەندیەکە دەبێت لە هەردوو لاکانەوە بە وشەی نووسراو پشتڕاست بکرێت."
            },
            {
              "language": "en",
              "text": "The assumptions in the contract must be confirmed in writing by both parties."
            },
            {
              "language": "fa",
              "text": "فرض‌های قرارداد باید توسط هر دو طرف به شکل مکتوب تأیید شوند."
            },
            {
              "language": "kmr",
              "text": "Qebûlên peymanê divê bi nivîsara her du aliyên re hatin pejirandin."
            },
