          "text": "udhëtim kthimi"
        },
        {
          "language": "tr",
          "text": "dönüş yolculuğu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rückfahrt beginnt um 17 Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدأ رحلة العودة في الساعة الخامسة مساءً."
            },
            {
              "language": "ckb",
              "text": "گەڕانەوەکە کاتژمێر ١٧ دەست پێ دەکات."
            },
            {
              "language": "en",
              "text": "The return trip starts at 5 p.m."
            },
            {
              "language": "fa",
              "text": "مسیر برگشت ساعت ۱۷ شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Vegera rêwîtiyê di saet 17 de dest pê dike."
            },
            {
              "language": "pl",
              "text": "Podróż powrotna zaczyna się o 17."
            },
            {
              "language": "ro",
              "text": "Drumul de întoarcere începe la ora 17."
            },
            {
              "language": "ru",
              "text": "Обратная поездка начинается в 17:00."
            },
            {
              "language": "sq",
              "text": "Udhëtimi i kthimit fillon në orën 17."
            },
            {
              "language": "tr",
              "text": "Dönüş yolculuğu saat 17’de başlıyor."
            }
          ]
        },
        {
          "baseText": "Für die Rückfahrt brauchen wir neue Tickets.",
          "translations": [
            {
              "language": "ar",
              "text": "لرحلة العودة نحتاج إلى تذاكر جديدة."
            },
            {
              "language": "ckb",
              "text": "بۆ گەڕانەوە پێویستمان بە بلیتی نوێ هەیە."
            },
            {
              "language": "en",
              "text": "For the return trip we need new tickets."
            },
            {
              "language": "fa",
              "text": "برای برگشت به بلیت‌های جدید نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo vegerê bilêtên nû divê me bin."
            },
            {
              "language": "pl",
              "text": "Na podróż powrotną potrzebujemy nowych biletów."
            },
            {
              "language": "ro",
              "text": "Pentru întoarcere avem nevoie de bilete noi."
            },
            {
              "language": "ru",
              "text": "Для обратной поездки нам нужны новые билеты."
            },
            {
              "language": "sq",
              "text": "Për kthimin na duhen bileta të reja."
            },
            {
              "language": "tr",
              "text": "Dönüş için yeni biletlere ihtiyacımız var."
            }
          ]
        }
      ]
