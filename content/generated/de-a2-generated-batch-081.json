      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يشم؛ تكون له رائحة"
        },
        {
          "language": "ckb",
          "text": "بۆن کردن؛ بۆن هەبوون"
        },
        {
          "language": "en",
          "text": "to smell"
        },
        {
          "language": "fa",
          "text": "بو کردن؛ بو دادن"
        },
        {
          "language": "kmr",
          "text": "bîn kirin; bêhn dan"
        },
        {
          "language": "pl",
          "text": "pachnieć; wąchać"
        },
        {
          "language": "ro",
          "text": "a mirosi; a avea miros"
        },
        {
          "language": "ru",
          "text": "пахнуть; нюхать"
        },
        {
          "language": "sq",
          "text": "nuhas; mbaj erë"
        },
        {
          "language": "tr",
          "text": "kokmak; koklamak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Suppe riecht sehr gut.",
          "translations": [
            {
              "language": "ar",
              "text": "رائحة الحساء جيدة جداً."
            },
            {
              "language": "ckb",
              "text": "شۆرباکە زۆر بۆنی خۆشە."
            },
            {
              "language": "en",
              "text": "The soup smells very good."
            },
            {
              "language": "fa",
              "text": "سوپ خیلی خوش‌بو است."
            },
            {
              "language": "kmr",
              "text": "Şorbe gelek baş bêhn dide."
            },
            {
              "language": "pl",
              "text": "Zupa bardzo ładnie pachnie."
            },
            {
              "language": "ro",
              "text": "Supa miroase foarte bine."
            },
            {
              "language": "ru",
              "text": "Суп очень хорошо пахнет."
            },
            {
              "language": "sq",
              "text": "Supa mban erë shumë të mirë."
            },
            {
              "language": "tr",
              "text": "Çorba çok güzel kokuyor."
            }
          ]
        },
        {
          "baseText": "Ich kann die Blumen im Garten riechen.",
          "translations": [
            {
              "language": "ar",
              "text": "أستطيع شم الزهور في الحديقة."
            },
            {
              "language": "ckb",
              "text": "دەتوانم بۆنی گوڵەکانی باخچە بکەم."
            },
            {
              "language": "en",
              "text": "I can smell the flowers in the garden."
            },
            {
              "language": "fa",
              "text": "می‌توانم گل‌های باغ را بو کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dikarim kulîlkên li baxçe bîn bikim."
            },
            {
              "language": "pl",
              "text": "Czuję zapach kwiatów w ogrodzie."
            },
            {
              "language": "ro",
              "text": "Pot mirosi florile din grădină."
            },
            {
              "language": "ru",
              "text": "Я чувствую запах цветов в саду."
            },
            {
              "language": "sq",
              "text": "Mund t’i nuhas lulet në kopsht."
            },
            {
              "language": "tr",
              "text": "Bahçedeki çiçekleri koklayabiliyorum."
            }
          ]
        }
      ]
