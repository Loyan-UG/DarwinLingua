            {
              "language": "ckb",
              "text": "چاوەڕێی وەڵامی مامۆستای کۆرسەکەم."
            },
            {
              "language": "en",
              "text": "I am waiting for feedback from the course instructor."
            },
            {
              "language": "fa",
