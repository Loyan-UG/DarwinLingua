            {
              "language": "fa",
              "text": "از پاسخ سریع شما متشکرم."
            },
            {
              "language": "kmr",
              "text": "Spas ji bo bersiva we ya bilez."
            },
            {
              "language": "pl",
              "text": "Dziękuję za szybką odpowiedź."
