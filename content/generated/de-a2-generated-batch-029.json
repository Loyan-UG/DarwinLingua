      ],
      "collocations": [
        {
          "text": "jemanden zum Essen einladen",
          "meaning": "to invite someone to dinner"
        },
        {
          "text": "zu einem Meeting einladen",
          "meaning": "to invite to a meeting"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Einladung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدعو"
        },
        {
          "language": "ckb",
          "text": "بانگهێشتکردن"
        },
        {
          "language": "en",
          "text": "to invite"
        },
        {
          "language": "fa",
          "text": "دعوت کردن"
        },
        {
          "language": "kmr",
          "text": "vexwendin"
        },
        {
          "language": "pl",
          "text": "zaprosić"
        },
        {
          "language": "ro",
          "text": "a invita"
        },
        {
          "language": "ru",
          "text": "приглашать"
        },
        {
          "language": "sq",
          "text": "të ftosh"
        },
        {
          "language": "tr",
          "text": "davet etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich lade meine Freunde am Samstag zum Essen ein.",
          "translations": [
            {
              "language": "ar",
              "text": "أدعو أصدقائي يوم السبت إلى الطعام."
            },
            {
              "language": "ckb",
              "text": "شەممە هاوڕێکانم بۆ خواردن بانگهێشت دەکەم."
            },
            {
              "language": "en",
              "text": "I invite my friends to dinner on Saturday."
            },
            {
              "language": "fa",
              "text": "شنبه دوستانم را برای غذا دعوت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez roja şemiyê hevalên xwe vexwendina xwarinê dikim."
            },
            {
              "language": "pl",
              "text": "W sobotę zapraszam przyjaciół na jedzenie."
            },
            {
              "language": "ro",
              "text": "Îmi invit prietenii la masă sâmbătă."
            },
            {
              "language": "ru",
              "text": "В субботу я приглашаю друзей на ужин."
            },
            {
              "language": "sq",
              "text": "Të shtunën i ftoj miqtë për darkë."
            },
            {
              "language": "tr",
              "text": "Cumartesi arkadaşlarımı yemeğe davet ediyorum."
            }
          ]
        },
        {
          "baseText": "Die Kollegin lädt uns zu einem kurzen Meeting ein.",
          "translations": [
            {
              "language": "ar",
              "text": "تدعونا الزميلة إلى اجتماع قصير."
            },
            {
              "language": "ckb",
              "text": "هاوکارە ژنەکە بانگهێشتمان دەکات بۆ کۆبوونەوەیەکی کورت."
            },
            {
              "language": "en",
              "text": "The colleague invites us to a short meeting."
            },
            {
              "language": "fa",
              "text": "همکارمان ما را به یک جلسه کوتاه دعوت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Hevkar me ji bo civînek kurt vedixwîne."
            },
            {
              "language": "pl",
              "text": "Koleżanka zaprasza nas na krótkie spotkanie."
            },
            {
              "language": "ro",
              "text": "Colega ne invită la o ședință scurtă."
            },
            {
              "language": "ru",
              "text": "Коллега приглашает нас на короткую встречу."
            },
            {
              "language": "sq",
              "text": "Kolegia na fton në një takim të shkurtër."
            },
            {
              "language": "tr",
              "text": "İş arkadaşımız bizi kısa bir toplantıya davet ediyor."
            }
          ]
        }
      ]
    },
