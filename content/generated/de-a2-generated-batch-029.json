        }
      ],
      "examples": [
        {
          "baseText": "Können Sie das Geschenk bitte einpacken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم تغليف الهدية من فضلكم؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن تکایە دیارییەکە بپێچنەوە؟"
            },
            {
              "language": "en",
              "text": "Can you please wrap the present?"
            },
            {
              "language": "fa",
              "text": "می‌توانید لطفاً هدیه را بسته‌بندی کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji kerema xwe diyarîyê pêçin?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan/Pani zapakować prezent?"
            },
            {
              "language": "ro",
              "text": "Puteți, vă rog, să împachetați cadoul?"
            },
            {
              "language": "ru",
              "text": "Можете, пожалуйста, упаковать подарок?"
            },
            {
              "language": "sq",
              "text": "A mund ta paketoni dhuratën, ju lutem?"
            },
            {
              "language": "tr",
              "text": "Hediyeyi lütfen paketleyebilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Ich packe heute Abend meinen Koffer ein.",
          "translations": [
            {
              "language": "ar",
              "text": "سأحزم حقيبتي هذا المساء."
            },
            {
              "language": "ckb",
              "text": "ئەم ئێوارەیە جانتاکەم ئامادە دەکەم."
            },
            {
              "language": "en",
              "text": "I am packing my suitcase this evening."
            },
            {
              "language": "fa",
              "text": "امشب چمدانم را می‌بندم."
            },
            {
              "language": "kmr",
              "text": "Ez îşev çenteya xwe pakêt dikim."
            },
            {
              "language": "pl",
              "text": "Dziś wieczorem pakuję walizkę."
            },
            {
              "language": "ro",
              "text": "În seara aceasta îmi fac bagajul."
            },
            {
              "language": "ru",
              "text": "Сегодня вечером я пакую чемодан."
            },
            {
              "language": "sq",
              "text": "Sonte e paketoj valixhen time."
            },
            {
              "language": "tr",
              "text": "Bu akşam valizimi hazırlıyorum."
            }
          ]
        }
      ]
