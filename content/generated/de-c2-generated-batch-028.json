  "entries": [
    {
      "word": "enthüllen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "enthüllen",
      "pronunciationIpa": null,
      "syllableBreak": "ent-hül-len",
      "topics": [
        "business-communication",
        "culture-and-media",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "transitive verb; enthüllt, enthüllte, hat enthüllt; to reveal or unveil"
      ],
      "collocations": [
        {
          "text": "neue Details enthüllen",
          "meaning": "to reveal new details"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Enthüllung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يكشف؛ يزيح الستار عن"
        },
        {
          "language": "ckb",
          "text": "ئاشکرا بکات؛ پەردە لەسەر شتێک لاببات"
        },
        {
          "language": "en",
          "text": "to reveal; to unveil"
        },
        {
          "language": "fa",
          "text": "آشکار کردن؛ پرده برداشتن از"
        },
        {
          "language": "kmr",
          "text": "eşkere kirin; perde rakirin"
        },
        {
          "language": "pl",
          "text": "ujawnić; odsłonić"
        },
        {
          "language": "ro",
          "text": "a dezvălui; a revela"
        },
        {
          "language": "ru",
          "text": "раскрывать; обнародовать"
        },
        {
          "language": "sq",
          "text": "të zbulojë; të shpalosë"
        },
        {
          "language": "tr",
          "text": "açığa çıkarmak; ortaya koymak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Auditbericht enthüllte, dass mehrere Freigaben ohne dokumentierte Prüfung erteilt worden waren.",
          "translations": [
            {
              "language": "ar",
              "text": "كشف تقرير التدقيق أن عدة موافقات مُنحت من دون فحص موثق."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتی وردبینی ئاشکرای کرد کە چەند پەسەندکردنێک بەبێ پشکنینی بەڵگەکراو درابوو."
            },
            {
              "language": "en",
              "text": "The audit report revealed that several approvals had been granted without documented review."
            },
            {
              "language": "fa",
              "text": "گزارش حسابرسی آشکار کرد که چندین تأیید بدون بررسی مستند صادر شده بود."
            },
            {
              "language": "kmr",
              "text": "Rapora kontrolê eşkere kir ku çend pejirandin bê vekolîna belgekirî hatibûn dayîn."
            },
            {
              "language": "pl",
              "text": "Raport audytowy ujawnił, że kilka zgód wydano bez udokumentowanej kontroli."
            },
            {
              "language": "ro",
              "text": "Raportul de audit a dezvăluit că mai multe aprobări fuseseră acordate fără verificare documentată."
            },
            {
              "language": "ru",
              "text": "Аудиторский отчёт выявил, что несколько согласований были выданы без документированной проверки."
            },
            {
              "language": "sq",
              "text": "Raporti i auditimit zbuloi se disa miratime ishin dhënë pa kontroll të dokumentuar."
            },
            {
              "language": "tr",
              "text": "Denetim raporu, birkaç onayın belgelenmiş inceleme olmadan verildiğini ortaya koydu."
            }
          ]
        },
        {
          "baseText": "Die Ausstellung enthüllt unter der restaurierten Oberfläche ältere Farbschichten.",
          "translations": [
            {
              "language": "ar",
              "text": "يكشف المعرض تحت السطح المرمم طبقات لون أقدم."
            },
            {
              "language": "ckb",
              "text": "پێشانگاکە لە ژێر ڕووی نۆژەنکراودا چینە ڕەنگی کۆنتر ئاشکرا دەکات."
            },
            {
              "language": "en",
              "text": "The exhibition reveals older layers of paint beneath the restored surface."
            },
            {
              "language": "fa",
              "text": "نمایشگاه زیر سطح مرمت‌شده، لایه‌های قدیمی‌تر رنگ را آشکار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pêşangeh di bin rûyê nûkirî de qatên kevntir ên rengê eşkere dike."
            },
            {
              "language": "pl",
              "text": "Wystawa odsłania starsze warstwy farby pod odrestaurowaną powierzchnią."
            },
            {
              "language": "ro",
              "text": "Expoziția dezvăluie straturi mai vechi de vopsea sub suprafața restaurată."
            },
            {
              "language": "ru",
              "text": "Выставка раскрывает более старые слои краски под отреставрированной поверхностью."
            },
            {
              "language": "sq",
              "text": "Ekspozita zbulon shtresa më të vjetra ngjyre nën sipërfaqen e restauruar."
            },
            {
              "language": "tr",
              "text": "Sergi, restore edilmiş yüzeyin altında daha eski boya katmanlarını ortaya çıkarır."
            }
          ]
        }
      ]
    },
    {
      "word": "entlarven",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entlarven",
      "pronunciationIpa": null,
      "syllableBreak": "ent-lar-ven",
      "topics": [
        "law-and-compliance",
        "business-communication",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "transitive verb; entlarvt, entlarvte, hat entlarvt; to expose something/someone as false or deceptive"
      ],
      "collocations": [
        {
          "text": "eine Täuschung entlarven",
          "meaning": "to expose a deception"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Entlarvung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Larve",
          "relationLabel": "noun",
          "note": "historically mask"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفضح؛ يكشف الزيف"
        },
        {
          "language": "ckb",
          "text": "ڕیسوا بکات؛ ساختەیی ئاشکرا بکات"
        },
        {
          "language": "en",
          "text": "to expose; to unmask"
        },
        {
          "language": "fa",
          "text": "رسوا کردن؛ نقاب از چهره برداشتن"
        },
        {
          "language": "kmr",
          "text": "rûpoş rakirin; derew eşkere kirin"
        },
        {
          "language": "pl",
          "text": "zdemaskować; obnażyć"
        },
        {
          "language": "ro",
          "text": "a demasca; a expune"
        },
        {
          "language": "ru",
          "text": "разоблачать; снимать маску"
        },
        {
          "language": "sq",
          "text": "të demaskosh; të nxjerrësh zbuluar"
        },
        {
          "language": "tr",
          "text": "maskesini düşürmek; ifşa etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die interne Untersuchung entlarvte die angebliche Kostenersparnis als reine Verschiebung von Risiken.",
          "translations": [
            {
              "language": "ar",
              "text": "فضح التحقيق الداخلي التوفير المزعوم في التكاليف بوصفه مجرد نقل للمخاطر."
            },
            {
              "language": "ckb",
              "text": "لێکۆڵینەوەی ناوخۆیی کەمکردنەوەی تێچووی بانگەشەکراوی وەک تەنها گواستنەوەی مەترسییەکان ڕیسوا کرد."
            },
            {
              "language": "en",
              "text": "The internal investigation exposed the alleged cost savings as merely a shift of risks."
            },
            {
              "language": "fa",
              "text": "بررسی داخلی صرفه‌جویی ادعایی را به‌عنوان صرفاً جابه‌جایی ریسک‌ها رسوا کرد."
            },
            {
              "language": "kmr",
              "text": "Lêpirsîna hundirîn kêmkirina lêçûnê ya gotî wek tenê veguhastina xetereyan eşkere kir."
            },
            {
              "language": "pl",
              "text": "Wewnętrzne dochodzenie zdemaskowało rzekome oszczędności jako zwykłe przesunięcie ryzyk."
            },
            {
              "language": "ro",
              "text": "Ancheta internă a demascat presupusele economii drept simplă transferare a riscurilor."
            },
            {
              "language": "ru",
              "text": "Внутреннее расследование разоблачило предполагаемую экономию как простое перекладывание рисков."
            },
            {
              "language": "sq",
              "text": "Hetimi i brendshëm e demaskoi kursimin e pretenduar të kostove si thjesht zhvendosje rreziqesh."
            },
            {
              "language": "tr",
              "text": "İç soruşturma, sözde maliyet tasarrufunu yalnızca risklerin yer değiştirmesi olarak ifşa etti."
            }
          ]
        },
        {
          "baseText": "Der Roman entlarvt die höfliche Fassade der Familie als mühsam bewahrte Illusion.",
          "translations": [
            {
              "language": "ar",
              "text": "يفضح roman الواجهة المهذبة للعائلة بوصفها وهماً محفوظاً بصعوبة."
            },
            {
              "language": "ckb",
              "text": "ڕۆمانەکە ڕووی ڕێزلێنانەی خێزانەکە وەک خەیاڵێکی بە زەحمەت پارێزراو ڕیسوا دەکات."
            },
            {
              "language": "en",
              "text": "The novel unmasks the family’s polite façade as a laboriously preserved illusion."
            },
            {
              "language": "fa",
              "text": "رمان نمای مؤدبانه خانواده را به‌عنوان توهمی سخت حفظ‌شده رسوا می‌کند."
            },
            {
              "language": "kmr",
              "text": "Roman rûyê nazik ê malbatê wek xeyalek bi zehmet parastî rûpoş dike."
            },
            {
              "language": "pl",
              "text": "Powieść demaskuje uprzejmą fasadę rodziny jako mozolnie podtrzymywaną iluzję."
            },
            {
              "language": "ro",
              "text": "Romanul demască fațada politicoasă a familiei ca pe o iluzie păstrată cu greu."
            },
            {
              "language": "ru",
              "text": "Роман разоблачает вежливый фасад семьи как с трудом поддерживаемую иллюзию."
            },
            {
              "language": "sq",
              "text": "Romani e demaskon fasadën e sjellshme të familjes si një iluzion të ruajtur me mund."
            },
            {
              "language": "tr",
              "text": "Roman, ailenin kibar cephesini güçlükle korunan bir yanılsama olarak açığa çıkarır."
            }
          ]
        }
      ]
    },
