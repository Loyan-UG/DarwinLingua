  "entries": [
    {
      "word": "unangenehm",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "un-an-ge-nehm",
      "topics": [
        "everyday-life",
        "social-and-relationships",
        "customer-service"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective"
      ],
      "collocations": [
        {
          "text": "eine unangenehme Situation",
          "meaning": "an unpleasant situation"
        },
        {
          "text": "unangenehm riechen",
          "meaning": "to smell unpleasant"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "angenehm",
          "relationLabel": "adjective",
          "note": "opposite"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "غير مريح؛ مزعج"
        },
        {
          "language": "ckb",
          "text": "ناخۆش؛ بێزارکەر"
        },
        {
          "language": "en",
          "text": "unpleasant; uncomfortable"
        },
        {
          "language": "fa",
          "text": "ناخوشایند؛ ناراحت‌کننده"
        },
        {
          "language": "kmr",
          "text": "ne xweş; acizker"
        },
        {
          "language": "pl",
          "text": "nieprzyjemny; krępujący"
        },
        {
          "language": "ro",
          "text": "neplăcut; incomod"
        },
        {
          "language": "ru",
          "text": "неприятный; неудобный"
        },
        {
          "language": "sq",
          "text": "i pakëndshëm; i parehatshëm"
        },
        {
          "language": "tr",
          "text": "rahatsız edici; hoş olmayan"
        }
      ],
      "examples": [
        {
          "baseText": "Das Gespräch mit dem unzufriedenen Kunden war unangenehm, aber nötig.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت المحادثة مع العميل غير الراضي مزعجة، لكنها كانت ضرورية."
            },
            {
              "language": "ckb",
              "text": "گفتوگۆکە لەگەڵ کڕیاری ناڕازی ناخۆش بوو، بەڵام پێویست بوو."
            },
            {
              "language": "en",
              "text": "The conversation with the dissatisfied customer was unpleasant but necessary."
            },
            {
              "language": "fa",
              "text": "گفت‌وگو با مشتری ناراضی ناخوشایند بود، اما لازم بود."
            },
            {
              "language": "kmr",
              "text": "Axaftina bi xerîdarê ne razî re ne xweş bû, lê pêwîst bû."
            },
            {
              "language": "pl",
              "text": "Rozmowa z niezadowolonym klientem była nieprzyjemna, ale konieczna."
            },
            {
              "language": "ro",
              "text": "Discuția cu clientul nemulțumit a fost neplăcută, dar necesară."
            },
            {
              "language": "ru",
              "text": "Разговор с недовольным клиентом был неприятным, но необходимым."
            },
            {
              "language": "sq",
              "text": "Biseda me klientin e pakënaqur ishte e pakëndshme, por e nevojshme."
            },
            {
              "language": "tr",
              "text": "Memnun olmayan müşteriyle görüşme rahatsız ediciydi ama gerekliydi."
            }
          ]
        },
        {
          "baseText": "Im Flur riecht es unangenehm, weil der Müll zu lange dort steht.",
          "translations": [
            {
              "language": "ar",
              "text": "الرائحة في الممر غير مريحة لأن القمامة بقيت هناك طويلًا."
            },
            {
              "language": "ckb",
              "text": "لە ڕاڕەوەکەدا بۆنێکی ناخۆش هەیە چونکە خۆڵەکە زۆر ماوە لەوێیە."
            },
            {
              "language": "en",
              "text": "It smells unpleasant in the hallway because the trash has been there too long."
            },
            {
              "language": "fa",
              "text": "در راهرو بوی ناخوشایندی می‌آید چون زباله مدت زیادی آنجا مانده است."
            },
            {
              "language": "kmr",
              "text": "Li korîdorê bêhneke ne xweş heye ji ber ku zibil zêde li wir maye."
            },
            {
              "language": "pl",
              "text": "Na korytarzu nieprzyjemnie pachnie, bo śmieci stoją tam za długo."
            },
            {
              "language": "ro",
              "text": "Pe hol miroase neplăcut, deoarece gunoiul stă acolo de prea mult timp."
            },
            {
              "language": "ru",
              "text": "В коридоре неприятно пахнет, потому что мусор слишком долго стоит там."
            },
            {
              "language": "sq",
              "text": "Në korridor ka erë të pakëndshme sepse plehrat kanë qëndruar aty shumë gjatë."
            },
            {
              "language": "tr",
              "text": "Koridorda kötü kokuyor çünkü çöp çok uzun süredir orada duruyor."
            }
          ]
        }
      ]
    },
    {
      "word": "unbefristet",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "un-be-fris-tet",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; often used for contracts"
      ],
      "collocations": [
        {
          "text": "ein unbefristeter Vertrag",
          "meaning": "a permanent contract"
        },
        {
          "text": "unbefristet angestellt sein",
          "meaning": "to be employed permanently"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "befristet",
          "relationLabel": "adjective",
          "note": "opposite"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "غير محدد المدة؛ دائم"
        },
        {
          "language": "ckb",
          "text": "بێ سنووری کات؛ هەمیشەیی"
        },
        {
          "language": "en",
          "text": "permanent; unlimited in time"
        },
        {
          "language": "fa",
          "text": "نامحدود از نظر مدت؛ دائمی"
        },
        {
          "language": "kmr",
          "text": "bêdemsînor; domdar"
        },
        {
          "language": "pl",
          "text": "bezterminowy; stały"
        },
        {
          "language": "ro",
          "text": "pe durată nedeterminată; permanent"
        },
        {
          "language": "ru",
          "text": "бессрочный; постоянный"
        },
        {
          "language": "sq",
          "text": "pa afat; i përhershëm"
        },
        {
          "language": "tr",
          "text": "süresiz; kalıcı"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Probezeit bekommt sie einen unbefristeten Arbeitsvertrag.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد فترة التجربة ستحصل على عقد عمل غير محدد المدة."
            },
            {
              "language": "ckb",
              "text": "دوای ماوەی تاقیکردنەوە، گرێبەستی کاری بێ سنووری کات وەردەگرێت."
            },
            {
              "language": "en",
              "text": "After the probation period, she gets a permanent employment contract."
            },
            {
              "language": "fa",
              "text": "بعد از دوره آزمایشی، او قرارداد کاری دائمی می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Piştî dema ceribandinê ew peymana karê bêdemsînor werdigire."
            },
            {
              "language": "pl",
              "text": "Po okresie próbnym dostanie umowę o pracę na czas nieokreślony."
            },
            {
              "language": "ro",
              "text": "După perioada de probă primește un contract de muncă pe durată nedeterminată."
            },
            {
              "language": "ru",
              "text": "После испытательного срока она получит бессрочный трудовой договор."
            },
            {
              "language": "sq",
              "text": "Pas periudhës provuese ajo merr një kontratë pune pa afat."
            },
            {
              "language": "tr",
              "text": "Deneme süresinden sonra süresiz iş sözleşmesi alır."
            }
          ]
        },
        {
          "baseText": "Die Wohnung wird unbefristet vermietet, wenn die Unterlagen vollständig sind.",
          "translations": [
            {
              "language": "ar",
              "text": "تُؤجر الشقة لمدة غير محددة إذا كانت المستندات كاملة."
            },
            {
              "language": "ckb",
              "text": "ئەگەر بەڵگەکان تەواو بن، خانووەکە بە بێ سنووری کات بەکرێ دەدرێت."
            },
            {
              "language": "en",
              "text": "The apartment is rented out without a fixed end date if the documents are complete."
            },
            {
              "language": "fa",
              "text": "اگر مدارک کامل باشند، آپارتمان به‌صورت نامحدود اجاره داده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Heke belge temam bin, xanî bêdemsînor tê kirêdan."
            },
            {
              "language": "pl",
              "text": "Mieszkanie będzie wynajmowane bezterminowo, jeśli dokumenty są kompletne."
            },
            {
              "language": "ro",
              "text": "Apartamentul se închiriază pe durată nedeterminată dacă documentele sunt complete."
            },
            {
              "language": "ru",
              "text": "Квартира сдается бессрочно, если документы полные."
            },
            {
              "language": "sq",
              "text": "Banesa jepet me qira pa afat nëse dokumentet janë të plota."
            },
            {
              "language": "tr",
              "text": "Belgeler eksiksizse daire süresiz olarak kiraya verilir."
            }
          ]
        }
      ]
    },
