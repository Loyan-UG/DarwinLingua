          "language": "ar",
          "text": "المخزون؛ الرصيد"
        },
        {
          "language": "ckb",
          "text": "کۆگا؛ بڕی بەردەست"
        },
        {
          "language": "en",
          "text": "stock; inventory balance"
        },
        {
          "language": "fa",
          "text": "موجودی؛ مانده انبار"
        },
        {
          "language": "kmr",
          "text": "stok; hebûn"
        },
        {
          "language": "pl",
          "text": "stan magazynowy"
        },
        {
          "language": "ro",
          "text": "stoc; sold de inventar"
        },
        {
          "language": "ru",
          "text": "запас; остаток"
        },
        {
          "language": "sq",
          "text": "stok; gjendje"
        },
        {
          "language": "tr",
          "text": "stok; envanter bakiyesi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bestand im ERP zeigt nur noch zehn Stück.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض المخزون في ERP عشر قطع فقط."
            },
            {
              "language": "ckb",
              "text": "کۆگا لە ERP دا تەنها دە دانە نیشان دەدات."
            },
            {
              "language": "en",
              "text": "The stock in the ERP shows only ten pieces left."
            },
            {
              "language": "fa",
              "text": "موجودی در ERP فقط ده عدد نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Stok di ERP de tenê deh parçe nîşan dide."
            },
            {
              "language": "pl",
              "text": "Stan w ERP pokazuje tylko dziesięć sztuk."
            },
            {
              "language": "ro",
              "text": "Stocul din ERP arată doar zece bucăți rămase."
            },
            {
              "language": "ru",
              "text": "Запас в ERP показывает только десять штук."
            },
            {
              "language": "sq",
              "text": "Stoku në ERP tregon vetëm dhjetë copë."
            },
            {
              "language": "tr",
              "text": "ERP’deki stokta sadece on adet görünüyor."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie den Bestand, bevor Sie dem Kunden zusagen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى فحص المخزون قبل أن تعد العميل."
            },
            {
              "language": "ckb",
              "text": "تکایە کۆگا بپشکنن پێش ئەوەی بە کڕیار بەڵێن بدەن."
            },
            {
              "language": "en",
              "text": "Please check the stock before you promise the customer."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از قول دادن به مشتری، موجودی را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe stokê kontrol bikin berî ku hûn soz bidin mişterî."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić stan magazynowy, zanim obieca Pan klientowi."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați stocul înainte să promiteți clientului."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте запас, прежде чем обещать клиенту."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni stokun para se t’i premtoni klientit."
            },
            {
              "language": "tr",
              "text": "Müşteriye söz vermeden önce lütfen stoku kontrol edin."
            }
          ]
        }
      ]
    }
