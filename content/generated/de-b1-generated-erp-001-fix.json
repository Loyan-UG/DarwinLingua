      "meanings": [
        {
          "language": "ar",
          "text": "وقت المعالجة"
        },
        {
          "language": "ckb",
          "text": "کاتی چارەسەرکردن"
        },
        {
          "language": "en",
          "text": "processing time"
        },
        {
          "language": "fa",
          "text": "زمان پردازش؛ مدت رسیدگی"
        },
        {
          "language": "kmr",
          "text": "dema xebitandinê"
        },
        {
          "language": "pl",
          "text": "czas przetwarzania"
        },
        {
          "language": "ro",
          "text": "timp de procesare"
        },
        {
          "language": "ru",
          "text": "время обработки"
        },
        {
          "language": "sq",
          "text": "kohë përpunimi"
        },
        {
          "language": "tr",
          "text": "işleme süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Bearbeitungszeit wird im ERP automatisch gemessen.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم قياس وقت المعالجة في ERP تلقائيًا."
            },
            {
              "language": "ckb",
              "text": "کاتی چارەسەرکردن لە ERP دا خۆکارانە پێوانە دەکرێت."
            },
            {
              "language": "en",
              "text": "The processing time is measured automatically in the ERP."
            },
            {
              "language": "fa",
              "text": "زمان پردازش در ERP به‌صورت خودکار اندازه‌گیری می‌شود."
            },
            {
              "language": "kmr",
              "text": "Dema xebitandinê di ERP de xweber tê pîvandin."
            },
            {
              "language": "pl",
              "text": "Czas przetwarzania jest automatycznie mierzony w ERP."
            },
            {
              "language": "ro",
              "text": "Timpul de procesare este măsurat automat în ERP."
            },
            {
              "language": "ru",
              "text": "Время обработки автоматически измеряется в ERP."
            },
            {
              "language": "sq",
              "text": "Koha e përpunimit matet automatikisht në ERP."
            },
            {
              "language": "tr",
              "text": "İşleme süresi ERP’de otomatik ölçülür."
            }
          ]
        },
        {
          "baseText": "Für neue Kunden ist die Bearbeitungszeit oft etwas länger.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة للعملاء الجدد يكون وقت المعالجة غالبًا أطول قليلًا."
            },
            {
              "language": "ckb",
              "text": "بۆ کڕیارانی نوێ کاتی چارەسەرکردن زۆرجار کەمێک درێژترە."
            },
            {
              "language": "en",
              "text": "For new customers, the processing time is often a little longer."
            },
            {
              "language": "fa",
              "text": "برای مشتریان جدید، زمان رسیدگی اغلب کمی طولانی‌تر است."
            },
            {
              "language": "kmr",
              "text": "Ji bo mişteriyên nû, dema xebitandinê gelek caran hinek dirêjtir e."
            },
            {
              "language": "pl",
              "text": "Dla nowych klientów czas obsługi jest często trochę dłuższy."
            },
            {
              "language": "ro",
              "text": "Pentru clienții noi, timpul de procesare este adesea puțin mai lung."
            },
            {
              "language": "ru",
              "text": "Для новых клиентов время обработки часто немного дольше."
            },
            {
              "language": "sq",
              "text": "Për klientët e rinj, koha e përpunimit shpesh është pak më e gjatë."
            },
            {
              "language": "tr",
              "text": "Yeni müşteriler için işleme süresi çoğu zaman biraz daha uzundur."
            }
          ]
        }
      ]
    },
