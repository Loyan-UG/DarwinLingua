      "grammarNotes": [
        "transitive verb; beirrt, beirrte, hat beirrt; often reflexive: sich nicht beirren lassen"
      ],
      "collocations": [
        {
          "text": "sich nicht beirren lassen",
          "meaning": "not to be deterred or confused"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Beirrung",
          "relationLabel": "noun",
          "note": "rare"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يربك؛ يثني؛ يزعزع الثقة"
        },
        {
          "language": "ckb",
          "text": "سەرلێشێواو بکات؛ لە ڕێگا لای بدات"
        },
        {
          "language": "en",
          "text": "to unsettle; to confuse; to deter"
        },
        {
          "language": "fa",
          "text": "مردد یا سردرگم کردن؛ از مسیر منحرف کردن"
        },
        {
          "language": "kmr",
          "text": "serê kesekî tevlihev kirin; ji rê derxistin"
        },
        {
          "language": "pl",
          "text": "zbić z tropu; zdezorientować; zniechęcić"
        },
        {
          "language": "ro",
          "text": "a deruta; a descuraja; a tulbura"
        },
        {
