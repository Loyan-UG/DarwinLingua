  "entries": [
    {
      "word": "beileibe",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "bei-lei-be",
      "topics": [
        "business-communication",
        "advanced-analysis",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb; emphatic negation, usually in phrases such as beileibe nicht"
      ],
      "collocations": [
        {
          "text": "beileibe nicht",
          "meaning": "certainly not; by no means"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قطعاً لا؛ بأي حال من الأحوال"
        },
        {
          "language": "ckb",
          "text": "بێگومان نا؛ بە هیچ شێوەیەک"
        },
        {
          "language": "en",
          "text": "certainly not; by no means"
        },
        {
          "language": "fa",
          "text": "قطعاً نه؛ به هیچ وجه"
        },
        {
          "language": "kmr",
          "text": "bêguman na; bi tu awayî na"
        },
        {
          "language": "pl",
          "text": "bynajmniej; w żadnym razie"
        },
        {
          "language": "ro",
          "text": "nicidecum; în niciun caz"
        },
        {
          "language": "ru",
          "text": "отнюдь не; никоим образом"
        },
        {
          "language": "sq",
          "text": "aspak; kurrsesi"
        },
        {
          "language": "tr",
          "text": "kesinlikle değil; asla"
        }
      ],
      "examples": [
        {
          "baseText": "Die Verzögerung ist beileibe kein Beweis dafür, dass das Projekt gescheitert ist.",
          "translations": [
            {
              "language": "ar",
              "text": "التأخير ليس إطلاقاً دليلاً على أن المشروع قد فشل."
            },
            {
              "language": "ckb",
              "text": "دواکەوتنەکە بە هیچ شێوەیەک بەڵگە نییە بۆ ئەوەی پڕۆژەکە شکستی هێناوە."
            },
            {
              "language": "en",
              "text": "The delay is by no means proof that the project has failed."
            },
            {
              "language": "fa",
              "text": "این تأخیر به هیچ وجه دلیل شکست پروژه نیست."
            },
            {
              "language": "kmr",
              "text": "Derengmayîn bi tu awayî belge nîne ku proje têk çûye."
            },
            {
              "language": "pl",
              "text": "Opóźnienie bynajmniej nie dowodzi, że projekt się nie powiódł."
            },
            {
              "language": "ro",
              "text": "Întârzierea nu este nicidecum o dovadă că proiectul a eșuat."
            },
            {
              "language": "ru",
              "text": "Задержка отнюдь не доказывает, что проект провалился."
            },
            {
              "language": "sq",
              "text": "Vonesa nuk është kurrsesi provë se projekti ka dështuar."
            },
            {
              "language": "tr",
              "text": "Gecikme, projenin başarısız olduğunun kesinlikle kanıtı değildir."
            }
          ]
        },
        {
          "baseText": "Seine Zurückhaltung bedeutete beileibe nicht, dass ihm die Entscheidung gleichgültig war.",
          "translations": [
            {
              "language": "ar",
              "text": "تحفظه لم يكن إطلاقاً يعني أن القرار لا يهمه."
            },
            {
              "language": "ckb",
              "text": "خۆپارێزییەکەی بە هیچ شێوەیەک واتای ئەوە نەبوو کە بڕیارەکە بۆی گرنگ نییە."
            },
            {
              "language": "en",
              "text": "His restraint certainly did not mean that the decision was a matter of indifference to him."
            },
            {
              "language": "fa",
              "text": "خویشتن‌داری او قطعاً به این معنا نبود که تصمیم برایش بی‌اهمیت است."
            },
            {
              "language": "kmr",
              "text": "Xweparastina wî bêguman wateya wê nedida ku biryar ji bo wî bêgirîng e."
            },
            {
              "language": "pl",
              "text": "Jego powściągliwość bynajmniej nie oznaczała, że decyzja była mu obojętna."
            },
            {
              "language": "ro",
              "text": "Reținerea lui nu însemna nicidecum că decizia îi era indiferentă."
            },
            {
              "language": "ru",
              "text": "Его сдержанность отнюдь не означала, что решение ему безразлично."
            },
            {
              "language": "sq",
              "text": "Përmbajtja e tij nuk nënkuptonte aspak se vendimi i ishte i parëndësishëm."
            },
            {
              "language": "tr",
              "text": "Çekingenliği, kararın onun için önemsiz olduğu anlamına kesinlikle gelmiyordu."
            }
          ]
        }
      ]
    },
    {
      "word": "beinahe zwangsläufig",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "bei-na-he zwangs-läu-fig",
      "topics": [
        "advanced-analysis",
        "business-communication",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "analysis",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "fixed adverbial phrase; means almost inevitably"
      ],
      "collocations": [
        {
          "text": "beinahe zwangsläufig eintreten",
          "meaning": "to occur almost inevitably"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zwangsläufig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تقريباً لا مفر منه؛ شبه حتمي"
        },
        {
          "language": "ckb",
          "text": "نزیکەی ناچاری؛ بە شێوەیەکی زۆر پێشبینیکراو"
        },
        {
          "language": "en",
          "text": "almost inevitably; nearly necessarily"
        },
        {
          "language": "fa",
          "text": "تقریباً ناگزیر؛ تقریباً حتمی"
        },
        {
          "language": "kmr",
          "text": "hema hema neçarî; nêzîkî bi pêwîstî"
        },
        {
          "language": "pl",
          "text": "niemal nieuchronnie; prawie z konieczności"
        },
        {
          "language": "ro",
          "text": "aproape inevitabil; aproape necesar"
        },
        {
          "language": "ru",
          "text": "почти неизбежно; почти закономерно"
        },
        {
          "language": "sq",
          "text": "pothuajse pashmangshëm; gati domosdoshmërisht"
        },
        {
          "language": "tr",
          "text": "neredeyse kaçınılmaz biçimde"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn Warnungen monatelang ignoriert werden, entsteht beinahe zwangsläufig ein größerer Schaden.",
          "translations": [
            {
              "language": "ar",
              "text": "عندما يتم تجاهل التحذيرات لأشهر، ينشأ ضرر أكبر بشكل شبه حتمي."
            },
            {
              "language": "ckb",
              "text": "ئەگەر ئاگادارکردنەوەکان مانگانە پشتگوێ بخرێن، زیانێکی گەورەتر نزیکەی ناچار دروست دەبێت."
            },
            {
              "language": "en",
              "text": "If warnings are ignored for months, more serious damage almost inevitably follows."
            },
            {
              "language": "fa",
              "text": "وقتی هشدارها ماه‌ها نادیده گرفته شوند، تقریباً ناگزیر خسارت بزرگ‌تری ایجاد می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ger hişyariyan bi mehan bêne paşguhkirin, zirareke mezintir hema hema neçarî çêdibe."
            },
            {
              "language": "pl",
              "text": "Jeśli ostrzeżenia są ignorowane przez miesiące, niemal nieuchronnie powstaje większa szkoda."
            },
            {
              "language": "ro",
              "text": "Dacă avertismentele sunt ignorate luni de zile, apare aproape inevitabil o pagubă mai mare."
            },
            {
              "language": "ru",
              "text": "Если предупреждения месяцами игнорируются, почти неизбежно возникает более серьёзный ущерб."
            },
            {
              "language": "sq",
              "text": "Nëse paralajmërimet shpërfillen për muaj, pothuajse pashmangshëm lind një dëm më i madh."
            },
            {
              "language": "tr",
              "text": "Uyarılar aylarca görmezden gelinirse neredeyse kaçınılmaz olarak daha büyük bir zarar doğar."
            }
          ]
        },
        {
          "baseText": "Aus dieser Perspektive wirkt der Konflikt beinahe zwangsläufig, nicht wie ein bloßes Missverständnis.",
          "translations": [
            {
              "language": "ar",
              "text": "من هذا المنظور يبدو النزاع شبه حتمي، لا مجرد سوء فهم."
            },
            {
              "language": "ckb",
              "text": "لەو ڕوانگەیەوە ناکۆکییەکە نزیکەی ناچار دەردەکەوێت، نە وەک تەنها تێنەگەیشتنێک."
            },
            {
              "language": "en",
              "text": "From this perspective, the conflict appears almost inevitable, not like a mere misunderstanding."
            },
            {
              "language": "fa",
              "text": "از این منظر، تعارض تقریباً ناگزیر به نظر می‌رسد، نه صرفاً یک سوءتفاهم."
            },
            {
              "language": "kmr",
              "text": "Ji vê perspektîfê, nakokî hema hema neçarî xuya dike, ne wek tenê şaşfêmkirinek."
            },
            {
              "language": "pl",
              "text": "Z tej perspektywy konflikt wydaje się niemal nieuchronny, a nie jedynie nieporozumieniem."
            },
            {
              "language": "ro",
              "text": "Din această perspectivă, conflictul pare aproape inevitabil, nu o simplă neînțelegere."
            },
            {
              "language": "ru",
              "text": "С этой точки зрения конфликт выглядит почти неизбежным, а не простым недоразумением."
            },
            {
              "language": "sq",
              "text": "Nga kjo perspektivë, konflikti duket pothuajse i pashmangshëm, jo thjesht një keqkuptim."
            },
            {
              "language": "tr",
              "text": "Bu açıdan çatışma basit bir yanlış anlaşılma değil, neredeyse kaçınılmaz görünür."
            }
          ]
        }
      ]
    },
    {
      "word": "beirren",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
