  "entries": [
    {
      "word": "abhelfen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abhelfen",
      "pronunciationIpa": null,
      "syllableBreak": "ab-hel-fen",
      "topics": [
        "law-and-compliance",
        "quality-and-risk",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "written",
        "administrative",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; used with dative: einem Mangel abhelfen"
      ],
      "collocations": [
        {
          "text": "einem Mangel abhelfen",
          "meaning": "to remedy a defect or shortcoming"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Abhilfe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعالج؛ يضع حدًا لمشكلة"
        },
        {
          "language": "ckb",
          "text": "چارەسەرکردن؛ کێشە لابردن"
        },
        {
          "language": "en",
          "text": "to remedy; to rectify"
        },
        {
          "language": "fa",
          "text": "رفع کردن؛ چاره کردن"
        },
        {
          "language": "kmr",
          "text": "çareser kirin"
        },
        {
          "language": "pl",
          "text": "zaradzić; usunąć problem"
        },
        {
          "language": "ro",
          "text": "a remedia; a corecta"
        },
        {
          "language": "ru",
          "text": "устранить; исправить"
        },
        {
          "language": "sq",
          "text": "të korrigjojë; të zgjidhë"
        },
        {
          "language": "tr",
          "text": "gidermek; çare bulmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Anbieter muss dem Sicherheitsmangel innerhalb von zehn Werktagen abhelfen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على المزود معالجة الخلل الأمني خلال عشرة أيام عمل."
            },
            {
              "language": "ckb",
              "text": "دابینکەر دەبێت لە ماوەی دە ڕۆژی کاری چارەسەری کەموکوڕیی ئاسایش بکات."
            },
            {
              "language": "en",
              "text": "The provider must remedy the security defect within ten working days."
            },
            {
              "language": "fa",
              "text": "ارائه‌دهنده باید ظرف ده روز کاری نقص امنیتی را رفع کند."
            },
            {
              "language": "kmr",
              "text": "Dabînker divê di nav deh rojên kar de kêmasiya ewlehiyê çareser bike."
            },
            {
              "language": "pl",
              "text": "Dostawca musi usunąć lukę bezpieczeństwa w ciągu dziesięciu dni roboczych."
            },
            {
              "language": "ro",
              "text": "Furnizorul trebuie să remedieze deficiența de securitate în termen de zece zile lucrătoare."
            },
            {
              "language": "ru",
              "text": "Поставщик должен устранить недостаток безопасности в течение десяти рабочих дней."
            },
            {
              "language": "sq",
              "text": "Ofruesi duhet ta korrigjojë mangësinë e sigurisë brenda dhjetë ditëve pune."
            },
            {
              "language": "tr",
              "text": "Sağlayıcı güvenlik eksikliğini on iş günü içinde gidermelidir."
            }
          ]
        },
        {
          "baseText": "Mit der zusätzlichen Schulung wollte die Leitung den wiederkehrenden Fehlern im Supportprozess abhelfen.",
          "translations": [
            {
              "language": "ar",
              "text": "أرادت الإدارة من خلال التدريب الإضافي معالجة الأخطاء المتكررة في عملية الدعم."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەرایەتی بە ڕاهێنانی زیادە ویستی هەڵە دووبارەبووەکانی پرۆسەی پشتگیری چارەسەر بکات."
            },
            {
              "language": "en",
              "text": "With the additional training, management wanted to remedy recurring errors in the support process."
            },
            {
              "language": "fa",
              "text": "مدیریت می‌خواست با آموزش اضافی خطاهای تکرارشونده در فرایند پشتیبانی را رفع کند."
            },
            {
              "language": "kmr",
              "text": "Rêveberî bi perwerdeya zêde dixwest xeletiyên dubare yên pêvajoya piştgiriyê çareser bike."
            },
            {
              "language": "pl",
              "text": "Dodatkowym szkoleniem kierownictwo chciało zaradzić powtarzającym się błędom w procesie wsparcia."
            },
            {
              "language": "ro",
              "text": "Prin instruirea suplimentară, conducerea a vrut să remedieze erorile recurente din procesul de suport."
            },
            {
              "language": "ru",
              "text": "Дополнительным обучением руководство хотело устранить повторяющиеся ошибки в процессе поддержки."
            },
            {
              "language": "sq",
              "text": "Me trajnimin shtesë, drejtimi donte të korrigjonte gabimet e përsëritura në procesin e mbështetjes."
            },
            {
              "language": "tr",
              "text": "Yönetim ek eğitimle destek sürecindeki tekrarlayan hataları gidermek istedi."
            }
          ]
        }
      ]
    },
    {
      "word": "ablassen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ablassen",
      "pronunciationIpa": null,
      "syllableBreak": "ab-las-sen",
      "topics": [
        "production-and-maintenance",
        "management-and-leadership",
        "quality-and-risk"
      ],
      "usageLabels": [
        "technical",
        "written",
        "business",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; literal draining or figurative refraining from something"
      ],
      "collocations": [
        {
          "text": "Druck ablassen",
          "meaning": "to release pressure"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Ablass",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفرغ؛ يطلق؛ يمتنع عن"
        },
        {
          "language": "ckb",
          "text": "دەرکردن؛ بەردان؛ وازلێهێنان"
        },
        {
          "language": "en",
          "text": "to drain; to release; to refrain from"
        },
        {
          "language": "fa",
          "text": "تخلیه کردن؛ رها کردن؛ دست برداشتن از"
        },
        {
          "language": "kmr",
          "text": "vala kirin; berdan; dev jê berdan"
        },
        {
          "language": "pl",
          "text": "spuścić; wypuścić; odstąpić od"
        },
        {
          "language": "ro",
          "text": "a evacua; a elibera; a renunța la"
        },
        {
          "language": "ru",
          "text": "спустить; выпустить; отказаться от"
        },
        {
          "language": "sq",
          "text": "të shkarkojë; të lëshojë; të heqë dorë"
        },
        {
          "language": "tr",
          "text": "boşaltmak; salmak; vazgeçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Vor der Wartung muss der Techniker den Druck aus der Leitung kontrolliert ablassen.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الصيانة يجب على الفني تفريغ الضغط من الخط بشكل مضبوط."
            },
            {
              "language": "ckb",
              "text": "پێش چاکسازی، تەکنیککار دەبێت فشارەکە لە هێڵەکە بە شێوەی کۆنترۆڵکراو دەر بکات."
            },
            {
              "language": "en",
              "text": "Before maintenance, the technician must release the pressure from the line in a controlled manner."
            },
            {
              "language": "fa",
              "text": "پیش از تعمیرات، تکنسین باید فشار را به‌صورت کنترل‌شده از خط تخلیه کند."
            },
            {
              "language": "kmr",
              "text": "Berî lênêrînê, teknîsyen divê zextê ji xetê bi awayekî kontrolkirî derxe."
            },
            {
              "language": "pl",
              "text": "Przed konserwacją technik musi kontrolowanie spuścić ciśnienie z przewodu."
            },
            {
              "language": "ro",
              "text": "Înainte de mentenanță, tehnicianul trebuie să elibereze controlat presiunea din conductă."
            },
            {
              "language": "ru",
              "text": "Перед обслуживанием техник должен контролируемо стравить давление из линии."
            },
            {
              "language": "sq",
              "text": "Para mirëmbajtjes, tekniku duhet ta lirojë presionin nga linja në mënyrë të kontrolluar."
            },
            {
              "language": "tr",
              "text": "Bakım öncesinde teknisyen hattaki basıncı kontrollü şekilde boşaltmalıdır."
            }
          ]
        },
        {
          "baseText": "Nach der kritischen Rückmeldung ließ das Team von der geplanten Automatisierung zunächst ab.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الملاحظة النقدية تراجع الفريق مؤقتًا عن الأتمتة المخطط لها."
            },
            {
              "language": "ckb",
              "text": "دوای فیدباکی ڕەخنەگرانە، تیمەکە سەرەتا لە ئۆتۆماتیککردنی پلانکراو وازی هێنا."
            },
            {
              "language": "en",
              "text": "After the critical feedback, the team initially refrained from the planned automation."
            },
            {
              "language": "fa",
              "text": "پس از بازخورد انتقادی، تیم ابتدا از اتوماسیون برنامه‌ریزی‌شده صرف‌نظر کرد."
            },
            {
              "language": "kmr",
              "text": "Piştî bersiva rexnegirî, tîm destpêkê ji otomatîzekirina plansazkirî dev jê berda."
            },
            {
              "language": "pl",
              "text": "Po krytycznej opinii zespół początkowo odstąpił od planowanej automatyzacji."
            },
            {
              "language": "ro",
              "text": "După feedbackul critic, echipa a renunțat inițial la automatizarea planificată."
            },
            {
              "language": "ru",
