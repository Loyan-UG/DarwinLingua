      "meanings": [
        {
          "language": "ar",
          "text": "صحيفة مدرسية"
        },
        {
          "language": "ckb",
          "text": "ڕۆژنامەی قوتابیان"
        },
        {
          "language": "en",
          "text": "school newspaper"
        },
        {
          "language": "fa",
          "text": "روزنامه مدرسه؛ نشریه دانش‌آموزی"
        },
        {
          "language": "kmr",
          "text": "rojnameya xwendekaran"
        },
        {
          "language": "pl",
          "text": "gazetka szkolna"
        },
        {
          "language": "ro",
          "text": "ziar școlar"
        },
        {
          "language": "ru",
          "text": "школьная газета"
        },
        {
          "language": "sq",
          "text": "gazetë shkollore"
        },
        {
          "language": "tr",
          "text": "okul gazetesi"
        }
      ],
      "examples": [
        {
          "baseText": "Unsere Klasse schreibt einen Text für die Schülerzeitung.",
          "translations": [
            {
              "language": "ar",
              "text": "يكتب صفنا نصاً للصحيفة المدرسية."
            },
            {
              "language": "ckb",
              "text": "پۆلەکەمان دەقێک بۆ ڕۆژنامەی قوتابیان دەنووسێت."
            },
            {
              "language": "en",
              "text": "Our class is writing a text for the school newspaper."
            },
            {
              "language": "fa",
              "text": "کلاس ما یک متن برای روزنامه مدرسه می‌نویسد."
            },
            {
              "language": "kmr",
              "text": "Pola me nivîsekê ji bo rojnameya xwendekaran dinivîse."
            },
            {
              "language": "pl",
              "text": "Nasza klasa pisze tekst do gazetki szkolnej."
            },
            {
              "language": "ro",
              "text": "Clasa noastră scrie un text pentru ziarul școlar."
            },
            {
              "language": "ru",
              "text": "Наш класс пишет текст для школьной газеты."
            },
            {
              "language": "sq",
              "text": "Klasa jonë shkruan një tekst për gazetën shkollore."
            },
            {
              "language": "tr",
              "text": "Sınıfımız okul gazetesi için bir yazı yazıyor."
            }
          ]
        },
        {
          "baseText": "In der Schülerzeitung steht ein Bericht über das Sportfest.",
          "translations": [
            {
              "language": "ar",
              "text": "يوجد في الصحيفة المدرسية تقرير عن يوم الرياضة."
            },
            {
              "language": "ckb",
              "text": "لە ڕۆژنامەی قوتابیاندا ڕاپۆرتێک دەربارەی جەژنی وەرزش هەیە."
            },
            {
              "language": "en",
              "text": "There is a report about the sports festival in the school newspaper."
            },
            {
              "language": "fa",
              "text": "در روزنامه مدرسه گزارشی درباره جشن ورزشی هست."
            },
            {
              "language": "kmr",
              "text": "Di rojnameya xwendekaran de raporek li ser festîvala werzîşê heye."
            },
            {
              "language": "pl",
              "text": "W gazetce szkolnej jest relacja z festynu sportowego."
            },
            {
              "language": "ro",
              "text": "În ziarul școlar este un articol despre serbarea sportivă."
            },
            {
              "language": "ru",
              "text": "В школьной газете есть репортаж о спортивном празднике."
            },
            {
              "language": "sq",
              "text": "Në gazetën shkollore ka një raport për festën sportive."
            },
            {
              "language": "tr",
              "text": "Okul gazetesinde spor şenliği hakkında bir haber var."
            }
          ]
        }
      ]
    },
