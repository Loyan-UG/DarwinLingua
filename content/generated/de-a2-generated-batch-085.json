      ],
      "examples": [
        {
          "baseText": "Der Schuh ist mir zu klein.",
          "translations": [
            {
              "language": "ar",
              "text": "الحذاء صغير جداً علي."
            },
            {
              "language": "ckb",
              "text": "پێڵاوەکە بۆ من زۆر بچووکە."
            },
            {
              "language": "en",
              "text": "The shoe is too small for me."
            },
            {
              "language": "fa",
              "text": "این کفش برایم خیلی کوچک است."
            },
            {
              "language": "kmr",
              "text": "Ev pêlav ji min re pir biçûk e."
            },
            {
              "language": "pl",
              "text": "Ten but jest dla mnie za mały."
            },
            {
              "language": "ro",
              "text": "Pantoful este prea mic pentru mine."
            },
            {
              "language": "ru",
              "text": "Этот ботинок мне слишком мал."
            },
            {
              "language": "sq",
              "text": "Këpuca është shumë e vogël për mua."
            },
            {
              "language": "tr",
              "text": "Ayakkabı bana çok küçük."
            }
          ]
        },
        {
          "baseText": "Haben Sie diesen Schuh auch in Größe 40?",
          "translations": [
            {
              "language": "ar",
              "text": "هل لديكم هذا الحذاء أيضاً بالمقاس 40؟"
            },
            {
              "language": "ckb",
              "text": "ئایا ئەم پێڵاوەتان بە قەبارەی ٤٠یش هەیە؟"
            },
            {
              "language": "en",
              "text": "Do you also have this shoe in size 40?"
            },
            {
              "language": "fa",
              "text": "آیا این کفش را در سایز ۴۰ هم دارید؟"
            },
            {
              "language": "kmr",
              "text": "Ma ev pêlav di mezinahiya 40 de jî heye?"
            },
            {
              "language": "pl",
              "text": "Czy mają państwo ten but także w rozmiarze 40?"
            },
            {
              "language": "ro",
              "text": "Aveți acest pantof și mărimea 40?"
            },
            {
              "language": "ru",
              "text": "У вас есть эта обувь также 40-го размера?"
            },
            {
              "language": "sq",
              "text": "A e keni këtë këpucë edhe në numrin 40?"
            },
            {
              "language": "tr",
              "text": "Bu ayakkabının 40 numarası da var mı?"
            }
          ]
        }
      ]
