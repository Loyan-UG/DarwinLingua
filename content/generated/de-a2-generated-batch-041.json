      "meanings": [
        {
          "language": "ar",
          "text": "معجنات؛ مخبوزات صغيرة"
        },
        {
          "language": "ckb",
          "text": "شیرینی و نانی بچووک"
        },
        {
          "language": "en",
          "text": "pastries; baked goods"
        },
        {
          "language": "fa",
          "text": "شیرینی و نان‌های کوچک"
        },
        {
          "language": "kmr",
          "text": "nan û şîrînahiyên biçûk"
        },
        {
          "language": "pl",
          "text": "wypieki; ciastka"
        },
        {
          "language": "ro",
          "text": "produse de patiserie"
        },
        {
          "language": "ru",
          "text": "выпечка; печенье"
        },
        {
          "language": "sq",
          "text": "ëmbëlsira të pjekura; produkte furre"
        },
        {
          "language": "tr",
          "text": "hamur işi; pastane ürünü"
        }
      ],
      "examples": [
        {
          "baseText": "Ich kaufe Gebäck für den Besuch.",
          "translations": [
            {
              "language": "ar",
              "text": "أشتري معجنات للضيوف."
            },
            {
              "language": "ckb",
              "text": "شیرینی بۆ میوانەکان دەکڕم."
            },
            {
              "language": "en",
              "text": "I am buying pastries for the visitors."
            },
            {
              "language": "fa",
              "text": "برای مهمان‌ها شیرینی می‌خرم."
            },
            {
              "language": "kmr",
              "text": "Ez ji bo mêvanan şîrînahî dikirim."
            },
            {
              "language": "pl",
              "text": "Kupuję wypieki dla gości."
            },
            {
              "language": "ro",
              "text": "Cumpăr produse de patiserie pentru musafiri."
            },
            {
              "language": "ru",
              "text": "Я покупаю выпечку для гостей."
            },
            {
              "language": "sq",
              "text": "Po blej ëmbëlsira për mysafirët."
            },
            {
              "language": "tr",
              "text": "Misafirler için hamur işi alıyorum."
            }
          ]
        },
        {
          "baseText": "Das Gebäck ist heute sehr frisch.",
          "translations": [
            {
              "language": "ar",
              "text": "المعجنات اليوم طازجة جداً."
            },
            {
              "language": "ckb",
              "text": "شیرینییەکان ئەمڕۆ زۆر تازەن."
            },
            {
              "language": "en",
              "text": "The pastries are very fresh today."
            },
            {
              "language": "fa",
              "text": "شیرینی‌ها امروز خیلی تازه هستند."
            },
            {
              "language": "kmr",
              "text": "Şîrînahî îro gelek teze ne."
            },
            {
              "language": "pl",
              "text": "Wypieki są dziś bardzo świeże."
            },
            {
              "language": "ro",
              "text": "Produsele de patiserie sunt foarte proaspete astăzi."
            },
            {
              "language": "ru",
              "text": "Выпечка сегодня очень свежая."
            },
            {
              "language": "sq",
              "text": "Ëmbëlsirat janë shumë të freskëta sot."
            },
            {
              "language": "tr",
              "text": "Hamur işleri bugün çok taze."
            }
          ]
        }
      ]
