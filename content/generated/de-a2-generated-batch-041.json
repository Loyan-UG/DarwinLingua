      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تعليمات الاستخدام؛ دليل الاستعمال"
        },
        {
          "language": "ckb",
          "text": "ڕێنمایی بەکارهێنان"
        },
        {
          "language": "en",
          "text": "instructions for use; user manual"
        },
        {
          "language": "fa",
          "text": "راهنمای استفاده؛ دستورالعمل استفاده"
        },
        {
          "language": "kmr",
          "text": "rêbernameya bikaranînê"
        },
        {
          "language": "pl",
          "text": "instrukcja obsługi"
        },
        {
          "language": "ro",
          "text": "instrucțiuni de utilizare"
        },
        {
          "language": "ru",
          "text": "инструкция по применению"
        },
        {
          "language": "sq",
          "text": "udhëzime përdorimi"
        },
        {
          "language": "tr",
          "text": "kullanım kılavuzu; kullanma talimatı"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte lesen Sie zuerst die Gebrauchsanweisung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى قراءة تعليمات الاستخدام أولاً."
            },
            {
              "language": "ckb",
              "text": "تکایە سەرەتا ڕێنمایی بەکارهێنان بخوێننەوە."
            },
            {
              "language": "en",
              "text": "Please read the instructions first."
            },
            {
              "language": "fa",
              "text": "لطفاً اول راهنمای استفاده را بخوانید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pêşî rêbernameya bikaranînê bixwînin."
            },
            {
              "language": "pl",
              "text": "Proszę najpierw przeczytać instrukcję obsługi."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să citiți mai întâi instrucțiunile."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сначала прочитайте инструкцию."
            },
            {
              "language": "sq",
              "text": "Ju lutemi lexoni së pari udhëzimet."
            },
            {
              "language": "tr",
              "text": "Lütfen önce kullanım kılavuzunu okuyun."
            }
          ]
        },
        {
          "baseText": "Die Gebrauchsanweisung liegt im Karton.",
          "translations": [
            {
              "language": "ar",
              "text": "تعليمات الاستخدام موجودة في الصندوق."
            },
            {
              "language": "ckb",
              "text": "ڕێنمایی بەکارهێنانەکە لە کارتۆنەکەدایە."
            },
            {
              "language": "en",
              "text": "The user manual is in the box."
            },
            {
              "language": "fa",
              "text": "راهنمای استفاده داخل کارتن است."
            },
            {
              "language": "kmr",
              "text": "Rêbernameya bikaranînê di qutiyê de ye."
            },
            {
              "language": "pl",
              "text": "Instrukcja obsługi leży w pudełku."
            },
            {
              "language": "ro",
              "text": "Instrucțiunile sunt în cutie."
            },
            {
              "language": "ru",
              "text": "Инструкция лежит в коробке."
            },
            {
              "language": "sq",
              "text": "Udhëzimet janë në kuti."
            },
            {
              "language": "tr",
              "text": "Kullanım kılavuzu kutunun içinde."
            }
          ]
        }
      ]
    },
