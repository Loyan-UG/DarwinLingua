            {
              "language": "fa",
              "text": "من اهل لهستان هستم."
            },
            {
              "language": "kmr",
              "text": "Ez ji Polonyayê têm."
            },
            {
              "language": "pl",
              "text": "Pochodzę z Polski."
            },
            {
              "language": "ro",
              "text": "Vin din Polonia."
