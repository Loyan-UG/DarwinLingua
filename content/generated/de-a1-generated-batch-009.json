      "examples": [
        {
          "baseText": "Wir machen am Samstag einen Ausflug.",
          "translations": [
            {
              "language": "ar",
              "text": "سنقوم برحلة قصيرة يوم السبت."
            },
            {
              "language": "ckb",
              "text": "ڕۆژی شەممە گەشتێکی کورت دەکەین."
            },
            {
              "language": "en",
              "text": "We are going on a trip on Saturday."
            },
            {
              "language": "fa",
              "text": "شنبه به گردش می‌رویم."
            },
            {
              "language": "kmr",
              "text": "Em roja şemiyê gerokekê dikin."
            },
            {
              "language": "pl",
              "text": "W sobotę robimy wycieczkę."
            },
            {
              "language": "ro",
              "text": "Sâmbătă facem o excursie."
            },
            {
              "language": "ru",
              "text": "В субботу мы едем на экскурсию."
            },
            {
              "language": "sq",
              "text": "Të shtunën bëjmë një shëtitje."
            },
            {
              "language": "tr",
              "text": "Cumartesi günü gezi yapıyoruz."
            }
          ]
        },
        {
          "baseText": "Der Ausflug kostet zehn Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "تكلف الرحلة عشرة يورو."
            },
            {
              "language": "ckb",
              "text": "گەشتەکە دە یۆرۆیە."
            },
            {
              "language": "en",
              "text": "The trip costs ten euros."
            },
            {
              "language": "fa",
              "text": "گردش ده یورو هزینه دارد."
            },
            {
              "language": "kmr",
              "text": "Gerok deh euro ye."
            },
            {
              "language": "pl",
              "text": "Wycieczka kosztuje dziesięć euro."
            },
            {
              "language": "ro",
              "text": "Excursia costă zece euro."
            },
            {
              "language": "ru",
              "text": "Экскурсия стоит десять евро."
            },
            {
              "language": "sq",
              "text": "Ekskursioni kushton dhjetë euro."
            },
