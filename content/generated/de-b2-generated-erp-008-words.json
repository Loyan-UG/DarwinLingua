      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; delivery note received with incoming goods"
      ],
      "collocations": [
        {
          "text": "einen Eingangslieferschein erfassen",
          "meaning": "to record an incoming delivery note"
        },
        {
          "text": "den Eingangslieferschein prüfen",
          "meaning": "to check the incoming delivery note"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Lieferschein",
