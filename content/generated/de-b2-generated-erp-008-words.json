      "meanings": [
        {
          "language": "ar",
          "text": "فاتورة واردة"
        },
        {
          "language": "ckb",
          "text": "فاکتورەی هاتوو"
        },
        {
          "language": "en",
          "text": "incoming invoice; supplier invoice"
        },
        {
          "language": "fa",
          "text": "فاکتور دریافتی؛ فاکتور خرید"
        },
        {
          "language": "kmr",
          "text": "fatûreya hatinê"
        },
        {
          "language": "pl",
          "text": "faktura przychodząca"
        },
        {
          "language": "ro",
          "text": "factură primită"
        },
        {
          "language": "ru",
          "text": "входящий счет; счет поставщика"
        },
        {
          "language": "sq",
          "text": "faturë hyrëse"
        },
        {
          "language": "tr",
          "text": "gelen fatura; tedarikçi faturası"
        }
      ],
      "examples": [
        {
          "baseText": "Die Eingangsrechnung ist im ERP gesperrt, weil der Preis von der Bestellung abweicht.",
          "translations": [
            {
              "language": "ar",
              "text": "الفاتورة الواردة محظورة في ERP لأن السعر يختلف عن طلب الشراء."
            },
            {
              "language": "ckb",
              "text": "فاکتورەی هاتوو لە ERP دا قەدەغەیە، چونکە نرخەکە لە داواکاریی کڕین جیاوازە."
            },
            {
              "language": "en",
              "text": "The incoming invoice is blocked in the ERP because the price differs from the purchase order."
            },
            {
              "language": "fa",
              "text": "فاکتور دریافتی در ERP مسدود است، چون قیمت با سفارش خرید تفاوت دارد."
            },
            {
              "language": "kmr",
              "text": "Fatûreya hatinê di ERP de astengkirî ye, ji ber ku biha ji fermana kirînê cuda ye."
            },
            {
              "language": "pl",
              "text": "Faktura przychodząca jest zablokowana w ERP, ponieważ cena różni się od zamówienia zakupu."
            },
            {
              "language": "ro",
              "text": "Factura primită este blocată în ERP, deoarece prețul diferă de comanda de achiziție."
            },
            {
              "language": "ru",
              "text": "Входящий счет заблокирован в ERP, потому что цена отличается от заказа на закупку."
            },
            {
              "language": "sq",
              "text": "Fatura hyrëse është e bllokuar në ERP sepse çmimi ndryshon nga porosia e blerjes."
            },
            {
              "language": "tr",
              "text": "Gelen fatura ERP’de bloke, çünkü fiyat satın alma siparişinden farklı."
            }
          ]
        },
        {
          "baseText": "Die Buchhaltung braucht die Eingangsrechnung noch heute für den Monatsabschluss.",
          "translations": [
            {
              "language": "ar",
              "text": "تحتاج المحاسبة إلى الفاتورة الواردة اليوم من أجل إقفال الشهر."
            },
            {
              "language": "ckb",
              "text": "ژمێریاری ئەمڕۆ پێویستی بە فاکتورەی هاتوو هەیە بۆ داخستنی مانگ."
            },
            {
              "language": "en",
              "text": "Accounting needs the incoming invoice today for month-end closing."
            },
            {
              "language": "fa",
              "text": "حسابداری برای بستن ماه، امروز به فاکتور دریافتی نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Hesabdarî ji bo girtina mehê îro hewceyê fatûreya hatinê ye."
            },
            {
              "language": "pl",
              "text": "Księgowość potrzebuje faktury przychodzącej jeszcze dziś do zamknięcia miesiąca."
            },
            {
              "language": "ro",
              "text": "Contabilitatea are nevoie de factura primită astăzi pentru închiderea lunii."
            },
            {
              "language": "ru",
              "text": "Бухгалтерии нужен входящий счет сегодня для закрытия месяца."
            },
            {
              "language": "sq",
              "text": "Kontabilitetit i duhet fatura hyrëse sot për mbylljen mujore."
            },
            {
              "language": "tr",
              "text": "Muhasebenin ay kapanışı için gelen faturaya bugün ihtiyacı var."
            }
          ]
        }
      ]
    },
