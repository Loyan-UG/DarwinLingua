          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إشعار تسليم وارد"
        },
        {
          "language": "ckb",
          "text": "پسوڵەی گەیاندنی هاتوو"
        },
        {
          "language": "en",
          "text": "incoming delivery note"
        },
        {
          "language": "fa",
          "text": "برگه تحویل ورودی"
        },
        {
          "language": "kmr",
          "text": "belgeya radestkirina hatinê"
        },
        {
          "language": "pl",
          "text": "przychodowy dokument dostawy"
        },
        {
          "language": "ro",
          "text": "aviz de livrare de intrare"
        },
        {
          "language": "ru",
          "text": "входящая накладная поставки"
        },
        {
          "language": "sq",
          "text": "fletëdorëzim hyrës"
        },
        {
          "language": "tr",
          "text": "gelen teslimat belgesi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Eingangslieferschein wird im ERP mit der Bestellung verglichen, bevor der Wareneingang gebucht wird.",
          "translations": [
            {
              "language": "ar",
              "text": "تتم مقارنة إشعار التسليم الوارد في ERP مع طلب الشراء قبل ترحيل استلام البضائع."
            },
            {
              "language": "ckb",
              "text": "پسوڵەی گەیاندنی هاتوو لە ERP دا لەگەڵ داواکاریی کڕین بەراورد دەکرێت پێش تۆمارکردنی وەرگرتنی کاڵا."
            },
            {
              "language": "en",
              "text": "The incoming delivery note is compared with the purchase order in the ERP before the goods receipt is posted."
            },
            {
              "language": "fa",
              "text": "برگه تحویل ورودی در ERP قبل از ثبت رسید کالا با سفارش خرید مقایسه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Belgeya radestkirina hatinê di ERP de berî tomarkirina wergirtina malan bi fermana kirînê re tê berawirdkirin."
            },
            {
              "language": "pl",
              "text": "Przychodowy dokument dostawy jest porównywany w ERP z zamówieniem zakupu przed zaksięgowaniem przyjęcia towaru."
            },
            {
              "language": "ro",
              "text": "Avizul de livrare de intrare este comparat în ERP cu comanda de achiziție înainte de înregistrarea recepției."
            },
            {
              "language": "ru",
              "text": "Входящая накладная поставки сравнивается в ERP с заказом на закупку до проведения поступления товара."
            },
            {
              "language": "sq",
              "text": "Fletëdorëzimi hyrës krahasohet në ERP me porosinë e blerjes para regjistrimit të pranimit të mallrave."
            },
            {
              "language": "tr",
              "text": "Gelen teslimat belgesi, mal kabulü kaydedilmeden önce ERP’de satın alma siparişiyle karşılaştırılır."
            }
          ]
        },
        {
          "baseText": "Bitte legen Sie den Eingangslieferschein zur Sendung, damit das Lager die Lieferung schneller findet.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرفاق إشعار التسليم الوارد بالشحنة حتى يجد المستودع التسليم بسرعة أكبر."
            },
            {
              "language": "ckb",
              "text": "تکایە پسوڵەی گەیاندنی هاتوو لەگەڵ بارەکە دابنێن بۆ ئەوەی کۆگا گەیاندنەکە خێراتر بدۆزێتەوە."
            },
            {
              "language": "en",
              "text": "Please attach the incoming delivery note to the shipment so the warehouse can find the delivery faster."
            },
            {
              "language": "fa",
              "text": "لطفاً برگه تحویل ورودی را همراه محموله بگذارید تا انبار تحویل را سریع‌تر پیدا کند."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeya radestkirina hatinê bi şandinê re daynin da ku embar radestkirinê zûtir bibîne."
            },
            {
              "language": "pl",
              "text": "Proszę dołączyć przychodowy dokument dostawy do przesyłki, aby magazyn szybciej znalazł dostawę."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să atașați avizul de livrare de intrare la expediție, ca depozitul să găsească livrarea mai repede."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, приложите входящую накладную к отправке, чтобы склад быстрее нашел поставку."
            },
            {
              "language": "sq",
              "text": "Ju lutemi bashkëngjitni fletëdorëzimin hyrës me dërgesën që magazina ta gjejë dorëzimin më shpejt."
            },
            {
              "language": "tr",
              "text": "Lütfen gelen teslimat belgesini sevkiyata ekleyin ki depo teslimatı daha hızlı bulsun."
            }
          ]
        }
      ]
    },
