      "meanings": [
        {
          "language": "ar",
          "text": "مساهمة؛ رسم؛ منشور أو مقال"
        },
        {
          "language": "ckb",
          "text": "بەشداری؛ پارەی بەشداری؛ بابەت"
        },
        {
          "language": "en",
