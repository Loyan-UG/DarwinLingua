      ],
      "examples": [
        {
          "baseText": "Jeder im Team kann einen Beitrag zur Verbesserung des Prozesses leisten.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن لكل شخص في الفريق أن يساهم في تحسين العملية."
            },
            {
              "language": "ckb",
              "text": "هەر کەسێک لە تیمەکەدا دەتوانێت بەشداری لە باشترکردنی پڕۆسەکە بکات."
            },
            {
              "language": "en",
              "text": "Everyone on the team can make a contribution to improving the process."
            },
            {
              "language": "fa",
              "text": "هر کسی در تیم می‌تواند در بهبود فرایند سهمی داشته باشد."
            },
            {
              "language": "kmr",
              "text": "Her kes di tîmê de dikare beşdarî baştirkirina pêvajoyê bike."
            },
            {
              "language": "pl",
              "text": "Każdy w zespole może wnieść wkład w poprawę procesu."
            },
            {
              "language": "ro",
              "text": "Fiecare din echipă poate contribui la îmbunătățirea procesului."
            },
            {
              "language": "ru",
              "text": "Каждый в команде может внести вклад в улучшение процесса."
            },
            {
              "language": "sq",
              "text": "Çdokush në ekip mund të japë kontribut në përmirësimin e procesit."
            },
            {
              "language": "tr",
              "text": "Ekipteki herkes sürecin iyileştirilmesine katkı sağlayabilir."
            }
          ]
        },
        {
          "baseText": "Der monatliche Beitrag für den Sportverein wurde leicht erhöht.",
          "translations": [
            {
              "language": "ar",
              "text": "تمت زيادة الرسوم الشهرية للنادي الرياضي قليلًا."
            },
            {
              "language": "ckb",
              "text": "پارەی مانگانەی یانەی وەرزشی کەمێک زیاد کرا."
            },
            {
              "language": "en",
              "text": "The monthly fee for the sports club was slightly increased."
            },
            {
              "language": "fa",
              "text": "حق عضویت ماهانه باشگاه ورزشی کمی افزایش یافت."
            },
            {
              "language": "kmr",
              "text": "Pereya mehane ya klûba werzîşê hinek zêde bû."
            },
            {
              "language": "pl",
              "text": "Miesięczna składka w klubie sportowym została lekko podniesiona."
            },
            {
              "language": "ro",
              "text": "Contribuția lunară pentru clubul sportiv a fost ușor mărită."
