              "text": "لا أستطيع فتح الملف."
            },
            {
              "language": "ckb",
              "text": "ناتوانم فایلەکە بکەمەوە."
            },
            {
              "language": "en",
              "text": "I cannot open the file."
            },
            {
              "language": "fa",
              "text": "نمی‌توانم فایل را باز کنم."
            },
            {
              "language": "kmr",
              "text": "Ez nikarim pelgeyê vekim."
            },
            {
              "language": "pl",
              "text": "Nie mogę otworzyć pliku."
            },
            {
              "language": "ro",
