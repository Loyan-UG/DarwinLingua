      "examples": [
        {
          "baseText": "Bitte schicken Sie mir die Datei per E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال الملف إلي عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "تکایە فایلەکە بە ئیمەیڵ بۆم بنێرن."
            },
            {
              "language": "en",
              "text": "Please send me the file by email."
            },
            {
              "language": "fa",
              "text": "لطفاً فایل را با ایمیل برای من بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe pelgeyê bi e-nameyê ji min re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę wysłać mi plik e-mailem."
            },
            {
              "language": "ro",
              "text": "Vă rog să îmi trimiteți fișierul prin e-mail."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте мне файл по электронной почте."
            },
            {
              "language": "sq",
              "text": "Ju lutem ma dërgoni skedarin me email."
            },
            {
              "language": "tr",
              "text": "Lütfen dosyayı bana e-posta ile gönderin."
            }
          ]
        },
        {
          "baseText": "Ich kann die Datei nicht öffnen.",
