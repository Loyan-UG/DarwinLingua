    {
      "word": "dagegen",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "da-ge-gen",
      "topics": [
        "business-communication",
        "everyday-life",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "pronominal adverb; means against it or in contrast"
      ],
      "collocations": [
        {
          "text": "dagegen sein",
          "meaning": "to be against it"
        },
        {
          "text": "etwas dagegen haben",
          "meaning": "to have something against it"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ضد ذلك؛ بالمقابل"
        },
        {
          "language": "ckb",
          "text": "دژی ئەوە؛ بە پێچەوانەوە"
        },
        {
          "language": "en",
          "text": "against it; on the other hand"
        },
        {
          "language": "fa",
          "text": "مخالف آن؛ در مقابل"
        },
        {
          "language": "kmr",
          "text": "li dijî wê; berevajî"
        },
        {
          "language": "pl",
          "text": "przeciw temu; natomiast"
        },
        {
          "language": "ro",
          "text": "împotriva acestui lucru; în schimb"
        },
        {
          "language": "ru",
          "text": "против этого; зато"
        },
        {
          "language": "sq",
          "text": "kundër kësaj; ndërsa"
        },
        {
          "language": "tr",
          "text": "buna karşı; aksine"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin dagegen, dass wir heute länger arbeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا ضد أن نعمل اليوم مدة أطول."
            },
            {
              "language": "ckb",
              "text": "من دژی ئەوەم ئەمڕۆ زیاتر کار بکەین."
            },
            {
              "language": "en",
              "text": "I am against us working longer today."
            },
            {
              "language": "fa",
              "text": "من مخالفم که امروز بیشتر کار کنیم."
            },
            {
              "language": "kmr",
              "text": "Ez li dijî wê me ku em îro dirêjtir bixebitin."
            },
            {
              "language": "pl",
              "text": "Jestem przeciw temu, żebyśmy dziś pracowali dłużej."
            },
            {
              "language": "ro",
              "text": "Sunt împotriva ideii să lucrăm mai mult astăzi."
            },
            {
              "language": "ru",
              "text": "Я против того, чтобы мы сегодня работали дольше."
            },
            {
              "language": "sq",
              "text": "Jam kundër që të punojmë më gjatë sot."
            },
            {
              "language": "tr",
              "text": "Bugün daha uzun çalışmamıza karşıyım."
            }
          ]
        },
        {
          "baseText": "Es regnet. Dagegen ist es morgen wieder sonnig.",
          "translations": [
            {
              "language": "ar",
              "text": "إنها تمطر. بالمقابل سيكون الجو غداً مشمساً من جديد."
            },
            {
              "language": "ckb",
              "text": "باران دەبارێت. بە پێچەوانەوە سبەی دووبارە خۆرەتاو دەبێت."
            },
            {
              "language": "en",
              "text": "It is raining. Tomorrow, on the other hand, it will be sunny again."
            },
            {
              "language": "fa",
              "text": "باران می‌بارد. در مقابل، فردا دوباره آفتابی است."
            },
            {
              "language": "kmr",
              "text": "Baran dibare. Berevajî, sibê dîsa rojî ye."
            },
            {
              "language": "pl",
              "text": "Pada deszcz. Natomiast jutro znów będzie słonecznie."
            },
            {
              "language": "ro",
              "text": "Plouă. În schimb, mâine va fi din nou însorit."
            },
            {
              "language": "ru",
              "text": "Идет дождь. Зато завтра снова будет солнечно."
            },
            {
              "language": "sq",
              "text": "Po bie shi. Ndërsa nesër do të jetë përsëri me diell."
            },
            {
              "language": "tr",
              "text": "Yağmur yağıyor. Buna karşılık yarın yine güneşli olacak."
            }
          ]
        }
      ]
    },
    {
      "word": "darum",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
