      "usageLabels": [
        "spoken",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb; often means therefore or about that"
      ],
      "collocations": [
        {
          "text": "darum geht es",
          "meaning": "that is what it is about"
        },
        {
          "text": "darum kommen",
          "meaning": "therefore come"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "لذلك؛ حول ذلك"
        },
        {
          "language": "ckb",
          "text": "بۆیە؛ لەسەر ئەوە"
        },
        {
          "language": "en",
          "text": "therefore; about that"
        },
        {
          "language": "fa",
          "text": "برای همین؛ درباره آن"
        },
        {
          "language": "kmr",
          "text": "ji ber vê; li ser wê"
        },
        {
          "language": "pl",
          "text": "dlatego; o to"
        },
        {
          "language": "ro",
          "text": "de aceea; despre asta"
        },
        {
          "language": "ru",
          "text": "поэтому; об этом"
        },
        {
          "language": "sq",
          "text": "prandaj; për këtë"
        },
        {
          "language": "tr",
          "text": "bu yüzden; bununla ilgili"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bus kommt nicht, darum nehme ich ein Taxi.",
          "translations": [
            {
              "language": "ar",
              "text": "الحافلة لا تأتي، لذلك سآخذ سيارة أجرة."
            },
            {
              "language": "ckb",
              "text": "پاسەکە نایەت، بۆیە تەکسی دەگرم."
            },
            {
              "language": "en",
              "text": "The bus is not coming, so I am taking a taxi."
            },
            {
              "language": "fa",
              "text": "اتوبوس نمی‌آید، برای همین تاکسی می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Otobus nayê, ji ber vê ez taksî digirim."
            },
            {
              "language": "pl",
              "text": "Autobus nie przyjeżdża, dlatego biorę taksówkę."
            },
            {
              "language": "ro",
              "text": "Autobuzul nu vine, de aceea iau un taxi."
            },
            {
              "language": "ru",
              "text": "Автобус не приходит, поэтому я беру такси."
            },
            {
              "language": "sq",
              "text": "Autobusi nuk vjen, prandaj marr taksi."
            },
            {
              "language": "tr",
              "text": "Otobüs gelmiyor, bu yüzden taksiye biniyorum."
            }
          ]
        },
        {
          "baseText": "Darum geht es in der nächsten Lektion.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا ما يدور حوله الدرس القادم."
            },
            {
              "language": "ckb",
              "text": "وانەی داهاتوو لەسەر ئەوەیە."
            },
            {
              "language": "en",
              "text": "That is what the next lesson is about."
            },
            {
              "language": "fa",
              "text": "درس بعدی درباره همین است."
            },
            {
              "language": "kmr",
              "text": "Dersa bê li ser wê ye."
            },
            {
              "language": "pl",
              "text": "O to chodzi w następnej lekcji."
            },
            {
              "language": "ro",
              "text": "Despre asta este lecția următoare."
            },
            {
              "language": "ru",
              "text": "Об этом идет речь в следующем уроке."
            },
            {
              "language": "sq",
              "text": "Për këtë bëhet fjalë në mësimin tjetër."
            },
            {
              "language": "tr",
              "text": "Sonraki ders bununla ilgili."
            }
          ]
        }
      ]
    },
