      "collocations": [
        {
          "text": "sich für einen Kurs anmelden",
          "meaning": "to register for a course"
        },
        {
          "text": "sich online anmelden",
          "meaning": "to log in/register online"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Anmeldung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "abmelden",
          "relationLabel": "verb",
          "note": "opposite in many contexts"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسجل؛ يسجل الدخول"
        },
        {
          "language": "ckb",
          "text": "ناونووسکردن؛ چوونە ژوورەوە"
        },
        {
          "language": "en",
          "text": "to register; to log in"
        },
        {
          "language": "fa",
          "text": "ثبت‌نام کردن؛ وارد حساب شدن"
        },
        {
          "language": "kmr",
          "text": "tomar kirin; têketin"
        },
        {
          "language": "pl",
          "text": "zarejestrować; zalogować się"
        },
        {
          "language": "ro",
          "text": "a înregistra; a se autentifica"
        },
        {
          "language": "ru",
          "text": "регистрировать; входить в аккаунт"
        },
        {
          "language": "sq",
          "text": "të regjistrohesh; të hysh në llogari"
        },
        {
          "language": "tr",
          "text": "kayıt olmak; giriş yapmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte mich für den Kurs anmelden.",
          "translations": [
            {
              "language": "ar",
              "text": "أريد التسجيل في الدورة."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت بۆ کۆرسەکە ناوم بنووسم."
            },
            {
              "language": "en",
              "text": "I would like to register for the course."
            },
            {
              "language": "fa",
              "text": "می‌خواهم برای دوره ثبت‌نام کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim ji bo kursê tomar bibim."
            },
            {
              "language": "pl",
              "text": "Chcę zapisać się na kurs."
            },
            {
              "language": "ro",
              "text": "Aș dori să mă înscriu la curs."
            },
            {
              "language": "ru",
              "text": "Я хочу записаться на курс."
            },
            {
              "language": "sq",
              "text": "Dua të regjistrohem për kursin."
            },
            {
              "language": "tr",
              "text": "Kursa kayıt olmak istiyorum."
            }
          ]
        },
        {
          "baseText": "Bitte melden Sie sich mit Ihrer E-Mail-Adresse an.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تسجيل الدخول بعنوان بريدكم الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "تکایە بە ناونیشانی ئیمەیڵەکەتان بچنە ژوورەوە."
            },
            {
              "language": "en",
              "text": "Please log in with your email address."
            },
            {
              "language": "fa",
              "text": "لطفاً با آدرس ایمیل خود وارد شوید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe bi navnîşana e-nameya xwe têkevin."
            },
            {
              "language": "pl",
              "text": "Proszę zalogować się adresem e-mail."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să vă autentificați cu adresa de e-mail."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, войдите с вашим адресом электронной почты."
            },
            {
              "language": "sq",
              "text": "Ju lutem hyni me adresën tuaj të emailit."
            },
            {
              "language": "tr",
              "text": "Lütfen e-posta adresinizle giriş yapın."
            }
          ]
        }
      ]
    },
