      "meanings": [
        {
          "language": "ar",
          "text": "تجربة الملابس؛ القياس"
        },
        {
          "language": "ckb",
          "text": "تاقیکردنەوەی جل"
        },
        {
          "language": "en",
          "text": "fitting; trying on clothes"
        },
        {
          "language": "fa",
          "text": "پرو لباس؛ امتحان کردن لباس"
        },
        {
          "language": "kmr",
          "text": "ceribandina cilê"
        },
        {
          "language": "pl",
          "text": "przymiarka"
        },
        {
          "language": "ro",
          "text": "probă de haine"
        },
        {
          "language": "ru",
          "text": "примерка"
        },
        {
          "language": "sq",
          "text": "provë rrobash"
        },
        {
          "language": "tr",
          "text": "kıyafet provası"
        }
      ],
      "examples": [
        {
          "baseText": "Die Anprobe ist morgen um zehn Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "تجربة الملابس غداً في الساعة العاشرة."
            },
            {
              "language": "ckb",
              "text": "تاقیکردنەوەی جلەکە سبەی کاتژمێر دەیە."
            },
            {
              "language": "en",
              "text": "The fitting is tomorrow at ten o’clock."
            },
            {
              "language": "fa",
              "text": "پرو لباس فردا ساعت ده است."
            },
            {
              "language": "kmr",
              "text": "Ceribandin sibê saet dehan e."
            },
            {
              "language": "pl",
              "text": "Przymiarka jest jutro o dziesiątej."
            },
            {
              "language": "ro",
              "text": "Proba este mâine la ora zece."
            },
            {
              "language": "ru",
              "text": "Примерка завтра в десять часов."
            },
            {
              "language": "sq",
              "text": "Prova është nesër në orën dhjetë."
            },
            {
              "language": "tr",
              "text": "Prova yarın saat onda."
            }
          ]
        },
        {
          "baseText": "Für die Anprobe brauche ich zehn Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "أحتاج إلى عشر دقائق لتجربة الملابس."
            },
            {
              "language": "ckb",
              "text": "بۆ تاقیکردنەوەی جلەکە پێویستم بە دە خولەکە."
            },
            {
              "language": "en",
              "text": "I need ten minutes for the fitting."
            },
            {
              "language": "fa",
              "text": "برای پرو لباس به ده دقیقه نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ji bo ceribandinê hewceyê deh xulekên min e."
            },
            {
              "language": "pl",
              "text": "Na przymiarkę potrzebuję dziesięciu minut."
            },
            {
              "language": "ro",
              "text": "Pentru probă am nevoie de zece minute."
            },
            {
              "language": "ru",
              "text": "На примерку мне нужно десять минут."
            },
            {
              "language": "sq",
              "text": "Për provën më duhen dhjetë minuta."
            },
            {
              "language": "tr",
              "text": "Prova için on dakikaya ihtiyacım var."
            }
          ]
        }
      ]
    },
