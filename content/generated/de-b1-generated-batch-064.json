        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تمديد المهلة"
        },
        {
          "language": "ckb",
          "text": "درێژکردنەوەی مۆڵەت"
        },
        {
          "language": "en",
          "text": "extension of a deadline"
        },
        {
          "language": "fa",
          "text": "تمدید مهلت"
        },
        {
          "language": "kmr",
          "text": "dirêjkirina dema dawî"
        },
        {
          "language": "pl",
          "text": "przedłużenie terminu"
        },
        {
          "language": "ro",
          "text": "prelungirea termenului"
        },
        {
          "language": "ru",
          "text": "продление срока"
        },
        {
          "language": "sq",
          "text": "zgjatje e afatit"
        },
        {
          "language": "tr",
          "text": "süre uzatımı"
        }
      ],
      "examples": [
        {
          "baseText": "Wir haben beim Finanzamt eine Fristverlängerung beantragt, weil noch Unterlagen fehlen.",
          "translations": [
            {
              "language": "ar",
              "text": "طلبنا من مكتب الضرائب تمديد المهلة لأن بعض المستندات لا تزال ناقصة."
            },
            {
              "language": "ckb",
              "text": "لە فەرمانگەی باج داوای درێژکردنەوەی مۆڵەتمان کرد، چونکە هێشتا هەندێک بەڵگەنامە کەمە."
            },
            {
              "language": "en",
              "text": "We requested an extension from the tax office because some documents are still missing."
            },
            {
              "language": "fa",
              "text": "از اداره مالیات درخواست تمدید مهلت کردیم، چون هنوز بعضی مدارک ناقص است."
            },
            {
              "language": "kmr",
              "text": "Me ji nivîsgeha bacê dirêjkirina dema dawî xwest, ji ber ku hîn hin belge kêm in."
            },
            {
              "language": "pl",
              "text": "Poprosiliśmy urząd skarbowy o przedłużenie terminu, ponieważ brakuje jeszcze kilku dokumentów."
            },
            {
              "language": "ro",
              "text": "Am cerut fiscului o prelungire a termenului, deoarece încă lipsesc unele documente."
            },
            {
              "language": "ru",
              "text": "Мы запросили в налоговой продление срока, потому что некоторых документов еще не хватает."
            },
            {
              "language": "sq",
              "text": "Kërkuam nga zyra e tatimeve zgjatje të afatit, sepse ende mungojnë disa dokumente."
            },
            {
              "language": "tr",
              "text": "Bazı belgeler hâlâ eksik olduğu için vergi dairesinden süre uzatımı istedik."
            }
          ]
        },
        {
          "baseText": "Der Kunde bekommt eine Fristverlängerung bis Freitag, damit er das Angebot intern prüfen kann.",
          "translations": [
            {
              "language": "ar",
              "text": "سيحصل العميل على تمديد للمهلة حتى يوم الجمعة كي يتمكن من مراجعة العرض داخلياً."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە تا هەینی درێژکردنەوەی مۆڵەت وەردەگرێت، بۆ ئەوەی بتوانێت پێشنیارەکە لەناوخۆدا بپشکنێت."
            },
            {
              "language": "en",
              "text": "The customer gets a deadline extension until Friday so they can review the offer internally."
            },
            {
              "language": "fa",
              "text": "مشتری تا جمعه تمدید مهلت می‌گیرد تا بتواند پیشنهاد را داخل شرکت بررسی کند."
            },
            {
              "language": "kmr",
              "text": "Xerîdar heta roja înê dirêjkirina dema dawî werdigire, da ku pêşniyarê li hundir binirxîne."
            },
            {
              "language": "pl",
              "text": "Klient otrzyma przedłużenie terminu do piątku, aby mógł wewnętrznie sprawdzić ofertę."
            },
            {
              "language": "ro",
              "text": "Clientul primește o prelungire a termenului până vineri, ca să poată verifica oferta intern."
            },
            {
              "language": "ru",
              "text": "Клиент получает продление срока до пятницы, чтобы проверить предложение внутри компании."
            },
            {
              "language": "sq",
              "text": "Klienti merr zgjatje të afatit deri të premten, që ta shqyrtojë ofertën brenda kompanisë."
            },
            {
              "language": "tr",
              "text": "Müşteri, teklifi şirket içinde inceleyebilmesi için cuma gününe kadar süre uzatımı alıyor."
            }
          ]
        }
      ]
    },
