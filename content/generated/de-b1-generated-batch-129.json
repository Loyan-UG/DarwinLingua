  "entries": [
    {
      "word": "die Tradition",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Traditionen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Tra-di-ti-on",
      "topics": [
        "culture-and-media",
        "social-and-relationships",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Tradition pflegen",
          "meaning": "to maintain a tradition"
        },
        {
          "text": "eine alte Tradition",
          "meaning": "an old tradition"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "traditionell",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تقليد؛ عادة متوارثة"
        },
        {
          "language": "ckb",
          "text": "نەریت؛ داب و نەریت"
        },
        {
          "language": "en",
          "text": "tradition"
        },
        {
          "language": "fa",
          "text": "سنت؛ رسم"
        },
        {
          "language": "kmr",
          "text": "kevneşopî; adet"
        },
        {
          "language": "pl",
          "text": "tradycja"
        },
        {
          "language": "ro",
          "text": "tradiție"
        },
        {
          "language": "ru",
          "text": "традиция"
        },
        {
          "language": "sq",
          "text": "traditë"
        },
        {
          "language": "tr",
          "text": "gelenek"
        }
      ],
      "examples": [
        {
          "baseText": "In meiner Familie ist es Tradition, am Sonntag gemeinsam zu essen.",
          "translations": [
            {
              "language": "ar",
              "text": "في عائلتي من التقاليد أن نأكل معًا يوم الأحد."
            },
            {
              "language": "ckb",
              "text": "لە خێزانەکەمدا نەریتە کە یەکشەممە پێکەوە نان بخۆین."
            },
            {
              "language": "en",
              "text": "In my family, it is a tradition to eat together on Sundays."
            },
            {
              "language": "fa",
              "text": "در خانواده من سنت است که یکشنبه‌ها با هم غذا بخوریم."
            },
            {
              "language": "kmr",
              "text": "Di malbata min de kevneşopî ye ku roja yekşemê bi hev re bixwin."
            },
            {
              "language": "pl",
              "text": "W mojej rodzinie tradycją jest wspólny posiłek w niedzielę."
            },
            {
              "language": "ro",
              "text": "În familia mea este o tradiție să mâncăm împreună duminica."
            },
            {
              "language": "ru",
              "text": "В моей семье есть традиция есть вместе по воскресеньям."
            },
            {
              "language": "sq",
              "text": "Në familjen time është traditë të hamë së bashku të dielave."
            },
            {
              "language": "tr",
              "text": "Ailemde pazar günleri birlikte yemek yemek bir gelenektir."
            }
          ]
        },
        {
          "baseText": "Die Firma hat die Tradition, neue Mitarbeiter persönlich zu begrüßen.",
          "translations": [
            {
              "language": "ar",
              "text": "لدى الشركة تقليد يتمثل في الترحيب بالموظفين الجدد شخصيًا."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە نەریتی ئەوەی هەیە کە بە شەخسی پێشوازی لە کارمەندانی نوێ بکات."
            },
            {
              "language": "en",
              "text": "The company has a tradition of welcoming new employees personally."
            },
            {
              "language": "fa",
              "text": "شرکت این سنت را دارد که از کارکنان جدید شخصاً استقبال کند."
            },
            {
              "language": "kmr",
              "text": "Şirket kevneşopiya wê heye ku karmendên nû bi kesane pêşwazî bike."
            },
            {
              "language": "pl",
              "text": "Firma ma tradycję osobistego witania nowych pracowników."
            },
            {
              "language": "ro",
              "text": "Firma are tradiția de a-i întâmpina personal pe noii angajați."
            },
            {
              "language": "ru",
              "text": "В компании есть традиция лично приветствовать новых сотрудников."
            },
            {
              "language": "sq",
              "text": "Kompania ka traditë t’i mirëpresë personalisht punonjësit e rinj."
            },
            {
              "language": "tr",
              "text": "Şirketin yeni çalışanları kişisel olarak karşılama geleneği var."
            }
          ]
        }
      ]
    },
    {
      "word": "tragen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "tragen",
      "pronunciationIpa": null,
      "syllableBreak": "tra-gen",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "shopping-and-services"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: trägt, trug, hat getragen"
      ],
      "collocations": [
        {
          "text": "eine Tasche tragen",
          "meaning": "to carry a bag"
        },
        {
          "text": "Verantwortung tragen",
          "meaning": "to bear responsibility"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Träger",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحمل؛ يرتدي؛ يتحمل"
        },
        {
          "language": "ckb",
          "text": "هەڵگرتن؛ لەبەرکردن؛ بەرپرسیاری هەڵگرتن"
        },
        {
          "language": "en",
          "text": "to carry; to wear; to bear"
        },
        {
          "language": "fa",
          "text": "حمل کردن؛ پوشیدن؛ به عهده داشتن"
        },
        {
          "language": "kmr",
          "text": "hilgirtin; li xwe kirin; berpirsiyarî hildan"
        },
        {
          "language": "pl",
          "text": "nosić; dźwigać; ponosić"
        },
        {
          "language": "ro",
          "text": "a purta; a duce; a suporta"
        },
        {
          "language": "ru",
          "text": "нести; носить; нести ответственность"
        },
        {
          "language": "sq",
          "text": "të mbash; të veshësh; të bartësh"
        },
        {
          "language": "tr",
          "text": "taşımak; giymek; üstlenmek"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie mir helfen, die Kisten ins Büro zu tragen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك مساعدتي في حمل الصناديق إلى المكتب؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت یارمەتیم بدەیت سندووقەکان بۆ ئۆفیس هەڵبگرم؟"
            },
            {
              "language": "en",
              "text": "Can you help me carry the boxes into the office?"
            },
            {
              "language": "fa",
              "text": "می‌توانید کمکم کنید جعبه‌ها را به دفتر ببرم؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin alîkariya min bikin qutiyan bibim nivîsgehê?"
            },
            {
              "language": "pl",
              "text": "Czy może mi Pan/Pani pomóc zanieść pudła do biura?"
            },
            {
              "language": "ro",
              "text": "Mă puteți ajuta să duc cutiile în birou?"
            },
            {
              "language": "ru",
              "text": "Вы можете помочь мне отнести коробки в офис?"
            },
            {
              "language": "sq",
              "text": "A mund të më ndihmoni t’i çoj kutitë në zyrë?"
            },
            {
              "language": "tr",
              "text": "Kutuları ofise taşımama yardım eder misiniz?"
            }
          ]
        },
        {
          "baseText": "Im Labor müssen alle Mitarbeiter eine Schutzbrille tragen.",
          "translations": [
            {
              "language": "ar",
              "text": "في المختبر يجب على جميع الموظفين ارتداء نظارات واقية."
            },
            {
              "language": "ckb",
              "text": "لە تاقیگەدا هەموو کارمەندان دەبێت چاویلکەی پاراستن لەبەر بکەن."
            },
            {
              "language": "en",
              "text": "In the lab, all employees must wear safety glasses."
            },
            {
              "language": "fa",
              "text": "در آزمایشگاه همه کارکنان باید عینک ایمنی بزنند."
            },
            {
              "language": "kmr",
              "text": "Di laboratuwarê de hemû karmend divê çavkên parastinê li xwe bikin."
            },
            {
              "language": "pl",
              "text": "W laboratorium wszyscy pracownicy muszą nosić okulary ochronne."
            },
            {
              "language": "ro",
              "text": "În laborator, toți angajații trebuie să poarte ochelari de protecție."
            },
            {
              "language": "ru",
              "text": "В лаборатории все сотрудники должны носить защитные очки."
            },
            {
              "language": "sq",
              "text": "Në laborator të gjithë punonjësit duhet të mbajnë syze mbrojtëse."
            },
            {
              "language": "tr",
              "text": "Laboratuvarda tüm çalışanlar koruyucu gözlük takmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "das Training",
