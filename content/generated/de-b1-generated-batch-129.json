      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تدريب؛ تمرين"
        },
        {
          "language": "ckb",
          "text": "ڕاهێنان؛ مەشق"
        },
        {
          "language": "en",
          "text": "training; practice"
        },
        {
          "language": "fa",
          "text": "آموزش؛ تمرین"
        },
        {
          "language": "kmr",
          "text": "perwerde; rahênan"
        },
        {
          "language": "pl",
          "text": "szkolenie; trening"
        },
        {
          "language": "ro",
          "text": "instruire; antrenament"
        },
        {
          "language": "ru",
          "text": "обучение; тренировка"
        },
        {
          "language": "sq",
          "text": "trajnim; stërvitje"
        },
        {
          "language": "tr",
          "text": "eğitim; antrenman"
        }
      ],
      "examples": [
        {
          "baseText": "Das Training für die neue Software dauert zwei Stunden.",
          "translations": [
            {
              "language": "ar",
              "text": "يستغرق التدريب على البرنامج الجديد ساعتين."
            },
            {
              "language": "ckb",
              "text": "ڕاهێنانەکە بۆ نەرمەکاڵای نوێ دوو کاتژمێر دەخایەنێت."
            },
            {
              "language": "en",
              "text": "The training for the new software takes two hours."
            },
            {
              "language": "fa",
              "text": "آموزش نرم‌افزار جدید دو ساعت طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Perwerdeya ji bo nermalava nû du saetan dikişîne."
            },
            {
              "language": "pl",
              "text": "Szkolenie z nowego oprogramowania trwa dwie godziny."
            },
            {
              "language": "ro",
              "text": "Trainingul pentru noul software durează două ore."
            },
            {
              "language": "ru",
              "text": "Обучение по новому программному обеспечению длится два часа."
            },
            {
              "language": "sq",
              "text": "Trajnimi për softuerin e ri zgjat dy orë."
            },
            {
              "language": "tr",
              "text": "Yeni yazılım eğitimi iki saat sürer."
            }
          ]
        },
        {
          "baseText": "Nach dem Training fühlt sie sich fitter und schläft besser.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد التمرين تشعر بأنها أكثر لياقة وتنام بشكل أفضل."
            },
            {
              "language": "ckb",
              "text": "دوای مەشقەکە، هەست دەکات لەشساغترە و باشتر دەخەوێت."
            },
            {
              "language": "en",
              "text": "After training, she feels fitter and sleeps better."
            },
            {
