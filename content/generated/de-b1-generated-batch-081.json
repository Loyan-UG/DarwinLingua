  "entries": [
    {
      "word": "der Kompromiss",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Kompromisse",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kom-pro-miss",
      "topics": [
        "contracts-and-negotiation",
        "business-communication",
        "social-and-relationships"
      ],
      "usageLabels": [
        "business",
        "formal",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; agreement in which both sides give up something"
      ],
      "collocations": [
        {
          "text": "einen Kompromiss finden",
          "meaning": "to find a compromise"
        },
        {
          "text": "zu einem Kompromiss bereit sein",
          "meaning": "to be willing to compromise"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kompromissbereit",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "حل وسط؛ تسوية"
        },
        {
          "language": "ckb",
          "text": "ڕێککەوتنی ناوەڕاست؛ کۆمپڕۆمیس"
        },
        {
          "language": "en",
          "text": "compromise"
        },
        {
          "language": "fa",
          "text": "مصالحه؛ سازش"
        },
        {
          "language": "kmr",
          "text": "lihevhatina navîn; kompromîs"
        },
        {
          "language": "pl",
          "text": "kompromis"
        },
        {
          "language": "ro",
          "text": "compromis"
        },
        {
          "language": "ru",
          "text": "компромисс"
        },
        {
          "language": "sq",
          "text": "kompromis"
        },
        {
          "language": "tr",
          "text": "uzlaşma; orta yol"
        }
      ],
      "examples": [
        {
          "baseText": "Nach langer Diskussion haben wir mit dem Kunden einen Kompromiss gefunden.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد نقاش طويل وجدنا حلاً وسطاً مع العميل."
            },
            {
              "language": "ckb",
              "text": "دوای گفتوگۆیەکی درێژ، لەگەڵ کڕیارەکە ڕێککەوتنێکی ناوەڕاستمان دۆزییەوە."
            },
            {
              "language": "en",
              "text": "After a long discussion, we found a compromise with the customer."
            },
            {
              "language": "fa",
              "text": "بعد از بحث طولانی، با مشتری به یک مصالحه رسیدیم."
            },
            {
              "language": "kmr",
              "text": "Piştî gotûbêjeke dirêj, me bi xerîdar re kompromîsek dît."
            },
            {
              "language": "pl",
              "text": "Po długiej dyskusji znaleźliśmy kompromis z klientem."
            },
            {
              "language": "ro",
              "text": "După o discuție lungă, am găsit un compromis cu clientul."
            },
            {
              "language": "ru",
              "text": "После долгого обсуждения мы нашли компромисс с клиентом."
            },
            {
              "language": "sq",
              "text": "Pas një diskutimi të gjatë gjetëm një kompromis me klientin."
            },
            {
              "language": "tr",
              "text": "Uzun bir tartışmadan sonra müşteriyle bir uzlaşma bulduk."
            }
          ]
        },
        {
          "baseText": "Beim Familienfest war der spätere Termin ein guter Kompromiss für alle.",
          "translations": [
            {
              "language": "ar",
              "text": "في الاحتفال العائلي كان الموعد المتأخر حلاً وسطاً جيداً للجميع."
            },
            {
              "language": "ckb",
              "text": "لە جەژنی خێزانیدا کاتی دواتر کۆمپڕۆمیسێکی باش بوو بۆ هەمووان."
            },
            {
              "language": "en",
              "text": "For the family celebration, the later time was a good compromise for everyone."
            },
            {
              "language": "fa",
              "text": "برای جشن خانوادگی، زمان دیرتر مصالحه خوبی برای همه بود."
            },
            {
              "language": "kmr",
              "text": "Ji bo şahiyê malbatê, dema derengtir ji bo her kesî kompromîseke baş bû."
            },
            {
              "language": "pl",
              "text": "Na uroczystość rodzinną późniejszy termin był dobrym kompromisem dla wszystkich."
            },
            {
              "language": "ro",
              "text": "Pentru petrecerea de familie, ora mai târzie a fost un compromis bun pentru toți."
            },
            {
              "language": "ru",
              "text": "Для семейного праздника более позднее время было хорошим компромиссом для всех."
            },
            {
              "language": "sq",
              "text": "Për festën familjare, orari më i vonë ishte një kompromis i mirë për të gjithë."
            },
            {
              "language": "tr",
              "text": "Aile kutlaması için daha geç saat herkes açısından iyi bir uzlaşmaydı."
            }
          ]
        }
      ]
    },
    {
