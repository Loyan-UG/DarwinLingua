        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نزاع؛ خلاف"
        },
        {
          "language": "ckb",
          "text": "ناکۆکی؛ کێشە"
        },
        {
          "language": "en",
          "text": "conflict; disagreement"
        },
        {
          "language": "fa",
          "text": "تعارض؛ اختلاف"
        },
        {
          "language": "kmr",
          "text": "nakokî; pevçûn"
        },
        {
          "language": "pl",
          "text": "konflikt; spór"
        },
        {
          "language": "ro",
          "text": "conflict; dispută"
        },
        {
          "language": "ru",
          "text": "конфликт; спор"
        },
        {
          "language": "sq",
          "text": "konflikt; mosmarrëveshje"
        },
        {
          "language": "tr",
          "text": "çatışma; anlaşmazlık"
        }
      ],
      "examples": [
        {
          "baseText": "Der Konflikt zwischen Vertrieb und Support muss schnell geklärt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب توضيح الخلاف بين المبيعات والدعم بسرعة."
            },
            {
              "language": "ckb",
              "text": "ناکۆکیی نێوان فرۆشتن و پشتگیری دەبێت بە خێرایی ڕوون بکرێتەوە."
            },
            {
              "language": "en",
              "text": "The conflict between sales and support must be clarified quickly."
            },
            {
              "language": "fa",
              "text": "اختلاف بین فروش و پشتیبانی باید سریع روشن شود."
            },
            {
              "language": "kmr",
              "text": "Nakokiya di navbera firotan û piştgiriyê de divê zû bê zelalkirin."
            },
            {
              "language": "pl",
              "text": "Konflikt między sprzedażą a wsparciem musi zostać szybko wyjaśniony."
            },
            {
              "language": "ro",
              "text": "Conflictul dintre vânzări și suport trebuie clarificat rapid."
            },
            {
              "language": "ru",
              "text": "Конфликт между продажами и поддержкой нужно быстро прояснить."
            },
            {
              "language": "sq",
              "text": "Konflikti mes shitjeve dhe mbështetjes duhet sqaruar shpejt."
            },
            {
              "language": "tr",
              "text": "Satış ve destek arasındaki çatışma hızlıca netleştirilmeli."
            }
          ]
        },
        {
          "baseText": "Nach dem Gespräch war der Konflikt mit dem Nachbarn nicht mehr so schlimm.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد المحادثة لم يعد الخلاف مع الجار شديداً كما كان."
            },
            {
              "language": "ckb",
              "text": "دوای گفتوگۆکە ناکۆکیی لەگەڵ دراوسێکە چیتر ئەوەندە خراپ نەبوو."
            },
            {
              "language": "en",
              "text": "After the conversation, the conflict with the neighbor was no longer so bad."
            },
            {
              "language": "fa",
              "text": "بعد از گفت‌وگو، اختلاف با همسایه دیگر آن‌قدر بد نبود."
            },
            {
              "language": "kmr",
              "text": "Piştî axaftinê nakokiya bi cîran re êdî ewqas xirab nebû."
            },
            {
              "language": "pl",
