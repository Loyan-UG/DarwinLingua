  "entries": [
    {
      "word": "herausarbeiten",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "herausarbeiten",
      "pronunciationIpa": null,
      "syllableBreak": "he-raus-ar-bei-ten",
      "topics": [
        "advanced-analysis",
        "business-communication",
        "data-and-reporting"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: arbeitet heraus, arbeitete heraus, hat herausgearbeitet"
      ],
      "collocations": [
        {
          "text": "Unterschiede herausarbeiten",
          "meaning": "to bring out differences"
        },
        {
          "text": "Kernpunkte herausarbeiten",
          "meaning": "to identify key points"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "arbeiten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يبرز؛ يستخلص؛ يوضح بالتحليل"
        },
        {
          "language": "ckb",
          "text": "دەردەخات؛ بە شیکردنەوە ڕوون دەکاتەوە"
        },
        {
          "language": "en",
          "text": "to bring out; to work out; to identify clearly"
        },
        {
          "language": "fa",
          "text": "برجسته کردن؛ استخراج کردن؛ روشن‌سازی تحلیلی"
        },
        {
          "language": "kmr",
          "text": "derxistin; bi analîzê zelal kirin"
        },
        {
          "language": "pl",
          "text": "wydobyć; wypracować; uwypuklić"
        },
        {
          "language": "ro",
          "text": "a evidenția; a elabora; a scoate în relief"
        },
        {
          "language": "ru",
          "text": "выявлять; прорабатывать; подчеркивать"
        },
        {
          "language": "sq",
          "text": "të nxjerrësh në pah; të përpunosh"
        },
        {
          "language": "tr",
          "text": "ortaya çıkarmak; vurgulamak"
        }
      ],
      "examples": [
        {
          "baseText": "Im Workshop arbeiten wir die wichtigsten Ursachen für die Verzögerung heraus.",
          "translations": [
            {
              "language": "ar",
              "text": "في ورشة العمل نستخلص أهم أسباب التأخير."
            },
            {
              "language": "ckb",
              "text": "لە وۆرکشۆپەکەدا گرنگترین هۆکارەکانی دواكەوتن دەردەخەین."
            },
            {
              "language": "en",
              "text": "In the workshop, we identify the main causes of the delay."
            },
            {
              "language": "fa",
              "text": "در کارگاه، مهم‌ترین علت‌های تأخیر را استخراج می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di atolyeyê de em sedemên herî girîng ên derengmayînê derdixin."
            },
            {
              "language": "pl",
              "text": "Podczas warsztatu wydobywamy najważniejsze przyczyny opóźnienia."
            },
            {
              "language": "ro",
              "text": "În workshop evidențiem principalele cauze ale întârzierii."
            },
            {
              "language": "ru",
              "text": "На воркшопе мы выявляем основные причины задержки."
            },
            {
              "language": "sq",
              "text": "Në punëtori nxjerrim në pah shkaqet kryesore të vonesës."
            },
            {
              "language": "tr",
              "text": "Atölyede gecikmenin başlıca nedenlerini ortaya çıkarıyoruz."
            }
          ]
        },
        {
          "baseText": "Die Studie arbeitet heraus, wie stark Wohnort und Bildungschancen zusammenhängen.",
          "translations": [
            {
              "language": "ar",
              "text": "توضح الدراسة مدى قوة ارتباط مكان السكن بفرص التعليم."
            },
            {
              "language": "ckb",
              "text": "توێژینەوەکە دەریدەخات شوێنی نیشتەجێبوون و دەرفەتی خوێندن چەندە بەهێز پەیوەستن."
            },
            {
              "language": "en",
              "text": "The study shows how strongly place of residence and educational opportunities are connected."
            },
            {
              "language": "fa",
              "text": "مطالعه نشان می‌دهد محل زندگی و فرصت‌های آموزشی چقدر به هم وابسته‌اند."
            },
            {
              "language": "kmr",
              "text": "Lêkolîn nîşan dide ka cihê jiyanê û derfetên perwerdeyê çiqas girêdayî ne."
            },
            {
              "language": "pl",
              "text": "Badanie uwypukla, jak silnie miejsce zamieszkania wiąże się z szansami edukacyjnymi."
            },
            {
              "language": "ro",
              "text": "Studiul evidențiază cât de puternic sunt legate locul de trai și șansele educaționale."
            },
            {
              "language": "ru",
              "text": "Исследование показывает, насколько сильно связаны место жительства и образовательные возможности."
            },
            {
              "language": "sq",
              "text": "Studimi nxjerr në pah sa fort lidhen vendbanimi dhe mundësitë arsimore."
            },
            {
              "language": "tr",
              "text": "Çalışma, ikamet yeri ile eğitim fırsatlarının ne kadar güçlü bağlantılı olduğunu ortaya koyuyor."
            }
          ]
        }
      ]
    },
    {
      "word": "herausschlagen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "herausschlagen",
      "pronunciationIpa": null,
      "syllableBreak": "he-raus-schla-gen",
      "topics": [
        "contracts-and-negotiation",
        "production-and-maintenance",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: schlägt heraus, schlug heraus, hat herausgeschlagen"
      ],
      "collocations": [
        {
          "text": "einen Vorteil herausschlagen",
          "meaning": "to gain an advantage"
        },
        {
          "text": "ein Teil herausschlagen",
          "meaning": "to knock out a part"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schlagen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينتزع مكسبًا؛ يطرق شيئًا لإخراجه"
        },
        {
          "language": "ckb",
          "text": "سوودێک بەدەستدەهێنێت؛ بە لێدان دەریدەهێنێت"
        },
        {
          "language": "en",
          "text": "to gain; to extract by force; to knock out"
        },
        {
          "language": "fa",
          "text": "به دست آوردن؛ با ضربه بیرون آوردن"
        },
        {
          "language": "kmr",
          "text": "bidestxistin; bi lêdanê derxistin"
        },
        {
          "language": "pl",
          "text": "ugrać; wybić"
        },
        {
          "language": "ro",
          "text": "a obține; a scoate prin lovire"
        },
        {
          "language": "ru",
          "text": "выбивать; выторговывать"
        },
        {
          "language": "sq",
          "text": "të nxjerrësh me goditje; të fitosh"
        },
        {
          "language": "tr",
          "text": "koparmak; vurup çıkarmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lieferant versuchte, aus der knappen Marktlage höhere Preise herauszuschlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "حاول المورد انتزاع أسعار أعلى من وضع السوق الضيق."
            },
            {
              "language": "ckb",
              "text": "دابینکەر هەوڵی دا لە دۆخی تنگی بازاڕ نرخە بەرزترەکان بەدەست بهێنێت."
            },
            {
              "language": "en",
              "text": "The supplier tried to gain higher prices from the tight market situation."
            },
            {
              "language": "fa",
              "text": "تأمین‌کننده تلاش کرد از وضعیت فشرده بازار قیمت‌های بالاتری بگیرد."
            },
            {
              "language": "kmr",
              "text": "Dabînker hewl da ji rewşa teng a bazarê bihayên bilindtir bidest bixe."
            },
            {
              "language": "pl",
              "text": "Dostawca próbował ugrać wyższe ceny przy napiętej sytuacji rynkowej."
            },
            {
              "language": "ro",
              "text": "Furnizorul a încercat să obțină prețuri mai mari din situația tensionată a pieței."
            },
            {
              "language": "ru",
              "text": "Поставщик пытался выторговать более высокие цены из-за напряженной ситуации на рынке."
            },
            {
              "language": "sq",
              "text": "Furnizuesi u përpoq të nxirrte çmime më të larta nga situata e ngushtë e tregut."
            },
            {
              "language": "tr",
              "text": "Tedarikçi sıkışık piyasa koşullarından daha yüksek fiyatlar koparmaya çalıştı."
            }
          ]
        },
        {
          "baseText": "Der Techniker musste den verrosteten Bolzen vorsichtig aus der Halterung herausschlagen.",
          "translations": [
            {
              "language": "ar",
              "text": "اضطر الفني إلى إخراج المسمار الصدئ بحذر من الحامل بالطرق."
            },
            {
              "language": "ckb",
              "text": "تەکنیککار ناچار بوو بولتی ژەنگاوی بە وریایی لە گرتنەکە بە لێدان دەربهێنێت."
            },
            {
              "language": "en",
              "text": "The technician had to carefully knock the rusty bolt out of the bracket."
            },
            {
              "language": "fa",
              "text": "تکنسین مجبور شد پیچ زنگ‌زده را با احتیاط از بست بیرون بکوبد."
            },
            {
              "language": "kmr",
              "text": "Teknîsyen neçar bû boltê zengî bi baldarî ji girêdanê derxe."
            },
            {
              "language": "pl",
              "text": "Technik musiał ostrożnie wybić zardzewiałą śrubę z uchwytu."
            },
            {
              "language": "ro",
              "text": "Tehnicianul a trebuit să scoată cu grijă bolțul ruginit din suport prin lovire."
            },
            {
              "language": "ru",
              "text": "Технику пришлось осторожно выбить ржавый болт из крепления."
            },
            {
              "language": "sq",
              "text": "Tekniku duhej ta nxirrte me kujdes bulonin e ndryshkur nga mbajtësja."
            },
            {
              "language": "tr",
              "text": "Teknisyen paslı cıvatayı bağlantıdan dikkatlice vurarak çıkarmak zorunda kaldı."
            }
          ]
        }
      ]
    },
    {
      "word": "herausstreichen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "herausstreichen",
      "pronunciationIpa": null,
      "syllableBreak": "he-raus-strei-chen",
      "topics": [
        "business-communication",
        "meetings-and-presentations",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: streicht heraus, strich heraus, hat herausgestrichen"
      ],
      "collocations": [
        {
          "text": "einen Aspekt herausstreichen",
          "meaning": "to emphasize an aspect"
        },
        {
          "text": "die Bedeutung herausstreichen",
          "meaning": "to underline the importance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "streichen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يبرز؛ يؤكد؛ يشدد على"
        },
        {
          "language": "ckb",
          "text": "جەخت دەکاتەوە؛ دیار دەکات"
        },
        {
          "language": "en",
          "text": "to emphasize; to underline; to highlight"
        },
        {
          "language": "fa",
          "text": "تأکید کردن؛ برجسته کردن"
        },
        {
          "language": "kmr",
          "text": "tekez kirin; diyar kirin"
        },
        {
          "language": "pl",
          "text": "podkreślić; uwypuklić"
        },
        {
          "language": "ro",
          "text": "a sublinia; a evidenția"
        },
        {
          "language": "ru",
          "text": "подчеркивать; выделять"
        },
        {
          "language": "sq",
          "text": "të theksosh; të nxjerrësh në pah"
        },
        {
          "language": "tr",
          "text": "vurgulamak; altını çizmek"
        }
      ],
      "examples": [
        {
          "baseText": "In der Präsentation sollten wir den Nutzen für bestehende Kunden stärker herausstreichen.",
          "translations": [
            {
              "language": "ar",
              "text": "في العرض ينبغي أن نبرز الفائدة للعملاء الحاليين بشكل أقوى."
            },
            {
              "language": "ckb",
              "text": "لە پێشکەشکردنەکەدا دەبێت سوودی کڕیارە هەبووەکان زیاتر جەخت بکەینەوە."
            },
            {
              "language": "en",
