      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فجأة"
        },
        {
          "language": "ckb",
          "text": "لەناکاو"
        },
        {
          "language": "en",
          "text": "suddenly"
        },
        {
          "language": "fa",
          "text": "ناگهان؛ یک‌دفعه"
        },
        {
          "language": "kmr",
          "text": "ji nişkê ve"
        },
        {
          "language": "pl",
          "text": "nagle"
        },
        {
          "language": "ro",
          "text": "brusc; dintr-odată"
        },
        {
          "language": "ru",
          "text": "вдруг; внезапно"
        },
        {
          "language": "sq",
          "text": "papritur"
        },
        {
          "language": "tr",
          "text": "aniden; birden"
        }
      ],
      "examples": [
        {
          "baseText": "Plötzlich war das Licht aus.",
          "translations": [
            {
              "language": "ar",
              "text": "فجأة انطفأ الضوء."
            },
            {
              "language": "ckb",
              "text": "لەناکاو ڕووناکییەکە کوژایەوە."
            },
            {
              "language": "en",
              "text": "Suddenly the light was off."
            },
            {
              "language": "fa",
              "text": "ناگهان چراغ خاموش شد."
            },
            {
              "language": "kmr",
              "text": "Ji nişkê ve ronahî vemirî."
            },
            {
              "language": "pl",
              "text": "Nagle zgasło światło."
            },
            {
              "language": "ro",
              "text": "Dintr-odată lumina s-a stins."
            },
            {
              "language": "ru",
              "text": "Вдруг свет погас."
            },
            {
              "language": "sq",
              "text": "Papritur drita u fik."
            },
            {
              "language": "tr",
              "text": "Aniden ışık söndü."
            }
          ]
        },
        {
          "baseText": "Das Auto hielt plötzlich an.",
          "translations": [
            {
              "language": "ar",
              "text": "توقفت السيارة فجأة."
            },
            {
              "language": "ckb",
              "text": "ئۆتۆمبێلەکە لەناکاو وەستا."
            },
            {
              "language": "en",
              "text": "The car stopped suddenly."
            },
            {
              "language": "fa",
              "text": "ماشین ناگهان توقف کرد."
            },
            {
              "language": "kmr",
              "text": "Erebe ji nişkê ve rawestiya."
            },
            {
              "language": "pl",
              "text": "Samochód nagle się zatrzymał."
            },
            {
              "language": "ro",
              "text": "Mașina s-a oprit brusc."
            },
            {
              "language": "ru",
              "text": "Машина внезапно остановилась."
            },
            {
              "language": "sq",
              "text": "Makina ndaloi papritur."
            },
            {
              "language": "tr",
              "text": "Araba aniden durdu."
            }
          ]
        }
      ]
    },
