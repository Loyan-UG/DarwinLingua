      ],
      "examples": [
        {
          "baseText": "Physik ist am Mittwoch in der ersten Stunde.",
          "translations": [
            {
              "language": "ar",
              "text": "الفيزياء يوم الأربعاء في الحصة الأولى."
            },
            {
              "language": "ckb",
              "text": "فیزیا چوارشەممە لە کاتژمێری یەکەمە."
            },
            {
              "language": "en",
              "text": "Physics is on Wednesday in the first lesson."
            },
            {
              "language": "fa",
              "text": "فیزیک چهارشنبه ساعت اول است."
            },
            {
              "language": "kmr",
              "text": "Fîzîk roja çarşemê di dersa yekem de ye."
            },
            {
              "language": "pl",
              "text": "Fizyka jest w środę na pierwszej lekcji."
            },
            {
              "language": "ro",
              "text": "Fizica este miercuri la prima oră."
            },
            {
              "language": "ru",
              "text": "Физика в среду первым уроком."
            },
            {
              "language": "sq",
              "text": "Fizika është të mërkurën në orën e parë."
            },
            {
              "language": "tr",
              "text": "Fizik çarşamba günü ilk derste."
            }
          ]
        },
        {
          "baseText": "Ich brauche Hilfe in Physik.",
          "translations": [
            {
              "language": "ar",
              "text": "أحتاج إلى مساعدة في الفيزياء."
            },
            {
              "language": "ckb",
              "text": "پێویستم بە یارمەتی لە فیزیا هەیە."
            },
            {
              "language": "en",
              "text": "I need help with physics."
            },
            {
              "language": "fa",
              "text": "در فیزیک به کمک نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ez di fîzîkê de hewceyê alîkariyê me."
            },
            {
              "language": "pl",
              "text": "Potrzebuję pomocy z fizyki."
            },
            {
              "language": "ro",
              "text": "Am nevoie de ajutor la fizică."
            },
            {
              "language": "ru",
              "text": "Мне нужна помощь по физике."
            },
            {
              "language": "sq",
              "text": "Kam nevojë për ndihmë në fizikë."
            },
            {
              "language": "tr",
              "text": "Fizikte yardıma ihtiyacım var."
            }
          ]
        }
      ]
