      "meanings": [
        {
          "language": "ar",
          "text": "مديرة؛ رئيسة"
        },
        {
          "language": "ckb",
          "text": "بەڕێوەبەری ژن؛ سەرپەرشتیاری ژن"
        },
        {
          "language": "en",
          "text": "female manager; female head; leader"
        },
        {
          "language": "fa",
          "text": "مدیر زن؛ سرپرست زن"
        },
        {
          "language": "kmr",
          "text": "rêvebera jin; serperiştiara jin"
        },
        {
          "language": "pl",
          "text": "kierowniczka; szefowa"
        },
        {
          "language": "ro",
          "text": "șefă; conducătoare"
        },
        {
          "language": "ru",
          "text": "руководительница; начальница"
        },
        {
          "language": "sq",
          "text": "drejtuese; përgjegjëse"
        },
        {
          "language": "tr",
          "text": "kadın yönetici; müdüre"
        }
      ],
      "examples": [
        {
          "baseText": "Die Leiterin des Support-Teams prüft jeden Morgen die offenen Tickets.",
          "translations": [
            {
              "language": "ar",
              "text": "تراجع مديرة فريق الدعم التذاكر المفتوحة كل صباح."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری ژنی تیمی پشتگیری هەر بەیانی تیکەتە کراوەکان دەپشکنێت."
            },
            {
              "language": "en",
              "text": "The head of the support team checks the open tickets every morning."
            },
            {
              "language": "fa",
              "text": "مدیر تیم پشتیبانی هر صبح تیکت‌های باز را بررسی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Rêvebera tîma piştgiriyê her sibeh ticketên vekirî kontrol dike."
            },
            {
              "language": "pl",
              "text": "Kierowniczka zespołu wsparcia codziennie rano sprawdza otwarte zgłoszenia."
            },
            {
              "language": "ro",
              "text": "Șefa echipei de suport verifică în fiecare dimineață tichetele deschise."
            },
            {
              "language": "ru",
              "text": "Руководительница команды поддержки каждое утро проверяет открытые тикеты."
            },
            {
              "language": "sq",
              "text": "Drejtuesja e ekipit të mbështetjes kontrollon çdo mëngjes tiketetat e hapura."
            },
            {
              "language": "tr",
              "text": "Destek ekibinin yöneticisi her sabah açık talepleri kontrol eder."
            }
          ]
        },
        {
          "baseText": "Die Leiterin der Kita informiert die Eltern über die neuen Öffnungszeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "تُعلم مديرة الروضة الآباء بأوقات العمل الجديدة."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری ژنی باخچەی منداڵان دایک و باوک لە کاتە نوێیەکانی کردنەوە ئاگادار دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The daycare director informs parents about the new opening hours."
            },
            {
              "language": "fa",
              "text": "مدیر مهدکودک والدین را درباره ساعات کاری جدید مطلع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Rêvebera baxçeyê zarokan dê û bavan li ser demên nû yên vekirinê agahdar dike."
            },
            {
              "language": "pl",
              "text": "Kierowniczka przedszkola informuje rodziców o nowych godzinach otwarcia."
            },
            {
              "language": "ro",
              "text": "Directoarea grădiniței îi informează pe părinți despre noul program."
            },
            {
              "language": "ru",
              "text": "Заведующая детским садом информирует родителей о новых часах работы."
            },
            {
              "language": "sq",
              "text": "Drejtuesja e kopshtit i informon prindërit për orarin e ri."
            },
            {
              "language": "tr",
              "text": "Kreş yöneticisi ebeveynleri yeni açılış saatleri hakkında bilgilendirir."
            }
          ]
        }
      ]
    },
