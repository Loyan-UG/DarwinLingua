  "entries": [
    {
      "word": "der Leiter",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Leiter",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Lei-ter",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "business",
        "workplace"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; male manager, head, or leader"
      ],
      "collocations": [
        {
          "text": "der Leiter der Abteilung",
          "meaning": "the head of the department"
        },
        {
          "text": "als Leiter arbeiten",
          "meaning": "to work as a manager"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "leiten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Leitung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مدير؛ رئيس"
        },
        {
          "language": "ckb",
          "text": "بەڕێوەبەر؛ سەرپەرشتیار"
        },
        {
          "language": "en",
          "text": "manager; head; leader"
        },
        {
          "language": "fa",
          "text": "مدیر؛ سرپرست"
        },
        {
          "language": "kmr",
          "text": "rêveber; serperişt"
        },
        {
          "language": "pl",
          "text": "kierownik; szef"
        },
        {
          "language": "ro",
          "text": "șef; conducător"
        },
        {
          "language": "ru",
          "text": "руководитель; начальник"
        },
        {
          "language": "sq",
          "text": "drejtues; përgjegjës"
        },
        {
          "language": "tr",
          "text": "yönetici; müdür"
        }
      ],
      "examples": [
        {
          "baseText": "Der Leiter der IT-Abteilung stellt morgen den neuen Projektplan vor.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض مدير قسم تقنية المعلومات خطة المشروع الجديدة غداً."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری بەشی IT سبەی پلانی نوێی پڕۆژەکە پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "The head of the IT department will present the new project plan tomorrow."
            },
            {
              "language": "fa",
              "text": "مدیر بخش IT فردا برنامه جدید پروژه را ارائه می‌کند."
            },
            {
              "language": "kmr",
              "text": "Rêveberê beşa IT sibê plana nû ya projeyê pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Kierownik działu IT przedstawi jutro nowy plan projektu."
            },
            {
              "language": "ro",
              "text": "Șeful departamentului IT prezintă mâine noul plan de proiect."
            },
            {
              "language": "ru",
              "text": "Руководитель IT-отдела завтра представит новый план проекта."
            },
            {
              "language": "sq",
              "text": "Drejtuesi i departamentit të IT-së nesër prezanton planin e ri të projektit."
            },
            {
              "language": "tr",
              "text": "IT bölümünün yöneticisi yarın yeni proje planını sunacak."
            }
          ]
        },
        {
          "baseText": "Bei Fragen wenden Sie sich bitte an den Leiter des Kurses.",
          "translations": [
            {
              "language": "ar",
              "text": "في حال وجود أسئلة يرجى التوجه إلى مدير الدورة."
            },
            {
              "language": "ckb",
              "text": "لە کاتی پرسیاردا تکایە پەیوەندی بە سەرپەرشتیاری کۆرسەکە بکەن."
            },
            {
              "language": "en",
              "text": "If you have questions, please contact the course leader."
            },
            {
              "language": "fa",
              "text": "در صورت سؤال، لطفاً با مسئول دوره تماس بگیرید."
            },
            {
              "language": "kmr",
              "text": "Heke pirs hebin, ji kerema xwe bi rêveberê kursê re têkilî bikin."
            },
            {
              "language": "pl",
              "text": "W razie pytań proszę zwrócić się do prowadzącego kurs."
            },
            {
              "language": "ro",
              "text": "Dacă aveți întrebări, vă rugăm să vă adresați conducătorului cursului."
            },
            {
              "language": "ru",
              "text": "При вопросах, пожалуйста, обращайтесь к руководителю курса."
            },
            {
              "language": "sq",
              "text": "Nëse keni pyetje, ju lutemi drejtojuni drejtuesit të kursit."
            },
            {
              "language": "tr",
              "text": "Sorularınız olursa lütfen kurs yöneticisine başvurun."
            }
          ]
        }
      ]
    },
