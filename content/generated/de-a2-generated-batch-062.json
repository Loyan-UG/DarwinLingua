            },
            {
              "language": "en",
              "text": "The local newspaper reports about the market."
            },
            {
              "language": "fa",
              "text": "روزنامه محلی درباره بازار گزارش می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Rojnameya herêmî li ser bazarê dinivîse."
            },
            {
              "language": "pl",
              "text": "Lokalna gazeta pisze o rynku."
            },
            {
              "language": "ro",
              "text": "Ziarul local relatează despre piață."
            },
            {
