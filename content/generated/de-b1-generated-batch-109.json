      ],
      "usageLabels": [
        "everyday",
        "polite",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: rät, riet, geraten; often with dative"
      ],
      "collocations": [
        {
          "text": "jemandem etwas raten",
          "meaning": "to advise someone to do something"
        },
        {
          "text": "dringend raten",
          "meaning": "to strongly advise"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Rat",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Ratschlag",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينصح؛ يخمّن"
        },
        {
          "language": "ckb",
          "text": "ئامۆژگاری دەکات؛ پێشبینی دەکات"
        },
        {
          "language": "en",
          "text": "to advise; to guess"
        },
        {
          "language": "fa",
          "text": "توصیه کردن؛ حدس زدن"
        },
        {
          "language": "kmr",
          "text": "şîret kirin; texmîn kirin"
        },
        {
          "language": "pl",
          "text": "radzić; zgadywać"
        },
        {
          "language": "ro",
          "text": "a sfătui; a ghici"
        },
        {
          "language": "ru",
          "text": "советовать; угадывать"
        },
        {
          "language": "sq",
          "text": "të këshillosh; të hamendësosh"
        },
        {
          "language": "tr",
          "text": "tavsiye etmek; tahmin etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich rate Ihnen, den Vertrag vor der Unterschrift genau zu lesen.",
          "translations": [
            {
              "language": "ar",
              "text": "أنصحكم بقراءة العقد جيدًا قبل التوقيع."
            },
            {
              "language": "ckb",
              "text": "ئامۆژگاریتان دەکەم پێش واژۆکردن گرێبەستەکە بە وردی بخوێننەوە."
            },
            {
              "language": "en",
              "text": "I advise you to read the contract carefully before signing it."
            },
            {
              "language": "fa",
              "text": "توصیه می‌کنم قبل از امضا، قرارداد را دقیق بخوانید."
            },
            {
              "language": "kmr",
              "text": "Ez şîret dikim ku hûn berî îmzekirinê peymanê bi hûrî bixwînin."
            },
            {
              "language": "pl",
              "text": "Radzę dokładnie przeczytać umowę przed podpisaniem."
            },
            {
              "language": "ro",
              "text": "Vă sfătuiesc să citiți atent contractul înainte de semnare."
            },
            {
              "language": "ru",
              "text": "Я советую вам внимательно прочитать договор перед подписанием."
            },
            {
              "language": "sq",
              "text": "Ju këshilloj ta lexoni me kujdes kontratën para nënshkrimit."
            },
            {
              "language": "tr",
              "text": "Sözleşmeyi imzalamadan önce dikkatlice okumanızı tavsiye ederim."
            }
          ]
        },
        {
          "baseText": "Kannst du raten, wer heute angerufen hat?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك أن تخمّن من اتصل اليوم؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت پێشبینی بکەیت ئەمڕۆ کێ پەیوەندی کرد؟"
            },
            {
              "language": "en",
              "text": "Can you guess who called today?"
            },
            {
              "language": "fa",
              "text": "می‌توانی حدس بزنی امروز چه کسی زنگ زد؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî texmîn bikî îro kî telefon kir?"
            },
            {
              "language": "pl",
              "text": "Czy możesz zgadnąć, kto dziś dzwonił?"
            },
            {
              "language": "ro",
              "text": "Poți ghici cine a sunat astăzi?"
            },
            {
              "language": "ru",
              "text": "Можешь угадать, кто сегодня звонил?"
            },
            {
              "language": "sq",
              "text": "A mund ta gjesh kush telefonoi sot?"
            },
            {
              "language": "tr",
              "text": "Bugün kimin aradığını tahmin edebilir misin?"
            }
          ]
        }
      ]
    },
