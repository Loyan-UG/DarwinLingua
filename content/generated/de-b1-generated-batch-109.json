  "entries": [
    {
      "word": "die Rate",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Raten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ra-te",
      "topics": [
        "finance-and-accounting",
        "shopping-and-services",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "formal",
        "business",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; in finance means installment"
      ],
      "collocations": [
        {
          "text": "eine monatliche Rate zahlen",
          "meaning": "to pay a monthly installment"
        },
        {
          "text": "die letzte Rate",
          "meaning": "the final installment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Ratenzahlung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "in Raten zahlen",
          "relationLabel": "phrase",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قسط؛ دفعة دورية"
        },
        {
          "language": "ckb",
          "text": "قیست؛ پارەدانی مانگانە"
        },
        {
          "language": "en",
          "text": "installment; payment rate"
        },
        {
          "language": "fa",
          "text": "قسط؛ پرداخت دوره‌ای"
        },
        {
          "language": "kmr",
          "text": "qist; dayîna demkî"
        },
        {
          "language": "pl",
          "text": "rata"
        },
        {
          "language": "ro",
          "text": "rată; tranșă de plată"
        },
        {
          "language": "ru",
          "text": "платёж; взнос; рассрочка"
        },
        {
          "language": "sq",
          "text": "këst; pagesë periodike"
        },
        {
          "language": "tr",
          "text": "taksit; ödeme dilimi"
        }
      ],
      "examples": [
        {
          "baseText": "Die monatliche Rate für das Fahrrad beträgt 35 Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "القسط الشهري للدراجة يبلغ 35 يورو."
            },
            {
              "language": "ckb",
              "text": "قیستی مانگانەی پاسکیلەکە ٣٥ یۆرۆیە."
            },
            {
              "language": "en",
              "text": "The monthly installment for the bicycle is 35 euros."
            },
            {
              "language": "fa",
              "text": "قسط ماهانه دوچرخه ۳۵ یورو است."
            },
            {
              "language": "kmr",
              "text": "Qista mehane ya bisiklêtê 35 euro ye."
            },
            {
              "language": "pl",
              "text": "Miesięczna rata za rower wynosi 35 euro."
            },
            {
              "language": "ro",
              "text": "Rata lunară pentru bicicletă este de 35 de euro."
            },
            {
              "language": "ru",
              "text": "Ежемесячный платёж за велосипед составляет 35 евро."
            },
            {
              "language": "sq",
              "text": "Kësti mujor për biçikletën është 35 euro."
            },
            {
              "language": "tr",
              "text": "Bisikletin aylık taksiti 35 avro."
            }
          ]
        },
        {
          "baseText": "Bitte überweisen Sie die nächste Rate bis zum Monatsende.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تحويل القسط التالي حتى نهاية الشهر."
            },
            {
              "language": "ckb",
              "text": "تکایە قیستی داهاتوو تا کۆتایی مانگ بگوازنەوە."
            },
            {
              "language": "en",
              "text": "Please transfer the next installment by the end of the month."
            },
            {
              "language": "fa",
              "text": "لطفاً قسط بعدی را تا پایان ماه واریز کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe qista bê heta dawiya mehê veguhêzin."
            },
            {
              "language": "pl",
              "text": "Proszę przelać następną ratę do końca miesiąca."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să transferați următoarea rată până la sfârșitul lunii."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, переведите следующий платёж до конца месяца."
            },
            {
              "language": "sq",
              "text": "Ju lutem transferoni këstin tjetër deri në fund të muajit."
            },
            {
              "language": "tr",
              "text": "Lütfen bir sonraki taksiti ay sonuna kadar havale edin."
            }
          ]
        }
      ]
    },
    {
      "word": "raten",
      "language": "de",
      "cefrLevel": "B1",
