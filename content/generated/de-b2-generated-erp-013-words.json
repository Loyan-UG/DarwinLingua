  "entries": [
    {
      "word": "Kalkulationsschema",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Kalkulationsschemata",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kal-ku-la-ti-ons-sche-ma",
      "topics": [
        "finance-and-accounting",
        "erp-and-business-systems",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter compound noun; calculation or costing scheme in pricing and accounting"
      ],
      "collocations": [
        {
          "text": "ein Kalkulationsschema pflegen",
          "meaning": "to maintain a costing scheme"
        },
        {
          "text": "das Kalkulationsschema anwenden",
          "meaning": "to apply the calculation scheme"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kalkulieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "das Schema",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مخطط حساب التكلفة"
        },
        {
          "language": "ckb",
          "text": "شێوازی هەژمارکردن"
        },
        {
          "language": "en",
          "text": "calculation scheme; costing scheme"
        },
        {
          "language": "fa",
          "text": "طرح محاسبه؛ شمای بهایابی"
        },
        {
          "language": "kmr",
          "text": "şemaya hesabkirinê"
        },
        {
          "language": "pl",
          "text": "schemat kalkulacji"
        },
        {
          "language": "ro",
          "text": "schemă de calculație"
        },
        {
          "language": "ru",
          "text": "схема калькуляции"
        },
        {
          "language": "sq",
          "text": "skemë kalkulimi"
        },
        {
          "language": "tr",
          "text": "hesaplama şeması"
        }
      ],
      "examples": [
        {
          "baseText": "Das Kalkulationsschema legt im ERP fest, welche Kosten in den Verkaufspreis einfließen.",
          "translations": [
            {
              "language": "ar",
              "text": "يحدد مخطط حساب التكلفة في ERP أي تكاليف تدخل في سعر البيع."
            },
            {
              "language": "ckb",
              "text": "شێوازی هەژمارکردن لە ERP دا دیاری دەکات کام تێچوو دەچێتە ناو نرخی فرۆشتن."
            },
            {
              "language": "en",
              "text": "The calculation scheme in the ERP defines which costs are included in the sales price."
            },
            {
              "language": "fa",
              "text": "طرح محاسبه در ERP مشخص می‌کند کدام هزینه‌ها وارد قیمت فروش شوند."
            },
            {
              "language": "kmr",
              "text": "Şemaya hesabkirinê di ERP de diyar dike kîjan lêçûn di bihayê firotanê de têne hesibandin."
            },
            {
              "language": "pl",
              "text": "Schemat kalkulacji w ERP określa, które koszty wchodzą do ceny sprzedaży."
            },
            {
              "language": "ro",
              "text": "Schema de calculație din ERP stabilește ce costuri intră în prețul de vânzare."
            },
            {
              "language": "ru",
              "text": "Схема калькуляции в ERP определяет, какие расходы включаются в продажную цену."
            },
            {
              "language": "sq",
              "text": "Skema e kalkulimit në ERP përcakton cilat kosto përfshihen në çmimin e shitjes."
            },
            {
              "language": "tr",
              "text": "ERP’deki hesaplama şeması hangi maliyetlerin satış fiyatına dahil edileceğini belirler."
            }
          ]
        },
        {
          "baseText": "Nach der Änderung im Kalkulationsschema müssen wir mehrere Angebote neu berechnen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد التغيير في مخطط الحساب يجب أن نعيد حساب عدة عروض."
            },
            {
              "language": "ckb",
              "text": "دوای گۆڕانکاری لە شێوازی هەژمارکردن، پێویستە چەند پێشنیارێک دووبارە هەژمار بکەین."
            },
            {
              "language": "en",
              "text": "After the change in the calculation scheme, we have to recalculate several quotations."
            },
            {
              "language": "fa",
              "text": "پس از تغییر در طرح محاسبه، باید چند پیشنهاد قیمت را دوباره محاسبه کنیم."
            },
            {
              "language": "kmr",
              "text": "Piştî guherîna di şemaya hesabkirinê de, divê em çend pêşniyaran ji nû ve hesab bikin."
            },
            {
              "language": "pl",
              "text": "Po zmianie w schemacie kalkulacji musimy ponownie przeliczyć kilka ofert."
            },
            {
              "language": "ro",
              "text": "După modificarea schemei de calculație, trebuie să recalculăm mai multe oferte."
            },
            {
              "language": "ru",
              "text": "После изменения схемы калькуляции нам нужно пересчитать несколько предложений."
            },
            {
              "language": "sq",
              "text": "Pas ndryshimit në skemën e kalkulimit, duhet të rillogarisim disa oferta."
            },
            {
              "language": "tr",
              "text": "Hesaplama şemasındaki değişiklikten sonra birkaç teklifi yeniden hesaplamalıyız."
            }
          ]
        }
      ]
    },
    {
      "word": "Kassenabschluss",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Kassenabschlüsse",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kas-sen-ab-schluss",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; cash register closing at end of shift or day"
      ],
      "collocations": [
        {
          "text": "den Kassenabschluss durchführen",
          "meaning": "to perform the cash register closing"
        },
        {
          "text": "den Kassenabschluss prüfen",
          "meaning": "to check the cash register closing"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kasse",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "abschließen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إغلاق الصندوق"
        },
        {
          "language": "ckb",
          "text": "داخستنی کاشێر"
        },
        {
          "language": "en",
          "text": "cash register closing"
        },
        {
          "language": "fa",
          "text": "بستن صندوق؛ تسویه صندوق"
        },
        {
          "language": "kmr",
          "text": "girtina kaseyê"
        },
        {
          "language": "pl",
          "text": "zamknięcie kasy"
        },
        {
          "language": "ro",
          "text": "închidere de casă"
        },
        {
          "language": "ru",
          "text": "закрытие кассы"
        },
        {
          "language": "sq",
          "text": "mbyllje arke"
        },
        {
          "language": "tr",
          "text": "kasa kapanışı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kassenabschluss wird nach Ladenschluss im ERP gebucht.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم ترحيل إغلاق الصندوق في ERP بعد إغلاق المتجر."
            },
            {
              "language": "ckb",
              "text": "داخستنی کاشێر دوای داخستنی دوکان لە ERP دا تۆمار دەکرێت."
            },
            {
              "language": "en",
              "text": "The cash register closing is posted in the ERP after the store closes."
            },
            {
              "language": "fa",
              "text": "بستن صندوق پس از بسته شدن فروشگاه در ERP ثبت می‌شود."
            },
            {
              "language": "kmr",
              "text": "Girtina kaseyê piştî girtina firoşgehê di ERP de tê tomarkirin."
            },
            {
              "language": "pl",
              "text": "Zamknięcie kasy jest księgowane w ERP po zamknięciu sklepu."
            },
            {
              "language": "ro",
              "text": "Închiderea de casă este înregistrată în ERP după închiderea magazinului."
            },
            {
              "language": "ru",
              "text": "Закрытие кассы проводится в ERP после закрытия магазина."
            },
            {
              "language": "sq",
              "text": "Mbyllja e arkës regjistrohet në ERP pas mbylljes së dyqanit."
            },
            {
              "language": "tr",
              "text": "Kasa kapanışı mağaza kapandıktan sonra ERP’de kaydedilir."
            }
          ]
        },
        {
          "baseText": "Beim Kassenabschluss fehlten zwanzig Euro, deshalb musste die Schichtleitung den Vorgang prüfen.",
          "translations": [
            {
              "language": "ar",
              "text": "عند إغلاق الصندوق كان هناك نقص عشرين يورو، لذلك كان على مسؤول الوردية فحص العملية."
            },
            {
              "language": "ckb",
              "text": "لە داخستنی کاشێردا بیست یۆرۆ کەم بوو، بۆیە سەرپەرشتی شفت پێویست بوو پرۆسەکە بپشکنێت."
            },
            {
              "language": "en",
              "text": "At cash register closing, twenty euros were missing, so the shift manager had to check the process."
            },
            {
              "language": "fa",
              "text": "هنگام بستن صندوق بیست یورو کم بود، بنابراین سرپرست شیفت باید فرایند را بررسی می‌کرد."
            },
            {
              "language": "kmr",
              "text": "Di girtina kaseyê de bîst euro kêm bû, ji ber vê yekê serokê şiftê diviya pêvajoyê kontrol bike."
            },
            {
              "language": "pl",
              "text": "Przy zamknięciu kasy brakowało dwudziestu euro, dlatego kierownik zmiany musiał sprawdzić proces."
            },
            {
              "language": "ro",
              "text": "La închiderea casei lipseau douăzeci de euro, de aceea șeful de tură a trebuit să verifice procesul."
            },
            {
              "language": "ru",
              "text": "При закрытии кассы не хватало двадцати евро, поэтому начальник смены должен был проверить процесс."
            },
            {
              "language": "sq",
              "text": "Gjatë mbylljes së arkës mungonin njëzet euro, prandaj përgjegjësi i turnit duhej të kontrollonte procesin."
            },
            {
              "language": "tr",
              "text": "Kasa kapanışında yirmi avro eksikti, bu yüzden vardiya sorumlusu işlemi kontrol etmek zorunda kaldı."
            }
          ]
        }
      ]
    },
