      "examples": [
        {
          "baseText": "Der Kassenbon wird im ERP mit dem Verkaufsvorgang verknüpft.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم ربط إيصال الصندوق في ERP بعملية البيع."
            },
            {
              "language": "ckb",
              "text": "پسوڵەی کاشێر لە ERP دا بە پرۆسەی فرۆشتنەکە دەبەسترێتەوە."
            },
            {
              "language": "en",
              "text": "The cash register receipt is linked to the sales transaction in the ERP."
