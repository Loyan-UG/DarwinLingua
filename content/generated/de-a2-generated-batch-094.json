      "contextLabels": [],
      "grammarNotes": [
        "regular verb; often used for tickets or documents"
      ],
      "collocations": [
        {
          "text": "ein Ticket stempeln",
          "meaning": "to stamp/validate a ticket"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Stempel",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يختم؛ يضع ختمًا"
        },
        {
          "language": "ckb",
          "text": "مۆر دەکات؛ ستەمپڵ دەکات"
        },
        {
          "language": "en",
          "text": "to stamp; to validate"
        },
        {
          "language": "fa",
          "text": "مهر زدن؛ اعتبارسنجی کردن"
        },
        {
          "language": "kmr",
          "text": "mor kirin; stempel kirin"
        },
        {
          "language": "pl",
          "text": "stemplować; kasować"
        },
        {
          "language": "ro",
          "text": "a ștampila; a valida"
        },
        {
          "language": "ru",
          "text": "ставить штамп; компостировать"
        },
        {
          "language": "sq",
          "text": "të vulosësh; të validosh"
        },
        {
          "language": "tr",
          "text": "damgalamak; onaylatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte stempeln Sie das Ticket vor der Fahrt.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى ختم التذكرة قبل الرحلة."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش گەشتەکە بلیتەکە ستەمپڵ بکەن."
            },
            {
              "language": "en",
              "text": "Please validate the ticket before the trip."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از سفر بلیت را مهر/اعتبارسنجی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî rêwîtiyê bilêtê stempel bikin."
            },
            {
              "language": "pl",
              "text": "Proszę skasować bilet przed podróżą."
            },
            {
              "language": "ro",
              "text": "Vă rog să validați biletul înainte de călătorie."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, прокомпостируйте билет перед поездкой."
            },
            {
              "language": "sq",
              "text": "Ju lutem validojeni biletën para udhëtimit."
            },
            {
              "language": "tr",
              "text": "Lütfen yolculuktan önce bileti onaylatın."
            }
          ]
        },
        {
          "baseText": "Die Mitarbeiterin stempelt das Formular am Schalter.",
          "translations": [
            {
              "language": "ar",
              "text": "تختم الموظفة الاستمارة عند الشباك."
            },
            {
              "language": "ckb",
              "text": "کارمەندەکە فۆرمەکە لە پەنجەرەکە ستەمپڵ دەکات."
            },
            {
              "language": "en",
              "text": "The employee stamps the form at the counter."
            },
            {
              "language": "fa",
              "text": "کارمند فرم را در باجه مهر می‌زند."
            },
            {
              "language": "kmr",
              "text": "Karmend formê li gişeyê mor dike."
            },
            {
              "language": "pl",
              "text": "Pracownica stempluje formularz przy okienku."
            },
            {
              "language": "ro",
              "text": "Angajata ștampilează formularul la ghișeu."
            },
            {
              "language": "ru",
              "text": "Сотрудница ставит штамп на форму у стойки."
            },
            {
              "language": "sq",
              "text": "Punonjësja vulos formularin te sporteli."
            },
            {
              "language": "tr",
              "text": "Çalışan formu gişede damgalıyor."
            }
          ]
        }
      ]
    },
