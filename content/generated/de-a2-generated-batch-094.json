      "examples": [
        {
          "baseText": "Viele alte Bäume sterben ohne Wasser.",
          "translations": [
            {
              "language": "ar",
              "text": "تموت أشجار قديمة كثيرة من دون ماء."
            },
            {
              "language": "ckb",
              "text": "دارە کۆنە زۆرەکان بەبێ ئاو دەمرن."
            },
            {
              "language": "en",
              "text": "Many old trees die without water."
            },
            {
              "language": "fa",
              "text": "بسیاری از درختان قدیمی بدون آب می‌میرند."
            },
            {
              "language": "kmr",
              "text": "Gelek darên kevn bê av dimirin."
            },
            {
              "language": "pl",
              "text": "Wiele starych drzew umiera bez wody."
            },
            {
              "language": "ro",
              "text": "Mulți copaci bătrâni mor fără apă."
            },
            {
              "language": "ru",
              "text": "Многие старые деревья погибают без воды."
            },
            {
              "language": "sq",
              "text": "Shumë pemë të vjetra vdesin pa ujë."
            },
            {
              "language": "tr",
              "text": "Birçok yaşlı ağaç susuz ölür."
            }
          ]
        },
        {
          "baseText": "Sein Hund ist letztes Jahr gestorben.",
          "translations": [
            {
              "language": "ar",
              "text": "مات كلبه في العام الماضي."
            },
            {
              "language": "ckb",
              "text": "سەگەکەی ساڵی ڕابردوو مرد."
            },
            {
              "language": "en",
              "text": "His dog died last year."
            },
            {
              "language": "fa",
              "text": "سگ او سال گذشته مرد."
            },
            {
              "language": "kmr",
              "text": "Kûçikê wî sala borî mir."
            },
            {
              "language": "pl",
              "text": "Jego pies umarł w zeszłym roku."
            },
            {
              "language": "ro",
              "text": "Câinele lui a murit anul trecut."
            },
            {
              "language": "ru",
              "text": "Его собака умерла в прошлом году."
            },
            {
              "language": "sq",
              "text": "Qeni i tij vdiq vitin e kaluar."
            },
            {
              "language": "tr",
              "text": "Köpeği geçen yıl öldü."
            }
          ]
        }
      ]
