      "examples": [
        {
          "baseText": "Ich möchte meine Reservierung stornieren.",
          "translations": [
            {
              "language": "ar",
              "text": "أود إلغاء حجزي."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت حجزەکەم هەڵبوەشێنمەوە."
            },
            {
              "language": "en",
              "text": "I would like to cancel my reservation."
            },
            {
              "language": "fa",
              "text": "می‌خواهم رزرو خود را لغو کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim veqetandina xwe betal bikim."
            },
            {
              "language": "pl",
              "text": "Chciałbym anulować rezerwację."
            },
            {
              "language": "ro",
              "text": "Aș dori să anulez rezervarea mea."
            },
            {
              "language": "ru",
              "text": "Я хотел бы отменить свое бронирование."
            },
            {
              "language": "sq",
              "text": "Do të doja të anuloja rezervimin tim."
            },
            {
              "language": "tr",
              "text": "Rezervasyonumu iptal etmek istiyorum."
            }
          ]
        },
        {
          "baseText": "Sie können das Ticket bis morgen kostenlos stornieren.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم إلغاء التذكرة مجانًا حتى الغد."
            },
            {
              "language": "ckb",
              "text": "دەتوانن تا سبەی بلیتەکە بەبێ پارە هەڵبوەشێننەوە."
            },
            {
              "language": "en",
              "text": "You can cancel the ticket free of charge until tomorrow."
            },
            {
              "language": "fa",
              "text": "می‌توانید بلیت را تا فردا رایگان لغو کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin heta sibê bilêtê belaş betal bikin."
            },
            {
              "language": "pl",
              "text": "Mogą państwo bezpłatnie anulować bilet do jutra."
            },
            {
              "language": "ro",
              "text": "Puteți anula biletul gratuit până mâine."
            },
            {
              "language": "ru",
              "text": "Вы можете бесплатно отменить билет до завтра."
            },
            {
              "language": "sq",
              "text": "Mund ta anuloni biletën falas deri nesër."
            },
            {
              "language": "tr",
              "text": "Bileti yarına kadar ücretsiz iptal edebilirsiniz."
            }
