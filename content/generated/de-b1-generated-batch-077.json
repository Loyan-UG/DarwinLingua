  "entries": [
    {
      "word": "die IBAN",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "IBANs",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "I-BAN",
      "topics": [
        "finance-and-accounting",
        "documents-and-administration",
        "shopping-and-services"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; abbreviation for Internationale Bankkontonummer"
      ],
      "collocations": [
        {
          "text": "die IBAN angeben",
          "meaning": "to provide the IBAN"
        },
        {
          "text": "die IBAN prüfen",
          "meaning": "to check the IBAN"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Kontonummer",
          "relationLabel": "related noun",
          "note": null
        },
        {
          "lemma": "die Bankverbindung",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "رقم الحساب المصرفي الدولي"
        },
        {
          "language": "ckb",
          "text": "ژمارەی نێودەوڵەتی هەژماری بانکی"
        },
        {
          "language": "en",
          "text": "IBAN; international bank account number"
        },
        {
          "language": "fa",
          "text": "شماره شبای بانکی؛ IBAN"
        },
        {
          "language": "kmr",
          "text": "hejmara hesabê bankê ya navneteweyî"
        },
        {
          "language": "pl",
          "text": "IBAN; międzynarodowy numer rachunku bankowego"
        },
        {
          "language": "ro",
          "text": "IBAN; număr internațional de cont bancar"
        },
        {
          "language": "ru",
          "text": "IBAN; международный номер банковского счёта"
        },
        {
          "language": "sq",
          "text": "IBAN; numër ndërkombëtar llogarie bankare"
        },
        {
          "language": "tr",
          "text": "IBAN; uluslararası banka hesap numarası"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte geben Sie auf dem Formular Ihre IBAN für die Rückzahlung an.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إدخال رقم IBAN الخاص بكم في النموذج من أجل استرداد المبلغ."
            },
            {
              "language": "ckb",
              "text": "تکایە بۆ گەڕاندنەوەی پارە IBAN ـەکەتان لە فۆرمەکەدا بنووسن."
            },
            {
              "language": "en",
              "text": "Please enter your IBAN on the form for the refund."
            },
            {
              "language": "fa",
              "text": "لطفاً برای بازپرداخت، IBAN خود را در فرم وارد کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe ji bo vegerandina pereyan IBAN-a xwe di formê de binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę podać na formularzu swój IBAN do zwrotu pieniędzy."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să introduceți IBAN-ul în formular pentru rambursare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, укажите свой IBAN в форме для возврата денег."
            },
            {
              "language": "sq",
              "text": "Ju lutemi shkruani IBAN-in tuaj në formular për rimbursimin."
            },
            {
              "language": "tr",
              "text": "İade için lütfen formda IBAN numaranızı belirtin."
            }
          ]
        },
        {
          "baseText": "Die Buchhaltung konnte die IBAN des Lieferanten nicht lesen.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يستطع قسم المحاسبة قراءة رقم IBAN الخاص بالمورّد."
            },
            {
              "language": "ckb",
              "text": "ژمێریاری نەیتوانی IBAN ـی دابینکەرەکە بخوێنێتەوە."
            },
            {
              "language": "en",
              "text": "Accounting could not read the supplier’s IBAN."
            },
            {
              "language": "fa",
              "text": "حسابداری نتوانست IBAN تأمین‌کننده را بخواند."
            },
            {
              "language": "kmr",
              "text": "Hesabgirî nikarî IBAN-a pêşkêşkerê bixwîne."
            },
            {
              "language": "pl",
              "text": "Księgowość nie mogła odczytać IBAN-u dostawcy."
            },
            {
              "language": "ro",
              "text": "Contabilitatea nu a putut citi IBAN-ul furnizorului."
            },
            {
              "language": "ru",
              "text": "Бухгалтерия не смогла прочитать IBAN поставщика."
            },
            {
              "language": "sq",
              "text": "Kontabiliteti nuk mundi ta lexonte IBAN-in e furnizuesit."
            },
            {
              "language": "tr",
              "text": "Muhasebe tedarikçinin IBAN numarasını okuyamadı."
            }
          ]
        }
      ]
    },
    {
      "word": "immerhin",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
