  "entries": [
    {
      "word": "die Stilistik",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Sti-lis-tik",
      "topics": [
        "culture-and-media",
        "education-and-training",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually used in the singular for the study or quality of style"
      ],
      "collocations": [
        {
          "text": "die Stilistik eines Textes analysieren",
          "meaning": "to analyze the stylistic features of a text"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "stilistisch",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "der Stil",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "علم الأسلوب؛ السمات الأسلوبية"
        },
        {
          "language": "ckb",
          "text": "ستایلناسی؛ تایبەتمەندییەکانی شێواز"
        },
        {
          "language": "en",
          "text": "stylistics; stylistic features"
        },
        {
          "language": "fa",
          "text": "سبک‌شناسی؛ ویژگی‌های سبکی"
        },
        {
          "language": "kmr",
          "text": "stilnasî; taybetmendiyên şêwazî"
        },
        {
          "language": "pl",
          "text": "stylistyka; cechy stylistyczne"
        },
        {
          "language": "ro",
          "text": "stilistică; trăsături stilistice"
        },
        {
          "language": "ru",
          "text": "стилистика; стилистические особенности"
        },
        {
          "language": "sq",
          "text": "stilistikë; veçori stilistike"
        },
        {
          "language": "tr",
          "text": "üslupbilim; biçemsel özellikler"
        }
      ],
      "examples": [
        {
          "baseText": "Die Stilistik des Berichts wirkt sachlich, vermeidet aber jede persönliche Verantwortung.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدو أسلوبية التقرير موضوعية، لكنها تتجنب أي مسؤولية شخصية."
            },
            {
              "language": "ckb",
              "text": "ستایلی ڕاپۆرتەکە بابەتی دەردەکەوێت، بەڵام هەر بەرپرسیارێتییەکی کەسی دەرباز دەکات."
            },
            {
              "language": "en",
              "text": "The stylistics of the report appear objective, but avoid any personal responsibility."
            },
            {
              "language": "fa",
              "text": "سبک گزارش عینی به نظر می‌رسد، اما از هرگونه مسئولیت شخصی پرهیز می‌کند."
            },
            {
              "language": "kmr",
              "text": "Stilistîka raporê objektîf dixuye, lê ji her berpirsiyariya kesane dûr dikeve."
            },
            {
              "language": "pl",
              "text": "Stylistyka raportu wydaje się rzeczowa, ale unika jakiejkolwiek osobistej odpowiedzialności."
            },
            {
              "language": "ro",
              "text": "Stilistica raportului pare obiectivă, dar evită orice responsabilitate personală."
            },
            {
              "language": "ru",
              "text": "Стилистика отчета выглядит объективной, но избегает любой личной ответственности."
            },
            {
              "language": "sq",
              "text": "Stilistika e raportit duket objektive, por shmang çdo përgjegjësi personale."
            },
            {
              "language": "tr",
              "text": "Raporun üslubu nesnel görünüyor, ancak her türlü kişisel sorumluluktan kaçınıyor."
            }
          ]
        },
        {
          "baseText": "In der Redaktion wurde lange über die Stilistik der Überschrift diskutiert.",
          "translations": [
            {
              "language": "ar",
              "text": "في هيئة التحرير نوقش أسلوب العنوان طويلاً."
            },
            {
              "language": "ckb",
              "text": "لە دەستەی نووسەراندا ماوەیەکی درێژ لەسەر شێوازی ناونیشانەکە گفتوگۆ کرا."
            },
            {
              "language": "en",
              "text": "The editorial team discussed the stylistics of the headline for a long time."
            },
            {
              "language": "fa",
              "text": "در تحریریه مدت زیادی درباره سبک تیتر بحث شد."
            },
            {
              "language": "kmr",
              "text": "Di redaksiyonê de demeke dirêj li ser stilistîka sernavê hate gotûbêjkirin."
            },
            {
              "language": "pl",
              "text": "W redakcji długo dyskutowano o stylistyce nagłówka."
            },
            {
              "language": "ro",
              "text": "În redacție s-a discutat mult despre stilistica titlului."
            },
            {
              "language": "ru",
              "text": "В редакции долго обсуждали стилистику заголовка."
            },
            {
              "language": "sq",
              "text": "Në redaksi u diskutua gjatë për stilistikën e titullit."
            },
            {
              "language": "tr",
              "text": "Yazı kurulunda başlığın üslubu uzun süre tartışıldı."
            }
          ]
        }
      ]
    },
    {
      "word": "stringent",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "strin-gent",
      "topics": [
        "advanced-analysis",
        "business-communication",
        "meetings-and-presentations"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes reasoning, argumentation, or structure as logically consistent and tight"
      ],
      "collocations": [
        {
          "text": "stringent argumentieren",
          "meaning": "to argue in a logically consistent way"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Stringenz",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "محكم ومنطقي ومتسق"
        },
        {
          "language": "ckb",
          "text": "توندوتۆڵ، لۆژیکی و یەکگرتوو"
        },
        {
          "language": "en",
          "text": "stringent; logically consistent and rigorous"
        },
        {
          "language": "fa",
          "text": "منسجم، منطقی و دقیق"
        },
        {
          "language": "kmr",
          "text": "zexm, mantiqî û yekgirtî"
        },
        {
          "language": "pl",
          "text": "spójny, logiczny i rygorystyczny"
        },
        {
          "language": "ro",
          "text": "riguros și logic coerent"
        },
        {
          "language": "ru",
          "text": "строгий, логичный и последовательный"
        },
        {
          "language": "sq",
          "text": "i rreptë, logjik dhe koherent"
        },
        {
          "language": "tr",
          "text": "tutarlı, mantıklı ve sıkı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Präsentation war fachlich stark, aber die Argumentation hätte stringenter aufgebaut sein müssen.",
          "translations": [
            {
              "language": "ar",
              "text": "كان العرض قوياً من الناحية المتخصصة، لكن كان ينبغي بناء الحجة بشكل أكثر إحكاماً."
            },
            {
              "language": "ckb",
              "text": "پێشکەشکردنەکە لە ڕووی پسپۆڕییەوە بەهێز بوو، بەڵام پێویست بوو بەڵگەهێنانەکە یەکگرتووتر دابنرێت."
            },
            {
              "language": "en",
              "text": "The presentation was strong in terms of expertise, but the argumentation should have been structured more stringently."
            },
            {
              "language": "fa",
              "text": "ارائه از نظر تخصصی قوی بود، اما استدلال باید منسجم‌تر ساخته می‌شد."
            },
            {
              "language": "kmr",
              "text": "Pêşkêşî ji aliyê pisporiyê ve xurt bû, lê diviya argûmentasyon zêdetir bi rêkûpêkî were avakirin."
            },
            {
              "language": "pl",
              "text": "Prezentacja była mocna merytorycznie, ale argumentacja powinna być zbudowana bardziej spójnie."
            },
            {
              "language": "ro",
              "text": "Prezentarea a fost solidă profesional, dar argumentația ar fi trebuit structurată mai riguros."
            },
            {
              "language": "ru",
              "text": "Презентация была сильной с профессиональной точки зрения, но аргументацию следовало выстроить более строго."
            },
            {
              "language": "sq",
              "text": "Prezantimi ishte i fortë nga ana profesionale, por argumentimi duhej ndërtuar më koherentisht."
            },
            {
              "language": "tr",
              "text": "Sunum uzmanlık açısından güçlüydü, ancak argümantasyon daha tutarlı kurulmalıydı."
            }
          ]
        },
        {
          "baseText": "Für ein komplexes Migrationsprojekt brauchen wir einen stringenten Ablaufplan mit klaren Abhängigkeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "لمشروع ترحيل معقد نحتاج إلى خطة سير محكمة ذات تبعيات واضحة."
            },
            {
              "language": "ckb",
              "text": "بۆ پرۆژەیەکی ئاڵۆزی گواستنەوە پێویستمان بە پلانی کاری یەکگرتوو هەیە کە پەیوەندییەکان ڕوون بن."
            },
            {
              "language": "en",
              "text": "For a complex migration project, we need a stringent process plan with clear dependencies."
            },
            {
              "language": "fa",
              "text": "برای یک پروژه مهاجرت پیچیده، به برنامه اجرایی منسجم با وابستگی‌های روشن نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo projeyeke tevlihev a veguheztinê em hewceyê plansaziyeke rêkûpêk in bi girêdanên zelal."
            },
            {
              "language": "pl",
              "text": "W złożonym projekcie migracji potrzebujemy spójnego planu przebiegu z jasnymi zależnościami."
            },
            {
              "language": "ro",
              "text": "Pentru un proiect complex de migrare avem nevoie de un plan riguros de desfășurare, cu dependențe clare."
            },
            {
              "language": "ru",
              "text": "Для сложного проекта миграции нам нужен строгий план процесса с четкими зависимостями."
            },
            {
              "language": "sq",
              "text": "Për një projekt kompleks migrimi na duhet një plan i rreptë procesi me varësi të qarta."
            },
            {
              "language": "tr",
              "text": "Karmaşık bir geçiş projesi için net bağımlılıkları olan tutarlı bir süreç planına ihtiyacımız var."
            }
          ]
        }
      ]
    },
    {
      "word": "die Strukturähnlichkeit",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Strukturähnlichkeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Struk-tur-ähn-lich-keit",
      "topics": [
        "advanced-analysis",
        "technology-and-it",
