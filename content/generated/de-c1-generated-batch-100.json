      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; used when comparing systems, texts, data, or institutions"
      ],
      "collocations": [
        {
          "text": "Strukturähnlichkeiten erkennen",
          "meaning": "to identify structural similarities"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "strukturähnlich",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "die Struktur",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تشابه بنيوي"
        },
        {
          "language": "ckb",
          "text": "لێکچوونی پێکهاتەیی"
        },
        {
          "language": "en",
          "text": "structural similarity"
        },
        {
          "language": "fa",
          "text": "شباهت ساختاری"
        },
        {
          "language": "kmr",
          "text": "wekheviya avahiyî"
        },
        {
          "language": "pl",
          "text": "podobieństwo strukturalne"
        },
        {
          "language": "ro",
          "text": "asemănare structurală"
        },
        {
          "language": "ru",
          "text": "структурное сходство"
        },
        {
          "language": "sq",
          "text": "ngjashmëri strukturore"
        },
        {
          "language": "tr",
          "text": "yapısal benzerlik"
        }
      ],
      "examples": [
        {
          "baseText": "Die Strukturähnlichkeit der beiden Verträge erleichterte die juristische Prüfung erheblich.",
          "translations": [
            {
              "language": "ar",
              "text": "سهّل التشابه البنيوي بين العقدين الفحص القانوني بشكل كبير."
            },
            {
              "language": "ckb",
              "text": "لێکچوونی پێکهاتەییی هەردوو گرێبەستەکە پشکنینی یاسایی زۆر ئاسانتر کرد."
            },
            {
              "language": "en",
              "text": "The structural similarity of the two contracts made the legal review much easier."
            },
            {
              "language": "fa",
              "text": "شباهت ساختاری دو قرارداد بررسی حقوقی را بسیار آسان‌تر کرد."
            },
            {
              "language": "kmr",
              "text": "Wekheviya avahiyî ya her du peymanan vekolîna hiqûqî gelek hêsantir kir."
            },
            {
              "language": "pl",
              "text": "Podobieństwo strukturalne obu umów znacznie ułatwiło analizę prawną."
            },
            {
              "language": "ro",
              "text": "Asemănarea structurală a celor două contracte a facilitat considerabil verificarea juridică."
            },
            {
              "language": "ru",
              "text": "Структурное сходство двух договоров значительно упростило юридическую проверку."
            },
            {
              "language": "sq",
              "text": "Ngjashmëria strukturore e dy kontratave e lehtësoi ndjeshëm kontrollin juridik."
            },
            {
