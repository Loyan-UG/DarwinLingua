      "examples": [
        {
          "baseText": "Die Gewichtung der Kriterien muss vor der Bewertung der Angebote feststehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب تحديد وزن المعايير قبل تقييم العروض."
            },
            {
              "language": "ckb",
              "text": "قورسایی پێدانی پێوەرەکان دەبێت پێش هەڵسەنگاندنی پێشنیارەکان دیاریکرابێت."
            },
            {
              "language": "en",
              "text": "The weighting of the criteria must be fixed before the offers are evaluated."
            },
            {
              "language": "fa",
              "text": "وزن‌دهی معیارها باید پیش از ارزیابی پیشنهادها مشخص شده باشد."
            },
            {
              "language": "kmr",
              "text": "Girangîdana pîvanan divê berî nirxandina pêşniyaran diyar bibe."
            },
            {
              "language": "pl",
              "text": "Wagi kryteriów muszą być ustalone przed oceną ofert."
            },
            {
              "language": "ro",
              "text": "Ponderarea criteriilor trebuie stabilită înainte de evaluarea ofertelor."
            },
            {
              "language": "ru",
              "text": "Вес критериев должен быть установлен до оценки предложений."
            },
            {
              "language": "sq",
              "text": "Peshimi i kritereve duhet të përcaktohet para vlerësimit të ofertave."
            },
            {
              "language": "tr",
              "text": "Kriterlerin ağırlıklandırması tekliflerin değerlendirilmesinden önce belirlenmiş olmalıdır."
            }
          ]
        },
        {
          "baseText": "Eine andere Gewichtung der Risikofaktoren würde zu einer deutlich anderen Empfehlung führen.",
          "translations": [
            {
              "language": "ar",
              "text": "سيؤدي ترجيح مختلف لعوامل الخطر إلى توصية مختلفة بوضوح."
            },
            {
              "language": "ckb",
              "text": "قورسایی پێدانێکی جیاواز بۆ هۆکارەکانی مەترسی دەبێتە هۆی پێشنیارێکی بە ڕوونی جیاواز."
            },
            {
              "language": "en",
              "text": "A different weighting of the risk factors would lead to a clearly different recommendation."
            },
            {
              "language": "fa",
              "text": "وزن‌دهی متفاوت به عوامل ریسک به توصیه‌ای به‌وضوح متفاوت منجر می‌شود."
            },
            {
              "language": "kmr",
              "text": "Girangîdaneke cuda ya faktorên metirsiyê dê bibe sedema pêşniyareke bi eşkere cuda."
            },
            {
              "language": "pl",
              "text": "Inne ważenie czynników ryzyka doprowadziłoby do wyraźnie odmiennej rekomendacji."
            },
            {
              "language": "ro",
              "text": "O altă ponderare a factorilor de risc ar duce la o recomandare clar diferită."
            },
            {
              "language": "ru",
              "text": "Иное взвешивание факторов риска привело бы к заметно другой рекомендации."
            },
            {
              "language": "sq",
              "text": "Një peshim tjetër i faktorëve të rrezikut do të çonte në një rekomandim dukshëm të ndryshëm."
            },
            {
              "language": "tr",
              "text": "Risk faktörlerinin farklı ağırlıklandırılması belirgin biçimde farklı bir öneriye yol açardı."
            }
          ]
        }
      ]
