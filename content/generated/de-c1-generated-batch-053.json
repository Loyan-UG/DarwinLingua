  "entries": [
    {
      "word": "die Gentechnik",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Gentechniken",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Gen-tech-nik",
      "topics": [
        "healthcare-and-appointments",
        "environment-and-sustainability",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "technical",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; plural uncommon, used for different genetic engineering methods"
      ],
      "collocations": [
        {
          "text": "moderne Gentechnik",
          "meaning": "modern genetic engineering"
        },
        {
          "text": "Gentechnik regulieren",
          "meaning": "to regulate genetic engineering"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gentechnisch",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "das Gen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الهندسة الوراثية؛ التقنية الجينية"
        },
        {
          "language": "ckb",
          "text": "تەکنیکی جینی؛ ئەندازیاری جینی"
        },
        {
          "language": "en",
          "text": "genetic engineering; gene technology"
        },
        {
          "language": "fa",
          "text": "مهندسی ژنتیک؛ فناوری ژنی"
        },
        {
          "language": "kmr",
          "text": "endezyariya genetîkî; teknîka genan"
        },
        {
          "language": "pl",
          "text": "inżynieria genetyczna; technika genowa"
        },
        {
          "language": "ro",
          "text": "inginerie genetică; tehnologie genetică"
        },
        {
          "language": "ru",
          "text": "генная инженерия; генетическая технология"
        },
        {
          "language": "sq",
          "text": "inxhinieri gjenetike; teknologji gjenike"
        },
        {
          "language": "tr",
          "text": "genetik mühendisliği; gen teknolojisi"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Verordnung soll den Einsatz von Gentechnik in der Landwirtschaft transparenter machen.",
          "translations": [
            {
              "language": "ar",
              "text": "تهدف اللائحة الجديدة إلى جعل استخدام الهندسة الوراثية في الزراعة أكثر شفافية."
            },
            {
              "language": "ckb",
              "text": "ڕێکخستنی نوێ دەبێت بەکارهێنانی تەکنیکی جینی لە کشتوکاڵدا ڕوونتر بکات."
            },
            {
              "language": "en",
              "text": "The new regulation is intended to make the use of genetic engineering in agriculture more transparent."
            },
            {
              "language": "fa",
              "text": "مقرره جدید قرار است استفاده از مهندسی ژنتیک در کشاورزی را شفاف‌تر کند."
            },
            {
              "language": "kmr",
              "text": "Rêziknameya nû divê bikaranîna endezyariya genetîkî di çandiniyê de zelaltir bike."
            },
            {
              "language": "pl",
              "text": "Nowe rozporządzenie ma uczynić stosowanie inżynierii genetycznej w rolnictwie bardziej przejrzystym."
            },
            {
              "language": "ro",
              "text": "Noua reglementare ar trebui să facă utilizarea ingineriei genetice în agricultură mai transparentă."
            },
            {
              "language": "ru",
              "text": "Новое постановление должно сделать использование генной инженерии в сельском хозяйстве более прозрачным."
            },
            {
              "language": "sq",
              "text": "Rregullorja e re synon ta bëjë më transparent përdorimin e inxhinierisë gjenetike në bujqësi."
            },
            {
              "language": "tr",
              "text": "Yeni düzenleme tarımda genetik mühendisliği kullanımını daha şeffaf hale getirmeyi amaçlıyor."
            }
          ]
        },
        {
          "baseText": "In der Forschung wird Gentechnik genutzt, um Krankheitsmechanismen besser zu verstehen.",
          "translations": [
            {
              "language": "ar",
              "text": "تُستخدم التقنية الجينية في البحث لفهم آليات المرض بشكل أفضل."
            },
            {
              "language": "ckb",
              "text": "لە توێژینەوەدا تەکنیکی جینی بەکاردێت بۆ تێگەیشتنی باشتر لە میکانیزمی نەخۆشی."
            },
            {
              "language": "en",
              "text": "In research, genetic engineering is used to better understand disease mechanisms."
            },
            {
              "language": "fa",
              "text": "در پژوهش از مهندسی ژنتیک برای فهم بهتر سازوکارهای بیماری استفاده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di lêkolînê de endezyariya genetîkî tê bikaranîn da ku mekanîzmên nexweşiyê baştir bên fêmkirin."
            },
            {
              "language": "pl",
              "text": "W badaniach inżynierię genetyczną wykorzystuje się do lepszego zrozumienia mechanizmów chorób."
            },
            {
              "language": "ro",
              "text": "În cercetare, ingineria genetică este folosită pentru a înțelege mai bine mecanismele bolilor."
            },
            {
              "language": "ru",
              "text": "В исследованиях генная инженерия используется для лучшего понимания механизмов заболеваний."
            },
            {
              "language": "sq",
              "text": "Në hulumtim, inxhinieria gjenetike përdoret për të kuptuar më mirë mekanizmat e sëmundjeve."
            },
            {
              "language": "tr",
              "text": "Araştırmada genetik mühendisliği hastalık mekanizmalarını daha iyi anlamak için kullanılır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Gewaltenteilung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Gewaltenteilungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ge-wal-ten-tei-lung",
      "topics": [
        "law-and-compliance",
        "public-services",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; plural rare, used for different systems of separation of powers"
      ],
      "collocations": [
        {
          "text": "Prinzip der Gewaltenteilung",
          "meaning": "principle of separation of powers"
        },
        {
          "text": "Gewaltenteilung sichern",
          "meaning": "to safeguard separation of powers"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Gewalt",
          "relationLabel": "noun",
          "note": "state power in this context"
        },
        {
          "lemma": "teilen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فصل السلطات"
        },
        {
          "language": "ckb",
          "text": "جیاکردنەوەی دەسەڵاتەکان"
        },
        {
          "language": "en",
          "text": "separation of powers"
        },
        {
          "language": "fa",
          "text": "تفکیک قوا"
        },
        {
          "language": "kmr",
          "text": "veqetandina desthilatan"
        },
        {
          "language": "pl",
          "text": "podział władz"
        },
        {
          "language": "ro",
          "text": "separarea puterilor"
        },
        {
          "language": "ru",
          "text": "разделение властей"
        },
        {
          "language": "sq",
          "text": "ndarja e pushteteve"
        },
        {
          "language": "tr",
          "text": "kuvvetler ayrılığı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Gewaltenteilung soll verhindern, dass politische Macht bei einer einzigen Institution konzentriert wird.",
          "translations": [
            {
              "language": "ar",
              "text": "يهدف فصل السلطات إلى منع تركّز السلطة السياسية في مؤسسة واحدة."
            },
            {
              "language": "ckb",
              "text": "جیاکردنەوەی دەسەڵاتەکان دەبێت ڕێگری بکات لەوەی دەسەڵاتی سیاسی لە دامەزراوەیەکی تاکدا کۆببێتەوە."
            },
            {
              "language": "en",
              "text": "The separation of powers is intended to prevent political power from being concentrated in a single institution."
            },
            {
              "language": "fa",
              "text": "تفکیک قوا قرار است مانع تمرکز قدرت سیاسی در یک نهاد واحد شود."
            },
            {
              "language": "kmr",
              "text": "Veqetandina desthilatan divê asteng bike ku hêza siyasî li saziyek tenê kom bibe."
            },
            {
              "language": "pl",
              "text": "Podział władz ma zapobiegać koncentracji władzy politycznej w jednej instytucji."
            },
            {
              "language": "ro",
              "text": "Separarea puterilor ar trebui să împiedice concentrarea puterii politice într-o singură instituție."
            },
            {
              "language": "ru",
              "text": "Разделение властей должно предотвращать концентрацию политической власти в одном институте."
            },
            {
              "language": "sq",
              "text": "Ndarja e pushteteve synon të parandalojë përqendrimin e pushtetit politik në një institucion të vetëm."
            },
            {
              "language": "tr",
              "text": "Kuvvetler ayrılığı siyasi gücün tek bir kurumda toplanmasını önlemeyi amaçlar."
            }
          ]
        },
        {
          "baseText": "In der Analyse wird geprüft, ob die Reform die Gewaltenteilung faktisch schwächt.",
          "translations": [
            {
              "language": "ar",
              "text": "في التحليل يتم فحص ما إذا كان الإصلاح يضعف فصل السلطات فعليًا."
            },
            {
              "language": "ckb",
              "text": "لە شیکردنەوەکەدا پشکنراوە ئایا چاکسازییەکە بە کردار جیاکردنەوەی دەسەڵاتەکان لاواز دەکات."
            },
            {
              "language": "en",
              "text": "The analysis examines whether the reform in practice weakens the separation of powers."
            },
            {
              "language": "fa",
              "text": "در تحلیل بررسی می‌شود که آیا اصلاحات عملاً تفکیک قوا را تضعیف می‌کند یا نه."
            },
            {
              "language": "kmr",
              "text": "Di analîzê de tê kontrolkirin ka reform bi rastî veqetandina desthilatan lawaz dike an na."
            },
            {
              "language": "pl",
              "text": "Analiza sprawdza, czy reforma faktycznie osłabia podział władz."
            },
            {
              "language": "ro",
              "text": "Analiza verifică dacă reforma slăbește de fapt separarea puterilor."
            },
            {
              "language": "ru",
              "text": "В анализе проверяется, ослабляет ли реформа фактически разделение властей."
            },
            {
              "language": "sq",
              "text": "Në analizë shqyrtohet nëse reforma e dobëson faktikisht ndarjen e pushteteve."
            },
            {
              "language": "tr",
              "text": "Analizde reformun fiilen kuvvetler ayrılığını zayıflatıp zayıflatmadığı inceleniyor."
            }
          ]
        }
      ]
    },
