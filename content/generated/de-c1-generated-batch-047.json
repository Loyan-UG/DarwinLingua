      "article": "die",
      "plural": "Evidenzgrundlagen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "E-vi-denz-grund-la-ge",
      "topics": [
        "advanced-analysis",
        "healthcare-and-appointments",
        "data-and-reporting"
      ],
      "usageLabels": [
        "academic",
        "medical",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Evidenzgrundlagen"
      ],
      "collocations": [
        {
          "text": "eine belastbare Evidenzgrundlage",
          "meaning": "a robust evidence base"
        },
        {
          "text": "die Evidenzgrundlage erweitern",
          "meaning": "to broaden the evidence base"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Evidenz",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Grundlage",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أساس الأدلة؛ قاعدة الأدلة"
        },
        {
          "language": "ckb",
          "text": "بنەمای بەڵگە؛ بنچینەی زانیاری پشتگیریکەر"
        },
        {
          "language": "en",
          "text": "evidence base; basis of evidence"
        },
        {
          "language": "fa",
          "text": "پایه شواهد؛ مبنای مستندات"
        },
        {
          "language": "kmr",
          "text": "bingehê delîlan; bingeha agahiyên piştgir"
        },
        {
          "language": "pl",
          "text": "podstawa dowodowa; baza dowodów"
        },
        {
          "language": "ro",
          "text": "bază de dovezi; fundament probator"
        },
        {
          "language": "ru",
          "text": "доказательная база; основа доказательств"
        },
        {
          "language": "sq",
          "text": "bazë evidence; themel dëshmish"
        },
        {
          "language": "tr",
          "text": "kanıt temeli; kanıt dayanağı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Evidenzgrundlage für die neue Leitlinie wurde in einem transparenten Verfahren geprüft.",
          "translations": [
            {
              "language": "ar",
              "text": "تم فحص قاعدة الأدلة للتوجيه الجديد في إجراء شفاف."
            },
            {
              "language": "ckb",
              "text": "بنەمای بەڵگەی ڕێنماییە نوێیەکە لە پرۆسەیەکی ڕووندا پشکنرا."
            },
            {
              "language": "en",
              "text": "The evidence base for the new guideline was reviewed in a transparent process."
            },
            {
              "language": "fa",
              "text": "پایه شواهد برای دستورالعمل جدید در فرایندی شفاف بررسی شد."
            },
            {
              "language": "kmr",
              "text": "Bingehê delîlan ê ji bo rêbernameya nû di pêvajoyeke zelal de hate kontrolkirin."
            },
            {
              "language": "pl",
              "text": "Podstawę dowodową nowej wytycznej sprawdzono w przejrzystej procedurze."
            },
            {
              "language": "ro",
              "text": "Baza de dovezi pentru noul ghid a fost verificată într-o procedură transparentă."
            },
            {
              "language": "ru",
              "text": "Доказательная база для нового руководства была проверена в прозрачной процедуре."
            },
            {
              "language": "sq",
              "text": "Baza e evidencës për udhëzimin e ri u shqyrtua në një proces transparent."
            },
            {
              "language": "tr",
              "text": "Yeni kılavuzun kanıt temeli şeffaf bir süreçte incelendi."
            }
          ]
        },
        {
          "baseText": "Ohne solide Evidenzgrundlage bleibt die Empfehlung politisch angreifbar.",
          "translations": [
            {
              "language": "ar",
