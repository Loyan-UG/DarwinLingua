    {
      "word": "evident",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "e-vi-dent",
      "topics": [
