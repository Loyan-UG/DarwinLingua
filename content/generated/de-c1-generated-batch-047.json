        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; in German often means evidence in research contexts or obviousness in philosophy"
      ],
      "collocations": [
        {
          "text": "empirische Evidenz",
          "meaning": "empirical evidence"
        },
        {
          "text": "Evidenz bewerten",
          "meaning": "to assess evidence"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "evident",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دليل علمي؛ بيّنة؛ وضوح"
        },
        {
          "language": "ckb",
          "text": "بەڵگەی زانستی؛ دەرکەوتنی ڕوون"
        },
        {
          "language": "en",
          "text": "evidence; research evidence; obviousness"
        },
        {
          "language": "fa",
          "text": "شواهد؛ مدرک علمی؛ وضوح"
        },
        {
          "language": "kmr",
          "text": "delîl; delîla lêkolînê; eşkerebûn"
        },
        {
          "language": "pl",
          "text": "dowody; evidencja; oczywistość"
        },
        {
          "language": "ro",
          "text": "dovezi; evidență; caracter evident"
        },
        {
          "language": "ru",
          "text": "доказательства; научные данные; очевидность"
        },
        {
          "language": "sq",
          "text": "evidencë; dëshmi; qartësi"
        },
        {
          "language": "tr",
          "text": "kanıt; bilimsel bulgu; açıklık"
        }
      ],
      "examples": [
        {
          "baseText": "Für diese Therapie gibt es bisher nur begrenzte klinische Evidenz.",
          "translations": [
            {
              "language": "ar",
              "text": "لا توجد حتى الآن إلا أدلة سريرية محدودة على هذا العلاج."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم چارەسەرە تا ئێستا تەنها بەڵگەی کلینیکیی سنووردار هەیە."
            },
            {
              "language": "en",
              "text": "So far, there is only limited clinical evidence for this therapy."
            },
            {
              "language": "fa",
              "text": "برای این درمان تاکنون فقط شواهد بالینی محدودی وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê dermankirinê heta niha tenê delîla klînîkî ya sînordar heye."
            },
            {
              "language": "pl",
              "text": "Dla tej terapii istnieją dotąd jedynie ograniczone dowody kliniczne."
            },
            {
              "language": "ro",
              "text": "Pentru această terapie există până acum doar dovezi clinice limitate."
            },
            {
              "language": "ru",
              "text": "Для этой терапии пока есть лишь ограниченные клинические данные."
            },
            {
              "language": "sq",
              "text": "Për këtë terapi deri tani ka vetëm evidencë klinike të kufizuar."
            },
            {
              "language": "tr",
              "text": "Bu tedavi için şimdiye kadar yalnızca sınırlı klinik kanıt vardır."
            }
          ]
        },
        {
          "baseText": "Die Entscheidung sollte sich auf Evidenz stützen, nicht auf einzelne Erfahrungsberichte.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي أن يستند القرار إلى الأدلة، لا إلى تقارير خبرة فردية."
            },
            {
              "language": "ckb",
              "text": "بڕیارەکە دەبێت پشت بە بەڵگە ببەستێت، نەک بە چەند ئەزموونی تاکەکەسی."
            },
            {
              "language": "en",
              "text": "The decision should be based on evidence, not on individual anecdotal reports."
            },
            {
              "language": "fa",
              "text": "تصمیم باید بر شواهد تکیه کند، نه بر گزارش‌های تجربه‌ای منفرد."
            },
            {
              "language": "kmr",
              "text": "Biryara divê li ser delîlan be, ne li ser çîrokên ezmûnê yên takekesî."
            },
            {
              "language": "pl",
              "text": "Decyzja powinna opierać się na dowodach, a nie na pojedynczych relacjach doświadczeń."
            },
            {
              "language": "ro",
              "text": "Decizia ar trebui să se bazeze pe dovezi, nu pe relatări individuale de experiență."
            },
            {
              "language": "ru",
              "text": "Решение должно опираться на доказательства, а не на отдельные рассказы об опыте."
            },
            {
              "language": "sq",
              "text": "Vendimi duhet të mbështetet në evidencë, jo në raporte të veçuara përvoje."
            },
            {
              "language": "tr",
              "text": "Karar tekil deneyim anlatılarına değil, kanıta dayanmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Evidenzgrundlage",
      "language": "de",
      "cefrLevel": "C1",
