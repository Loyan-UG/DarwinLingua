        "data-and-reporting",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; often used predicatively: etwas ist evident"
      ],
      "collocations": [
        {
          "text": "evidente Mängel",
          "meaning": "obvious defects"
        },
        {
          "text": "evident sein",
          "meaning": "to be evident"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Evidenz",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "واضح؛ جلي؛ بديهي"
        },
        {
          "language": "ckb",
          "text": "ئاشکرا؛ ڕوون؛ بەڵگەدار"
        },
        {
          "language": "en",
          "text": "evident; obvious; clear"
        },
        {
          "language": "fa",
          "text": "آشکار؛ بدیهی؛ روشن"
        },
        {
          "language": "kmr",
          "text": "eşkere; zelal; diyar"
        },
        {
          "language": "pl",
          "text": "oczywisty; ewidentny; jasny"
        },
        {
          "language": "ro",
          "text": "evident; clar; vădit"
        },
        {
          "language": "ru",
          "text": "очевидный; явный"
        },
        {
          "language": "sq",
          "text": "i dukshëm; evident; i qartë"
        },
        {
          "language": "tr",
          "text": "açık; bariz; aşikar"
        }
      ],
      "examples": [
        {
          "baseText": "Es ist evident, dass der aktuelle Prozess bei steigenden Fallzahlen nicht skaliert.",
          "translations": [
            {
              "language": "ar",
              "text": "من الواضح أن العملية الحالية لا تتوسع مع زيادة عدد الحالات."
            },
            {
              "language": "ckb",
              "text": "ئاشکرایە کە پرۆسەی ئێستا لەگەڵ زیادبوونی ژمارەی کەیسەکاندا گونجاو گەورە نابێت."
            },
            {
              "language": "en",
              "text": "It is evident that the current process does not scale as case numbers increase."
            },
            {
              "language": "fa",
              "text": "آشکار است که فرایند فعلی با افزایش تعداد پرونده‌ها مقیاس‌پذیر نیست."
            },
            {
              "language": "kmr",
              "text": "Eşkere ye ku pêvajoya niha bi zêdebûna hejmarên dozan re ne dikare mezin bibe."
            },
            {
              "language": "pl",
              "text": "Jest oczywiste, że obecny proces nie skaluje się przy rosnącej liczbie spraw."
            },
            {
              "language": "ro",
              "text": "Este evident că procesul actual nu se scalează odată cu creșterea numărului de cazuri."
            },
            {
              "language": "ru",
              "text": "Очевидно, что текущий процесс не масштабируется при росте числа случаев."
            },
            {
              "language": "sq",
              "text": "Është evidente se procesi aktual nuk shkallëzohet me rritjen e numrit të rasteve."
            },
            {
              "language": "tr",
              "text": "Mevcut sürecin artan vaka sayılarıyla ölçeklenmediği açıktır."
            }
          ]
        },
        {
          "baseText": "Die evident mangelhafte Dokumentation erschwert jede spätere Prüfung.",
          "translations": [
            {
              "language": "ar",
              "text": "إن التوثيق الناقص بوضوح يصعّب أي مراجعة لاحقة."
            },
            {
              "language": "ckb",
              "text": "بەڵگەنامەسازییەکە کە بە ڕوونی کەم و کوڕی هەیە، هەر پشکنینێکی داهاتوو قورس دەکات."
            },
            {
              "language": "en",
              "text": "The evidently deficient documentation makes any later review more difficult."
            },
            {
              "language": "fa",
              "text": "مستندسازی آشکارا ناقص، هر بررسی بعدی را دشوارتر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Belgekirina bi eşkere kêmasîdar her kontrola paşerojê dijwartir dike."
            },
            {
              "language": "pl",
              "text": "Ewidentnie wadliwa dokumentacja utrudnia każdą późniejszą kontrolę."
            },
            {
              "language": "ro",
              "text": "Documentația evident deficitară îngreunează orice verificare ulterioară."
            },
            {
              "language": "ru",
              "text": "Очевидно недостаточная документация затрудняет любую последующую проверку."
            },
            {
              "language": "sq",
              "text": "Dokumentimi dukshëm i mangët e vështirëson çdo kontroll të mëvonshëm."
            },
            {
              "language": "tr",
              "text": "Açıkça yetersiz dokümantasyon sonraki her incelemeyi zorlaştırır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Evidenz",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Evidenzen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "E-vi-denz",
      "topics": [
        "advanced-analysis",
        "healthcare-and-appointments",
        "data-and-reporting"
      ],
      "usageLabels": [
        "academic",
        "medical",
