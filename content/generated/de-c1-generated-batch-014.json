  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "aufbringen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufbringen",
      "syllableBreak": "auf-brin-gen",
      "topics": [
        "finance-and-accounting",
        "management-and-leadership",
        "social-and-relationships"
      ],
      "usageLabels": [
        "business",
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "irregular separable verb; meanings include raising money, applying material, or upsetting someone"
      ],
      "collocations": [
        {
          "text": "Mittel aufbringen",
          "meaning": "to raise funds"
        },
        {
          "text": "Verständnis aufbringen",
          "meaning": "to show understanding"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bringen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يوفر أو يجمع؛ يبذل؛ يضع طبقة"
        },
        {
          "language": "ckb",
          "text": "دابین دەکات؛ کۆدەکاتەوە؛ چینێک دادەنێت"
        },
        {
          "language": "en",
          "text": "to raise; to muster; to apply"
        },
        {
          "language": "fa",
          "text": "فراهم کردن؛ جمع‌آوری کردن؛ اعمال کردن"
        },
        {
          "language": "kmr",
          "text": "peyda kirin; kom kirin; danîn"
        },
        {
          "language": "pl",
          "text": "zgromadzić; zdobyć; nałożyć"
        },
        {
          "language": "ro",
          "text": "a strânge; a face rost; a aplica"
        },
        {
          "language": "ru",
          "text": "изыскать; собрать; нанести"
        },
        {
          "language": "sq",
          "text": "të sigurosh; të mbledhësh; të aplikosh"
        },
        {
          "language": "tr",
          "text": "sağlamak; toplamak; uygulamak"
        }
      ],
      "examples": [
        {
          "baseText": "Das Start-up konnte die nötigen Mittel für die Zertifizierung nicht rechtzeitig aufbringen.",
          "translations": [
            {
              "language": "ar",
              "text": "لم تتمكن الشركة الناشئة من توفير الأموال اللازمة للشهادة في الوقت المناسب."
            },
            {
              "language": "ckb",
              "text": "ستارتاپەکە نەیتوانی پارەی پێویست بۆ بڕوانامەکە لە کاتی خۆیدا دابین بکات."
            },
            {
              "language": "en",
              "text": "The start-up could not raise the funds needed for certification in time."
            },
            {
              "language": "fa",
              "text": "استارتاپ نتوانست منابع مالی لازم برای گواهی‌گیری را به‌موقع فراهم کند."
            },
            {
              "language": "kmr",
              "text": "Start-upê nikarî pereyên pêwîst ji bo sertîfîkayê di demê de peyda bike."
            },
            {
              "language": "pl",
              "text": "Start-up nie zdołał na czas zgromadzić środków potrzebnych na certyfikację."
            },
            {
              "language": "ro",
              "text": "Start-upul nu a reușit să strângă la timp fondurile necesare pentru certificare."
            },
            {
              "language": "ru",
              "text": "Стартап не смог вовремя изыскать средства, необходимые для сертификации."
            },
            {
              "language": "sq",
              "text": "Start-up-i nuk arriti t’i siguronte në kohë fondet e nevojshme për certifikimin."
            },
            {
              "language": "tr",
              "text": "Start-up sertifikasyon için gerekli kaynakları zamanında sağlayamadı."
            }
          ]
        },
        {
          "baseText": "Nach mehreren Verzögerungen musste die Projektleiterin viel Geduld mit dem Lieferanten aufbringen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد عدة تأخيرات اضطرت مديرة المشروع إلى التحلي بكثير من الصبر مع المورد."
            },
            {
              "language": "ckb",
              "text": "دوای چەند دواکەوتنێک، بەڕێوەبەری پڕۆژەکە دەبوو زۆر ئارامی بەرامبەر دابینکەرەکە پیشان بدات."
            },
            {
              "language": "en",
              "text": "After several delays, the project manager had to muster a lot of patience with the supplier."
            },
            {
              "language": "fa",
              "text": "پس از چند تأخیر، مدیر پروژه ناچار بود صبر زیادی در برابر تأمین‌کننده به خرج دهد."
            },
            {
              "language": "kmr",
              "text": "Piştî çend derengiyan, rêvebera projeyê neçar bû gelek sebir li hember dabînkerê nîşan bide."
            },
            {
              "language": "pl",
              "text": "Po kilku opóźnieniach kierowniczka projektu musiała wykazać dużo cierpliwości wobec dostawcy."
            },
            {
              "language": "ro",
              "text": "După mai multe întârzieri, managera de proiect a trebuit să dea dovadă de multă răbdare față de furnizor."
            },
            {
              "language": "ru",
              "text": "После нескольких задержек руководителю проекта пришлось проявить много терпения к поставщику."
            },
            {
              "language": "sq",
              "text": "Pas disa vonesave, menaxherja e projektit duhej të tregonte shumë durim ndaj furnitorit."
            },
            {
              "language": "tr",
              "text": "Birkaç gecikmeden sonra proje yöneticisi tedarikçiye karşı çok sabır göstermek zorunda kaldı."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "aufgießen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufgießen",
      "syllableBreak": "auf-gie-ßen",
      "topics": [
        "everyday-life",
        "shopping-and-services",
        "healthcare-and-appointments"
      ],
      "usageLabels": [
        "written",
        "spoken",
        "technical"
      ],
      "grammarNotes": [
        "strong separable verb; commonly used for pouring hot water onto tea, herbs, or food"
      ],
      "collocations": [
        {
          "text": "Tee mit heißem Wasser aufgießen",
          "meaning": "to pour hot water over tea"
        },
        {
          "text": "eine Infusion aufgießen",
          "meaning": "to prepare an infusion"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gießen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يسكب الماء على؛ يحضّر بالنقع"
        },
        {
          "language": "ckb",
          "text": "ئاوی گەرم بەسەر دەکات؛ بە تێکردنی ئاو ئامادە دەکات"
        },
        {
          "language": "en",
          "text": "to pour liquid over; to infuse"
        },
        {
          "language": "fa",
          "text": "آب ریختن روی چیزی؛ دم کردن"
        },
        {
          "language": "kmr",
          "text": "av li ser rijandin; dem kirin"
        },
        {
          "language": "pl",
          "text": "zalać; zaparzyć"
        },
        {
          "language": "ro",
          "text": "a turna peste; a infuza"
        },
        {
          "language": "ru",
          "text": "заливать; заваривать"
        },
        {
          "language": "sq",
          "text": "të hedhësh ujë mbi; të përgatisësh infuzion"
        },
        {
          "language": "tr",
          "text": "üzerine su dökmek; demlemek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte gießen Sie die Kräutermischung mit kochendem Wasser auf und lassen Sie sie zehn Minuten ziehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى صب الماء المغلي على خلطة الأعشاب وتركها تنقع عشر دقائق."
            },
            {
              "language": "ckb",
              "text": "تکایە ئاوێکی کوڵاو بەسەر تێکەڵە گیاکەدا بکەن و دە خولەک بیهێڵنەوە."
            },
            {
              "language": "en",
              "text": "Please pour boiling water over the herbal mixture and let it steep for ten minutes."
            },
            {
              "language": "fa",
              "text": "لطفاً روی ترکیب گیاهی آب جوش بریزید و بگذارید ده دقیقه دم بکشد."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe avê kelandî li ser tevliheviya giyayan birijînin û deh xulek bihêlin."
            },
            {
              "language": "pl",
              "text": "Proszę zalać mieszankę ziół wrzątkiem i odstawić na dziesięć minut."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să turnați apă clocotită peste amestecul de plante și să îl lăsați zece minute la infuzat."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, залейте травяную смесь кипятком и дайте настояться десять минут."
            },
            {
              "language": "sq",
              "text": "Ju lutem hidhni ujë të valuar mbi përzierjen bimore dhe lëreni dhjetë minuta."
            },
            {
              "language": "tr",
              "text": "Lütfen bitki karışımının üzerine kaynar su dökün ve on dakika demlemeye bırakın."
            }
          ]
        },
        {
          "baseText": "In der Kantine wird die Sauce erst kurz vor dem Servieren frisch aufgegossen.",
          "translations": [
            {
              "language": "ar",
              "text": "في المقصف تُسكب الصلصة طازجة قبل التقديم مباشرة."
            },
            {
              "language": "ckb",
              "text": "لە چێشتخانەی کاردا سۆسەکە تەنها کەمێک پێش پێشکەشکردن بە تازەیی ئاودەکرێت."
            },
            {
              "language": "en",
              "text": "In the canteen, the sauce is freshly poured on shortly before serving."
            },
            {
              "language": "fa",
              "text": "در غذاخوری، سس درست کمی پیش از سرو تازه روی غذا ریخته می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di kantînê de sos tenê demeke kurt berî pêşkêşkirinê bi taze tê rijandin."
            },
            {
              "language": "pl",
              "text": "W stołówce sos jest świeżo dolewany dopiero tuż przed podaniem."
            },
            {
              "language": "ro",
              "text": "La cantină, sosul este turnat proaspăt abia cu puțin înainte de servire."
            },
            {
              "language": "ru",
              "text": "В столовой соус свежо заливают только незадолго до подачи."
            },
            {
              "language": "sq",
              "text": "Në mensë, salca hidhet e freskët pak para servirjes."
            },
            {
              "language": "tr",
              "text": "Kantinada sos servis edilmeden hemen önce taze olarak dökülür."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "auflaufen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auflaufen",
      "syllableBreak": "auf-lau-fen",
      "topics": [
        "finance-and-accounting",
        "transport-and-travel",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; can mean costs accumulating, a ship running aground, or encountering resistance"
      ],
      "collocations": [
        {
          "text": "Kosten laufen auf",
          "meaning": "costs accumulate"
        },
        {
          "text": "auf Widerstand auflaufen",
          "meaning": "to run into resistance"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "laufen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يتراكم؛ يصطدم بعائق؛ يجنح"
        },
        {
          "language": "ckb",
          "text": "کۆدەبێتەوە؛ تووشی بەربەست دەبێت"
        },
        {
          "language": "en",
          "text": "to accumulate; to run aground; to run into resistance"
        },
        {
          "language": "fa",
          "text": "انباشته شدن؛ به مانع برخوردن؛ به گل نشستن"
        },
        {
          "language": "kmr",
          "text": "kom bûn; li astengiyê ketin"
        },
        {
          "language": "pl",
          "text": "narastać; utknąć; natrafić na opór"
        },
        {
          "language": "ro",
          "text": "a se acumula; a eșua; a întâmpina rezistență"
        },
        {
          "language": "ru",
          "text": "накапливаться; сесть на мель; натолкнуться на сопротивление"
        },
        {
          "language": "sq",
          "text": "të grumbullohet; të ngecë; të hasë rezistencë"
        },
        {
          "language": "tr",
          "text": "birikmek; karaya oturmak; dirençle karşılaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Durch die Verzögerung liefen zusätzliche Lagerkosten in erheblicher Höhe auf.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب التأخير تراكمت تكاليف تخزين إضافية بمبلغ كبير."
            },
            {
              "language": "ckb",
              "text": "بەهۆی دواکەوتنەکەوە تێچووی کۆگاکردنی زیادە بە بڕێکی بەرچاو کۆبووەوە."
            },
            {
              "language": "en",
              "text": "Because of the delay, substantial additional storage costs accumulated."
            },
            {
              "language": "fa",
              "text": "به دلیل تأخیر، هزینه‌های اضافی انبارداری به میزان قابل توجهی انباشته شد."
            },
            {
              "language": "kmr",
              "text": "Ji ber derengiyê lêçûnên zêde yên embarê bi qaseke girîng kom bûn."
            },
            {
              "language": "pl",
              "text": "Z powodu opóźnienia narosły znaczne dodatkowe koszty magazynowania."
            },
            {
