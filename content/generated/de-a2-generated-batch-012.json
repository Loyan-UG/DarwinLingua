      ],
      "examples": [
        {
          "baseText": "Ihre Aussprache ist schon sehr gut.",
          "translations": [
            {
              "language": "ar",
              "text": "نطقها جيد جداً بالفعل."
            },
            {
              "language": "ckb",
              "text": "دەربڕینی ئەو ئێستا زۆر باشە."
            },
            {
              "language": "en",
              "text": "Her pronunciation is already very good."
            },
            {
              "language": "fa",
              "text": "تلفظ او الان خیلی خوب است."
            },
            {
              "language": "kmr",
              "text": "Bilêvkirina wê jixwe pir baş e."
            },
            {
              "language": "pl",
              "text": "Jej wymowa jest już bardzo dobra."
            },
            {
              "language": "ro",
              "text": "Pronunția ei este deja foarte bună."
            },
            {
              "language": "ru",
              "text": "Ее произношение уже очень хорошее."
            },
            {
              "language": "sq",
              "text": "Shqiptimi i saj është tashmë shumë i mirë."
            },
            {
              "language": "tr",
              "text": "Telaffuzu şimdiden çok iyi."
            }
          ]
        },
        {
          "baseText": "Im Kurs üben wir die deutsche Aussprache.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدورة نتدرب على النطق الألماني."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسەکەدا دەربڕینی ئەڵمانی ڕاهێنان دەکەین."
            },
            {
              "language": "en",
              "text": "In the course, we practice German pronunciation."
            },
            {
              "language": "fa",
              "text": "در کلاس تلفظ آلمانی را تمرین می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di kursê de em bilêvkirina Almanî hîn dibin."
            },
            {
              "language": "pl",
              "text": "Na kursie ćwiczymy niemiecką wymowę."
            },
            {
              "language": "ro",
              "text": "La curs exersăm pronunția germană."
            },
            {
              "language": "ru",
              "text": "На курсе мы тренируем немецкое произношение."
            },
            {
              "language": "sq",
              "text": "Në kurs praktikojmë shqiptimin gjerman."
            },
            {
              "language": "tr",
              "text": "Kursta Almanca telaffuz çalışıyoruz."
            }
          ]
        }
      ]
    },
