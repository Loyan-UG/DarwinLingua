      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خارج؛ خارج نطاق"
        },
        {
          "language": "ckb",
          "text": "لە دەرەوەی"
        },
        {
          "language": "en",
          "text": "outside; beyond"
        },
        {
          "language": "fa",
          "text": "خارج از؛ بیرون از"
        },
        {
          "language": "kmr",
          "text": "li derveyî"
        },
        {
          "language": "pl",
          "text": "poza; na zewnątrz"
        },
        {
          "language": "ro",
          "text": "în afara"
        },
        {
          "language": "ru",
          "text": "вне; за пределами"
        },
        {
          "language": "sq",
          "text": "jashtë"
        },
        {
          "language": "tr",
          "text": "dışında"
        }
      ],
      "examples": [
        {
          "baseText": "Das Hotel liegt außerhalb der Stadt.",
          "translations": [
            {
              "language": "ar",
              "text": "يقع الفندق خارج المدينة."
            },
            {
              "language": "ckb",
              "text": "هۆتێلەکە لە دەرەوەی شارەکەیە."
            },
            {
              "language": "en",
              "text": "The hotel is outside the city."
            },
            {
              "language": "fa",
              "text": "هتل خارج از شهر قرار دارد."
            },
            {
              "language": "kmr",
              "text": "Otêl li derveyî bajêr e."
            },
            {
              "language": "pl",
              "text": "Hotel leży poza miastem."
            },
            {
              "language": "ro",
              "text": "Hotelul este în afara orașului."
            },
            {
              "language": "ru",
              "text": "Отель находится за пределами города."
            },
            {
              "language": "sq",
              "text": "Hoteli ndodhet jashtë qytetit."
            },
            {
              "language": "tr",
              "text": "Otel şehrin dışında."
            }
          ]
        },
        {
          "baseText": "Außerhalb der Öffnungszeiten ist das Büro geschlossen.",
          "translations": [
            {
              "language": "ar",
              "text": "خارج أوقات العمل يكون المكتب مغلقاً."
            },
            {
              "language": "ckb",
              "text": "لە دەرەوەی کاتەکانی کردنەوە، ئۆفیسەکە داخراوە."
            },
            {
              "language": "en",
              "text": "Outside opening hours, the office is closed."
            },
            {
              "language": "fa",
              "text": "خارج از ساعات کاری، دفتر بسته است."
            },
            {
              "language": "kmr",
              "text": "Li derveyî demên vekirinê nivîsgeh girtî ye."
            },
            {
              "language": "pl",
              "text": "Poza godzinami otwarcia biuro jest zamknięte."
            },
            {
              "language": "ro",
              "text": "În afara programului, biroul este închis."
            },
            {
              "language": "ru",
              "text": "Вне часов работы офис закрыт."
            },
            {
              "language": "sq",
              "text": "Jashtë orarit të hapjes, zyra është e mbyllur."
            },
            {
              "language": "tr",
              "text": "Çalışma saatleri dışında ofis kapalıdır."
            }
          ]
        }
      ]
    },
