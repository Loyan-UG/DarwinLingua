              "text": "Aștept răspunsul dumneavoastră."
            },
            {
              "language": "ru",
              "text": "Я жду вашего ответа."
            },
            {
              "language": "sq",
              "text": "Po pres përgjigjen tuaj."
            },
            {
              "language": "tr",
              "text": "Cevabınızı bekliyorum."
            }
          ]
        },
        {
          "baseText": "Die Antwort ist richtig.",
          "translations": [
