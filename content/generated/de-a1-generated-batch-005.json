            {
              "language": "ckb",
              "text": "ئاگادارییەکە بۆ ئەپارتمانێک دەخوێنمەوە."
            },
            {
              "language": "en",
              "text": "I read the ad for an apartment."
            },
            {
              "language": "fa",
              "text": "آگهی یک آپارتمان را می‌خوانم."
            },
            {
              "language": "kmr",
              "text": "Ez reklama apartmanekê dixwînim."
            },
            {
              "language": "pl",
              "text": "Czytam ogłoszenie o apartamencie."
            },
            {
              "language": "ro",
              "text": "Citesc anunțul pentru un apartament."
            },
            {
              "language": "ru",
              "text": "Я читаю объявление о квартире."
            },
            {
              "language": "sq",
              "text": "Lexoj njoftimin për një apartament."
            },
            {
              "language": "tr",
              "text": "Bir daire ilanını okuyorum."
            }
          ]
        },
        {
          "baseText": "Die Anzeige am Automaten ist kaputt.",
