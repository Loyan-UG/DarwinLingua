              "language": "ckb",
              "text": "پیشاندەرەکەی ئامێرەکە خراپە."
            },
            {
              "language": "en",
              "text": "The display on the machine is broken."
            },
            {
              "language": "fa",
              "text": "نمایشگر دستگاه خراب است."
            },
            {
              "language": "kmr",
              "text": "Nîşandera amûrê xerab e."
            },
            {
              "language": "pl",
              "text": "Wyświetlacz w automacie jest zepsuty."
            },
            {
              "language": "ro",
              "text": "Afișajul aparatului este stricat."
            },
            {
              "language": "ru",
              "text": "Дисплей автомата сломан."
