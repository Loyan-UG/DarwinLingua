      "examples": [
        {
          "baseText": "Ich warte auf Ihre Antwort.",
          "translations": [
            {
              "language": "ar",
              "text": "أنتظر إجابتكم."
            },
            {
              "language": "ckb",
              "text": "چاوەڕێی وەڵامی ئێوەم."
            },
            {
              "language": "en",
              "text": "I am waiting for your answer."
            },
            {
              "language": "fa",
              "text": "منتظر پاسخ شما هستم."
            },
            {
              "language": "kmr",
              "text": "Ez li benda bersiva we me."
            },
            {
              "language": "pl",
              "text": "Czekam na państwa odpowiedź."
            },
            {
