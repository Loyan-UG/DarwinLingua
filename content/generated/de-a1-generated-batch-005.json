              "text": "The answer is correct."
            },
            {
              "language": "fa",
              "text": "پاسخ درست است."
            },
            {
              "language": "kmr",
              "text": "Bersiv rast e."
            },
            {
              "language": "pl",
              "text": "Odpowiedź jest poprawna."
            },
            {
              "language": "ro",
              "text": "Răspunsul este corect."
            },
            {
              "language": "ru",
              "text": "Ответ правильный."
