      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb meaning mostly or usually"
      ],
      "collocations": [
        {
          "text": "meist zu Hause",
          "meaning": "mostly at home"
        },
        {
          "text": "meist pünktlich",
          "meaning": "usually on time"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "غالباً؛ في الغالب"
        },
        {
          "language": "ckb",
          "text": "زۆربەی جار؛ بە زۆری"
        },
        {
          "language": "en",
          "text": "mostly; usually"
        },
        {
          "language": "fa",
          "text": "اغلب؛ بیشتر اوقات"
        },
        {
          "language": "kmr",
          "text": "pir caran; bi piranî"
        },
        {
          "language": "pl",
          "text": "najczęściej; przeważnie"
        },
        {
          "language": "ro",
          "text": "de obicei; în mare parte"
        },
        {
          "language": "ru",
          "text": "обычно; чаще всего"
        },
        {
          "language": "sq",
          "text": "zakonisht; kryesisht"
        },
        {
          "language": "tr",
          "text": "çoğunlukla; genellikle"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin meist zu Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "أكون غالباً في البيت."
            },
            {
              "language": "ckb",
              "text": "من زۆربەی جار لە ماڵەوەم."
            },
            {
              "language": "en",
              "text": "I am mostly at home."
            },
            {
              "language": "fa",
              "text": "من بیشتر اوقات در خانه هستم."
            },
            {
              "language": "kmr",
              "text": "Ez bi piranî li malê me."
            },
            {
              "language": "pl",
              "text": "Najczęściej jestem w domu."
            },
            {
              "language": "ro",
              "text": "De obicei sunt acasă."
            },
            {
              "language": "ru",
              "text": "Я обычно дома."
            },
            {
              "language": "sq",
              "text": "Zakonisht jam në shtëpi."
            },
            {
              "language": "tr",
              "text": "Genellikle evdeyim."
            }
          ]
        },
        {
          "baseText": "Der Bus ist meist pünktlich.",
          "translations": [
            {
              "language": "ar",
              "text": "الحافلة غالباً في الوقت المحدد."
            },
            {
              "language": "ckb",
              "text": "پاسەکە زۆربەی جار لە کاتی خۆیدایە."
            },
            {
              "language": "en",
              "text": "The bus is usually on time."
            },
            {
              "language": "fa",
              "text": "اتوبوس معمولاً به‌موقع است."
            },
            {
              "language": "kmr",
              "text": "Otobûs pir caran di wextê xwe de ye."
            },
            {
              "language": "pl",
              "text": "Autobus zwykle jest punktualny."
            },
            {
              "language": "ro",
              "text": "Autobuzul este de obicei punctual."
            },
            {
              "language": "ru",
              "text": "Автобус обычно приходит вовремя."
            },
            {
              "language": "sq",
              "text": "Autobusi zakonisht është në kohë."
            },
            {
              "language": "tr",
              "text": "Otobüs genellikle zamanında gelir."
            }
          ]
        }
      ]
    },
