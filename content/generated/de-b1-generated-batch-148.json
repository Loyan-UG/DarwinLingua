  "entries": [
    {
      "word": "vorschlagen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vorschlagen",
      "pronunciationIpa": null,
      "syllableBreak": "vor-schla-gen",
      "topics": [
        "business-communication",
        "meetings-and-presentations",
        "social-and-relationships"
      ],
      "usageLabels": [
        "business",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: schlägt vor, schlug vor, hat vorgeschlagen"
      ],
      "collocations": [
        {
          "text": "einen Termin vorschlagen",
          "meaning": "to suggest an appointment time"
        },
        {
          "text": "eine Lösung vorschlagen",
          "meaning": "to suggest a solution"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Vorschlag",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقترح"
        },
        {
          "language": "ckb",
          "text": "پێشنیارکردن"
        },
        {
          "language": "en",
          "text": "to suggest; to propose"
        },
        {
          "language": "fa",
          "text": "پیشنهاد دادن"
        },
        {
          "language": "kmr",
          "text": "pêşniyar kirin"
        },
        {
          "language": "pl",
          "text": "zaproponować"
        },
        {
          "language": "ro",
          "text": "a propune"
        },
        {
          "language": "ru",
          "text": "предлагать"
        },
        {
          "language": "sq",
          "text": "të propozosh"
        },
        {
          "language": "tr",
          "text": "önermek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich schlage vor, dass wir den Kunden zuerst anrufen.",
          "translations": [
            {
              "language": "ar",
              "text": "أقترح أن نتصل بالعميل أولًا."
            },
            {
              "language": "ckb",
              "text": "پێشنیار دەکەم سەرەتا پەیوەندی بە کڕیارەکەوە بکەین."
            },
            {
              "language": "en",
              "text": "I suggest that we call the customer first."
            },
            {
              "language": "fa",
              "text": "پیشنهاد می‌کنم اول با مشتری تماس بگیریم."
            },
            {
              "language": "kmr",
              "text": "Ez pêşniyar dikim ku em pêşî telefonî xerîdar bikin."
            },
            {
              "language": "pl",
              "text": "Proponuję, żebyśmy najpierw zadzwonili do klienta."
            },
            {
              "language": "ro",
              "text": "Propun să sunăm mai întâi clientul."
            },
            {
              "language": "ru",
              "text": "Я предлагаю сначала позвонить клиенту."
            },
            {
              "language": "sq",
              "text": "Propozoj që së pari ta telefonojmë klientin."
            },
            {
              "language": "tr",
              "text": "Önce müşteriyi aramamızı öneriyorum."
            }
          ]
        },
        {
          "baseText": "Können Sie mir einen passenden Termin für nächste Woche vorschlagen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك اقتراح موعد مناسب لي للأسبوع القادم؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن کاتێکی گونجاو بۆ هەفتەی داهاتوو پێشنیار بکەن؟"
            },
            {
              "language": "en",
              "text": "Can you suggest a suitable appointment for next week?"
            },
            {
              "language": "fa",
              "text": "می‌توانید یک زمان مناسب برای هفته آینده پیشنهاد دهید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji bo hefteya bê randevûyek guncaw pêşniyar bikin?"
            },
            {
              "language": "pl",
              "text": "Czy może Pan/Pani zaproponować odpowiedni termin na przyszły tydzień?"
            },
            {
              "language": "ro",
              "text": "Îmi puteți propune o programare potrivită pentru săptămâna viitoare?"
            },
            {
              "language": "ru",
              "text": "Можете предложить подходящее время на следующую неделю?"
            },
            {
              "language": "sq",
              "text": "A mund të më propozoni një takim të përshtatshëm për javën tjetër?"
            },
            {
              "language": "tr",
              "text": "Gelecek hafta için uygun bir randevu önerebilir misiniz?"
            }
          ]
        }
      ]
    },
    {
      "word": "die Vorsorge",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Vor-sor-ge",
      "topics": [
        "healthcare-and-appointments",
        "finance-and-accounting",
        "public-services"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "medizinische Vorsorge",
          "meaning": "preventive healthcare"
        },
        {
          "text": "für das Alter vorsorgen",
          "meaning": "to provide for old age"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vorsorgen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وقاية؛ احتياط؛ تأمين للمستقبل"
        },
        {
          "language": "ckb",
          "text": "پێشگیری؛ ئامادەکاری بۆ داهاتوو"
        },
        {
          "language": "en",
          "text": "prevention; provision for the future"
        },
        {
          "language": "fa",
          "text": "پیشگیری؛ تأمین برای آینده"
        },
        {
          "language": "kmr",
          "text": "pêşîlêgirtin; amadekariya paşerojê"
        },
        {
          "language": "pl",
          "text": "profilaktyka; zabezpieczenie na przyszłość"
        },
        {
          "language": "ro",
          "text": "prevenție; asigurare pentru viitor"
        },
        {
          "language": "ru",
          "text": "профилактика; обеспечение на будущее"
        },
        {
          "language": "sq",
          "text": "parandalim; sigurim për të ardhmen"
        },
        {
          "language": "tr",
          "text": "önlem; gelecek için güvence"
        }
      ],
      "examples": [
        {
          "baseText": "Regelmäßige Vorsorge hilft, Krankheiten früh zu erkennen.",
          "translations": [
            {
              "language": "ar",
              "text": "تساعد الوقاية المنتظمة على اكتشاف الأمراض مبكرًا."
            },
            {
              "language": "ckb",
              "text": "پێشگیریی بەردەوام یارمەتی دەدات نەخۆشییەکان زوو بناسرێن."
            },
            {
              "language": "en",
              "text": "Regular preventive care helps detect illnesses early."
            },
            {
              "language": "fa",
              "text": "مراقبت پیشگیرانه منظم کمک می‌کند بیماری‌ها زود تشخیص داده شوند."
            },
            {
              "language": "kmr",
              "text": "Vorsorgeya bi rêkûpêk alîkar dike nexweşî zû bên nasîn."
            },
            {
              "language": "pl",
              "text": "Regularna profilaktyka pomaga wcześnie wykrywać choroby."
            },
            {
              "language": "ro",
              "text": "Prevenția regulată ajută la depistarea timpurie a bolilor."
            },
            {
              "language": "ru",
              "text": "Регулярная профилактика помогает рано выявлять болезни."
            },
            {
              "language": "sq",
              "text": "Kontrolli parandalues i rregullt ndihmon në zbulimin e hershëm të sëmundjeve."
            },
            {
              "language": "tr",
              "text": "Düzenli önleyici bakım hastalıkları erken fark etmeye yardımcı olur."
            }
          ]
        },
        {
          "baseText": "Viele Beschäftigte informieren sich über private Vorsorge für die Rente.",
          "translations": [
            {
              "language": "ar",
              "text": "يستعلم كثير من الموظفين عن التأمين الخاص للتقاعد."
            },
            {
              "language": "ckb",
              "text": "زۆر کارمەند زانیاری دەگرن دەربارەی ئامادەکاری تایبەتی بۆ خانەنشینی."
            },
            {
              "language": "en",
              "text": "Many employees get information about private provision for retirement."
            },
            {
              "language": "fa",
              "text": "بسیاری از کارکنان درباره تأمین خصوصی برای بازنشستگی اطلاعات می‌گیرند."
            },
            {
              "language": "kmr",
              "text": "Gelek karmend li ser amadekariya taybet ji bo teqawidiyê agahî werdigirin."
            },
            {
              "language": "pl",
              "text": "Wielu pracowników informuje się o prywatnym zabezpieczeniu emerytalnym."
            },
            {
              "language": "ro",
              "text": "Mulți angajați se informează despre pensia privată."
            },
            {
              "language": "ru",
              "text": "Многие сотрудники узнают о частном пенсионном обеспечении."
            },
            {
              "language": "sq",
              "text": "Shumë punonjës informohen për sigurimin privat për pension."
            },
            {
              "language": "tr",
              "text": "Birçok çalışan emeklilik için özel birikim hakkında bilgi alıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "das Vorstellungsgespräch",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Vorstellungsgespräche",
      "infinitive": null,
