      "syllableBreak": "Vor-stel-lungs-ge-spräch",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "ein Vorstellungsgespräch führen",
          "meaning": "to conduct a job interview"
        },
        {
          "text": "zum Vorstellungsgespräch eingeladen werden",
          "meaning": "to be invited to a job interview"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sich vorstellen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مقابلة عمل"
        },
        {
          "language": "ckb",
          "text": "چاوپێکەوتنی کار"
        },
        {
          "language": "en",
          "text": "job interview"
        },
        {
          "language": "fa",
          "text": "مصاحبه کاری"
        },
        {
          "language": "kmr",
          "text": "hevpeyvîna karê"
        },
        {
          "language": "pl",
          "text": "rozmowa kwalifikacyjna"
        },
        {
          "language": "ro",
          "text": "interviu de angajare"
        },
        {
          "language": "ru",
          "text": "собеседование"
        },
        {
          "language": "sq",
          "text": "intervistë pune"
        },
        {
          "language": "tr",
          "text": "iş görüşmesi"
        }
      ],
      "examples": [
        {
          "baseText": "Morgen habe ich ein Vorstellungsgespräch bei einer Softwarefirma.",
          "translations": [
            {
              "language": "ar",
              "text": "غدًا لدي مقابلة عمل في شركة برمجيات."
            },
            {
              "language": "ckb",
              "text": "سبەی چاوپێکەوتنی کارم لە کۆمپانیایەکی نەرمەکاڵادا هەیە."
            },
            {
              "language": "en",
              "text": "Tomorrow I have a job interview at a software company."
            },
            {
              "language": "fa",
              "text": "فردا در یک شرکت نرم‌افزاری مصاحبه کاری دارم."
            },
            {
              "language": "kmr",
              "text": "Sibê hevpeyvîna karê min li şirketeke nermalavê heye."
            },
            {
              "language": "pl",
              "text": "Jutro mam rozmowę kwalifikacyjną w firmie programistycznej."
            },
            {
              "language": "ro",
              "text": "Mâine am un interviu de angajare la o firmă de software."
            },
            {
              "language": "ru",
              "text": "Завтра у меня собеседование в софтверной компании."
            },
            {
              "language": "sq",
              "text": "Nesër kam një intervistë pune në një kompani softuerësh."
            },
            {
              "language": "tr",
              "text": "Yarın bir yazılım şirketinde iş görüşmem var."
            }
          ]
        },
        {
          "baseText": "Im Vorstellungsgespräch fragt die Personalabteilung nach meiner Erfahrung.",
          "translations": [
            {
              "language": "ar",
              "text": "في مقابلة العمل يسأل قسم الموارد البشرية عن خبرتي."
            },
