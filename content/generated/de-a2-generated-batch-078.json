        {
          "language": "ar",
          "text": "بانتظام"
        },
        {
          "language": "ckb",
          "text": "بەردەوام؛ بە ڕێکخراوی"
        },
        {
          "language": "en",
          "text": "regularly; regular"
        },
        {
          "language": "fa",
          "text": "منظم؛ به طور منظم"
        },
        {
          "language": "kmr",
          "text": "bi rêkûpêkî"
        },
        {
          "language": "pl",
          "text": "regularnie; regularny"
        },
        {
          "language": "ro",
          "text": "regulat; în mod regulat"
        },
        {
          "language": "ru",
          "text": "регулярно; регулярный"
        },
        {
          "language": "sq",
          "text": "rregullisht; i rregullt"
        },
        {
          "language": "tr",
          "text": "düzenli; düzenli olarak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich gehe regelmäßig zum Arzt.",
          "translations": [
            {
              "language": "ar",
              "text": "أذهب إلى الطبيب بانتظام."
            },
            {
              "language": "ckb",
              "text": "بەردەوام دەچم لای پزیشک."
            },
            {
              "language": "en",
              "text": "I go to the doctor regularly."
            },
            {
              "language": "fa",
              "text": "من به طور منظم به پزشک می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez bi rêkûpêkî diçim ba bijîşk."
            },
            {
              "language": "pl",
              "text": "Regularnie chodzę do lekarza."
            },
            {
              "language": "ro",
              "text": "Merg regulat la medic."
            },
            {
              "language": "ru",
              "text": "Я регулярно хожу к врачу."
            },
            {
              "language": "sq",
              "text": "Shkoj rregullisht te mjeku."
            },
            {
              "language": "tr",
              "text": "Düzenli olarak doktora giderim."
            }
          ]
        },
        {
          "baseText": "Wir treffen uns regelmäßig nach der Arbeit.",
          "translations": [
            {
              "language": "ar",
              "text": "نلتقي بانتظام بعد العمل."
            },
            {
              "language": "ckb",
              "text": "دوای کار بەردەوام یەکتر دەبینین."
            },
            {
              "language": "en",
              "text": "We meet regularly after work."
            },
            {
              "language": "fa",
              "text": "ما بعد از کار به طور منظم همدیگر را می‌بینیم."
            },
            {
              "language": "kmr",
              "text": "Em piştî xebatê bi rêkûpêk hev dibînin."
            },
            {
              "language": "pl",
              "text": "Spotykamy się regularnie po pracy."
            },
            {
              "language": "ro",
              "text": "Ne întâlnim regulat după serviciu."
            },
            {
              "language": "ru",
              "text": "Мы регулярно встречаемся после работы."
            },
            {
              "language": "sq",
              "text": "Takohemi rregullisht pas punës."
            },
            {
              "language": "tr",
              "text": "İşten sonra düzenli olarak buluşuruz."
            }
          ]
        }
      ]
