        "procurement-and-suppliers"
      ],
      "usageLabels": [
        "business",
        "written",
        "administrative"
      ],
      "grammarNotes": [
        "past participle used as adjective"
      ],
      "collocations": [
        {
          "text": "der Auftrag ist freigegeben",
          "meaning": "the order is approved/released"
        },
        {
          "text": "freigegebene Ware",
          "meaning": "released goods"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "freigeben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "موافق عليه؛ مُفرج عنه"
        },
        {
          "language": "ckb",
          "text": "ڕێگەپێدراو؛ ئازادکراو"
        },
        {
          "language": "en",
          "text": "approved; released"
        },
        {
          "language": "fa",
          "text": "تأییدشده؛ آزادشده"
        },
        {
          "language": "kmr",
          "text": "pejirandî; berdan"
        },
        {
          "language": "pl",
          "text": "zatwierdzony; zwolniony"
        },
        {
          "language": "ro",
          "text": "aprobat; eliberat"
        },
        {
          "language": "ru",
          "text": "одобренный; разблокированный"
        },
        {
          "language": "sq",
          "text": "i miratuar; i liruar"
        },
        {
          "language": "tr",
          "text": "onaylanmış; serbest bırakılmış"
        }
      ],
      "examples": [
        {
          "baseText": "Der Auftrag ist im ERP-System freigegeben.",
          "translations": [
            {
              "language": "ar",
              "text": "تمت الموافقة على الطلب في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "داواکارییەکە لە سیستەمی ERPدا ڕێگەپێدراوە."
            },
            {
              "language": "en",
              "text": "The order is approved in the ERP system."
            },
            {
              "language": "fa",
              "text": "سفارش در سیستم ERP تأیید شده است."
            },
            {
              "language": "kmr",
              "text": "Fermariş di pergala ERP de pejirandî ye."
            },
            {
              "language": "pl",
              "text": "Zamówienie jest zatwierdzone w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Comanda este aprobată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Заказ одобрен в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Porosia është miratuar në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Sipariş ERP sisteminde onaylandı."
            }
          ]
        },
        {
          "baseText": "Der Raum ist für die Gruppe freigegeben.",
          "translations": [
            {
              "language": "ar",
              "text": "الغرفة متاحة للمجموعة."
            },
            {
              "language": "ckb",
              "text": "ژوورەکە بۆ گرووپەکە ڕێگەپێدراوە."
            },
            {
              "language": "en",
              "text": "The room is released for the group."
            },
            {
              "language": "fa",
              "text": "اتاق برای گروه آزاد شده است."
            },
            {
              "language": "kmr",
              "text": "Ode ji bo komê berdan e."
            },
            {
              "language": "pl",
              "text": "Sala jest udostępniona dla grupy."
            },
            {
              "language": "ro",
              "text": "Camera este disponibilă pentru grup."
            },
            {
              "language": "ru",
              "text": "Комната доступна для группы."
            },
            {
              "language": "sq",
              "text": "Dhoma është liruar për grupin."
            },
            {
              "language": "tr",
              "text": "Oda grup için kullanıma açıldı."
            }
          ]
        }
      ]
    },
