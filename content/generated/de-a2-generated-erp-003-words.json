          "text": "ein Gebiet betreuen",
          "meaning": "to cover an area"
        },
        {
          "text": "im Gebiet liefern",
          "meaning": "to deliver in the area"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "منطقة؛ مجال"
        },
        {
          "language": "ckb",
          "text": "ناوچە؛ بوار"
        },
        {
          "language": "en",
          "text": "area; region"
        },
        {
          "language": "fa",
          "text": "منطقه؛ حوزه"
        },
        {
          "language": "kmr",
          "text": "herêm; war"
        },
        {
          "language": "pl",
          "text": "obszar; teren"
        },
        {
          "language": "ro",
          "text": "zonă; domeniu"
        },
        {
          "language": "ru",
          "text": "район; область"
        },
        {
          "language": "sq",
          "text": "zonë; fushë"
        },
        {
          "language": "tr",
          "text": "bölge; alan"
        }
      ],
      "examples": [
        {
          "baseText": "Dieses Gebiet ist im ERP-System dem Vertreter zugeordnet.",
          "translations": [
            {
              "language": "ar",
              "text": "هذه المنطقة مخصصة للمندوب في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "ئەم ناوچەیە لە سیستەمی ERPدا بە نوێنەرەکە سپێردراوە."
            },
            {
              "language": "en",
              "text": "This area is assigned to the representative in the ERP system."
            },
            {
              "language": "fa",
              "text": "این منطقه در سیستم ERP به نماینده اختصاص داده شده است."
            },
            {
              "language": "kmr",
              "text": "Ev herêm di pergala ERP de ji nûner re hatiye veqetandin."
            },
            {
              "language": "pl",
              "text": "Ten obszar jest przypisany przedstawicielowi w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Această zonă este alocată reprezentantului în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Этот район назначен представителю в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Kjo zonë i është caktuar përfaqësuesit në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Bu bölge ERP sisteminde temsilciye atanmış."
            }
          ]
        },
        {
          "baseText": "In diesem Gebiet gibt es viele Seen.",
          "translations": [
            {
              "language": "ar",
              "text": "في هذه المنطقة توجد بحيرات كثيرة."
            },
            {
              "language": "ckb",
              "text": "لەم ناوچەیەدا زۆر دەریاچە هەیە."
            },
            {
              "language": "en",
              "text": "There are many lakes in this area."
            },
            {
              "language": "fa",
              "text": "در این منطقه دریاچه‌های زیادی وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Li vê herêmê gelek gol hene."
            },
            {
              "language": "pl",
              "text": "Na tym obszarze jest wiele jezior."
            },
            {
              "language": "ro",
              "text": "În această zonă sunt multe lacuri."
            },
            {
              "language": "ru",
              "text": "В этом районе много озер."
            },
            {
              "language": "sq",
              "text": "Në këtë zonë ka shumë liqene."
            },
            {
              "language": "tr",
              "text": "Bu bölgede birçok göl var."
            }
          ]
        }
      ]
    },
