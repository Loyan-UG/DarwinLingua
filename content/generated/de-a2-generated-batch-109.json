      "wordFamilies": [
        {
          "lemma": "der Wunsch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتمنى؛ يرغب"
        },
        {
          "language": "ckb",
          "text": "ئارەزوو دەکات؛ دەیەوێت"
        },
        {
          "language": "en",
          "text": "to wish; to want"
        },
        {
          "language": "fa",
          "text": "آرزو کردن؛ خواستن"
        },
        {
          "language": "kmr",
          "text": "xwestin; hêvî kirin"
        },
        {
          "language": "pl",
          "text": "życzyć; chcieć"
        },
        {
          "language": "ro",
          "text": "a dori; a ura"
        },
        {
          "language": "ru",
          "text": "желать; хотеть"
        },
        {
          "language": "sq",
          "text": "të urosh; të dëshirosh"
        },
        {
          "language": "tr",
          "text": "dilemek; istemek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich wünsche Ihnen einen schönen Tag.",
          "translations": [
            {
              "language": "ar",
              "text": "أتمنى لكم يوماً جميلاً."
            },
            {
              "language": "ckb",
              "text": "ڕۆژێکی خۆشتان بۆ ئارەزوو دەکەم."
            },
            {
              "language": "en",
              "text": "I wish you a nice day."
            },
            {
              "language": "fa",
              "text": "روز خوبی برای شما آرزو می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez rojake xweş ji we re dixwazim."
            },
            {
              "language": "pl",
              "text": "Życzę państwu miłego dnia."
            },
            {
              "language": "ro",
              "text": "Vă doresc o zi frumoasă."
            },
            {
              "language": "ru",
              "text": "Желаю вам хорошего дня."
            },
            {
              "language": "sq",
              "text": "Ju uroj një ditë të bukur."
            },
            {
              "language": "tr",
              "text": "Size güzel bir gün dilerim."
            }
          ]
        },
        {
          "baseText": "Welche Größe wünschen Sie?",
          "translations": [
            {
              "language": "ar",
              "text": "أي مقاس ترغبون؟"
            },
            {
              "language": "ckb",
              "text": "کام قەبارەتان دەوێت؟"
            },
            {
              "language": "en",
              "text": "Which size would you like?"
            },
            {
              "language": "fa",
              "text": "چه سایزی می‌خواهید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn kîjan mezinahiyê dixwazin?"
            },
            {
              "language": "pl",
              "text": "Jaki rozmiar państwo sobie życzą?"
            },
            {
              "language": "ro",
              "text": "Ce mărime doriți?"
            },
            {
              "language": "ru",
              "text": "Какой размер вы желаете?"
            },
            {
              "language": "sq",
              "text": "Çfarë madhësie dëshironi?"
            },
            {
              "language": "tr",
              "text": "Hangi bedeni istersiniz?"
            }
          ]
        }
      ]
    },
