      "examples": [
        {
          "baseText": "Ich kaufe zwei Würste auf dem Wochenmarkt.",
          "translations": [
            {
              "language": "ar",
              "text": "أشتري قطعتين من النقانق من السوق الأسبوعي."
            },
            {
              "language": "ckb",
              "text": "من دوو سۆسج لە بازاڕی هەفتانە دەکڕم."
            },
            {
              "language": "en",
              "text": "I buy two sausages at the weekly market."
            },
            {
              "language": "fa",
              "text": "من از بازار هفتگی دو سوسیس می‌خرم."
            },
            {
              "language": "kmr",
              "text": "Ez ji sûka heftane du sosîs dikirim."
            },
            {
              "language": "pl",
              "text": "Kupuję dwie kiełbasy na targu."
            },
            {
              "language": "ro",
              "text": "Cumpăr doi cârnați de la piața săptămânală."
            },
            {
              "language": "ru",
              "text": "Я покупаю две колбасы на еженедельном рынке."
            },
            {
              "language": "sq",
              "text": "Blej dy sallame në tregun javor."
            },
            {
              "language": "tr",
              "text": "Haftalık pazardan iki sosis alıyorum."
            }
          ]
        },
        {
          "baseText": "Möchten Sie die Wurst warm oder kalt?",
          "translations": [
            {
              "language": "ar",
              "text": "هل تريدون النقانق ساخنة أم باردة؟"
            },
            {
              "language": "ckb",
              "text": "سۆسجەکەتان گەرم دەوێت یان سارد؟"
            },
            {
              "language": "en",
              "text": "Would you like the sausage warm or cold?"
            },
            {
              "language": "fa",
              "text": "سوسیس را گرم می‌خواهید یا سرد؟"
            },
            {
              "language": "kmr",
              "text": "Hûn sosîsê germ dixwazin an sar?"
            },
            {
              "language": "pl",
              "text": "Czy chce pan/pani kiełbasę na ciepło czy na zimno?"
            },
            {
              "language": "ro",
              "text": "Doriți cârnatul cald sau rece?"
            },
            {
              "language": "ru",
              "text": "Хотите колбасу теплой или холодной?"
            },
            {
              "language": "sq",
              "text": "E dëshironi sallamin të ngrohtë apo të ftohtë?"
            },
            {
              "language": "tr",
              "text": "Sosisi sıcak mı soğuk mu istersiniz?"
            }
          ]
        }
