      "meanings": [
        {
          "language": "ar",
          "text": "البحث عن شقة"
        },
        {
          "language": "ckb",
          "text": "گەڕان بەدوای خانوو"
        },
        {
          "language": "en",
          "text": "apartment search; search for housing"
        },
        {
          "language": "fa",
          "text": "جست‌وجوی خانه؛ خانه‌گشتن"
        },
        {
          "language": "kmr",
          "text": "lêgerîna xaniyê"
        },
        {
          "language": "pl",
          "text": "szukanie mieszkania"
        },
        {
          "language": "ro",
          "text": "căutare de locuință"
        },
        {
          "language": "ru",
          "text": "поиск квартиры; поиск жилья"
        },
        {
          "language": "sq",
          "text": "kërkim banese"
        },
        {
          "language": "tr",
          "text": "ev arama; daire arama"
        }
      ],
      "examples": [
        {
          "baseText": "Die Wohnungssuche in der Stadt ist nicht leicht.",
          "translations": [
            {
              "language": "ar",
              "text": "البحث عن شقة في المدينة ليس سهلاً."
            },
            {
              "language": "ckb",
              "text": "گەڕان بەدوای خانوو لە شارەکەدا ئاسان نییە."
            },
            {
              "language": "en",
              "text": "Looking for an apartment in the city is not easy."
            },
            {
              "language": "fa",
              "text": "جست‌وجوی خانه در شهر آسان نیست."
            },
            {
              "language": "kmr",
              "text": "Lêgerîna xaniyê li bajêr hêsan nîne."
            },
            {
              "language": "pl",
              "text": "Szukanie mieszkania w mieście nie jest łatwe."
            },
            {
              "language": "ro",
              "text": "Căutarea unei locuințe în oraș nu este ușoară."
            },
            {
              "language": "ru",
              "text": "Поиск квартиры в городе нелегкий."
            },
            {
              "language": "sq",
              "text": "Kërkimi i banesës në qytet nuk është i lehtë."
            },
            {
              "language": "tr",
              "text": "Şehirde ev aramak kolay değil."
            }
          ]
        },
        {
          "baseText": "Eine Kollegin hilft mir bei der Wohnungssuche.",
          "translations": [
            {
              "language": "ar",
              "text": "تساعدني زميلة في البحث عن شقة."
            },
            {
              "language": "ckb",
              "text": "هاوکارێکم یارمەتیم دەدات لە گەڕان بەدوای خانوو."
            },
            {
              "language": "en",
              "text": "A colleague is helping me with the apartment search."
            },
            {
              "language": "fa",
              "text": "یک همکار در جست‌وجوی خانه به من کمک می‌کند."
            },
            {
              "language": "kmr",
              "text": "Hevkariyek alîkariya min dike di lêgerîna xaniyê de."
            },
            {
              "language": "pl",
              "text": "Koleżanka pomaga mi w szukaniu mieszkania."
            },
            {
              "language": "ro",
              "text": "O colegă mă ajută la căutarea unei locuințe."
            },
            {
              "language": "ru",
              "text": "Коллега помогает мне с поиском квартиры."
            },
            {
              "language": "sq",
              "text": "Një kolege më ndihmon në kërkimin e banesës."
            },
            {
              "language": "tr",
              "text": "Bir iş arkadaşım ev aramamda bana yardım ediyor."
            }
          ]
        }
      ]
    },
