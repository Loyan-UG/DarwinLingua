        {
          "language": "tr",
          "text": "hemşire"
        }
      ],
      "examples": [
        {
          "baseText": "Die Krankenschwester bringt mir ein Glas Wasser.",
          "translations": [
            {
              "language": "ar",
              "text": "الممرضة تحضر لي كوب ماء."
            },
            {
              "language": "ckb",
              "text": "پەرستارە ژنەکە پەرداخێک ئاوم بۆ دێنێت."
            },
            {
              "language": "en",
              "text": "The nurse brings me a glass of water."
            },
            {
              "language": "fa",
              "text": "پرستار برایم یک لیوان آب می‌آورد."
            },
            {
              "language": "kmr",
              "text": "Hemşîre qedehek avê ji min re tîne."
            },
            {
              "language": "pl",
              "text": "Pielęgniarka przynosi mi szklankę wody."
            },
            {
              "language": "ro",
              "text": "Asistenta medicală îmi aduce un pahar cu apă."
            },
            {
              "language": "ru",
              "text": "Медсестра приносит мне стакан воды."
            },
            {
              "language": "sq",
              "text": "Infermierja më sjell një gotë ujë."
            },
            {
              "language": "tr",
              "text": "Hemşire bana bir bardak su getiriyor."
            }
          ]
        },
        {
          "baseText": "Meine Tante ist Krankenschwester im Krankenhaus.",
          "translations": [
            {
              "language": "ar",
              "text": "خالتي/عمتي ممرضة في المستشفى."
            },
            {
              "language": "ckb",
              "text": "پوورم لە نەخۆشخانە پەرستارە."
            },
            {
              "language": "en",
              "text": "My aunt is a nurse at the hospital."
            },
            {
              "language": "fa",
              "text": "خاله/عمه‌ام در بیمارستان پرستار است."
            },
            {
              "language": "kmr",
              "text": "Xaltîka min li nexweşxaneyê hemşîre ye."
            },
            {
              "language": "pl",
              "text": "Moja ciocia jest pielęgniarką w szpitalu."
            },
            {
              "language": "ro",
              "text": "Mătușa mea este asistentă medicală la spital."
            },
            {
              "language": "ru",
              "text": "Моя тётя медсестра в больнице."
            },
            {
              "language": "sq",
              "text": "Halla ime është infermiere në spital."
            },
            {
              "language": "tr",
              "text": "Teyzem hastanede hemşire."
            }
          ]
        }
      ]
    },
