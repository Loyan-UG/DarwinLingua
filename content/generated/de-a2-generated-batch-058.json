      "examples": [
        {
          "baseText": "Bitte rufen Sie einen Krankenwagen.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى طلب سيارة إسعاف."
            },
            {
              "language": "ckb",
              "text": "تکایە ئامبولانسێک بانگ بکەن."
            },
            {
              "language": "en",
              "text": "Please call an ambulance."
            },
            {
              "language": "fa",
              "text": "لطفاً آمبولانس خبر کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe ambûlansekê bang bikin."
            },
            {
              "language": "pl",
              "text": "Proszę wezwać karetkę."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să chemați o ambulanță."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, вызовите скорую."
            },
            {
              "language": "sq",
              "text": "Ju lutemi thirrni një ambulancë."
            },
            {
              "language": "tr",
              "text": "Lütfen ambulans çağırın."
            }
          ]
        },
        {
          "baseText": "Der Krankenwagen kommt in fünf Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "سيارة الإسعاف تأتي خلال خمس دقائق."
            },
            {
              "language": "ckb",
              "text": "ئامبولانسەکە لە پێنج خولەکدا دێت."
            },
            {
              "language": "en",
              "text": "The ambulance will arrive in five minutes."
            },
            {
              "language": "fa",
              "text": "آمبولانس پنج دقیقه دیگر می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Ambûlans di pênc deqeyan de tê."
            },
            {
              "language": "pl",
              "text": "Karetka przyjedzie za pięć minut."
            },
            {
              "language": "ro",
              "text": "Ambulanța vine în cinci minute."
            },
            {
              "language": "ru",
              "text": "Скорая приедет через пять минут."
            },
            {
              "language": "sq",
              "text": "Ambulanca vjen për pesë minuta."
            },
            {
              "language": "tr",
              "text": "Ambulans beş dakika içinde geliyor."
            }
          ]
        }
