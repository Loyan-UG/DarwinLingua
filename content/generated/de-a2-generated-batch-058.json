      "examples": [
        {
          "baseText": "Wegen der Krankheit bleibt er zu Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب المرض يبقى في البيت."
            },
            {
              "language": "ckb",
              "text": "بەهۆی نەخۆشییەکە لە ماڵەوە دەمێنێتەوە."
            },
            {
              "language": "en",
              "text": "Because of the illness, he stays at home."
            },
            {
              "language": "fa",
              "text": "به خاطر بیماری در خانه می‌ماند."
            },
            {
              "language": "kmr",
              "text": "Ji ber nexweşiyê ew li mal dimîne."
            },
            {
              "language": "pl",
              "text": "Z powodu choroby zostaje w domu."
            },
            {
              "language": "ro",
              "text": "Din cauza bolii rămâne acasă."
            },
            {
              "language": "ru",
              "text": "Из-за болезни он остаётся дома."
            },
            {
              "language": "sq",
              "text": "Për shkak të sëmundjes ai qëndron në shtëpi."
            },
            {
              "language": "tr",
              "text": "Hastalık nedeniyle evde kalıyor."
            }
          ]
        },
        {
          "baseText": "Der Arzt fragt nach meiner Krankheit.",
          "translations": [
            {
              "language": "ar",
              "text": "الطبيب يسأل عن مرضي."
            },
            {
              "language": "ckb",
              "text": "پزیشکەکە پرسیار لە نەخۆشییەکەم دەکات."
            },
            {
              "language": "en",
              "text": "The doctor asks about my illness."
            },
            {
              "language": "fa",
              "text": "پزشک درباره بیماری‌ام می‌پرسد."
            },
            {
              "language": "kmr",
              "text": "Bijîşk li ser nexweşiya min dipirse."
            },
            {
              "language": "pl",
              "text": "Lekarz pyta o moją chorobę."
            },
            {
              "language": "ro",
              "text": "Medicul întreabă despre boala mea."
            },
            {
              "language": "ru",
              "text": "Врач спрашивает о моей болезни."
            },
            {
              "language": "sq",
              "text": "Mjeku pyet për sëmundjen time."
            },
            {
              "language": "tr",
              "text": "Doktor hastalığımı soruyor."
            }
