  "entries": [
    {
      "word": "sich verpflichten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "sich verpflichten",
      "pronunciationIpa": null,
      "syllableBreak": "sich ver-pflich-ten",
      "topics": [
        "law-and-compliance",
        "contracts-and-negotiation",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive verb; often with zu + dative or durch einen Vertrag"
      ],
      "collocations": [
        {
          "text": "sich zur Zahlung verpflichten",
          "meaning": "to commit to payment"
        },
        {
          "text": "sich vertraglich verpflichten",
          "meaning": "to commit contractually"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Verpflichtung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "verpflichtend",
          "relationLabel": "adjective/participle",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يلتزم؛ يتعهد"
        },
        {
          "language": "ckb",
          "text": "پابەند دەبێت؛ بەڵێن دەدات"
        },
        {
          "language": "en",
          "text": "to commit oneself; to be obliged"
        },
        {
          "language": "fa",
          "text": "متعهد شدن؛ خود را موظف کردن"
        },
        {
          "language": "kmr",
          "text": "xwe mecbûr kirin; peyman dan"
        },
        {
          "language": "pl",
          "text": "zobowiązać się"
        },
        {
          "language": "ro",
          "text": "a se obliga; a se angaja"
        },
        {
          "language": "ru",
          "text": "обязываться; брать на себя обязательство"
        },
        {
          "language": "sq",
          "text": "të angazhohesh; të detyrohesh"
        },
        {
          "language": "tr",
          "text": "taahhüt etmek; yükümlü olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Mit der Unterschrift verpflichten Sie sich zur pünktlichen Zahlung.",
          "translations": [
            {
              "language": "ar",
              "text": "بتوقيعكم تتعهدون بالدفع في الوقت المحدد."
            },
            {
              "language": "ckb",
              "text": "بە واژۆکەتان پابەند دەبن بە پارەدانی لە کاتی خۆیدا."
            },
            {
              "language": "en",
              "text": "By signing, you commit yourself to paying on time."
            },
            {
              "language": "fa",
              "text": "با امضا، خود را متعهد به پرداخت به‌موقع می‌کنید."
            },
            {
              "language": "kmr",
              "text": "Bi îmzeyê hûn xwe mecbûr dikin ku di wextê xwe de pere bidin."
            },
            {
              "language": "pl",
              "text": "Podpisem zobowiązują się państwo do terminowej płatności."
            },
            {
              "language": "ro",
              "text": "Prin semnătură vă obligați la plata la timp."
            },
            {
              "language": "ru",
              "text": "Подписывая, вы обязуетесь оплатить вовремя."
            },
            {
              "language": "sq",
              "text": "Me nënshkrim angazhoheni të paguani në kohë."
            },
            {
              "language": "tr",
              "text": "İmza ile zamanında ödeme yapmayı taahhüt edersiniz."
            }
          ]
        },
        {
          "baseText": "Die Firma verpflichtet sich, die Daten vertraulich zu behandeln.",
          "translations": [
            {
              "language": "ar",
              "text": "تتعهد الشركة بمعالجة البيانات بسرية."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە پابەند دەبێت زانیارییەکان بە نهێنی مامەڵە بکات."
            },
            {
              "language": "en",
              "text": "The company undertakes to treat the data confidentially."
            },
            {
              "language": "fa",
              "text": "شرکت متعهد می‌شود با داده‌ها محرمانه برخورد کند."
            },
            {
              "language": "kmr",
              "text": "Şîrket xwe mecbûr dike ku daneyan bi nepenî bi kar bîne."
            },
            {
              "language": "pl",
              "text": "Firma zobowiązuje się do poufnego traktowania danych."
            },
            {
              "language": "ro",
              "text": "Firma se obligă să trateze datele confidențial."
            },
            {
              "language": "ru",
              "text": "Компания обязуется обращаться с данными конфиденциально."
            },
            {
              "language": "sq",
              "text": "Kompania angazhohet t’i trajtojë të dhënat në mënyrë konfidenciale."
            },
            {
              "language": "tr",
              "text": "Şirket verileri gizli tutmayı taahhüt eder."
            }
          ]
        }
      ]
    },
    {
      "word": "sich vorbereiten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "sich vorbereiten",
      "pronunciationIpa": null,
      "syllableBreak": "sich vor-be-rei-ten",
      "topics": [
        "work-and-jobs",
        "meetings-and-presentations",
        "education-and-training"
      ],
      "usageLabels": [
        "everyday",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive separable verb: bereitet sich vor, bereitete sich vor, sich vorbereitet; often with auf + accusative"
      ],
      "collocations": [
        {
          "text": "sich auf ein Gespräch vorbereiten",
          "meaning": "to prepare for a conversation"
        },
        {
          "text": "sich gut vorbereiten",
          "meaning": "to prepare well"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Vorbereitung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "vorbereitet",
          "relationLabel": "participle/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يستعد؛ يحضّر نفسه"
        },
        {
          "language": "ckb",
          "text": "خۆی ئامادە دەکات"
        },
        {
          "language": "en",
          "text": "to prepare oneself; to get ready"
        },
        {
          "language": "fa",
          "text": "آماده شدن؛ خود را آماده کردن"
        },
        {
          "language": "kmr",
          "text": "xwe amade kirin"
        },
        {
          "language": "pl",
          "text": "przygotowywać się"
        },
        {
          "language": "ro",
          "text": "a se pregăti"
        },
        {
          "language": "ru",
          "text": "готовиться"
        },
        {
          "language": "sq",
          "text": "të përgatitesh"
        },
        {
          "language": "tr",
          "text": "hazırlanmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bereite mich heute auf das Gespräch mit dem Kunden vor.",
          "translations": [
            {
              "language": "ar",
              "text": "أستعد اليوم للمحادثة مع العميل."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ خۆم بۆ گفتوگۆ لەگەڵ کڕیارەکە ئامادە دەکەم."
            },
            {
              "language": "en",
              "text": "Today I am preparing for the conversation with the customer."
            },
            {
              "language": "fa",
              "text": "امروز برای گفت‌وگو با مشتری آماده می‌شوم."
            },
            {
              "language": "kmr",
              "text": "Ez îro xwe ji bo axaftina bi mişterî re amade dikim."
            },
            {
              "language": "pl",
              "text": "Dziś przygotowuję się do rozmowy z klientem."
            },
            {
              "language": "ro",
              "text": "Astăzi mă pregătesc pentru discuția cu clientul."
            },
            {
              "language": "ru",
              "text": "Сегодня я готовлюсь к разговору с клиентом."
            },
            {
              "language": "sq",
              "text": "Sot po përgatitem për bisedën me klientin."
            },
            {
              "language": "tr",
              "text": "Bugün müşteriyle görüşmeye hazırlanıyorum."
            }
          ]
        },
        {
          "baseText": "Für die Prüfung muss man sich regelmäßig vorbereiten.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن يستعد المرء بانتظام للامتحان."
            },
            {
              "language": "ckb",
              "text": "بۆ تاقیکردنەوە دەبێت بە بەردەوامی خۆت ئامادە بکەیت."
            },
            {
              "language": "en",
              "text": "You have to prepare regularly for the exam."
            },
            {
              "language": "fa",
              "text": "برای امتحان باید منظم آماده شد."
            },
            {
              "language": "kmr",
              "text": "Ji bo ezmûnê divê mirov bi rêkûpêk xwe amade bike."
            },
            {
              "language": "pl",
              "text": "Do egzaminu trzeba przygotowywać się regularnie."
            },
            {
              "language": "ro",
              "text": "Pentru examen trebuie să te pregătești regulat."
            },
            {
              "language": "ru",
              "text": "К экзамену нужно готовиться регулярно."
            },
            {
              "language": "sq",
              "text": "Për provimin duhet të përgatitesh rregullisht."
            },
            {
              "language": "tr",
              "text": "Sınava düzenli olarak hazırlanmak gerekir."
            }
          ]
        }
      ]
    },
