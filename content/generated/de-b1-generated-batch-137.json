  "entries": [
    {
      "word": "die Urlaubsvertretung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Urlaubsvertretungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ur-laubs-ver-tre-tung",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Urlaubsvertretung übernehmen",
          "meaning": "to cover for someone during vacation"
        },
        {
          "text": "eine Urlaubsvertretung organisieren",
          "meaning": "to organize vacation cover"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vertreten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بديل أثناء الإجازة؛ تغطية الإجازة"
        },
        {
          "language": "ckb",
          "text": "جێگری پشووی ساڵانە"
        },
        {
          "language": "en",
          "text": "vacation cover; substitute during leave"
        },
        {
          "language": "fa",
          "text": "جانشین زمان مرخصی؛ پوشش مرخصی"
        },
        {
          "language": "kmr",
          "text": "cihgirê dema betlaneyê"
        },
        {
          "language": "pl",
          "text": "zastępstwo urlopowe"
        },
        {
          "language": "ro",
          "text": "înlocuire pe perioada concediului"
        },
        {
          "language": "ru",
          "text": "замещение на время отпуска"
        },
        {
          "language": "sq",
          "text": "zëvendësim gjatë pushimit"
        },
        {
          "language": "tr",
          "text": "izin dönemi vekaleti"
        }
      ],
      "examples": [
        {
          "baseText": "Während meiner Abwesenheit übernimmt Lisa die Urlaubsvertretung im Support.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء غيابي ستتولى ليزا تغطية الإجازة في الدعم."
            },
            {
              "language": "ckb",
              "text": "لە کاتی نەبوونمدا لیزا جێگری پشووم لە پاڵپشتی وەردەگرێت."
            },
            {
              "language": "en",
              "text": "During my absence, Lisa will cover for me in support."
            },
            {
              "language": "fa",
              "text": "در زمان نبود من، لیزا جانشینی مرخصی را در پشتیبانی به عهده می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Di dema nebûna min de Lisa cihgirtiya betlaneyê di piştgiriyê de digire."
            },
            {
              "language": "pl",
              "text": "Podczas mojej nieobecności Lisa przejmuje zastępstwo urlopowe w dziale wsparcia."
            },
            {
              "language": "ro",
              "text": "În timpul absenței mele, Lisa preia înlocuirea în suport."
            },
            {
              "language": "ru",
              "text": "Во время моего отсутствия Лиза будет замещать меня в поддержке."
            },
            {
              "language": "sq",
              "text": "Gjatë mungesës sime, Lisa merr zëvendësimin në mbështetje."
            },
            {
              "language": "tr",
              "text": "Ben yokken destek biriminde izin vekaletini Lisa üstlenecek."
            }
          ]
        },
        {
          "baseText": "Bitte klären Sie vor dem Urlaub, wer Ihre Urlaubsvertretung ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى توضيح من سيكون بديلك قبل الإجازة."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش پشوویەکە ڕوون بکەنەوە کێ جێگری پشووتانە."
            },
            {
              "language": "en",
              "text": "Please clarify before your vacation who will cover for you."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از مرخصی مشخص کنید چه کسی جانشین شماست."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî betlaneyê zelal bikin ka kî cihgirê we ye."
            },
            {
              "language": "pl",
              "text": "Przed urlopem proszę ustalić, kto będzie Państwa zastępstwem."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să clarificați înainte de concediu cine vă înlocuiește."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, перед отпуском уточните, кто будет вас замещать."
            },
            {
              "language": "sq",
              "text": "Ju lutemi sqaroni para pushimit kush do t’ju zëvendësojë."
            },
            {
              "language": "tr",
              "text": "Lütfen izinden önce sizi kimin vekalet edeceğini netleştirin."
            }
          ]
        }
      ]
    },
    {
      "word": "veranlassen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "veranlassen",
      "pronunciationIpa": null,
      "syllableBreak": "ver-an-las-sen",
      "topics": [
        "documents-and-administration",
        "business-communication",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb; veranlasst, veranlasste, hat veranlasst"
      ],
      "collocations": [
        {
          "text": "eine Zahlung veranlassen",
          "meaning": "to initiate a payment"
        },
        {
          "text": "eine Prüfung veranlassen",
          "meaning": "to arrange a check"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Veranlassung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يأمر؛ يسبب؛ يشرع في إجراء"
        },
        {
          "language": "ckb",
          "text": "ڕێکخستن؛ وا لێکردن؛ دەستپێکردنی کارێک"
        },
        {
          "language": "en",
          "text": "to arrange; to initiate; to cause"
        },
        {
          "language": "fa",
          "text": "ترتیب دادن؛ دستور انجام دادن؛ باعث شدن"
        },
        {
          "language": "kmr",
          "text": "amadekirin; destpêkirin; bûn sedem"
        },
        {
          "language": "pl",
          "text": "zlecić; spowodować; zainicjować"
        },
        {
          "language": "ro",
          "text": "a dispune; a iniția; a determina"
        },
        {
          "language": "ru",
          "text": "инициировать; распорядиться; вызвать"
        },
        {
          "language": "sq",
          "text": "të urdhërosh; të nisësh; të shkaktosh"
        },
        {
          "language": "tr",
          "text": "başlatmak; talimat vermek; neden olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Buchhaltung veranlasst die Zahlung, sobald die Rechnung geprüft ist.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرع المحاسبة في الدفع بمجرد فحص الفاتورة."
            },
            {
              "language": "ckb",
              "text": "ژمێریاری پارەدانەکە دەستپێدەکات کاتێک پسووڵەکە پشکنرا."
            },
            {
              "language": "en",
              "text": "Accounting initiates the payment as soon as the invoice has been checked."
            },
            {
              "language": "fa",
              "text": "حسابداری به محض بررسی فاکتور، پرداخت را انجام می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Hesabdarî dema fatûre hat kontrolkirin, dayînê dest pê dike."
            },
            {
              "language": "pl",
              "text": "Księgowość zleca płatność, gdy tylko faktura zostanie sprawdzona."
            },
            {
              "language": "ro",
              "text": "Contabilitatea inițiază plata imediat ce factura este verificată."
            },
            {
              "language": "ru",
              "text": "Бухгалтерия инициирует оплату, как только счет проверен."
            },
            {
              "language": "sq",
              "text": "Kontabiliteti nis pagesën sapo fatura të kontrollohet."
            },
            {
              "language": "tr",
              "text": "Muhasebe, fatura kontrol edilir edilmez ödemeyi başlatır."
            }
          ]
        },
        {
          "baseText": "Nach der Beschwerde hat die Stadt eine Überprüfung der Baustelle veranlasst.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الشكوى أمرت المدينة بفحص موقع البناء."
            },
            {
              "language": "ckb",
              "text": "دوای سکاڵاکە، شارەکە پشکنینی شوێنی بیناسازییەکەی ڕێکخست."
            },
            {
              "language": "en",
              "text": "After the complaint, the city arranged an inspection of the construction site."
            },
            {
              "language": "fa",
              "text": "پس از شکایت، شهر بررسی محل ساخت‌وساز را ترتیب داد."
            },
            {
              "language": "kmr",
              "text": "Piştî gilîkirinê, bajar kontrola cihê avahîsaziyê amade kir."
            },
            {
              "language": "pl",
              "text": "Po skardze miasto zleciło kontrolę placu budowy."
            },
            {
              "language": "ro",
              "text": "După reclamație, orașul a dispus verificarea șantierului."
            },
            {
              "language": "ru",
              "text": "После жалобы город распорядился проверить строительную площадку."
            },
            {
              "language": "sq",
              "text": "Pas ankesës, qyteti urdhëroi kontrollin e kantierit."
            },
            {
              "language": "tr",
              "text": "Şikayetten sonra şehir inşaat alanının kontrol edilmesini sağladı."
            }
          ]
        }
      ]
    },
    {
      "word": "verantwortlich",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ver-ant-wort-lich",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; often used with für + accusative"
      ],
      "collocations": [
        {
          "text": "für ein Projekt verantwortlich sein",
          "meaning": "to be responsible for a project"
        },
        {
          "text": "die verantwortliche Person",
          "meaning": "the responsible person"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Verantwortung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مسؤول"
        },
        {
          "language": "ckb",
          "text": "بەرپرسیار"
        },
        {
          "language": "en",
          "text": "responsible"
        },
        {
          "language": "fa",
          "text": "مسئول؛ پاسخگو"
        },
        {
          "language": "kmr",
          "text": "berpirsiyar"
        },
        {
          "language": "pl",
          "text": "odpowiedzialny"
        },
        {
          "language": "ro",
          "text": "responsabil"
        },
        {
          "language": "ru",
          "text": "ответственный"
        },
        {
          "language": "sq",
          "text": "përgjegjës"
        },
        {
          "language": "tr",
          "text": "sorumlu"
        }
      ],
      "examples": [
        {
          "baseText": "Wer ist für die Pflege der Kundendaten verantwortlich?",
          "translations": [
            {
              "language": "ar",
              "text": "من المسؤول عن تحديث بيانات العملاء؟"
            },
            {
              "language": "ckb",
              "text": "کێ بەرپرسیاری پاراستن و نوێکردنەوەی داتای کڕیارانە؟"
            },
            {
              "language": "en",
              "text": "Who is responsible for maintaining the customer data?"
            },
            {
              "language": "fa",
              "text": "چه کسی مسئول نگهداری داده‌های مشتریان است؟"
            },
            {
              "language": "kmr",
              "text": "Kî ji bo lênihêrîna daneyên xerîdaran berpirsiyar e?"
            },
            {
              "language": "pl",
              "text": "Kto jest odpowiedzialny za utrzymanie danych klientów?"
            },
            {
              "language": "ro",
              "text": "Cine este responsabil pentru întreținerea datelor clienților?"
            },
            {
              "language": "ru",
              "text": "Кто отвечает за ведение данных клиентов?"
            },
            {
              "language": "sq",
              "text": "Kush është përgjegjës për mirëmbajtjen e të dhënave të klientëve?"
            },
            {
              "language": "tr",
              "text": "Müşteri verilerinin bakımından kim sorumlu?"
            }
          ]
        },
        {
          "baseText": "Die verantwortliche Mitarbeiterin meldet sich heute Nachmittag bei Ihnen.",
          "translations": [
            {
              "language": "ar",
              "text": "ستتواصل معك الموظفة المسؤولة بعد ظهر اليوم."
            },
            {
              "language": "ckb",
              "text": "کارمەندە بەرپرسیارەکە ئەمڕۆ دوای نیوەڕۆ پەیوەندیت پێوە دەکات."
            },
            {
              "language": "en",
              "text": "The responsible employee will contact you this afternoon."
            },
            {
              "language": "fa",
              "text": "کارمند مسئول امروز بعدازظهر با شما تماس می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Karmenda berpirsiyar îro piştî nîvro bi we re têkilî dike."
            },
            {
              "language": "pl",
              "text": "Odpowiedzialna pracowniczka skontaktuje się z Państwem dziś po południu."
            },
            {
              "language": "ro",
              "text": "Angajata responsabilă vă va contacta în această după-amiază."
            },
            {
