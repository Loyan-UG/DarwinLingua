  "entries": [
    {
      "word": "die Arbeitserlaubnis",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Arbeitserlaubnisse",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ar-beits-er-laub-nis",
      "topics": [
        "work-and-jobs",
        "public-services",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "hr",
        "public-services",
        "legal"
      ],
      "grammarNotes": [
        "feminine noun",
        "official permission to work"
      ],
      "collocations": [
        {
          "text": "eine Arbeitserlaubnis beantragen",
          "meaning": "to apply for a work permit"
        },
        {
          "text": "eine gültige Arbeitserlaubnis",
          "meaning": "a valid work permit"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erlaubnis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "arbeiten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تصريح عمل؛ إذن عمل"
        },
        {
          "language": "ckb",
          "text": "مۆڵەتی کارکردن"
        },
        {
          "language": "en",
          "text": "work permit"
        },
        {
          "language": "fa",
          "text": "اجازه کار؛ مجوز کار"
        },
        {
          "language": "kmr",
          "text": "destûra karê"
        },
        {
          "language": "pl",
          "text": "pozwolenie na pracę"
        },
        {
          "language": "ro",
          "text": "permis de muncă"
        },
        {
          "language": "ru",
          "text": "разрешение на работу"
        },
        {
          "language": "sq",
          "text": "leje pune"
        },
        {
          "language": "tr",
          "text": "çalışma izni"
        }
      ],
      "examples": [
        {
          "baseText": "Ohne gültige Arbeitserlaubnis darf die Firma ihn nicht einstellen.",
          "translations": [
            {
              "language": "ar",
              "text": "بدون تصريح عمل صالح لا يجوز للشركة توظيفه."
            },
            {
              "language": "ckb",
              "text": "بەبێ مۆڵەتی کاری دروست، کۆمپانیاکە ناتوانێت دایبمەزرێنێت."
            },
            {
              "language": "en",
              "text": "Without a valid work permit, the company is not allowed to hire him."
            },
            {
              "language": "fa",
              "text": "بدون اجازه کار معتبر، شرکت اجازه ندارد او را استخدام کند."
            },
            {
              "language": "kmr",
              "text": "Bê destûra karê ya derbasdar, şirket nikare wî bigire kar."
            },
            {
              "language": "pl",
              "text": "Bez ważnego pozwolenia na pracę firma nie może go zatrudnić."
            },
            {
              "language": "ro",
              "text": "Fără un permis de muncă valabil, compania nu are voie să îl angajeze."
            },
            {
              "language": "ru",
              "text": "Без действительного разрешения на работу компания не имеет права его нанять."
            },
            {
              "language": "sq",
              "text": "Pa leje pune të vlefshme, kompania nuk lejohet ta punësojë atë."
            },
            {
              "language": "tr",
              "text": "Geçerli çalışma izni olmadan şirket onu işe alamaz."
            }
          ]
        },
        {
          "baseText": "Sie hat beim Amt eine neue Arbeitserlaubnis beantragt.",
          "translations": [
            {
              "language": "ar",
              "text": "قدمت طلبًا لدى الدائرة للحصول على تصريح عمل جديد."
            },
            {
              "language": "ckb",
              "text": "لە فەرمانگەکە داوای مۆڵەتی کاری نوێی کردووە."
            },
            {
              "language": "en",
              "text": "She applied for a new work permit at the office."
            },
            {
              "language": "fa",
              "text": "او در اداره برای اجازه کار جدید درخواست داده است."
            },
            {
              "language": "kmr",
              "text": "Wê li dezgehê ji bo destûra karê ya nû daxwaz kir."
            },
            {
              "language": "pl",
              "text": "Złożyła w urzędzie wniosek o nowe pozwolenie na pracę."
            },
            {
              "language": "ro",
              "text": "Ea a solicitat la oficiu un nou permis de muncă."
            },
            {
              "language": "ru",
              "text": "Она подала в ведомство заявление на новое разрешение на работу."
            },
            {
              "language": "sq",
              "text": "Ajo aplikoi në zyrë për një leje të re pune."
            },
            {
              "language": "tr",
              "text": "Daireye yeni çalışma izni için başvurdu."
            }
          ]
        }
      ]
    },
    {
      "word": "die Arbeitsgenehmigung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Arbeitsgenehmigungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ar-beits-ge-neh-mi-gung",
      "topics": [
        "work-and-jobs",
