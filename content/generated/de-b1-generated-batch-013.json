        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "hr",
        "public-services",
        "legal"
      ],
      "grammarNotes": [
        "feminine noun",
        "official approval to work; often similar to Arbeitserlaubnis"
      ],
      "collocations": [
        {
          "text": "eine Arbeitsgenehmigung vorlegen",
          "meaning": "to present a work authorization"
        },
        {
          "text": "Arbeitsgenehmigung erhalten",
          "meaning": "to receive work authorization"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "genehmigen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Genehmigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تصريح عمل؛ موافقة للعمل"
        },
        {
          "language": "ckb",
          "text": "ڕێپێدانی کار؛ مۆڵەتی کار"
        },
        {
          "language": "en",
          "text": "work authorization; work permit"
        },
        {
          "language": "fa",
          "text": "مجوز کار؛ اجازه کار"
        },
        {
          "language": "kmr",
          "text": "destûra karê; pejirandina karê"
        },
        {
          "language": "pl",
          "text": "zezwolenie na pracę"
        },
        {
          "language": "ro",
          "text": "autorizație de muncă"
        },
        {
          "language": "ru",
          "text": "разрешение на работу"
        },
        {
          "language": "sq",
          "text": "autorizim pune; leje pune"
        },
        {
          "language": "tr",
          "text": "çalışma izni; çalışma onayı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Personalabteilung prüft, ob die Arbeitsgenehmigung noch gültig ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يتحقق قسم الموارد البشرية مما إذا كان تصريح العمل لا يزال صالحًا."
            },
            {
              "language": "ckb",
              "text": "بەشی کارمەندان دەپشکنێت ئایا ڕێپێدانی کار هێشتا دروستە یان نا."
            },
            {
              "language": "en",
              "text": "HR checks whether the work authorization is still valid."
            },
            {
              "language": "fa",
              "text": "بخش منابع انسانی بررسی می‌کند که آیا مجوز کار هنوز معتبر است یا نه."
            },
            {
              "language": "kmr",
              "text": "Beşa HR kontrol dike ka destûra karê hîn derbasdar e an na."
            },
            {
              "language": "pl",
              "text": "Dział kadr sprawdza, czy zezwolenie na pracę jest jeszcze ważne."
            },
            {
              "language": "ro",
              "text": "Departamentul de resurse umane verifică dacă autorizația de muncă mai este valabilă."
            },
            {
              "language": "ru",
              "text": "Отдел кадров проверяет, действительно ли ещё разрешение на работу."
            },
            {
              "language": "sq",
              "text": "Burimet njerëzore kontrollojnë nëse autorizimi i punës është ende i vlefshëm."
            },
            {
              "language": "tr",
