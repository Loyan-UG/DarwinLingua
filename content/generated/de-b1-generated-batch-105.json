          "note": null
        },
        {
          "lemma": "das Praktikum",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متدرب؛ طالب تدريب عملي"
        },
        {
          "language": "ckb",
          "text": "ڕاهێنراوی پیاو؛ پراکتیکانت"
        },
        {
          "language": "en",
          "text": "intern; male trainee"
        },
        {
          "language": "fa",
          "text": "کارآموز مرد؛ اینترن"
        },
        {
          "language": "kmr",
          "text": "stajyerê mêr"
        },
        {
          "language": "pl",
          "text": "praktykant; stażysta"
        },
        {
          "language": "ro",
          "text": "stagiar; practicant"
        },
        {
          "language": "ru",
          "text": "практикант; стажёр"
        },
        {
          "language": "sq",
          "text": "praktikant; stazhier"
        },
        {
          "language": "tr",
          "text": "erkek stajyer"
        }
      ],
      "examples": [
        {
          "baseText": "Der Praktikant unterstützt das Team bei einfachen Aufgaben.",
          "translations": [
            {
              "language": "ar",
              "text": "يدعم المتدرب الفريق في المهام البسيطة."
            },
            {
              "language": "ckb",
              "text": "پراکتیکانتەکە یارمەتی تیمەکە دەدات لە ئەرکە ئاسانەکاندا."
            },
            {
              "language": "en",
              "text": "The intern supports the team with simple tasks."
            },
            {
              "language": "fa",
              "text": "کارآموز در کارهای ساده به تیم کمک می‌کند."
            },
            {
              "language": "kmr",
              "text": "Stajyer di erkên hêsan de alîkariya tîmê dike."
            },
            {
              "language": "pl",
              "text": "Praktykant wspiera zespół przy prostych zadaniach."
            },
            {
              "language": "ro",
              "text": "Stagiarul sprijină echipa la sarcini simple."
            },
            {
              "language": "ru",
              "text": "Стажёр помогает команде с простыми задачами."
            },
            {
              "language": "sq",
              "text": "Praktikanti e ndihmon ekipin me detyra të thjeshta."
            },
            {
              "language": "tr",
              "text": "Stajyer ekibe basit görevlerde destek olur."
            }
          ]
        },
        {
          "baseText": "Am ersten Tag bekommt der Praktikant eine kurze Einführung.",
          "translations": [
            {
              "language": "ar",
              "text": "في اليوم الأول يحصل المتدرب على مقدمة قصيرة."
            },
            {
              "language": "ckb",
              "text": "لە یەکەم ڕۆژدا پراکتیکانتەکە ناساندنێکی کورتی وەردەگرێت."
            },
            {
              "language": "en",
              "text": "On the first day, the intern gets a short introduction."
            },
            {
              "language": "fa",
              "text": "در روز اول، کارآموز یک معرفی کوتاه دریافت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di roja yekem de stajyer danasîneke kurt werdigire."
            },
            {
              "language": "pl",
              "text": "Pierwszego dnia praktykant otrzymuje krótkie wprowadzenie."
            },
            {
              "language": "ro",
              "text": "În prima zi, stagiarul primește o scurtă introducere."
            },
            {
              "language": "ru",
              "text": "В первый день стажёр получает краткое введение."
            },
            {
              "language": "sq",
              "text": "Ditën e parë praktikanti merr një prezantim të shkurtër."
            },
            {
              "language": "tr",
              "text": "İlk gün stajyer kısa bir tanıtım alır."
            }
          ]
        }
      ]
    },
