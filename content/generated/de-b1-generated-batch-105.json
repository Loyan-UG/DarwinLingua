  "entries": [
    {
      "word": "präsentieren",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "präsentieren",
      "pronunciationIpa": null,
      "syllableBreak": "prä-sen-tie-ren",
      "topics": [
        "meetings-and-presentations",
        "business-communication",
        "education-and-training"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "formal",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "Ergebnisse präsentieren",
          "meaning": "to present results"
        },
        {
          "text": "ein Produkt präsentieren",
          "meaning": "to present a product"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Präsentation",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "präsentiert",
          "relationLabel": "participle/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعرض؛ يقدم"
        },
        {
          "language": "ckb",
          "text": "پێشکەش دەکات؛ نیشان دەدات"
        },
        {
          "language": "en",
          "text": "to present; to show"
        },
        {
          "language": "fa",
          "text": "ارائه کردن؛ نمایش دادن"
        },
        {
          "language": "kmr",
          "text": "pêşkêş kirin; nîşan dan"
        },
        {
          "language": "pl",
          "text": "prezentować; przedstawiać"
        },
        {
          "language": "ro",
          "text": "a prezenta"
        },
        {
          "language": "ru",
          "text": "представлять; презентовать"
        },
        {
          "language": "sq",
          "text": "të prezantosh"
        },
        {
          "language": "tr",
          "text": "sunmak; tanıtmak"
        }
      ],
      "examples": [
        {
          "baseText": "Morgen präsentieren wir dem Kunden die neue Lösung.",
          "translations": [
            {
              "language": "ar",
              "text": "غدًا سنعرض على العميل الحل الجديد."
            },
            {
              "language": "ckb",
              "text": "سبەی چارەسەری نوێ بە کڕیارەکە پێشکەش دەکەین."
            },
            {
              "language": "en",
              "text": "Tomorrow we will present the new solution to the customer."
            },
            {
              "language": "fa",
              "text": "فردا راه‌حل جدید را به مشتری ارائه می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Sibê em ê çareseriya nû ji mişterî re pêşkêş bikin."
            },
            {
              "language": "pl",
              "text": "Jutro przedstawimy klientowi nowe rozwiązanie."
            },
            {
              "language": "ro",
              "text": "Mâine îi prezentăm clientului noua soluție."
            },
            {
              "language": "ru",
              "text": "Завтра мы представим клиенту новое решение."
            },
            {
              "language": "sq",
              "text": "Nesër do t’i prezantojmë klientit zgjidhjen e re."
            },
            {
              "language": "tr",
              "text": "Yarın müşteriye yeni çözümü sunacağız."
            }
          ]
        },
        {
          "baseText": "Die Teilnehmenden präsentieren ihre Ergebnisse am Ende des Kurses.",
          "translations": [
            {
              "language": "ar",
              "text": "يعرض المشاركون نتائجهم في نهاية الدورة."
            },
            {
              "language": "ckb",
              "text": "بەشداربووان لە کۆتایی کۆرسەکەدا ئەنجامەکانیان پێشکەش دەکەن."
            },
            {
              "language": "en",
              "text": "The participants present their results at the end of the course."
            },
            {
              "language": "fa",
              "text": "شرکت‌کنندگان در پایان دوره نتایج خود را ارائه می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Beşdar di dawiya kursê de encamên xwe pêşkêş dikin."
            },
            {
              "language": "pl",
              "text": "Uczestnicy prezentują swoje wyniki na końcu kursu."
            },
            {
              "language": "ro",
              "text": "Participanții își prezintă rezultatele la finalul cursului."
            },
            {
              "language": "ru",
              "text": "Участники представляют свои результаты в конце курса."
            },
            {
              "language": "sq",
              "text": "Pjesëmarrësit prezantojnë rezultatet e tyre në fund të kursit."
            },
            {
              "language": "tr",
              "text": "Katılımcılar kursun sonunda sonuçlarını sunar."
            }
          ]
        }
      ]
    },
