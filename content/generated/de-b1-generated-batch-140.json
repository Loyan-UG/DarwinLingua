        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: vergibt, vergab, hat vergeben"
      ],
      "collocations": [
        {
          "text": "einen Auftrag vergeben",
          "meaning": "to award a contract"
        },
        {
          "text": "einen Fehler vergeben",
          "meaning": "to forgive a mistake"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Vergabe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يمنح؛ يخصص؛ يسامح"
        },
        {
          "language": "ckb",
          "text": "دان؛ دابەشکردن؛ لێخۆشبوون"
        },
        {
          "language": "en",
          "text": "to award; to allocate; to forgive"
        },
        {
          "language": "fa",
          "text": "واگذار کردن؛ اختصاص دادن؛ بخشیدن"
        },
        {
          "language": "kmr",
          "text": "dayîn; veqetandin; lêborîn"
        },
        {
          "language": "pl",
          "text": "przyznać; zlecić; wybaczyć"
        },
        {
          "language": "ro",
          "text": "a acorda; a atribui; a ierta"
        },
        {
          "language": "ru",
          "text": "присуждать; распределять; прощать"
        },
        {
          "language": "sq",
          "text": "të japësh; të ndash; të falësh"
        },
        {
          "language": "tr",
          "text": "vermek; tahsis etmek; affetmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Auftrag wurde an einen lokalen Dienstleister vergeben.",
          "translations": [
            {
              "language": "ar",
              "text": "تم إسناد الطلب إلى مزود خدمة محلي."
            },
            {
              "language": "ckb",
              "text": "ئەرکەکە درا بە دابینکەرێکی خزمەتگوزاری ناوخۆیی."
            },
            {
              "language": "en",
              "text": "The contract was awarded to a local service provider."
            },
            {
              "language": "fa",
              "text": "قرارداد به یک ارائه‌دهنده خدمات محلی واگذار شد."
            },
            {
              "language": "kmr",
              "text": "Kar ji dabînkerê xizmetê yê herêmî re hat dayîn."
            },
            {
              "language": "pl",
              "text": "Zlecenie przyznano lokalnemu usługodawcy."
            },
            {
              "language": "ro",
              "text": "Contractul a fost atribuit unui furnizor local de servicii."
            },
            {
              "language": "ru",
              "text": "Заказ был передан местному поставщику услуг."
            },
            {
              "language": "sq",
              "text": "Kontrata iu dha një ofruesi lokal shërbimesh."
            },
            {
              "language": "tr",
              "text": "İş yerel bir hizmet sağlayıcıya verildi."
            }
          ]
        },
        {
          "baseText": "Ich hoffe, du kannst mir den Fehler vergeben.",
          "translations": [
            {
              "language": "ar",
              "text": "آمل أن تسامحني على الخطأ."
            },
            {
              "language": "ckb",
              "text": "هیوادارم بتوانیت لەو هەڵەیەم خۆش ببیت."
            },
            {
              "language": "en",
              "text": "I hope you can forgive me for the mistake."
            },
            {
              "language": "fa",
              "text": "امیدوارم بتوانی این اشتباه را از من ببخشی."
            },
            {
              "language": "kmr",
              "text": "Ez hêvî dikim tu dikarî ji bo vê şaşiyê li min biborî."
            },
            {
              "language": "pl",
              "text": "Mam nadzieję, że możesz mi wybaczyć ten błąd."
            },
            {
              "language": "ro",
              "text": "Sper că poți să-mi ierți greșeala."
            },
            {
              "language": "ru",
              "text": "Надеюсь, ты сможешь простить мне эту ошибку."
            },
            {
              "language": "sq",
              "text": "Shpresoj të ma falësh gabimin."
            },
            {
              "language": "tr",
              "text": "Umarım bu hatamı affedebilirsin."
            }
          ]
        }
      ]
    },
    {
      "word": "der Vergleich",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Vergleiche",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-gleich",
      "topics": [
        "data-and-reporting",
        "shopping-and-services",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "einen Vergleich machen",
          "meaning": "to make a comparison"
        },
        {
          "text": "im Vergleich zu",
          "meaning": "compared with"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vergleichen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مقارنة؛ تسوية"
        },
        {
          "language": "ckb",
          "text": "بەراورد؛ ڕێککەوتنی چارەسەر"
        },
        {
          "language": "en",
          "text": "comparison; settlement"
        },
        {
          "language": "fa",
          "text": "مقایسه؛ مصالحه"
        },
        {
          "language": "kmr",
          "text": "berawird; lihevhatina çareseriyê"
        },
        {
          "language": "pl",
          "text": "porównanie; ugoda"
        },
        {
          "language": "ro",
          "text": "comparație; acord"
        },
        {
          "language": "ru",
          "text": "сравнение; мировое соглашение"
        },
        {
          "language": "sq",
          "text": "krahasim; marrëveshje pajtimi"
        },
        {
          "language": "tr",
          "text": "karşılaştırma; uzlaşma"
        }
      ],
      "examples": [
        {
          "baseText": "Im Vergleich zum letzten Jahr sind die Kosten deutlich gesunken.",
          "translations": [
            {
              "language": "ar",
              "text": "بالمقارنة مع العام الماضي انخفضت التكاليف بوضوح."
            },
            {
              "language": "ckb",
              "text": "بە بەراورد بە ساڵی ڕابردوو، تێچووەکان بە ڕوونی کەم بوونەتەوە."
            },
            {
              "language": "en",
              "text": "Compared with last year, the costs have fallen significantly."
            },
            {
              "language": "fa",
              "text": "در مقایسه با سال گذشته، هزینه‌ها به‌طور قابل توجهی کاهش یافته‌اند."
            },
            {
              "language": "kmr",
              "text": "Li gor sala borî, lêçûn bi awayekî eşkere kêm bûne."
            },
            {
              "language": "pl",
              "text": "W porównaniu z zeszłym rokiem koszty wyraźnie spadły."
            },
            {
              "language": "ro",
              "text": "În comparație cu anul trecut, costurile au scăzut clar."
            },
            {
              "language": "ru",
              "text": "По сравнению с прошлым годом расходы заметно снизились."
            },
            {
              "language": "sq",
              "text": "Në krahasim me vitin e kaluar, kostot kanë rënë dukshëm."
            },
            {
              "language": "tr",
              "text": "Geçen yıla kıyasla maliyetler belirgin şekilde düştü."
            }
          ]
        },
        {
          "baseText": "Vor dem Kauf lohnt sich ein Vergleich der Stromtarife.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الشراء تستحق مقارنة تعرفة الكهرباء العناء."
            },
            {
              "language": "ckb",
              "text": "پێش کڕین بەراوردکردنی تاریفی کارەبا بەسوودە."
            },
            {
              "language": "en",
              "text": "Before buying, comparing electricity tariffs is worthwhile."
            },
            {
              "language": "fa",
              "text": "قبل از خرید، مقایسه تعرفه‌های برق ارزش دارد."
            },
            {
              "language": "kmr",
              "text": "Berî kirînê berawirdkirina tarîfên elektrîkê hêja ye."
            },
            {
              "language": "pl",
              "text": "Przed zakupem warto porównać taryfy za prąd."
            },
            {
              "language": "ro",
              "text": "Înainte de cumpărare merită o comparație a tarifelor la electricitate."
            },
            {
              "language": "ru",
              "text": "Перед покупкой стоит сравнить тарифы на электроэнергию."
            },
            {
              "language": "sq",
              "text": "Para blerjes ia vlen krahasimi i tarifave të energjisë."
            },
            {
              "language": "tr",
              "text": "Satın almadan önce elektrik tarifelerini karşılaştırmak faydalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Vergleichsmöglichkeit",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Vergleichsmöglichkeiten",
      "infinitive": null,
