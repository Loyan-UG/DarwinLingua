      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine gute Vergleichsmöglichkeit",
          "meaning": "a good way to compare"
        },
        {
          "text": "Vergleichsmöglichkeiten anbieten",
          "meaning": "to offer comparison options"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Vergleich",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إمكانية المقارنة؛ خيار المقارنة"
        },
        {
          "language": "ckb",
          "text": "هەلی بەراوردکردن؛ توانای بەراورد"
        },
        {
          "language": "en",
          "text": "comparison option; possibility to compare"
        },
        {
          "language": "fa",
          "text": "امکان مقایسه؛ گزینه مقایسه"
        },
        {
          "language": "kmr",
          "text": "îmkanê berawirdkirinê"
        },
        {
          "language": "pl",
          "text": "możliwość porównania"
        },
        {
          "language": "ro",
          "text": "posibilitate de comparație"
        },
        {
          "language": "ru",
          "text": "возможность сравнения"
        },
        {
          "language": "sq",
          "text": "mundësi krahasimi"
        },
        {
          "language": "tr",
          "text": "karşılaştırma imkanı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Webseite bietet eine gute Vergleichsmöglichkeit für verschiedene Versicherungen.",
          "translations": [
            {
              "language": "ar",
              "text": "يوفر الموقع إمكانية جيدة لمقارنة تأمينات مختلفة."
            },
            {
              "language": "ckb",
              "text": "ماڵپەڕەکە هەلی باشی بەراوردکردنی بیمەی جیاواز پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "The website offers a good way to compare different insurance policies."
            },
            {
              "language": "fa",
              "text": "وب‌سایت امکان خوبی برای مقایسه بیمه‌های مختلف ارائه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Malper îmkana baş a berawirdkirina sîgorteyên cuda pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Strona oferuje dobrą możliwość porównania różnych ubezpieczeń."
            },
            {
              "language": "ro",
              "text": "Site-ul oferă o bună posibilitate de comparare a diferitelor asigurări."
            },
            {
              "language": "ru",
              "text": "Сайт предлагает хорошую возможность сравнить разные страховки."
            },
            {
              "language": "sq",
              "text": "Faqja ofron një mundësi të mirë për të krahasuar sigurime të ndryshme."
            },
            {
              "language": "tr",
              "text": "Web sitesi farklı sigortaları karşılaştırmak için iyi bir imkan sunuyor."
            }
          ]
        },
        {
          "baseText": "Ohne Vergleichsmöglichkeit ist der Preis für Kunden schwer einzuschätzen.",
          "translations": [
            {
              "language": "ar",
              "text": "بدون إمكانية مقارنة يصعب على العملاء تقدير السعر."
            },
            {
              "language": "ckb",
              "text": "بێ هەلی بەراوردکردن، هەڵسەنگاندنی نرخ بۆ کڕیاران قورسە."
            },
            {
              "language": "en",
              "text": "Without a comparison option, the price is hard for customers to assess."
            },
            {
              "language": "fa",
              "text": "بدون امکان مقایسه، ارزیابی قیمت برای مشتریان دشوار است."
            },
            {
              "language": "kmr",
              "text": "Bê îmkana berawirdkirinê, nirx ji bo xerîdaran zehmet tê nirxandin."
            },
            {
              "language": "pl",
              "text": "Bez możliwości porównania cena jest dla klientów trudna do oceny."
            },
            {
              "language": "ro",
              "text": "Fără posibilitate de comparație, prețul este greu de evaluat pentru clienți."
            },
            {
              "language": "ru",
              "text": "Без возможности сравнения клиентам трудно оценить цену."
            },
            {
              "language": "sq",
              "text": "Pa mundësi krahasimi, çmimi është i vështirë për klientët të vlerësohet."
            },
            {
              "language": "tr",
              "text": "Karşılaştırma imkanı olmadan fiyatı müşterilerin değerlendirmesi zordur."
            }
          ]
        }
      ]
    },
