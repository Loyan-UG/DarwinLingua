      "examples": [
        {
          "baseText": "Unser Hotel bietet Frühstück bis zehn Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "يقدم فندقنا الفطور حتى الساعة العاشرة."
            },
            {
              "language": "ckb",
              "text": "هۆتێلەکەمان تا کاتژمێر دە نانی بەیانی پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "Our hotel offers breakfast until ten o’clock."
            },
            {
              "language": "fa",
              "text": "هتل ما تا ساعت ده صبحانه ارائه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Otêla me heta saet dehan taştê pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Nasz hotel oferuje śniadanie do dziesiątej."
            },
            {
              "language": "ro",
              "text": "Hotelul nostru oferă mic dejun până la ora zece."
            },
            {
              "language": "ru",
              "text": "Наш отель предлагает завтрак до десяти часов."
            },
            {
              "language": "sq",
              "text": "Hoteli ynë ofron mëngjes deri në orën dhjetë."
            },
            {
              "language": "tr",
              "text": "Otelimiz saat ona kadar kahvaltı sunar."
            }
          ]
        },
        {
          "baseText": "Die Firma bietet einen guten Service.",
          "translations": [
            {
              "language": "ar",
              "text": "تقدم الشركة خدمة جيدة."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە خزمەتگوزارییەکی باش پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "The company offers good service."
            },
            {
              "language": "fa",
              "text": "شرکت خدمات خوبی ارائه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Şîrket xizmetek baş pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Firma oferuje dobrą obsługę."
            },
            {
              "language": "ro",
              "text": "Firma oferă un serviciu bun."
            },
            {
              "language": "ru",
              "text": "Компания предлагает хороший сервис."
