  "entries": [
    {
      "word": "die Teilzeitstelle",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Teilzeitstellen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Teil-zeit-stel-le",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Teilzeitstelle suchen",
          "meaning": "to look for a part-time position"
        },
        {
          "text": "eine Teilzeitstelle anbieten",
          "meaning": "to offer a part-time position"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Teilzeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وظيفة بدوام جزئي"
        },
        {
          "language": "ckb",
          "text": "کارێکی نیوەکات"
        },
        {
          "language": "en",
          "text": "part-time position"
        },
        {
          "language": "fa",
          "text": "موقعیت شغلی پاره‌وقت"
        },
        {
          "language": "kmr",
          "text": "karê nîv-dem"
        },
        {
          "language": "pl",
          "text": "stanowisko w niepełnym wymiarze czasu"
        },
        {
          "language": "ro",
          "text": "post cu jumătate de normă"
        },
        {
          "language": "ru",
          "text": "должность на неполный рабочий день"
        },
        {
          "language": "sq",
          "text": "vend pune me kohë të pjesshme"
        },
        {
          "language": "tr",
          "text": "yarı zamanlı iş pozisyonu"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Elternzeit sucht sie eine Teilzeitstelle im Büro.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد إجازة رعاية الطفل تبحث عن وظيفة بدوام جزئي في المكتب."
            },
            {
              "language": "ckb",
              "text": "دوای پشووی دایک و باوک، ئەو بەدوای کارێکی نیوەکات لە ئۆفیس دەگەڕێت."
            },
            {
              "language": "en",
              "text": "After parental leave, she is looking for a part-time office position."
            },
            {
              "language": "fa",
              "text": "بعد از مرخصی والدین، او دنبال یک شغل پاره‌وقت در دفتر است."
            },
            {
              "language": "kmr",
              "text": "Piştî betlaneya dêûbavan, ew li karê nîv-dem li nivîsgehê digere."
            },
            {
              "language": "pl",
              "text": "Po urlopie rodzicielskim szuka pracy biurowej na część etatu."
            },
            {
              "language": "ro",
              "text": "După concediul parental, ea caută un post cu jumătate de normă la birou."
            },
            {
              "language": "ru",
              "text": "После отпуска по уходу за ребенком она ищет офисную работу на неполный день."
            },
            {
              "language": "sq",
              "text": "Pas lejes prindërore ajo kërkon një punë me kohë të pjesshme në zyrë."
            },
            {
              "language": "tr",
              "text": "Ebeveyn izninden sonra ofiste yarı zamanlı bir iş arıyor."
            }
          ]
        },
        {
          "baseText": "Die Anzeige für die Teilzeitstelle passt gut zu meinem Stundenplan.",
          "translations": [
            {
              "language": "ar",
              "text": "إعلان الوظيفة بدوام جزئي يناسب جدول وقتي جيدًا."
            },
            {
              "language": "ckb",
              "text": "ئاگاداری کارە نیوەکاتەکە زۆر باش لەگەڵ خشتەی کاتەکانم دەگونجێت."
            },
            {
              "language": "en",
              "text": "The ad for the part-time position fits my schedule well."
            },
            {
              "language": "fa",
              "text": "آگهی شغل پاره‌وقت با برنامه زمانی من خوب هماهنگ است."
            },
            {
              "language": "kmr",
              "text": "Îlana karê nîv-dem bi nexşeya demê ya min re baş tê."
            },
            {
              "language": "pl",
              "text": "Ogłoszenie o pracy na część etatu dobrze pasuje do mojego planu zajęć."
            },
            {
              "language": "ro",
              "text": "Anunțul pentru postul cu jumătate de normă se potrivește bine cu programul meu."
            },
            {
              "language": "ru",
              "text": "Объявление о работе на неполный день хорошо подходит к моему расписанию."
            },
            {
              "language": "sq",
              "text": "Shpallja për punën me kohë të pjesshme i përshtatet mirë orarit tim."
            },
            {
              "language": "tr",
              "text": "Yarı zamanlı iş ilanı programıma iyi uyuyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Terminabsage",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Terminabsagen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ter-min-ab-sa-ge",
      "topics": [
        "business-communication",
        "customer-service",
        "healthcare-and-appointments"
      ],
      "usageLabels": [
        "formal",
        "polite",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Terminabsage schicken",
          "meaning": "to send a cancellation of an appointment"
        },
        {
          "text": "eine Terminabsage erhalten",
          "meaning": "to receive an appointment cancellation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "absagen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إلغاء موعد"
        },
        {
          "language": "ckb",
          "text": "هەڵوەشاندنەوەی کات/مەوعید"
        },
        {
          "language": "en",
          "text": "appointment cancellation"
        },
        {
          "language": "fa",
          "text": "لغو قرار ملاقات"
        },
        {
          "language": "kmr",
          "text": "betalkirina hevdîtinê"
        },
        {
          "language": "pl",
          "text": "odwołanie terminu"
        },
        {
          "language": "ro",
          "text": "anulare a programării"
        },
        {
          "language": "ru",
          "text": "отмена встречи или записи"
        },
        {
          "language": "sq",
          "text": "anulim takimi"
        },
        {
          "language": "tr",
          "text": "randevu iptali"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte senden Sie uns die Terminabsage so früh wie möglich.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال إلغاء الموعد إلينا في أقرب وقت ممكن."
            },
            {
              "language": "ckb",
              "text": "تکایە هەڵوەشاندنەوەی کاتەکە هەرچی زووە بۆمان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us the appointment cancellation as early as possible."
            },
            {
              "language": "fa",
              "text": "لطفاً لغو قرار را تا حد ممکن زود برای ما بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe betalkirina hevdîtinê her çiqas zû be ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę wysłać nam odwołanie terminu jak najwcześniej."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți anularea programării cât mai devreme posibil."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам отмену записи как можно раньше."
            },
            {
              "language": "sq",
              "text": "Ju lutemi na dërgoni anulimin e takimit sa më herët të jetë e mundur."
            },
            {
              "language": "tr",
              "text": "Lütfen randevu iptalini bize mümkün olduğunca erken gönderin."
            }
          ]
        },
        {
          "baseText": "Wegen Krankheit habe ich heute Morgen eine Terminabsage vom Arzt bekommen.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب المرض تلقيت هذا الصباح إلغاءً للموعد من الطبيب."
            },
            {
              "language": "ckb",
              "text": "بەهۆی نەخۆشییەوە ئەم بەیانییە هەڵوەشاندنەوەی کاتم لە پزیشک وەرگرت."
            },
            {
              "language": "en",
              "text": "Because of illness, I got an appointment cancellation from the doctor this morning."
            },
            {
              "language": "fa",
              "text": "به دلیل بیماری، امروز صبح از پزشک لغو قرار دریافت کردم."
            },
            {
              "language": "kmr",
              "text": "Ji ber nexweşiyê, vê sibehê min betalkirina hevdîtinê ji bijîşk wergirt."
            },
            {
              "language": "pl",
              "text": "Z powodu choroby dziś rano dostałem od lekarza odwołanie wizyty."
            },
            {
              "language": "ro",
              "text": "Din cauza bolii, am primit azi dimineață o anulare a programării de la medic."
            },
            {
              "language": "ru",
              "text": "Из-за болезни сегодня утром я получил отмену записи от врача."
            },
            {
              "language": "sq",
              "text": "Për shkak të sëmundjes, sot në mëngjes mora anulim takimi nga mjeku."
            },
            {
              "language": "tr",
              "text": "Hastalık nedeniyle bu sabah doktordan randevu iptali aldım."
            }
          ]
        }
      ]
    },
