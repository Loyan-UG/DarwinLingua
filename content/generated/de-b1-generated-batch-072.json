      "meanings": [
        {
          "language": "ar",
          "text": "حبكة؛ فعل؛ تصرف"
        },
        {
          "language": "ckb",
          "text": "چیرۆک؛ کردار؛ ڕەفتار"
        },
        {
          "language": "en",
          "text": "plot; action; act"
        },
        {
          "language": "fa",
          "text": "داستان؛ کنش؛ عمل"
        },
        {
          "language": "kmr",
          "text": "çîrok; kiryar; tevger"
        },
        {
          "language": "pl",
          "text": "fabuła; działanie; czyn"
        },
        {
          "language": "ro",
          "text": "acțiune; intrigă; faptă"
        },
        {
          "language": "ru",
          "text": "сюжет; действие; поступок"
        },
        {
          "language": "sq",
          "text": "ngjarje; veprim; akt"
        },
        {
          "language": "tr",
          "text": "olay örgüsü; eylem; davranış"
        }
      ],
      "examples": [
        {
          "baseText": "Die Handlung des Films ist einfach, aber sehr spannend.",
          "translations": [
            {
              "language": "ar",
              "text": "حبكة الفيلم بسيطة لكنها مشوقة جداً."
            },
            {
              "language": "ckb",
              "text": "چیرۆکی فیلمەکە سادەیە، بەڵام زۆر سەرنجڕاکێشە."
            },
            {
              "language": "en",
              "text": "The plot of the film is simple but very exciting."
            },
            {
              "language": "fa",
              "text": "داستان فیلم ساده است، اما بسیار هیجان‌انگیز است."
            },
            {
              "language": "kmr",
              "text": "Çîroka fîlmê sade ye, lê gelek balkêş e."
            },
            {
              "language": "pl",
              "text": "Fabuła filmu jest prosta, ale bardzo wciągająca."
            },
            {
              "language": "ro",
              "text": "Acțiunea filmului este simplă, dar foarte captivantă."
            },
            {
              "language": "ru",
              "text": "Сюжет фильма простой, но очень захватывающий."
            },
            {
              "language": "sq",
              "text": "Ngjarja e filmit është e thjeshtë, por shumë tërheqëse."
            },
            {
              "language": "tr",
              "text": "Filmin olay örgüsü basit ama çok heyecanlı."
            }
          ]
        },
        {
          "baseText": "Jede Handlung im System wird mit Uhrzeit und Benutzername gespeichert.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم حفظ كل إجراء في النظام مع الوقت واسم المستخدم."
            },
            {
              "language": "ckb",
              "text": "هەر کردارێک لە سیستەمەکەدا لەگەڵ کات و ناوی بەکارهێنەر پاشەکەوت دەکرێت."
            },
            {
              "language": "en",
              "text": "Every action in the system is saved with the time and username."
            },
            {
              "language": "fa",
              "text": "هر اقدام در سیستم با زمان و نام کاربری ذخیره می‌شود."
            },
            {
              "language": "kmr",
              "text": "Her kiryar di pergalê de bi dem û navê bikarhêner tê tomarkirin."
            },
            {
              "language": "pl",
              "text": "Każde działanie w systemie jest zapisywane z godziną i nazwą użytkownika."
            },
            {
              "language": "ro",
              "text": "Fiecare acțiune din sistem este salvată cu ora și numele utilizatorului."
            },
            {
              "language": "ru",
              "text": "Каждое действие в системе сохраняется со временем и именем пользователя."
            },
            {
              "language": "sq",
              "text": "Çdo veprim në sistem ruhet me orën dhe emrin e përdoruesit."
            },
            {
              "language": "tr",
              "text": "Sistemdeki her işlem saat ve kullanıcı adıyla kaydedilir."
            }
          ]
        }
      ]
    },
