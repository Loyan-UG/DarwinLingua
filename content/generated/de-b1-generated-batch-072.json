  "entries": [
    {
      "word": "handeln von",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Phrase",
      "article": null,
      "plural": null,
      "infinitive": "handeln von",
      "pronunciationIpa": null,
      "syllableBreak": "han-deln von",
      "topics": [
        "culture-and-media",
        "business-communication",
        "education-and-training"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb phrase with von plus dative; used to say what a text, film, meeting, or topic is about"
      ],
      "collocations": [
        {
          "text": "der Film handelt von ...",
          "meaning": "the film is about ..."
        },
        {
          "text": "der Bericht handelt von ...",
          "meaning": "the report deals with ..."
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Handlung",
          "relationLabel": "related noun",
          "note": null
        },
        {
          "lemma": "behandeln",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتناول؛ يدور حول"
        },
        {
          "language": "ckb",
          "text": "باسکردن لە؛ دەربارەی بوون"
        },
        {
          "language": "en",
          "text": "to be about; to deal with"
        },
        {
          "language": "fa",
          "text": "درباره چیزی بودن؛ به چیزی پرداختن"
        },
        {
          "language": "kmr",
          "text": "li ser tiştekê bûn; behsa tiştekê kirin"
        },
        {
          "language": "pl",
          "text": "być o czymś; dotyczyć"
        },
        {
          "language": "ro",
          "text": "a fi despre; a trata despre"
        },
        {
          "language": "ru",
          "text": "быть о; касаться"
        },
        {
          "language": "sq",
          "text": "të jetë për; të trajtojë"
        },
        {
          "language": "tr",
          "text": "hakkında olmak; ele almak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bericht handelt von den häufigsten Problemen im Kundenservice.",
          "translations": [
            {
              "language": "ar",
              "text": "يتناول التقرير أكثر المشكلات شيوعاً في خدمة العملاء."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتەکە باس لە باوترین کێشەکان لە خزمەتگوزاری کڕیاردا دەکات."
            },
            {
              "language": "en",
              "text": "The report is about the most common problems in customer service."
            },
            {
              "language": "fa",
              "text": "این گزارش درباره رایج‌ترین مشکلات در خدمات مشتری است."
            },
            {
              "language": "kmr",
              "text": "Rapor li ser pirsgirêkên herî gelemperî di xizmeta xerîdar de ye."
            },
            {
              "language": "pl",
              "text": "Raport dotyczy najczęstszych problemów w obsłudze klienta."
            },
            {
              "language": "ro",
              "text": "Raportul este despre cele mai frecvente probleme din serviciul clienți."
            },
            {
              "language": "ru",
              "text": "Отчёт касается самых частых проблем в обслуживании клиентов."
            },
            {
              "language": "sq",
              "text": "Raporti është për problemet më të zakonshme në shërbimin ndaj klientit."
            },
            {
              "language": "tr",
              "text": "Rapor, müşteri hizmetlerindeki en yaygın sorunlar hakkındadır."
            }
          ]
        },
        {
          "baseText": "Das Buch handelt von einer Familie, die in eine neue Stadt zieht.",
          "translations": [
            {
              "language": "ar",
              "text": "يدور الكتاب حول عائلة تنتقل إلى مدينة جديدة."
            },
            {
              "language": "ckb",
              "text": "کتێبەکە باس لە خێزانێک دەکات کە دەچێتە شارێکی نوێ."
            },
            {
              "language": "en",
              "text": "The book is about a family that moves to a new city."
            },
            {
              "language": "fa",
              "text": "کتاب درباره خانواده‌ای است که به شهری جدید نقل مکان می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pirtûk li ser malbatekê ye ku koçî bajarekî nû dike."
            },
            {
              "language": "pl",
              "text": "Książka opowiada o rodzinie, która przeprowadza się do nowego miasta."
            },
            {
              "language": "ro",
              "text": "Cartea este despre o familie care se mută într-un oraș nou."
            },
            {
              "language": "ru",
              "text": "Книга о семье, которая переезжает в новый город."
            },
            {
              "language": "sq",
              "text": "Libri është për një familje që zhvendoset në një qytet të ri."
            },
            {
              "language": "tr",
              "text": "Kitap, yeni bir şehre taşınan bir aile hakkındadır."
            }
          ]
        }
      ]
    },
