  "entries": [
    {
      "word": "erlöschen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "erlöschen",
      "pronunciationIpa": null,
      "syllableBreak": "er-lö-schen",
      "topics": [
        "law-and-compliance",
        "contracts-and-negotiation",
        "production-and-maintenance"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: erlischt, erlosch, ist erloschen; used for rights, claims, lights, fire, or validity"
      ],
      "collocations": [
        {
          "text": "ein Anspruch erlischt",
          "meaning": "a claim expires"
        },
        {
          "text": "die Garantie erlischt",
          "meaning": "the warranty expires"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Erlöschen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينتهي؛ ينقضي؛ ينطفئ"
        },
        {
          "language": "ckb",
          "text": "کۆتایی دێت؛ بەسەر دەچێت؛ دەکوژێتەوە"
        },
        {
          "language": "en",
          "text": "to expire; to lapse; to go out"
        },
        {
          "language": "fa",
          "text": "منقضی شدن؛ از بین رفتن؛ خاموش شدن"
        },
        {
          "language": "kmr",
          "text": "qediya; betal bûn; vemirîn"
        },
        {
          "language": "pl",
          "text": "wygasnąć; ustać; zgasnąć"
        },
        {
          "language": "ro",
          "text": "a expira; a înceta; a se stinge"
        },
        {
          "language": "ru",
          "text": "истекать; прекращаться; гаснуть"
        },
        {
          "language": "sq",
          "text": "të skadojë; të shuhet; të pushojë së vlejturi"
        },
        {
          "language": "tr",
          "text": "sona ermek; geçerliliğini yitirmek; sönmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Anspruch erlischt, wenn die Frist ohne Antrag verstreicht.",
          "translations": [
            {
              "language": "ar",
              "text": "ينقضي الحق إذا انتهت المهلة من دون تقديم طلب."
            },
            {
              "language": "ckb",
              "text": "مافەکە کۆتایی دێت ئەگەر ماوەکە بەبێ داواکاری تێپەڕێت."
            },
            {
              "language": "en",
              "text": "The claim expires if the deadline passes without an application."
            },
            {
              "language": "fa",
              "text": "اگر مهلت بدون درخواست سپری شود، حق مطالبه منقضی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Maf diqede heke dem bê daxwaz derbas bibe."
            },
            {
              "language": "pl",
              "text": "Roszczenie wygasa, jeśli termin minie bez złożenia wniosku."
            },
            {
              "language": "ro",
              "text": "Dreptul expiră dacă termenul trece fără depunerea unei cereri."
            },
            {
              "language": "ru",
              "text": "Требование прекращается, если срок проходит без подачи заявления."
            },
            {
              "language": "sq",
              "text": "E drejta skadon nëse afati kalon pa kërkesë."
            },
            {
              "language": "tr",
              "text": "Süre başvuru olmadan geçerse hak sona erer."
            }
          ]
        },
        {
          "baseText": "Nach dem Stromausfall erlosch die Kontrollleuchte an der Maschine.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد انقطاع الكهرباء انطفأ مصباح التحكم في الآلة."
            },
            {
              "language": "ckb",
              "text": "دوای پچڕانی کارەبا، چرای چاودێریی ئامێرەکە کوژایەوە."
            },
            {
              "language": "en",
              "text": "After the power outage, the indicator light on the machine went out."
            },
            {
              "language": "fa",
              "text": "پس از قطع برق، چراغ کنترل دستگاه خاموش شد."
            },
            {
              "language": "kmr",
              "text": "Piştî qutbûna elektrîkê, çiraya kontrolê ya makîneyê vemirî."
            },
            {
              "language": "pl",
              "text": "Po awarii zasilania zgasła lampka kontrolna maszyny."
            },
            {
              "language": "ro",
              "text": "După pana de curent, lampa de control a mașinii s-a stins."
            },
            {
              "language": "ru",
              "text": "После отключения электричества контрольная лампа на машине погасла."
            },
            {
              "language": "sq",
              "text": "Pas ndërprerjes së rrymës, drita treguese në makineri u fik."
            },
            {
              "language": "tr",
              "text": "Elektrik kesintisinden sonra makinedeki kontrol lambası söndü."
            }
          ]
        }
      ]
    },
    {
      "word": "ermessen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ermessen",
      "pronunciationIpa": null,
      "syllableBreak": "er-mes-sen",
      "topics": [
        "law-and-compliance",
        "advanced-analysis",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: ermisst, ermaß, hat ermessen; also noun das Ermessen means discretion"
      ],
      "collocations": [
        {
          "text": "die Tragweite ermessen",
          "meaning": "to gauge the implications"
        },
        {
          "text": "nach Ermessen entscheiden",
          "meaning": "to decide at one’s discretion"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Ermessen",
          "relationLabel": "noun",
          "note": "discretion or judgment"
        },
        {
          "lemma": "ermessensgerecht",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقدّر؛ يقيس مدى؛ يقيّم"
        },
        {
          "language": "ckb",
          "text": "هەڵدەسەنگێنێت؛ قەبارە یان گرنگی دەزانێت"
        },
        {
          "language": "en",
          "text": "to assess; to gauge; to estimate the scope"
        },
        {
          "language": "fa",
          "text": "سنجیدن؛ برآورد کردن؛ میزان اهمیت را تشخیص دادن"
        },
        {
          "language": "kmr",
          "text": "nirxandin; pîvan; qebareyê texmîn kirin"
        },
        {
          "language": "pl",
          "text": "ocenić; oszacować; zmierzyć znaczenie"
        },
        {
          "language": "ro",
          "text": "a evalua; a estima; a aprecia amploarea"
        },
        {
          "language": "ru",
          "text": "оценивать; измерять; осознавать масштаб"
        },
        {
          "language": "sq",
          "text": "të vlerësosh; të matësh; të kuptosh shtrirjen"
        },
        {
          "language": "tr",
          "text": "değerlendirmek; ölçmek; kapsamını kestirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Folgen der Entscheidung lassen sich erst nach einigen Monaten zuverlässig ermessen.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يمكن تقدير عواقب القرار بشكل موثوق إلا بعد بضعة أشهر."
            },
            {
              "language": "ckb",
              "text": "ئەنجامەکانی بڕیارەکە تەنها دوای چەند مانگێک بە متمانەوە هەڵدەسەنگێندرێن."
            },
            {
              "language": "en",
              "text": "The consequences of the decision can only be reliably assessed after a few months."
            },
            {
              "language": "fa",
              "text": "پیامدهای تصمیم را فقط پس از چند ماه می‌توان قابل اعتماد سنجید."
            },
            {
              "language": "kmr",
              "text": "Encamên biryarê tenê piştî çend mehan bi bawerî dikarin bên nirxandin."
            },
            {
              "language": "pl",
              "text": "Skutki decyzji można wiarygodnie ocenić dopiero po kilku miesiącach."
            },
            {
              "language": "ro",
              "text": "Consecințele deciziei pot fi evaluate fiabil abia după câteva luni."
            },
            {
              "language": "ru",
              "text": "Последствия решения можно надежно оценить только через несколько месяцев."
            },
            {
              "language": "sq",
              "text": "Pasojat e vendimit mund të vlerësohen besueshëm vetëm pas disa muajsh."
            },
            {
              "language": "tr",
              "text": "Kararın sonuçları ancak birkaç ay sonra güvenilir biçimde değerlendirilebilir."
            }
          ]
        },
        {
          "baseText": "Die Sachbearbeiterin muss ermessen, ob die vorgelegten Nachweise ausreichen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على الموظفة المختصة أن تقيّم ما إذا كانت المستندات المقدمة كافية."
            },
            {
              "language": "ckb",
              "text": "کارمەندی بەرپرسیار دەبێت هەڵبسەنگێنێت ئایا بەڵگەنامە پێشکەشکراوەکان بەسن یان نا."
            },
            {
              "language": "en",
              "text": "The case worker must assess whether the submitted documents are sufficient."
            },
            {
              "language": "fa",
              "text": "کارشناس پرونده باید تشخیص دهد آیا مدارک ارائه‌شده کافی هستند یا نه."
            },
            {
              "language": "kmr",
              "text": "Karmenda dozê divê binirxîne ka belgeyên pêşkêşkirî bes in an na."
            },
            {
              "language": "pl",
              "text": "Pracowniczka musi ocenić, czy przedstawione dokumenty są wystarczające."
            },
            {
              "language": "ro",
              "text": "Funcționara trebuie să aprecieze dacă dovezile prezentate sunt suficiente."
            },
            {
              "language": "ru",
              "text": "Сотрудница должна оценить, достаточно ли представленных документов."
            },
            {
              "language": "sq",
              "text": "Punonjësja duhet të vlerësojë nëse dokumentet e paraqitura janë të mjaftueshme."
            },
            {
              "language": "tr",
              "text": "Dosya sorumlusu sunulan belgelerin yeterli olup olmadığını değerlendirmelidir."
            }
          ]
        }
      ]
    },
    {
