  "entries": [
    {
      "word": "nachlesen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "nachlesen",
      "pronunciationIpa": null,
      "syllableBreak": "nach-le-sen",
      "topics": [
        "education-and-training",
        "documents-and-administration",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "workplace",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: liest nach, las nach, nachgelesen"
      ],
      "collocations": [
        {
          "text": "im Handbuch nachlesen",
          "meaning": "to look it up in the manual"
        },
        {
          "text": "die Regeln nachlesen",
          "meaning": "to read up on the rules"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "lesen",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "das Nachlesen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يراجع قراءة؛ يبحث في النص"
        },
        {
          "language": "ckb",
          "text": "لە نووسراوێکدا دەگەڕێت؛ دووبارە دەخوێنێتەوە"
        },
        {
          "language": "en",
          "text": "to look up; to read up on"
        },
        {
          "language": "fa",
          "text": "مراجعه کردن و خواندن؛ جست‌وجو در متن"
        },
        {
          "language": "kmr",
          "text": "li nivîsê gerîn; ji nû ve xwendin"
        },
        {
          "language": "pl",
          "text": "sprawdzić w tekście; doczytać"
        },
        {
          "language": "ro",
          "text": "a consulta; a citi pentru verificare"
        },
        {
          "language": "ru",
          "text": "посмотреть в тексте; перечитать для уточнения"
        },
        {
          "language": "sq",
          "text": "të kërkosh në tekst; të lexosh për sqarim"
        },
        {
          "language": "tr",
          "text": "metinden bakmak; okuyup kontrol etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Du kannst die Anleitung im Handbuch nachlesen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنك مراجعة التعليمات في الدليل."
            },
            {
              "language": "ckb",
              "text": "دەتوانیت ڕێنماییەکە لە دەستنامەکەدا بخوێنیتەوە."
            },
            {
              "language": "en",
              "text": "You can look up the instructions in the manual."
            },
            {
              "language": "fa",
              "text": "می‌توانی دستورالعمل را در دفترچه راهنما بخوانی."
            },
            {
              "language": "kmr",
              "text": "Tu dikarî rêbernameyê di destnameyê de bibînî û bixwînî."
            },
            {
              "language": "pl",
              "text": "Możesz sprawdzić instrukcję w podręczniku."
            },
            {
              "language": "ro",
              "text": "Poți consulta instrucțiunile în manual."
            },
            {
              "language": "ru",
              "text": "Ты можешь посмотреть инструкцию в руководстве."
            },
            {
              "language": "sq",
              "text": "Mund t’i shohësh udhëzimet në manual."
            },
            {
              "language": "tr",
              "text": "Talimatları kılavuzdan okuyup kontrol edebilirsin."
            }
          ]
        },
        {
          "baseText": "Ich lese die Regel noch einmal nach, bevor ich dem Kunden antworte.",
          "translations": [
            {
              "language": "ar",
              "text": "أراجع القاعدة مرة أخرى قبل أن أرد على العميل."
            },
            {
              "language": "ckb",
              "text": "پێش ئەوەی وەڵامی کڕیارەکە بدەمەوە، یاساکە جارێکی تر دەخوێنمەوە."
            },
            {
              "language": "en",
              "text": "I will look up the rule once more before I answer the customer."
            },
            {
              "language": "fa",
              "text": "قبل از پاسخ دادن به مشتری، قانون را یک بار دیگر بررسی می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Berî ku ez bersiva mişterî bidim, ez qaîdeyê careke din dixwînim."
            },
            {
              "language": "pl",
              "text": "Sprawdzę tę zasadę jeszcze raz, zanim odpowiem klientowi."
            },
            {
              "language": "ro",
              "text": "Mai verific o dată regula înainte să îi răspund clientului."
            },
            {
              "language": "ru",
              "text": "Я ещё раз посмотрю правило, прежде чем ответить клиенту."
            },
            {
              "language": "sq",
              "text": "Do ta kontrolloj edhe një herë rregullin para se t’i përgjigjem klientit."
            },
            {
              "language": "tr",
              "text": "Müşteriye cevap vermeden önce kuralı bir kez daha kontrol edeceğim."
            }
          ]
        }
      ]
    },
    {
      "word": "der Nachmieter",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Nachmieter",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Nach-mie-ter",
      "topics": [
        "housing-and-real-estate",
        "contracts-and-negotiation",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; female form: die Nachmieterin"
      ],
      "collocations": [
        {
          "text": "einen Nachmieter suchen",
          "meaning": "to look for a new tenant to take over"
        },
        {
          "text": "einen Nachmieter vorschlagen",
          "meaning": "to propose a replacement tenant"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Miete",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "mieten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مستأجر بديل؛ مستأجر لاحق"
        },
        {
          "language": "ckb",
          "text": "کرێچی جێگرەوە؛ کرێچی دواتر"
        },
        {
          "language": "en",
          "text": "replacement tenant; next tenant"
        },
        {
          "language": "fa",
          "text": "مستأجر جایگزین؛ مستأجر بعدی"
        },
        {
          "language": "kmr",
          "text": "kirêdarê cihgir; kirêdarê piştî"
        },
        {
          "language": "pl",
          "text": "następny najemca; zastępczy najemca"
        },
        {
          "language": "ro",
          "text": "chiriaș înlocuitor; următorul chiriaș"
        },
        {
          "language": "ru",
          "text": "новый арендатор; замещающий арендатор"
        },
        {
          "language": "sq",
          "text": "qiramarrës zëvendësues; qiramarrësi pasues"
        },
        {
          "language": "tr",
          "text": "yerine geçecek kiracı; sonraki kiracı"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn wir früher ausziehen wollen, müssen wir einen Nachmieter suchen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا أردنا الخروج مبكرًا، فعلينا البحث عن مستأجر بديل."
            },
            {
              "language": "ckb",
              "text": "ئەگەر بمانەوێت زووتر بچینە دەرەوە، دەبێت کرێچی جێگرەوە بدۆزینەوە."
            },
            {
              "language": "en",
              "text": "If we want to move out earlier, we have to look for a replacement tenant."
            },
            {
              "language": "fa",
              "text": "اگر بخواهیم زودتر تخلیه کنیم، باید مستأجر جایگزین پیدا کنیم."
            },
            {
              "language": "kmr",
              "text": "Heke em bixwazin zûtir derkevin, divê em kirêdarekî cihgir bibînin."
            },
            {
              "language": "pl",
              "text": "Jeśli chcemy wyprowadzić się wcześniej, musimy znaleźć następnego najemcę."
            },
            {
              "language": "ro",
              "text": "Dacă vrem să ne mutăm mai devreme, trebuie să căutăm un chiriaș înlocuitor."
            },
            {
              "language": "ru",
              "text": "Если мы хотим съехать раньше, нам нужно найти нового арендатора."
            },
            {
              "language": "sq",
              "text": "Nëse duam të largohemi më herët, duhet të gjejmë një qiramarrës zëvendësues."
            },
            {
              "language": "tr",
              "text": "Daha erken taşınmak istiyorsak yerine geçecek bir kiracı bulmalıyız."
            }
          ]
        },
        {
          "baseText": "Der Vermieter möchte den Nachmieter vor der Entscheidung persönlich kennenlernen.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد المؤجّر التعرف شخصيًا على المستأجر البديل قبل القرار."
            },
            {
              "language": "ckb",
              "text": "خاوەن ماڵەکە دەیەوێت پێش بڕیارەکە کرێچی جێگرەوە بە شەخسی بناسێت."
            },
            {
              "language": "en",
              "text": "The landlord wants to meet the replacement tenant in person before making a decision."
            },
            {
              "language": "fa",
              "text": "صاحب‌خانه می‌خواهد قبل از تصمیم، مستأجر جایگزین را شخصاً ببیند."
            },
            {
              "language": "kmr",
              "text": "Xwediyê malê dixwaze berî biryarê kirêdarê cihgir bi xwe nas bike."
            },
            {
              "language": "pl",
              "text": "Właściciel chce osobiście poznać następnego najemcę przed decyzją."
            },
            {
              "language": "ro",
              "text": "Proprietarul vrea să îl cunoască personal pe chiriașul înlocuitor înainte de decizie."
            },
            {
              "language": "ru",
