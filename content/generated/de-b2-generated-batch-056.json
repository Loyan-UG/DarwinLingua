  "entries": [
    {
      "word": "automatisieren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "automatisieren",
      "pronunciationIpa": null,
      "syllableBreak": "au-to-mi-sie-ren",
      "topics": [
        "technology-and-it",
        "work-and-jobs",
        "planning-and-projects"
      ],
      "usageLabels": [
        "workplace",
        "technical",
        "business"
      ],
      "contextLabels": ["it", "software"],
      "meanings": [
        {
          "text": "أتمتة",
          "language": "ar"
        },
        {
          "text": "خودکارسازی",
          "language": "ckb"
        },
        {
          "text": "to automate",
          "language": "en"
        },
        {
          "text": "خودکارسازی",
          "language": "fa"
        },
        {
          "text": "xweberpêkirin",
          "language": "kmr"
        },
        {
          "text": "automatyzować",
          "language": "pl"
        },
        {
          "text": "a automatiza",
          "language": "ro"
        },
        {
          "text": "автоматизировать",
          "language": "ru"
        },
        {
          "text": "automatizon",
          "language": "sq"
        },
        {
          "text": "otomatikleştirmek",
          "language": "tr"
        }
      ],
      "examples": [
        {
          "baseText": "Wir automatisieren den Testablauf im CI/CD-Workflow, damit manuelle Schritte weniger Fehler verursachen.",
          "translations": [
            {
              "text": "نحن نؤتمت سير العمل في خط CI/CD بحيث يقل عدد الأخطاء الناتجة عن الخطوات اليدوية.",
              "language": "ar"
            },
            {
              "text": "پڕۆسەی تاقیکردنەوە لە کارگەی CI/CD خۆکار دەکەین تا هەڵەکانی هەنگاوە دەستەواژیەکان کەمتر بن.",
              "language": "ckb"
            },
            {
              "text": "We automate the CI/CD test flow so fewer errors are caused by manual steps.",
              "language": "en"
            },
            {
              "text": "جریان تست CI/CD را خودکار می‌کنیم تا خطاهای ناشی از کارهای دستی کمتر شوند.",
              "language": "fa"
            },
            {
              "text": "Em pêvajoya ceribandinê ya CI/CD-ê otomate dikin da ku zevqî hilanîna destê kêm bêt.",
              "language": "kmr"
            },
            {
              "text": "Automatyzujemy przepływ testów CI/CD, aby ręczne kroki powodowały mniej błędów.",
              "language": "pl"
            },
            {
              "text": "Automatizăm fluxul de testare CI/CD pentru ca pașii manuali să provoace mai puține erori.",
              "language": "ro"
            },
            {
              "text": "Мы автоматизируем поток тестирования CI/CD, чтобы ручные шаги вызывали меньше ошибок.",
              "language": "ru"
            },
            {
              "text": "Ne automatizojmë rrjedhën e testimit CI/CD, në mënyrë që hapat manualë të shkaktojnë më pak gabime.",
              "language": "sq"
            },
            {
              "text": "CI/CD test akışını otomatikleştiriyoruz; böylece manuel adımlar daha az hata üretir.",
              "language": "tr"
            }
          ]
        },
        {
          "baseText": "Die Personalabteilung automatisiert die Urlaubsanträge, damit das Team sich auf Beratung konzentrieren kann.",
          "translations": [
            {
              "text": "قسم الموارد البشرية يقوم بأتمتة طلبات الإجازات حتى يركز الفريق على الاستشارات.",
              "language": "ar"
            },
            {
              "text": "بڕۆینەکەی سەرچاوەی مرۆڤ داواکاریەکانی ئیجازە خۆکار دەکات بۆ ئەوەی تیمەکە بتوانێت سەبارەت بە ئاستکاریکردن توانا بێت.",
              "language": "ckb"
            },
            {
              "text": "The HR department automates leave requests so the team can focus on support and consultation.",
              "language": "en"
            },
            {
              "text": "بخش منابع انسانی درخواست‌های مرخصی را خودکار می‌کند تا تیم روی پشتیبانی و مشاوره تمرکز کند.",
              "language": "fa"
            },
            {
              "text": "Beşa HR daxistina mêndalî yên hênik otomate dike da ku tîm bikarî be li ser alîkarî û şopandina çêbikin.",
              "language": "kmr"
            },
            {
              "text": "Dział HR automatyzuje wnioski urlopowe, aby zespół mógł się skupić na obsłudze i doradztwie.",
              "language": "pl"
            },
            {
              "text": "Departamentul HR automatizează cererile de concediu, astfel încât echipa să se concentreze pe consultanță.",
              "language": "ro"
            },
            {
              "text": "Отдел кадров автоматизирует заявки на отпуск, чтобы команда могла сосредоточиться на поддержке и консультациях.",
              "language": "ru"
            },
            {
              "text": "Departamenti i burimeve njerëzore automatizon kërkesat e pushimit, në mënyrë që ekipi të fokusohet në mbështetje dhe këshillim.",
              "language": "sq"
            },
            {
              "text": "İK departmanı izin taleplerini otomatikleştiriyor, böylece ekip danışmanlık işine odaklanabiliyor.",
              "language": "tr"
            }
          ]
        }
      ]
    },
    {
      "word": "die Automatisierung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "die Automatisierungen",
      "infinitive": null,
