      "contextLabels": [
        "it",
        "software"
      ],
      "meanings": [
        {
          "text": "أتمتة؛ رقمنة عمليات",
          "language": "ar"
        },
        {
          "text": "خودکارسازی؛ خۆکارکردن",
          "language": "ckb"
        },
        {
          "text": "automation",
          "language": "en"
        },
        {
          "text": "خودکارسازی؛ اتوماسیون",
          "language": "fa"
        },
        {
          "text": "xweberpêkirin; otomasyon",
          "language": "kmr"
        },
        {
          "text": "automatyzacja",
          "language": "pl"
        },
        {
          "text": "automatizare",
          "language": "ro"
        },
        {
          "text": "автоматизация",
          "language": "ru"
        },
        {
          "text": "automatizim",
          "language": "sq"
        },
        {
          "text": "otomasyon",
          "language": "tr"
        }
      ],
      "examples": [
        {
          "baseText": "Die vollständige Automatisierung der Deployment-Pipeline hat Ausfälle bei Releases deutlich reduziert.",
          "translations": [
            {
              "text": "أدت الأتمتة الكاملة لمسار النشر إلى تقليل الأعطال خلال الإصدارات بشكل واضح.",
              "language": "ar"
            },
            {
              "text": "خۆکاری تەواوی پەیپلاینەی داپڵۆدکردن ڕووداوەی کێشەکانی بەتاڵی بەردەستە.",
              "language": "ckb"
            },
            {
              "text": "Complete automation of the deployment pipeline has clearly reduced outages during releases.",
              "language": "en"
            },
            {
              "text": "خودکارسازی کامل خط استقرار، خرابی‌های هنگام انتشار را به‌طور قابل توجهی کاهش داده است.",
              "language": "fa"
            },
            {
              "text": "Otomasyona tevahî a pipeline ya deploymentê kêmkirina pirtûkek li doza berdanê zêde kir.",
              "language": "kmr"
            },
            {
              "text": "Pełna automatyzacja pipeline’u wdrożeniowego wyraźnie zmniejszyła awarie podczas wydań.",
              "language": "pl"
            },
            {
              "text": "Automatizarea completă a pipeline-ului de deployment a redus vizibil întreruperile în timpul lansărilor.",
              "language": "ro"
            },
            {
              "text": "Полная автоматизация пайплайна развертывания явно сократила простои при релизах.",
              "language": "ru"
            },
            {
              "text": "Automatizimi i plotë i pipeline-it të deploymentit ka ulur dukshëm ndërprerjet gjatë botimeve.",
              "language": "sq"
            },
            {
              "text": "Dağıtım hattının tam otomasyonu sürümdeki kesintileri belirgin biçimde azalttı.",
              "language": "tr"
            }
          ]
        },
        {
          "baseText": "Die Automatisierung der Rechnungsprüfung hat die Durchlaufzeit im Finanzteam um 30 Prozent verringert.",
          "translations": [
            {
              "text": "أدى أتمتة تدقيق الفواتير إلى تقليل زمن المعالجة في فريق المالية بنسبة 30 بالمئة.",
              "language": "ar"
            },
            {
              "text": "خۆکاری کردنەوەی پشکنینی پسوڵەکان کاتی چارەسەرکردن لە تیمی دارایی 30 لە سەد کەم کرد.",
              "language": "ckb"
            },
            {
              "text": "Automating invoice checks reduced processing time in the finance team by 30 percent.",
              "language": "en"
            },
            {
              "text": "خودکارسازی بررسی فاکتورها زمان پردازش در تیم مالی را 30 درصد کاهش داد.",
              "language": "fa"
            },
            {
              "text": "Otomasyona kirina kontrola fatura demê pêvajoya tîmê aborî bi 30% kêm kir.",
              "language": "kmr"
            },
            {
              "text": "Automatyzacja weryfikacji faktur skróciła czas realizacji w zespole finansowym o 30 procent.",
              "language": "pl"
            },
