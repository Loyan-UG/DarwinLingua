        {
          "language": "ar",
          "text": "الفيلم المفضل"
        },
        {
          "language": "ckb",
          "text": "فیلمی دڵخواز"
        },
        {
          "language": "en",
          "text": "favorite film; favorite movie"
        },
        {
          "language": "fa",
          "text": "فیلم مورد علاقه"
        },
        {
          "language": "kmr",
          "text": "fîlmê herî hezkirî"
        },
        {
          "language": "pl",
          "text": "ulubiony film"
        },
        {
          "language": "ro",
          "text": "film preferat"
        },
        {
          "language": "ru",
          "text": "любимый фильм"
        },
        {
          "language": "sq",
          "text": "filmi i preferuar"
        },
        {
          "language": "tr",
          "text": "en sevilen film"
        }
      ],
      "examples": [
        {
          "baseText": "Mein Lieblingsfilm läuft heute Abend im Fernsehen.",
          "translations": [
            {
              "language": "ar",
              "text": "فيلمي المفضل يُعرض هذا المساء على التلفاز."
            },
            {
              "language": "ckb",
              "text": "فیلمی دڵخوازم ئەم ئێوارەیە لە تەلەفزیۆن دەدرێت."
            },
            {
              "language": "en",
              "text": "My favorite film is on TV this evening."
            },
            {
              "language": "fa",
              "text": "فیلم مورد علاقه‌ام امشب از تلویزیون پخش می‌شود."
            },
            {
              "language": "kmr",
              "text": "Fîlmê min ê herî hezkirî îvarê li televîzyonê ye."
            },
            {
              "language": "pl",
              "text": "Mój ulubiony film leci dziś wieczorem w telewizji."
            },
            {
              "language": "ro",
              "text": "Filmul meu preferat este la televizor în seara aceasta."
            },
            {
              "language": "ru",
              "text": "Мой любимый фильм сегодня вечером по телевизору."
            },
            {
              "language": "sq",
              "text": "Filmi im i preferuar jepet sonte në televizor."
            },
            {
              "language": "tr",
              "text": "En sevdiğim film bu akşam televizyonda."
            }
          ]
        },
        {
          "baseText": "Was ist dein Lieblingsfilm?",
          "translations": [
            {
              "language": "ar",
              "text": "ما فيلمك المفضل؟"
            },
            {
              "language": "ckb",
              "text": "فیلمی دڵخوازت چییە؟"
            },
            {
              "language": "en",
              "text": "What is your favorite film?"
            },
            {
              "language": "fa",
              "text": "فیلم مورد علاقه‌ات چیست؟"
            },
            {
              "language": "kmr",
              "text": "Fîlmê te yê herî hezkirî çi ye?"
            },
            {
              "language": "pl",
              "text": "Jaki jest twój ulubiony film?"
            },
            {
              "language": "ro",
              "text": "Care este filmul tău preferat?"
            },
            {
              "language": "ru",
              "text": "Какой твой любимый фильм?"
            },
            {
              "language": "sq",
              "text": "Cili është filmi yt i preferuar?"
            },
            {
              "language": "tr",
              "text": "En sevdiğin film hangisi?"
            }
          ]
        }
      ]
    },
