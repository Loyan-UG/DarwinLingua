        {
          "language": "tr",
          "text": "en sevilen müzik"
        }
      ],
      "examples": [
        {
          "baseText": "Beim Kochen höre ich meine Lieblingsmusik.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء الطبخ أستمع إلى موسيقاي المفضلة."
            },
            {
              "language": "ckb",
              "text": "لە کاتی چێشتلێناندا گوێ لە مۆسیقای دڵخوازم دەگرم."
            },
            {
              "language": "en",
              "text": "When cooking, I listen to my favorite music."
            },
            {
              "language": "fa",
              "text": "هنگام آشپزی به موسیقی مورد علاقه‌ام گوش می‌دهم."
            },
            {
              "language": "kmr",
              "text": "Dema xwarinê çêdikim ez guh didim muzîka xwe ya herî hezkirî."
            },
            {
              "language": "pl",
              "text": "Podczas gotowania słucham ulubionej muzyki."
            },
            {
              "language": "ro",
              "text": "Când gătesc, ascult muzica mea preferată."
            },
            {
              "language": "ru",
              "text": "Когда готовлю, я слушаю любимую музыку."
            },
            {
              "language": "sq",
              "text": "Kur gatuaj, dëgjoj muzikën time të preferuar."
            },
            {
              "language": "tr",
              "text": "Yemek yaparken en sevdiğim müziği dinlerim."
            }
          ]
        },
        {
          "baseText": "Ihre Lieblingsmusik ist sehr ruhig.",
          "translations": [
            {
              "language": "ar",
              "text": "موسيقاها المفضلة هادئة جداً."
            },
            {
              "language": "ckb",
              "text": "مۆسیقای دڵخوازی ئەو زۆر ئارامە."
            },
            {
              "language": "en",
              "text": "Her favorite music is very calm."
            },
            {
              "language": "fa",
              "text": "موسیقی مورد علاقه او خیلی آرام است."
            },
            {
              "language": "kmr",
              "text": "Muzîka wê ya herî hezkirî gelek aram e."
            },
            {
              "language": "pl",
              "text": "Jej ulubiona muzyka jest bardzo spokojna."
            },
            {
              "language": "ro",
              "text": "Muzica ei preferată este foarte liniștită."
            },
            {
              "language": "ru",
              "text": "Её любимая музыка очень спокойная."
            },
            {
              "language": "sq",
              "text": "Muzika e saj e preferuar është shumë e qetë."
            },
            {
              "language": "tr",
              "text": "Onun en sevdiği müzik çok sakin."
            }
          ]
        }
      ]
    },
