  "entries": [
    {
      "word": "herausfinden",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "herausfinden",
      "pronunciationIpa": null,
      "syllableBreak": "he-raus-fin-den",
      "topics": [
        "work-and-jobs",
        "technology-and-it",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "business",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; past participle: herausgefunden"
      ],
      "collocations": [
        {
          "text": "den Grund herausfinden",
          "meaning": "to find out the reason"
        },
        {
          "text": "herausfinden, warum ...",
          "meaning": "to find out why ..."
        }
      ],
      "wordFamilies": [
        {
          "lemma": "finden",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يكتشف؛ يعرف"
        },
        {
          "language": "ckb",
          "text": "دۆزینەوە؛ زانین"
        },
        {
          "language": "en",
          "text": "to find out; to discover"
        },
        {
          "language": "fa",
          "text": "فهمیدن؛ کشف کردن"
        },
        {
          "language": "kmr",
          "text": "fêr bûn; dîtin"
        },
        {
          "language": "pl",
          "text": "dowiedzieć się; odkryć"
        },
        {
          "language": "ro",
          "text": "a afla; a descoperi"
        },
        {
          "language": "ru",
          "text": "выяснять; узнавать"
        },
        {
          "language": "sq",
          "text": "të zbulosh; të kuptosh"
        },
        {
          "language": "tr",
          "text": "öğrenmek; ortaya çıkarmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir müssen herausfinden, warum die Anmeldung im Portal nicht funktioniert.",
          "translations": [
            {
              "language": "ar",
              "text": "علينا أن نكتشف لماذا لا يعمل تسجيل الدخول في البوابة."
            },
            {
              "language": "ckb",
              "text": "دەبێت بدۆزینەوە بۆچی چوونەژوورەوە لە پۆرتاڵەکە کار ناکات."
            },
            {
              "language": "en",
              "text": "We need to find out why login in the portal is not working."
            },
            {
              "language": "fa",
              "text": "باید بفهمیم چرا ورود به پورتال کار نمی‌کند."
            },
            {
              "language": "kmr",
              "text": "Divê em fêr bibin ka çima têketina portalê naxebite."
            },
            {
              "language": "pl",
              "text": "Musimy dowiedzieć się, dlaczego logowanie w portalu nie działa."
            },
            {
              "language": "ro",
              "text": "Trebuie să aflăm de ce autentificarea în portal nu funcționează."
            },
            {
              "language": "ru",
              "text": "Нам нужно выяснить, почему вход на портал не работает."
            },
            {
              "language": "sq",
              "text": "Duhet të zbulojmë pse hyrja në portal nuk funksionon."
            },
            {
              "language": "tr",
              "text": "Portaldaki girişin neden çalışmadığını öğrenmemiz gerekiyor."
            }
          ]
        },
        {
          "baseText": "Ich möchte herausfinden, welcher Bus sonntags zum Bahnhof fährt.",
          "translations": [
            {
              "language": "ar",
              "text": "أريد أن أعرف أي حافلة تذهب إلى المحطة يوم الأحد."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت بزانم یەکشەممە کام پاس دەچێتە وێستگەی شەمەندەفەر."
            },
            {
              "language": "en",
              "text": "I want to find out which bus goes to the station on Sundays."
            },
            {
              "language": "fa",
              "text": "می‌خواهم بفهمم یکشنبه‌ها کدام اتوبوس به ایستگاه قطار می‌رود."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim fêr bibim ka roja yekşemê kîjan otobûs diçe stasyona trênê."
            },
            {
              "language": "pl",
              "text": "Chcę się dowiedzieć, który autobus jedzie w niedzielę na dworzec."
            },
            {
              "language": "ro",
              "text": "Vreau să aflu ce autobuz merge duminica la gară."
            },
            {
              "language": "ru",
              "text": "Я хочу узнать, какой автобус ходит по воскресеньям к вокзалу."
            },
            {
              "language": "sq",
              "text": "Dua të zbuloj cili autobus shkon të dielave në stacion."
            },
            {
              "language": "tr",
              "text": "Pazar günleri hangi otobüsün istasyona gittiğini öğrenmek istiyorum."
            }
          ]
        }
      ]
    },
    {
      "word": "die Herausforderung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Herausforderungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "He-raus-for-de-rung",
      "topics": [
        "work-and-jobs",
        "planning-and-projects",
        "everyday-life"
      ],
      "usageLabels": [
        "business",
        "formal",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; a difficult task or challenge"
      ],
      "collocations": [
        {
          "text": "eine große Herausforderung",
          "meaning": "a major challenge"
        },
        {
          "text": "eine Herausforderung meistern",
          "meaning": "to master a challenge"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "herausfordern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تحدٍّ"
        },
        {
          "language": "ckb",
          "text": "ئاستەنگ؛ چالش"
        },
        {
          "language": "en",
          "text": "challenge"
        },
        {
          "language": "fa",
          "text": "چالش"
        },
        {
          "language": "kmr",
          "text": "astengî; çelenc"
        },
        {
          "language": "pl",
          "text": "wyzwanie"
        },
        {
          "language": "ro",
          "text": "provocare"
        },
        {
          "language": "ru",
          "text": "вызов; сложная задача"
        },
        {
          "language": "sq",
          "text": "sfidë"
        },
        {
          "language": "tr",
          "text": "zorluk; meydan okuma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Umstellung auf das neue System ist für das Team eine echte Herausforderung.",
          "translations": [
            {
              "language": "ar",
              "text": "الانتقال إلى النظام الجديد يمثل تحدياً حقيقياً للفريق."
            },
            {
              "language": "ckb",
              "text": "گۆڕین بۆ سیستەمی نوێ بۆ تیمەکە ئاستەنگێکی ڕاستەقینەیە."
            },
            {
              "language": "en",
              "text": "Switching to the new system is a real challenge for the team."
            },
            {
              "language": "fa",
              "text": "تغییر به سیستم جدید برای تیم یک چالش واقعی است."
            },
            {
              "language": "kmr",
              "text": "Guhertina ber bi pergala nû ve ji bo tîmê astengiyeke rastîn e."
            },
            {
              "language": "pl",
              "text": "Przejście na nowy system jest dla zespołu prawdziwym wyzwaniem."
            },
            {
              "language": "ro",
              "text": "Trecerea la noul sistem este o adevărată provocare pentru echipă."
            },
            {
              "language": "ru",
              "text": "Переход на новую систему — настоящий вызов для команды."
            },
            {
              "language": "sq",
              "text": "Kalimi në sistemin e ri është një sfidë e vërtetë për ekipin."
            },
            {
              "language": "tr",
              "text": "Yeni sisteme geçiş ekip için gerçek bir zorluk."
            }
          ]
        },
        {
          "baseText": "Mit zwei kleinen Kindern ist der Umzug eine große Herausforderung.",
          "translations": [
            {
              "language": "ar",
              "text": "مع طفلين صغيرين يكون الانتقال تحدياً كبيراً."
            },
            {
              "language": "ckb",
              "text": "لەگەڵ دوو منداڵی بچووک، گواستنەوە ئاستەنگێکی گەورەیە."
            },
            {
              "language": "en",
              "text": "With two small children, moving is a big challenge."
            },
            {
              "language": "fa",
              "text": "با دو کودک کوچک، اسباب‌کشی یک چالش بزرگ است."
            },
            {
              "language": "kmr",
              "text": "Bi du zarokên biçûk re koçkirin astengiyeke mezin e."
            },
            {
              "language": "pl",
              "text": "Z dwójką małych dzieci przeprowadzka jest dużym wyzwaniem."
            },
            {
              "language": "ro",
              "text": "Cu doi copii mici, mutarea este o mare provocare."
            },
            {
              "language": "ru",
              "text": "С двумя маленькими детьми переезд — большая сложность."
            },
            {
              "language": "sq",
