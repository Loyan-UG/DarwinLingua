      "examples": [
        {
          "baseText": "Ich gehe zweimal pro Woche schwimmen.",
          "translations": [
            {
              "language": "ar",
              "text": "أذهب للسباحة مرتين في الأسبوع."
            },
            {
              "language": "ckb",
              "text": "دوو جار لە هەفتەیەکدا دەچم مەلە."
            },
            {
              "language": "en",
              "text": "I go swimming twice a week."
            },
            {
              "language": "fa",
              "text": "من هفته‌ای دو بار شنا می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez heftê du caran diçim avjeniyê."
            },
            {
              "language": "pl",
              "text": "Chodzę pływać dwa razy w tygodniu."
            },
            {
              "language": "ro",
              "text": "Merg la înot de două ori pe săptămână."
            },
            {
              "language": "ru",
              "text": "Я хожу плавать два раза в неделю."
            },
            {
              "language": "sq",
              "text": "Shkoj të notoj dy herë në javë."
            },
            {
              "language": "tr",
              "text": "Haftada iki kez yüzmeye giderim."
            }
          ]
        },
        {
          "baseText": "Bitte wiederholen Sie das Wort zweimal.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك كرر الكلمة مرتين."
            },
            {
              "language": "ckb",
              "text": "تکایە وشەکە دوو جار دووبارە بکەرەوە."
            },
            {
              "language": "en",
              "text": "Please repeat the word twice."
            },
            {
              "language": "fa",
              "text": "لطفاً کلمه را دو بار تکرار کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe peyvê du caran dubare bikin."
            },
            {
              "language": "pl",
              "text": "Proszę powtórzyć słowo dwa razy."
            },
            {
              "language": "ro",
              "text": "Vă rog să repetați cuvântul de două ori."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, повторите слово два раза."
            },
            {
              "language": "sq",
              "text": "Ju lutem përsëriteni fjalën dy herë."
            },
            {
              "language": "tr",
              "text": "Lütfen kelimeyi iki kez tekrarlayın."
            }
          ]
        }
