                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҷЕ ГҳВ«ГҳВЁГҳВӘГҳвҖә ГҷЕ ГҳВЁГҳВұГҷвҖЎГҷвҖ "
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҳВіГӣвҖўГҷвҖһГҷвҖҰГҳВ§ГҷвҖ ГҳВҜГҷвҖ ГҳвҖә ГҳВЁГӣвҖўГҡВөГҡВҜГӣвҖўГҷвҖЎГӣЕҪГҷвҖ ГҳВ§ГҷвҖ ГӣвҖўГҷЛҶГӣвҖў"
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "to prove; to demonstrate"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҳВ«ГҳВ§ГҳВЁГҳВӘ ГҡВ©ГҳВұГҳВҜГҷвҖ ГҳвҖә ГҳВ§ГҳВ«ГҳВЁГҳВ§ГҳВӘ ГҡВ©ГҳВұГҳВҜГҷвҖ "
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "ГғВ®spat kirin; nГғВ®Г…Еёan dan"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "udowodniГ„вҖЎ; wykazaГ„вҖЎ"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "a dovedi; a demonstra"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "ГҗВҙГҗВҫГҗВәГҗВ°ГҗВ·Г‘вҖ№ГҗВІГҗВ°Г‘вҖҡГ‘Е’; ГҗВҝГҗВҫГҗВҙГ‘вҖҡГҗВІГҗВөГ‘вӮ¬ГҗВ¶ГҗВҙГҗВ°Г‘вҖҡГ‘Е’"
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "tГғВ« provosh; tГғВ« dГғВ«shmosh"
                                         },
                                         {
                                             "language":  "tr",
                                             "text":  "kanГ„Вұtlamak; ispatlamak"
                                         }
                                     ],
                        "examples":  [
                                         {
                                             "baseText":  "KГғВ¶nnen Sie beweisen, dass die Ware schon bezahlt wurde?",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҷвҖЎГҷвҖһ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ ГҷЖ’ ГҳВҘГҳВ«ГҳВЁГҳВ§ГҳВӘ ГҳВЈГҷвҖ  ГҳВ§ГҷвҖһГҳВЁГҳВ¶ГҳВ§ГҳВ№ГҳВ© ГҷвҖҡГҳВҜ ГҳВҜГҷВҸГҷВҒГҳВ№ГҳВӘ ГҳВЁГҳВ§ГҷвҖһГҷВҒГҳВ№ГҷвҖһГҳЕё"
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҳВҜГӣвҖўГҳВӘГҷЛҶГҳВ§ГҷвҖ ГҷвҖ  ГҳВЁГҳВіГӣвҖўГҷвҖһГҷвҖҰГӣЕҪГҷвҖ ГҷвҖ  ГҡВ©ГӣвҖў ГҡВ©ГҳВ§ГҡВөГҳВ§ГҡВ©ГӣвҖў ГҷВҫГӣЕҪГҳВҙГҳВӘГҳВұ ГҷВҫГҳВ§ГҳВұГӣвҖўГӣЕ’ ГҳВҜГҳВұГҳВ§ГҷЛҶГӣвҖўГҳЕё"
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "Can you prove that the goods have already been paid for?"
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҳВўГӣЕ’ГҳВ§ ГҷвҖҰГӣЕ’ГўвӮ¬Е’ГҳВӘГҷЛҶГҳВ§ГҷвҖ ГӣЕ’ГҳВҜ ГҳВ«ГҳВ§ГҳВЁГҳВӘ ГҡВ©ГҷвҖ ГӣЕ’ГҳВҜ ГҡВ©ГҷвҖЎ ГҷвҖЎГҳВІГӣЕ’ГҷвҖ ГҷвҖЎ ГҡВ©ГҳВ§ГҷвҖһГҳВ§ ГҷвҖҡГҳВЁГҷвҖһГҳВ§ГҷвҖ№ ГҷВҫГҳВұГҳВҜГҳВ§ГҳВ®ГҳВӘ ГҳВҙГҳВҜГҷвҖЎ ГҳВ§ГҳВіГҳВӘГҳЕё"
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "HГғВ»n dikarin ГғВ®spat bikin ku pereyГғВӘ malГғВӘ berГғВӘ hatiye dayГғВ®n?"
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Czy moГ…Вјe Pan/Pani udowodniГ„вҖЎ, Г…Вјe towar zostaГ…вҖҡ juГ…Вј opГ…вҖҡacony?"
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "PuteГҲвҖәi dovedi cГ„Ж’ marfa a fost deja plГ„Ж’titГ„Ж’?"
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗЕ“ГҗВҫГҗВ¶ГҗВөГ‘вҖҡГҗВө ГҗВ»ГҗВё ГҗВІГ‘вҖ№ ГҗВҙГҗВҫГҗВәГҗВ°ГҗВ·ГҗВ°Г‘вҖҡГ‘Е’, Г‘вҖЎГ‘вҖҡГҗВҫ Г‘вҖҡГҗВҫГҗВІГҗВ°Г‘вӮ¬ Г‘Ж’ГҗВ¶ГҗВө ГҗВҫГҗВҝГҗВ»ГҗВ°Г‘вҖЎГҗВөГҗВҪ?"
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "A mund tГғВ« provoni se malli ГғВ«shtГғВ« paguar tashmГғВ«?"
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "MalГ„Вұn zaten ГғВ¶dendiГ„Еёini kanГ„Вұtlayabilir misiniz?"
                                                                  }
                                                              ]
                                         },
                                         {
                                             "baseText":  "Die Zahlen beweisen, dass sich der Service verbessert hat.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҳВӘГҳВ«ГҳВЁГҳВӘ ГҳВ§ГҷвҖһГҳВЈГҳВұГҷвҖҡГҳВ§ГҷвҖҰ ГҳВЈГҷвҖ  ГҳВ§ГҷвҖһГҳВ®ГҳВҜГҷвҖҰГҳВ© ГҷвҖҡГҳВҜ ГҳВӘГҳВӯГҳВіГҷвҖ ГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҡЛңГҷвҖҰГҳВ§ГҳВұГӣвҖўГҡВ©ГҳВ§ГҷвҖ  ГҳВҜГӣвҖўГӣЕ’ГҳВіГӣвҖўГҷвҖһГҷвҖҰГӣЕҪГҷвҖ ГҷвҖ  ГҡВ©ГӣвҖў ГҳВ®ГҳВІГҷвҖҰГӣвҖўГҳВӘГҡВҜГҷЛҶГҳВІГҳВ§ГҳВұГӣЕ’ГӣЕ’ГӣвҖўГҡВ©ГӣвҖў ГҳВЁГҳВ§ГҳВҙГҳВӘГҳВұ ГҳВЁГҷЛҶГҷЛҶГӣвҖў."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "The figures prove that the service has improved."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҳВўГҷвҖҰГҳВ§ГҳВұ ГҳВ«ГҳВ§ГҳВЁГҳВӘ ГҷвҖҰГӣЕ’ГўвӮ¬Е’ГҡВ©ГҷвҖ ГҳВҜ ГҡВ©ГҷвҖЎ ГҳВ®ГҳВҜГҷвҖҰГҳВ§ГҳВӘ ГҳВЁГҷвҖЎГҳВӘГҳВұ ГҳВҙГҳВҜГҷвҖЎ ГҳВ§ГҳВіГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "Hejmar ГғВ®spat dikin ku xizmet baГ…Еёtir bГғВ»ye."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Liczby dowodzГ„вҖҰ, Г…Вјe obsГ…вҖҡuga siГ„в„ў poprawiГ…вҖҡa."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "Cifrele dovedesc cГ„Ж’ serviciul s-a ГғВ®mbunГ„Ж’tГ„Ж’ГҲвҖәit."
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗВҰГҗВёГ‘вҖһГ‘вӮ¬Г‘вҖ№ ГҗВҙГҗВҫГҗВәГҗВ°ГҗВ·Г‘вҖ№ГҗВІГҗВ°Г‘ЕҪГ‘вҖҡ, Г‘вҖЎГ‘вҖҡГҗВҫ Г‘ВҒГҗВөГ‘вӮ¬ГҗВІГҗВёГ‘ВҒ Г‘Ж’ГҗВ»Г‘Ж’Г‘вҖЎГ‘ЛҶГҗВёГҗВ»Г‘ВҒГ‘ВҸ."
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "Shifrat tregojnГғВ« se shГғВ«rbimi ГғВ«shtГғВ« pГғВ«rmirГғВ«suar."
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "Rakamlar hizmetin iyileГ…ЕёtiГ„Еёini kanГ„ВұtlГ„Вұyor."
