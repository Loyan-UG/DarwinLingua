                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҷвҖҰГҳВӯГҳВҜГҳВҜ ГҳВ§ГҷвҖһГҷвҖҰГҳВҜГҳВ©ГҳвҖә ГҷвҖҰГҳВӨГҷвҖҡГҳВӘ"
