                                         {
                                             "language":  "ckb",
                                             "text":  "ГҷвҖҰГҳВ§ГҷЛҶГӣвҖўГҳВҜГҳВ§ГҳВұГҳвҖә ГҡВ©ГҳВ§ГҳВӘГӣЕ’"
                                         },
                                         {
                                             "language":  "en",
