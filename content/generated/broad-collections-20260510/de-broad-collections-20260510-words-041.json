                        "examples":  [
                                         {
                                             "baseText":  "Der Arbeitsvertrag ist zunГғВӨchst auf ein Jahr befristet.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҳВ№ГҷвҖҡГҳВҜ ГҳВ§ГҷвҖһГҳВ№ГҷвҖҰГҷвҖһ ГҷвҖҰГҳВӯГҳВҜГҳВҜ ГҷВҒГҷЕ  ГҳВ§ГҷвҖһГҳВЁГҳВҜГҳВ§ГҷЕ ГҳВ© ГҷвҖһГҷвҖҰГҳВҜГҳВ© ГҳВіГҷвҖ ГҳВ© ГҷЛҶГҳВ§ГҳВӯГҳВҜГҳВ©."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҡВҜГҳВұГӣЕҪГҳВЁГӣвҖўГҳВіГҳВӘГӣЕ’ ГҡВ©ГҳВ§ГҳВұ ГҳВіГӣвҖўГҳВұГӣвҖўГҳВӘГҳВ§ ГҳВЁГӣвҖ  ГҷвҖҰГҳВ§ГҷЛҶГӣвҖўГӣЕ’ ГҳВіГҳВ§ГҡВөГӣЕҪГҡВ© ГҳВҜГӣЕ’ГҳВ§ГҳВұГӣЕ’ГҡВ©ГҳВұГҳВ§ГҷЛҶГӣвҖў."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "The employment contract is initially limited to one year."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҷвҖҡГҳВұГҳВ§ГҳВұГҳВҜГҳВ§ГҳВҜ ГҡВ©ГҳВ§ГҳВұ ГҳВҜГҳВұ ГҳВ§ГҳВЁГҳВӘГҳВҜГҳВ§ ГҳВЁГҳВұГҳВ§ГӣЕ’ ГӣЕ’ГҡВ© ГҳВіГҳВ§ГҷвҖһ ГҷвҖҰГҷЛҶГҷвҖҡГҳВӘ ГҳВ§ГҳВіГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "Peymana karГғВӘ di destpГғВӘkГғВӘ de ji bo salekГғВӘ hatiye sГғВ®nordarkirin."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Umowa o pracГ„в„ў jest poczГ„вҖҰtkowo zawarta na jeden rok."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "Contractul de muncГ„Ж’ este iniГҲвҖәial pe duratГ„Ж’ determinatГ„Ж’ de un an."
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗВўГ‘вӮ¬Г‘Ж’ГҗВҙГҗВҫГҗВІГҗВҫГҗВ№ ГҗВҙГҗВҫГҗВіГҗВҫГҗВІГҗВҫГ‘вӮ¬ Г‘ВҒГҗВҪГҗВ°Г‘вҖЎГҗВ°ГҗВ»ГҗВ° ГҗВҫГҗВіГ‘вӮ¬ГҗВ°ГҗВҪГҗВёГ‘вҖЎГҗВөГҗВҪ ГҗВҫГҗВҙГҗВҪГҗВёГҗВј ГҗВіГҗВҫГҗВҙГҗВҫГҗВј."
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "Kontrata e punГғВ«s fillimisht ГғВ«shtГғВ« me afat njГғВ«vjeГғВ§ar."
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "Г„В°Г…Её sГғВ¶zleГ…Еёmesi baГ…ЕёlangГ„ВұГғВ§ta bir yГ„Вұl sГғВјreyle sГ„ВұnГ„ВұrlГ„ВұdГ„Вұr."
                                                                  }
                                                              ]
