                                         ],
                        "topics":  [
                                       "everyday-life"
                                   ],
                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҷЕ ГҳВіГҷвҖҡГҳВ·ГҳвҖә ГҷЕ ГҷвҖ ГҷвҖҡГҷвҖһГҳВЁ"
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҡВ©ГӣвҖўГҷЛҶГҳВӘГҷвҖ ГӣвҖў ГҳВ®ГҷЛҶГҳВ§ГҳВұГӣвҖўГҷЛҶГӣвҖўГҳвҖә ГҷвҖһГӣвҖўГҳВіГӣвҖўГҳВұ ГҷвҖһГҳВ§ ГҡВ©ГӣвҖўГҷЛҶГҳВӘГҷвҖ "
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "to fall over; to topple over"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҳВ§ГҷВҒГҳВӘГҳВ§ГҳВҜГҷвҖ ГҳвҖә ГҷЛҶГҳВ§ГҡЛңГҡВҜГҷЛҶГҷвҖ  ГҳВҙГҳВҜГҷвҖ "
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "ketin; hilweГ…ЕёГғВ®n"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "przewrГғВіciГ„вҖЎ siГ„в„ў; upaГ…вҖәГ„вҖЎ"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "a cГ„Ж’dea; a se rГ„Ж’sturna"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "ГҗВҝГҗВ°ГҗВҙГҗВ°Г‘вҖҡГ‘Е’; ГҗВҫГҗВҝГ‘вӮ¬ГҗВҫГҗВәГҗВёГҗВҙГ‘вҖ№ГҗВІГҗВ°Г‘вҖҡГ‘Е’Г‘ВҒГ‘ВҸ"
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "tГғВ« rrГғВ«zohesh; tГғВ« pГғВ«rmbytesh"
                                         },
                                         {
                                             "language":  "tr",
                                             "text":  "devrilmek; dГғВјГ…Еёmek"
                                         }
                                     ],
                        "examples":  [
                                         {
                                             "baseText":  "Bei dem starken Wind ist der Sonnenschirm im Garten umgefallen.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҳВЁГҳВіГҳВЁГҳВЁ ГҳВ§ГҷвҖһГҳВұГҷЕ ГҳВ§ГҳВӯ ГҳВ§ГҷвҖһГҷвҖҡГҷЛҶГҷЕ ГҳВ© ГҳВіГҷвҖҡГҳВ·ГҳВӘ ГҳВ§ГҷвҖһГҷвҖҰГҳВёГҷвҖһГҳВ© ГҷВҒГҷЕ  ГҳВ§ГҷвҖһГҳВӯГҳВҜГҷЕ ГҷвҖҡГҳВ©."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҳВЁГӣвҖўГҷвҖЎГӣвҖ ГӣЕ’ ГҳВЁГҳВ§ГӣЕ’ ГҳВӘГҷЛҶГҷвҖ ГҳВҜГӣвҖўГҷЛҶГӣвҖў ГҡвҖ ГӣвҖўГҳВӘГҳВұГӣЕ’ ГҳВ®ГӣвҖ ГҳВұ ГҷвҖһГӣвҖў ГҳВЁГҳВ§ГҳВ®ГҡвҖ ГӣвҖўГҡВ©ГӣвҖўГҳВҜГҳВ§ ГҡВ©ГӣвҖўГҷЛҶГҳВӘГӣвҖў ГҳВ®ГҷЛҶГҳВ§ГҳВұГӣвҖўГҷЛҶГӣвҖў."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "In the strong wind, the sun umbrella in the garden fell over."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҳВҜГҳВұ ГҳВЁГҳВ§ГҳВҜ ГҳВҙГҳВҜГӣЕ’ГҳВҜГҳЕ’ ГҡвҖ ГҳВӘГҳВұ ГҳВўГҷВҒГҳВӘГҳВ§ГҳВЁГўвӮ¬Е’ГҡВҜГӣЕ’ГҳВұ ГҳВҜГҳВұ ГҳВЁГҳВ§ГҳВә ГҷЛҶГҳВ§ГҡЛңГҡВҜГҷЛҶГҷвҖ  ГҳВҙГҳВҜ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "Di bayГғВӘ tund de sГғВ®wana rojГғВӘ ya li baxГғВ§e ket."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Przy silnym wietrze parasol ogrodowy siГ„в„ў przewrГғВіciГ…вҖҡ."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "Din cauza vГғВўntului puternic, umbrela de soare din grГ„Ж’dinГ„Ж’ s-a rГ„Ж’sturnat."
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗЛңГҗВ·-ГҗВ·ГҗВ° Г‘ВҒГҗВёГҗВ»Г‘Е’ГҗВҪГҗВҫГҗВіГҗВҫ ГҗВІГҗВөГ‘вҖҡГ‘вӮ¬ГҗВ° Г‘ВҒГҗВ°ГҗВҙГҗВҫГҗВІГ‘вҖ№ГҗВ№ ГҗВ·ГҗВҫГҗВҪГ‘вҖҡ ГҗВҫГҗВҝГ‘вӮ¬ГҗВҫГҗВәГҗВёГҗВҪГ‘Ж’ГҗВ»Г‘ВҒГ‘ВҸ."
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "Nga era e fortГғВ«, ГғВ§adra e diellit nГғВ« kopsht u rrГғВ«zua."
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "Г…Еҫiddetli rГғВјzgarda bahГғВ§edeki gГғВјneГ…Её Г…Еёemsiyesi devrildi."
                                                                  }
                                                              ]
                                         },
                                         {
                                             "baseText":  "Wenn jemand im Wartezimmer umfГғВӨllt, rufen Sie bitte sofort das Personal.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҳВҘГҳВ°ГҳВ§ ГҳВіГҷвҖҡГҳВ· ГҳВҙГҳВ®ГҳВө ГҷВҒГҷЕ  ГҳВәГҳВұГҷВҒГҳВ© ГҳВ§ГҷвҖһГҳВ§ГҷвҖ ГҳВӘГҳВёГҳВ§ГҳВұГҳЕ’ ГҷЕ ГҳВұГҳВ¬ГҷвҖ° ГҳВ§ГҳВіГҳВӘГҳВҜГҳВ№ГҳВ§ГҳВЎ ГҳВ§ГҷвҖһГҷвҖҰГҷЛҶГҳВёГҷВҒГҷЕ ГҷвҖ  ГҷВҒГҷЛҶГҳВұГҷвҖ№ГҳВ§."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҳВҰГӣвҖўГҡВҜГӣвҖўГҳВұ ГҡВ©ГӣвҖўГҳВіГӣЕҪГҡВ© ГҷвҖһГӣвҖў ГҡЛңГҷЛҶГҷЛҶГҳВұГӣЕ’ ГҡвҖ ГҳВ§ГҷЛҶГӣвҖўГҡвҖўГҷЛҶГҳВ§ГҷвҖ ГӣЕ’ГҳВҜГҳВ§ ГҳВЁГҡВ©ГӣвҖўГҷЛҶГӣЕҪГҳВӘГҳЕ’ ГҳВӘГҡВ©ГҳВ§ГӣЕ’ГӣвҖў ГҳВҜГӣвҖўГҳВіГҳВӘГҳВЁГӣвҖўГҳВ¬ГӣЕҪ ГҳВіГҳВӘГҳВ§ГҷВҒ ГҳВЁГҳВ§ГҷвҖ ГҡВҜ ГҳВЁГҡВ©ГӣвҖўГҷвҖ ."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "If someone falls over in the waiting room, please call the staff immediately."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҳВ§ГҡВҜГҳВұ ГҡВ©ГҳВіГӣЕ’ ГҳВҜГҳВұ ГҳВ§ГҳВӘГҳВ§ГҷвҖҡ ГҳВ§ГҷвҖ ГҳВӘГҳВёГҳВ§ГҳВұ ГҳВ§ГҷВҒГҳВӘГҳВ§ГҳВҜГҳЕ’ ГҷвҖһГҳВ·ГҷВҒГҳВ§ГҷвҖ№ ГҷВҒГҷЛҶГҳВұГҳВ§ГҷвҖ№ ГҡВ©ГҳВ§ГҳВұГҡВ©ГҷвҖ ГҳВ§ГҷвҖ  ГҳВұГҳВ§ ГҳВ®ГҳВЁГҳВұ ГҡВ©ГҷвҖ ГӣЕ’ГҳВҜ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "Heke kesek li odeya bendГғВӘ bikeve, ji kerema xwe tavilГғВӘ karmendan bang bikin."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "JeГ…вҖәli ktoГ…вҖә przewrГғВіci siГ„в„ў w poczekalni, proszГ„в„ў natychmiast wezwaГ„вҖЎ personel."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "DacГ„Ж’ cineva cade ГғВ®n sala de aГҲв„ўteptare, vГ„Ж’ rugГ„Ж’m sГ„Ж’ chemaГҲвҖәi imediat personalul."
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗвҖўГ‘ВҒГҗВ»ГҗВё ГҗВәГ‘вҖҡГҗВҫ-Г‘вҖҡГҗВҫ Г‘Ж’ГҗВҝГҗВ°ГҗВҙГҗВөГ‘вҖҡ ГҗВІ ГҗВ·ГҗВ°ГҗВ»ГҗВө ГҗВҫГҗВ¶ГҗВёГҗВҙГҗВ°ГҗВҪГҗВёГ‘ВҸ, ГҗВҝГҗВҫГҗВ¶ГҗВ°ГҗВ»Г‘Ж’ГҗВ№Г‘ВҒГ‘вҖҡГҗВ°, Г‘ВҒГ‘вӮ¬ГҗВ°ГҗВ·Г‘Ж’ ГҗВҝГҗВҫГҗВ·ГҗВҫГҗВІГҗВёГ‘вҖҡГҗВө ГҗВҝГҗВөГ‘вӮ¬Г‘ВҒГҗВҫГҗВҪГҗВ°ГҗВ»."
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "NГғВ«se dikush rrГғВ«zohet nГғВ« dhomГғВ«n e pritjes, ju lutemi thГғВ«rrisni menjГғВ«herГғВ« personelin."
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "Bekleme odasГ„Вұnda biri dГғВјГ…Еёerse lГғВјtfen hemen personeli ГғВ§aГ„ЕёГ„ВұrГ„Вұn."
                                                                  }
                                                              ]
                                         }
