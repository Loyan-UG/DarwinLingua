                                                                      "text":  "Talep belirgin biГғВ§imde dГғВјГ…ЕёtГғВј; bunu gГғВ¶z ГғВ¶nГғВјnde bulundurarak planlanan geniГ…Еёlemeyi erteliyoruz."
                                                                  }
                                                              ]
                                         },
                                         {
                                             "baseText":  "Mehrere BehГғВ¶rden haben zusГғВӨtzliche Nachweise verlangt; angesichts dessen ist der ursprГғВјngliche Zeitplan kaum haltbar.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҳВ·ГҷвҖһГҳВЁГҳВӘ ГҳВ№ГҳВҜГҳВ© ГҳВіГҷвҖһГҳВ·ГҳВ§ГҳВӘ ГҳВЈГҳВҜГҷвҖһГҳВ© ГҳВҘГҳВ¶ГҳВ§ГҷВҒГҷЕ ГҳВ©ГҳвҖә ГҷВҒГҷЕ  ГҳВ¶ГҷЛҶГҳВЎ ГҳВ°ГҷвҖһГҷЖ’ ГҷЕ ГҳВөГҳВ№ГҳВЁ ГҳВ§ГҷвҖһГҳВ§ГҷвҖһГҳВӘГҳВІГҳВ§ГҷвҖҰ ГҳВЁГҳВ§ГҷвҖһГҳВ¬ГҳВҜГҷЛҶГҷвҖһ ГҳВ§ГҷвҖһГҳВЈГҳВөГҷвҖһГҷЕ ."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҡвҖ ГӣвҖўГҷвҖ ГҳВҜ ГҳВҜГӣвҖўГҳВІГҡВҜГҳВ§ГӣЕ’ГӣвҖўГҡВ© ГҳВЁГӣвҖўГҡВөГҡВҜГӣвҖўГӣЕ’ ГҳВІГӣЕ’ГҳВ§ГҳВҜГӣвҖўГӣЕ’ГҳВ§ГҷвҖ  ГҳВҜГҳВ§ГҷЛҶГҳВ§ ГҡВ©ГҳВұГҳВҜГҷЛҶГҷЛҶГӣвҖўГҳвҖә ГҷвҖһГӣвҖўГҳВЁГӣвҖўГҳВұ ГҳВҰГӣвҖўГҷЛҶГӣвҖў ГҳВ®ГҳВҙГҳВӘГӣвҖўГӣЕ’ ГҡВ©ГҳВ§ГҳВӘГӣЕ’ ГҳВіГӣвҖўГҳВұГӣвҖўГҳВӘГҳВ§ГӣЕ’ГӣЕ’ ГҳВЁГӣвҖў ГҳВІГӣвҖўГҳВӯГҷвҖҰГӣвҖўГҳВӘ ГҳВҜГӣвҖўГҡВҜГӣЕ’ГҳВұГӣЕҪГҳВӘГӣвҖўГҷЛҶГӣвҖў."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "Several authorities have requested additional evidence; given this, the original schedule is hardly sustainable."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҡвҖ ГҷвҖ ГҳВҜ ГҳВ§ГҳВҜГҳВ§ГҳВұГҷвҖЎ ГҷвҖҰГҳВҜГҳВ§ГҳВұГҡВ© ГҳВ§ГҳВ¶ГҳВ§ГҷВҒГӣЕ’ ГҳВ®ГҷЛҶГҳВ§ГҳВіГҳВӘГҷвҖЎГўвӮ¬Е’ГҳВ§ГҷвҖ ГҳВҜГҳвҖә ГҳВЁГҳВ§ ГҳВӘГҷЛҶГҳВ¬ГҷвҖЎ ГҳВЁГҷвҖЎ ГҳВ§ГӣЕ’ГҷвҖ ГҳЕ’ ГҳВІГҷвҖҰГҳВ§ГҷвҖ ГўвӮ¬Е’ГҳВЁГҷвҖ ГҳВҜГӣЕ’ ГҳВ§ГҷЛҶГҷвҖһГӣЕ’ГҷвҖЎ ГҳВЁГҷвҖЎГўвӮ¬Е’ГҳВіГҳВ®ГҳВӘГӣЕ’ ГҷвҖҡГҳВ§ГҳВЁГҷвҖһ ГҳВӯГҷВҒГҳВё ГҳВ§ГҳВіГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "ГғвҖЎend dezgeh belgeyГғВӘn zГғВӘde xwestine; li ber vГғВӘ yekГғВӘ demjimГғВӘra destpГғВӘkГғВӘ zehmet e were parastin."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Kilka urzГ„в„ўdГғВіw zaГ…ВјГ„вҖҰdaГ…вҖҡo dodatkowych dowodГғВіw; wobec tego pierwotny harmonogram jest trudny do utrzymania."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "Mai multe autoritГ„Ж’ГҲвҖәi au solicitat dovezi suplimentare; avГғВўnd ГғВ®n vedere aceasta, calendarul iniГҲвҖәial este greu de menГҲвҖәinut."
                                                                  },
