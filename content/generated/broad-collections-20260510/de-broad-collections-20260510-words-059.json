                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҳВіГҳВ¬ГҷвҖһ ГҷЛҶГҳВӯГҳВҜГҳВ§ГҳВӘ ГҳВ§ГҷвҖһГҳВӘГҳВӯГҷвҖҰГҷЕ ГҷвҖһ"
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҡЛңГҷЛҶГҷЛҶГҳВұГҷвҖ ГҳВ§ГҡВөГӣЕ’ ГӣЕ’ГӣвҖўГҡВ©ГӣвҖўГӣЕ’ ГҳВЁГҳВ§ГҳВұГҡВ©ГҳВұГҳВҜГҷвҖ "
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "load unit journal"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҳВҜГҷВҒГҳВӘГҳВұГҡвҖ ГҷвҖЎ ГҷЛҶГҳВ§ГҳВӯГҳВҜ ГҳВЁГҳВ§ГҳВұГҡВҜГӣЕ’ГҳВұГӣЕ’"
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "rojnameya yekГғВ®neya barkirinГғВӘ"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "dziennik jednostek Г…вҖҡadunkowych"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "jurnal unitГ„Ж’ГҲвҖәi de ГғВ®ncГ„Ж’rcare"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "ГҗВ¶Г‘Ж’Г‘вӮ¬ГҗВҪГҗВ°ГҗВ» ГҗВіГ‘вӮ¬Г‘Ж’ГҗВ·ГҗВҫГҗВІГ‘вҖ№Г‘вҖҰ ГҗВөГҗВҙГҗВёГҗВҪГҗВёГ‘вҖ "
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "ditar i njГғВ«sive tГғВ« ngarkesГғВ«s"
                                         },
                                         {
