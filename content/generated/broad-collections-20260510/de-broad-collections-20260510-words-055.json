                                   ],
                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҷЕ ГҷвҖҡГҷЛҶГҷвҖҳГҳВ¶ГҳвҖә ГҷЕ ГҳВІГҳВ№ГҳВІГҳВ№ ГҷвҖҰГҷвҖ  ГҳВ§ГҷвҖһГҳВҜГҳВ§ГҳВ®ГҷвҖһ"
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҷвҖһГӣвҖўГҡЛңГӣЕҪГҳВұГӣвҖўГҷЛҶГӣвҖў ГҳВӘГӣЕҪГҡВ©ГҳВҜГҳВ§ГҷвҖ ГҳвҖә ГҳВЁГҷвҖ ГӣвҖўГҷвҖҰГҳВ§ ГҡЛңГӣЕҪГҳВұГҳВ®ГҳВіГҳВӘГҷвҖ "
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "to subvert; to undermine from within"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҳВІГӣЕ’ГҳВұГҷЛҶГҳВұГҷЛҶ ГҡВ©ГҳВұГҳВҜГҷвҖ ГҳвҖә ГҳВ§ГҳВІ ГҳВҜГҳВұГҷЛҶГҷвҖ  ГҳВӘГҳВ¶ГҳВ№ГӣЕ’ГҷВҒ ГҡВ©ГҳВұГҳВҜГҷвҖ "
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "ji hundir ve hilweГ…Еёandin; subvert kirin"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "subwertowaГ„вҖЎ; podwaГ…ВјaГ„вҖЎ"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "a submina; a subverti"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "ГҗВҝГҗВҫГҗВҙГ‘вӮ¬Г‘вҖ№ГҗВІГҗВ°Г‘вҖҡГ‘Е’; Г‘ВҒГ‘Ж’ГҗВұГҗВІГҗВөГ‘вӮ¬Г‘вҖҡГҗВёГ‘вӮ¬ГҗВҫГҗВІГҗВ°Г‘вҖҡГ‘Е’"
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "minoj; subvertoj"
                                         },
                                         {
                                             "language":  "tr",
                                             "text":  "altГ„ВұnГ„Вұ oymak; subvert etmek"
                                         }
                                     ],
                        "examples":  [
                                         {
                                             "baseText":  "Ein inoffizieller Freigabeweg subvertiert jede Auditierbarkeit, selbst wenn er kurzfristig Geschwindigkeit verspricht.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҷЕ ГҷвҖҡГҷЛҶГҷвҖҳГҳВ¶ ГҷвҖҰГҳВіГҳВ§ГҳВұ ГҷвҖҰГҷЛҶГҳВ§ГҷВҒГҷвҖҡГҳВ© ГҳВәГҷЕ ГҳВұ ГҳВұГҳВіГҷвҖҰГҷЕ  ГҷЖ’ГҷвҖһ ГҷвҖҡГҳВ§ГҳВЁГҷвҖһГҷЕ ГҳВ© ГҷвҖһГҷвҖһГҳВӘГҳВҜГҷвҖҡГҷЕ ГҷвҖҡ ГҳВӯГҳВӘГҷвҖ° ГҷвҖһГҷЛҶ ГҷЛҶГҳВ№ГҳВҜ ГҳВЁГҳВіГҳВұГҳВ№ГҳВ© ГҷвҖҡГҳВөГҷЕ ГҳВұГҳВ© ГҳВ§ГҷвҖһГҳВЈГҳВ¬ГҷвҖһ."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҡвҖўГӣЕҪГҡвҖўГӣвҖўГҷЛҶГӣЕ’ ГҷВҫГӣвҖўГҳВіГӣвҖўГҷвҖ ГҳВҜГҡВ©ГҳВұГҳВҜГҷвҖ ГӣЕ’ ГҷвҖ ГҳВ§ГҷВҒГӣвҖўГҳВұГҷвҖҰГӣЕ’ ГҷвҖЎГӣвҖўГҳВұ auditabilityГӣЕ’ГӣвҖўГҡВ© ГҷвҖһГӣвҖўГҡЛңГӣЕҪГҳВұГӣвҖўГҷЛҶГӣвҖў ГҳВӘГӣЕҪГҡВ©ГҳВҜГӣвҖўГҳВҜГҳВ§ГҳВӘГҳЕ’ ГҳВӘГӣвҖўГҷвҖ ГҳВ§ГҷвҖ ГӣвҖўГҳВӘ ГҳВҰГӣвҖўГҡВҜГӣвҖўГҳВұ ГҳВЁГӣвҖў ГҳВ®ГӣЕҪГҳВұГҳВ§ГӣЕ’ГӣЕ’ ГҡВ©ГҷЛҶГҳВұГҳВӘГҳВ®ГҳВ§ГӣЕ’ГӣвҖўГҷвҖ ГӣЕ’ГҳВҙ ГҳВЁГӣвҖўГҡВөГӣЕҪГҷвҖ  ГҳВЁГҳВҜГҳВ§ГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "An unofficial approval path subverts any auditability, even if it promises short-term speed."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
