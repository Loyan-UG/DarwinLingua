    "entries":  [
                    {
                        "word":  "die Datenhoheit",
                        "language":  "de",
                        "cefrLevel":  "B2",
                        "partOfSpeech":  "Noun",
                        "lexicalForms":  [
                                             {
                                                 "partOfSpeech":  "Noun",
                                                 "article":  "die",
                                                 "plural":  "Datenhoheiten",
                                                 "infinitive":  null,
                                                 "isPrimary":  true
                                             }
                                         ],
                        "topics":  [
                                       "work-and-jobs"
                                   ],
                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҳВ§ГҷвҖһГҳВіГҷЕ ГҳВ§ГҳВҜГҳВ© ГҳВ№ГҷвҖһГҷвҖ° ГҳВ§ГҷвҖһГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘГҳвҖә ГҳВ§ГҷвҖһГҳВӘГҳВӯГҷЖ’ГҷвҖҰ ГҳВЁГҳВ§ГҷвҖһГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘ"
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҳВіГӣвҖўГҳВұГҷЛҶГӣвҖўГҳВұГӣЕ’ ГҳВҜГҳВ§ГҳВӘГҳВ§ГҳвҖә ГҡВ©ГӣвҖ ГҷвҖ ГҳВӘГҳВұГӣвҖ ГҡВөГӣЕ’ ГҳВҜГҳВ§ГҳВӘГҳВ§"
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "data sovereignty; control over data"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҳВӯГҳВ§ГҡВ©ГҷвҖҰГӣЕ’ГҳВӘ ГҳВҜГҳВ§ГҳВҜГҷвҖЎГҳвҖә ГҡВ©ГҷвҖ ГҳВӘГҳВұГҷвҖһ ГҳВЁГҳВұ ГҳВҜГҳВ§ГҳВҜГҷвҖЎГўвӮ¬Е’ГҷвҖЎГҳВ§"
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "serweriya daneyan; kontrola daneyan"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "suwerennoГ…вҖәГ„вҖЎ danych; kontrola nad danymi"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "suveranitate asupra datelor; control asupra datelor"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "Г‘ВҒГ‘Ж’ГҗВІГҗВөГ‘вӮ¬ГҗВөГҗВҪГҗВёГ‘вҖҡГҗВөГ‘вҖҡ ГҗВҙГҗВ°ГҗВҪГҗВҪГ‘вҖ№Г‘вҖҰ; ГҗВәГҗВҫГҗВҪГ‘вҖҡГ‘вӮ¬ГҗВҫГҗВ»Г‘Е’ ГҗВҪГҗВ°ГҗВҙ ГҗВҙГҗВ°ГҗВҪГҗВҪГ‘вҖ№ГҗВјГҗВё"
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "sovranitet i tГғВ« dhГғВ«nave; kontroll mbi tГғВ« dhГғВ«nat"
                                         },
                                         {
                                             "language":  "tr",
                                             "text":  "veri egemenliГ„Еёi; veriler ГғВјzerinde kontrol"
                                         }
                                     ],
                        "examples":  [
                                         {
                                             "baseText":  "Das Unternehmen mГғВ¶chte die Datenhoheit behalten und speichert sensible Kundendaten deshalb nicht bei einem externen Anbieter.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҳВӘГҳВұГҷЕ ГҳВҜ ГҳВ§ГҷвҖһГҳВҙГҳВұГҷЖ’ГҳВ© ГҳВ§ГҷвҖһГҳВ§ГҳВӯГҳВӘГҷВҒГҳВ§ГҳВё ГҳВЁГҳВ§ГҷвҖһГҳВіГҷЕ ГҳВ§ГҳВҜГҳВ© ГҳВ№ГҷвҖһГҷвҖ° ГҳВ§ГҷвҖһГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘГҳЕ’ ГҷЛҶГҷвҖһГҳВ°ГҷвҖһГҷЖ’ ГҷвҖһГҳВ§ ГҳВӘГҳВ®ГҳВІГҷвҖ  ГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘ ГҳВ§ГҷвҖһГҳВ№ГҷвҖҰГҷвҖһГҳВ§ГҳВЎ ГҳВ§ГҷвҖһГҳВӯГҳВіГҳВ§ГҳВіГҳВ© ГҷвҖһГҳВҜГҷвҖ° ГҷвҖҰГҳВІГҷЛҶГҳВҜ ГҳВ®ГҳВ§ГҳВұГҳВ¬ГҷЕ ."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҡВ©ГӣвҖ ГҷвҖҰГҷВҫГҳВ§ГҷвҖ ГӣЕ’ГҳВ§ГҡВ©ГӣвҖў ГҳВҜГӣвҖўГӣЕ’ГӣвҖўГҷЛҶГӣЕҪГҳВӘ ГҳВіГӣвҖўГҳВұГҷЛҶГӣвҖўГҳВұГӣЕ’ ГҳВҜГҳВ§ГҳВӘГҳВ§ ГҳВЁГҷВҫГҳВ§ГҳВұГӣЕҪГҳВІГӣЕҪГҳВӘГҳЕ’ ГҳВЁГӣвҖ ГӣЕ’ГӣвҖў ГҳВҜГҳВ§ГҳВӘГҳВ§ГӣЕ’ ГҷвҖЎГӣвҖўГҳВіГҳВӘГӣЕ’ГҳВ§ГҳВұГӣЕ’ ГҡВ©ГҡвҖўГӣЕ’ГҳВ§ГҳВұГҳВ§ГҷвҖ  ГҷвҖһГҳВ§ГӣЕ’ ГҳВҜГҳВ§ГҳВЁГӣЕ’ГҷвҖ ГҡВ©ГӣвҖўГҳВұГӣЕҪГҡВ©ГӣЕ’ ГҳВҜГӣвҖўГҳВұГӣвҖўГҡВ©ГӣЕ’ ГҷВҫГҳВ§ГҳВҙГӣвҖўГҡВ©ГӣвҖўГҷЛҶГҳВӘ ГҷвҖ ГҳВ§ГҡВ©ГҳВ§ГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "The company wants to retain data sovereignty and therefore does not store sensitive customer data with an external provider."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
