                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҳВҘГҳВ¬ГҳВ§ГҳВІГҳВ© ГҳВөГҷЕ ГҷВҒГҷЕ ГҳВ©"
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҷВҫГҳВҙГҷЛҶГҷЛҶГӣЕ’ ГҷвҖЎГҳВ§ГҷЛҶГӣЕ’ГҷвҖ "
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "summer vacation"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҷвҖҰГҳВұГҳВ®ГҳВөГӣЕ’ ГҳВӘГҳВ§ГҳВЁГҳВіГҳВӘГҳВ§ГҷвҖ ГӣЕ’ГҳвҖә ГҳВіГҷВҒГҳВұ ГҳВӘГҳВ§ГҳВЁГҳВіГҳВӘГҳВ§ГҷвҖ ГӣЕ’"
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "betlaneya havГғВ®nГғВӘ"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "urlop letni"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "concediu de varГ„Ж’"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "ГҗВ»ГҗВөГ‘вҖҡГҗВҪГҗВёГҗВ№ ГҗВҫГ‘вҖҡГҗВҝГ‘Ж’Г‘ВҒГҗВә"
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "pushim veror"
                                         },
                                         {
                                             "language":  "tr",
                                             "text":  "yaz izni; yaz tatili"
                                         }
                                     ],
                        "examples":  [
                                         {
                                             "baseText":  "Wir planen unseren Sommerurlaub am Meer.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҷвҖ ГҳВ®ГҳВ·ГҳВ· ГҷвҖһГҳВҘГҳВ¬ГҳВ§ГҳВІГҳВӘГҷвҖ ГҳВ§ ГҳВ§ГҷвҖһГҳВөГҷЕ ГҷВҒГҷЕ ГҳВ© ГҳВ№ГҷвҖһГҷвҖ° ГҳВ§ГҷвҖһГҳВЁГҳВӯГҳВұ."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҳВҰГӣЕҪГҷвҖҰГӣвҖў ГҷВҫГҷвҖһГҳВ§ГҷвҖ ГӣЕ’ ГҷВҫГҳВҙГҷЛҶГҷЛҶГӣЕ’ ГҷвҖЎГҳВ§ГҷЛҶГӣЕ’ГҷвҖ ГҷвҖҰГҳВ§ГҷвҖ  ГҷвҖһГӣвҖў ГҳВҜГӣвҖўГҳВұГӣЕ’ГҳВ§ ГҳВҜГӣвҖўГҡВ©ГӣвҖўГӣЕ’ГҷвҖ ."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "We are planning our summer vacation by the sea."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҷвҖҰГҳВ§ ГҳВЁГҳВұГҳВ§ГӣЕ’ ГҳВӘГҳВ№ГҳВ·ГӣЕ’ГҷвҖһГҳВ§ГҳВӘ ГҳВӘГҳВ§ГҳВЁГҳВіГҳВӘГҳВ§ГҷвҖ ГӣЕ’ ГҡВ©ГҷвҖ ГҳВ§ГҳВұ ГҳВҜГҳВұГӣЕ’ГҳВ§ ГҳВЁГҳВұГҷвҖ ГҳВ§ГҷвҖҰГҷвҖЎГўвӮ¬Е’ГҳВұГӣЕ’ГҳВІГӣЕ’ ГҷвҖҰГӣЕ’ГўвӮ¬Е’ГҡВ©ГҷвҖ ГӣЕ’ГҷвҖҰ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "Em betlaneya xwe ya havГғВ®nГғВӘ li kГғВӘleka deryayГғВӘ plan dikin."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Planujemy letni urlop nad morzem."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "Ne planificГ„Ж’m concediul de varГ„Ж’ la mare."
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗЕ“Г‘вҖ№ ГҗВҝГҗВ»ГҗВ°ГҗВҪГҗВёГ‘вӮ¬Г‘Ж’ГҗВөГҗВј ГҗВ»ГҗВөГ‘вҖҡГҗВҪГҗВёГҗВ№ ГҗВҫГ‘вҖҡГҗВҝГ‘Ж’Г‘ВҒГҗВә Г‘Ж’ ГҗВјГҗВҫГ‘вӮ¬Г‘ВҸ."
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "Po planifikojmГғВ« pushimin tonГғВ« veror pranГғВ« detit."
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "Yaz tatilimizi deniz kenarГ„Вұnda planlГ„Вұyoruz."
                                                                  }
                                                              ]
                                         },
                                         {
                                             "baseText":  "Mein Sommerurlaub dauert zwei Wochen.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҳВӘГҳВіГҳВӘГҷвҖҰГҳВұ ГҳВҘГҳВ¬ГҳВ§ГҳВІГҳВӘГҷЕ  ГҳВ§ГҷвҖһГҳВөГҷЕ ГҷВҒГҷЕ ГҳВ© ГҳВЈГҳВіГҳВЁГҷЛҶГҳВ№ГҷЕ ГҷвҖ ."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҷВҫГҳВҙГҷЛҶГҷЛҶГӣЕ’ ГҷвҖЎГҳВ§ГҷЛҶГӣЕ’ГҷвҖ ГҷвҖҰ ГҳВҜГҷЛҶГҷЛҶ ГҷвҖЎГӣвҖўГҷВҒГҳВӘГӣвҖў ГҳВҜГӣвҖўГҳВ®ГҳВ§ГӣЕ’ГӣвҖўГҷвҖ ГӣЕҪГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "My summer vacation lasts two weeks."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҳВӘГҳВ№ГҳВ·ГӣЕ’ГҷвҖһГҳВ§ГҳВӘ ГҳВӘГҳВ§ГҳВЁГҳВіГҳВӘГҳВ§ГҷвҖ ГӣЕ’ ГҷвҖҰГҷвҖ  ГҳВҜГҷЛҶ ГҷвҖЎГҷВҒГҳВӘГҷвҖЎ ГҳВ·ГҷЛҶГҷвҖһ ГҷвҖҰГӣЕ’ГўвӮ¬Е’ГҡВ©ГҳВҙГҳВҜ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "Betlaneya min a havГғВ®nГғВӘ du hefte dom dike."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "MГғВіj letni urlop trwa dwa tygodnie."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "Concediul meu de varГ„Ж’ dureazГ„Ж’ douГ„Ж’ sГ„Ж’ptГ„Ж’mГғВўni."
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗЕ“ГҗВҫГҗВ№ ГҗВ»ГҗВөГ‘вҖҡГҗВҪГҗВёГҗВ№ ГҗВҫГ‘вҖҡГҗВҝГ‘Ж’Г‘ВҒГҗВә ГҗВҙГҗВ»ГҗВёГ‘вҖҡГ‘ВҒГ‘ВҸ ГҗВҙГҗВІГҗВө ГҗВҪГҗВөГҗВҙГҗВөГҗВ»ГҗВё."
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "Pushimi im veror zgjat dy javГғВ«."
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "Yaz tatilim iki hafta sГғВјrГғВјyor."
                                                                  }
                                                              ]
                                         }
