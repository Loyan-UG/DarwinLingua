                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҷЕ ГҳВЁГҳВҜГҳВЈ ГҳВ§ГҷвҖһГҳВҙГҳВұГҳВЁ ГҷвҖҰГҷвҖ  ГҳВҙГҷЕ ГҳВЎГҳвҖә ГҷЕ ГҳВҙГҳВұГҳВЁ ГҷвҖ ГҳВ®ГҳВЁГҷвҖ№ГҳВ§"
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҳВҜГӣвҖўГҳВіГҳВӘ ГҳВҜГӣвҖўГҡВ©ГҳВ§ГҳВӘ ГҳВЁГӣвҖў ГҳВ®ГҷЛҶГҳВ§ГҳВұГҳВҜГҷвҖ ГӣвҖўГҷЛҶГӣвҖўГҳвҖә ГҳВЁГӣвҖ ГҷвҖ ГӣвҖўГӣЕ’ГӣвҖўГҡВ© ГҳВЁГӣвҖў ГҳВ®ГҷЛҶГҳВ§ГҳВұГҳВҜГҷвҖ ГӣвҖўГҷЛҶГӣвҖў ГҷвҖ ГӣЕ’ГҳВҙГҳВ§ГҷвҖ  ГҳВҜГӣвҖўГҳВҜГҳВ§ГҳВӘ"
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "to start drinking; to drink a toast"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҳВҙГҳВұГҷЛҶГҳВ№ ГҳВЁГҷвҖЎ ГҷвҖ ГҷЛҶГҳВҙГӣЕ’ГҳВҜГҷвҖ  ГҡВ©ГҳВұГҳВҜГҷвҖ ГҳвҖә ГҳВЁГҷвҖЎ ГҳВіГҷвҖһГҳВ§ГҷвҖҰГҳВӘГӣЕ’ ГҡвҖ ГӣЕ’ГҳВІГӣЕ’ ГҷвҖ ГҷЛҶГҳВҙГӣЕ’ГҳВҜГҷвҖ "
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "dest bi vexwarinГғВӘ kirin; ji bo tiГ…Еёtek vexwarin"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "nadpiГ„вҖЎ; wznieГ…вҖәГ„вҖЎ toast"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "a ГғВ®ncepe sГ„Ж’ bei; a ГғВ®nchina"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "ГҗВҪГҗВ°Г‘вҖЎГҗВ°Г‘вҖҡГ‘Е’ ГҗВҝГҗВёГ‘вҖҡГ‘Е’; ГҗВІГ‘вҖ№ГҗВҝГҗВёГ‘вҖҡГ‘Е’ ГҗВ·ГҗВ° Г‘вҖЎГ‘вҖҡГҗВҫ-Г‘вҖҡГҗВҫ"
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "tГғВ« fillosh tГғВ« pish; tГғВ« ngresh dolli"
                                         },
                                         {
                                             "language":  "tr",
                                             "text":  "iГғВ§meye baГ…Еёlamak; kadeh kaldГ„Вұrmak"
                                         }
