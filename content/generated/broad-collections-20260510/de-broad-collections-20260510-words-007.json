    "entries":  [
                    {
                        "word":  "die Aufenthaltsgenehmigung",
                        "language":  "de",
                        "cefrLevel":  "B1",
                        "partOfSpeech":  "Noun",
                        "lexicalForms":  [
                                             {
                                                 "partOfSpeech":  "Noun",
                                                 "article":  "die",
                                                 "plural":  "Aufenthaltsgenehmigungen",
                                                 "infinitive":  null,
                                                 "isPrimary":  true
                                             }
                                         ],
                        "topics":  [
                                       "everyday-life"
                                   ],
                        "meanings":  [
                                         {
                                             "language":  "ar",
                                             "text":  "ГҳВӘГҳВөГҳВұГҷЕ ГҳВӯ ГҳВҘГҷвҖҡГҳВ§ГҷвҖҰГҳВ©ГҳвҖә ГҳВҘГҳВ°ГҷвҖ  ГҳВҘГҷвҖҡГҳВ§ГҷвҖҰГҳВ©"
                                         },
                                         {
                                             "language":  "ckb",
                                             "text":  "ГҷвҖҰГӣвҖ ГҡВөГӣвҖўГҳВӘГӣЕ’ ГҷвҖҰГҳВ§ГҷвҖ ГӣвҖўГҷЛҶГӣвҖўГҳвҖә ГҡвҖўГӣЕҪГҷВҫГӣЕҪГҳВҜГҳВ§ГҷвҖ ГӣЕ’ ГҷвҖ ГӣЕ’ГҳВҙГҳВӘГӣвҖўГҳВ¬ГӣЕҪГҳВЁГҷЛҶГҷЛҶГҷвҖ "
                                         },
                                         {
                                             "language":  "en",
                                             "text":  "residence permit; residence authorization"
                                         },
                                         {
                                             "language":  "fa",
                                             "text":  "ГҳВ§ГҳВ¬ГҳВ§ГҳВІГҷвҖЎ ГҳВ§ГҷвҖҡГҳВ§ГҷвҖҰГҳВӘГҳвҖә ГҷвҖҰГҳВ¬ГҷЛҶГҳВІ ГҳВ§ГҷвҖҡГҳВ§ГҷвҖҰГҳВӘ"
                                         },
                                         {
                                             "language":  "kmr",
                                             "text":  "destГғВ»ra rГғВ»niГ…ЕёtinГғВӘ; mГӣвҖ ГҡВөГӣвҖўГҳВӘГӣЕ’ ГҷвҖҰГҳВ§ГҷвҖ ГӣвҖўГҷЛҶГӣвҖў"
                                         },
                                         {
                                             "language":  "pl",
                                             "text":  "zezwolenie na pobyt"
                                         },
                                         {
                                             "language":  "ro",
                                             "text":  "permis de ГҲв„ўedere"
                                         },
                                         {
                                             "language":  "ru",
                                             "text":  "Г‘вӮ¬ГҗВ°ГҗВ·Г‘вӮ¬ГҗВөГ‘ЛҶГҗВөГҗВҪГҗВёГҗВө ГҗВҪГҗВ° ГҗВҝГ‘вӮ¬ГҗВөГҗВұГ‘вҖ№ГҗВІГҗВ°ГҗВҪГҗВёГҗВө; ГҗВІГҗВёГҗВҙ ГҗВҪГҗВ° ГҗВ¶ГҗВёГ‘вҖҡГҗВөГҗВ»Г‘Е’Г‘ВҒГ‘вҖҡГҗВІГҗВҫ"
                                         },
                                         {
                                             "language":  "sq",
                                             "text":  "leje qГғВ«ndrimi"
                                         },
                                         {
                                             "language":  "tr",
                                             "text":  "oturma izni"
                                         }
                                     ],
                        "examples":  [
                                         {
                                             "baseText":  "FГғВјr die VerlГғВӨngerung der Aufenthaltsgenehmigung brauchen Sie einen Termin beim Amt.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҷвҖһГҳВӘГҷвҖҰГҳВҜГҷЕ ГҳВҜ ГҳВӘГҳВөГҳВұГҷЕ ГҳВӯ ГҳВ§ГҷвҖһГҳВҘГҷвҖҡГҳВ§ГҷвҖҰГҳВ© ГҳВӘГҳВӯГҳВӘГҳВ§ГҳВ¬ГҷЛҶГҷвҖ  ГҳВҘГҷвҖһГҷвҖ° ГҷвҖҰГҷЛҶГҳВ№ГҳВҜ ГҷвҖһГҳВҜГҷвҖ° ГҳВ§ГҷвҖһГҳВҜГҳВ§ГҳВҰГҳВұГҳВ©."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҳВЁГӣвҖ  ГҳВҜГҳВұГӣЕҪГҡЛңГҡВ©ГҳВұГҳВҜГҷвҖ ГӣвҖўГҷЛҶГӣвҖўГӣЕ’ ГҷвҖҰГӣвҖ ГҡВөГӣвҖўГҳВӘГӣЕ’ ГҷвҖҰГҳВ§ГҷвҖ ГӣвҖўГҷЛҶГӣвҖў ГҷВҫГӣЕҪГҷЛҶГӣЕ’ГҳВіГҳВӘГҳВӘГҳВ§ГҷвҖ  ГҳВЁГӣвҖў ГҡВ©ГҳВ§ГҳВӘГӣЕҪГҡВ© ГҷвҖһГӣвҖў ГҷВҒГӣвҖўГҳВұГҷвҖҰГҳВ§ГҷвҖ ГҡВҜГӣвҖў ГҷвҖЎГӣвҖўГӣЕ’ГӣвҖў."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "To extend the residence permit, you need an appointment at the office."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҳВЁГҳВұГҳВ§ГӣЕ’ ГҳВӘГҷвҖҰГҳВҜГӣЕ’ГҳВҜ ГҳВ§ГҳВ¬ГҳВ§ГҳВІГҷвҖЎ ГҳВ§ГҷвҖҡГҳВ§ГҷвҖҰГҳВӘ ГҳВЁГҷвҖЎ ГҷЛҶГҷвҖҡГҳВӘ ГҷвҖҡГҳВЁГҷвҖһГӣЕ’ ГҳВҜГҳВұ ГҳВ§ГҳВҜГҳВ§ГҳВұГҷвҖЎ ГҷвҖ ГӣЕ’ГҳВ§ГҳВІ ГҳВҜГҳВ§ГҳВұГӣЕ’ГҳВҜ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "Ji bo dirГғВӘjkirina destГғВ»ra rГғВ»niГ…ЕёtinГғВӘ, hГғВ»n hewceyГғВӘ randevГғВ»yekГғВӘ li dezgehГғВӘ ne."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Do przedГ…вҖҡuГ…Вјenia zezwolenia na pobyt potrzebny jest termin w urzГ„в„ўdzie."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "Pentru prelungirea permisului de ГҲв„ўedere aveГҲвҖәi nevoie de o programare la oficiu."
                                                                  },
                                                                  {
                                                                      "language":  "ru",
                                                                      "text":  "ГҗвҖқГҗВ»Г‘ВҸ ГҗВҝГ‘вӮ¬ГҗВҫГҗВҙГҗВ»ГҗВөГҗВҪГҗВёГ‘ВҸ ГҗВІГҗВёГҗВҙГҗВ° ГҗВҪГҗВ° ГҗВ¶ГҗВёГ‘вҖҡГҗВөГҗВ»Г‘Е’Г‘ВҒГ‘вҖҡГҗВІГҗВҫ ГҗВІГҗВ°ГҗВј ГҗВҪГ‘Ж’ГҗВ¶ГҗВҪГҗВ° ГҗВ·ГҗВ°ГҗВҝГҗВёГ‘ВҒГ‘Е’ ГҗВІ ГҗВІГҗВөГҗВҙГҗВҫГҗВјГ‘ВҒГ‘вҖҡГҗВІГҗВҫ."
                                                                  },
                                                                  {
                                                                      "language":  "sq",
                                                                      "text":  "PГғВ«r zgjatjen e lejes sГғВ« qГғВ«ndrimit ju duhet njГғВ« takim nГғВ« zyrГғВ«."
                                                                  },
                                                                  {
                                                                      "language":  "tr",
                                                                      "text":  "Oturma iznini uzatmak iГғВ§in daireden randevu almanГ„Вұz gerekir."
                                                                  }
                                                              ]
                                         },
                                         {
                                             "baseText":  "Ohne Aufenthaltsgenehmigung kann sie den Arbeitsvertrag noch nicht unterschreiben.",
                                             "translations":  [
                                                                  {
                                                                      "language":  "ar",
                                                                      "text":  "ГҷвҖҰГҷвҖ  ГҳВҜГҷЛҶГҷвҖ  ГҳВӘГҳВөГҳВұГҷЕ ГҳВӯ ГҳВҘГҷвҖҡГҳВ§ГҷвҖҰГҳВ© ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ ГҷвҖЎГҳВ§ ГҳВЁГҳВ№ГҳВҜ ГҳВӘГҷЛҶГҷвҖҡГҷЕ ГҳВ№ ГҳВ№ГҷвҖҡГҳВҜ ГҳВ§ГҷвҖһГҳВ№ГҷвҖҰГҷвҖһ."
                                                                  },
                                                                  {
                                                                      "language":  "ckb",
                                                                      "text":  "ГҳВЁГӣвҖўГҳВЁГӣЕҪ ГҷвҖҰГӣвҖ ГҡВөГӣвҖўГҳВӘГӣЕ’ ГҷвҖҰГҳВ§ГҷвҖ ГӣвҖўГҷЛҶГӣвҖў ГҷвҖ ГҳВ§ГҳВӘГҷЛҶГҳВ§ГҷвҖ ГӣЕҪГҳВӘ ГҷвҖЎГӣЕҪГҳВҙГҳВӘГҳВ§ ГҡВҜГҳВұГӣЕҪГҳВЁГӣвҖўГҳВіГҳВӘГӣЕ’ ГҡВ©ГҳВ§ГҳВұ ГҷЛҶГҳВ§ГҡЛңГӣвҖ  ГҳВЁГҡВ©ГҳВ§ГҳВӘ."
                                                                  },
                                                                  {
                                                                      "language":  "en",
                                                                      "text":  "Without a residence permit, she cannot sign the employment contract yet."
                                                                  },
                                                                  {
                                                                      "language":  "fa",
                                                                      "text":  "ГҳВЁГҳВҜГҷЛҶГҷвҖ  ГҳВ§ГҳВ¬ГҳВ§ГҳВІГҷвҖЎ ГҳВ§ГҷвҖҡГҳВ§ГҷвҖҰГҳВӘГҳЕ’ ГҳВ§ГҷЛҶ ГҷвҖЎГҷвҖ ГҷЛҶГҳВІ ГҷвҖ ГҷвҖҰГӣЕ’ГўвӮ¬Е’ГҳВӘГҷЛҶГҳВ§ГҷвҖ ГҳВҜ ГҷвҖҡГҳВұГҳВ§ГҳВұГҳВҜГҳВ§ГҳВҜ ГҡВ©ГҳВ§ГҳВұ ГҳВұГҳВ§ ГҳВ§ГҷвҖҰГҳВ¶ГҳВ§ ГҡВ©ГҷвҖ ГҳВҜ."
                                                                  },
                                                                  {
                                                                      "language":  "kmr",
                                                                      "text":  "BГғВӘ destГғВ»ra rГғВ»niГ…ЕёtinГғВӘ, ew hГғВ®n nikare peymana karГғВӘ ГғВ®mze bike."
                                                                  },
                                                                  {
                                                                      "language":  "pl",
                                                                      "text":  "Bez zezwolenia na pobyt nie moГ…Вјe jeszcze podpisaГ„вҖЎ umowy o pracГ„в„ў."
                                                                  },
                                                                  {
                                                                      "language":  "ro",
                                                                      "text":  "FГ„Ж’rГ„Ж’ permis de ГҲв„ўedere, ГғВ®ncГ„Ж’ nu poate semna contractul de muncГ„Ж’."
                                                                  },
                                                                  {
