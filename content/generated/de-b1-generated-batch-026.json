  "entries": [
    {
      "word": "die Behandlung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Behandlungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-hand-lung",
      "topics": [
        "healthcare-and-appointments",
        "customer-service",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "business"
      ],
      "contextLabels": [
        "healthcare",
        "customer-service",
        "hr"
      ],
      "grammarNotes": [
        "feminine noun",
        "means medical treatment or the way a person/topic is handled"
      ],
      "collocations": [
        {
          "text": "medizinische Behandlung",
          "meaning": "medical treatment"
        },
        {
          "text": "faire Behandlung",
          "meaning": "fair treatment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "behandeln",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "علاج؛ معاملة؛ معالجة"
        },
        {
          "language": "ckb",
          "text": "چارەسەر؛ مامەڵە؛ پزیشکی کردن"
        },
        {
          "language": "en",
          "text": "treatment; handling"
        },
        {
          "language": "fa",
          "text": "درمان؛ برخورد؛ رسیدگی"
        },
        {
          "language": "kmr",
          "text": "derman; reftar; pêvajokirin"
        },
        {
          "language": "pl",
          "text": "leczenie; traktowanie"
        },
        {
          "language": "ro",
          "text": "tratament; tratare"
        },
        {
          "language": "ru",
          "text": "лечение; обращение; рассмотрение"
        },
        {
          "language": "sq",
          "text": "trajtim; mjekim"
        },
        {
          "language": "tr",
          "text": "tedavi; muamele; ele alma"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Behandlung soll der Patient noch eine Stunde in der Praxis bleiben.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد العلاج ينبغي أن يبقى المريض ساعة أخرى في العيادة."
            },
            {
              "language": "ckb",
              "text": "دوای چارەسەرەکە نەخۆشەکە دەبێت کاتژمێرێکی تر لە کلینیکەکە بمێنێتەوە."
            },
            {
              "language": "en",
              "text": "After the treatment, the patient should stay at the practice for another hour."
            },
            {
              "language": "fa",
              "text": "بعد از درمان، بیمار باید یک ساعت دیگر در مطب بماند."
            },
            {
              "language": "kmr",
              "text": "Piştî dermankirinê, nexweş divê saetek din li praksîsê bimîne."
            },
            {
              "language": "pl",
              "text": "Po leczeniu pacjent powinien zostać w gabinecie jeszcze godzinę."
            },
            {
              "language": "ro",
              "text": "După tratament, pacientul trebuie să mai rămână o oră în cabinet."
            },
            {
              "language": "ru",
              "text": "После лечения пациенту следует остаться в клинике ещё на час."
            },
            {
              "language": "sq",
              "text": "Pas trajtimit, pacienti duhet të qëndrojë edhe një orë në ordinancë."
            },
            {
              "language": "tr",
              "text": "Tedaviden sonra hasta muayenehanede bir saat daha kalmalı."
            }
          ]
        },
        {
          "baseText": "Alle Beschwerden verdienen eine faire und schnelle Behandlung.",
          "translations": [
            {
              "language": "ar",
              "text": "كل الشكاوى تستحق معالجة عادلة وسريعة."
            },
            {
              "language": "ckb",
              "text": "هەموو سکاڵاکان شایانی مامەڵەیەکی دادپەروەرانە و خێران."
            },
            {
              "language": "en",
              "text": "All complaints deserve fair and quick handling."
            },
            {
              "language": "fa",
              "text": "همه شکایت‌ها سزاوار رسیدگی عادلانه و سریع هستند."
            },
            {
              "language": "kmr",
              "text": "Hemû gilî hêjayî pêvajoyeke dadmend û zû ne."
            },
            {
              "language": "pl",
              "text": "Wszystkie skargi zasługują na uczciwe i szybkie rozpatrzenie."
            },
            {
              "language": "ro",
              "text": "Toate reclamațiile merită o tratare corectă și rapidă."
            },
            {
              "language": "ru",
              "text": "Все жалобы заслуживают справедливого и быстрого рассмотрения."
            },
