      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive verb; sich nach/über etwas erkundigen"
      ],
      "collocations": [
        {
          "text": "sich nach den Öffnungszeiten erkundigen",
          "meaning": "to ask about the opening hours"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erkundigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يستعلم؛ يسأل عن"
        },
        {
          "language": "ckb",
          "text": "پرسیار دەکات؛ زانیاری دەوێت"
        },
        {
          "language": "en",
          "text": "to ask; to inquire"
        },
        {
          "language": "fa",
          "text": "پرس‌وجو کردن؛ سؤال کردن درباره"
        },
        {
          "language": "kmr",
          "text": "pirsîn; agahî xwestin"
        },
        {
          "language": "pl",
          "text": "dowiadywać się; pytać"
        },
        {
          "language": "ro",
          "text": "a se interesa; a întreba"
        },
        {
          "language": "ru",
          "text": "справляться; узнавать"
        },
        {
          "language": "sq",
          "text": "të pyesësh; të interesohesh"
        },
        {
          "language": "tr",
          "text": "bilgi almak; sormak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte mich nach den Öffnungszeiten erkundigen.",
          "translations": [
            {
              "language": "ar",
              "text": "أود أن أستعلم عن أوقات العمل."
            },
            {
              "language": "ckb",
              "text": "دەمەوێت دەربارەی کاتەکانی کردنەوە پرسیار بکەم."
            },
            {
              "language": "en",
              "text": "I would like to ask about the opening hours."
            },
            {
              "language": "fa",
              "text": "می‌خواهم درباره ساعت‌های کاری پرس‌وجو کنم."
            },
            {
              "language": "kmr",
              "text": "Ez dixwazim li ser demên vekirinê bipirsim."
            },
            {
              "language": "pl",
              "text": "Chciałbym zapytać o godziny otwarcia."
            },
            {
              "language": "ro",
              "text": "Aș dori să mă interesez despre program."
            },
            {
              "language": "ru",
              "text": "Я хотел бы узнать часы работы."
            },
            {
              "language": "sq",
              "text": "Do të doja të pyes për orarin e hapjes."
            },
            {
              "language": "tr",
              "text": "Açılış saatleri hakkında bilgi almak istiyorum."
            }
          ]
        },
        {
          "baseText": "Sie erkundigt sich am Empfang nach dem Termin.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تسأل عند الاستقبال عن الموعد."
            },
            {
              "language": "ckb",
              "text": "ئەو لە پێشوازی دەربارەی کاتەکە پرسیار دەکات."
            },
            {
              "language": "en",
              "text": "She asks at reception about the appointment."
            },
            {
              "language": "fa",
              "text": "او در پذیرش درباره وقت ملاقات سؤال می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ew li pêşwaziyê li ser demê dipirse."
            },
            {
              "language": "pl",
              "text": "Ona pyta w recepcji o termin."
            },
            {
              "language": "ro",
              "text": "Ea întreabă la recepție despre programare."
            },
            {
              "language": "ru",
              "text": "Она спрашивает на ресепшене о встрече."
            },
            {
              "language": "sq",
              "text": "Ajo pyet në recepsion për takimin."
            },
            {
              "language": "tr",
              "text": "Resepsiyonda randevu hakkında bilgi alıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "sich verlaufen",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "sich verlaufen",
      "pronunciationIpa": null,
      "syllableBreak": "sich ver-lau-fen",
      "topics": [
        "transport-and-travel",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive verb; irregular: läuft sich, verlief sich, hat sich verlaufen"
      ],
      "collocations": [
        {
          "text": "sich in der Stadt verlaufen",
          "meaning": "to get lost in the city"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verlaufen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يضل الطريق"
        },
        {
          "language": "ckb",
          "text": "ڕێگا ون دەکات"
        },
        {
          "language": "en",
          "text": "to get lost"
        },
        {
          "language": "fa",
          "text": "گم شدن؛ راه را گم کردن"
        },
        {
          "language": "kmr",
          "text": "rê winda kirin"
        },
        {
          "language": "pl",
          "text": "zgubić się"
        },
        {
          "language": "ro",
          "text": "a se rătăci"
        },
        {
          "language": "ru",
          "text": "заблудиться"
        },
        {
          "language": "sq",
          "text": "të humbasësh rrugën"
        },
        {
          "language": "tr",
          "text": "yolunu kaybetmek"
        }
      ],
      "examples": [
        {
          "baseText": "Wir haben uns in der Altstadt verlaufen.",
          "translations": [
            {
              "language": "ar",
              "text": "ضللنا الطريق في المدينة القديمة."
            },
            {
              "language": "ckb",
              "text": "ئێمە لە شارە کۆنەکەدا ڕێگامان ون کرد."
            },
            {
              "language": "en",
              "text": "We got lost in the old town."
            },
            {
              "language": "fa",
              "text": "ما در شهر قدیمی گم شدیم."
            },
            {
              "language": "kmr",
              "text": "Me li bajarê kevn rê winda kir."
            },
            {
              "language": "pl",
              "text": "Zgubiliśmy się na starym mieście."
            },
            {
              "language": "ro",
              "text": "Ne-am rătăcit în orașul vechi."
            },
            {
              "language": "ru",
              "text": "Мы заблудились в старом городе."
            },
            {
              "language": "sq",
              "text": "Ne humbëm rrugën në qytetin e vjetër."
            },
            {
              "language": "tr",
              "text": "Eski şehirde yolumuzu kaybettik."
            }
          ]
        },
        {
          "baseText": "Wenn du dich verläufst, ruf mich bitte an.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا ضللت الطريق فاتصل بي من فضلك."
            },
            {
              "language": "ckb",
              "text": "ئەگەر ڕێگات ون کرد، تکایە پەیوەندیم پێوە بکە."
            },
            {
              "language": "en",
              "text": "If you get lost, please call me."
            },
            {
              "language": "fa",
              "text": "اگر گم شدی، لطفاً به من زنگ بزن."
            },
            {
              "language": "kmr",
              "text": "Ger tu rê winda bikî, ji kerema xwe telefonî min bike."
            },
            {
              "language": "pl",
              "text": "Jeśli się zgubisz, zadzwoń do mnie proszę."
            },
            {
              "language": "ro",
              "text": "Dacă te rătăcești, sună-mă, te rog."
            },
            {
              "language": "ru",
              "text": "Если заблудишься, пожалуйста, позвони мне."
            },
            {
              "language": "sq",
              "text": "Nëse humbet rrugën, të lutem më telefono."
            },
            {
              "language": "tr",
              "text": "Yolunu kaybedersen lütfen beni ara."
            }
          ]
        }
      ]
    },
