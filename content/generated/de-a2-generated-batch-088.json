      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يخطب؛ تتم الخطوبة"
        },
        {
          "language": "ckb",
          "text": "مارەبڕین دەکات؛ دەبێتە نامزاد"
        },
        {
          "language": "en",
          "text": "to get engaged"
        },
        {
          "language": "fa",
          "text": "نامزد کردن؛ نامزد شدن"
        },
        {
          "language": "kmr",
          "text": "destnîşan bûn"
        },
        {
          "language": "pl",
          "text": "zaręczyć się"
        },
        {
          "language": "ro",
          "text": "a se logodi"
        },
        {
          "language": "ru",
          "text": "обручиться"
        },
        {
          "language": "sq",
          "text": "të fejohesh"
        },
        {
          "language": "tr",
          "text": "nişanlanmak"
        }
      ],
      "examples": [
        {
          "baseText": "Meine Schwester hat sich im Urlaub verlobt.",
          "translations": [
            {
              "language": "ar",
              "text": "خطبت أختي أثناء العطلة."
            },
            {
              "language": "ckb",
              "text": "خوشکەکەم لە پشوودا نامزاد بوو."
            },
            {
              "language": "en",
              "text": "My sister got engaged during her vacation."
            },
            {
              "language": "fa",
              "text": "خواهرم در تعطیلات نامزد کرد."
            },
            {
              "language": "kmr",
              "text": "Xwişka min di betlaneyê de destnîşan bû."
            },
            {
              "language": "pl",
              "text": "Moja siostra zaręczyła się na urlopie."
            },
            {
              "language": "ro",
              "text": "Sora mea s-a logodit în vacanță."
            },
            {
              "language": "ru",
              "text": "Моя сестра обручилась в отпуске."
            },
            {
              "language": "sq",
              "text": "Motra ime u fejua gjatë pushimeve."
            },
            {
              "language": "tr",
              "text": "Kız kardeşim tatilde nişanlandı."
            }
          ]
        },
        {
          "baseText": "Sie möchten sich nächstes Jahr verloben.",
          "translations": [
            {
              "language": "ar",
              "text": "يريدان أن يخطبا العام القادم."
            },
            {
              "language": "ckb",
              "text": "ئەوان دەیانەوێت ساڵی داهاتوو نامزاد ببن."
            },
            {
              "language": "en",
              "text": "They want to get engaged next year."
            },
            {
              "language": "fa",
              "text": "آن‌ها می‌خواهند سال آینده نامزد کنند."
            },
            {
              "language": "kmr",
              "text": "Ew dixwazin sala bê destnîşan bibin."
            },
            {
              "language": "pl",
              "text": "Oni chcą się zaręczyć w przyszłym roku."
            },
            {
              "language": "ro",
              "text": "Ei vor să se logodească anul viitor."
            },
            {
              "language": "ru",
              "text": "Они хотят обручиться в следующем году."
            },
            {
              "language": "sq",
              "text": "Ata duan të fejohen vitin e ardhshëm."
            },
            {
              "language": "tr",
              "text": "Gelecek yıl nişanlanmak istiyorlar."
            }
          ]
        }
      ]
    },
