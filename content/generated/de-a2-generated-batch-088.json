      "collocations": [
        {
          "text": "sich mit jemandem verloben",
          "meaning": "to get engaged to someone"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Verlobung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "verlobt",
          "relationLabel": "adjective/participle",
