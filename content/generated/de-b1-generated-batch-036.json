      "meanings": [
        {
          "language": "ar",
          "text": "متقدمة؛ مرشحة"
        },
        {
          "language": "ckb",
          "text": "داواکاری ژن؛ کاندیدی ژن"
        },
        {
          "language": "en",
          "text": "female applicant; female candidate"
        },
        {
          "language": "fa",
          "text": "متقاضی زن؛ داوطلب زن"
        },
        {
          "language": "kmr",
          "text": "berendama jin; daxwazkara jin"
        },
        {
          "language": "pl",
          "text": "kandydatka; aplikantka"
        },
        {
          "language": "ro",
          "text": "candidată; solicitantă"
        },
        {
          "language": "ru",
