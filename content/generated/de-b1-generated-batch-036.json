      "grammarNotes": [
        "masculine noun; person applying for a job or position"
      ],
      "collocations": [
        {
          "text": "einen Bewerber zum Gespräch einladen",
          "meaning": "to invite an applicant to an interview"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sich bewerben",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Bewerbung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متقدم؛ مرشح"
        },
        {
          "language": "ckb",
          "text": "داواکار؛ کاندید"
        },
        {
          "language": "en",
          "text": "applicant; candidate"
        },
        {
          "language": "fa",
          "text": "متقاضی؛ داوطلب"
        },
        {
          "language": "kmr",
          "text": "berendam; daxwazkar"
        },
        {
          "language": "pl",
          "text": "kandydat; aplikant"
        },
        {
          "language": "ro",
          "text": "candidat; solicitant"
        },
        {
          "language": "ru",
          "text": "кандидат; соискатель"
        },
        {
          "language": "sq",
          "text": "aplikant; kandidat"
        },
        {
          "language": "tr",
          "text": "başvuran; aday"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bewerber bringt zum Gespräch seinen Lebenslauf und die Zeugnisse mit.",
          "translations": [
            {
              "language": "ar",
              "text": "يحضر المتقدم إلى المقابلة سيرته الذاتية والشهادات."
            },
            {
              "language": "ckb",
              "text": "داواکارەکە لە چاوپێکەوتنەکەدا ژیاننامە و بڕوانامەکانی لەگەڵ خۆی دەهێنێت."
            },
            {
              "language": "en",
              "text": "The applicant brings his CV and certificates to the interview."
            },
            {
              "language": "fa",
              "text": "متقاضی برای مصاحبه رزومه و مدارک خود را همراه می‌آورد."
            },
            {
              "language": "kmr",
              "text": "Daxwazkar CV û belgeyên xwe tîne hevpeyivînê."
            },
            {
              "language": "pl",
              "text": "Kandydat przynosi na rozmowę CV i świadectwa."
            },
            {
              "language": "ro",
              "text": "Candidatul aduce la interviu CV-ul și certificatele."
            },
            {
              "language": "ru",
              "text": "Кандидат приносит на собеседование резюме и документы."
            },
            {
              "language": "sq",
              "text": "Aplikanti sjell në intervistë CV-në dhe certifikatat e tij."
            },
            {
              "language": "tr",
              "text": "Aday görüşmeye özgeçmişini ve belgelerini getirir."
            }
          ]
        },
        {
          "baseText": "Ein Bewerber hat schon Erfahrung im Kundensupport.",
          "translations": [
            {
              "language": "ar",
              "text": "أحد المتقدمين لديه بالفعل خبرة في دعم العملاء."
            },
            {
              "language": "ckb",
              "text": "یەکێک لە داواکارەکان پێشتر ئەزموونی لە پاڵپشتی کڕیاراندا هەیە."
            },
            {
              "language": "en",
              "text": "One applicant already has experience in customer support."
            },
            {
              "language": "fa",
              "text": "یکی از متقاضیان قبلاً در پشتیبانی مشتری تجربه دارد."
            },
            {
              "language": "kmr",
              "text": "Berendamek berê ezmûna piştgiriya xerîdaran heye."
            },
            {
              "language": "pl",
              "text": "Jeden kandydat ma już doświadczenie w obsłudze klienta."
            },
            {
              "language": "ro",
              "text": "Un candidat are deja experiență în suportul pentru clienți."
            },
            {
              "language": "ru",
              "text": "Один кандидат уже имеет опыт в клиентской поддержке."
            },
            {
              "language": "sq",
              "text": "Një aplikant ka tashmë përvojë në mbështetjen e klientëve."
            },
            {
              "language": "tr",
              "text": "Bir adayın müşteri desteği alanında deneyimi var."
            }
          ]
        }
      ]
    },
