      "infinitive": "nachverfolgen",
      "topics": ["work-and-jobs"],
      "usageLabels": ["business"],
      "contextLabels": ["sales", "crm"],
      "meanings": [
        { "language": "en", "text": "to track; to follow up" },
        { "language": "fa", "text": "پیگیری کردن" }
      ],
      "examples": [
        {
          "baseText": "Alle offenen Punkte aus dem Demo-Termin werden im CRM nachverfolgt.",
