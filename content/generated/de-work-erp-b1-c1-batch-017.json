    {
      "word": "Zielkunde",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "lexicalForms": [{ "partOfSpeech": "Noun", "article": "der", "plural": "Zielkunden", "isPrimary": true }],
      "article": "der",
      "plural": "Zielkunden",
      "topics": ["work-and-jobs"],
      "usageLabels": ["business"],
      "contextLabels": ["sales", "crm"],
      "meanings": [
