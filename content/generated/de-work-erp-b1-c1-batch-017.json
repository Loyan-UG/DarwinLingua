      "topics": ["work-and-jobs"],
      "usageLabels": ["business"],
      "contextLabels": ["sales", "presentation"],
      "meanings": [
        { "language": "en", "text": "to argue; to present arguments" },
        { "language": "fa", "text": "استدلال کردن" }
      ],
      "examples": [
        {
          "baseText": "Im Termin müssen wir stärker über Nutzen und weniger über Funktionen argumentieren.",
          "translations": [
            { "language": "en", "text": "In the meeting, we need to argue more about benefits and less about features." },
            { "language": "fa", "text": "در جلسه باید بیشتر درباره مزایا و کمتر درباره قابلیت‌ها استدلال کنیم." }
          ]
        }
      ]
    },
    {
      "word": "entgegenkommen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "lexicalForms": [{ "partOfSpeech": "Verb", "infinitive": "entgegenkommen", "isPrimary": true }],
