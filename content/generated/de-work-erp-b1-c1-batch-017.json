        { "language": "fa", "text": "مشتری هدف" }
      ],
      "examples": [
        {
          "baseText": "Unser Zielkunde braucht meist CRM, Vertrieb und Lager in einem System.",
          "translations": [
            { "language": "en", "text": "Our target customer usually needs CRM, sales, and warehouse in one system." },
            { "language": "fa", "text": "مشتری هدف ما معمولاً CRM، فروش و انبار را در یک سیستم می‌خواهد." }
          ]
        }
      ]
    },
    {
