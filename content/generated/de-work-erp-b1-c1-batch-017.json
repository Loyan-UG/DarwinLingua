            { "language": "fa", "text": "پیش از جلسه با مشتری باید فضای مذاکره خود را دقیق مشخص کنیم." }
          ]
        }
      ]
    },
    {
      "word": "argumentieren",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "lexicalForms": [{ "partOfSpeech": "Verb", "infinitive": "argumentieren", "isPrimary": true }],
