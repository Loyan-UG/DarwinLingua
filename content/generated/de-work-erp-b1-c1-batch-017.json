        { "language": "fa", "text": "کوتاه آمدن، امتیاز دادن" }
      ],
      "examples": [
        {
          "baseText": "Wir können dem Kunden beim Starttermin entgegenkommen, aber nicht beim Leistungsumfang.",
          "translations": [
            { "language": "en", "text": "We can accommodate the customer on the start date, but not on the scope." },
            { "language": "fa", "text": "ما می‌توانیم درباره تاریخ شروع به مشتری امتیاز بدهیم، اما نه درباره دامنه خدمات." }
          ]
        }
      ]
    },
