      "topics": ["work-and-jobs"],
      "usageLabels": ["business"],
      "contextLabels": ["sales", "management"],
      "meanings": [
        { "language": "en", "text": "competitive" },
        { "language": "fa", "text": "رقابتی" }
      ],
      "examples": [
        {
          "baseText": "Unsere Lösung ist technisch stark und gleichzeitig wettbewerbsfähig kalkuliert.",
          "translations": [
            { "language": "en", "text": "Our solution is technically strong and priced competitively at the same time." },
            { "language": "fa", "text": "راه‌حل ما از نظر فنی قوی است و هم‌زمان به‌صورت رقابتی قیمت‌گذاری شده است." }
          ]
        }
      ]
