      ],
      "examples": [
        {
          "baseText": "Die Filialleiterin organisiert die Einarbeitung der neuen Mitarbeitenden.",
          "translations": [
            {
              "language": "ar",
              "text": "تنظم مديرة الفرع تدريب الموظفين الجدد."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری ژنی لق ڕاهێنانی کارمەندانی نوێ ڕێک دەخات."
            },
            {
              "language": "en",
              "text": "The branch manager organizes the onboarding of the new employees."
            },
            {
              "language": "fa",
              "text": "مدیر زن شعبه آموزش اولیه کارکنان جدید را سازمان‌دهی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Rêvebera şaxê hînbûna karmendên nû rêk dixe."
            },
            {
              "language": "pl",
              "text": "Kierowniczka oddziału organizuje wdrożenie nowych pracowników."
            },
            {
              "language": "ro",
              "text": "Directoarea de filială organizează integrarea noilor angajați."
            },
            {
              "language": "ru",
              "text": "Управляющая филиалом организует ввод новых сотрудников в работу."
            },
            {
              "language": "sq",
              "text": "Menaxherja e degës organizon integrimin e punonjësve të rinj."
            },
            {
              "language": "tr",
              "text": "Kadın şube müdürü yeni çalışanların işe alışma sürecini organize eder."
            }
          ]
        },
        {
          "baseText": "Die Kundin möchte mit der Filialleiterin über den Vertrag sprechen.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد العميلة التحدث مع مديرة الفرع حول العقد."
            },
            {
              "language": "ckb",
              "text": "کڕیارە ژنەکە دەیەوێت لەگەڵ بەڕێوەبەری ژنی لق دەربارەی گرێبەستەکە قسە بکات."
            },
            {
              "language": "en",
              "text": "The customer wants to speak with the branch manager about the contract."
            },
            {
              "language": "fa",
              "text": "مشتری زن می‌خواهد درباره قرارداد با مدیر شعبه صحبت کند."
            },
            {
              "language": "kmr",
              "text": "Xerîdara jin dixwaze bi rêvebera şaxê re li ser peymanê biaxive."
            },
            {
              "language": "pl",
              "text": "Klientka chce porozmawiać z kierowniczką oddziału o umowie."
            },
            {
              "language": "ro",
              "text": "Clienta dorește să vorbească cu directoarea filialei despre contract."
            },
            {
              "language": "ru",
              "text": "Клиентка хочет поговорить с управляющей филиалом о договоре."
            },
            {
              "language": "sq",
              "text": "Klientja dëshiron të flasë me menaxheren e degës për kontratën."
            },
            {
              "language": "tr",
              "text": "Kadın müşteri sözleşme hakkında kadın şube müdürüyle konuşmak istiyor."
            }
          ]
        }
      ]
    }
