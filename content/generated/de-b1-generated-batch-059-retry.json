      "meanings": [
        {
          "language": "ar",
          "text": "مدير الفرع"
        },
        {
          "language": "ckb",
          "text": "بەڕێوەبەری لق"
        },
        {
          "language": "en",
          "text": "branch manager"
        },
        {
          "language": "fa",
          "text": "مدیر شعبه"
        },
        {
          "language": "kmr",
          "text": "rêveberê şaxê"
        },
        {
          "language": "pl",
          "text": "kierownik oddziału"
        },
        {
          "language": "ro",
          "text": "director de filială"
        },
        {
          "language": "ru",
          "text": "управляющий филиалом"
        },
        {
          "language": "sq",
          "text": "menaxher dege"
        },
        {
          "language": "tr",
          "text": "şube müdürü"
        }
      ],
      "examples": [
        {
          "baseText": "Der Filialleiter bespricht die Verkaufszahlen jeden Montag mit dem Team.",
          "translations": [
            {
              "language": "ar",
              "text": "يناقش مدير الفرع أرقام المبيعات كل يوم اثنين مع الفريق."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری لق هەموو دووشەممە ژمارەکانی فرۆشتن لەگەڵ تیمەکە تاوتوێ دەکات."
            },
            {
              "language": "en",
              "text": "The branch manager discusses the sales figures with the team every Monday."
            },
            {
              "language": "fa",
              "text": "مدیر شعبه هر دوشنبه ارقام فروش را با تیم بررسی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Rêveberê şaxê her duşem hejmarên firotanê bi tîmê re nîqaş dike."
            },
            {
              "language": "pl",
              "text": "Kierownik oddziału omawia wyniki sprzedaży z zespołem w każdy poniedziałek."
            },
            {
              "language": "ro",
              "text": "Directorul de filială discută cifrele de vânzări cu echipa în fiecare luni."
            },
            {
              "language": "ru",
              "text": "Управляющий филиалом каждый понедельник обсуждает с командой показатели продаж."
            },
            {
              "language": "sq",
              "text": "Menaxheri i degës diskuton shifrat e shitjeve me ekipin çdo të hënë."
            },
            {
              "language": "tr",
              "text": "Şube müdürü satış rakamlarını her pazartesi ekiple görüşür."
            }
          ]
        },
        {
          "baseText": "Bei einer Beschwerde können Sie sich direkt an den Filialleiter wenden.",
          "translations": [
            {
              "language": "ar",
              "text": "في حال وجود شكوى يمكنك التوجه مباشرة إلى مدير الفرع."
            },
            {
              "language": "ckb",
              "text": "لە کاتی سکاڵادا دەتوانن ڕاستەوخۆ پەیوەندی بە بەڕێوەبەری لق بکەن."
            },
            {
              "language": "en",
              "text": "In case of a complaint, you can contact the branch manager directly."
            },
            {
              "language": "fa",
              "text": "در صورت شکایت می‌توانید مستقیم به مدیر شعبه مراجعه کنید."
            },
            {
              "language": "kmr",
              "text": "Di rewşa gilî de hûn dikarin rasterast serî li rêveberê şaxê bidin."
            },
            {
              "language": "pl",
              "text": "W przypadku reklamacji można zwrócić się bezpośrednio do kierownika oddziału."
            },
            {
              "language": "ro",
              "text": "În cazul unei reclamații vă puteți adresa direct directorului de filială."
            },
            {
              "language": "ru",
              "text": "В случае жалобы вы можете напрямую обратиться к управляющему филиалом."
            },
            {
              "language": "sq",
              "text": "Në rast ankese mund t’i drejtoheni direkt menaxherit të degës."
            },
            {
              "language": "tr",
              "text": "Şikayet durumunda doğrudan şube müdürüne başvurabilirsiniz."
            }
          ]
        }
      ]
    },
