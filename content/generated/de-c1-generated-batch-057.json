      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يبتلع بسرعة؛ يلتهم على عجل"
        },
        {
          "language": "ckb",
          "text": "بە خێرایی دەیخوات؛ بە پەلە قووتی دەدات"
        },
        {
          "language": "en",
