        }
      ],
      "examples": [
        {
          "baseText": "Der Berater musste die mögliche Interessenkollision vor Vertragsabschluss offenlegen.",
          "translations": [
            {
              "language": "ar",
              "text": "كان على المستشار الإفصاح عن تضارب المصالح المحتمل قبل إبرام العقد."
            },
            {
