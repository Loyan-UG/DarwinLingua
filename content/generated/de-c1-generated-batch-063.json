  "entries": [
    {
      "word": "die Interessenabwägung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Interessenabwägungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "In-te-res-sen-ab-wä-gung",
      "topics": [
        "law-and-compliance",
        "management-and-leadership",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Interessenabwägungen"
      ],
      "collocations": [
        {
          "text": "eine Interessenabwägung vornehmen",
          "meaning": "to balance competing interests"
        },
        {
          "text": "sorgfältige Interessenabwägung",
          "meaning": "careful balancing of interests"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Interesse",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "abwägen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موازنة المصالح"
        },
        {
          "language": "ckb",
          "text": "هاوسەنگکردنی بەرژەوەندییەکان"
        },
        {
          "language": "en",
          "text": "balancing of interests"
        },
        {
          "language": "fa",
          "text": "سنجش و موازنه منافع"
        },
        {
          "language": "kmr",
          "text": "hevsengkirina berjewendiyan"
        },
        {
          "language": "pl",
          "text": "ważenie interesów"
        },
        {
          "language": "ro",
          "text": "punere în balanță a intereselor"
        },
        {
          "language": "ru",
          "text": "взвешивание интересов"
        },
        {
          "language": "sq",
          "text": "balancim interesash"
        },
        {
          "language": "tr",
          "text": "menfaatlerin dengelenmesi"
        }
      ],
      "examples": [
        {
          "baseText": "Vor der Veröffentlichung der Daten ist eine sorgfältige Interessenabwägung erforderlich.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل نشر البيانات يلزم إجراء موازنة دقيقة للمصالح."
            },
            {
              "language": "ckb",
              "text": "پێش بڵاوکردنەوەی داتاکان هاوسەنگکردنی وردی بەرژەوەندییەکان پێویستە."
            },
            {
              "language": "en",
              "text": "Before publishing the data, a careful balancing of interests is required."
            },
            {
              "language": "fa",
              "text": "پیش از انتشار داده‌ها، موازنه دقیق منافع لازم است."
            },
            {
              "language": "kmr",
              "text": "Berî weşandina daneyan hevsengkirina baldar a berjewendiyan pêwîst e."
            },
            {
              "language": "pl",
              "text": "Przed publikacją danych konieczne jest staranne wyważenie interesów."
            },
            {
              "language": "ro",
              "text": "Înainte de publicarea datelor este necesară o punere atentă în balanță a intereselor."
            },
            {
              "language": "ru",
              "text": "Перед публикацией данных требуется тщательное взвешивание интересов."
            },
            {
              "language": "sq",
              "text": "Para publikimit të të dhënave kërkohet balancim i kujdesshëm i interesave."
            },
            {
              "language": "tr",
              "text": "Veriler yayımlanmadan önce menfaatlerin dikkatli biçimde dengelenmesi gerekir."
            }
          ]
        },
        {
          "baseText": "Die Interessenabwägung zwischen schneller Lieferung und fairen Arbeitsbedingungen wurde im Bericht kaum erläutert.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يوضح التقرير تقريبًا موازنة المصالح بين التسليم السريع وظروف العمل العادلة."
            },
            {
              "language": "ckb",
              "text": "هاوسەنگکردنی نێوان گەیاندنی خێرا و مەرجی کاری دادپەروەرانە لە ڕاپۆرتەکەدا زۆر کەم ڕوونکراوەتەوە."
            },
            {
              "language": "en",
              "text": "The report barely explained the balancing of interests between fast delivery and fair working conditions."
            },
            {
              "language": "fa",
              "text": "در گزارش، موازنه میان تحویل سریع و شرایط کاری عادلانه به‌ندرت توضیح داده شده بود."
            },
            {
              "language": "kmr",
              "text": "Di raportê de hevsengkirina di navbera radestkirina lez û mercên kar ên dadperwer de pir kêm hatibû ravekirin."
            },
            {
              "language": "pl",
              "text": "W raporcie ledwo wyjaśniono wyważenie interesów między szybką dostawą a uczciwymi warunkami pracy."
            },
            {
              "language": "ro",
              "text": "Raportul a explicat foarte puțin echilibrarea intereselor dintre livrarea rapidă și condițiile de muncă echitabile."
            },
            {
              "language": "ru",
              "text": "В отчете почти не объяснялось взвешивание интересов между быстрой доставкой и справедливыми условиями труда."
            },
            {
              "language": "sq",
              "text": "Raporti pothuajse nuk e shpjegoi balancimin e interesave midis dorëzimit të shpejtë dhe kushteve të drejta të punës."
            },
            {
              "language": "tr",
              "text": "Raporda hızlı teslimat ile adil çalışma koşulları arasındaki menfaat dengesi neredeyse hiç açıklanmadı."
            }
          ]
        }
      ]
    },
    {
      "word": "die Interessengruppe",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Interessengruppen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "In-te-res-sen-grup-pe",
      "topics": [
        "public-services",
        "business-communication",
        "management-and-leadership"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; plural: die Interessengruppen"
      ],
      "collocations": [
        {
          "text": "eine betroffene Interessengruppe",
          "meaning": "an affected interest group"
        },
        {
          "text": "Interessengruppen einbeziehen",
          "meaning": "to involve interest groups"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Interesse",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Gruppe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مجموعة مصالح؛ جماعة ضغط"
        },
        {
          "language": "ckb",
          "text": "گرووپی بەرژەوەندی"
        },
        {
          "language": "en",
          "text": "interest group; stakeholder group"
        },
        {
          "language": "fa",
          "text": "گروه ذی‌نفع؛ گروه منافع"
        },
        {
          "language": "kmr",
          "text": "koma berjewendiyê"
        },
        {
          "language": "pl",
          "text": "grupa interesu"
        },
        {
          "language": "ro",
          "text": "grup de interese"
        },
        {
          "language": "ru",
          "text": "группа интересов"
        },
        {
          "language": "sq",
          "text": "grup interesi"
        },
        {
          "language": "tr",
          "text": "çıkar grubu"
        }
      ],
      "examples": [
        {
          "baseText": "Bei der Reform wurde keine zentrale Interessengruppe frühzeitig eingebunden.",
          "translations": [
            {
              "language": "ar",
              "text": "في الإصلاح لم تُشرك أي مجموعة مصالح مركزية في وقت مبكر."
            },
            {
              "language": "ckb",
              "text": "لە چاکسازییەکەدا هیچ گرووپی بەرژەوەندیی سەرەکی لە سەرەتادا بەشداری پێنەکرا."
            },
            {
              "language": "en",
              "text": "No central interest group was involved early in the reform."
            },
            {
              "language": "fa",
              "text": "در اصلاحات، هیچ گروه ذی‌نفع اصلی به‌موقع درگیر نشد."
            },
            {
              "language": "kmr",
              "text": "Di reformê de tu koma berjewendiyê ya sereke zû nehat tevlîkirin."
            },
            {
              "language": "pl",
              "text": "W reformie nie włączono wcześnie żadnej kluczowej grupy interesu."
            },
            {
              "language": "ro",
              "text": "În reformă nu a fost implicat din timp niciun grup de interese central."
            },
            {
              "language": "ru",
              "text": "В реформу заранее не была вовлечена ни одна ключевая группа интересов."
            },
            {
              "language": "sq",
              "text": "Në reformë nuk u përfshi herët asnjë grup qendror interesi."
            },
            {
              "language": "tr",
              "text": "Reformda hiçbir merkezi çıkar grubu erken aşamada dahil edilmedi."
            }
          ]
        },
        {
          "baseText": "Die Interessengruppe der kleinen Händler kritisierte die neuen Gebühren offen.",
          "translations": [
            {
              "language": "ar",
              "text": "انتقدت مجموعة مصالح التجار الصغار الرسوم الجديدة علنًا."
            },
            {
              "language": "ckb",
              "text": "گرووپی بەرژەوەندیی فرۆشیارە بچووکەکان بە ئاشکرا ڕەخنەیان لە باجە نوێیەکان گرت."
            },
            {
              "language": "en",
              "text": "The interest group of small retailers openly criticized the new fees."
            },
            {
              "language": "fa",
              "text": "گروه ذی‌نفع فروشندگان کوچک آشکارا از هزینه‌های جدید انتقاد کرد."
            },
            {
              "language": "kmr",
              "text": "Koma berjewendiyê ya firoşkarên biçûk bi eşkere rexne li xercên nû girt."
            },
            {
              "language": "pl",
              "text": "Grupa interesu małych sprzedawców otwarcie skrytykowała nowe opłaty."
            },
            {
              "language": "ro",
              "text": "Grupul de interese al micilor comercianți a criticat deschis noile taxe."
            },
            {
              "language": "ru",
              "text": "Группа интересов мелких торговцев открыто раскритиковала новые сборы."
            },
            {
              "language": "sq",
              "text": "Grupi i interesit i tregtarëve të vegjël kritikoi hapur tarifat e reja."
            },
            {
              "language": "tr",
              "text": "Küçük satıcıların çıkar grubu yeni ücretleri açıkça eleştirdi."
            }
          ]
        }
      ]
    },
