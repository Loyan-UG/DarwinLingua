      ],
      "examples": [
        {
          "baseText": "Unsere Klassenfahrt geht nach Hamburg.",
          "translations": [
            {
              "language": "ar",
              "text": "رحلتنا المدرسية إلى هامبورغ."
            },
            {
              "language": "ckb",
              "text": "گەشتی پۆلەکەمان بۆ هامبۆرگ دەچێت."
            },
            {
              "language": "en",
              "text": "Our class trip goes to Hamburg."
            },
            {
              "language": "fa",
              "text": "اردوی کلاسی ما به هامبورگ می‌رود."
            },
            {
              "language": "kmr",
              "text": "Gera pola me diçe Hamburgê."
            },
            {
              "language": "pl",
              "text": "Nasza wycieczka klasowa jest do Hamburga."
            },
            {
              "language": "ro",
              "text": "Excursia clasei noastre este la Hamburg."
            },
            {
              "language": "ru",
              "text": "Наша школьная поездка в Гамбург."
            },
            {
              "language": "sq",
              "text": "Udhëtimi i klasës sonë është për në Hamburg."
            },
            {
              "language": "tr",
              "text": "Sınıf gezimiz Hamburg’a."
            }
          ]
        },
        {
          "baseText": "Für die Klassenfahrt brauchen wir einen Rucksack.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج إلى حقيبة ظهر للرحلة المدرسية."
            },
            {
              "language": "ckb",
              "text": "بۆ گەشتی پۆل پێویستمان بە جانتای پشتە."
            },
            {
              "language": "en",
              "text": "We need a backpack for the class trip."
            },
            {
              "language": "fa",
              "text": "برای اردوی کلاسی به کوله‌پشتی نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo gera polê çenteyeke piştê divê me be."
            },
            {
              "language": "pl",
              "text": "Na wycieczkę klasową potrzebujemy plecaka."
            },
            {
              "language": "ro",
              "text": "Pentru excursia clasei avem nevoie de un rucsac."
            },
            {
              "language": "ru",
              "text": "Для школьной поездки нам нужен рюкзак."
            },
            {
              "language": "sq",
              "text": "Për udhëtimin e klasës na duhet një çantë shpine."
            },
            {
              "language": "tr",
              "text": "Sınıf gezisi için sırt çantasına ihtiyacımız var."
            }
          ]
        }
      ]
    },
