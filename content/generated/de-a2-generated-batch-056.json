        },
        {
          "language": "tr",
          "text": "sınıf sınavı; yazılı sınav"
        }
      ],
      "examples": [
        {
          "baseText": "Morgen schreiben wir eine Klassenarbeit in Deutsch.",
          "translations": [
            {
              "language": "ar",
              "text": "غداً نكتب اختباراً صفياً في الألمانية."
            },
            {
              "language": "ckb",
              "text": "سبەی تاقیکردنەوەی پۆل لە ئەڵمانی دەنووسین."
            },
            {
              "language": "en",
              "text": "Tomorrow we have a German class test."
            },
            {
              "language": "fa",
              "text": "فردا امتحان کلاسی آلمانی داریم."
            },
            {
              "language": "kmr",
              "text": "Em sibê di almanî de ezmûna polê dinivîsin."
            },
            {
              "language": "pl",
              "text": "Jutro piszemy sprawdzian z niemieckiego."
            },
            {
              "language": "ro",
              "text": "Mâine dăm o lucrare la germană."
            },
            {
              "language": "ru",
              "text": "Завтра у нас контрольная по немецкому."
            },
            {
              "language": "sq",
              "text": "Nesër kemi test klase në gjermanisht."
            },
            {
              "language": "tr",
              "text": "Yarın Almanca yazılı sınavımız var."
            }
          ]
        },
        {
          "baseText": "Die Klassenarbeit war nicht schwer.",
          "translations": [
            {
              "language": "ar",
              "text": "الاختبار الصفي لم يكن صعباً."
            },
            {
              "language": "ckb",
              "text": "تاقیکردنەوەکە قورس نەبوو."
            },
            {
              "language": "en",
              "text": "The class test was not difficult."
            },
            {
              "language": "fa",
              "text": "امتحان کلاسی سخت نبود."
            },
            {
              "language": "kmr",
              "text": "Ezmûna polê ne dijwar bû."
            },
            {
              "language": "pl",
              "text": "Sprawdzian nie był trudny."
            },
            {
              "language": "ro",
              "text": "Lucrarea nu a fost grea."
            },
            {
              "language": "ru",
              "text": "Контрольная была несложной."
            },
            {
              "language": "sq",
              "text": "Testi i klasës nuk ishte i vështirë."
            },
            {
              "language": "tr",
              "text": "Yazılı sınav zor değildi."
            }
          ]
        }
