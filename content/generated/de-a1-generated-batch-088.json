          "language": "fa",
          "text": "امن؛ مطمئن"
        },
        {
          "language": "kmr",
          "text": "ewle; bawer"
        },
        {
          "language": "pl",
          "text": "bezpieczny; pewny"
        },
        {
          "language": "ro",
          "text": "sigur"
        },
