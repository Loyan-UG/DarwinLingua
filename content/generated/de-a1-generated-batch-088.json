          "language": "tr",
          "text": "güvenli; emin"
        }
      ],
      "examples": [
        {
          "baseText": "Sind Sie sicher?",
          "translations": [
            {
              "language": "ar",
              "text": "هل أنت متأكد؟"
            },
            {
              "language": "ckb",
              "text": "ئایا دڵنیایت؟"
            },
            {
              "language": "en",
              "text": "Are you sure?"
            },
            {
              "language": "fa",
              "text": "مطمئن هستید؟"
            },
            {
              "language": "kmr",
              "text": "Ma hûn bawer in?"
            },
            {
              "language": "pl",
              "text": "Czy jest pan/pani pewien/pewna?"
            },
            {
              "language": "ro",
              "text": "Sunteți sigur?"
            },
            {
              "language": "ru",
              "text": "Вы уверены?"
            },
            {
              "language": "sq",
              "text": "A jeni i sigurt?"
            },
            {
              "language": "tr",
              "text": "Emin misiniz?"
            }
          ]
        },
        {
          "baseText": "Der Weg ist sicher.",
          "translations": [
            {
              "language": "ar",
              "text": "الطريق آمن."
            },
            {
              "language": "ckb",
              "text": "ڕێگاکە پارێزراوە."
            },
            {
              "language": "en",
              "text": "The way is safe."
            },
            {
              "language": "fa",
              "text": "راه امن است."
            },
            {
              "language": "kmr",
              "text": "Rê ewle ye."
            },
            {
              "language": "pl",
              "text": "Droga jest bezpieczna."
            },
            {
              "language": "ro",
              "text": "Drumul este sigur."
            },
            {
              "language": "ru",
              "text": "Дорога безопасна."
            },
            {
              "language": "sq",
              "text": "Rruga është e sigurt."
            },
            {
              "language": "tr",
              "text": "Yol güvenli."
            }
          ]
        }
      ]
