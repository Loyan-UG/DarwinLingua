  "entries": [
    {
      "word": "der Untersuchungsgegenstand",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Untersuchungsgegenstände",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Un-ter-su-chungs-ge-gen-stand",
      "topics": [
        "advanced-analysis",
        "education-and-training",
        "data-and-reporting"
      ],
      "usageLabels": [
        "written",
        "academic"
      ],
      "contextLabels": [
        "research",
        "analytics",
        "training"
      ],
      "grammarNotes": [
        "masculine compound noun; plural: Untersuchungsgegenstände"
      ],
      "collocations": [
        {
          "text": "den Untersuchungsgegenstand klar abgrenzen",
          "meaning": "to clearly define the object of investigation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Untersuchung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Gegenstand",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موضوع الدراسة أو التحقيق"
        },
        {
          "language": "ckb",
          "text": "بابەتی لێکۆڵینەوە"
        },
        {
          "language": "en",
          "text": "object of investigation; subject of study"
        },
        {
          "language": "fa",
          "text": "موضوع بررسی یا پژوهش"
        },
        {
          "language": "kmr",
          "text": "mijara lêkolînê"
        },
        {
          "language": "pl",
          "text": "przedmiot badania"
        },
        {
          "language": "ro",
          "text": "obiect de investigație; subiect de studiu"
        },
        {
          "language": "ru",
          "text": "предмет исследования"
        },
        {
          "language": "sq",
          "text": "objekt studimi; subjekt hetimi"
        },
        {
          "language": "tr",
          "text": "inceleme konusu; araştırma nesnesi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Untersuchungsgegenstand der Studie sind die Erwartungen von Kunden an digitale Services.",
          "translations": [
            {
              "language": "ar",
              "text": "موضوع الدراسة هو توقعات العملاء من الخدمات الرقمية."
            },
            {
              "language": "ckb",
              "text": "بابەتی لێکۆڵینەوەکە چاوەڕوانییەکانی کڕیارانە لە خزمەتگوزارییە دیجیتاڵەکان."
            },
            {
              "language": "en",
              "text": "The object of the study is customers’ expectations of digital services."
            },
            {
              "language": "fa",
              "text": "موضوع این مطالعه، انتظارات مشتریان از خدمات دیجیتال است."
            },
            {
              "language": "kmr",
              "text": "Mijara lêkolînê hêviyên xerîdaran ji xizmetên dîjîtal e."
            },
            {
              "language": "pl",
              "text": "Przedmiotem badania są oczekiwania klientów wobec usług cyfrowych."
            },
            {
              "language": "ro",
              "text": "Obiectul studiului îl constituie așteptările clienților față de serviciile digitale."
            },
            {
              "language": "ru",
              "text": "Предметом исследования являются ожидания клиентов от цифровых сервисов."
            },
            {
              "language": "sq",
              "text": "Objekti i studimit janë pritjet e klientëve ndaj shërbimeve digjitale."
            },
            {
              "language": "tr",
              "text": "Çalışmanın inceleme konusu, müşterilerin dijital hizmetlerden beklentileridir."
            }
          ]
        },
        {
          "baseText": "Im ersten Kapitel wird der Untersuchungsgegenstand genau beschrieben und von anderen Themen abgegrenzt.",
          "translations": [
            {
              "language": "ar",
              "text": "في الفصل الأول يتم وصف موضوع الدراسة بدقة وتمييزه عن موضوعات أخرى."
            },
            {
              "language": "ckb",
              "text": "لە بەشی یەکەمدا بابەتی لێکۆڵینەوەکە بە وردی وەسف دەکرێت و لە بابەتەکانی دیکە جیا دەکرێتەوە."
            },
            {
              "language": "en",
              "text": "In the first chapter, the object of investigation is described precisely and separated from other topics."
            },
            {
              "language": "fa",
              "text": "در فصل اول، موضوع بررسی دقیق توصیف و از موضوعات دیگر تفکیک می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di beşa yekem de mijara lêkolînê bi hûrgilî tê ravekirin û ji mijarên din tê cudakirin."
            },
            {
              "language": "pl",
              "text": "W pierwszym rozdziale przedmiot badania jest dokładnie opisany i odgraniczony od innych tematów."
            },
            {
              "language": "ro",
              "text": "În primul capitol, obiectul investigației este descris precis și delimitat de alte teme."
            },
            {
              "language": "ru",
              "text": "В первой главе предмет исследования подробно описывается и отделяется от других тем."
            },
            {
              "language": "sq",
              "text": "Në kapitullin e parë, objekti i hetimit përshkruhet saktë dhe ndahet nga tema të tjera."
            },
            {
              "language": "tr",
              "text": "İlk bölümde inceleme konusu ayrıntılı olarak açıklanır ve diğer konulardan ayrılır."
            }
          ]
        }
      ]
    },
