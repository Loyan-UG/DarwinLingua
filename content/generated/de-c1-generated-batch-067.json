      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "Komplexitätsreduktion erreichen",
          "meaning": "to achieve a reduction of complexity"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Komplexität",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "reduzieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تقليل التعقيد"
        },
        {
          "language": "ckb",
          "text": "کەمکردنەوەی ئاڵۆزی"
        },
        {
          "language": "en",
          "text": "complexity reduction"
        },
        {
          "language": "fa",
          "text": "کاهش پیچیدگی"
        },
        {
          "language": "kmr",
          "text": "kêmkirina tevliheviyê"
        },
        {
          "language": "pl",
          "text": "redukcja złożoności"
        },
        {
          "language": "ro",
          "text": "reducerea complexității"
        },
        {
          "language": "ru",
          "text": "снижение сложности"
        },
        {
          "language": "sq",
          "text": "reduktim i kompleksitetit"
        },
        {
          "language": "tr",
          "text": "karmaşıklığın azaltılması"
        }
      ],
      "examples": [
        {
          "baseText": "Die Komplexitätsreduktion im Bestellprozess senkte die Fehlerquote deutlich.",
          "translations": [
            {
              "language": "ar",
              "text": "أدى تقليل التعقيد في عملية الطلب إلى خفض معدل الأخطاء بوضوح."
            },
            {
              "language": "ckb",
              "text": "کەمکردنەوەی ئاڵۆزی لە پرۆسەی داواکارییەکاندا ڕێژەی هەڵەکان بە ڕوونی کەم کردەوە."
            },
            {
              "language": "en",
              "text": "The complexity reduction in the ordering process significantly lowered the error rate."
            },
            {
              "language": "fa",
              "text": "کاهش پیچیدگی در فرایند سفارش، نرخ خطا را به‌طور قابل توجهی پایین آورد."
            },
            {
              "language": "kmr",
              "text": "Kêmkirina tevliheviyê di pêvajoya fermanê de rêjeya şaşiyan bi awayekî berbiçav daxist."
            },
            {
              "language": "pl",
              "text": "Redukcja złożoności w procesie zamówień wyraźnie obniżyła wskaźnik błędów."
            },
            {
              "language": "ro",
              "text": "Reducerea complexității în procesul de comandă a scăzut clar rata erorilor."
            },
            {
              "language": "ru",
              "text": "Снижение сложности в процессе заказов заметно уменьшило долю ошибок."
            },
            {
              "language": "sq",
              "text": "Reduktimi i kompleksitetit në procesin e porosisë uli ndjeshëm shkallën e gabimeve."
            },
            {
              "language": "tr",
              "text": "Sipariş sürecindeki karmaşıklığın azaltılması hata oranını belirgin şekilde düşürdü."
            }
          ]
        },
        {
          "baseText": "In der Beratung wird Komplexitätsreduktion oft mit Vereinfachung verwechselt.",
          "translations": [
            {
              "language": "ar",
              "text": "في الاستشارات كثيراً ما يُخلط بين تقليل التعقيد والتبسيط."
            },
            {
              "language": "ckb",
              "text": "لە ڕاوێژکاریدا زۆرجار کەمکردنەوەی ئاڵۆزی لەگەڵ سادەکردنەوە تێکەڵ دەکرێت."
            },
            {
              "language": "en",
              "text": "In consulting, complexity reduction is often confused with simplification."
            },
            {
              "language": "fa",
              "text": "در مشاوره، کاهش پیچیدگی اغلب با ساده‌سازی اشتباه گرفته می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di şêwirmendiyê de kêmkirina tevliheviyê gelek caran bi hêsankirinê tê tevlihev kirin."
            },
            {
              "language": "pl",
              "text": "W doradztwie redukcję złożoności często myli się z uproszczeniem."
            },
            {
              "language": "ro",
              "text": "În consultanță, reducerea complexității este adesea confundată cu simplificarea."
            },
            {
              "language": "ru",
              "text": "В консалтинге снижение сложности часто путают с упрощением."
            },
            {
              "language": "sq",
              "text": "Në konsulencë, reduktimi i kompleksitetit shpesh ngatërrohet me thjeshtimin."
            },
            {
              "language": "tr",
              "text": "Danışmanlıkta karmaşıklığın azaltılması çoğu zaman basitleştirme ile karıştırılır."
            }
          ]
        }
      ]
    },
    {
      "word": "das Konfidenzintervall",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Konfidenzintervalle",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kon-fi-denz-in-ter-vall",
      "topics": [
        "data-and-reporting",
        "advanced-analysis",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; statistical term"
      ],
      "collocations": [
        {
          "text": "ein Konfidenzintervall berechnen",
          "meaning": "to calculate a confidence interval"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Konfidenz",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "das Intervall",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فاصل الثقة"
        },
        {
          "language": "ckb",
          "text": "ماوەی متمانە"
        },
        {
          "language": "en",
          "text": "confidence interval"
        },
        {
          "language": "fa",
          "text": "فاصله اطمینان"
        },
        {
          "language": "kmr",
          "text": "navbera baweriyê"
        },
        {
          "language": "pl",
          "text": "przedział ufności"
        },
        {
          "language": "ro",
          "text": "interval de încredere"
        },
        {
          "language": "ru",
          "text": "доверительный интервал"
        },
        {
          "language": "sq",
          "text": "interval besimi"
        },
        {
          "language": "tr",
          "text": "güven aralığı"
        }
      ],
      "examples": [
        {
          "baseText": "Das Konfidenzintervall zeigt, wie unsicher die Schätzung trotz großer Stichprobe bleibt.",
          "translations": [
            {
              "language": "ar",
              "text": "يُظهر فاصل الثقة مدى بقاء التقدير غير مؤكد رغم كبر حجم العينة."
            },
            {
              "language": "ckb",
              "text": "ماوەی متمانە پیشان دەدات کە خەملاندنەکە سەرەڕای نموونەی گەورە تا چەند نادڵنیا دەمێنێتەوە."
            },
            {
              "language": "en",
              "text": "The confidence interval shows how uncertain the estimate remains despite the large sample."
            },
            {
              "language": "fa",
              "text": "فاصله اطمینان نشان می‌دهد که برآورد با وجود نمونه بزرگ چقدر نامطمئن باقی می‌ماند."
            },
            {
              "language": "kmr",
              "text": "Navbera baweriyê nîşan dide ku texmîn tevî nimûneya mezin çiqas nediyar dimîne."
            },
            {
              "language": "pl",
              "text": "Przedział ufności pokazuje, jak niepewne pozostaje oszacowanie mimo dużej próby."
            },
            {
              "language": "ro",
              "text": "Intervalul de încredere arată cât de incertă rămâne estimarea în ciuda eșantionului mare."
            },
            {
              "language": "ru",
              "text": "Доверительный интервал показывает, насколько неопределенной остается оценка, несмотря на большую выборку."
            },
            {
              "language": "sq",
              "text": "Intervali i besimit tregon sa i pasigurt mbetet vlerësimi pavarësisht kampionit të madh."
            },
            {
              "language": "tr",
              "text": "Güven aralığı, büyük örnekleme rağmen tahminin ne kadar belirsiz kaldığını gösterir."
            }
          ]
        },
        {
          "baseText": "Im Reporting sollte das Konfidenzintervall neben dem Mittelwert ausgewiesen werden.",
          "translations": [
            {
              "language": "ar",
              "text": "في التقارير ينبغي إظهار فاصل الثقة إلى جانب المتوسط."
            },
            {
              "language": "ckb",
              "text": "لە ڕاپۆرتداندا پێویستە ماوەی متمانە لەگەڵ ناوەندەکە پیشان بدرێت."
            },
            {
              "language": "en",
              "text": "In reporting, the confidence interval should be shown alongside the mean value."
            },
            {
              "language": "fa",
              "text": "در گزارش‌دهی باید فاصله اطمینان در کنار مقدار میانگین نمایش داده شود."
            },
            {
              "language": "kmr",
              "text": "Di raporkirinê de divê navbera baweriyê ligel nirxa navîn were nîşandan."
            },
            {
              "language": "pl",
              "text": "W raportowaniu przedział ufności powinien być podawany obok średniej."
            },
            {
              "language": "ro",
              "text": "În raportare, intervalul de încredere ar trebui afișat lângă valoarea medie."
            },
            {
              "language": "ru",
              "text": "В отчетности доверительный интервал следует указывать рядом со средним значением."
            },
            {
              "language": "sq",
              "text": "Në raportim, intervali i besimit duhet të paraqitet krahas vlerës mesatare."
            },
            {
              "language": "tr",
              "text": "Raporlamada güven aralığı ortalama değerle birlikte gösterilmelidir."
            }
          ]
        }
      ]
    },
