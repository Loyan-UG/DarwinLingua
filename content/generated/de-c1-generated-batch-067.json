      "plural": "Komplexitätsreduktionen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Kom-ple-xi-täts-re-duk-ti-on",
      "topics": [
        "advanced-analysis",
        "planning-and-projects",
