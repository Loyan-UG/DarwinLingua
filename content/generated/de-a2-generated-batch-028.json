        {
          "language": "tr",
          "text": "check-in yapmak; giriş yapmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir checken um 15 Uhr im Hotel ein.",
          "translations": [
            {
              "language": "ar",
              "text": "نسجل الوصول في الفندق الساعة الثالثة بعد الظهر."
            },
            {
              "language": "ckb",
              "text": "کاتژمێر ١٥ لە هۆتێل چێک ئین دەکەین."
            },
            {
              "language": "en",
              "text": "We check in at the hotel at 3 p.m."
            },
            {
              "language": "fa",
              "text": "ما ساعت ۱۵ در هتل چک‌این می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em di saet 15 de li otêlê check-in dikin."
            },
            {
              "language": "pl",
              "text": "Meldujemy się w hotelu o godzinie 15."
            },
            {
              "language": "ro",
              "text": "Facem check-in la hotel la ora 15."
            },
            {
              "language": "ru",
              "text": "Мы регистрируемся в отеле в 15 часов."
            },
            {
              "language": "sq",
              "text": "Bëjmë check-in në hotel në orën 15."
            },
            {
              "language": "tr",
              "text": "Saat 15’te otele giriş yapıyoruz."
            }
          ]
        },
        {
          "baseText": "Für den Flug können Sie online einchecken.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم تسجيل الوصول للرحلة عبر الإنترنت."
            },
            {
              "language": "ckb",
              "text": "بۆ فڕۆکەکە دەتوانن ئۆنلاین چێک ئین بکەن."
            },
            {
              "language": "en",
              "text": "You can check in online for the flight."
            },
            {
              "language": "fa",
              "text": "برای پرواز می‌توانید آنلاین چک‌این کنید."
            },
            {
              "language": "kmr",
              "text": "Ji bo firînê hûn dikarin online check-in bikin."
            },
            {
              "language": "pl",
              "text": "Na lot można odprawić się online."
            },
            {
              "language": "ro",
              "text": "Pentru zbor puteți face check-in online."
            },
            {
              "language": "ru",
              "text": "На рейс можно зарегистрироваться онлайн."
            },
            {
              "language": "sq",
              "text": "Për fluturimin mund të bëni check-in online."
            },
            {
              "language": "tr",
              "text": "Uçuş için çevrim içi check-in yapabilirsiniz."
            }
          ]
        }
