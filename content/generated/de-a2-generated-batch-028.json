      "collocations": [
        {
          "text": "in eine Einbahnstraße fahren",
          "meaning": "to drive into a one-way street"
        },
        {
          "text": "eine Einbahnstraße beachten",
          "meaning": "to observe a one-way street"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Straße",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شارع باتجاه واحد"
        },
        {
          "language": "ckb",
          "text": "شەقامی یەک ئاراستە"
        },
        {
          "language": "en",
          "text": "one-way street"
        },
        {
          "language": "fa",
          "text": "خیابان یک‌طرفه"
        },
        {
          "language": "kmr",
          "text": "kolana yek-alî"
        },
        {
          "language": "pl",
          "text": "ulica jednokierunkowa"
        },
        {
          "language": "ro",
          "text": "stradă cu sens unic"
        },
        {
          "language": "ru",
          "text": "улица с односторонним движением"
        },
        {
          "language": "sq",
          "text": "rrugë me një drejtim"
        },
        {
          "language": "tr",
          "text": "tek yönlü sokak"
        }
      ],
      "examples": [
        {
          "baseText": "Diese Straße ist eine Einbahnstraße.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا الشارع باتجاه واحد."
            },
            {
              "language": "ckb",
              "text": "ئەم شەقامە یەک ئاراستەیە."
            },
            {
              "language": "en",
              "text": "This street is a one-way street."
            },
            {
              "language": "fa",
              "text": "این خیابان یک‌طرفه است."
            },
            {
              "language": "kmr",
              "text": "Ev kolan yek-alî ye."
            },
            {
              "language": "pl",
              "text": "Ta ulica jest jednokierunkowa."
            },
            {
              "language": "ro",
              "text": "Această stradă este cu sens unic."
            },
            {
              "language": "ru",
              "text": "Эта улица с односторонним движением."
            },
            {
              "language": "sq",
              "text": "Kjo rrugë është me një drejtim."
            },
            {
              "language": "tr",
              "text": "Bu sokak tek yönlüdür."
            }
          ]
        },
        {
          "baseText": "Fahren Sie hier nicht hinein, das ist eine Einbahnstraße.",
          "translations": [
            {
              "language": "ar",
              "text": "لا تدخلوا هنا بالسيارة، فهذا شارع باتجاه واحد."
            },
            {
              "language": "ckb",
              "text": "لێرە مەچنە ژوورەوە، ئەمە شەقامی یەک ئاراستەیە."
            },
            {
              "language": "en",
              "text": "Do not drive in here; it is a one-way street."
            },
            {
              "language": "fa",
              "text": "اینجا وارد نشوید، این خیابان یک‌طرفه است."
            },
            {
              "language": "kmr",
              "text": "Li vir nekevin, ev kolan yek-alî ye."
            },
            {
              "language": "pl",
              "text": "Proszę tu nie wjeżdżać, to ulica jednokierunkowa."
            },
            {
              "language": "ro",
              "text": "Nu intrați aici, este o stradă cu sens unic."
            },
            {
              "language": "ru",
              "text": "Не въезжайте сюда, это улица с односторонним движением."
            },
            {
              "language": "sq",
              "text": "Mos hyni këtu, është rrugë me një drejtim."
            },
            {
              "language": "tr",
              "text": "Buraya girmeyin, burası tek yönlü sokak."
            }
          ]
        }
      ]
    },
