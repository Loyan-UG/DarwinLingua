      "examples": [
        {
          "baseText": "Ich bleibe zu Hause, weil ich krank bin.",
          "translations": [
            {
              "language": "ar",
              "text": "أبقى في البيت لأنني مريض."
            },
            {
              "language": "ckb",
              "text": "لە ماڵەوە دەمێنمەوە چونکە نەخۆشم."
            },
            {
              "language": "en",
              "text": "I am staying at home because I am sick."
            },
            {
              "language": "fa",
              "text": "در خانه می‌مانم چون مریض هستم."
            },
            {
              "language": "kmr",
              "text": "Ez li malê dimînim, ji ber ku nexweş im."
            },
            {
              "language": "pl",
              "text": "Zostaję w domu, ponieważ jestem chory."
            },
            {
              "language": "ro",
              "text": "Rămân acasă pentru că sunt bolnav."
            },
            {
              "language": "ru",
              "text": "Я остаюсь дома, потому что болен."
            },
            {
              "language": "sq",
              "text": "Po rri në shtëpi sepse jam i sëmurë."
            },
            {
              "language": "tr",
              "text": "Hasta olduğum için evde kalıyorum."
            }
          ]
        },
        {
          "baseText": "Ich komme später, weil der Bus voll ist.",
