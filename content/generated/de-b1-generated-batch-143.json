      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "المرأة المؤمن عليها"
        },
        {
          "language": "ckb",
          "text": "ژنی بیمەکراو"
        },
        {
          "language": "en",
          "text": "insured woman; female insured person"
        },
        {
          "language": "fa",
          "text": "بیمه‌شده زن"
        },
        {
          "language": "kmr",
          "text": "jina sîgortekirî"
        },
        {
          "language": "pl",
          "text": "ubezpieczona"
        },
        {
          "language": "ro",
          "text": "asigurată"
        },
        {
          "language": "ru",
          "text": "застрахованная"
        },
        {
          "language": "sq",
          "text": "e siguruara"
        },
        {
          "language": "tr",
          "text": "kadın sigortalı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Versicherte zeigt ihre Gesundheitskarte am Empfang.",
          "translations": [
            {
              "language": "ar",
              "text": "تُظهر المرأة المؤمن عليها بطاقة التأمين الصحي عند الاستقبال."
            },
            {
              "language": "ckb",
              "text": "ژنی بیمەکراو کارتی تەندروستییەکەی لە پێشوازی نیشان دەدات."
            },
            {
              "language": "en",
              "text": "The insured woman shows her health card at reception."
            },
            {
              "language": "fa",
              "text": "بیمه‌شده زن کارت سلامت خود را در پذیرش نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Jina sîgortekirî karta tenduristiyê li pêşwaziyê nîşan dide."
            },
            {
              "language": "pl",
              "text": "Ubezpieczona pokazuje kartę zdrowia w recepcji."
            },
            {
              "language": "ro",
              "text": "Asigurata își arată cardul de sănătate la recepție."
            },
            {
              "language": "ru",
              "text": "Застрахованная показывает свою медицинскую карту на рецепции."
            },
            {
              "language": "sq",
              "text": "E siguruara tregon kartën e saj shëndetësore në recepsion."
            },
            {
              "language": "tr",
              "text": "Kadın sigortalı sağlık kartını resepsiyonda gösterir."
            }
          ]
        },
        {
          "baseText": "Die Versicherte erhält nach der Prüfung eine schriftliche Antwort.",
          "translations": [
            {
              "language": "ar",
              "text": "تحصل المرأة المؤمن عليها بعد الفحص على رد كتابي."
            },
            {
              "language": "ckb",
              "text": "ژنی بیمەکراو دوای پشکنینەکە وەڵامێکی نووسراو وەردەگرێت."
            },
            {
              "language": "en",
