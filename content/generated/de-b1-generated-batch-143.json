  "entries": [
    {
      "word": "versichern",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "versichern",
      "pronunciationIpa": null,
      "syllableBreak": "ver-si-chern",
      "topics": [
        "finance-and-accounting",
        "healthcare-and-appointments",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb; can mean to insure or to assure"
      ],
      "collocations": [
        {
          "text": "ein Auto versichern",
          "meaning": "to insure a car"
        },
        {
          "text": "jemandem etwas versichern",
          "meaning": "to assure someone of something"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Versicherung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يؤمّن؛ يؤكد"
        },
        {
          "language": "ckb",
          "text": "بیمەکردن؛ دڵنیاکردن"
        },
        {
          "language": "en",
          "text": "to insure; to assure"
        },
        {
          "language": "fa",
          "text": "بیمه کردن؛ اطمینان دادن"
        },
        {
          "language": "kmr",
          "text": "sîgorte kirin; piştrast kirin"
        },
        {
          "language": "pl",
          "text": "ubezpieczyć; zapewnić"
        },
        {
          "language": "ro",
          "text": "a asigura"
        },
        {
          "language": "ru",
          "text": "страховать; уверять"
        },
        {
          "language": "sq",
          "text": "të sigurosh"
        },
        {
          "language": "tr",
          "text": "sigortalamak; temin etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bevor Sie das Auto anmelden, müssen Sie es versichern.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل أن تسجل السيارة يجب أن تؤمّنها."
            },
            {
              "language": "ckb",
              "text": "پێش ئەوەی ئۆتۆمبێلەکە تۆمار بکەیت، دەبێت بیمەی بکەیت."
            },
            {
              "language": "en",
              "text": "Before you register the car, you have to insure it."
            },
            {
              "language": "fa",
              "text": "قبل از ثبت خودرو باید آن را بیمه کنید."
            },
            {
              "language": "kmr",
              "text": "Berî ku hûn erebeyê tomar bikin, divê wê sîgorte bikin."
            },
            {
              "language": "pl",
              "text": "Zanim zarejestrują Państwo samochód, trzeba go ubezpieczyć."
            },
            {
              "language": "ro",
              "text": "Înainte să înmatriculați mașina, trebuie să o asigurați."
            },
            {
              "language": "ru",
              "text": "Перед регистрацией автомобиля его нужно застраховать."
            },
            {
              "language": "sq",
              "text": "Para se ta regjistroni makinën, duhet ta siguroni."
            },
            {
              "language": "tr",
              "text": "Arabayı kaydettirmeden önce sigortalamanız gerekir."
            }
          ]
        },
        {
          "baseText": "Der Support versichert dem Kunden, dass das Problem heute geprüft wird.",
          "translations": [
            {
              "language": "ar",
              "text": "تؤكد خدمة الدعم للعميل أن المشكلة ستُفحص اليوم."
            },
            {
              "language": "ckb",
              "text": "پاڵپشتی کڕیارەکە دڵنیا دەکاتەوە کە کێشەکە ئەمڕۆ دەپشکنرێت."
            },
            {
              "language": "en",
              "text": "Support assures the customer that the problem will be checked today."
            },
            {
              "language": "fa",
              "text": "پشتیبانی به مشتری اطمینان می‌دهد که مشکل امروز بررسی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Piştgirî xerîdar piştrast dike ku pirsgirêk îro tê kontrolkirin."
            },
            {
              "language": "pl",
              "text": "Dział wsparcia zapewnia klienta, że problem zostanie dziś sprawdzony."
            },
            {
              "language": "ro",
              "text": "Suportul îl asigură pe client că problema va fi verificată astăzi."
            },
            {
              "language": "ru",
              "text": "Поддержка уверяет клиента, что проблема будет проверена сегодня."
            },
            {
              "language": "sq",
              "text": "Mbështetja e siguron klientin se problemi do të kontrollohet sot."
            },
            {
              "language": "tr",
              "text": "Destek ekibi müşteriye sorunun bugün kontrol edileceğini garanti eder."
            }
          ]
        }
      ]
    },
    {
      "word": "der Versicherte",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Versicherte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ver-si-cher-te",
      "topics": [
        "healthcare-and-appointments",
        "finance-and-accounting",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine weak adjective noun; plural: die Versicherten"
      ],
      "collocations": [
        {
          "text": "der Versicherte meldet den Schaden",
          "meaning": "the insured person reports the damage"
        },
        {
          "text": "Daten des Versicherten",
          "meaning": "data of the insured person"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "versichern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "الشخص المؤمن عليه"
        },
        {
          "language": "ckb",
          "text": "پیاوی بیمەکراو"
        },
        {
          "language": "en",
          "text": "insured person"
        },
        {
          "language": "fa",
          "text": "بیمه‌شده مرد؛ شخص بیمه‌شده"
        },
        {
          "language": "kmr",
          "text": "kesê sîgortekirî"
        },
        {
          "language": "pl",
          "text": "ubezpieczony"
        },
        {
          "language": "ro",
          "text": "asigurat"
        },
        {
          "language": "ru",
          "text": "застрахованный"
        },
        {
          "language": "sq",
          "text": "i siguruari"
        },
        {
          "language": "tr",
          "text": "sigortalı kişi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Versicherte muss den Unfall innerhalb einer Woche melden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على المؤمن عليه الإبلاغ عن الحادث خلال أسبوع."
            },
            {
              "language": "ckb",
              "text": "بیمەکراوەکە دەبێت ڕووداوەکە لە ماوەی هەفتەیەکدا ڕابگەیەنێت."
            },
            {
              "language": "en",
              "text": "The insured person must report the accident within one week."
            },
            {
              "language": "fa",
              "text": "بیمه‌شده باید حادثه را ظرف یک هفته گزارش کند."
            },
            {
              "language": "kmr",
              "text": "Kesê sîgortekirî divê qezayê di nav hefteyekê de ragihîne."
            },
            {
              "language": "pl",
              "text": "Ubezpieczony musi zgłosić wypadek w ciągu tygodnia."
            },
            {
              "language": "ro",
              "text": "Asiguratul trebuie să anunțe accidentul în termen de o săptămână."
            },
            {
              "language": "ru",
              "text": "Застрахованный должен сообщить о несчастном случае в течение недели."
            },
            {
              "language": "sq",
              "text": "I siguruari duhet ta raportojë aksidentin brenda një jave."
            },
            {
              "language": "tr",
              "text": "Sigortalı kişi kazayı bir hafta içinde bildirmelidir."
            }
          ]
        },
        {
          "baseText": "Im System fehlen noch die Kontaktdaten des Versicherten.",
          "translations": [
            {
              "language": "ar",
              "text": "لا تزال بيانات الاتصال الخاصة بالمؤمن عليه ناقصة في النظام."
            },
            {
              "language": "ckb",
              "text": "لە سیستەمەکەدا هێشتا زانیاریی پەیوەندی بیمەکراوەکە کەمە."
            },
            {
              "language": "en",
              "text": "The insured person’s contact details are still missing in the system."
            },
            {
              "language": "fa",
              "text": "اطلاعات تماس بیمه‌شده هنوز در سیستم ناقص است."
            },
            {
              "language": "kmr",
              "text": "Di sîstemê de hîn agahiyên têkiliyê yên kesê sîgortekirî kêm in."
            },
            {
              "language": "pl",
              "text": "W systemie nadal brakuje danych kontaktowych ubezpieczonego."
            },
            {
              "language": "ro",
              "text": "În sistem lipsesc încă datele de contact ale asiguratului."
            },
            {
              "language": "ru",
              "text": "В системе еще отсутствуют контактные данные застрахованного."
            },
            {
              "language": "sq",
              "text": "Në sistem mungojnë ende të dhënat e kontaktit të të siguruarit."
            },
            {
              "language": "tr",
              "text": "Sistemde sigortalının iletişim bilgileri hâlâ eksik."
            }
          ]
        }
      ]
    },
