      "meanings": [
        {
          "language": "ar",
          "text": "عمل ثنائي؛ عمل مع شريك"
        },
        {
          "language": "ckb",
          "text": "کاری دووکەسی؛ کاری هاوبەش"
        },
        {
          "language": "en",
          "text": "pair work; partner work"
        },
        {
          "language": "fa",
          "text": "کار دونفره؛ کار با همکار/هم‌گروهی"
        },
        {
          "language": "kmr",
          "text": "xebata hevpar; karê du kesî"
        },
        {
          "language": "pl",
          "text": "praca w parach"
