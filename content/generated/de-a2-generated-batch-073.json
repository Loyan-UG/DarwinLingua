          "language": "tr",
          "text": "eşli çalışma; ikili çalışma"
        }
      ],
      "examples": [
        {
          "baseText": "Im Deutschkurs machen wir oft Partnerarbeit.",
          "translations": [
            {
              "language": "ar",
              "text": "في دورة الألمانية نعمل كثيراً في أزواج."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسی ئەڵمانیدا زۆرجار کاری دووکەسی دەکەین."
            },
            {
              "language": "en",
              "text": "In the German course, we often do pair work."
            },
            {
              "language": "fa",
              "text": "در کلاس آلمانی اغلب کار دونفره انجام می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Di kursa almanî de em gelek caran xebata hevpar dikin."
            },
            {
              "language": "pl",
              "text": "Na kursie niemieckiego często pracujemy w parach."
            },
            {
              "language": "ro",
              "text": "La cursul de germană lucrăm des în perechi."
            },
            {
              "language": "ru",
              "text": "На курсе немецкого мы часто работаем в парах."
            },
            {
              "language": "sq",
              "text": "Në kursin e gjermanishtes shpesh bëjmë punë në çift."
            },
            {
              "language": "tr",
              "text": "Almanca kursunda sık sık ikili çalışma yapıyoruz."
            }
          ]
        },
        {
          "baseText": "Die Partnerarbeit dauert zehn Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "العمل الثنائي يستغرق عشر دقائق."
            },
            {
              "language": "ckb",
              "text": "کاری دووکەسی دە خولەک دەخایەنێت."
            },
            {
              "language": "en",
              "text": "The pair work lasts ten minutes."
            },
            {
              "language": "fa",
              "text": "کار دونفره ده دقیقه طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Xebata hevpar deh deqe dirêj dibe."
            },
            {
              "language": "pl",
              "text": "Praca w parach trwa dziesięć minut."
            },
            {
              "language": "ro",
              "text": "Lucrul în perechi durează zece minute."
            },
            {
              "language": "ru",
              "text": "Работа в парах длится десять минут."
            },
            {
              "language": "sq",
              "text": "Puna në çift zgjat dhjetë minuta."
            },
            {
              "language": "tr",
              "text": "İkili çalışma on dakika sürüyor."
            }
          ]
        }
      ]
    },
