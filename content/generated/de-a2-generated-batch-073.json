      ],
      "examples": [
        {
          "baseText": "Du musst einen Parkschein kaufen.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن تشتري تذكرة موقف."
            },
            {
              "language": "ckb",
              "text": "پێویستە بلیتی پارککردن بکڕیت."
            },
            {
              "language": "en",
              "text": "You have to buy a parking ticket."
            },
            {
              "language": "fa",
              "text": "باید بلیط پارکینگ بخری."
            },
            {
              "language": "kmr",
              "text": "Divê tu bilêta parkê bikirî."
            },
            {
              "language": "pl",
              "text": "Musisz kupić bilet parkingowy."
            },
            {
              "language": "ro",
              "text": "Trebuie să cumperi un tichet de parcare."
            },
            {
              "language": "ru",
              "text": "Ты должен купить парковочный талон."
            },
            {
              "language": "sq",
              "text": "Duhet të blesh një biletë parkimi."
            },
            {
              "language": "tr",
              "text": "Park bileti almalısın."
            }
          ]
        },
        {
          "baseText": "Der Parkschein liegt vorne im Auto.",
          "translations": [
            {
              "language": "ar",
              "text": "تذكرة الموقف في الأمام داخل السيارة."
            },
            {
              "language": "ckb",
              "text": "بلیتی پارککردنەکە لە پێشەوەی ئۆتۆمبێلەکەدایە."
            },
            {
              "language": "en",
              "text": "The parking ticket is at the front of the car."
            },
            {
              "language": "fa",
              "text": "بلیط پارکینگ جلوی ماشین است."
            },
            {
              "language": "kmr",
              "text": "Bilêta parkê li pêşiya erebeyê ye."
            },
            {
              "language": "pl",
              "text": "Bilet parkingowy leży z przodu w samochodzie."
            },
            {
              "language": "ro",
              "text": "Tichetul de parcare este în față în mașină."
            },
            {
              "language": "ru",
              "text": "Парковочный талон лежит впереди в машине."
            },
            {
              "language": "sq",
              "text": "Bileta e parkimit është përpara në makinë."
            },
            {
              "language": "tr",
              "text": "Park bileti arabanın ön tarafında."
            }
          ]
        }
