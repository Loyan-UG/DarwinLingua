        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عقب کشیدن/حرکت کردن"
        },
        {
          "language": "ckb",
          "text": "پەیوەندیکردنەوە"
        },
        {
          "language": "en",
          "text": "to move toward; to approach"
        },
        {
          "language": "fa",
          "text": "نزدیک شدن؛ به سوی چیزی حرکت کردن"
        },
        {
          "language": "kmr",
          "text": "wergerîn; digel xwe hatin"
        },
        {
          "language": "pl",
          "text": "podjechać; podążać"
        },
        {
          "language": "ro",
          "text": "a se îndrepta; a ajunge"
        },
        {
          "language": "ru",
          "text": "подъезжать; приступать"
        },
        {
          "language": "sq",
          "text": "të afrohesh; të nishe"
        },
        {
          "language": "tr",
          "text": "yaklaşmak; harekete başlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Paketwagen hat kurz nach acht den Kundenstandort angefahren.",
          "translations": [
            {
              "language": "ar",
              "text": "وانت پیک به بعد از ساعت هشت به محل مشتری رسید."
            },
            {
              "language": "ckb",
              "text": "فەرامەی گواستنەوەکە پاش چەکوێی هەشت کلیەکەی کڕیارەکەى ئاسا کرد."
            },
            {
              "language": "en",
              "text": "The delivery van approached the customer site shortly after eight."
            },
            {
              "language": "fa",
              "text": "ونت پستی کمی بعد از ساعت هشت به محل مشتری رسید."
            },
            {
              "language": "kmr",
              "text": "Girtina barkirinê li piştî saetekê şeşê cihê xerîdarê derbas kir."
            },
            {
              "language": "pl",
              "text": "Dostawczyni wyruszyła do klienta tuż po ósmej."
            },
            {
              "language": "ro",
              "text": "Furgoneta de livrare a ajuns la locația clientului puțin după opt."
            },
            {
              "language": "ru",
              "text": "Авто доставки подъехало к клиенту чуть после восьми."
            },
            {
              "language": "sq",
              "text": "Furgoni i dorëzimit iu afrua vendndodhjes së klientit pak pas orës tetë."
            },
            {
              "language": "tr",
              "text": "Teslimat aracı saat sekizden biraz sonra müşteri lokasyonuna yaklaştı."
            }
          ]
        },
        {
          "baseText": "Wir fahren das Refactoring-Modul erst an, wenn die Architektur freigegeben ist.",
          "translations": [
            {
              "language": "ar",
              "text": "ما ماژول بازسازی را فقط وقتی آغاز می‌کنیم که معماری تأیید شده باشد."
            },
            {
              "language": "ckb",
              "text": "ئەنجامەری ڕیفاکتورینگ تەنها کاتێک دەستپێدەکەینەوە کە بیناکردنی ئارخیتەکتورەکە ڕێگەپێدراو بێت."
            },
            {
              "language": "en",
              "text": "We start the refactoring module only when the architecture has been approved."
            },
            {
              "language": "fa",
              "text": "ما ماژول بازطراحی را فقط زمانی آغاز می‌کنیم که معماری تأیید شده باشد."
            },
            {
              "language": "kmr",
              "text": "Em modula refaktora tenê dema avabûn hat erêkirin dest pê dikin."
            },
            {
              "language": "pl",
              "text": "Moduł refaktoryzacji uruchamiamy dopiero, gdy architektura została zatwierdzona."
            },
            {
              "language": "ro",
