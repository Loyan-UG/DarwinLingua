      ],
      "collocations": [
        {
          "text": "die Umsetzbarkeit prüfen",
          "meaning": "to check feasibility"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "umsetzbar",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "umsetzen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قابلية التنفيذ"
        },
        {
          "language": "ckb",
          "text": "توانای جێبەجێکردن"
        },
        {
          "language": "en",
          "text": "feasibility; implementability"
        },
        {
          "language": "fa",
          "text": "قابلیت اجرا؛ امکان پیاده‌سازی"
        },
        {
          "language": "kmr",
          "text": "pêkanînbûn; cîbicîkirinbarî"
        },
        {
          "language": "pl",
          "text": "wykonalność; możliwość wdrożenia"
        },
        {
          "language": "ro",
          "text": "fezabilitate; posibilitate de implementare"
        },
        {
          "language": "ru",
          "text": "осуществимость; реализуемость"
        },
        {
          "language": "sq",
          "text": "realizueshmëri; zbatueshmëri"
        },
        {
          "language": "tr",
          "text": "uygulanabilirlik; gerçekleştirilebilirlik"
        }
      ],
      "examples": [
        {
          "baseText": "Vor dem Angebot prüfen wir die Umsetzbarkeit der gewünschten Schnittstelle.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل العرض نتحقق من قابلية تنفيذ الواجهة المطلوبة."
            },
            {
              "language": "ckb",
              "text": "پێش پێشنیارەکە توانای جێبەجێکردنی ڕووکاری پەیوەندیی داواکراو دەپشکنین."
            },
            {
              "language": "en",
              "text": "Before the offer, we check the feasibility of the requested interface."
            },
            {
              "language": "fa",
              "text": "قبل از ارائه پیشنهاد، امکان پیاده‌سازی رابط درخواستی را بررسی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Berî pêşniyarê em pêkanînbûna navrûya daxwazkirî kontrol dikin."
            },
            {
              "language": "pl",
              "text": "Przed ofertą sprawdzamy wykonalność żądanego interfejsu."
            },
            {
              "language": "ro",
              "text": "Înainte de ofertă verificăm fezabilitatea interfeței solicitate."
            },
            {
              "language": "ru",
              "text": "Перед предложением мы проверяем реализуемость нужного интерфейса."
            },
            {
              "language": "sq",
              "text": "Para ofertës kontrollojmë realizueshmërinë e ndërfaqes së kërkuar."
            },
            {
              "language": "tr",
              "text": "Tekliften önce istenen arayüzün uygulanabilirliğini kontrol ediyoruz."
            }
          ]
        },
        {
          "baseText": "Die Umsetzbarkeit hängt stark davon ab, ob genug Personal verfügbar ist.",
          "translations": [
            {
              "language": "ar",
              "text": "تعتمد قابلية التنفيذ إلى حد كبير على توفر عدد كافٍ من الموظفين."
            },
            {
              "language": "ckb",
              "text": "توانای جێبەجێکردن زۆر پەیوەستە بەوەی ئایا کارمەندی پێویست بەردەستە یان نا."
            },
            {
              "language": "en",
              "text": "Feasibility depends heavily on whether enough staff is available."
            },
            {
              "language": "fa",
              "text": "قابلیت اجرا تا حد زیادی به این بستگی دارد که نیروی کافی در دسترس باشد یا نه."
            },
            {
              "language": "kmr",
              "text": "Pêkanînbûn pir girêdayî ye bi ku gelo karmendê têr heye an na."
            },
            {
              "language": "pl",
              "text": "Wykonalność zależy w dużej mierze od dostępności wystarczającej liczby pracowników."
            },
            {
