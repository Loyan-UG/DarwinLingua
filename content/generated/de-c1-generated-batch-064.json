        "feminine compound noun; plural: die Interpretationsleistungen"
      ],
      "collocations": [
        {
          "text": "eine überzeugende Interpretationsleistung",
          "meaning": "a convincing interpretive achievement"
        },
        {
          "text": "Interpretationsleistung der Lesenden",
          "meaning": "readers’ interpretive contribution"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "interpretieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Interpretation",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إنجاز تفسيري؛ مساهمة تأويلية"
        },
        {
          "language": "ckb",
          "text": "ئەنجامی لێکدانەوە؛ بەشداریی تەفسیر"
        },
        {
          "language": "en",
          "text": "interpretive achievement; interpretive contribution"
        },
        {
          "language": "fa",
          "text": "دستاورد تفسیری؛ کارکرد تفسیری"
        },
        {
          "language": "kmr",
          "text": "encama şîrovekirinê"
        },
        {
          "language": "pl",
          "text": "osiągnięcie interpretacyjne"
        },
        {
          "language": "ro",
          "text": "performanță interpretativă"
        },
        {
          "language": "ru",
          "text": "интерпретационное достижение"
        },
        {
          "language": "sq",
          "text": "arritje interpretuese"
        },
        {
          "language": "tr",
          "text": "yorumlama başarısı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Interpretationsleistung des Aufsatzes besteht darin, scheinbare Widersprüche produktiv zu erklären.",
          "translations": [
            {
              "language": "ar",
              "text": "تكمن الإنجاز التفسيري للمقال في شرح التناقضات الظاهرية بطريقة منتجة."
            },
            {
              "language": "ckb",
              "text": "ئەنجامی لێکدانەوەی وتارەکە لەوەدایە کە ناکۆکییە دەرکەوتووەکان بە شێوەیەکی بەرهەمدار ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The interpretive achievement of the essay lies in productively explaining apparent contradictions."
            },
            {
              "language": "fa",
              "text": "دستاورد تفسیری مقاله در توضیح سازنده تناقض‌های ظاهری است."
            },
            {
              "language": "kmr",
              "text": "Encama şîrovekirina gotarê di ravekirina berhemdar a dijberiyên xuya de ye."
            },
            {
              "language": "pl",
              "text": "Osiągnięcie interpretacyjne eseju polega na produktywnym wyjaśnieniu pozornych sprzeczności."
            },
            {
              "language": "ro",
              "text": "Performanța interpretativă a eseului constă în explicarea productivă a contradicțiilor aparente."
            },
            {
              "language": "ru",
              "text": "Интерпретационное достижение эссе состоит в продуктивном объяснении кажущихся противоречий."
            },
            {
              "language": "sq",
              "text": "Arritja interpretuese e esesë qëndron në shpjegimin produktiv të kundërshtive të dukshme."
            },
            {
              "language": "tr",
              "text": "Makalenin yorumlama başarısı görünürdeki çelişkileri üretken biçimde açıklamasında yatar."
            }
          ]
        },
        {
          "baseText": "Bei komplexen Verträgen ist die Interpretationsleistung der Fachabteilung oft entscheidend.",
          "translations": [
            {
              "language": "ar",
              "text": "في العقود المعقدة تكون مساهمة القسم المتخصص في التفسير غالبًا حاسمة."
            },
            {
              "language": "ckb",
              "text": "لە گرێبەستە ئاڵۆزەکاندا بەشداریی لێکدانەوەی بەشی پسپۆڕ زۆرجار بڕیاریدەرە."
            },
            {
              "language": "en",
              "text": "In complex contracts, the interpretive contribution of the specialist department is often decisive."
            },
            {
              "language": "fa",
              "text": "در قراردادهای پیچیده، کارکرد تفسیری بخش تخصصی اغلب تعیین‌کننده است."
            },
            {
              "language": "kmr",
              "text": "Di peymanên aloz de encama şîrovekirina beşa pispor gelek caran biryarder e."
            },
            {
              "language": "pl",
              "text": "Przy złożonych umowach wkład interpretacyjny działu specjalistycznego jest często decydujący."
            },
            {
              "language": "ro",
              "text": "În contractele complexe, contribuția interpretativă a departamentului de specialitate este adesea decisivă."
            },
            {
              "language": "ru",
              "text": "В сложных договорах интерпретационный вклад профильного отдела часто является решающим."
            },
            {
              "language": "sq",
              "text": "Në kontrata komplekse, kontributi interpretues i departamentit specialist shpesh është vendimtar."
            },
            {
              "language": "tr",
              "text": "Karmaşık sözleşmelerde uzman birimin yorumlama katkısı çoğu zaman belirleyicidir."
            }
          ]
        }
      ]
    },
