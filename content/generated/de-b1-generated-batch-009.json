  "entries": [
    {
      "word": "das Anschreiben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Anschreiben",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-schrei-ben",
      "topics": [
        "work-and-jobs",
        "documents-and-administration",
        "business-communication"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [
        "hr",
        "documents",
        "administration"
      ],
      "grammarNotes": [
        "neuter noun",
        "plural unchanged; often means cover letter in applications"
      ],
      "collocations": [
        {
          "text": "ein Anschreiben verfassen",
          "meaning": "to write a cover letter"
        },
        {
          "text": "Anschreiben und Lebenslauf",
          "meaning": "cover letter and CV"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "anschreiben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خطاب مرفق؛ رسالة تقديم"
        },
        {
          "language": "ckb",
          "text": "نامەی هاوپێچ؛ نامەی داواکاری"
        },
        {
          "language": "en",
          "text": "cover letter; accompanying letter"
        },
        {
          "language": "fa",
          "text": "نامه همراه؛ نامه درخواست کار"
        },
        {
          "language": "kmr",
          "text": "nameya pêvekirî; nameya serlêdanê"
        },
        {
          "language": "pl",
          "text": "list motywacyjny; pismo przewodnie"
        },
        {
          "language": "ro",
          "text": "scrisoare de intenție; adresă de însoțire"
        },
        {
          "language": "ru",
          "text": "сопроводительное письмо; мотивационное письмо"
        },
        {
          "language": "sq",
          "text": "letër motivimi; shkresë shoqëruese"
        },
        {
          "language": "tr",
          "text": "ön yazı; başvuru mektubu"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte senden Sie uns Ihr Anschreiben zusammen mit dem Lebenslauf als PDF.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال خطاب التقديم مع السيرة الذاتية بصيغة PDF."
            },
            {
              "language": "ckb",
              "text": "تکایە نامەی داواکارییەکەتان لەگەڵ ژیاننامە بە PDF بۆمان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us your cover letter together with your CV as a PDF."
            },
            {
              "language": "fa",
              "text": "لطفاً نامه همراه را همراه با رزومه به صورت PDF برای ما ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe nameya serlêdana xwe bi CV re wek PDF ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać list motywacyjny wraz z CV jako plik PDF."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți scrisoarea de intenție împreună cu CV-ul în format PDF."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам сопроводительное письмо вместе с резюме в формате PDF."
            },
            {
              "language": "sq",
              "text": "Ju lutem na dërgoni letrën e motivimit së bashku me CV-në si PDF."
            },
            {
              "language": "tr",
              "text": "Lütfen ön yazınızı özgeçmişinizle birlikte PDF olarak bize gönderin."
            }
          ]
        },
        {
          "baseText": "Im Anschreiben sollte kurz stehen, warum Sie sich für die Stelle interessieren.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي أن يوضح خطاب التقديم باختصار سبب اهتمامكم بالوظيفة."
            },
            {
              "language": "ckb",
              "text": "لە نامەی داواکارییەکەدا دەبێت بە کورتی بنووسرێت بۆچی ئارەزووی ئەم کارەتان هەیە."
            },
            {
              "language": "en",
              "text": "The cover letter should briefly state why you are interested in the position."
            },
            {
              "language": "fa",
              "text": "در نامه همراه باید کوتاه نوشته شود که چرا به این موقعیت علاقه دارید."
            },
            {
              "language": "kmr",
              "text": "Di nameya serlêdanê de divê bi kurtî were nivîsandin ka çima hûn bi vê postê eleqedar in."
            },
            {
              "language": "pl",
              "text": "W liście motywacyjnym powinno krótko być napisane, dlaczego interesuje Państwa to stanowisko."
            },
            {
              "language": "ro",
              "text": "În scrisoarea de intenție ar trebui să scrie pe scurt de ce vă interesează postul."
            },
            {
              "language": "ru",
              "text": "В сопроводительном письме следует кратко указать, почему вас интересует эта должность."
            },
            {
              "language": "sq",
              "text": "Në letrën e motivimit duhet të shkruhet shkurt pse jeni të interesuar për pozicionin."
            },
            {
              "language": "tr",
              "text": "Ön yazıda bu pozisyonla neden ilgilendiğiniz kısaca yazmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "ansehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ansehen",
      "pronunciationIpa": null,
      "syllableBreak": "an-se-hen",
      "topics": [
        "technology-and-it",
        "customer-service",
        "everyday-life"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "customer-service",
        "support",
        "documents"
      ],
      "grammarNotes": [
        "separable verb",
        "can mean to look at, watch, or consider someone/something as"
      ],
      "collocations": [
        {
          "text": "sich etwas ansehen",
          "meaning": "to look at something"
        },
        {
          "text": "als Problem ansehen",
          "meaning": "to consider as a problem"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Ansicht",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينظر إلى؛ يشاهد؛ يعتبر"
        },
        {
          "language": "ckb",
          "text": "سەیرکردن؛ بینین؛ بە شتێک دانان"
        },
        {
          "language": "en",
          "text": "to look at; to watch; to consider"
        },
        {
          "language": "fa",
          "text": "نگاه کردن؛ دیدن؛ تلقی کردن"
        },
        {
          "language": "kmr",
          "text": "temaşe kirin; nihêrîn; wek tiştekî dîtin"
        },
        {
          "language": "pl",
          "text": "obejrzeć; przyjrzeć się; uważać za"
        },
        {
          "language": "ro",
          "text": "a privi; a viziona; a considera"
        },
        {
          "language": "ru",
          "text": "посмотреть; рассмотреть; считать"
        },
        {
          "language": "sq",
          "text": "të shikosh; të konsiderosh"
        },
        {
          "language": "tr",
          "text": "bakmak; izlemek; değerlendirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich sehe mir den Fehler im System gleich an und melde mich danach.",
          "translations": [
            {
              "language": "ar",
              "text": "سأفحص الخطأ في النظام حالًا ثم أتواصل معكم بعد ذلك."
            },
            {
              "language": "ckb",
              "text": "هەر ئێستا هەڵەکە لە سیستەمدا دەبینمەوە و پاشان پەیوەندیتان پێوە دەکەم."
            },
            {
              "language": "en",
              "text": "I will look at the error in the system right away and get back to you afterward."
            },
            {
              "language": "fa",
              "text": "الان خطا را در سیستم بررسی می‌کنم و بعد با شما تماس می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez ê niha li çewtiya di pergalê de binêrim û paşê vegerim cem we."
            },
            {
              "language": "pl",
              "text": "Zaraz sprawdzę błąd w systemie i potem się odezwę."
            },
            {
              "language": "ro",
              "text": "Mă uit imediat la eroarea din sistem și revin după aceea."
            },
            {
              "language": "ru",
              "text": "Я сейчас посмотрю ошибку в системе и затем свяжусь с вами."
            },
            {
              "language": "sq",
              "text": "Do ta shikoj menjëherë gabimin në sistem dhe pastaj do t’ju kontaktoj."
            },
            {
              "language": "tr",
              "text": "Sistemdeki hataya hemen bakıp ardından size döneceğim."
            }
          ]
        },
        {
          "baseText": "Am Wochenende sehen wir uns eine Wohnung in der Nähe des Parks an.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع سنعاين شقة بالقرب من الحديقة."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا خانوویەک لە نزیک پارکەکە دەبینین."
            },
            {
              "language": "en",
