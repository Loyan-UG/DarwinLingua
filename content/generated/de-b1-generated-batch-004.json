  "entries": [
    {
      "word": "absinken",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "absinken",
      "pronunciationIpa": null,
      "syllableBreak": "ab-sin-ken",
      "topics": [
        "data-and-reporting",
        "finance-and-accounting",
        "environment-and-sustainability"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "analytics",
        "finance",
        "sustainability"
      ],
      "grammarNotes": [
        "separable verb",
        "often used for numbers, prices, temperatures, or levels that go down"
      ],
      "collocations": [
        {
          "text": "die Temperatur sinkt ab",
          "meaning": "the temperature drops"
        },
        {
          "text": "die Nachfrage sinkt ab",
          "meaning": "demand decreases"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sinken",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينخفض؛ يتراجع"
        },
        {
          "language": "ckb",
          "text": "دابەزین؛ کەمبوونەوە"
        },
        {
          "language": "en",
          "text": "to decrease; to drop; to sink"
        },
        {
          "language": "fa",
          "text": "کاهش یافتن؛ پایین آمدن"
        },
        {
          "language": "kmr",
          "text": "daketin; kêm bûn"
        },
        {
          "language": "pl",
          "text": "spadać; obniżać się"
        },
        {
          "language": "ro",
          "text": "a scădea; a coborî"
        },
        {
          "language": "ru",
          "text": "снижаться; падать"
        },
        {
          "language": "sq",
          "text": "të bjerë; të ulet"
        },
        {
          "language": "tr",
          "text": "düşmek; azalmak"
        }
      ],
      "examples": [
        {
          "baseText": "Im letzten Quartal ist die Zahl der Supportanfragen deutlich abgesunken.",
          "translations": [
            {
              "language": "ar",
              "text": "في الربع الأخير انخفض عدد طلبات الدعم بشكل واضح."
            },
            {
              "language": "ckb",
              "text": "لە چارەکی رابردوودا ژمارەی داواکارییەکانی پاڵپشتی بە روونی دابەزی."
            },
            {
              "language": "en",
              "text": "In the last quarter, the number of support requests dropped significantly."
            },
            {
              "language": "fa",
              "text": "در سه‌ماهه گذشته تعداد درخواست‌های پشتیبانی به‌طور واضح کاهش یافت."
            },
            {
              "language": "kmr",
              "text": "Di çaryeka dawî de hejmara daxwazên piştgiriyê bi eşkere daket."
            },
            {
              "language": "pl",
              "text": "W ostatnim kwartale liczba zgłoszeń do wsparcia wyraźnie spadła."
            },
            {
              "language": "ro",
              "text": "În ultimul trimestru, numărul cererilor de suport a scăzut clar."
            },
            {
              "language": "ru",
              "text": "В прошлом квартале количество обращений в поддержку заметно снизилось."
            },
            {
              "language": "sq",
              "text": "Në tremujorin e fundit, numri i kërkesave për mbështetje ra ndjeshëm."
            },
            {
              "language": "tr",
              "text": "Son çeyrekte destek taleplerinin sayısı belirgin şekilde düştü."
            }
          ]
        },
        {
          "baseText": "Nach Sonnenuntergang sinkt die Temperatur in den Bergen schnell ab.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد غروب الشمس تنخفض درجة الحرارة في الجبال بسرعة."
            },
            {
              "language": "ckb",
              "text": "دوای ئاوا بوونی خۆر، پلەی گەرمی لە چیاکان بە خێرایی دادەبەزێت."
            },
            {
              "language": "en",
              "text": "After sunset, the temperature in the mountains drops quickly."
            },
            {
              "language": "fa",
              "text": "بعد از غروب آفتاب، دما در کوهستان سریع پایین می‌آید."
            },
            {
              "language": "kmr",
              "text": "Piştî avabûna rojê, germahî li çiyan zû dadikeve."
            },
            {
              "language": "pl",
              "text": "Po zachodzie słońca temperatura w górach szybko spada."
            },
            {
              "language": "ro",
              "text": "După apus, temperatura în munți scade repede."
            },
            {
              "language": "ru",
              "text": "После захода солнца температура в горах быстро падает."
            },
            {
              "language": "sq",
              "text": "Pas perëndimit të diellit, temperatura në male bie shpejt."
            },
            {
              "language": "tr",
              "text": "Güneş battıktan sonra dağlarda sıcaklık hızla düşer."
            }
          ]
        }
      ]
    },
