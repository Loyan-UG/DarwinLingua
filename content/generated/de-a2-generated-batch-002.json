      "contextLabels": [],
      "grammarNotes": [
        "separable verb: ich gebe ab, ich habe abgegeben"
      ],
      "collocations": [
        {
          "text": "ein Formular abgeben",
          "meaning": "to hand in a form"
        },
        {
          "text": "den Schlüssel abgeben",
          "meaning": "to hand over the key"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "geben",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Abgabe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسلّم؛ يقدّم"
        },
        {
          "language": "ckb",
          "text": "ڕادەستکردن؛ پێشکەشکردن"
        },
        {
          "language": "en",
          "text": "to hand in; to hand over"
        },
        {
          "language": "fa",
          "text": "تحویل دادن؛ ارائه کردن"
        },
        {
          "language": "kmr",
          "text": "radest kirin; dayîn"
        },
        {
          "language": "pl",
          "text": "oddać; złożyć"
        },
        {
          "language": "ro",
          "text": "a preda; a depune"
        },
        {
          "language": "ru",
          "text": "сдавать; передавать"
        },
        {
          "language": "sq",
          "text": "të dorëzosh"
        },
        {
          "language": "tr",
          "text": "teslim etmek; vermek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich muss das Formular heute abgeben.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن أسلّم الاستمارة اليوم."
            },
            {
              "language": "ckb",
              "text": "دەبێت ئەمڕۆ فۆرمەکە ڕادەست بکەم."
            },
            {
              "language": "en",
              "text": "I have to hand in the form today."
            },
            {
              "language": "fa",
              "text": "باید امروز فرم را تحویل بدهم."
            },
            {
              "language": "kmr",
              "text": "Divê ez îro formê radest bikim."
            },
            {
              "language": "pl",
              "text": "Muszę dziś oddać formularz."
            },
            {
              "language": "ro",
              "text": "Trebuie să predau formularul astăzi."
            },
            {
              "language": "ru",
              "text": "Я должен сегодня сдать форму."
            },
            {
              "language": "sq",
              "text": "Duhet ta dorëzoj formularin sot."
            },
            {
              "language": "tr",
              "text": "Formu bugün teslim etmeliyim."
            }
          ]
        },
        {
          "baseText": "Bitte geben Sie den Schlüssel an der Rezeption ab.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تسليم المفتاح في الاستقبال."
            },
            {
              "language": "ckb",
              "text": "تکایە کلیلەکە لە پێشوازی ڕادەست بکەن."
            },
            {
              "language": "en",
              "text": "Please leave the key at reception."
            },
            {
              "language": "fa",
              "text": "لطفاً کلید را در پذیرش تحویل دهید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe mifte li resepsiyonê radest bikin."
            },
            {
              "language": "pl",
              "text": "Proszę oddać klucz w recepcji."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să predați cheia la recepție."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сдайте ключ на ресепшене."
            },
            {
              "language": "sq",
              "text": "Ju lutem dorëzojeni çelësin te recepsioni."
            },
            {
              "language": "tr",
              "text": "Lütfen anahtarı resepsiyona teslim edin."
            }
          ]
        }
      ]
    },
    {
      "word": "abgemacht",
