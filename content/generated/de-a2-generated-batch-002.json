          "language": "sq",
          "text": "i varur nga"
        },
        {
          "language": "tr",
          "text": "bağımlı; bağlı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Termin ist vom Arzt abhängig.",
          "translations": [
            {
              "language": "ar",
              "text": "الموعد يعتمد على الطبيب."
            },
            {
              "language": "ckb",
              "text": "کاتەکە پشت بە پزیشکەکە دەبەستێت."
            },
            {
              "language": "en",
              "text": "The appointment depends on the doctor."
            },
            {
              "language": "fa",
              "text": "وقت ملاقات به دکتر بستگی دارد."
            },
            {
              "language": "kmr",
              "text": "Dem girêdayî bijîşk e."
            },
            {
              "language": "pl",
              "text": "Termin zależy od lekarza."
            },
            {
              "language": "ro",
              "text": "Programarea depinde de medic."
            },
            {
              "language": "ru",
              "text": "Запись зависит от врача."
            },
            {
              "language": "sq",
              "text": "Takimi varet nga mjeku."
            },
            {
              "language": "tr",
              "text": "Randevu doktora bağlıdır."
            }
          ]
        },
        {
          "baseText": "Unsere Planung ist vom Wetter abhängig.",
          "translations": [
            {
              "language": "ar",
              "text": "تخطيطنا يعتمد على الطقس."
            },
            {
              "language": "ckb",
              "text": "پلانەکەمان پشت بە کەشوهەوا دەبەستێت."
            },
            {
              "language": "en",
              "text": "Our plan depends on the weather."
            },
            {
              "language": "fa",
              "text": "برنامه‌ریزی ما به هوا بستگی دارد."
            },
            {
              "language": "kmr",
              "text": "Plana me girêdayî hewayê ye."
            },
            {
              "language": "pl",
              "text": "Nasz plan zależy od pogody."
            },
            {
              "language": "ro",
              "text": "Planul nostru depinde de vreme."
            },
            {
              "language": "ru",
              "text": "Наш план зависит от погоды."
            },
            {
              "language": "sq",
              "text": "Plani ynë varet nga moti."
            },
            {
              "language": "tr",
              "text": "Planımız hava durumuna bağlı."
            }
          ]
        }
      ]
