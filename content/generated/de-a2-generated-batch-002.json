      ],
      "usageLabels": [
        "spoken",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "often used as a short answer meaning agreed"
      ],
      "collocations": [
        {
          "text": "Abgemacht!",
          "meaning": "Agreed!"
        },
        {
          "text": "das ist abgemacht",
          "meaning": "that is agreed"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "abmachen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Abmachung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متفق عليه؛ حسناً"
        },
        {
          "language": "ckb",
          "text": "ڕێککەوتوو؛ باشە"
        },
        {
          "language": "en",
          "text": "agreed; settled"
        },
        {
          "language": "fa",
          "text": "توافق شد؛ باشه"
        },
        {
          "language": "kmr",
          "text": "li hev hatî; baş e"
        },
        {
          "language": "pl",
          "text": "uzgodnione; umówione"
        },
        {
          "language": "ro",
          "text": "stabilit; de acord"
        },
        {
          "language": "ru",
          "text": "договорились; согласовано"
        },
        {
          "language": "sq",
          "text": "e rënë dakord"
        },
        {
          "language": "tr",
          "text": "anlaştık; kararlaştırılmış"
        }
      ],
      "examples": [
        {
          "baseText": "Wir treffen uns um acht Uhr, abgemacht?",
          "translations": [
            {
              "language": "ar",
              "text": "نلتقي في الساعة الثامنة، اتفقنا؟"
            },
            {
              "language": "ckb",
              "text": "کاتژمێر هەشت یەکدەگرینەوە، ڕێککەوتین؟"
            },
            {
              "language": "en",
              "text": "We meet at eight o’clock, agreed?"
            },
            {
              "language": "fa",
              "text": "ساعت هشت همدیگر را می‌بینیم، باشه؟"
            },
            {
              "language": "kmr",
              "text": "Em di saet heştan de hev dibînin, li hev hat?"
            },
            {
              "language": "pl",
              "text": "Spotykamy się o ósmej, zgoda?"
            },
            {
              "language": "ro",
              "text": "Ne întâlnim la ora opt, de acord?"
            },
            {
              "language": "ru",
              "text": "Встречаемся в восемь, договорились?"
            },
            {
              "language": "sq",
              "text": "Takohemi në orën tetë, dakord?"
            },
            {
              "language": "tr",
              "text": "Saat sekizde buluşuyoruz, anlaştık mı?"
            }
          ]
        },
        {
          "baseText": "Abgemacht, ich rufe Sie morgen an.",
          "translations": [
            {
              "language": "ar",
              "text": "اتفقنا، سأتصل بكم غداً."
            },
            {
              "language": "ckb",
              "text": "باشە، سبەی پەیوەندیت پێوە دەکەم."
            },
            {
              "language": "en",
              "text": "Agreed, I will call you tomorrow."
            },
            {
              "language": "fa",
              "text": "باشه، فردا با شما تماس می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Baş e, ez ê sibê telefonî we bikim."
            },
            {
              "language": "pl",
              "text": "Uzgodnione, zadzwonię jutro."
            },
            {
              "language": "ro",
              "text": "De acord, vă sun mâine."
            },
            {
              "language": "ru",
              "text": "Договорились, я позвоню вам завтра."
            },
            {
              "language": "sq",
              "text": "Dakord, do t’ju telefonoj nesër."
            },
            {
              "language": "tr",
              "text": "Anlaştık, yarın sizi arayacağım."
            }
          ]
        }
      ]
    },
