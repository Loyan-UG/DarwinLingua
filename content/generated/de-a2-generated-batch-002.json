          "language": "en",
          "text": "dependent on; depending on"
        },
        {
          "language": "fa",
          "text": "وابسته به؛ بستگی دارد به"
        },
        {
          "language": "kmr",
          "text": "girêdayî; pê ve girêdayî"
        },
        {
          "language": "pl",
          "text": "zależny od"
        },
        {
          "language": "ro",
          "text": "dependent de"
        },
        {
          "language": "ru",
          "text": "зависимый от; зависящий от"
