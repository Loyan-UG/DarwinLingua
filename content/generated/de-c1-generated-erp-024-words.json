  "entries": [
    {
      "word": "vorgelagerte Tour",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "vorgelagerten Touren",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "vor-ge-la-ger-te Tour",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP/logistics term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جولة سابقة في السلسلة"
        },
        {
          "language": "ckb",
          "text": "گەشتی پێشووتر"
        },
        {
          "language": "en",
          "text": "upstream route"
        },
        {
          "language": "fa",
          "text": "مسیر پیشین"
        },
        {
          "language": "kmr",
          "text": "gera pêşîn"
        },
        {
          "language": "pl",
          "text": "trasa poprzedzająca"
        },
        {
          "language": "ro",
          "text": "tură anterioară"
        },
        {
          "language": "ru",
          "text": "предшествующий маршрут"
        },
        {
          "language": "sq",
          "text": "tur paraprak"
        },
        {
          "language": "tr",
          "text": "önceki tur"
        }
      ],
      "examples": [
        {
          "baseText": "Die vorgelagerte Tour muss im ERP abgeschlossen sein, bevor die Anschlusslieferung geplant werden kann.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب إغلاق الجولة السابقة في ERP قبل تخطيط التسليم اللاحق."
            },
            {
              "language": "ckb",
              "text": "گەشتی پێشووتر دەبێت لە ERPدا تەواو بکرێت پێش پلاندانی گەیاندنی دواتر."
            },
            {
              "language": "en",
              "text": "The upstream route must be completed in ERP before the connecting delivery can be planned."
            },
            {
              "language": "fa",
              "text": "مسیر پیشین باید در ERP بسته شود تا تحویل بعدی برنامه‌ریزی شود."
            },
            {
              "language": "kmr",
              "text": "Gera pêşîn divê di ERP de qediya be berî plansaziya radestkirina din."
            },
            {
              "language": "pl",
              "text": "Trasa poprzedzająca musi być zamknięta w ERP przed planowaniem dostawy."
            },
            {
              "language": "ro",
              "text": "Tura anterioară trebuie finalizată în ERP înaintea livrării următoare."
            },
            {
              "language": "ru",
              "text": "Предшествующий маршрут должен быть закрыт в ERP до планирования последующей поставки."
            },
            {
              "language": "sq",
              "text": "Turi paraprak duhet mbyllur në ERP para planifikimit të dorëzimit vijues."
            },
            {
              "language": "tr",
              "text": "Önceki tur bağlantılı teslimat planlanmadan ERP içinde tamamlanmış olmalıdır."
            }
          ]
        },
        {
          "baseText": "Die Disposition verschob die vorgelagerte Tour, weil ein Zubringerfahrzeug verspätet am Umschlaglager eintraf.",
          "translations": [
            {
              "language": "ar",
              "text": "نقلت الديسبتش الجولة السابقة لأن مركبة التغذية وصلت متأخرة إلى مستودع التحويل."
            },
            {
              "language": "ckb",
              "text": "پلاندانان گەشتی پێشووتری گواستەوە چونکە ئۆتۆمبێلی پەیوەستکراو دوا گەیشت."
            },
            {
              "language": "en",
              "text": "Dispatch postponed the upstream route because a feeder vehicle arrived late at the transshipment warehouse."
            },
            {
              "language": "fa",
              "text": "برنامه‌ریزی مسیر پیشین را عقب انداخت چون خودروی تغذیه‌کننده دیر به انبار انتقال رسید."
            },
            {
              "language": "kmr",
              "text": "Plansazî gera pêşîn paşxist ji ber ku wesayîta girêdanê dereng hat."
            },
            {
              "language": "pl",
              "text": "Dyspozycja przesunęła trasę, bo pojazd dowozowy się spóźnił."
            },
            {
              "language": "ro",
              "text": "Dispeceratul a amânat tura deoarece vehiculul de alimentare a întârziat."
            },
            {
              "language": "ru",
              "text": "Диспозиция перенесла маршрут, потому что подвозящая машина опоздала."
            },
            {
              "language": "sq",
              "text": "Dispeçeria e shtyu turin sepse automjeti ushqyes u vonua."
            },
            {
              "language": "tr",
              "text": "Planlama önceki turu erteledi, çünkü besleme aracı aktarma deposuna geç geldi."
            }
          ]
        }
      ]
    },
    {
      "word": "vorgelagerter Tourstopp",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "vorgelagerten Tourstopps",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "vor-ge-la-ger-ter Tour-stopp",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "der noun; specialized ERP/logistics term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "توقف سابق في الجولة"
        },
        {
          "language": "ckb",
          "text": "وەستانی پێشووتری گەشت"
        },
        {
          "language": "en",
          "text": "upstream route stop"
        },
        {
          "language": "fa",
          "text": "توقف پیشین مسیر"
        },
        {
          "language": "kmr",
          "text": "rawestgeha pêşîn"
        },
        {
          "language": "pl",
          "text": "poprzedzający przystanek trasy"
        },
        {
          "language": "ro",
          "text": "oprire anterioară"
        },
        {
          "language": "ru",
          "text": "предшествующая остановка маршрута"
        },
        {
          "language": "sq",
          "text": "ndalesë paraprake"
        },
        {
          "language": "tr",
          "text": "önceki tur durağı"
        }
      ],
      "examples": [
        {
          "baseText": "Der vorgelagerte Tourstopp bestimmt im ERP, wann die Ware am Umschlagpunkt für die nächste Tour bereitsteht.",
          "translations": [
            {
              "language": "ar",
              "text": "يحدد التوقف السابق في ERP متى تكون البضاعة جاهزة في نقطة التحويل للجولة التالية."
            },
            {
              "language": "ckb",
              "text": "وەستانی پێشووتر لە ERPدا دیاری دەکات کاڵا کەی لە خاڵی گواستنەوە بۆ گەشتی داهاتوو ئامادەیە."
            },
            {
              "language": "en",
              "text": "The upstream route stop determines in ERP when goods are available at the transfer point for the next route."
            },
            {
              "language": "fa",
              "text": "توقف پیشین در ERP مشخص می‌کند کالا چه زمانی در نقطه انتقال برای مسیر بعدی آماده است."
            },
            {
              "language": "kmr",
              "text": "Rawestgeha pêşîn di ERP de diyar dike mal kengî li xala veguhastinê amade ye."
            },
            {
              "language": "pl",
              "text": "Poprzedzający przystanek określa w ERP dostępność towaru dla kolejnej trasy."
            },
            {
              "language": "ro",
              "text": "Oprirea anterioară stabilește în ERP disponibilitatea mărfii pentru tura următoare."
            },
            {
              "language": "ru",
              "text": "Предшествующая остановка определяет в ERP готовность товара для следующего маршрута."
            },
            {
              "language": "sq",
              "text": "Ndalesa paraprake përcakton në ERP kur malli është gati për turin tjetër."
            },
            {
              "language": "tr",
              "text": "Önceki tur durağı, malın sonraki tur için ne zaman hazır olduğunu ERP içinde belirler."
            }
          ]
        },
        {
          "baseText": "Der vorgelagerte Tourstopp wurde storniert, weil der Kunde die Abholung kurzfristig in ein anderes Lager verlegte.",
          "translations": [
            {
              "language": "ar",
              "text": "أُلغي التوقف السابق لأن العميل نقل الاستلام في وقت قصير إلى مستودع آخر."
            },
            {
              "language": "ckb",
              "text": "وەستانی پێشووتر هەڵوەشێنرایەوە چونکە کڕیار وەرگرتنی بە کاتی کورت بۆ کۆگایەکی تر گواستەوە."
            },
            {
              "language": "en",
              "text": "The upstream route stop was cancelled because the customer moved pickup to another warehouse at short notice."
            },
            {
              "language": "fa",
              "text": "توقف پیشین لغو شد چون مشتری تحویل‌گیری را در لحظه آخر به انبار دیگری منتقل کرد."
            },
            {
              "language": "kmr",
              "text": "Rawestgeh hate betal kirin ji ber ku xerîdar wergirtin veguhezand depoyeke din."
            },
            {
              "language": "pl",
              "text": "Przystanek anulowano, bo klient przeniósł odbiór do innego magazynu."
            },
            {
              "language": "ro",
              "text": "Oprirea a fost anulată deoarece clientul a mutat ridicarea."
            },
            {
              "language": "ru",
              "text": "Остановка была отменена, потому что клиент перенес самовывоз на другой склад."
            },
            {
              "language": "sq",
              "text": "Ndalesa u anulua sepse klienti e zhvendosi marrjen."
            },
            {
              "language": "tr",
              "text": "Önceki durak iptal edildi, çünkü müşteri alımı başka depoya taşıdı."
            }
          ]
        }
      ]
    },
    {
      "word": "Vorschau Auftragsimport",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Vorschauen Auftragsimport",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Vor-schau Auf-trags-im-port",
      "topics": [
        "erp-and-business-systems",
        "sales-and-customers",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "die noun; specialized ERP/logistics term"
      ],
      "collocations": [],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "معاينة استيراد الطلبات"
        },
        {
          "language": "ckb",
          "text": "پێشبینی هاوردەی داواکاری"
        },
        {
          "language": "en",
          "text": "order import preview"
        },
        {
          "language": "fa",
          "text": "پیش‌نمایش واردسازی سفارش"
        },
        {
          "language": "kmr",
          "text": "pêşdîtina importkirina fermanan"
        },
        {
          "language": "pl",
          "text": "podgląd importu zamówień"
        },
        {
          "language": "ro",
          "text": "previzualizare import comenzi"
        },
        {
          "language": "ru",
          "text": "предпросмотр импорта заказов"
        },
        {
          "language": "sq",
          "text": "parapamje importi porosish"
        },
        {
          "language": "tr",
          "text": "sipariş içe aktarma önizlemesi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Vorschau Auftragsimport zeigt im ERP, welche Kundenaufträge vor dem eigentlichen Import fehlerhaft oder unvollständig sind.",
          "translations": [
            {
              "language": "ar",
              "text": "تُظهر معاينة استيراد الطلبات في ERP أي طلبات عملاء فيها أخطاء أو نواقص قبل الاستيراد الفعلي."
            },
            {
              "language": "ckb",
              "text": "پێشبینی هاوردەی داواکاری لە ERPدا نیشان دەدات کام داواکاریی کڕیار پێش هاوردەکردنی ڕاستەقینە هەڵە یان کەمە."
            },
            {
              "language": "en",
              "text": "The order import preview shows in ERP which customer orders are faulty or incomplete before the actual import."
            },
            {
              "language": "fa",
              "text": "پیش‌نمایش واردسازی سفارش در ERP نشان می‌دهد کدام سفارش‌های مشتری قبل از واردسازی واقعی ناقص یا خطادارند."
            },
            {
              "language": "kmr",
              "text": "Pêşdîtin di ERP de nîşan dide kîjan ferman berî importê şaş an netemam e."
            },
            {
              "language": "pl",
              "text": "Podgląd importu pokazuje w ERP błędne lub niepełne zamówienia przed importem."
            },
            {
              "language": "ro",
              "text": "Previzualizarea arată în ERP comenzile eronate sau incomplete înainte de import."
            },
            {
              "language": "ru",
              "text": "Предпросмотр показывает в ERP ошибочные или неполные заказы до импорта."
            },
            {
              "language": "sq",
              "text": "Parapamja tregon në ERP porositë me gabime para importit."
            },
            {
              "language": "tr",
              "text": "Sipariş içe aktarma önizlemesi ERP içinde hatalı veya eksik siparişleri gösterir."
            }
          ]
        },
        {
          "baseText": "Der Vertrieb nutzte die Vorschau Auftragsimport, um fehlende Lieferadressen vor dem Tagesabschluss zu korrigieren.",
          "translations": [
            {
              "language": "ar",
              "text": "استخدمت المبيعات معاينة الاستيراد لتصحيح عناوين تسليم مفقودة قبل إقفال اليوم."
            },
            {
              "language": "ckb",
