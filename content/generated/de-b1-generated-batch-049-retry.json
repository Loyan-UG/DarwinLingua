      "examples": [
        {
          "baseText": "Haben Sie eine Empfehlung für ein gutes Projektmanagement-Tool?",
          "translations": [
            {
              "language": "ar",
              "text": "هل لديك توصية لأداة جيدة لإدارة المشاريع؟"
            },
            {
              "language": "ckb",
              "text": "پێشنیارتان هەیە بۆ ئامرازێکی باشی بەڕێوەبردنی پرۆژە؟"
            },
            {
              "language": "en",
              "text": "Do you have a recommendation for a good project management tool?"
            },
            {
              "language": "fa",
              "text": "آیا پیشنهادی برای یک ابزار خوب مدیریت پروژه دارید؟"
            },
            {
              "language": "kmr",
              "text": "Ma pêşniyara we ji bo amûrekî baş ê rêveberiya projeyê heye?"
            },
            {
              "language": "pl",
              "text": "Czy mają Państwo rekomendację dobrego narzędzia do zarządzania projektami?"
            },
            {
              "language": "ro",
              "text": "Aveți o recomandare pentru un instrument bun de management al proiectelor?"
            },
            {
              "language": "ru",
              "text": "У вас есть рекомендация хорошего инструмента для управления проектами?"
            },
            {
              "language": "sq",
              "text": "A keni ndonjë rekomandim për një mjet të mirë menaxhimi projektesh?"
            },
            {
              "language": "tr",
              "text": "İyi bir proje yönetim aracı için öneriniz var mı?"
            }
          ]
        },
        {
          "baseText": "Auf Empfehlung meiner Ärztin mache ich jetzt mehr Pausen.",
          "translations": [
            {
              "language": "ar",
              "text": "بناءً على توصية طبيبتي آخذ الآن فترات راحة أكثر."
            },
            {
              "language": "ckb",
              "text": "بەپێی ڕاسپاردەی پزیشکەکەم، ئێستا پشووی زیاتر دەدەم."
            },
            {
              "language": "en",
              "text": "On my doctor’s recommendation, I now take more breaks."
            },
            {
              "language": "fa",
              "text": "به توصیه پزشکم، حالا بیشتر استراحت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Li gor pêşniyara bijîşka min, ez niha bêhnvedanên zêdetir dikim."
            },
            {
              "language": "pl",
              "text": "Z zalecenia lekarki robię teraz więcej przerw."
            },
            {
              "language": "ro",
              "text": "La recomandarea medicului meu, fac acum mai multe pauze."
            },
            {
              "language": "ru",
              "text": "По рекомендации врача я теперь делаю больше перерывов."
            },
            {
              "language": "sq",
              "text": "Me rekomandimin e mjekes sime, tani bëj më shumë pushime."
            },
            {
              "language": "tr",
              "text": "Doktorumun tavsiyesiyle artık daha fazla mola veriyorum."
            }
          ]
        }
      ]
    }
