  "entries": [
    {
      "language": "de",
      "cefrLevel": "C2",
      "article": "der",
      "plural": "Untertöne",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Un-ter-ton",
      "contextLabels": [],
      "grammarNotes": [],
      "collocations": [
        {
          "text": "ein kritischer Unterton",
          "meaning": "a critical undertone"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "word": "der Unterton",
      "partOfSpeech": "Noun",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "culture-and-media"
      ],
      "usageLabels": [
        "formal",
        "written",
        "analysis",
        "sensitive"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "نبرة ضمنية؛ إيحاء خفي"
        },
        {
          "language": "ckb",
          "text": "تۆنی شاراوە؛ مانای لاوەکی"
        },
        {
          "language": "en",
          "text": "undertone; implicit nuance"
        },
        {
          "language": "fa",
          "text": "لحن پنهان؛ معنای ضمنی"
        },
        {
          "language": "kmr",
          "text": "tona veşartî; nîansa veşartî"
        },
        {
          "language": "pl",
          "text": "podtekst; ton poboczny"
        },
        {
          "language": "ro",
          "text": "subton; nuanță implicită"
        },
        {
          "language": "ru",
          "text": "подтекст; оттенок"
        },
        {
          "language": "sq",
          "text": "nënton; nuancë e fshehtë"
        },
        {
          "language": "tr",
          "text": "alt ton; ima"
        }
      ],
      "examples": [
        {
          "baseText": "In der Antwort des Kunden lag ein deutlicher Unterton von Misstrauen, obwohl er formal höflich blieb.",
          "translations": [
            {
              "language": "ar",
              "text": "كان في رد العميل إيحاء واضح بعدم الثقة، رغم أنه بقي مهذباً رسمياً."
            },
            {
              "language": "ckb",
              "text": "لە وەڵامی کڕیارەکەدا تۆنێکی ڕوونی بێمتمانەیی هەبوو، هەرچەندە بە فەرمی ڕێزدار مایەوە."
            },
            {
              "language": "en",
              "text": "There was a clear undertone of mistrust in the customer’s reply, although it remained formally polite."
            },
            {
              "language": "fa",
              "text": "در پاسخ مشتری لحن پنهان بی‌اعتمادی کاملاً محسوس بود، هرچند از نظر رسمی مؤدبانه ماند."
            },
            {
              "language": "kmr",
              "text": "Di bersiva xerîdar de tona bêbaweriyê ya zelal hebû, herçend ew bi fermî nezaketî ma."
            },
            {
              "language": "pl",
              "text": "W odpowiedzi klienta był wyraźny podtekst nieufności, choć formalnie pozostała uprzejma."
            },
            {
              "language": "ro",
              "text": "În răspunsul clientului exista un subton clar de neîncredere, deși formal a rămas politicos."
            },
            {
              "language": "ru",
              "text": "В ответе клиента был явный оттенок недоверия, хотя формально он оставался вежливым."
            },
            {
              "language": "sq",
              "text": "Në përgjigjen e klientit kishte një nënton të qartë mosbesimi, megjithëse formalisht mbeti i sjellshëm."
            },
            {
              "language": "tr",
              "text": "Müşterinin yanıtında belirgin bir güvensizlik alt tonu vardı, ancak biçimsel olarak nazik kaldı."
            }
          ]
        },
        {
          "baseText": "Der ironische Unterton der Erzählung verhindert, dass die Trauer sentimental wirkt.",
          "translations": [
            {
              "language": "ar",
              "text": "تمنع النبرة الساخرة الخفية في السرد الحزن من أن يبدو عاطفياً مبتذلاً."
            },
            {
              "language": "ckb",
              "text": "تۆنی ئیرۆنیای شاراوەی گێڕانەوەکە ڕێگری دەکات لەوەی خەمگینی هەستیارانەی سادە دەربکەوێت."
            },
            {
              "language": "en",
              "text": "The ironic undertone of the narrative keeps the grief from seeming sentimental."
            },
            {
              "language": "fa",
              "text": "لحن پنهان طنزآمیز روایت مانع می‌شود اندوه احساساتی و سطحی به نظر برسد."
            },
            {
              "language": "kmr",
              "text": "Tona ironîk a veşartî ya vegotinê nahêle ku xem sentimental xuya bike."
            },
            {
              "language": "pl",
              "text": "Ironiczny podtekst opowieści sprawia, że żałoba nie wydaje się sentymentalna."
            },
            {
              "language": "ro",
              "text": "Subtonul ironic al narațiunii împiedică durerea să pară sentimentală."
            },
            {
              "language": "ru",
              "text": "Иронический подтекст повествования не дает горю выглядеть сентиментальным."
            },
            {
              "language": "sq",
              "text": "Nëntoni ironik i rrëfimit e pengon pikëllimin të duket sentimental."
            },
            {
              "language": "tr",
              "text": "Anlatının ironik alt tonu, kederin duygusal ve basit görünmesini engeller."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C2",
      "article": "die",
      "plural": "Unterwanderungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Un-ter-wan-de-rung",
      "contextLabels": [],
      "grammarNotes": [],
      "collocations": [
        {
          "text": "die Unterwanderung von Kontrollmechanismen",
          "meaning": "the infiltration or undermining of control mechanisms"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "word": "die Unterwanderung",
      "partOfSpeech": "Noun",
      "topics": [
        "law-and-compliance",
        "quality-and-risk",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive",
        "analysis"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تسلل تقويضي؛ اختراق من الداخل"
        },
        {
          "language": "ckb",
          "text": "ژێرەوە تێکدان؛ چوونەناوەوە بۆ لاوازکردن"
        },
        {
          "language": "en",
          "text": "infiltration; undermining from within"
        },
        {
          "language": "fa",
          "text": "نفوذ و تضعیف از درون"
        },
        {
          "language": "kmr",
          "text": "ji hundir ve têkdan; ketina nav ji bo lawazkirin"
        },
        {
          "language": "pl",
          "text": "infiltracja; podkopywanie"
        },
        {
          "language": "ro",
          "text": "infiltrare; subminare din interior"
        },
        {
          "language": "ru",
          "text": "подрыв изнутри; инфильтрация"
        },
        {
          "language": "sq",
          "text": "infiltrim; minimin nga brenda"
        },
        {
          "language": "tr",
          "text": "içten sızma; altını oyma"
        }
      ],
      "examples": [
        {
          "baseText": "Die interne Revision warnte vor einer schleichenden Unterwanderung der Freigabeprozesse durch informelle Absprachen.",
          "translations": [
            {
              "language": "ar",
              "text": "حذرت المراجعة الداخلية من تقويض تدريجي لعمليات الموافقة عبر تفاهمات غير رسمية."
            },
            {
              "language": "ckb",
              "text": "پشکنینی ناوخۆ ئاگاداری دا لە ژێرەوە تێکدانی هێواشی پڕۆسەکانی پەسەندکردن بە ڕێککەوتنی نافەرمی."
            },
            {
              "language": "en",
              "text": "Internal audit warned of a gradual undermining of approval processes through informal arrangements."
            },
            {
              "language": "fa",
              "text": "حسابرسی داخلی درباره تضعیف تدریجی فرایندهای تأیید از طریق توافق‌های غیررسمی هشدار داد."
            },
            {
              "language": "kmr",
              "text": "Kontrola hundirîn hişyarî da li ser binpêkirina hêdî ya pêvajoyên pejirandinê bi rêkeftinên nefermî."
            },
            {
              "language": "pl",
              "text": "Audyt wewnętrzny ostrzegł przed stopniowym podkopywaniem procesów zatwierdzania przez nieformalne ustalenia."
            },
            {
              "language": "ro",
              "text": "Auditul intern a avertizat asupra subminării treptate a proceselor de aprobare prin înțelegeri informale."
            },
            {
              "language": "ru",
              "text": "Внутренний аудит предупредил о постепенном подрыве процессов согласования через неформальные договоренности."
            },
            {
              "language": "sq",
              "text": "Auditimi i brendshëm paralajmëroi për minimin gradual të proceseve të miratimit përmes marrëveshjeve joformale."
            },
            {
              "language": "tr",
              "text": "İç denetim, gayriresmi anlaşmalar yoluyla onay süreçlerinin kademeli olarak altının oyulmasına karşı uyardı."
            }
          ]
        },
        {
          "baseText": "Der Roman beschreibt die Unterwanderung einer Familie durch Schweigen, nicht durch offene Feindschaft.",
          "translations": [
            {
              "language": "ar",
              "text": "تصف الرواية تقويض عائلة بالصمت لا بالعداء المفتوح."
            },
            {
              "language": "ckb",
              "text": "ڕۆمانەکە ژێرەوە تێکدانی خێزانێک بە بێدەنگی وەسف دەکات، نەک بە دوژمنایەتی ئاشکرا."
            },
            {
              "language": "en",
              "text": "The novel describes the undermining of a family by silence, not by open hostility."
            },
            {
              "language": "fa",
              "text": "رمان تضعیف یک خانواده را از راه سکوت توصیف می‌کند، نه دشمنی آشکار."
            },
            {
              "language": "kmr",
              "text": "Roman binpêkirina malbatekê bi bêdengiyê vedibêje, ne bi dijminatiya eşkere."
            },
            {
              "language": "pl",
              "text": "Powieść opisuje podkopywanie rodziny przez milczenie, a nie przez otwartą wrogość."
            },
            {
              "language": "ro",
              "text": "Romanul descrie subminarea unei familii prin tăcere, nu prin ostilitate deschisă."
            },
            {
              "language": "ru",
              "text": "Роман описывает подрыв семьи молчанием, а не открытой враждой."
            },
            {
              "language": "sq",
              "text": "Romani përshkruan minimin e një familjeje përmes heshtjes, jo armiqësisë së hapur."
            },
            {
              "language": "tr",
              "text": "Roman bir ailenin açık düşmanlıkla değil, sessizlikle içten içe aşındırılmasını anlatır."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
