      ],
      "examples": [
        {
          "baseText": "Ich gehe morgen zum Friseur.",
          "translations": [
            {
              "language": "ar",
              "text": "سأذهب غداً إلى الحلاق."
            },
            {
              "language": "ckb",
              "text": "سبەی دەچم بۆ قژبڕ."
            },
            {
              "language": "en",
              "text": "I am going to the hairdresser tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا به آرایشگاه می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez sibê diçim ba porçêker."
            },
            {
              "language": "pl",
              "text": "Jutro idę do fryzjera."
            },
            {
              "language": "ro",
              "text": "Mâine merg la frizer."
            },
            {
              "language": "ru",
              "text": "Завтра я иду к парикмахеру."
            },
            {
              "language": "sq",
              "text": "Nesër shkoj te parukieri."
            },
            {
              "language": "tr",
              "text": "Yarın kuaföre gidiyorum."
            }
          ]
        },
        {
          "baseText": "Der Friseur schneidet meine Haare kurz.",
          "translations": [
            {
              "language": "ar",
              "text": "الحلاق يقص شعري قصيراً."
            },
            {
              "language": "ckb",
              "text": "قژبڕەکە قژم کورت دەکات."
            },
            {
              "language": "en",
              "text": "The hairdresser cuts my hair short."
            },
            {
              "language": "fa",
              "text": "آرایشگر موهایم را کوتاه می‌کند."
            },
            {
              "language": "kmr",
              "text": "Porçêker porê min kurt dike."
            },
            {
              "language": "pl",
              "text": "Fryzjer ścina mi włosy krótko."
            },
            {
              "language": "ro",
              "text": "Frizerul îmi tunde părul scurt."
            },
            {
              "language": "ru",
              "text": "Парикмахер коротко стрижёт мне волосы."
            },
            {
              "language": "sq",
              "text": "Parukieri m’i pret flokët shkurt."
            },
            {
              "language": "tr",
              "text": "Kuaför saçımı kısa kesiyor."
            }
          ]
        }
      ]
