      ],
      "wordFamilies": [
        {
          "lemma": "frei",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وقت فراغ"
        },
        {
          "language": "ckb",
          "text": "کاتی ئازاد"
        },
        {
          "language": "en",
          "text": "free time; leisure time"
        },
        {
          "language": "fa",
          "text": "وقت آزاد؛ اوقات فراغت"
        },
        {
          "language": "kmr",
          "text": "dema vala"
        },
        {
          "language": "pl",
          "text": "czas wolny"
        },
        {
          "language": "ro",
          "text": "timp liber"
        },
        {
          "language": "ru",
          "text": "свободное время"
        },
        {
          "language": "sq",
          "text": "kohë e lirë"
        },
        {
          "language": "tr",
          "text": "boş zaman"
        }
      ],
      "examples": [
        {
          "baseText": "Was machst du in deiner Freizeit?",
          "translations": [
            {
              "language": "ar",
              "text": "ماذا تفعل في وقت فراغك؟"
            },
            {
              "language": "ckb",
              "text": "لە کاتی ئازادتدا چی دەکەیت؟"
            },
            {
              "language": "en",
              "text": "What do you do in your free time?"
            },
            {
              "language": "fa",
              "text": "در وقت آزادت چه کار می‌کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu di dema xwe ya vala de çi dikî?"
            },
            {
              "language": "pl",
              "text": "Co robisz w wolnym czasie?"
            },
            {
              "language": "ro",
              "text": "Ce faci în timpul liber?"
            },
            {
              "language": "ru",
              "text": "Что ты делаешь в свободное время?"
            },
            {
              "language": "sq",
              "text": "Çfarë bën në kohën tënde të lirë?"
            },
            {
              "language": "tr",
              "text": "Boş zamanında ne yaparsın?"
            }
          ]
        },
        {
          "baseText": "Nach der Arbeit habe ich wenig Freizeit.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد العمل لدي وقت فراغ قليل."
            },
            {
              "language": "ckb",
              "text": "دوای کار کاتی ئازادم کەمە."
            },
            {
              "language": "en",
              "text": "After work I have little free time."
            },
            {
              "language": "fa",
              "text": "بعد از کار وقت آزاد کمی دارم."
            },
            {
              "language": "kmr",
              "text": "Piştî xebatê dema min ya vala kêm e."
            },
            {
              "language": "pl",
              "text": "Po pracy mam mało wolnego czasu."
            },
            {
              "language": "ro",
              "text": "După muncă am puțin timp liber."
            },
            {
              "language": "ru",
              "text": "После работы у меня мало свободного времени."
            },
            {
              "language": "sq",
              "text": "Pas punës kam pak kohë të lirë."
            },
            {
              "language": "tr",
              "text": "İşten sonra az boş vaktim var."
            }
          ]
        }
      ]
    },
