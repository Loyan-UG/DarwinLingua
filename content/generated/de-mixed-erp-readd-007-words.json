      "word": "der Spediteur",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Spediteure",
      "infinitive": null,
      "syllableBreak": "Spe-di-teur",
      "topics": [
        "warehouse-and-logistics",
        "procurement-and-suppliers",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "workplace"
      ],
      "grammarNotes": [
        "masculine noun; feminine form: die Spediteurin"
      ],
      "collocations": [
        {
          "text": "den Spediteur beauftragen",
          "meaning": "to commission the freight forwarder"
        },
        {
          "text": "mit dem Spediteur sprechen",
          "meaning": "to speak with the freight forwarder"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Spedition",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "شركة شحن؛ وكيل شحن"
        },
        {
          "language": "ckb",
          "text": "کۆمپانیای گواستنەوە؛ سپێدیتۆر"
        },
        {
          "language": "en",
          "text": "freight forwarder"
        },
        {
          "language": "fa",
          "text": "شرکت حمل‌ونقل؛ فورواردر"
        },
        {
          "language": "kmr",
          "text": "şirketa barkirinê"
        },
        {
          "language": "pl",
          "text": "spedytor"
        },
        {
          "language": "ro",
          "text": "expeditor"
        },
        {
          "language": "ru",
          "text": "экспедитор; транспортная компания"
        },
        {
          "language": "sq",
          "text": "spedicioner"
        },
        {
          "language": "tr",
          "text": "nakliyeci; lojistik firması"
        }
      ],
      "examples": [
        {
          "baseText": "Der Spediteur erhält die Abholadresse direkt aus dem ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "يحصل وكيل الشحن على عنوان الاستلام مباشرة من نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "سپێدیتۆرەکە ناونیشانی وەرگرتن ڕاستەوخۆ لە سیستەمی ERP وەردەگرێت."
            },
            {
              "language": "en",
              "text": "The freight forwarder receives the pickup address directly from the ERP system."
            },
            {
              "language": "fa",
              "text": "شرکت حمل‌ونقل آدرس بارگیری را مستقیم از سیستم ERP دریافت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Şirketa barkirinê navnîşana hildanê rasterast ji pergala ERP werdigire."
            },
            {
              "language": "pl",
              "text": "Spedytor otrzymuje adres odbioru bezpośrednio z systemu ERP."
            },
            {
              "language": "ro",
              "text": "Expeditorul primește adresa de ridicare direct din sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Экспедитор получает адрес забора напрямую из ERP-системы."
            },
            {
              "language": "sq",
              "text": "Spedicioneri e merr adresën e marrjes direkt nga sistemi ERP."
            },
            {
              "language": "tr",
              "text": "Nakliyeci teslim alma adresini doğrudan ERP sisteminden alır."
            }
          ]
        },
        {
          "baseText": "Bitte informieren Sie den Spediteur über die neue Uhrzeit.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إبلاغ شركة الشحن بالموعد الجديد."
            },
            {
              "language": "ckb",
              "text": "تکایە سپێدیتۆرەکە لە کاتی نوێ ئاگادار بکەنەوە."
            },
            {
              "language": "en",
              "text": "Please inform the freight forwarder about the new time."
            },
            {
              "language": "fa",
              "text": "لطفاً شرکت حمل‌ونقل را از زمان جدید مطلع کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe şirketa barkirinê ji dema nû agahdar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę poinformować spedytora o nowej godzinie."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să informați expeditorul despre noua oră."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сообщите экспедитору о новом времени."
            },
            {
              "language": "sq",
              "text": "Ju lutemi informoni spedicionerin për orarin e ri."
            },
            {
              "language": "tr",
              "text": "Lütfen nakliyeciyi yeni saat hakkında bilgilendirin."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "das Storno",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Stornos",
      "infinitive": null,
      "syllableBreak": "Stor-no",
      "topics": [
        "finance-and-accounting",
        "documents-and-administration",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "written"
      ],
      "grammarNotes": [
        "neuter noun; business/accounting term"
      ],
      "collocations": [
        {
          "text": "ein Storno erfassen",
          "meaning": "to record a cancellation"
        },
        {
          "text": "das Storno prüfen",
          "meaning": "to check the cancellation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "stornieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Stornierung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "إلغاء؛ قيد عكسي"
        },
        {
          "language": "ckb",
          "text": "هەڵوەشاندنەوە"
        },
        {
          "language": "en",
          "text": "cancellation; reversal"
        },
        {
          "language": "fa",
          "text": "لغو؛ برگشت ثبت"
        },
        {
          "language": "kmr",
          "text": "betalkirin; vegerandin"
        },
        {
          "language": "pl",
          "text": "anulowanie; storno"
        },
        {
          "language": "ro",
          "text": "anulare; stornare"
        },
        {
          "language": "ru",
          "text": "сторно; отмена"
        },
        {
          "language": "sq",
          "text": "anulim; kthim regjistrimi"
        },
        {
          "language": "tr",
          "text": "iptal; ters kayıt"
        }
      ],
      "examples": [
        {
          "baseText": "Das Storno der Rechnung wurde im ERP-System gebucht.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تسجيل إلغاء الفاتورة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "هەڵوەشاندنەوەی فاکتورەکە لە سیستەمی ERPدا تۆمار کرا."
            },
            {
              "language": "en",
              "text": "The cancellation of the invoice was posted in the ERP system."
            },
            {
              "language": "fa",
              "text": "لغو فاکتور در سیستم ERP ثبت شد."
            },
            {
              "language": "kmr",
              "text": "Betalkirina fatûreyê di pergala ERP de hate tomarkirin."
            },
            {
              "language": "pl",
              "text": "Storno faktury zostało zaksięgowane w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Stornarea facturii a fost înregistrată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Сторно счета было проведено в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Anulimi i faturës u regjistrua në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Faturanın iptali ERP sisteminde kaydedildi."
            }
          ]
        },
        {
          "baseText": "Für dieses Storno brauchen wir eine kurze Begründung.",
          "translations": [
            {
              "language": "ar",
              "text": "لهذا الإلغاء نحتاج إلى سبب قصير."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم هەڵوەشاندنەوەیە پێویستمان بە هۆکارێکی کورتە."
            },
            {
              "language": "en",
              "text": "For this cancellation, we need a short reason."
            },
            {
              "language": "fa",
              "text": "برای این لغو به یک دلیل کوتاه نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo vê betalkirinê em hewceyê sedemek kurt in."
            },
            {
              "language": "pl",
              "text": "Do tego storna potrzebujemy krótkiego uzasadnienia."
            },
            {
              "language": "ro",
              "text": "Pentru această stornare avem nevoie de o scurtă justificare."
            },
            {
              "language": "ru",
              "text": "Для этого сторно нам нужно краткое обоснование."
            },
            {
              "language": "sq",
              "text": "Për këtë anulim na duhet një arsye e shkurtër."
            },
            {
              "language": "tr",
              "text": "Bu iptal için kısa bir gerekçeye ihtiyacımız var."
            }
          ]
        }
      ]
    },
