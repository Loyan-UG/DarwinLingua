  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "behelfen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "behelfen",
      "syllableBreak": "be-hel-fen",
      "topics": [
        "work-and-jobs",
        "technology-and-it",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong reflexive verb; sich mit etwas behelfen means to manage with a temporary substitute"
      ],
      "collocations": [
        {
          "text": "sich mit einer Übergangslösung behelfen",
          "meaning": "to manage with an interim solution"
        },
        {
          "text": "sich notdürftig behelfen",
          "meaning": "to make do temporarily"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "helfen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يتدبر مؤقتًا؛ يستخدم حلاً بديلًا"
        },
        {
          "language": "ckb",
          "text": "بە چارەسەری کاتی خۆی دەرباز دەکات"
        },
        {
          "language": "en",
          "text": "to make do; to manage with a workaround"
        },
        {
          "language": "fa",
          "text": "موقتاً سر کردن؛ با راه‌حل جایگزین کار را پیش بردن"
        },
        {
          "language": "kmr",
          "text": "bi çareseriya demkî xwe derbas kirin"
        },
        {
          "language": "pl",
          "text": "radzić sobie prowizorycznie"
        },
        {
          "language": "ro",
          "text": "a se descurca provizoriu"
        },
        {
          "language": "ru",
          "text": "обходиться временным решением"
        },
        {
          "language": "sq",
          "text": "të ia dalësh përkohësisht"
        },
        {
          "language": "tr",
          "text": "idare etmek; geçici çözümle yetinmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bis das neue Ticketsystem verfügbar ist, müssen wir uns mit einer gemeinsamen Tabelle behelfen.",
          "translations": [
            {
              "language": "ar",
              "text": "إلى أن يصبح نظام التذاكر الجديد متاحًا، يجب أن نتدبر الأمر بجدول مشترك."
            },
            {
              "language": "ckb",
              "text": "تا سیستەمی نوێی تیکەت ئامادە دەبێت، دەبێت بە خشتەیەکی هاوبەش خۆمان دەرباز بکەین."
            },
            {
              "language": "en",
              "text": "Until the new ticket system is available, we have to make do with a shared spreadsheet."
            },
            {
              "language": "fa",
              "text": "تا زمانی که سیستم جدید تیکت آماده شود، باید با یک جدول مشترک کار را پیش ببریم."
            },
            {
              "language": "kmr",
              "text": "Heta pergala nû ya ticketê amade dibe, divê em bi tabloyeke hevpar xwe derbas bikin."
            },
            {
              "language": "pl",
              "text": "Dopóki nowy system zgłoszeń nie będzie dostępny, musimy radzić sobie wspólną tabelą."
            },
            {
              "language": "ro",
              "text": "Până când noul sistem de tichete este disponibil, trebuie să ne descurcăm cu un tabel comun."
            },
            {
              "language": "ru",
              "text": "Пока новая тикет-система недоступна, нам придется обходиться общей таблицей."
            },
            {
              "language": "sq",
              "text": "Derisa sistemi i ri i tiketave të jetë gati, duhet të ia dalim me një tabelë të përbashkët."
            },
            {
              "language": "tr",
              "text": "Yeni ticket sistemi hazır olana kadar ortak bir tabloyla idare etmemiz gerekiyor."
            }
          ]
        },
        {
          "baseText": "Auf der Reise behalf sie sich mit einer Offline-Karte, weil das mobile Netz ausgefallen war.",
          "translations": [
            {
              "language": "ar",
              "text": "في الرحلة تدبرت أمرها بخريطة غير متصلة لأن شبكة الهاتف تعطلت."
            },
            {
              "language": "ckb",
              "text": "لە گەشتەکەدا بە نەخشەی ئۆفلاین خۆی دەرباز کرد چونکە تۆڕی مۆبایل وەستابوو."
            },
            {
              "language": "en",
              "text": "During the trip, she made do with an offline map because the mobile network was down."
            },
            {
              "language": "fa",
              "text": "در سفر با نقشه آفلاین سر کرد، چون شبکه موبایل قطع شده بود."
            },
            {
              "language": "kmr",
              "text": "Di rêwîtiyê de wê bi nexşeyeke offline xwe derbas kir, ji ber ku tora mobîl rawestabû."
            },
            {
              "language": "pl",
              "text": "W podróży poradziła sobie mapą offline, bo sieć komórkowa nie działała."
            },
            {
              "language": "ro",
              "text": "În călătorie s-a descurcat cu o hartă offline, deoarece rețeaua mobilă căzuse."
            },
            {
              "language": "ru",
              "text": "В поездке она обошлась офлайн-картой, потому что мобильная сеть не работала."
            },
            {
              "language": "sq",
              "text": "Në udhëtim ajo ia doli me një hartë offline, sepse rrjeti celular kishte rënë."
            },
            {
              "language": "tr",
              "text": "Yolculukta mobil ağ kesildiği için çevrimdışı haritayla idare etti."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "behelligen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "behelligen",
      "syllableBreak": "be-hel-li-gen",
      "topics": [
        "business-communication",
        "customer-service",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "polite",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "regular verb; often in polite negative phrases nicht weiter behelligen"
      ],
      "collocations": [
        {
          "text": "jemanden mit Nachfragen behelligen",
          "meaning": "to bother someone with follow-up questions"
        },
        {
          "text": "nicht weiter behelligen",
          "meaning": "not to trouble someone further"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يزعج؛ يضايق بسؤال أو طلب"
        },
        {
          "language": "ckb",
          "text": "بێزار دەکات؛ بە داواکاری یان پرسیار ئاژاوە دەکات"
        },
        {
          "language": "en",
          "text": "to bother; to trouble; to pester"
        },
        {
          "language": "fa",
          "text": "مزاحم شدن؛ با پرسش یا درخواست اذیت کردن"
        },
        {
          "language": "kmr",
          "text": "aciz kirin; gêj kirin"
        },
        {
          "language": "pl",
          "text": "niepokoić; naprzykrzać się"
        },
        {
          "language": "ro",
          "text": "a deranja; a deranja cu întrebări"
        },
        {
          "language": "ru",
          "text": "беспокоить; докучать"
        },
        {
          "language": "sq",
          "text": "të shqetësosh; të bezdisësh"
        },
        {
          "language": "tr",
          "text": "rahatsız etmek; bunaltmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich möchte Sie nicht weiter behelligen, brauche aber noch eine kurze Bestätigung der Lieferadresse.",
          "translations": [
            {
              "language": "ar",
              "text": "لا أريد إزعاجكم أكثر، لكنني أحتاج إلى تأكيد قصير لعنوان التسليم."
            },
            {
              "language": "ckb",
              "text": "نامەوێت زیاتر بێزارتان بکەم، بەڵام پێویستم بە پشتڕاستکردنەوەیەکی کورت بۆ ناونیشانی گەیاندن هەیە."
            },
            {
              "language": "en",
              "text": "I do not want to trouble you further, but I still need a brief confirmation of the delivery address."
            },
            {
              "language": "fa",
              "text": "نمی‌خواهم بیشتر مزاحم شوم، اما هنوز یک تأیید کوتاه از آدرس تحویل لازم دارم."
            },
            {
              "language": "kmr",
              "text": "Naxwazim we zêdetir aciz bikim, lê hîn jî piştrastkirineke kurt a navnîşana radestkirinê hewce ye."
            },
            {
              "language": "pl",
              "text": "Nie chcę Państwa dalej niepokoić, ale potrzebuję jeszcze krótkiego potwierdzenia adresu dostawy."
            },
            {
              "language": "ro",
              "text": "Nu vreau să vă deranjez mai mult, dar am nevoie de o scurtă confirmare a adresei de livrare."
            },
            {
              "language": "ru",
              "text": "Не хочу больше вас беспокоить, но мне нужно краткое подтверждение адреса доставки."
            },
            {
              "language": "sq",
              "text": "Nuk dua t’ju shqetësoj më tej, por më duhet ende një konfirmim i shkurtër i adresës së dorëzimit."
            },
            {
              "language": "tr",
              "text": "Sizi daha fazla rahatsız etmek istemem, ancak teslimat adresinin kısa bir onayına ihtiyacım var."
            }
          ]
        },
        {
          "baseText": "Die Nachbarn fühlten sich durch die ständigen Werbeanrufe massiv behelligt.",
          "translations": [
            {
              "language": "ar",
              "text": "شعر الجيران بانزعاج شديد من مكالمات الإعلانات المستمرة."
            },
            {
              "language": "ckb",
              "text": "دراوسێکان بەهۆی تەلەفۆنە ڕیکلامییە بەردەوامەکانەوە زۆر بێزار بوون."
            },
            {
              "language": "en",
              "text": "The neighbors felt seriously bothered by the constant advertising calls."
            },
            {
              "language": "fa",
              "text": "همسایه‌ها از تماس‌های تبلیغاتی مداوم به‌شدت آزرده بودند."
            },
            {
              "language": "kmr",
              "text": "Cîran ji bangên reklâmê yên domdar gelek aciz bûn."
            },
            {
              "language": "pl",
              "text": "Sąsiedzi czuli się bardzo nękani ciągłymi telefonami reklamowymi."
            },
            {
              "language": "ro",
              "text": "Vecinii se simțeau puternic deranjați de apelurile publicitare constante."
            },
            {
              "language": "ru",
              "text": "Соседи чувствовали себя сильно потревоженными постоянными рекламными звонками."
            },
            {
              "language": "sq",
              "text": "Fqinjët ndiheshin shumë të bezdisur nga telefonatat e vazhdueshme reklamuese."
            },
            {
              "language": "tr",
              "text": "Komşular sürekli reklam aramalarından ciddi şekilde rahatsız oldu."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "beigeben",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beigeben",
      "syllableBreak": "bei-ge-ben",
      "topics": [
        "documents-and-administration",
        "production-and-maintenance",
        "healthcare-and-appointments"
      ],
      "usageLabels": [
        "formal",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "strong separable verb; means to add or enclose something"
      ],
      "collocations": [
        {
          "text": "Unterlagen beigeben",
          "meaning": "to enclose documents"
        },
        {
          "text": "einen Zusatzstoff beigeben",
          "meaning": "to add an additive"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "geben",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Beigabe",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يرفق؛ يضيف"
        },
        {
          "language": "ckb",
          "text": "هاوپێچ دەکات؛ زیاد دەکات"
        },
        {
          "language": "en",
          "text": "to enclose; to add"
        },
        {
          "language": "fa",
          "text": "ضمیمه کردن؛ افزودن"
        },
        {
          "language": "kmr",
          "text": "pêve kirin; zêde kirin"
        },
        {
          "language": "pl",
          "text": "dołączyć; dodać"
        },
        {
          "language": "ro",
          "text": "a anexa; a adăuga"
        },
        {
          "language": "ru",
          "text": "прилагать; добавлять"
        },
        {
          "language": "sq",
          "text": "të bashkëngjitësh; të shtosh"
        },
        {
          "language": "tr",
          "text": "eklemek; iliştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte geben Sie dem Antrag eine Kopie des aktuellen Handelsregisterauszugs bei.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرفاق نسخة من مستخرج السجل التجاري الحالي بالطلب."
            },
            {
              "language": "ckb",
