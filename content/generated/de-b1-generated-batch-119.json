  "entries": [
    {
      "word": "sich bewerben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "sich bewerben",
      "pronunciationIpa": null,
      "syllableBreak": "sich be-wer-ben",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "workplace",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive verb; irregular: bewirbt sich, bewarb sich, sich beworben; often with um + accusative or bei + dative"
      ],
      "collocations": [
        {
          "text": "sich um eine Stelle bewerben",
          "meaning": "to apply for a job"
        },
        {
          "text": "sich online bewerben",
          "meaning": "to apply online"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Bewerbung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Bewerber",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتقدم بطلب؛ يترشح لوظيفة"
        },
        {
          "language": "ckb",
          "text": "داواکاری کار دەکات؛ خۆی پێشکەش دەکات"
        },
        {
          "language": "en",
          "text": "to apply; to apply for a job"
        },
        {
          "language": "fa",
          "text": "درخواست دادن؛ برای شغل اقدام کردن"
        },
        {
          "language": "kmr",
          "text": "serlêdan kirin; ji bo karê daxwaz kirin"
        },
        {
          "language": "pl",
          "text": "ubiegać się; aplikować"
        },
        {
          "language": "ro",
          "text": "a candida; a aplica"
        },
        {
          "language": "ru",
          "text": "подавать заявление; претендовать на работу"
        },
        {
          "language": "sq",
          "text": "të aplikosh; të kandidohesh"
        },
        {
          "language": "tr",
          "text": "başvurmak; işe başvurmak"
        }
      ],
      "examples": [
        {
          "baseText": "Sie möchte sich bei einer großen Softwarefirma bewerben.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد أن تتقدم إلى شركة برمجيات كبيرة."
            },
            {
              "language": "ckb",
              "text": "دەیەوێت داواکاری کار لە کۆمپانیایەکی گەورەی نەرمەکاڵا بکات."
            },
            {
              "language": "en",
              "text": "She wants to apply to a large software company."
            },
            {
              "language": "fa",
              "text": "او می‌خواهد برای یک شرکت بزرگ نرم‌افزاری درخواست بدهد."
            },
            {
              "language": "kmr",
              "text": "Ew dixwaze li şîrketeke mezin a softwareyê serlêdan bike."
            },
            {
              "language": "pl",
              "text": "Ona chce aplikować do dużej firmy programistycznej."
            },
            {
              "language": "ro",
              "text": "Ea vrea să candideze la o firmă mare de software."
            },
            {
              "language": "ru",
              "text": "Она хочет подать заявку в крупную софтверную компанию."
            },
            {
              "language": "sq",
              "text": "Ajo dëshiron të aplikojë në një kompani të madhe softuerësh."
            },
            {
              "language": "tr",
              "text": "Büyük bir yazılım şirketine başvurmak istiyor."
            }
          ]
        },
        {
          "baseText": "Für die Stelle können Sie sich bis Ende des Monats online bewerben.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم التقدم للوظيفة عبر الإنترنت حتى نهاية الشهر."
            },
            {
              "language": "ckb",
              "text": "بۆ ئەم پۆستە دەتوانن تا کۆتایی مانگ بە ئۆنلاین داواکاری بکەن."
            },
            {
              "language": "en",
              "text": "You can apply online for the position until the end of the month."
            },
            {
              "language": "fa",
              "text": "برای این موقعیت می‌توانید تا پایان ماه آنلاین درخواست بدهید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji bo vê pozîsyonê heta dawiya mehê online serlêdan bikin."
            },
            {
              "language": "pl",
              "text": "Na to stanowisko można aplikować online do końca miesiąca."
            },
            {
              "language": "ro",
              "text": "Pentru acest post puteți aplica online până la sfârșitul lunii."
            },
            {
              "language": "ru",
              "text": "На эту должность можно подать заявку онлайн до конца месяца."
            },
            {
              "language": "sq",
              "text": "Për këtë pozicion mund të aplikoni online deri në fund të muajit."
            },
            {
              "language": "tr",
              "text": "Bu pozisyon için ay sonuna kadar çevrim içi başvurabilirsiniz."
            }
          ]
        }
      ]
    },
    {
      "word": "sich beziehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "sich beziehen",
      "pronunciationIpa": null,
      "syllableBreak": "sich be-zie-hen",
      "topics": [
        "business-communication",
        "documents-and-administration",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive verb; irregular: bezieht sich, bezog sich, sich bezogen; usually with auf + accusative"
      ],
      "collocations": [
        {
          "text": "sich auf eine E-Mail beziehen",
          "meaning": "to refer to an email"
        },
        {
          "text": "sich auf den Vertrag beziehen",
          "meaning": "to refer to the contract"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Bezug",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "bezüglich",
          "relationLabel": "preposition/adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يشير إلى؛ يتعلق بـ"
        },
        {
          "language": "ckb",
          "text": "ئاماژە بە دەکات؛ پەیوەندی بە هەیە"
        },
        {
          "language": "en",
          "text": "to refer to; to relate to"
        },
        {
          "language": "fa",
          "text": "اشاره داشتن به؛ مربوط بودن به"
        },
        {
          "language": "kmr",
          "text": "behsa ... kirin; têkildar bûn bi"
        },
        {
          "language": "pl",
          "text": "odnosić się do; dotyczyć"
        },
        {
          "language": "ro",
          "text": "a se referi la; a avea legătură cu"
        },
        {
          "language": "ru",
          "text": "относиться к; ссылаться на"
        },
        {
          "language": "sq",
          "text": "t’i referohesh; të lidhet me"
        },
        {
          "language": "tr",
          "text": "atıfta bulunmak; ilgili olmak"
        }
      ],
      "examples": [
        {
          "baseText": "Meine Frage bezieht sich auf Ihre E-Mail von gestern.",
          "translations": [
            {
              "language": "ar",
              "text": "سؤالي يتعلق برسالتكم الإلكترونية من أمس."
            },
            {
              "language": "ckb",
              "text": "پرسیارەکەم پەیوەندی بە ئیمەیڵەکەتانی دوێنێوە هەیە."
            },
            {
              "language": "en",
              "text": "My question refers to your email from yesterday."
            },
            {
              "language": "fa",
              "text": "سؤال من به ایمیل دیروز شما مربوط می‌شود."
            },
            {
              "language": "kmr",
              "text": "Pirsa min têkildarî e-nameya we ya duh e."
            },
            {
              "language": "pl",
              "text": "Moje pytanie odnosi się do państwa e-maila z wczoraj."
            },
            {
              "language": "ro",
              "text": "Întrebarea mea se referă la e-mailul dumneavoastră de ieri."
            },
            {
              "language": "ru",
              "text": "Мой вопрос относится к вашему письму от вчерашнего дня."
            },
            {
              "language": "sq",
              "text": "Pyetja ime i referohet emailit tuaj të djeshëm."
            },
            {
              "language": "tr",
              "text": "Sorum dünkü e-postanızla ilgilidir."
            }
          ]
        },
        {
          "baseText": "Diese Regel bezieht sich nur auf interne Dokumente.",
          "translations": [
            {
              "language": "ar",
              "text": "هذه القاعدة تتعلق فقط بالمستندات الداخلية."
            },
            {
              "language": "ckb",
              "text": "ئەم ڕێسایە تەنها پەیوەندی بە بەڵگەنامە ناوخۆییەکانەوە هەیە."
            },
            {
              "language": "en",
              "text": "This rule applies only to internal documents."
            },
            {
              "language": "fa",
              "text": "این قانون فقط به اسناد داخلی مربوط می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ev qaîde tenê têkildarî belgeyên navxweyî ye."
            },
            {
              "language": "pl",
              "text": "Ta zasada odnosi się tylko do dokumentów wewnętrznych."
            },
            {
              "language": "ro",
              "text": "Această regulă se referă doar la documente interne."
            },
            {
              "language": "ru",
              "text": "Это правило относится только к внутренним документам."
            },
            {
              "language": "sq",
              "text": "Ky rregull lidhet vetëm me dokumentet e brendshme."
            },
            {
              "language": "tr",
              "text": "Bu kural yalnızca iç belgelerle ilgilidir."
            }
          ]
        }
      ]
    },
