  "entries": [
    {
      "word": "die Gewährleistung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Gewährleistungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ge-währ-leis-tung",
      "topics": [
        "shopping-and-services",
        "customer-service",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "business",
        "customer-facing"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; legal/customer-service term for statutory warranty rights"
      ],
      "collocations": [
        {
          "text": "unter die Gewährleistung fallen",
          "meaning": "to be covered by statutory warranty"
        },
        {
          "text": "die Gewährleistung prüfen",
          "meaning": "to check warranty coverage"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gewährleisten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Garantie",
          "relationLabel": "related noun",
          "note": "similar in everyday use but legally not always the same"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ضمان قانوني؛ مسؤولية الضمان"
        },
        {
          "language": "ckb",
          "text": "گەرەنتی یاسایی؛ بەرپرسیاریەتی گەرەنتی"
        },
        {
          "language": "en",
          "text": "statutory warranty; warranty obligation"
        },
        {
          "language": "fa",
          "text": "ضمانت قانونی؛ مسئولیت گارانتی"
        },
        {
          "language": "kmr",
          "text": "garantiya qanûnî; berpirsiyariya garantiyê"
        },
        {
          "language": "pl",
          "text": "rękojmia; odpowiedzialność gwarancyjna"
        },
        {
          "language": "ro",
          "text": "garanție legală; răspundere pentru garanție"
        },
        {
          "language": "ru",
          "text": "законная гарантия; гарантийное обязательство"
        },
        {
          "language": "sq",
          "text": "garanci ligjore; përgjegjësi garancie"
        },
        {
          "language": "tr",
          "text": "yasal garanti; ayıptan sorumluluk"
        }
      ],
      "examples": [
        {
          "baseText": "Der Defekt fällt noch unter die Gewährleistung, deshalb reparieren wir das Gerät kostenlos.",
          "translations": [
            {
              "language": "ar",
              "text": "ما زال العطل ضمن الضمان القانوني، لذلك نصلح الجهاز مجاناً."
            },
            {
              "language": "ckb",
              "text": "کێشەکە هێشتا لە ژێر گەرەنتی یاساییە، بۆیە ئامێرەکە بەخۆڕایی چاک دەکەینەوە."
            },
            {
              "language": "en",
              "text": "The defect is still covered by the statutory warranty, so we will repair the device free of charge."
            },
            {
              "language": "fa",
              "text": "این خرابی هنوز شامل ضمانت قانونی است، بنابراین دستگاه را رایگان تعمیر می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Ev kêmasî hîn di bin garantiya qanûnî de ye, ji ber vê em amûrê bêpere tamîr dikin."
            },
            {
              "language": "pl",
              "text": "Usterka nadal podlega rękojmi, dlatego naprawimy urządzenie bezpłatnie."
            },
            {
              "language": "ro",
              "text": "Defectul este încă acoperit de garanția legală, de aceea reparăm aparatul gratuit."
            },
            {
              "language": "ru",
              "text": "Дефект всё ещё подпадает под законную гарантию, поэтому мы отремонтируем устройство бесплатно."
            },
            {
              "language": "sq",
              "text": "Defekti ende mbulohet nga garancia ligjore, prandaj do ta riparojmë pajisjen falas."
            },
            {
              "language": "tr",
              "text": "Arıza hâlâ yasal garanti kapsamındadır, bu yüzden cihazı ücretsiz tamir ederiz."
            }
          ]
        },
        {
          "baseText": "Bitte schicken Sie uns die Rechnung, damit wir die Gewährleistung prüfen können.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال الفاتورة إلينا كي نتمكن من فحص الضمان القانوني."
            },
            {
              "language": "ckb",
              "text": "تکایە فاکتورەکە بۆمان بنێرن، بۆ ئەوەی بتوانین گەرەنتی یاسایی بپشکنین."
            },
            {
              "language": "en",
              "text": "Please send us the invoice so we can check the warranty coverage."
            },
            {
              "language": "fa",
              "text": "لطفاً فاکتور را برای ما بفرستید تا بتوانیم ضمانت قانونی را بررسی کنیم."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fatûreyê ji me re bişînin, da ku em garantiya qanûnî kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać nam fakturę, abyśmy mogli sprawdzić rękojmię."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți factura, ca să putem verifica garanția legală."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам счёт, чтобы мы могли проверить гарантийное покрытие."
            },
            {
              "language": "sq",
              "text": "Ju lutemi na dërgoni faturën, që të mund ta kontrollojmë garancinë ligjore."
            },
            {
              "language": "tr",
              "text": "Yasal garanti kapsamını kontrol edebilmemiz için lütfen faturayı bize gönderin."
            }
          ]
        }
      ]
    },
