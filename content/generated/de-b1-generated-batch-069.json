      "meanings": [
        {
          "language": "ar",
          "text": "تسجيل نشاط تجاري"
        },
        {
          "language": "ckb",
          "text": "تۆمارکردنی کاری بازرگانی"
        },
        {
          "language": "en",
          "text": "business registration; trade registration"
        },
        {
          "language": "fa",
          "text": "ثبت کسب‌وکار؛ ثبت فعالیت تجاری"
        },
        {
          "language": "kmr",
          "text": "tomarkirina bazirganiyê; tomara karê bazirganî"
        },
        {
          "language": "pl",
          "text": "rejestracja działalności gospodarczej"
        },
        {
          "language": "ro",
          "text": "înregistrare comercială; înregistrarea unei afaceri"
        },
        {
          "language": "ru",
          "text": "регистрация предпринимательской деятельности"
        },
        {
          "language": "sq",
          "text": "regjistrim biznesi; regjistrim tregtar"
        },
        {
          "language": "tr",
          "text": "iş yeri kaydı; ticari faaliyet kaydı"
        }
      ],
      "examples": [
        {
          "baseText": "Für den Online-Shop braucht sie zuerst eine Gewerbeanmeldung.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل المتجر الإلكتروني تحتاج أولاً إلى تسجيل نشاط تجاري."
            },
            {
              "language": "ckb",
              "text": "بۆ دووکانی ئۆنلاینەکە، سەرەتا پێویستی بە تۆمارکردنی کاری بازرگانی هەیە."
            },
            {
              "language": "en",
              "text": "For the online shop, she first needs a business registration."
            },
            {
              "language": "fa",
              "text": "برای فروشگاه آنلاین، او ابتدا به ثبت کسب‌وکار نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Ji bo firoşgeha serhêlê, ew pêşî hewceyê tomarkirina bazirganiyê ye."
            },
            {
              "language": "pl",
              "text": "Do sklepu internetowego najpierw potrzebuje rejestracji działalności gospodarczej."
            },
            {
              "language": "ro",
              "text": "Pentru magazinul online, ea are mai întâi nevoie de o înregistrare comercială."
            },
            {
              "language": "ru",
              "text": "Для интернет-магазина ей сначала нужна регистрация предпринимательской деятельности."
            },
            {
              "language": "sq",
              "text": "Për dyqanin online asaj i duhet së pari regjistrimi i biznesit."
