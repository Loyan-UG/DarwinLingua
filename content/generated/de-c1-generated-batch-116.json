  "entries": [
    {
      "word": "verschmelzen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verschmelzen",
      "pronunciationIpa": null,
      "syllableBreak": "ver-schmel-zen",
      "topics": [
        "management-and-leadership",
        "technology-and-it",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "business",
        "analysis",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "regular verb; means to merge or fuse, literally or figuratively"
      ],
      "collocations": [
        {
          "text": "zwei Systeme verschmelzen",
          "meaning": "to merge two systems"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Verschmelzung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "schmelzen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يندمج؛ ينصهر"
        },
        {
          "language": "ckb",
          "text": "تێکەڵ دەبێت؛ یەک دەگرێتەوە"
        },
        {
          "language": "en",
          "text": "to merge; to fuse"
        },
        {
          "language": "fa",
          "text": "ادغام شدن؛ ذوب و یکی شدن"
        },
        {
          "language": "kmr",
          "text": "yekbûn; têkelbûn"
        },
        {
          "language": "pl",
          "text": "łączyć się; stapiać się"
        },
        {
          "language": "ro",
          "text": "a fuziona; a se contopi"
        },
        {
          "language": "ru",
          "text": "сливаться; объединяться"
        },
        {
          "language": "sq",
          "text": "të shkrihet; të bashkohet"
        },
        {
          "language": "tr",
          "text": "birleşmek; kaynaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Übernahme sollen die beiden CRM-Systeme schrittweise zu einer gemeinsamen Plattform verschmelzen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الاستحواذ من المقرر أن يندمج نظاما إدارة العملاء تدريجياً في منصة مشتركة."
            },
            {
              "language": "ckb",
              "text": "دوای کڕینەوەکە پێویستە هەردوو سیستەمی CRM بە هەنگاو هەنگاو ببنە پلاتفۆرمێکی هاوبەش."
            },
            {
              "language": "en",
              "text": "After the acquisition, the two CRM systems are to gradually merge into a shared platform."
            },
            {
              "language": "fa",
              "text": "پس از تملک، قرار است دو سیستم CRM به‌تدریج در یک پلتفرم مشترک ادغام شوند."
            },
            {
              "language": "kmr",
              "text": "Piştî kirînê divê her du pergalên CRM gav bi gav bibin platformeke hevpar."
            },
            {
              "language": "pl",
              "text": "Po przejęciu oba systemy CRM mają stopniowo połączyć się we wspólną platformę."
            },
            {
              "language": "ro",
              "text": "După achiziție, cele două sisteme CRM urmează să fuzioneze treptat într-o platformă comună."
            },
            {
              "language": "ru",
              "text": "После поглощения две CRM-системы должны постепенно слиться в общую платформу."
            },
            {
              "language": "sq",
              "text": "Pas blerjes, dy sistemet CRM duhet të bashkohen gradualisht në një platformë të përbashkët."
            },
            {
              "language": "tr",
              "text": "Satın alma sonrasında iki CRM sisteminin kademeli olarak ortak bir platformda birleşmesi planlanıyor."
            }
          ]
        },
        {
          "baseText": "In dem Stadtviertel verschmelzen alte Industriearchitektur und neue Wohnkonzepte auf ungewöhnliche Weise.",
          "translations": [
            {
              "language": "ar",
              "text": "في ذلك الحي تندمج العمارة الصناعية القديمة ومفاهيم السكن الجديدة بطريقة غير معتادة."
            },
            {
              "language": "ckb",
              "text": "لەو گەڕەکەدا ئەندازیاری پیشەسازی کۆن و کۆنسیپتی نوێی نیشتەجێبوون بە شێوەیەکی نامۆ تێکەڵ دەبن."
            },
            {
              "language": "en",
              "text": "In the district, old industrial architecture and new housing concepts merge in an unusual way."
            },
            {
              "language": "fa",
              "text": "در آن محله، معماری صنعتی قدیمی و مفاهیم جدید سکونت به شکلی غیرمعمول درهم می‌آمیزند."
            },
            {
              "language": "kmr",
              "text": "Di wê taxê de avahîsaziya pîşesazî ya kevn û konsepên nû yên rûniştinê bi awayekî neasayî têkel dibin."
            },
            {
              "language": "pl",
              "text": "W tej dzielnicy stara architektura przemysłowa i nowe koncepcje mieszkaniowe łączą się w niezwykły sposób."
            },
            {
              "language": "ro",
              "text": "În acel cartier, arhitectura industrială veche și noile concepte de locuire se contopesc într-un mod neobișnuit."
            },
            {
              "language": "ru",
              "text": "В этом районе старая промышленная архитектура и новые жилищные концепции необычно сливаются."
            },
            {
              "language": "sq",
              "text": "Në atë lagje, arkitektura e vjetër industriale dhe konceptet e reja të banimit shkrihen në mënyrë të pazakontë."
            },
            {
              "language": "tr",
              "text": "Bu semtte eski endüstriyel mimari ile yeni konut konseptleri alışılmadık biçimde kaynaşıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "verschneiden",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verschneiden",
      "pronunciationIpa": null,
      "syllableBreak": "ver-schnei-den",
      "topics": [
        "production-and-maintenance",
        "culture-and-media",
        "data-and-reporting"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular/strong verb; can mean to blend materials, edit footage, or cut incorrectly depending on context"
      ],
      "collocations": [
        {
          "text": "Datenquellen miteinander verschneiden",
          "meaning": "to combine or cross-reference data sources"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schneiden",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Verschnitt",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يمزج؛ يقطع خطأً؛ يدمج مصادر"
        },
        {
          "language": "ckb",
          "text": "تێکەڵ دەکات؛ بە هەڵە دەبڕێت؛ سەرچاوەکان یەکدەخات"
        },
        {
          "language": "en",
          "text": "to blend; to cross-reference; to cut incorrectly"
        },
        {
          "language": "fa",
          "text": "ترکیب کردن؛ برش اشتباه دادن؛ تلفیق منابع"
        },
        {
          "language": "kmr",
          "text": "têkelkirin; şaş birîn; çavkaniyan yek kirin"
        },
        {
          "language": "pl",
          "text": "mieszać; zestawiać; źle przyciąć"
        },
        {
          "language": "ro",
          "text": "a amesteca; a corela; a tăia greșit"
        },
        {
          "language": "ru",
          "text": "смешивать; сопоставлять; неправильно обрезать"
        },
        {
          "language": "sq",
          "text": "të përziesh; të ndërthurësh; të presësh gabim"
        },
        {
          "language": "tr",
          "text": "harmanlamak; çapraz birleştirmek; yanlış kesmek"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Risikoanalyse wurden interne Schadensmeldungen mit externen Wetterdaten verschnitten.",
          "translations": [
            {
              "language": "ar",
              "text": "من أجل تحليل المخاطر دُمجت بلاغات الأضرار الداخلية مع بيانات الطقس الخارجية."
            },
            {
              "language": "ckb",
              "text": "بۆ شیکردنەوەی مەترسی، ڕاپۆرتە ناوخۆییەکانی زیان لەگەڵ داتای کەشوهەوای دەرەکی تێکەڵ کران."
            },
            {
              "language": "en",
              "text": "For the risk analysis, internal damage reports were cross-referenced with external weather data."
            },
            {
              "language": "fa",
              "text": "برای تحلیل ریسک، گزارش‌های داخلی خسارت با داده‌های بیرونی هواشناسی تلفیق شدند."
            },
            {
              "language": "kmr",
              "text": "Ji bo analîza xetereyê, raporên hundirîn ên ziyanê bi daneyên derveyî yên hewayê re hatin têkelkirin."
            },
            {
              "language": "pl",
              "text": "Na potrzeby analizy ryzyka wewnętrzne zgłoszenia szkód zestawiono z zewnętrznymi danymi pogodowymi."
            },
            {
              "language": "ro",
              "text": "Pentru analiza riscurilor, rapoartele interne de daune au fost corelate cu date meteorologice externe."
            },
            {
              "language": "ru",
              "text": "Для анализа рисков внутренние сообщения об ущербе сопоставили с внешними погодными данными."
            },
            {
              "language": "sq",
              "text": "Për analizën e rrezikut, raportet e brendshme të dëmeve u ndërthurën me të dhënat e jashtme të motit."
            },
            {
              "language": "tr",
              "text": "Risk analizi için iç hasar bildirimleri dış hava durumu verileriyle çapraz birleştirildi."
            }
          ]
        },
        {
          "baseText": "Der Cutter verschneidet historische Aufnahmen mit aktuellen Interviews, ohne die Zeitebenen zu verwischen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمزج المونتير لقطات تاريخية مع مقابلات حديثة من دون طمس المستويات الزمنية."
            },
            {
              "language": "ckb",
              "text": "مۆنتاژکارەکە وێنەی مێژوویی لەگەڵ چاوپێکەوتنی نوێ تێکەڵ دەکات، بێ ئەوەی ئاستەکانی کات تێک بدات."
            },
            {
              "language": "en",
              "text": "The editor intercuts historical footage with current interviews without blurring the time levels."
            },
            {
              "language": "fa",
              "text": "تدوینگر تصاویر تاریخی را با مصاحبه‌های جدید تلفیق می‌کند، بدون اینکه لایه‌های زمانی را مخدوش کند."
            },
            {
              "language": "kmr",
              "text": "Edîtor wêneyên dîrokî bi hevpeyvînên nû re têkel dike bêyî ku astên demê tevlihev bike."
            },
            {
              "language": "pl",
              "text": "Montażysta łączy ujęcia historyczne z aktualnymi wywiadami, nie zacierając poziomów czasowych."
            },
            {
              "language": "ro",
              "text": "Editorul îmbină imagini istorice cu interviuri actuale fără a estompa planurile temporale."
            },
            {
              "language": "ru",
              "text": "Монтажер соединяет исторические кадры с актуальными интервью, не размывая временные уровни."
            },
            {
              "language": "sq",
              "text": "Montazhieri ndërthur pamje historike me intervista aktuale pa i mjegulluar nivelet kohore."
            },
            {
              "language": "tr",
              "text": "Kurgucu, tarihsel görüntüleri güncel röportajlarla zaman katmanlarını bulanıklaştırmadan harmanlıyor."
            }
          ]
        }
      ]
    },
