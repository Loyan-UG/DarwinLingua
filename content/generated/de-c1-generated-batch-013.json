      "examples": [
        {
          "baseText": "Der Bericht zeigt, dass Alleinerziehende besonders häufig von Armutsgefährdung betroffen sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يُظهر التقرير أن الوالدين الوحيدين يتعرضون لخطر الفقر بشكل خاص."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتەکە نیشان دەدات دایک یان باوکی تاک بە تایبەتی زۆرجار تووشی مەترسی هەژاری دەبن."
            },
            {
              "language": "en",
              "text": "The report shows that single parents are particularly often at risk of poverty."
            },
            {
              "language": "fa",
              "text": "گزارش نشان می‌دهد والدین تنها به‌ویژه زیاد در معرض خطر فقر هستند."
            },
            {
              "language": "kmr",
              "text": "Rapor nîşan dide ku dê û bavên tenê pir caran di bin xetera hejariyê de ne."
            },
            {
              "language": "pl",
              "text": "Raport pokazuje, że samotni rodzice są szczególnie często zagrożeni ubóstwem."
            },
            {
              "language": "ro",
              "text": "Raportul arată că părinții singuri sunt deosebit de des expuși riscului de sărăcie."
            },
            {
              "language": "ru",
              "text": "Отчет показывает, что одинокие родители особенно часто подвержены риску бедности."
            },
            {
              "language": "sq",
              "text": "Raporti tregon se prindërit e vetëm janë veçanërisht shpesh në rrezik varfërie."
            },
            {
              "language": "tr",
              "text": "Rapor, tek ebeveynlerin özellikle sık yoksulluk riski altında olduğunu gösteriyor."
            }
          ]
        },
        {
          "baseText": "Steigende Mieten erhöhen die Armutsgefährdung in vielen mittelgroßen Städten.",
          "translations": [
            {
              "language": "ar",
              "text": "تزيد الإيجارات المرتفعة خطر الفقر في كثير من المدن المتوسطة."
            },
            {
              "language": "ckb",
              "text": "کرێی خانووی بەرزبووەوە مەترسی هەژاری لە زۆر شارۆچکەی مامناوەند زیاد دەکات."
            },
            {
              "language": "en",
              "text": "Rising rents increase the risk of poverty in many medium-sized cities."
            },
            {
              "language": "fa",
              "text": "افزایش اجاره‌ها خطر فقر را در بسیاری از شهرهای متوسط بالا می‌برد."
            },
            {
              "language": "kmr",
              "text": "Kirêyên bilindbûyî xetera hejariyê li gelek bajarên navîn zêde dikin."
            },
            {
              "language": "pl",
              "text": "Rosnące czynsze zwiększają zagrożenie ubóstwem w wielu średnich miastach."
            },
            {
              "language": "ro",
              "text": "Chiriile în creștere măresc riscul de sărăcie în multe orașe medii."
            },
            {
              "language": "ru",
              "text": "Рост арендной платы повышает риск бедности во многих средних городах."
            },
            {
              "language": "sq",
              "text": "Qiratë në rritje e shtojnë rrezikun e varfërisë në shumë qytete të mesme."
            },
            {
              "language": "tr",
              "text": "Artan kiralar birçok orta ölçekli şehirde yoksulluk riskini artırıyor."
            }
          ]
        }
