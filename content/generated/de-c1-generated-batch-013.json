        }
      ],
      "examples": [
        {
          "baseText": "Der Lieferant wollte uns aufbinden, die Verzögerung liege ausschließlich am Zoll.",
          "translations": [
            {
              "language": "ar",
              "text": "أراد المورد أن يجعلنا نصدق أن التأخير سببه الجمارك فقط."
            },
            {
              "language": "ckb",
              "text": "دابینکەرەکە دەیویست پێمان بباوەڕێنێت کە دواکەوتنەکە تەنها لە گومرگ بووە."
            },
            {
              "language": "en",
              "text": "The supplier tried to make us believe that the delay was entirely due to customs."
            },
            {
              "language": "fa",
              "text": "تأمین‌کننده می‌خواست به ما بقبولاند که تأخیر فقط به‌خاطر گمرک بوده است."
            },
            {
              "language": "kmr",
              "text": "Dabînker xwest me bawer bike ku derengî tenê ji gumrikê bûye."
            },
            {
              "language": "pl",
              "text": "Dostawca chciał nam wmówić, że opóźnienie wynika wyłącznie z odprawy celnej."
            },
            {
              "language": "ro",
              "text": "Furnizorul a vrut să ne facă să credem că întârzierea se datora exclusiv vămii."
            },
            {
              "language": "ru",
              "text": "Поставщик хотел убедить нас, что задержка связана исключительно с таможней."
            },
            {
              "language": "sq",
              "text": "Furnitori donte të na bindte se vonesa ishte vetëm për shkak të doganës."
            },
            {
              "language": "tr",
              "text": "Tedarikçi gecikmenin tamamen gümrükten kaynaklandığını bize yutturmaya çalıştı."
            }
          ]
        },
        {
          "baseText": "Lass dir nicht aufbinden, dass diese Versicherung alle Schäden ohne Ausnahme bezahlt.",
