        {
          "language": "fa",
          "text": "به کسی چیزی دروغین قبولاندن؛ بستن/بازکردن در کاربردهای خاص"
        },
        {
          "language": "kmr",
          "text": "bi çîrokek derewîn xapandin; girêdan"
