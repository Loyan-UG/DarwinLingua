      "word": "auswerfen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auswerfen",
      "syllableBreak": "aus-wer-fen",
      "topics": [
        "technology-and-it",
        "production-and-maintenance",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "technical",
        "business",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; can mean to eject, output, or calculate/produce a result"
      ],
      "collocations": [
        {
          "text": "einen Datensatz auswerfen",
          "meaning": "to output a data record"
        },
        {
          "text": "einen Fehler auswerfen",
          "meaning": "to throw or output an error"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "werfen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يُخرج؛ يقذف؛ ينتج نتيجة"
        },
        {
          "language": "ckb",
          "text": "دەردەدات؛ فڕێی دەدات؛ ئەنجامێک دەردەخات"
        },
        {
          "language": "en",
          "text": "to eject; to output; to produce a result"
        },
        {
          "language": "fa",
          "text": "بیرون انداختن؛ خروجی دادن؛ نتیجه تولید کردن"
        },
        {
          "language": "kmr",
          "text": "derxistin; avêtin; encamek derxistin"
        },
        {
          "language": "pl",
          "text": "wyrzucić; wygenerować wynik"
        },
        {
          "language": "ro",
          "text": "a ejecta; a genera un rezultat"
        },
        {
          "language": "ru",
          "text": "выбрасывать; выдавать результат"
        },
        {
          "language": "sq",
          "text": "të nxjerrësh; të gjenerosh rezultat"
        },
        {
          "language": "tr",
          "text": "çıkarmak; çıktı üretmek"
        }
      ],
      "examples": [
        {
          "baseText": "Das Monitoring-System warf nach dem Update mehrere neue Warnmeldungen aus.",
          "translations": [
            {
              "language": "ar",
              "text": "أصدر نظام المراقبة بعد التحديث عدة رسائل تحذير جديدة."
            },
            {
              "language": "ckb",
              "text": "سیستەمی چاودێری دوای نوێکردنەوەکە چەند ئاگادارییەکی نوێی دەرهێنا."
            },
            {
              "language": "en",
              "text": "After the update, the monitoring system output several new warning messages."
            },
            {
              "language": "fa",
              "text": "سیستم مانیتورینگ پس از به‌روزرسانی چند هشدار جدید خروجی داد."
            },
            {
              "language": "kmr",
              "text": "Pergala çavdêriyê piştî nûkirinê çend peyamên hişyariyê yên nû derxistin."
            },
            {
              "language": "pl",
              "text": "Po aktualizacji system monitoringu wygenerował kilka nowych ostrzeżeń."
            },
            {
              "language": "ro",
              "text": "După actualizare, sistemul de monitorizare a generat mai multe avertizări noi."
            },
            {
              "language": "ru",
              "text": "После обновления система мониторинга выдала несколько новых предупреждений."
            },
            {
              "language": "sq",
              "text": "Pas përditësimit, sistemi i monitorimit nxori disa paralajmërime të reja."
            },
            {
              "language": "tr",
              "text": "Güncellemeden sonra izleme sistemi birkaç yeni uyarı mesajı üretti."
            }
          ]
        },
        {
          "baseText": "Der Finanzrechner wirft für das konservative Szenario eine deutlich niedrigere Rendite aus.",
          "translations": [
            {
              "language": "ar",
              "text": "تعطي حاسبة التمويل عائدًا أقل بكثير للسيناريو المحافظ."
            },
            {
              "language": "ckb",
              "text": "ژمێرەری دارایی بۆ سیناریۆی پارێزکارانە قازانجێکی زۆر نزمتر دەردەخات."
            },
            {
              "language": "en",
              "text": "The financial calculator produces a significantly lower return for the conservative scenario."
            },
            {
              "language": "fa",
              "text": "ماشین‌حساب مالی برای سناریوی محافظه‌کارانه بازده بسیار کمتری نشان می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Hesabkera darayî ji bo senaryoya parêzkar qezenceke gelek kêmtir derdixe."
            },
            {
              "language": "pl",
              "text": "Kalkulator finansowy dla scenariusza konserwatywnego pokazuje znacznie niższą stopę zwrotu."
            },
            {
              "language": "ro",
              "text": "Calculatorul financiar produce pentru scenariul conservator un randament semnificativ mai mic."
            },
            {
              "language": "ru",
              "text": "Финансовый калькулятор выдает для консервативного сценария значительно более низкую доходность."
            },
            {
              "language": "sq",
              "text": "Llogaritësi financiar nxjerr për skenarin konservator një kthim dukshëm më të ulët."
            },
            {
              "language": "tr",
              "text": "Finans hesaplayıcısı muhafazakar senaryo için belirgin şekilde daha düşük getiri veriyor."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "auswringen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auswringen",
      "syllableBreak": "aus-wrin-gen",
      "topics": [
        "everyday-life",
        "production-and-maintenance",
        "quality-and-risk"
      ],
      "usageLabels": [
        "technical",
        "spoken",
        "written"
      ],
      "grammarNotes": [
        "strong separable verb; means to wring liquid out of cloth or similar material"
      ],
      "collocations": [
        {
          "text": "ein Tuch auswringen",
          "meaning": "to wring out a cloth"
        },
        {
          "text": "den Schwamm auswringen",
          "meaning": "to wring out the sponge"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "wringen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يعصر لإخراج السائل"
        },
        {
          "language": "ckb",
          "text": "دەهەڵوەشێت بۆ دەرکردنی شلەمەنی"
        },
        {
          "language": "en",
          "text": "to wring out"
        },
        {
          "language": "fa",
          "text": "چلاندن؛ آب چیزی را گرفتن"
        },
        {
          "language": "kmr",
          "text": "zivirandin û av jê derxistin"
        },
        {
          "language": "pl",
          "text": "wyżąć"
        },
        {
          "language": "ro",
          "text": "a stoarce"
        },
        {
          "language": "ru",
          "text": "выжимать"
        },
        {
          "language": "sq",
          "text": "të shtrydhësh"
        },
        {
          "language": "tr",
          "text": "sıkıp suyunu çıkarmak"
        }
      ],
      "examples": [
        {
          "baseText": "Vor der Reinigung wrang der Techniker das Tuch gründlich aus, damit keine Feuchtigkeit in das Gerät gelangte.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل التنظيف عصر الفني القماش جيدًا كي لا تصل الرطوبة إلى الجهاز."
            },
            {
              "language": "ckb",
              "text": "پێش پاککردنەوە، تەکنیکەرەکە قوماشەکەی بە باشی چلاند بۆ ئەوەی شێ نەچێتە ناو ئامێرەکە."
            },
            {
              "language": "en",
              "text": "Before cleaning, the technician thoroughly wrung out the cloth so no moisture would get into the device."
            },
            {
              "language": "fa",
              "text": "قبل از تمیزکاری، تکنسین دستمال را کاملاً چلاند تا رطوبت وارد دستگاه نشود."
            },
            {
              "language": "kmr",
              "text": "Berî paqijkirinê, teknîsyen paçê baş zivirand da ku şilî nekeve nav amûrê."
            },
            {
              "language": "pl",
              "text": "Przed czyszczeniem technik dokładnie wyżął ściereczkę, aby wilgoć nie dostała się do urządzenia."
            },
            {
              "language": "ro",
              "text": "Înainte de curățare, tehnicianul a stors bine cârpa ca umezeala să nu ajungă în aparat."
            },
            {
              "language": "ru",
              "text": "Перед очисткой техник тщательно выжал ткань, чтобы влага не попала в устройство."
            },
            {
              "language": "sq",
              "text": "Para pastrimit, tekniku e shtrydhi mirë leckën që lagështia të mos hynte në pajisje."
            },
            {
              "language": "tr",
              "text": "Temizlikten önce teknisyen bezin suyunu iyice sıktı ki cihaza nem girmesin."
            }
          ]
        },
        {
          "baseText": "Nach dem Regen wrang sie ihre Socken über dem Waschbecken aus.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد المطر عصرت جواربها فوق المغسلة."
            },
            {
              "language": "ckb",
              "text": "دوای بارانەکە، گۆرەوییەکانی لەسەر دەستشۆرەکە چلاند."
            },
            {
              "language": "en",
              "text": "After the rain, she wrung out her socks over the sink."
            },
            {
              "language": "fa",
              "text": "بعد از باران، جوراب‌هایش را روی روشویی چلاند."
            },
            {
              "language": "kmr",
              "text": "Piştî baranê, wê goreyên xwe li ser destşokê zivirandin."
            },
            {
              "language": "pl",
              "text": "Po deszczu wyżęła skarpetki nad umywalką."
            },
            {
              "language": "ro",
              "text": "După ploaie, și-a stors șosetele deasupra chiuvetei."
            },
            {
              "language": "ru",
              "text": "После дождя она выжала носки над раковиной."
            },
            {
              "language": "sq",
              "text": "Pas shiut, ajo i shtrydhi çorapet mbi lavaman."
            },
            {
              "language": "tr",
              "text": "Yağmurdan sonra çoraplarının suyunu lavabonun üzerinde sıktı."
            }
          ]
        }
      ]
    },
