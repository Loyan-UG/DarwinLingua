      "meanings": [
        {
          "language": "ar",
          "text": "يُهجّي"
        },
        {
          "language": "ckb",
          "text": "پیت بە پیت وتن"
        },
        {
          "language": "en",
          "text": "to spell"
        },
        {
          "language": "fa",
          "text": "هجی کردن"
        },
        {
          "language": "kmr",
          "text": "tîp bi tîp gotin"
        },
        {
          "language": "pl",
          "text": "literować"
        },
        {
          "language": "ro",
          "text": "a silabisi; a spune pe litere"
        },
        {
          "language": "ru",
          "text": "произносить по буквам"
        },
        {
          "language": "sq",
          "text": "shkronjëzoj"
        },
        {
          "language": "tr",
          "text": "harf harf söylemek"
        }
      ],
      "examples": [
        {
          "baseText": "Können Sie Ihren Namen buchstabieren?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك تهجئة اسمك؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن ناوتان پیت بە پیت بڵێن؟"
            },
            {
              "language": "en",
              "text": "Can you spell your name?"
            },
            {
              "language": "fa",
              "text": "می‌توانید نامتان را هجی کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin navê xwe tîp bi tîp bibêjin?"
            },
            {
              "language": "pl",
              "text": "Czy może pan przeliterować swoje imię?"
            },
            {
              "language": "ro",
              "text": "Puteți să vă spuneți numele pe litere?"
            },
            {
              "language": "ru",
              "text": "Можете произнести ваше имя по буквам?"
            },
            {
              "language": "sq",
              "text": "A mund ta thoni emrin tuaj shkronjë për shkronjë?"
            },
            {
              "language": "tr",
              "text": "Adınızı harf harf söyleyebilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Bitte buchstabieren Sie die Adresse.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك هجّئ العنوان."
            },
            {
              "language": "ckb",
              "text": "تکایە ناونیشانەکە پیت بە پیت بڵێن."
            },
            {
              "language": "en",
              "text": "Please spell the address."
            },
            {
              "language": "fa",
              "text": "لطفاً آدرس را هجی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe navnîşanê tîp bi tîp bibêjin."
            },
            {
              "language": "pl",
              "text": "Proszę przeliterować adres."
            },
            {
              "language": "ro",
              "text": "Vă rog să spuneți adresa pe litere."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, произнесите адрес по буквам."
            },
            {
              "language": "sq",
              "text": "Ju lutem thoni adresën shkronjë për shkronjë."
            },
            {
              "language": "tr",
              "text": "Lütfen adresi harf harf söyleyin."
            }
          ]
        }
      ]
    },
