      "meanings": [
        {
          "language": "ar",
          "text": "تغذية؛ نظام غذائي"
        },
        {
          "language": "ckb",
          "text": "خۆراک؛ شێوازی خۆراکخواردن"
        },
        {
          "language": "en",
          "text": "nutrition; diet"
        },
        {
          "language": "fa",
          "text": "تغذیه؛ رژیم غذایی"
        },
        {
          "language": "kmr",
          "text": "xwarin; perwerdeya xwarinê"
        },
        {
          "language": "pl",
          "text": "odżywianie; dieta"
        },
        {
          "language": "ro",
          "text": "alimentație; nutriție"
        },
        {
          "language": "ru",
          "text": "питание; рацион"
        },
        {
          "language": "sq",
          "text": "ushqyerje; dietë"
        },
        {
          "language": "tr",
          "text": "beslenme; diyet"
        }
      ],
      "examples": [
        {
          "baseText": "Die Ärztin empfiehlt mehr Bewegung und eine gesunde Ernährung.",
          "translations": [
            {
              "language": "ar",
              "text": "توصي الطبيبة بمزيد من الحركة وتغذية صحية."
            },
            {
              "language": "ckb",
              "text": "پزیشکەکە پێشنیاری جووڵەی زیاتر و خۆراکێکی تەندروست دەکات."
            },
            {
              "language": "en",
              "text": "The doctor recommends more exercise and a healthy diet."
            },
            {
              "language": "fa",
              "text": "پزشک تحرک بیشتر و تغذیه سالم را توصیه می‌کند."
            },
            {
              "language": "kmr",
              "text": "Bijîşk tevgerîna zêdetir û xwarineke tendurist pêşniyar dike."
            },
            {
              "language": "pl",
              "text": "Lekarka zaleca więcej ruchu i zdrowe odżywianie."
            },
            {
              "language": "ro",
              "text": "Medicul recomandă mai multă mișcare și o alimentație sănătoasă."
            },
            {
              "language": "ru",
              "text": "Врач рекомендует больше движения и здоровое питание."
            },
            {
              "language": "sq",
              "text": "Mjekja rekomandon më shumë lëvizje dhe ushqyerje të shëndetshme."
            },
            {
              "language": "tr",
              "text": "Doktor daha fazla hareket ve sağlıklı beslenme öneriyor."
            }
          ]
        },
        {
          "baseText": "In der Kantine gibt es jetzt einen Kurs über Ernährung im Arbeitsalltag.",
          "translations": [
            {
              "language": "ar",
              "text": "يوجد الآن في المقصف دورة عن التغذية في يوم العمل."
            },
            {
              "language": "ckb",
              "text": "لە کانتینەکەدا ئێستا خولێک دەربارەی خۆراک لە ڕۆژانی کاردا هەیە."
            },
            {
              "language": "en",
              "text": "There is now a course in the cafeteria about nutrition in everyday work life."
            },
            {
              "language": "fa",
              "text": "در سلف شرکت حالا دوره‌ای درباره تغذیه در روز کاری برگزار می‌شود."
            },
            {
              "language": "kmr",
              "text": "Li kantînê niha kursek li ser xwarinê di jiyana karê rojane de heye."
            },
            {
              "language": "pl",
              "text": "W stołówce jest teraz kurs o odżywianiu w codziennej pracy."
            },
            {
              "language": "ro",
              "text": "La cantină există acum un curs despre alimentație în viața de lucru de zi cu zi."
            },
            {
              "language": "ru",
              "text": "В столовой теперь есть курс о питании в рабочие будни."
            },
            {
              "language": "sq",
              "text": "Në mensë tani ka një kurs për ushqyerjen gjatë ditës së punës."
            },
            {
              "language": "tr",
              "text": "Kantinada artık iş hayatında beslenme hakkında bir kurs var."
            }
          ]
        }
      ]
    },
    {
      "word": "erraten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "erraten",
      "pronunciationIpa": null,
      "syllableBreak": "er-ra-ten",
