  "entries": [
    {
      "word": "ankündigen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ankündigen",
      "pronunciationIpa": null,
      "syllableBreak": "an-kün-di-gen",
      "topics": [
        "business-communication",
        "work-and-jobs",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "customer-service",
        "documents"
      ],
      "grammarNotes": [
        "separable verb",
        "means to announce something in advance"
      ],
      "collocations": [
        {
          "text": "eine Änderung ankündigen",
          "meaning": "to announce a change"
        },
        {
          "text": "einen Termin ankündigen",
          "meaning": "to announce an appointment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Ankündigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعلن مسبقًا؛ يبلّغ عن شيء قادم"
        },
        {
          "language": "ckb",
          "text": "پێشوەخت راگەیاندن؛ ئاگادارکردنەوە لە شتێکی داهاتوو"
        },
        {
          "language": "en",
          "text": "to announce; to give advance notice"
        },
        {
          "language": "fa",
          "text": "اعلام کردن؛ از قبل خبر دادن"
        },
        {
          "language": "kmr",
          "text": "ragihandin; berê agahdar kirin"
        },
        {
          "language": "pl",
          "text": "zapowiedzieć; ogłosić"
        },
        {
          "language": "ro",
          "text": "a anunța; a comunica dinainte"
        },
        {
          "language": "ru",
          "text": "объявить; заранее сообщить"
        },
        {
          "language": "sq",
          "text": "të njoftosh; të shpallësh paraprakisht"
        },
        {
          "language": "tr",
          "text": "duyurmak; önceden bildirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Anbieter hat eine Wartung für Freitagabend angekündigt.",
          "translations": [
            {
              "language": "ar",
              "text": "أعلن المزود عن صيانة مساء الجمعة."
            },
            {
              "language": "ckb",
              "text": "دابینکەرەکە چاکسازییەکی بۆ ئێوارەی هەینی راگەیاندووە."
            },
            {
              "language": "en",
              "text": "The provider announced maintenance for Friday evening."
            },
            {
              "language": "fa",
              "text": "ارائه‌دهنده برای جمعه شب یک عملیات نگهداری اعلام کرده است."
            },
            {
              "language": "kmr",
              "text": "Dabînker ji bo êvara înê lênêrînek ragihandiye."
            },
            {
              "language": "pl",
              "text": "Dostawca zapowiedział prace serwisowe na piątkowy wieczór."
            },
            {
              "language": "ro",
              "text": "Furnizorul a anunțat mentenanță pentru vineri seara."
            },
            {
              "language": "ru",
              "text": "Поставщик объявил техническое обслуживание на вечер пятницы."
            },
            {
              "language": "sq",
              "text": "Ofruesi ka njoftuar mirëmbajtje për të premten në mbrëmje."
            },
            {
              "language": "tr",
              "text": "Sağlayıcı cuma akşamı için bakım çalışması duyurdu."
            }
          ]
        },
        {
          "baseText": "Die Schule kündigt den Eltern den Ausflug mindestens zwei Wochen vorher an.",
          "translations": [
            {
              "language": "ar",
              "text": "تبلغ المدرسة الأهالي بالرحلة قبل أسبوعين على الأقل."
            },
            {
              "language": "ckb",
              "text": "قوتابخانەکە بە لایەنی کەم دوو هەفتە پێشتر گەشتەکە بە دایک و باوکان رادەگەیەنێت."
            },
            {
              "language": "en",
              "text": "The school announces the trip to parents at least two weeks in advance."
            },
            {
              "language": "fa",
              "text": "مدرسه گردش را حداقل دو هفته قبل به والدین اعلام می‌کند."
            },
            {
              "language": "kmr",
              "text": "Dibistan herî kêm du hefte berê seyranê ji dêûbavan re radigihîne."
            },
            {
              "language": "pl",
              "text": "Szkoła zapowiada rodzicom wycieczkę co najmniej dwa tygodnie wcześniej."
            },
            {
              "language": "ro",
              "text": "Școala anunță părinții despre excursie cu cel puțin două săptămâni înainte."
            },
            {
              "language": "ru",
              "text": "Школа сообщает родителям об экскурсии как минимум за две недели."
            },
            {
              "language": "sq",
              "text": "Shkolla ua njofton prindërve ekskursionin të paktën dy javë më parë."
            },
            {
              "language": "tr",
              "text": "Okul geziyi velilere en az iki hafta önceden duyurur."
            }
          ]
        }
      ]
    },
    {
      "word": "die Anlage",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Anlagen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-la-ge",
      "topics": [
        "documents-and-administration",
        "technology-and-it",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "documents",
        "it",
        "finance"
      ],
      "grammarNotes": [
        "feminine noun",
        "can mean attachment, system/facility, or investment"
      ],
      "collocations": [
        {
          "text": "siehe Anlage",
          "meaning": "see attachment"
        },
        {
          "text": "eine technische Anlage",
          "meaning": "a technical system or facility"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "anlegen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مرفق؛ منشأة؛ جهاز أو نظام؛ استثمار"
        },
        {
          "language": "ckb",
          "text": "هاوپێچ؛ دامەزراوە؛ سیستەم؛ وەبەرهێنان"
        },
        {
          "language": "en",
          "text": "attachment; facility; system; investment"
        },
        {
          "language": "fa",
          "text": "پیوست؛ تأسیسات؛ سیستم؛ سرمایه‌گذاری"
        },
        {
          "language": "kmr",
          "text": "pêvekirî; sazgeh; pergal; veberhênan"
        },
        {
          "language": "pl",
          "text": "załącznik; instalacja; lokata"
        },
        {
          "language": "ro",
          "text": "anexă; instalație; investiție"
        },
        {
          "language": "ru",
          "text": "приложение; установка; вложение"
        },
        {
          "language": "sq",
          "text": "bashkëngjitje; objekt; investim"
        },
        {
          "language": "tr",
          "text": "ek; tesis; sistem; yatırım"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rechnung finden Sie in der Anlage dieser E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "تجدون الفاتورة في مرفق هذا البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "فاکتورەکە لە هاوپێچی ئەم ئیمەیڵەدا دەدۆزنەوە."
            },
            {
              "language": "en",
              "text": "You can find the invoice in the attachment to this email."
            },
            {
              "language": "fa",
              "text": "فاکتور را در پیوست این ایمیل پیدا می‌کنید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin fatûreyê di pêveka vê e-nameyê de bibînin."
            },
            {
              "language": "pl",
              "text": "Fakturę znajdą Państwo w załączniku do tego e-maila."
            },
            {
              "language": "ro",
              "text": "Găsiți factura în anexa acestui e-mail."
            },
            {
              "language": "ru",
              "text": "Счёт вы найдёте во вложении к этому письму."
            },
            {
              "language": "sq",
              "text": "Faturën e gjeni në bashkëngjitjen e këtij emaili."
            },
            {
              "language": "tr",
              "text": "Faturayı bu e-postanın ekinde bulabilirsiniz."
            }
          ]
        },
        {
          "baseText": "Die neue Anlage in der Produktion spart deutlich Energie.",
          "translations": [
            {
              "language": "ar",
              "text": "توفر المنشأة الجديدة في الإنتاج قدرًا واضحًا من الطاقة."
            },
            {
              "language": "ckb",
              "text": "دامەزراوە نوێیەکە لە بەرهەمهێناندا بە روونی وزە پاشەکەوت دەکات."
            },
            {
              "language": "en",
              "text": "The new system in production saves a significant amount of energy."
            },
            {
              "language": "fa",
              "text": "تأسیسات جدید در بخش تولید به‌طور قابل توجهی انرژی صرفه‌جویی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pergala nû ya di hilberînê de bi eşkere enerjiyê paş dixe."
            },
            {
              "language": "pl",
