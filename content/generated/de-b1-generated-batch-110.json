        "feminine noun"
      ],
      "collocations": [
        {
          "text": "kostenlose Rechtsberatung",
          "meaning": "free legal advice"
        },
        {
          "text": "Rechtsberatung anbieten",
          "meaning": "to offer legal advice"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Recht",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "beraten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "استشارة قانونية"
        },
        {
          "language": "ckb",
          "text": "ڕاوێژی یاسایی"
        },
        {
          "language": "en",
          "text": "legal advice; legal consultation"
        },
        {
          "language": "fa",
          "text": "مشاوره حقوقی"
        },
        {
          "language": "kmr",
          "text": "şêwirmendiya hiqûqî"
        },
        {
          "language": "pl",
          "text": "porada prawna; doradztwo prawne"
        },
        {
          "language": "ro",
          "text": "consiliere juridică"
        },
        {
          "language": "ru",
          "text": "юридическая консультация"
        },
        {
          "language": "sq",
          "text": "këshillim juridik"
        },
        {
          "language": "tr",
          "text": "hukuki danışmanlık"
        }
      ],
      "examples": [
        {
          "baseText": "Bei Problemen mit dem Mietvertrag kann eine Rechtsberatung helfen.",
          "translations": [
            {
              "language": "ar",
              "text": "عند وجود مشاكل في عقد الإيجار يمكن أن تساعد الاستشارة القانونية."
            },
            {
              "language": "ckb",
              "text": "لە کێشەی گرێبەستی کرێدا ڕاوێژی یاسایی دەتوانێت یارمەتی بدات."
            },
            {
              "language": "en",
              "text": "If there are problems with the rental contract, legal advice can help."
            },
            {
              "language": "fa",
              "text": "در صورت مشکل با قرارداد اجاره، مشاوره حقوقی می‌تواند کمک کند."
            },
            {
              "language": "kmr",
              "text": "Heke pirsgirêkên peymana kirê hebin, şêwirmendiya hiqûqî dikare alîkar be."
            },
            {
              "language": "pl",
              "text": "Przy problemach z umową najmu może pomóc porada prawna."
            },
            {
              "language": "ro",
              "text": "În caz de probleme cu contractul de închiriere, consilierea juridică poate ajuta."
            },
            {
              "language": "ru",
              "text": "При проблемах с договором аренды может помочь юридическая консультация."
            },
            {
              "language": "sq",
              "text": "Në rast problemesh me kontratën e qirasë, këshillimi juridik mund të ndihmojë."
            },
            {
              "language": "tr",
              "text": "Kira sözleşmesiyle ilgili sorunlarda hukuki danışmanlık yardımcı olabilir."
            }
          ]
        },
        {
          "baseText": "Die Beratungsstelle bietet jeden Dienstag kostenlose Rechtsberatung an.",
          "translations": [
            {
              "language": "ar",
              "text": "يقدم مركز الاستشارة استشارة قانونية مجانية كل يوم ثلاثاء."
            },
            {
              "language": "ckb",
              "text": "ناوەندی ڕاوێژ هەموو سێشەممەیەک ڕاوێژی یاسایی بەخۆڕایی پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "The counseling center offers free legal advice every Tuesday."
            },
            {
              "language": "fa",
              "text": "مرکز مشاوره هر سه‌شنبه مشاوره حقوقی رایگان ارائه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Navenda şêwirmendiyê her sêşemiyê şêwirmendiya hiqûqî ya belaş pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Punkt porad oferuje bezpłatne porady prawne w każdy wtorek."
            },
            {
              "language": "ro",
              "text": "Centrul de consiliere oferă consiliere juridică gratuită în fiecare marți."
            },
            {
              "language": "ru",
              "text": "Консультационный центр предлагает бесплатные юридические консультации каждый вторник."
            },
            {
              "language": "sq",
              "text": "Qendra e këshillimit ofron këshillim juridik falas çdo të martë."
            },
            {
              "language": "tr",
              "text": "Danışma merkezi her salı ücretsiz hukuki danışmanlık sunar."
            }
          ]
        }
      ]
    },
