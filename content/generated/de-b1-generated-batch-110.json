  "entries": [
    {
      "word": "die Rechnungskopie",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Rechnungskopien",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Rech-nungs-ko-pie",
      "topics": [
        "finance-and-accounting",
        "documents-and-administration",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "business",
        "customer-facing",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Rechnungskopie anfordern",
          "meaning": "to request a copy of an invoice"
        },
        {
          "text": "eine Rechnungskopie per E-Mail senden",
          "meaning": "to send an invoice copy by email"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Rechnung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Kopie",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "نسخة من الفاتورة"
        },
        {
          "language": "ckb",
          "text": "کۆپیی فاکتور"
        },
        {
          "language": "en",
          "text": "copy of an invoice; invoice copy"
        },
        {
          "language": "fa",
          "text": "کپی فاکتور؛ نسخه‌ای از صورت‌حساب"
        },
        {
          "language": "kmr",
          "text": "kopiya fatûreyê"
        },
        {
          "language": "pl",
          "text": "kopia faktury"
        },
        {
          "language": "ro",
          "text": "copie a facturii"
        },
        {
          "language": "ru",
          "text": "копия счёта; копия фактуры"
        },
        {
          "language": "sq",
          "text": "kopje fature"
        },
        {
          "language": "tr",
          "text": "fatura kopyası"
        }
      ],
      "examples": [
        {
          "baseText": "Könnten Sie mir bitte eine Rechnungskopie per E-Mail schicken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنكم من فضلكم إرسال نسخة من الفاتورة إليّ بالبريد الإلكتروني؟"
            },
            {
              "language": "ckb",
              "text": "تکایە دەتوانن کۆپیی فاکتورەکە بە ئیمەیڵ بۆم بنێرن؟"
            },
            {
              "language": "en",
              "text": "Could you please send me a copy of the invoice by email?"
            },
            {
              "language": "fa",
              "text": "ممکن است لطفاً یک کپی از فاکتور را برایم ایمیل کنید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin ji kerema xwe kopiya fatûreyê bi e-nameyê ji min re bişînin?"
            },
            {
              "language": "pl",
              "text": "Czy mogliby państwo przesłać mi kopię faktury e-mailem?"
            },
            {
              "language": "ro",
              "text": "Ați putea, vă rog, să îmi trimiteți o copie a facturii prin e-mail?"
            },
            {
              "language": "ru",
              "text": "Не могли бы вы отправить мне копию счёта по электронной почте?"
            },
            {
              "language": "sq",
              "text": "A mund të më dërgoni, ju lutem, një kopje të faturës me email?"
            },
            {
              "language": "tr",
              "text": "Bana faturanın bir kopyasını e-posta ile gönderebilir misiniz?"
            }
          ]
        },
        {
          "baseText": "Für die Buchhaltung brauchen wir eine Rechnungskopie mit Bestellnummer.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج للمحاسبة إلى نسخة من الفاتورة مع رقم الطلب."
            },
            {
              "language": "ckb",
              "text": "بۆ ژمێریاری پێویستمان بە کۆپیی فاکتور لەگەڵ ژمارەی داواکاری هەیە."
            },
            {
              "language": "en",
              "text": "For accounting, we need an invoice copy with the order number."
            },
            {
              "language": "fa",
              "text": "برای حسابداری به یک کپی فاکتور همراه با شماره سفارش نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo hesabdarî em hewceyê kopiya fatûreyê bi hejmara siparişê ne."
            },
            {
              "language": "pl",
              "text": "Do księgowości potrzebujemy kopii faktury z numerem zamówienia."
            },
            {
              "language": "ro",
              "text": "Pentru contabilitate avem nevoie de o copie a facturii cu numărul comenzii."
            },
            {
              "language": "ru",
              "text": "Для бухгалтерии нам нужна копия счёта с номером заказа."
            },
            {
              "language": "sq",
              "text": "Për kontabilitet na duhet një kopje fature me numrin e porosisë."
            },
            {
              "language": "tr",
              "text": "Muhasebe için sipariş numarası olan bir fatura kopyasına ihtiyacımız var."
            }
          ]
        }
      ]
    },
    {
      "word": "die Rechtsberatung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Rechtsberatungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Rechts-be-ra-tung",
      "topics": [
