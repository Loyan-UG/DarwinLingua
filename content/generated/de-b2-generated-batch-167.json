  "entries": [
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "entfallen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entfallen",
      "syllableBreak": "ent-fal-len",
      "topics": [
        "business-communication",
        "documents-and-administration",
        "planning-and-projects"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "documents",
        "management"
      ],
      "grammarNotes": [
        "inseparable strong verb; common meaning: to be omitted, canceled, or no longer apply"
      ],
      "collocations": [
        {
          "text": "ein Termin entfällt",
          "meaning": "an appointment is canceled"
        },
        {
          "text": "eine Gebühr entfällt",
          "meaning": "a fee is waived/no longer applies"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fallen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يُلغى؛ لا يعود مطلوبًا"
        },
        {
          "language": "ckb",
          "text": "هەڵدەوەشێتەوە؛ چیتر پێویست نابێت"
        },
        {
          "language": "en",
          "text": "to be canceled; to be omitted; to no longer apply"
        },
        {
          "language": "fa",
          "text": "لغو شدن؛ حذف شدن؛ دیگر لازم نبودن"
        },
        {
          "language": "kmr",
          "text": "betal bûn; nema pêwîst bûn"
        },
        {
          "language": "pl",
          "text": "odpadać; zostać anulowanym"
        },
        {
          "language": "ro",
          "text": "a fi anulat; a nu se mai aplica"
        },
        {
          "language": "ru",
          "text": "отменяться; отпадать"
        },
        {
          "language": "sq",
          "text": "të anulohet; të mos vlejë më"
        },
        {
          "language": "tr",
          "text": "iptal olmak; kalkmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Termin am Freitag entfällt, weil die Entscheidung bereits gefallen ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يُلغى موعد يوم الجمعة لأن القرار قد اتُخذ بالفعل."
            },
            {
              "language": "ckb",
              "text": "کاتی هەینی هەڵدەوەشێتەوە، چونکە بڕیارەکە پێشتر دراوە."
            },
            {
              "language": "en",
              "text": "The appointment on Friday is canceled because the decision has already been made."
            },
            {
              "language": "fa",
              "text": "قرار روز جمعه لغو می‌شود، چون تصمیم قبلاً گرفته شده است."
            },
            {
              "language": "kmr",
              "text": "Dema roja înê betal dibe, ji ber ku biryar berê hatiye dayîn."
            },
            {
              "language": "pl",
              "text": "Termin w piątek odpada, ponieważ decyzja już zapadła."
            },
            {
              "language": "ro",
              "text": "Programarea de vineri se anulează, deoarece decizia a fost deja luată."
            },
            {
              "language": "ru",
              "text": "Встреча в пятницу отменяется, потому что решение уже принято."
            },
            {
              "language": "sq",
              "text": "Takimi të premten anulohet, sepse vendimi tashmë është marrë."
            },
            {
              "language": "tr",
              "text": "Cuma günkü randevu iptal oluyor çünkü karar zaten verildi."
            }
          ]
        },
        {
          "baseText": "Für Kinder unter sechs Jahren entfällt der Eintritt im Museum.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة للأطفال دون السادسة لا توجد رسوم دخول إلى المتحف."
            },
            {
              "language": "ckb",
              "text": "بۆ منداڵانی خوار شەش ساڵ، کرێی چوونەژوورەوەی مۆزەخانە نامێنێت."
            },
            {
              "language": "en",
              "text": "For children under six, the museum admission fee does not apply."
            },
            {
              "language": "fa",
              "text": "برای کودکان زیر شش سال، ورودی موزه حذف می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ji bo zarokên bin şeş salî, pereya ketina muzeyê namîne."
            },
            {
              "language": "pl",
              "text": "Dla dzieci poniżej sześciu lat opłata za wstęp do muzeum odpada."
            },
            {
              "language": "ro",
              "text": "Pentru copiii sub șase ani, taxa de intrare la muzeu nu se aplică."
            },
            {
              "language": "ru",
              "text": "Для детей до шести лет входная плата в музей не взимается."
            },
            {
              "language": "sq",
              "text": "Për fëmijët nën gjashtë vjeç, hyrja në muze nuk paguhet."
            },
            {
              "language": "tr",
              "text": "Altı yaşından küçük çocuklar için müze giriş ücreti alınmaz."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "entfliehen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entfliehen",
      "syllableBreak": "ent-flie-hen",
      "topics": [
        "social-and-relationships",
        "everyday-life",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written"
      ],
      "contextLabels": [
        "risk"
      ],
      "grammarNotes": [
        "inseparable strong verb; often used with dative: einer Situation entfliehen"
      ],
      "collocations": [
        {
          "text": "dem Alltag entfliehen",
          "meaning": "to escape everyday life"
        },
        {
          "text": "einer Gefahr entfliehen",
          "meaning": "to escape a danger"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fliehen",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "die Flucht",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يهرب من؛ يفلت من"
        },
        {
          "language": "ckb",
          "text": "لە شتێک ڕادەکات؛ دەرباز دەبێت"
        },
        {
          "language": "en",
          "text": "to escape; to flee from"
        },
        {
          "language": "fa",
          "text": "گریختن از؛ فرار کردن از"
        },
        {
          "language": "kmr",
          "text": "revîn ji; xilas bûn ji"
        },
        {
          "language": "pl",
          "text": "uciec przed; wymknąć się"
        },
        {
          "language": "ro",
          "text": "a scăpa de; a fugi de"
        },
        {
          "language": "ru",
          "text": "убежать от; спастись от"
        },
        {
          "language": "sq",
          "text": "të arratisesh nga; t’i shpëtosh"
        },
        {
          "language": "tr",
          "text": "kaçmak; kurtulmak"
        }
      ],
      "examples": [
        {
          "baseText": "Viele Menschen möchten am Wochenende dem Stress der Arbeit entfliehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد كثير من الناس في عطلة نهاية الأسبوع الهروب من ضغط العمل."
            },
            {
              "language": "ckb",
              "text": "زۆر کەس لە کۆتایی هەفتەدا دەیانەوێت لە سترێسی کار دەرباز بن."
            },
            {
              "language": "en",
              "text": "Many people want to escape the stress of work at the weekend."
            },
            {
              "language": "fa",
              "text": "بسیاری از افراد آخر هفته می‌خواهند از استرس کار فاصله بگیرند."
            },
            {
              "language": "kmr",
              "text": "Gelek kes dixwazin dawiya hefteyê ji stresê karê xilas bibin."
            },
            {
              "language": "pl",
              "text": "Wiele osób chce w weekend uciec od stresu pracy."
            },
            {
              "language": "ro",
              "text": "Mulți oameni vor să scape în weekend de stresul muncii."
            },
            {
              "language": "ru",
              "text": "Многие люди хотят на выходных уйти от рабочего стресса."
            },
            {
              "language": "sq",
              "text": "Shumë njerëz duan t’i shpëtojnë stresit të punës në fundjavë."
            },
            {
              "language": "tr",
              "text": "Birçok insan hafta sonu iş stresinden kaçmak ister."
            }
          ]
        },
        {
          "baseText": "Die Familie konnte dem Feuer rechtzeitig entfliehen.",
          "translations": [
            {
              "language": "ar",
              "text": "تمكنت العائلة من الهرب من الحريق في الوقت المناسب."
            },
            {
              "language": "ckb",
              "text": "خێزانەکە توانی لە ئاگرەکە بەکاتی دەرباز بێت."
            },
            {
              "language": "en",
              "text": "The family was able to escape the fire in time."
            },
            {
              "language": "fa",
              "text": "خانواده توانست به‌موقع از آتش‌سوزی فرار کند."
            },
            {
              "language": "kmr",
              "text": "Malbat karî di demê de ji agir xilas bibe."
            },
            {
              "language": "pl",
              "text": "Rodzina zdołała w porę uciec przed ogniem."
            },
            {
              "language": "ro",
