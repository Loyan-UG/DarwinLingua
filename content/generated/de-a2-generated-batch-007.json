      ],
      "examples": [
        {
          "baseText": "Der Angestellte am Empfang hilft den Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "الموظف في الاستقبال يساعد العملاء."
            },
            {
              "language": "ckb",
              "text": "کارمەندەکە لە پێشوازی یارمەتی کڕیارەکان دەدات."
            },
            {
              "language": "en",
              "text": "The employee at reception helps the customers."
            },
            {
              "language": "fa",
              "text": "کارمند پذیرش به مشتریان کمک می‌کند."
            },
            {
              "language": "kmr",
              "text": "Karmendê resepsiyonê alîkariya xerîdaran dike."
            },
            {
              "language": "pl",
              "text": "Pracownik w recepcji pomaga klientom."
            },
            {
              "language": "ro",
              "text": "Angajatul de la recepție îi ajută pe clienți."
            },
            {
              "language": "ru",
              "text": "Сотрудник на ресепшене помогает клиентам."
            },
            {
              "language": "sq",
              "text": "Punonjësi në recepsion ndihmon klientët."
            },
            {
              "language": "tr",
              "text": "Resepsiyondaki çalışan müşterilere yardım ediyor."
            }
          ]
        },
        {
          "baseText": "Ein neuer Angestellter beginnt am Montag.",
          "translations": [
            {
              "language": "ar",
              "text": "موظف جديد يبدأ يوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "کارمەندێکی نوێ دووشەممە دەست پێدەکات."
            },
            {
              "language": "en",
              "text": "A new employee starts on Monday."
            },
            {
              "language": "fa",
              "text": "یک کارمند جدید دوشنبه شروع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Karmendekî nû duşemê dest pê dike."
            },
            {
              "language": "pl",
              "text": "Nowy pracownik zaczyna w poniedziałek."
            },
            {
              "language": "ro",
              "text": "Un angajat nou începe luni."
            },
            {
              "language": "ru",
              "text": "Новый сотрудник начинает в понедельник."
            },
            {
              "language": "sq",
              "text": "Një punonjës i ri fillon të hënën."
            },
            {
              "language": "tr",
              "text": "Yeni bir çalışan pazartesi başlıyor."
            }
          ]
        }
      ]
    },
