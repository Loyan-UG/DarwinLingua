      "examples": [
        {
          "baseText": "Wir brauchen einen Anhänger für den Umzug.",
          "translations": [
            {
              "language": "ar",
              "text": "نحتاج إلى مقطورة للانتقال."
            },
            {
              "language": "ckb",
              "text": "بۆ گواستنەوەکە پێویستمان بە تریلەرێک هەیە."
            },
            {
              "language": "en",
              "text": "We need a trailer for the move."
            },
            {
              "language": "fa",
              "text": "برای اسباب‌کشی به یک تریلر نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo koçkirinê hewceyê trêlerekê ne."
            },
            {
              "language": "pl",
              "text": "Potrzebujemy przyczepy do przeprowadzki."
            },
            {
              "language": "ro",
              "text": "Avem nevoie de o remorcă pentru mutare."
            },
            {
              "language": "ru",
              "text": "Нам нужен прицеп для переезда."
            },
            {
              "language": "sq",
              "text": "Na duhet një rimorkio për shpërnguljen."
            },
            {
              "language": "tr",
              "text": "Taşınma için bir römorka ihtiyacımız var."
            }
          ]
        },
        {
          "baseText": "An meinem Schlüssel hängt ein kleiner Anhänger.",
          "translations": [
            {
              "language": "ar",
              "text": "على مفتاحي توجد علاقة صغيرة."
            },
            {
              "language": "ckb",
              "text": "لەسەر کلیلەکەم هەڵواسراوێکی بچووک هەیە."
            },
            {
              "language": "en",
              "text": "There is a small pendant on my key."
            },
            {
              "language": "fa",
              "text": "روی کلید من یک آویز کوچک هست."
            },
            {
              "language": "kmr",
              "text": "Li mifteya min pendikek biçûk heye."
            },
            {
              "language": "pl",
              "text": "Przy moim kluczu jest mała zawieszka."
            },
            {
              "language": "ro",
              "text": "La cheia mea este un breloc mic."
            },
            {
              "language": "ru",
              "text": "На моем ключе висит маленький брелок."
            },
            {
              "language": "sq",
              "text": "Në çelësin tim ka një varëse të vogël."
