      "examples": [
        {
          "baseText": "Die Angestellte erklärt mir das Formular.",
          "translations": [
            {
              "language": "ar",
              "text": "الموظفة تشرح لي الاستمارة."
            },
            {
              "language": "ckb",
              "text": "کارمەندە ژنەکە فۆرمەکە بۆم ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The employee explains the form to me."
            },
            {
              "language": "fa",
              "text": "کارمند فرم را برای من توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Karmend formê ji min re rave dike."
            },
            {
              "language": "pl",
              "text": "Pracownica wyjaśnia mi formularz."
            },
            {
              "language": "ro",
              "text": "Angajata îmi explică formularul."
            },
            {
              "language": "ru",
              "text": "Сотрудница объясняет мне форму."
            },
            {
              "language": "sq",
              "text": "Punonjësja ma shpjegon formularin."
            },
            {
              "language": "tr",
              "text": "Kadın çalışan bana formu açıklıyor."
            }
          ]
        },
        {
          "baseText": "Eine Angestellte bringt die Bestellung an den Tisch.",
          "translations": [
            {
              "language": "ar",
              "text": "موظفة تحضر الطلب إلى الطاولة."
            },
            {
              "language": "ckb",
              "text": "کارمەندێکی ژن داواکارییەکە دێنێتە سەر مێزەکە."
            },
            {
              "language": "en",
              "text": "An employee brings the order to the table."
            },
            {
              "language": "fa",
              "text": "یک کارمند سفارش را به میز می‌آورد."
            },
            {
              "language": "kmr",
              "text": "Karmendek daxwazê tîne ser maseyê."
            },
            {
              "language": "pl",
              "text": "Pracownica przynosi zamówienie do stolika."
            },
            {
              "language": "ro",
              "text": "O angajată aduce comanda la masă."
            },
            {
              "language": "ru",
              "text": "Сотрудница приносит заказ к столу."
            },
            {
              "language": "sq",
              "text": "Një punonjëse e sjell porosinë në tavolinë."
            },
            {
              "language": "tr",
              "text": "Bir çalışan siparişi masaya getiriyor."
            }
          ]
        }
