  "entries": [
    {
      "word": "die Anwendung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Anwendungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-wen-dung",
      "topics": [
        "technology-and-it",
        "documents-and-administration"
      ],
      "usageLabels": [
        "workplace",
        "technical",
        "written"
      ],
      "contextLabels": [
        "it",
        "software"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تطبيق; استخدام"
        },
        {
          "language": "ckb",
          "text": "بەرنامە; بەکارھێنان"
        },
        {
          "language": "en",
          "text": "application; implementation"
        },
        {
          "language": "fa",
          "text": "برنامهٔ کاربردی؛ اجرا"
        },
        {
          "language": "kmr",
          "text": "serlêdan; bikaranîn"
        },
        {
          "language": "pl",
          "text": "aplikacja; zastosowanie"
        },
        {
          "language": "ro",
          "text": "aplicație; utilizare"
        },
        {
          "language": "ru",
          "text": "приложение; применение"
        },
        {
          "language": "sq",
          "text": "aplikim; përdorim"
        },
        {
          "language": "tr",
          "text": "uygulama; kullanım"
        }
      ],
      "examples": [
        {
          "baseText": "Wir testen die neue Anwendung zuerst auf einem separaten Server.",
          "translations": [
            {
              "language": "ar",
              "text": "نحن نختبر التطبيق الجديد أولاً على خادم منفصل."
            },
            {
              "language": "ckb",
              "text": "ئێمە بەکارھێنانی نوێکەکە یەکەمجار لەسەر سێرڤەرێکی جیاواز تاقی دەکەین."
            },
            {
              "language": "en",
              "text": "We test the new application first on a separate server."
            },
            {
              "language": "fa",
              "text": "ابتدا نرم‌افزار جدید را روی یک سرور جداگانه آزمایش می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em sepanekî nû yên dawîn di ser serverek cuda de di pêşî da ceribî dikin."
            },
            {
              "language": "pl",
              "text": "Nowe zastosowanie najpierw testujemy na oddzielnym serwerze."
            },
            {
              "language": "ro",
              "text": "Testăm mai întâi noua aplicație pe un server separat."
            },
            {
              "language": "ru",
              "text": "Новое приложение мы сначала тестируем на отдельном сервере."
            },
            {
              "language": "sq",
              "text": "Ne fillimisht e testojmë aplikacionin e ri në një server të veçantë."
            },
            {
              "language": "tr",
              "text": "Yeni uygulamayı önce ayrı bir sunucuda test ediyoruz."
            }
          ]
        },
        {
          "baseText": "Kannst du die Anwendung kurz im Team erklären?",
          "translations": [
            {
              "language": "ar",
              "text": "می‌توانید این کاربرد را به‌صورت کوتاه برای تیم توضیح دهید؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانی بەکارهێنانیەکە بە کورتی لەخۆی تیمەکە ڕوون بکەیت؟"
            },
            {
              "language": "en",
              "text": "Can you explain the application briefly to the team?"
            },
            {
              "language": "fa",
              "text": "آیا می‌توانی این کاربرد را کوتاه برای تیم توضیح دهی؟"
            },
            {
              "language": "kmr",
              "text": "Dikarî ev bikaranîn bi kurtasîr bi tîmê re ragihînî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz krótko wyjaśnić to zastosowanie zespołowi?"
            },
            {
              "language": "ro",
              "text": "Poți explica pe scurt aplicația echipei?"
            },
            {
              "language": "ru",
              "text": "Можешь кратко объяснить это приложение команде?"
            },
            {
              "language": "sq",
              "text": "Mund ta shpjegosh shkurt aplikacionin ndaj ekipit?"
            },
            {
              "language": "tr",
              "text": "Uygulamayı ekibe kısaca açıklayabilir misin?"
            }
          ]
        }
      ]
    },
    {
      "word": "der Anwendungsfall",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Anwendungsfälle",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-wen-dungs-fall",
      "topics": [
        "technology-and-it",
        "planning-and-projects"
      ],
      "usageLabels": [
        "workplace",
        "formal",
        "technical"
      ],
      "contextLabels": [
        "it",
        "software"
      ],
      "grammarNotes": [
        "masculine noun"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "حالة استخدام"
        },
        {
          "language": "ckb",
          "text": "کەیسێکی بەکارھێنان"
        },
        {
          "language": "en",
          "text": "use case"
        },
        {
          "language": "fa",
          "text": "سناریوی استفاده"
        },
        {
          "language": "kmr",
          "text": "bikaranîna rewşê"
        },
        {
          "language": "pl",
          "text": "przypadek użycia"
        },
        {
          "language": "ro",
          "text": "caz de utilizare"
        },
        {
          "language": "ru",
          "text": "случай использования"
        },
        {
          "language": "sq",
          "text": "rast përdorimi"
        },
        {
          "language": "tr",
          "text": "kullanım durumu"
        }
      ],
      "examples": [
        {
          "baseText": "Der Anwendungsfall beschreibt, wie ein Ticket im Ticketsystem geöffnet wird.",
          "translations": [
            {
              "language": "ar",
              "text": "حالة الاستخدام تصف كيف يتم فتح تذكرة في نظام التذاكر."
            },
            {
              "language": "ckb",
              "text": "کەیسێکی بەکارھێنان دەتوانێت ڕەوشەی کردنەوەی تیکتێک لە سیستەمی تیکتەکان دیاری بکات."
            },
            {
              "language": "en",
              "text": "The use case describes how a ticket is opened in the ticketing system."
            },
            {
              "language": "fa",
              "text": "سناریوی استفاده توضیح می‌دهد که یک تیکت چگونه در سیستم تیکت‌گذاری باز می‌شود."
            },
            {
              "language": "kmr",
              "text": "Anwendungsfall diyar dike ka çawa tiketekê di pergala ticketan de vedigere."
            },
            {
              "language": "pl",
              "text": "Przypadek użycia opisuje, w jaki sposób zgłoszenie jest otwierane w systemie ticketów."
            },
            {
              "language": "ro",
              "text": "Cazul de utilizare descrie cum se deschide un tichet în sistemul de tichete."
            },
            {
              "language": "ru",
              "text": "Сценарий использования описывает, как создается тикет в системе тикетов."
            },
            {
              "language": "sq",
              "text": "Rasti i përdorimit përshkruan se si hapet një tiket në sistemin e biletave."
            },
            {
              "language": "tr",
              "text": "Kullanım durumu, biletin biletleme sisteminde nasıl açıldığını açıklar."
            }
          ]
        },
        {
          "baseText": "Wir haben den Anwendungsfall für den Onboarding-Prozess dokumentiert.",
          "translations": [
            {
              "language": "ar",
              "text": "ما حالت استخدام برای فرایند ورود کارکنان جدید را مستند کرده‌ایم."
            },
            {
              "language": "ckb",
              "text": "ئێمە بەکارهێنانی کەیسەکە بۆ پڕۆسەی پەیوەندیدانەوە بە پێڕاستی نووسیوە."
            },
            {
              "language": "en",
              "text": "We documented the use case for the onboarding process."
            },
            {
              "language": "fa",
              "text": "سناریوی استفاده برای فرایند ورود کارکنان جدید را مستند کرده‌ایم."
            },
            {
              "language": "kmr",
              "text": "Em Anwendungsfallê ji bo pêşberdana (onboarding) tomar kirin."
            },
            {
              "language": "pl",
              "text": "Udokumentowaliśmy przypadek użycia dla procesu wdrażania."
            },
