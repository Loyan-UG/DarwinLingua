      "examples": [
        {
          "baseText": "Die Grafik veranschaulicht, wie sich die Kosten über das Jahr entwickelt haben.",
          "translations": [
            {
              "language": "ar",
              "text": "يوضح الرسم البياني كيف تطورت التكاليف خلال السنة."
            },
            {
              "language": "ckb",
              "text": "گرافیکەکە ڕوون دەکاتەوە تێچووەکان چۆن لە ماوەی ساڵەکەدا گەشەیان کردووە."
            },
            {
              "language": "en",
              "text": "The chart illustrates how costs developed over the year."
            },
            {
              "language": "fa",
              "text": "نمودار نشان می‌دهد هزینه‌ها در طول سال چگونه تغییر کرده‌اند."
            },
            {
              "language": "kmr",
              "text": "Grafîk nîşan dide ka lêçûn di salê de çawa pêş ketine."
