        }
      ],
      "examples": [
        {
          "baseText": "Die Veränderung der Arbeitsprozesse wurde den Teams früh erklärt.",
          "translations": [
            {
              "language": "ar",
              "text": "تم شرح تغيير إجراءات العمل للفرق في وقت مبكر."
            },
            {
              "language": "ckb",
              "text": "گۆڕانکاریی پڕۆسەکانی کار زوو بۆ تیمەکان ڕوون کرایەوە."
            },
            {
              "language": "en",
              "text": "The change in work processes was explained to the teams early."
            },
            {
              "language": "fa",
              "text": "تغییر فرایندهای کاری زود برای تیم‌ها توضیح داده شد."
            },
            {
              "language": "kmr",
              "text": "Guhertina pêvajoyên karê zû ji tîman re hate ravekirin."
            },
            {
              "language": "pl",
              "text": "Zmiana procesów pracy została wcześnie wyjaśniona zespołom."
            },
            {
              "language": "ro",
              "text": "Schimbarea proceselor de lucru a fost explicată din timp echipelor."
            },
            {
              "language": "ru",
              "text": "Изменение рабочих процессов было заранее объяснено командам."
            },
            {
              "language": "sq",
              "text": "Ndryshimi i proceseve të punës iu shpjegua herët ekipeve."
            },
            {
              "language": "tr",
              "text": "İş süreçlerindeki değişiklik ekiplere erken açıklandı."
            }
          ]
        },
        {
          "baseText": "Viele Kunden haben die Veränderung im Bestellformular sofort bemerkt.",
          "translations": [
            {
              "language": "ar",
              "text": "لاحظ كثير من العملاء التغيير في نموذج الطلب فورًا."
            },
            {
              "language": "ckb",
              "text": "زۆر کڕیار گۆڕانکاریی فۆرمی داواکارییان دەستبەجێ تێبینی کرد."
            },
            {
              "language": "en",
              "text": "Many customers immediately noticed the change in the order form."
            },
            {
              "language": "fa",
              "text": "بسیاری از مشتریان تغییر در فرم سفارش را فوراً متوجه شدند."
            },
            {
              "language": "kmr",
              "text": "Gelek xerîdar guhertina di forma fermanê de demildest ferq kirin."
            },
            {
              "language": "pl",
              "text": "Wielu klientów od razu zauważyło zmianę w formularzu zamówienia."
            },
            {
              "language": "ro",
              "text": "Mulți clienți au observat imediat schimbarea din formularul de comandă."
            },
            {
              "language": "ru",
              "text": "Многие клиенты сразу заметили изменение в форме заказа."
            },
            {
              "language": "sq",
              "text": "Shumë klientë e vunë re menjëherë ndryshimin në formularin e porosisë."
            },
            {
              "language": "tr",
              "text": "Birçok müşteri sipariş formundaki değişikliği hemen fark etti."
            }
          ]
        }
      ]
    },
    {
      "word": "veranschaulichen",
