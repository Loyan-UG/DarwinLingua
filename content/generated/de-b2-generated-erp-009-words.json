    {
      "word": "Erstellbeschränkung",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Erstellbeschränkungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Er-stell-be-schrän-kung",
      "topics": [
