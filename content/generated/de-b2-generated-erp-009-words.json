        "documents-and-administration",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "technical",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; restriction that limits creation of records or documents"
      ],
      "collocations": [
        {
          "text": "eine Erstellbeschränkung aktivieren",
          "meaning": "to activate a creation restriction"
        },
        {
          "text": "die Erstellbeschränkung prüfen",
          "meaning": "to check the creation restriction"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "erstellen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "beschränken",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قيد على الإنشاء"
        },
        {
          "language": "ckb",
          "text": "سنوورداریی دروستکردن"
        },
        {
          "language": "en",
          "text": "creation restriction"
        },
        {
          "language": "fa",
          "text": "محدودیت ایجاد"
        },
        {
          "language": "kmr",
          "text": "sînordarkirina çêkirinê"
        },
        {
          "language": "pl",
          "text": "ograniczenie tworzenia"
        },
        {
          "language": "ro",
          "text": "restricție de creare"
        },
        {
          "language": "ru",
          "text": "ограничение создания"
        },
        {
          "language": "sq",
          "text": "kufizim krijimi"
        },
        {
          "language": "tr",
          "text": "oluşturma kısıtlaması"
        }
      ],
      "examples": [
        {
          "baseText": "Die Erstellbeschränkung verhindert im ERP, dass Bestellungen ohne Kostenstelle angelegt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يمنع قيد الإنشاء في ERP إنشاء طلبات شراء بدون مركز تكلفة."
            },
            {
              "language": "ckb",
              "text": "سنوورداریی دروستکردن لە ERP دا ڕێگری دەکات داواکاریی کڕین بەبێ ناوەندی تێچوو دروست بکرێت."
            },
            {
              "language": "en",
              "text": "The creation restriction in the ERP prevents purchase orders from being created without a cost center."
            },
            {
              "language": "fa",
              "text": "محدودیت ایجاد در ERP مانع ایجاد سفارش‌های خرید بدون مرکز هزینه می‌شود."
            },
            {
              "language": "kmr",
              "text": "Sînordarkirina çêkirinê di ERP de rê nade ku fermanên kirînê bê navenda lêçûnê werin çêkirin."
            },
            {
              "language": "pl",
              "text": "Ograniczenie tworzenia w ERP zapobiega zakładaniu zamówień zakupu bez miejsca powstawania kosztów."
            },
            {
              "language": "ro",
              "text": "Restricția de creare din ERP împiedică crearea comenzilor de achiziție fără centru de cost."
            },
            {
              "language": "ru",
              "text": "Ограничение создания в ERP не позволяет создавать заказы на закупку без места затрат."
            },
            {
              "language": "sq",
              "text": "Kufizimi i krijimit në ERP pengon krijimin e porosive të blerjes pa qendër kostoje."
            },
            {
              "language": "tr",
              "text": "ERP’deki oluşturma kısıtlaması, maliyet merkezi olmadan satın alma siparişi oluşturulmasını engeller."
            }
          ]
        },
        {
          "baseText": "Für neue Kunden gilt vorübergehend eine Erstellbeschränkung, bis alle Stammdaten geprüft sind.",
          "translations": [
            {
              "language": "ar",
              "text": "ينطبق مؤقتًا قيد إنشاء على العملاء الجدد حتى يتم فحص جميع البيانات الأساسية."
            },
            {
              "language": "ckb",
              "text": "بۆ کڕیارە نوێیەکان کاتییەک سنوورداریی دروستکردن هەیە تا هەموو داتای بنەڕەتی بپشکنرێت."
            },
            {
              "language": "en",
              "text": "A creation restriction temporarily applies to new customers until all master data has been checked."
            },
            {
              "language": "fa",
              "text": "برای مشتریان جدید تا بررسی کامل داده‌های پایه، موقتاً محدودیت ایجاد اعمال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ji bo mişteriyên nû heta kontrolkirina hemû daneyên bingehîn demkî sînordarkirina çêkirinê heye."
            },
            {
              "language": "pl",
              "text": "Dla nowych klientów tymczasowo obowiązuje ograniczenie tworzenia, dopóki wszystkie dane podstawowe nie zostaną sprawdzone."
            },
            {
              "language": "ro",
              "text": "Pentru clienții noi se aplică temporar o restricție de creare până când toate datele master sunt verificate."
            },
            {
              "language": "ru",
              "text": "Для новых клиентов временно действует ограничение создания, пока все основные данные не будут проверены."
            },
            {
              "language": "sq",
              "text": "Për klientët e rinj vlen përkohësisht një kufizim krijimi derisa të kontrollohen të gjitha të dhënat bazë."
            },
            {
              "language": "tr",
              "text": "Yeni müşteriler için tüm ana veriler kontrol edilene kadar geçici bir oluşturma kısıtlaması geçerlidir."
            }
          ]
        }
      ]
    },
    {
      "word": "Fahrerzeit",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Fahrerzeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Fah-rer-zeit",
      "topics": [
        "transport-and-travel",
        "warehouse-and-logistics",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "planning"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun; working or driving time of a driver"
      ],
      "collocations": [
        {
          "text": "Fahrerzeiten erfassen",
          "meaning": "to record driver times"
        },
        {
          "text": "die Fahrerzeit planen",
          "meaning": "to plan driver time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Fahrer",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "die Zeit",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وقت السائق"
        },
        {
          "language": "ckb",
          "text": "کاتی شۆفێر"
        },
        {
          "language": "en",
          "text": "driver time"
        },
        {
          "language": "fa",
          "text": "زمان راننده"
        },
        {
          "language": "kmr",
          "text": "dema ajokar"
        },
        {
          "language": "pl",
          "text": "czas kierowcy"
        },
        {
          "language": "ro",
          "text": "timpul șoferului"
        },
        {
          "language": "ru",
          "text": "время водителя"
        },
        {
          "language": "sq",
          "text": "koha e shoferit"
        },
        {
          "language": "tr",
          "text": "sürücü süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Fahrerzeit wird im ERP erfasst, damit die Tourkosten korrekt berechnet werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تسجيل وقت السائق في ERP حتى تُحسب تكاليف الجولة بشكل صحيح."
            },
            {
              "language": "ckb",
              "text": "کاتی شۆفێر لە ERP دا تۆمار دەکرێت بۆ ئەوەی تێچووی گەشتەکە بە دروستی هەژمار بکرێت."
            },
            {
              "language": "en",
              "text": "The driver time is recorded in the ERP so that route costs are calculated correctly."
            },
            {
              "language": "fa",
              "text": "زمان راننده در ERP ثبت می‌شود تا هزینه‌های مسیر درست محاسبه شود."
            },
            {
              "language": "kmr",
              "text": "Dema ajokar di ERP de tê tomarkirin da ku lêçûnên rêyê rast werin hesibandin."
            },
            {
              "language": "pl",
              "text": "Czas kierowcy jest rejestrowany w ERP, aby koszty trasy zostały poprawnie obliczone."
            },
            {
              "language": "ro",
              "text": "Timpul șoferului este înregistrat în ERP pentru ca costurile rutei să fie calculate corect."
            },
            {
              "language": "ru",
              "text": "Время водителя фиксируется в ERP, чтобы правильно рассчитать расходы маршрута."
            },
            {
              "language": "sq",
              "text": "Koha e shoferit regjistrohet në ERP që kostot e turit të llogariten saktë."
            },
            {
              "language": "tr",
              "text": "Sürücü süresi ERP’de kaydedilir, böylece tur maliyetleri doğru hesaplanır."
            }
          ]
        },
        {
          "baseText": "Wegen der langen Wartezeit am Werkstor überschreitet die Fahrerzeit den geplanten Wert.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب الانتظار الطويل عند بوابة المصنع يتجاوز وقت السائق القيمة المخططة."
            },
            {
              "language": "ckb",
              "text": "بەهۆی چاوەڕوانیی درێژ لە دەرگای کارگە، کاتی شۆفێر لە نرخی پلاندانراو زیاتر دەبێت."
            },
            {
              "language": "en",
              "text": "Because of the long waiting time at the plant gate, the driver time exceeds the planned value."
            },
            {
              "language": "fa",
              "text": "به دلیل انتظار طولانی جلوی دروازه کارخانه، زمان راننده از مقدار برنامه‌ریزی‌شده بیشتر می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ji ber benda dirêj li deriyê fabrîkayê, dema ajokar ji nirxa plankirî derbas dibe."
            },
            {
              "language": "pl",
              "text": "Z powodu długiego oczekiwania przy bramie zakładu czas kierowcy przekracza planowaną wartość."
            },
            {
              "language": "ro",
              "text": "Din cauza așteptării lungi la poarta fabricii, timpul șoferului depășește valoarea planificată."
            },
            {
              "language": "ru",
              "text": "Из-за долгого ожидания у ворот завода время водителя превышает запланированное значение."
            },
            {
              "language": "sq",
              "text": "Për shkak të pritjes së gjatë te porta e fabrikës, koha e shoferit e tejkalon vlerën e planifikuar."
            },
            {
              "language": "tr",
              "text": "Fabrika kapısındaki uzun bekleme nedeniyle sürücü süresi planlanan değeri aşıyor."
            }
          ]
        }
      ]
    },
