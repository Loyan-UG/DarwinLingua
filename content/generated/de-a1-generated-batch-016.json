      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb; also used as an adjective in other contexts"
      ],
      "collocations": [
        {
          "text": "bestimmt kommen",
          "meaning": "to definitely come"
        },
        {
          "text": "bestimmt richtig",
          "meaning": "certainly right"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bestimmen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بالتأكيد؛ حتماً"
        },
        {
          "language": "ckb",
          "text": "بەدڵنیایی؛ حەتماً"
        },
        {
          "language": "en",
          "text": "certainly; definitely"
        },
        {
          "language": "fa",
          "text": "حتماً؛ قطعاً"
        },
        {
          "language": "kmr",
          "text": "bêguman; teqez"
        },
        {
          "language": "pl",
          "text": "na pewno"
        },
        {
          "language": "ro",
          "text": "sigur; cu siguranță"
        },
        {
          "language": "ru",
          "text": "конечно; наверняка"
        },
        {
          "language": "sq",
          "text": "me siguri"
        },
        {
          "language": "tr",
          "text": "kesinlikle; mutlaka"
        }
      ],
      "examples": [
        {
          "baseText": "Das ist bestimmt richtig.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا صحيح بالتأكيد."
            },
            {
              "language": "ckb",
              "text": "ئەمە بەدڵنیایی ڕاستە."
            },
            {
              "language": "en",
              "text": "That is certainly correct."
            },
            {
              "language": "fa",
              "text": "این حتماً درست است."
            },
            {
              "language": "kmr",
              "text": "Ev bêguman rast e."
            },
            {
              "language": "pl",
              "text": "To na pewno jest poprawne."
            },
            {
              "language": "ro",
              "text": "Asta este cu siguranță corect."
            },
            {
              "language": "ru",
              "text": "Это наверняка правильно."
            },
            {
              "language": "sq",
              "text": "Kjo është me siguri e saktë."
            },
            {
              "language": "tr",
              "text": "Bu kesinlikle doğru."
            }
          ]
        },
        {
          "baseText": "Er kommt bestimmt heute.",
          "translations": [
            {
              "language": "ar",
              "text": "سيأتي بالتأكيد اليوم."
            },
            {
              "language": "ckb",
              "text": "ئەو ئەمڕۆ حەتماً دێت."
            },
            {
              "language": "en",
              "text": "He will definitely come today."
            },
            {
              "language": "fa",
              "text": "او حتماً امروز می‌آید."
            },
            {
              "language": "kmr",
              "text": "Ew îro teqez tê."
            },
            {
              "language": "pl",
              "text": "On na pewno przyjdzie dzisiaj."
            },
            {
              "language": "ro",
              "text": "El vine sigur astăzi."
            },
            {
              "language": "ru",
              "text": "Он точно придет сегодня."
            },
            {
              "language": "sq",
              "text": "Ai vjen patjetër sot."
            },
            {
              "language": "tr",
              "text": "O bugün kesinlikle gelir."
            }
          ]
        }
      ]
    },
    {
