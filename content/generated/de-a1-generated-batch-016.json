        {
          "text": "einen Kurs besuchen",
          "meaning": "to attend a course"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Besuch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يزور؛ يحضر"
        },
        {
          "language": "ckb",
          "text": "سەردانکردن؛ بەشداری کردن"
        },
        {
          "language": "en",
          "text": "to visit; to attend"
        },
        {
          "language": "fa",
          "text": "دیدن کردن؛ شرکت کردن"
        },
        {
          "language": "kmr",
          "text": "serdan kirin; beşdar bûn"
        },
        {
          "language": "pl",
          "text": "odwiedzać; uczęszczać"
        },
        {
          "language": "ro",
          "text": "a vizita; a frecventa"
        },
        {
          "language": "ru",
          "text": "посещать; навещать"
        },
        {
          "language": "sq",
          "text": "vizitoj; ndjek"
        },
        {
          "language": "tr",
          "text": "ziyaret etmek; katılmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich besuche morgen meine Mutter.",
          "translations": [
            {
              "language": "ar",
              "text": "سأزور أمي غداً."
            },
            {
              "language": "ckb",
              "text": "سبەی سەردانی دایکم دەکەم."
            },
            {
              "language": "en",
              "text": "I am visiting my mother tomorrow."
            },
            {
              "language": "fa",
              "text": "فردا به دیدن مادرم می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez sibê serdana diya xwe dikim."
            },
            {
              "language": "pl",
              "text": "Jutro odwiedzę moją mamę."
            },
            {
              "language": "ro",
              "text": "Mâine o vizitez pe mama mea."
            },
            {
              "language": "ru",
              "text": "Завтра я навещу маму."
            },
            {
              "language": "sq",
              "text": "Nesër vizitoj nënën time."
            },
            {
              "language": "tr",
              "text": "Yarın annemi ziyaret ediyorum."
            }
          ]
        },
        {
          "baseText": "Sie besucht einen Deutschkurs.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تحضر دورة لغة ألمانية."
            },
            {
              "language": "ckb",
              "text": "ئەو بەشداری کۆرسی ئەڵمانی دەکات."
            },
            {
              "language": "en",
              "text": "She attends a German course."
            },
            {
              "language": "fa",
              "text": "او در یک کلاس آلمانی شرکت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ew beşdarî kursekî almanî dibe."
            },
            {
              "language": "pl",
              "text": "Ona chodzi na kurs niemieckiego."
            },
            {
              "language": "ro",
              "text": "Ea frecventează un curs de germană."
            },
            {
              "language": "ru",
              "text": "Она посещает курс немецкого языка."
            },
            {
              "language": "sq",
              "text": "Ajo ndjek një kurs gjermanishteje."
            },
            {
              "language": "tr",
              "text": "O bir Almanca kursuna gidiyor."
            }
          ]
        }
      ]
    },
