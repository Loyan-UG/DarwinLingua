      "word": "die Repräsentation",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Repräsentationen",
      "infinitive": null,
      "syllableBreak": "Re-prä-sen-ta-ti-on",
      "topics": [
        "public-services",
        "culture-and-media",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "politische Repräsentation stärken",
          "meaning": "to strengthen political representation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "repräsentieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "repräsentativ",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تمثيل؛ عرض رمزي"
        },
        {
          "language": "ckb",
          "text": "نوێنەرایەتی؛ پیشاندانی واتایی"
        },
        {
          "language": "en",
          "text": "representation"
        },
        {
          "language": "fa",
          "text": "نمایندگی؛ بازنمایی"
        },
        {
          "language": "kmr",
          "text": "temsîlkirin; nûneratî"
        },
        {
          "language": "pl",
          "text": "reprezentacja"
        },
        {
          "language": "ro",
          "text": "reprezentare"
        },
        {
          "language": "ru",
          "text": "представительство; репрезентация"
        },
        {
          "language": "sq",
          "text": "përfaqësim; reprezentim"
        },
        {
          "language": "tr",
          "text": "temsil; gösterim"
        }
      ],
      "examples": [
        {
          "baseText": "Die Repräsentation kleiner Gemeinden im Ausschuss wurde nach der Reform verbessert.",
          "translations": [
            {
              "language": "ar",
              "text": "تحسن تمثيل البلديات الصغيرة في اللجنة بعد الإصلاح."
            },
            {
              "language": "ckb",
              "text": "نوێنەرایەتی شارۆچکە بچووکەکان لە لیژنەکەدا دوای چاکسازی باشتر کرا."
            },
            {
              "language": "en",
              "text": "The representation of small municipalities on the committee improved after the reform."
            },
            {
              "language": "fa",
              "text": "نمایندگی شهرداری‌های کوچک در کمیته پس از اصلاحات بهتر شد."
            },
            {
              "language": "kmr",
              "text": "Nûneratiya şaredariyên biçûk di komîteyê de piştî reformê baştir bû."
            },
            {
              "language": "pl",
              "text": "Reprezentacja małych gmin w komisji poprawiła się po reformie."
            },
            {
              "language": "ro",
              "text": "Reprezentarea comunelor mici în comisie s-a îmbunătățit după reformă."
            },
            {
              "language": "ru",
              "text": "Представительство малых муниципалитетов в комитете улучшилось после реформы."
            },
            {
              "language": "sq",
              "text": "Përfaqësimi i komunave të vogla në komision u përmirësua pas reformës."
            },
            {
              "language": "tr",
              "text": "Küçük belediyelerin komisyondaki temsili reformdan sonra iyileşti."
            }
          ]
        },
        {
          "baseText": "Die Repräsentation von Arbeit im Film wirkt bewusst nüchtern und unspektakulär.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدو بازنمایی العمل في الفيلم جافة وغير مثيرة عمداً."
            },
            {
              "language": "ckb",
              "text": "بازنمایی کار لە فیلمەکەدا بە ئەنقەست سادە و بێ درەوشاوەیە."
            },
            {
              "language": "en",
              "text": "The representation of work in the film deliberately appears sober and unspectacular."
            },
            {
              "language": "fa",
              "text": "بازنمایی کار در فیلم عمداً خشک و غیرنمایشی به نظر می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Temsîlkirina kar di fîlmê de bi zanebûn sade û bêşewq xuya dike."
            },
            {
              "language": "pl",
              "text": "Reprezentacja pracy w filmie jest celowo trzeźwa i niespektakularna."
            },
            {
              "language": "ro",
              "text": "Reprezentarea muncii în film pare deliberat sobră și nespectaculoasă."
            },
            {
              "language": "ru",
              "text": "Репрезентация труда в фильме намеренно выглядит сдержанной и неброской."
            },
            {
              "language": "sq",
              "text": "Reprezentimi i punës në film duket qëllimisht i kthjellët dhe jo spektakolar."
            },
            {
              "language": "tr",
              "text": "Filmde emeğin temsili bilinçli olarak sade ve gösterişsiz görünür."
            }
          ]
        }
      ]
    },
    {
