      "word": "die Replizierbarkeit",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "syllableBreak": "Re-pli-zier-bar-keit",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "Replizierbarkeit sicherstellen",
          "meaning": "to ensure replicability"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "replizieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Replikation",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "قابلية التكرار العلمي"
        },
        {
          "language": "ckb",
          "text": "دووبارەکردنەوەکراوی؛ شیاوی تکرارکردنەوە"
        },
        {
          "language": "en",
          "text": "replicability"
        },
        {
          "language": "fa",
          "text": "تکرارپذیری"
        },
        {
          "language": "kmr",
          "text": "dubarekirinbarî"
        },
        {
          "language": "pl",
          "text": "replikowalność"
        },
        {
          "language": "ro",
          "text": "replicabilitate"
        },
        {
          "language": "ru",
          "text": "воспроизводимость; реплицируемость"
        },
        {
          "language": "sq",
          "text": "replikueshmëri"
        },
        {
          "language": "tr",
          "text": "tekrarlanabilirlik"
        }
      ],
      "examples": [
        {
          "baseText": "Die Replizierbarkeit der Ergebnisse ist fraglich, weil der Datensatz nicht veröffentlicht wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "قابلية تكرار النتائج موضع شك لأن مجموعة البيانات لم تُنشر."
            },
            {
              "language": "ckb",
              "text": "دووبارەکردنەوەکراوی ئەنجامەکان گومانلێکراوە چونکە کۆمەڵە داتاکە بڵاو نەکراوەتەوە."
            },
            {
              "language": "en",
              "text": "The replicability of the results is questionable because the dataset was not published."
            },
            {
              "language": "fa",
              "text": "تکرارپذیری نتایج محل تردید است، چون مجموعه داده منتشر نشده است."
            },
            {
              "language": "kmr",
              "text": "Dubarekirinbariya encaman gumanbar e, ji ber ku koma daneyan nehatiye weşandin."
            },
            {
              "language": "pl",
              "text": "Replikowalność wyników jest wątpliwa, ponieważ zbiór danych nie został opublikowany."
            },
            {
              "language": "ro",
              "text": "Replicabilitatea rezultatelor este discutabilă deoarece setul de date nu a fost publicat."
            },
            {
              "language": "ru",
              "text": "Воспроизводимость результатов сомнительна, потому что набор данных не был опубликован."
            },
            {
              "language": "sq",
              "text": "Replikueshmëria e rezultateve është e dyshimtë sepse grupi i të dhënave nuk u publikua."
            },
            {
              "language": "tr",
              "text": "Veri seti yayımlanmadığı için sonuçların tekrarlanabilirliği tartışmalıdır."
            }
          ]
        },
        {
          "baseText": "Im Entwicklungsteam verbessert eine dokumentierte Testumgebung die Replizierbarkeit von Fehleranalysen.",
          "translations": [
            {
              "language": "ar",
              "text": "في فريق التطوير تحسن بيئة اختبار موثقة قابلية تكرار تحليلات الأخطاء."
            },
            {
              "language": "ckb",
              "text": "لە تیمی پەرەپێداندا ژینگەی تاقیکردنەوەی بەڵگەکراو دووبارەکردنەوەکراوی شیکردنەوەی هەڵەکان باشتر دەکات."
            },
            {
              "language": "en",
              "text": "In the development team, a documented test environment improves the replicability of error analyses."
            },
            {
              "language": "fa",
              "text": "در تیم توسعه، محیط تست مستند تکرارپذیری تحلیل خطاها را بهتر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di tîma pêşxistinê de jîngeha testê ya belgekirî dubarekirinbariya analîzên şaşiyan baştir dike."
            },
            {
              "language": "pl",
              "text": "W zespole deweloperskim udokumentowane środowisko testowe poprawia replikowalność analiz błędów."
            },
            {
              "language": "ro",
              "text": "În echipa de dezvoltare, un mediu de test documentat îmbunătățește replicabilitatea analizelor de erori."
            },
            {
              "language": "ru",
              "text": "В команде разработки документированная тестовая среда повышает воспроизводимость анализа ошибок."
            },
            {
              "language": "sq",
              "text": "Në ekipin e zhvillimit, një mjedis testimi i dokumentuar përmirëson replikueshmërinë e analizave të gabimeve."
            },
            {
              "language": "tr",
              "text": "Geliştirme ekibinde belgelenmiş test ortamı hata analizlerinin tekrarlanabilirliğini artırır."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
