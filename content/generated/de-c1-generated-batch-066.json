  "entries": [
    {
      "word": "klimmen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "klimmen",
      "pronunciationIpa": null,
      "syllableBreak": "klim-men",
      "topics": [
        "everyday-life",
        "transport-and-travel",
        "culture-and-media"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong verb; elevated or literary synonym of steigen/klettern"
      ],
      "collocations": [
        {
          "text": "auf einen Berg klimmen",
          "meaning": "to climb up a mountain"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Klimmzug",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتسلق؛ يصعد بصعوبة"
        },
        {
          "language": "ckb",
          "text": "سەر دەکەوێت؛ بە زەحمەت هەڵدەکشێت"
        },
        {
          "language": "en",
          "text": "to climb; to ascend with effort"
        },
        {
          "language": "fa",
          "text": "بالا رفتن؛ با زحمت صعود کردن"
        },
        {
          "language": "kmr",
          "text": "hilkişîn; bi zehmetî derketin"
        },
        {
          "language": "pl",
          "text": "wspinać się; piąć się"
        },
        {
          "language": "ro",
          "text": "a se cățăra; a urca cu efort"
        },
        {
          "language": "ru",
          "text": "взбираться; подниматься с усилием"
        },
        {
          "language": "sq",
          "text": "të ngjitesh; të hipësh me mundim"
        },
        {
          "language": "tr",
          "text": "tırmanmak; güçlükle yükselmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Rettungskräfte mussten bei Dunkelheit über einen schmalen Steig zum Unfallort klimmen.",
          "translations": [
            {
              "language": "ar",
              "text": "اضطرت فرق الإنقاذ في الظلام إلى التسلق عبر ممر ضيق إلى مكان الحادث."
            },
            {
              "language": "ckb",
              "text": "تیمەکانی فریاکەوتن لە تاریکیدا ناچار بوون بە ڕێڕەوێکی تەنگدا بۆ شوێنی ڕووداوەکە سەر بکەون."
            },
            {
              "language": "en",
              "text": "In the dark, the rescue teams had to climb up a narrow path to the accident site."
            },
            {
              "language": "fa",
              "text": "نیروهای امداد در تاریکی مجبور شدند از یک مسیر باریک به محل حادثه بالا بروند."
            },
            {
              "language": "kmr",
              "text": "Tîmên rizgarkirinê di tarîtiyê de neçar bûn bi rêyek teng ve heta cihê qezayê hilkişin."
            },
            {
              "language": "pl",
              "text": "Ratownicy musieli po ciemku wspiąć się wąską ścieżką na miejsce wypadku."
            },
            {
              "language": "ro",
              "text": "Echipele de salvare au trebuit să urce pe întuneric pe o potecă îngustă până la locul accidentului."
            },
            {
              "language": "ru",
              "text": "Спасателям пришлось в темноте взбираться по узкой тропе к месту аварии."
            },
            {
              "language": "sq",
              "text": "Ekipet e shpëtimit duhej të ngjiteshin në errësirë nëpër një shteg të ngushtë deri te vendi i aksidentit."
            },
            {
              "language": "tr",
              "text": "Kurtarma ekipleri karanlıkta dar bir patikadan kaza yerine tırmanmak zorunda kaldı."
            }
          ]
        },
        {
          "baseText": "Im alten Bericht heißt es, die Preise seien damals langsam, aber stetig nach oben geklommen.",
          "translations": [
            {
              "language": "ar",
              "text": "يذكر التقرير القديم أن الأسعار في ذلك الوقت صعدت ببطء ولكن بثبات."
            },
            {
              "language": "ckb",
              "text": "لە ڕاپۆرتە کۆنەکەدا هاتووە کە نرخەکان ئەوکات بە هێواشی بەڵام بەردەوام بەرەو سەرەوە چوون."
            },
            {
              "language": "en",
              "text": "The old report says that prices climbed slowly but steadily at that time."
            },
            {
              "language": "fa",
              "text": "در گزارش قدیمی آمده است که قیمت‌ها آن زمان آهسته اما پیوسته بالا رفتند."
            },
            {
              "language": "kmr",
              "text": "Di rapora kevn de hatiye nivîsîn ku wê demê biha hêdî lê bi domdarî hilkişiyan."
            },
            {
              "language": "pl",
              "text": "W starym raporcie napisano, że ceny rosły wtedy powoli, ale stale."
            },
            {
              "language": "ro",
              "text": "În vechiul raport se spune că prețurile au urcat atunci încet, dar constant."
            },
            {
              "language": "ru",
              "text": "В старом отчете говорится, что цены тогда медленно, но неуклонно росли."
            },
            {
              "language": "sq",
              "text": "Në raportin e vjetër thuhet se çmimet atëherë u ngjitën ngadalë, por vazhdimisht."
            },
            {
              "language": "tr",
              "text": "Eski raporda fiyatların o dönemde yavaş ama istikrarlı biçimde yükseldiği yazıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "kneifen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "kneifen",
      "pronunciationIpa": null,
      "syllableBreak": "knei-fen",
      "topics": [
        "everyday-life",
        "social-and-relationships",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "weak verb; can mean pinch or avoid something out of fear"
      ],
      "collocations": [
        {
          "text": "vor einer Entscheidung kneifen",
          "meaning": "to back out of making a decision"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Kneifer",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقرص؛ يتهرب جبناً"
        },
        {
          "language": "ckb",
          "text": "پینچ دەکات؛ لە ترسدا خۆی لێ دەدزێتەوە"
        },
        {
          "language": "en",
          "text": "to pinch; to back out"
        },
        {
          "language": "fa",
          "text": "نیشگون گرفتن؛ جا زدن"
        },
        {
          "language": "kmr",
          "text": "pinç kirin; paşve kişandin"
        },
        {
          "language": "pl",
          "text": "szczypać; wycofywać się ze strachu"
        },
        {
          "language": "ro",
          "text": "a ciupi; a da înapoi"
        },
        {
          "language": "ru",
          "text": "щипать; струсить и отказаться"
        },
        {
          "language": "sq",
          "text": "të pickosh; të tërhiqesh nga frika"
        },
        {
          "language": "tr",
          "text": "çimdiklemek; korkup vazgeçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Kurz vor der Vertragsunterzeichnung durfte das Management nicht kneifen.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل توقيع العقد بقليل لم يكن مسموحاً للإدارة أن تتراجع خوفاً."
            },
            {
              "language": "ckb",
              "text": "کەمێک پێش واژۆکردنی گرێبەستەکە بەڕێوەبەرایەتی نەدەبوو خۆی لێ بدزێتەوە."
            },
            {
              "language": "en",
              "text": "Shortly before signing the contract, management could not afford to back out."
            },
            {
              "language": "fa",
              "text": "کمی پیش از امضای قرارداد، مدیریت نباید جا می‌زد."
            },
            {
              "language": "kmr",
              "text": "Demek kurt berî îmzekirina peymanê rêveberî nikaribû paşve bikeve."
            },
            {
              "language": "pl",
              "text": "Krótko przed podpisaniem umowy zarząd nie mógł się wycofać."
            },
            {
              "language": "ro",
              "text": "Cu puțin înainte de semnarea contractului, conducerea nu își putea permite să dea înapoi."
            },
            {
              "language": "ru",
              "text": "Незадолго до подписания договора руководство не могло струсить и отказаться."
            },
            {
              "language": "sq",
              "text": "Pak para nënshkrimit të kontratës, menaxhmenti nuk mund të tërhiqej."
            },
            {
              "language": "tr",
              "text": "Sözleşmenin imzalanmasından kısa süre önce yönetim geri adım atamazdı."
            }
          ]
        },
        {
          "baseText": "Das neue Hemd kneift am Kragen, deshalb trage ich es nicht den ganzen Tag.",
          "translations": [
            {
              "language": "ar",
              "text": "القميص الجديد يضغط عند الياقة، لذلك لا أرتديه طوال اليوم."
            },
            {
              "language": "ckb",
              "text": "کراسە نوێیەکە لە ملی پینچ دەکات، بۆیە تەواوی ڕۆژ نایپۆشم."
            },
            {
              "language": "en",
              "text": "The new shirt pinches at the collar, so I do not wear it all day."
            },
            {
              "language": "fa",
              "text": "پیراهن جدید دور یقه اذیت می‌کند، برای همین تمام روز آن را نمی‌پوشم."
            },
            {
              "language": "kmr",
              "text": "Kirasê nû li stûyê min teng dike, ji ber vê yekê ez tevahiya rojê wî napoşim."
            },
            {
              "language": "pl",
              "text": "Nowa koszula uwiera przy kołnierzu, dlatego nie noszę jej przez cały dzień."
            },
            {
              "language": "ro",
              "text": "Cămașa nouă mă strânge la guler, de aceea nu o port toată ziua."
            },
            {
              "language": "ru",
              "text": "Новая рубашка жмет у воротника, поэтому я не ношу ее весь день."
            },
            {
              "language": "sq",
              "text": "Këmisha e re më shtrëngon te jaka, prandaj nuk e vesh gjithë ditën."
            },
            {
              "language": "tr",
              "text": "Yeni gömlek yakadan sıkıyor, bu yüzden onu bütün gün giymiyorum."
            }
          ]
        }
      ]
    },
