  "entries": [
    {
      "word": "die Ansprechpartnerin",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Ansprechpartnerinnen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "An-sprech-part-ne-rin",
      "topics": [
        "work-and-jobs",
        "customer-service",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "formal",
        "spoken"
      ],
      "contextLabels": [
        "customer-service",
        "support",
        "management"
      ],
      "grammarNotes": [
        "feminine noun",
        "female contact person for questions or a specific topic"
      ],
      "collocations": [
        {
          "text": "die richtige Ansprechpartnerin",
          "meaning": "the right female contact person"
        },
        {
          "text": "Ansprechpartnerin für Rückfragen",
          "meaning": "contact person for follow-up questions"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Ansprechpartner",
          "relationLabel": "masculine form",
          "note": null
        },
        {
          "lemma": "die Ansprechperson",
          "relationLabel": "gender-neutral form",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مسؤولة التواصل؛ جهة الاتصال"
        },
        {
          "language": "ckb",
          "text": "کەسی پەیوەندیی ژن؛ بەرپرسی پەیوەندی"
        },
        {
          "language": "en",
          "text": "female contact person"
        },
        {
          "language": "fa",
          "text": "مسئول تماس زن؛ فرد پاسخگوی زن"
        },
        {
          "language": "kmr",
          "text": "jina têkiliyê; berpirsê pirsan"
        },
        {
          "language": "pl",
          "text": "osoba kontaktowa; kierowniczka kontaktu"
        },
        {
          "language": "ro",
          "text": "persoană de contact feminină"
        },
        {
          "language": "ru",
          "text": "контактное лицо; ответственная сотрудница"
        },
        {
          "language": "sq",
          "text": "person kontakti femër"
        },
        {
          "language": "tr",
          "text": "kadın iletişim kişisi"
        }
      ],
      "examples": [
        {
          "baseText": "Frau Keller ist Ihre Ansprechpartnerin für alle Fragen zur Rechnung.",
          "translations": [
            {
              "language": "ar",
              "text": "السيدة كيلر هي جهة الاتصال الخاصة بكم لكل الأسئلة المتعلقة بالفاتورة."
            },
            {
              "language": "ckb",
              "text": "خانم کێلەڕ کەسی پەیوەندیتانە بۆ هەموو پرسیارەکانی پەیوەست بە فاکتور."
            },
            {
              "language": "en",
              "text": "Ms. Keller is your contact person for all questions about the invoice."
            },
            {
              "language": "fa",
              "text": "خانم کلر مسئول تماس شما برای همه سؤالات مربوط به فاکتور است."
            },
            {
              "language": "kmr",
              "text": "Xanim Keller ji bo hemû pirsên derbarê fatûreyê de kesê têkiliya we ye."
            },
            {
              "language": "pl",
              "text": "Pani Keller jest Państwa osobą kontaktową we wszystkich pytaniach dotyczących faktury."
            },
            {
              "language": "ro",
              "text": "Doamna Keller este persoana dumneavoastră de contact pentru toate întrebările despre factură."
            },
            {
              "language": "ru",
              "text": "Госпожа Келлер является вашим контактным лицом по всем вопросам о счёте."
            },
            {
              "language": "sq",
              "text": "Zonja Keller është personi juaj i kontaktit për të gjitha pyetjet rreth faturës."
            },
            {
              "language": "tr",
              "text": "Faturayla ilgili tüm sorularınız için iletişim kişiniz Bayan Keller’dir."
            }
          ]
        },
        {
          "baseText": "Bei Problemen mit der Kita ist die Leiterin unsere erste Ansprechpartnerin.",
          "translations": [
            {
              "language": "ar",
              "text": "عند وجود مشاكل في الروضة تكون المديرة أول جهة نتواصل معها."
            },
            {
              "language": "ckb",
              "text": "لە کاتی کێشە لە باخچەی منداڵاندا، بەڕێوەبەرەکە یەکەم کەسی پەیوەندیمانە."
            },
            {
              "language": "en",
              "text": "If there are problems with the daycare, the manager is our first contact person."
            },
            {
              "language": "fa",
              "text": "در صورت بروز مشکل با مهدکودک، مدیر اولین فردی است که با او تماس می‌گیریم."
            },
            {
              "language": "kmr",
              "text": "Heke pirsgirêk bi baxçeya zarokan re hebe, rêveber yekem kesê têkiliya me ye."
            },
            {
              "language": "pl",
              "text": "W razie problemów z przedszkolem kierowniczka jest naszą pierwszą osobą kontaktową."
            },
            {
              "language": "ro",
              "text": "În caz de probleme cu grădinița, directoarea este prima noastră persoană de contact."
            },
            {
              "language": "ru",
              "text": "При проблемах с детским садом заведующая является нашим первым контактным лицом."
            },
            {
              "language": "sq",
              "text": "Në rast problemesh me kopshtin, drejtuesja është personi ynë i parë i kontaktit."
            },
            {
              "language": "tr",
