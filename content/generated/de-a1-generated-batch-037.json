          "baseText": "Darf ich etwas fragen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني أن أسأل شيئاً؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم شتێک بپرسم؟"
