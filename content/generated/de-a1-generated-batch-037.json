            },
            {
              "language": "tr",
              "text": "Bir şey sorabilir miyim?"
            }
          ]
        },
        {
          "baseText": "Bitte fragen Sie am Eingang.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى السؤال عند المدخل."
            },
            {
              "language": "ckb",
              "text": "تکایە لە دەرگای چوونەژوورەوە بپرسن."
            },
            {
              "language": "en",
              "text": "Please ask at the entrance."
            },
            {
              "language": "fa",
              "text": "لطفاً کنار ورودی بپرسید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li ber deriyê ketinê bipirsin."
            },
            {
              "language": "pl",
              "text": "Proszę zapytać przy wejściu."
            },
            {
              "language": "ro",
              "text": "Vă rog să întrebați la intrare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, спросите у входа."
            },
            {
              "language": "sq",
              "text": "Ju lutem pyesni te hyrja."
            },
            {
              "language": "tr",
              "text": "Lütfen girişte sorun."
            }
