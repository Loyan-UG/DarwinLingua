  "entries": [
    {
      "word": "betroffen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "be-trof-fen",
      "topics": [
        "business-communication",
        "public-services",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "written"
      ],
      "contextLabels": [
        "administration",
        "customer-service",
        "support"
      ],
      "grammarNotes": [
        "adjective; often used with von + dative"
      ],
      "collocations": [
        {
          "text": "von einer Änderung betroffen sein",
          "meaning": "to be affected by a change"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "betreffen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "متأثر؛ معنيّ"
        },
        {
          "language": "ckb",
          "text": "کاریگەرلێکراو؛ پەیوەندیدار"
        },
        {
          "language": "en",
          "text": "affected; concerned"
        },
        {
          "language": "fa",
          "text": "تحت تأثیر؛ درگیر"
        },
        {
          "language": "kmr",
          "text": "bandor lê bûyî; têkildar"
        },
        {
          "language": "pl",
          "text": "dotknięty; zainteresowany"
        },
        {
          "language": "ro",
          "text": "afectat; vizat"
        },
        {
          "language": "ru",
          "text": "затронутый; пострадавший"
        },
        {
          "language": "sq",
          "text": "i prekur; i përfshirë"
        },
        {
          "language": "tr",
          "text": "etkilenen; ilgili"
        }
      ],
      "examples": [
        {
          "baseText": "Von der Störung sind nur wenige Kunden betroffen.",
          "translations": [
            {
              "language": "ar",
              "text": "تأثر عدد قليل فقط من العملاء بالعطل."
            },
            {
              "language": "ckb",
              "text": "تەنها ژمارەیەکی کەم لە کڕیاران بە کێشەکە کاریگەر بوون."
            },
            {
              "language": "en",
              "text": "Only a few customers are affected by the outage."
            },
            {
              "language": "fa",
              "text": "فقط تعداد کمی از مشتریان تحت تأثیر اختلال قرار گرفته‌اند."
            },
            {
              "language": "kmr",
              "text": "Tenê çend xerîdar ji vê astengiyê bandor dîtine."
            },
            {
              "language": "pl",
              "text": "Awarią dotkniętych jest tylko kilku klientów."
            },
            {
              "language": "ro",
              "text": "Doar câțiva clienți sunt afectați de defecțiune."
            },
            {
              "language": "ru",
              "text": "Сбоем затронуто лишь несколько клиентов."
            },
            {
              "language": "sq",
              "text": "Vetëm pak klientë janë prekur nga ndërprerja."
            },
            {
              "language": "tr",
              "text": "Kesintiden sadece birkaç müşteri etkilendi."
            }
          ]
        },
        {
          "baseText": "Die betroffenen Mitarbeiter bekommen heute noch eine E-Mail.",
          "translations": [
            {
              "language": "ar",
              "text": "سيتلقى الموظفون المعنيون رسالة إلكترونية اليوم."
            },
            {
              "language": "ckb",
              "text": "کارمەندە پەیوەندیدارەکان ئەمڕۆ ئیمەیڵێک وەردەگرن."
            },
            {
              "language": "en",
              "text": "The affected employees will receive an email today."
            },
            {
              "language": "fa",
              "text": "کارکنان درگیر امروز یک ایمیل دریافت می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Karmendên bandor lê bûyî dê îro e-nameyekê bistînin."
            },
            {
              "language": "pl",
              "text": "Zainteresowani pracownicy otrzymają dziś jeszcze e-mail."
            },
            {
              "language": "ro",
              "text": "Angajații afectați vor primi astăzi un e-mail."
            },
            {
              "language": "ru",
              "text": "Затронутые сотрудники сегодня получат письмо."
            },
            {
              "language": "sq",
              "text": "Punonjësit e prekur do të marrin një email sot."
            },
            {
              "language": "tr",
              "text": "Etkilenen çalışanlar bugün bir e-posta alacak."
            }
          ]
        }
      ]
    },
    {
      "word": "betrügen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "betrügen",
      "pronunciationIpa": null,
      "syllableBreak": "be-trü-gen",
      "topics": [
        "law-and-compliance",
        "shopping-and-services",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "formal"
      ],
      "contextLabels": [
        "compliance",
        "customer-service"
      ],
      "grammarNotes": [
        "strong verb: betrügt, betrog, hat betrogen"
      ],
      "collocations": [
        {
          "text": "einen Kunden betrügen",
          "meaning": "to cheat a customer"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Betrug",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يخدع؛ يحتال على"
        },
        {
          "language": "ckb",
          "text": "فریودان؛ ساختەکاری کردن لەگەڵ"
        },
        {
          "language": "en",
          "text": "to cheat; to deceive; to defraud"
        },
        {
          "language": "fa",
          "text": "فریب دادن؛ کلاهبرداری کردن"
        },
        {
          "language": "kmr",
          "text": "xapandin; sextekari kirin"
        },
        {
          "language": "pl",
          "text": "oszukać; zdradzić"
        },
        {
          "language": "ro",
          "text": "a înșela; a frauda"
        },
        {
          "language": "ru",
          "text": "обманывать; мошенничать"
        },
        {
          "language": "sq",
          "text": "të mashtrosh; të tradhtosh"
        },
        {
          "language": "tr",
          "text": "aldatmak; dolandırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Firma darf Kunden nicht mit falschen Preisen betrügen.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يجوز للشركة خداع العملاء بأسعار خاطئة."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیا نابێت بە نرخی هەڵە کڕیاران بفریوێنێت."
            },
            {
              "language": "en",
              "text": "The company must not deceive customers with false prices."
            },
            {
              "language": "fa",
              "text": "شرکت نباید مشتریان را با قیمت‌های نادرست فریب دهد."
            },
            {
              "language": "kmr",
              "text": "Şirket nabe bi bihayên şaş xerîdaran bixapîne."
            },
            {
              "language": "pl",
              "text": "Firma nie może oszukiwać klientów fałszywymi cenami."
            },
            {
              "language": "ro",
              "text": "Firma nu are voie să înșele clienții cu prețuri false."
            },
            {
              "language": "ru",
              "text": "Компания не должна обманывать клиентов неверными ценами."
            },
            {
              "language": "sq",
              "text": "Kompania nuk duhet t’i mashtrojë klientët me çmime të rreme."
            },
            {
              "language": "tr",
              "text": "Şirket müşterileri yanlış fiyatlarla aldatmamalıdır."
            }
          ]
        },
        {
          "baseText": "Er fühlte sich betrogen, weil die Wohnung ganz anders aussah.",
          "translations": [
            {
              "language": "ar",
              "text": "شعر أنه خُدع لأن الشقة بدت مختلفة تمامًا."
            },
            {
              "language": "ckb",
              "text": "هەستی کرد فریودراوە، چونکە خانووبەرەکە تەواو جیاواز دەرکەوت."
            },
            {
              "language": "en",
              "text": "He felt cheated because the apartment looked completely different."
            },
            {
              "language": "fa",
              "text": "او احساس کرد فریب خورده، چون آپارتمان کاملاً متفاوت به نظر می‌رسید."
            },
            {
              "language": "kmr",
              "text": "Wî hest kir ku hatiye xapandin, ji ber ku apartman bi tevahî cuda xuya dikir."
            },
            {
              "language": "pl",
              "text": "Czuł się oszukany, bo mieszkanie wyglądało zupełnie inaczej."
            },
            {
              "language": "ro",
              "text": "S-a simțit înșelat, deoarece apartamentul arăta complet diferit."
            },
            {
              "language": "ru",
              "text": "Он почувствовал себя обманутым, потому что квартира выглядела совсем иначе."
            },
            {
              "language": "sq",
              "text": "Ai u ndje i mashtruar sepse banesa dukej krejt ndryshe."
            },
            {
              "language": "tr",
              "text": "Daire tamamen farklı göründüğü için kendini aldatılmış hissetti."
            }
          ]
        }
      ]
    },
