  "entries": [
    {
      "word": "die Referenz",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Referenzen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Re-fe-renz",
      "topics": [
        "work-and-jobs",
        "business-communication",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "workplace"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "Referenzen angeben",
          "meaning": "to provide references"
        },
        {
          "text": "eine gute Referenz",
          "meaning": "a good reference"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "referenzieren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "das Referenzschreiben",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مرجع؛ توصية؛ جهة مرجعية"
        },
        {
          "language": "ckb",
          "text": "سەرچاوە؛ ڕەفەرەنس؛ پێشنیاری کار"
        },
        {
          "language": "en",
          "text": "reference; recommendation"
        },
        {
          "language": "fa",
          "text": "معرف؛ مرجع؛ توصیه‌نامه/سابقه قابل استناد"
        },
        {
          "language": "kmr",
          "text": "referans; pêşniyar"
        },
        {
          "language": "pl",
          "text": "referencja; rekomendacja"
        },
        {
          "language": "ro",
          "text": "referință; recomandare"
        },
        {
          "language": "ru",
          "text": "рекомендация; ссылка; референция"
        },
        {
          "language": "sq",
          "text": "referencë; rekomandim"
        },
        {
          "language": "tr",
          "text": "referans; tavsiye"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte geben Sie in der Bewerbung zwei Referenzen an.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى ذكر مرجعين في طلب التقديم."
            },
            {
              "language": "ckb",
              "text": "تکایە لە داواکاریی کاردا دوو ڕەفەرەنس بنووسن."
            },
            {
              "language": "en",
              "text": "Please provide two references in the application."
            },
            {
              "language": "fa",
              "text": "لطفاً در درخواست کار دو معرف ذکر کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe di serlêdanê de du referans binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę podać w aplikacji dwie referencje."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să indicați două referințe în candidatură."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, укажите в заявке две рекомендации."
            },
            {
              "language": "sq",
              "text": "Ju lutem jepni dy referenca në aplikim."
            },
            {
              "language": "tr",
              "text": "Başvuruda lütfen iki referans belirtin."
            }
          ]
        },
        {
          "baseText": "Das abgeschlossene Projekt ist eine gute Referenz für neue Kunden.",
          "translations": [
            {
              "language": "ar",
              "text": "المشروع المنجز مرجع جيد للعملاء الجدد."
            },
            {
              "language": "ckb",
              "text": "پڕۆژە تەواوکراوەکە ڕەفەرەنسێکی باشە بۆ کڕیارانی نوێ."
            },
            {
              "language": "en",
              "text": "The completed project is a good reference for new customers."
            },
            {
              "language": "fa",
              "text": "پروژه تکمیل‌شده مرجع خوبی برای مشتریان جدید است."
            },
            {
              "language": "kmr",
              "text": "Projeya qediyayî ji bo mişteriyên nû referanseke baş e."
            },
            {
              "language": "pl",
              "text": "Zakończony projekt jest dobrą referencją dla nowych klientów."
            },
            {
              "language": "ro",
              "text": "Proiectul finalizat este o referință bună pentru clienți noi."
            },
            {
              "language": "ru",
              "text": "Завершённый проект является хорошей рекомендацией для новых клиентов."
            },
            {
              "language": "sq",
              "text": "Projekti i përfunduar është një referencë e mirë për klientë të rinj."
            },
            {
              "language": "tr",
              "text": "Tamamlanan proje yeni müşteriler için iyi bir referanstır."
            }
          ]
        }
      ]
    },
    {
      "word": "die Regel",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Regeln",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Re-gel",
      "topics": [
        "law-and-compliance",
        "work-and-jobs",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Regel beachten",
          "meaning": "to follow a rule"
        },
        {
          "text": "klare Regeln",
          "meaning": "clear rules"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "regeln",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "regelmäßig",
          "relationLabel": "adjective/adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قاعدة؛ نظام"
        },
        {
          "language": "ckb",
          "text": "یاسا؛ ڕێسا"
        },
        {
          "language": "en",
          "text": "rule; regulation"
        },
        {
          "language": "fa",
          "text": "قانون؛ قاعده"
        },
        {
          "language": "kmr",
          "text": "qaîde; rêzik"
        },
        {
          "language": "pl",
          "text": "zasada; reguła"
        },
        {
          "language": "ro",
          "text": "regulă"
        },
        {
          "language": "ru",
          "text": "правило; норма"
        },
        {
          "language": "sq",
          "text": "rregull"
        },
        {
          "language": "tr",
          "text": "kural"
        }
      ],
      "examples": [
        {
          "baseText": "Im Büro gilt die Regel, dass vertrauliche Dokumente nicht offen liegen dürfen.",
          "translations": [
            {
              "language": "ar",
              "text": "في المكتب تسري قاعدة أن المستندات السرية لا يجوز أن تبقى مكشوفة."
            },
            {
              "language": "ckb",
              "text": "لە ئۆفیسدا ئەو ڕێسایە هەیە کە نابێت بەڵگەنامە نهێنییەکان بە کراوەیی بمێننەوە."
            },
            {
              "language": "en",
              "text": "In the office, the rule is that confidential documents must not be left out openly."
            },
            {
              "language": "fa",
              "text": "در دفتر این قانون وجود دارد که مدارک محرمانه نباید باز روی میز بمانند."
            },
            {
              "language": "kmr",
              "text": "Li ofîsê ev qaîde heye ku belgeyên nepenî divê vekirî nemînin."
            },
            {
              "language": "pl",
              "text": "W biurze obowiązuje zasada, że poufne dokumenty nie mogą leżeć na wierzchu."
            },
            {
              "language": "ro",
              "text": "La birou există regula ca documentele confidențiale să nu fie lăsate la vedere."
            },
            {
              "language": "ru",
              "text": "В офисе действует правило, что конфиденциальные документы нельзя оставлять открыто."
            },
            {
              "language": "sq",
              "text": "Në zyrë vlen rregulli që dokumentet konfidenciale nuk duhet të lihen hapur."
            },
            {
              "language": "tr",
              "text": "Ofiste gizli belgelerin açıkta bırakılmaması kuralı geçerlidir."
            }
          ]
        },
        {
          "baseText": "Die Lehrerin erklärt die neue Regel mit einem Beispiel.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح المعلمة القاعدة الجديدة بمثال."
            },
            {
              "language": "ckb",
              "text": "مامۆستاکە ڕێسای نوێ بە نموونەیەک ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The teacher explains the new rule with an example."
            },
            {
              "language": "fa",
              "text": "معلم قانون جدید را با یک مثال توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Mamoste qaîdeya nû bi mînakekê rave dike."
            },
            {
              "language": "pl",
              "text": "Nauczycielka wyjaśnia nową zasadę przykładem."
            },
            {
              "language": "ro",
              "text": "Profesoara explică noua regulă cu un exemplu."
            },
            {
              "language": "ru",
              "text": "Учительница объясняет новое правило на примере."
            },
            {
              "language": "sq",
              "text": "Mësuesja e shpjegon rregullin e ri me një shembull."
            },
            {
              "language": "tr",
              "text": "Öğretmen yeni kuralı bir örnekle açıklıyor."
            }
          ]
        }
      ]
    },
