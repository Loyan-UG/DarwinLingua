  "entries": [
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "entkommen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entkommen",
      "syllableBreak": "ent-kom-men",
      "topics": [
        "quality-and-risk",
        "everyday-life",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "spoken"
      ],
      "contextLabels": [
        "risk"
      ],
      "grammarNotes": [
        "inseparable verb; often with dative: einer Gefahr entkommen"
      ],
      "collocations": [
        {
          "text": "einer Gefahr entkommen",
          "meaning": "to escape a danger"
        },
        {
          "text": "knapp entkommen",
          "meaning": "to narrowly escape"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kommen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ينجو؛ يفلت"
        },
        {
          "language": "ckb",
          "text": "دەرباز دەبێت؛ ڕزگاری دەبێت"
        },
        {
          "language": "en",
          "text": "to escape; to get away"
        },
        {
          "language": "fa",
          "text": "فرار کردن؛ جان سالم به در بردن"
        },
        {
          "language": "kmr",
          "text": "xilas bûn; revîn"
        },
        {
          "language": "pl",
          "text": "uciec; uniknąć"
        },
        {
          "language": "ro",
          "text": "a scăpa; a evada"
        },
        {
          "language": "ru",
          "text": "спастись; сбежать"
        },
        {
          "language": "sq",
          "text": "të shpëtosh; të ikësh"
        },
        {
          "language": "tr",
          "text": "kaçmak; kurtulmak"
        }
      ],
      "examples": [
        {
          "baseText": "Durch die schnelle Reaktion des Teams konnte das Projekt einem größeren Schaden entkommen.",
          "translations": [
            {
              "language": "ar",
              "text": "بفضل رد الفعل السريع للفريق تمكن المشروع من تجنب ضرر أكبر."
            },
            {
              "language": "ckb",
              "text": "بەهۆی کاردانەوەی خێرای تیمەکەوە پرۆژەکە لە زیانێکی گەورەتر دەرباز بوو."
            },
            {
              "language": "en",
              "text": "Thanks to the team’s quick response, the project avoided more serious damage."
            },
            {
              "language": "fa",
              "text": "به‌خاطر واکنش سریع تیم، پروژه از آسیب بزرگ‌تر نجات پیدا کرد."
            },
            {
              "language": "kmr",
              "text": "Bi bersiva lezgîn a tîmê, proje ji zirareke mezintir xilas bû."
            },
            {
              "language": "pl",
              "text": "Dzięki szybkiej reakcji zespołu projekt uniknął większych szkód."
            },
            {
              "language": "ro",
              "text": "Datorită reacției rapide a echipei, proiectul a scăpat de daune mai mari."
            },
            {
              "language": "ru",
              "text": "Благодаря быстрой реакции команды проект избежал более серьезного ущерба."
            },
            {
              "language": "sq",
              "text": "Falë reagimit të shpejtë të ekipit, projekti shpëtoi nga një dëm më i madh."
            },
            {
              "language": "tr",
              "text": "Ekibin hızlı tepkisi sayesinde proje daha büyük bir zarardan kurtuldu."
            }
          ]
        },
        {
          "baseText": "Die Wanderer sind dem Gewitter nur knapp entkommen.",
          "translations": [
            {
              "language": "ar",
              "text": "نجا المتنزهون من العاصفة الرعدية بالكاد."
            },
            {
              "language": "ckb",
              "text": "گەشتیارەکان بە زەحمەت لە هەورەتریشقەکە دەرباز بوون."
            },
            {
              "language": "en",
              "text": "The hikers narrowly escaped the thunderstorm."
            },
            {
              "language": "fa",
              "text": "کوهنوردان به‌سختی از طوفان رعدوبرق جان سالم به در بردند."
            },
            {
              "language": "kmr",
              "text": "Gerok bi zor ji bahoza birûskê xilas bûn."
            },
            {
              "language": "pl",
              "text": "Wędrowcy ledwo uniknęli burzy."
            },
            {
              "language": "ro",
              "text": "Drumeții au scăpat la limită de furtună."
            },
            {
              "language": "ru",
              "text": "Туристы едва спаслись от грозы."
            },
            {
              "language": "sq",
              "text": "Alpinistët mezi i shpëtuan stuhisë."
            },
            {
              "language": "tr",
              "text": "Yürüyüşçüler fırtınadan kıl payı kurtuldu."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "die Entlastung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Entlastungen",
      "infinitive": null,
      "syllableBreak": "Ent-las-tung",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "business",
        "formal"
      ],
      "contextLabels": [
        "management",
        "finance"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Entlastung für das Team",
          "meaning": "relief for the team"
        },
        {
          "text": "steuerliche Entlastung",
          "meaning": "tax relief"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "entlasten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تخفيف؛ إعفاء؛ راحة"
        },
        {
          "language": "ckb",
          "text": "سووککردنەوە؛ کەمکردنەوەی بار"
        },
        {
          "language": "en",
          "text": "relief; easing of burden"
        },
        {
          "language": "fa",
          "text": "کاهش فشار؛ سبک‌سازی بار"
        },
        {
          "language": "kmr",
          "text": "sivik kirin; kêmkirina barê"
        },
        {
          "language": "pl",
          "text": "odciążenie; ulga"
        },
        {
          "language": "ro",
          "text": "ușurare; degrevare"
        },
        {
          "language": "ru",
          "text": "разгрузка; облегчение"
        },
        {
          "language": "sq",
          "text": "lehtësim; shkarkim barre"
        },
        {
          "language": "tr",
          "text": "rahatlama; yükün azaltılması"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Schichtplanung bringt eine spürbare Entlastung für den Kundenservice.",
          "translations": [
            {
              "language": "ar",
              "text": "يجلب تخطيط الورديات الجديد تخفيفًا ملموسًا لخدمة العملاء."
            },
            {
              "language": "ckb",
              "text": "پلانی نوێی شفتەکان سووککردنەوەیەکی هەستپێکراو بۆ خزمەتی کڕیار دەهێنێت."
            },
            {
              "language": "en",
              "text": "The new shift planning brings noticeable relief for customer service."
            },
            {
              "language": "fa",
              "text": "برنامه‌ریزی جدید شیفت‌ها فشار خدمات مشتریان را به‌طور محسوسی کم می‌کند."
            },
            {
              "language": "kmr",
              "text": "Plansaziya nû ya şiftan sivikbûneke xuya ji bo xizmeta xerîdar tîne."
            },
            {
              "language": "pl",
              "text": "Nowe planowanie zmian przynosi wyraźne odciążenie dla obsługi klienta."
            },
            {
              "language": "ro",
              "text": "Noua planificare a turelor aduce o degrevare vizibilă pentru serviciul clienți."
            },
            {
              "language": "ru",
              "text": "Новое планирование смен заметно разгружает службу поддержки клиентов."
            },
            {
              "language": "sq",
              "text": "Planifikimi i ri i turneve sjell lehtësim të dukshëm për shërbimin ndaj klientit."
            },
            {
              "language": "tr",
              "text": "Yeni vardiya planlaması müşteri hizmetleri için belirgin bir rahatlama sağlıyor."
            }
          ]
        },
        {
          "baseText": "Viele Familien hoffen auf eine Entlastung bei den Energiekosten.",
          "translations": [
            {
              "language": "ar",
              "text": "تأمل عائلات كثيرة في تخفيف تكاليف الطاقة."
            },
            {
              "language": "ckb",
              "text": "زۆر خێزان هیوادارن تێچووی وزەیان سووک بکرێتەوە."
            },
            {
              "language": "en",
              "text": "Many families hope for relief with energy costs."
            },
            {
              "language": "fa",
              "text": "بسیاری از خانواده‌ها امیدوارند هزینه‌های انرژی کاهش پیدا کند."
            },
            {
              "language": "kmr",
              "text": "Gelek malbat hêvî dikin ku lêçûnên enerjiyê sivik bibin."
            },
            {
              "language": "pl",
              "text": "Wiele rodzin liczy na ulgę w kosztach energii."
            },
            {
              "language": "ro",
              "text": "Multe familii speră la o reducere a costurilor cu energia."
            },
            {
              "language": "ru",
              "text": "Многие семьи надеются на облегчение расходов на энергию."
            },
            {
              "language": "sq",
              "text": "Shumë familje shpresojnë për lehtësim në kostot e energjisë."
            },
            {
              "language": "tr",
              "text": "Birçok aile enerji maliyetlerinde rahatlama umuyor."
            }
          ]
        }
      ]
    },
