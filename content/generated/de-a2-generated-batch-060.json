            {
              "language": "ar",
              "text": "نبحث عن الطريق على الخريطة."
            },
            {
              "language": "ckb",
              "text": "ڕێگاکە لەسەر نەخشەکە دەگەڕێین."
            },
            {
              "language": "en",
              "text": "We look for the way on the map."
            },
            {
              "language": "fa",
              "text": "راه را روی نقشه پیدا می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em rêyê li ser nexşeyê digerin."
            },
            {
              "language": "pl",
              "text": "Szukamy drogi na mapie."
            },
            {
              "language": "ro",
              "text": "Căutăm drumul pe hartă."
            },
            {
              "language": "ru",
              "text": "Мы ищем дорогу на карте."
            },
            {
              "language": "sq",
              "text": "E kërkojmë rrugën në hartë."
            },
            {
              "language": "tr",
              "text": "Yolu haritada arıyoruz."
            }
          ]
        },
        {
          "baseText": "Die Landkarte liegt im Auto.",
          "translations": [
