      ],
      "examples": [
        {
          "baseText": "Ich laufe jeden Morgen zum Bahnhof.",
          "translations": [
            {
              "language": "ar",
              "text": "أمشي كل صباح إلى المحطة."
            },
            {
              "language": "ckb",
              "text": "هەموو بەیانییەک دەڕۆم بۆ وێستگە."
            },
            {
              "language": "en",
              "text": "I walk to the station every morning."
            },
            {
              "language": "fa",
              "text": "هر صبح تا ایستگاه پیاده می‌روم."
            },
            {
              "language": "kmr",
              "text": "Ez her sibeh dimeşim stasyonê."
            },
            {
              "language": "pl",
              "text": "Każdego ranka idę pieszo na dworzec."
            },
            {
              "language": "ro",
              "text": "Merg pe jos la gară în fiecare dimineață."
            },
            {
              "language": "ru",
              "text": "Каждое утро я иду пешком на вокзал."
            },
            {
              "language": "sq",
              "text": "Çdo mëngjes eci për në stacion."
            },
            {
              "language": "tr",
              "text": "Her sabah istasyona yürürüm."
            }
          ]
        },
        {
          "baseText": "Das Kind kann schon schnell laufen.",
          "translations": [
            {
              "language": "ar",
              "text": "الطفل يستطيع بالفعل الركض بسرعة."
            },
            {
              "language": "ckb",
              "text": "منداڵەکە ئێستا دەتوانێت خێرا بڕوات/ڕابکات."
            },
            {
              "language": "en",
              "text": "The child can already run fast."
            },
            {
              "language": "fa",
              "text": "کودک الان می‌تواند سریع بدود."
            },
            {
              "language": "kmr",
              "text": "Zarok êdî dikare zû bibeze."
            },
            {
              "language": "pl",
              "text": "Dziecko umie już szybko biegać."
            },
            {
              "language": "ro",
              "text": "Copilul poate deja să alerge repede."
            },
            {
              "language": "ru",
              "text": "Ребёнок уже может быстро бегать."
            },
            {
              "language": "sq",
              "text": "Fëmija tashmë mund të vrapojë shpejt."
            },
            {
              "language": "tr",
              "text": "Çocuk artık hızlı koşabiliyor."
            }
          ]
        }
