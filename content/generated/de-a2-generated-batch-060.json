      "examples": [
        {
          "baseText": "Bitte schicken Sie uns Ihren Lebenslauf.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال سيرتك الذاتية إلينا."
            },
            {
              "language": "ckb",
              "text": "تکایە ژیاننامەکەتان بۆ ئێمە بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us your CV."
            },
            {
              "language": "fa",
              "text": "لطفاً رزومه خود را برای ما بفرستید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe CV-ya xwe ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę przesłać nam swoje CV."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți CV-ul dumneavoastră."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, пришлите нам ваше резюме."
            },
            {
              "language": "sq",
              "text": "Ju lutemi na dërgoni CV-në tuaj."
            },
            {
              "language": "tr",
              "text": "Lütfen özgeçmişinizi bize gönderin."
            }
          ]
        },
        {
          "baseText": "Ich aktualisiere meinen Lebenslauf heute Abend.",
          "translations": [
            {
              "language": "ar",
              "text": "أحدث سيرتي الذاتية هذا المساء."
            },
            {
              "language": "ckb",
              "text": "ئەم ئێوارە ژیاننامەکەم نوێ دەکەمەوە."
            },
            {
              "language": "en",
              "text": "I am updating my CV this evening."
            },
            {
              "language": "fa",
              "text": "امشب رزومه‌ام را به‌روزرسانی می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez îvarê CV-ya xwe nû dikim."
            },
            {
              "language": "pl",
              "text": "Dziś wieczorem aktualizuję swoje CV."
            },
            {
              "language": "ro",
              "text": "În seara aceasta îmi actualizez CV-ul."
            },
            {
              "language": "ru",
              "text": "Сегодня вечером я обновляю своё резюме."
            },
            {
              "language": "sq",
              "text": "Sonte e përditësoj CV-në time."
            },
            {
              "language": "tr",
              "text": "Bu akşam özgeçmişimi güncelliyorum."
