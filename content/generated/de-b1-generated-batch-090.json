  "entries": [
    {
      "word": "die Mahnung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Mahnungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Mah-nung",
      "topics": [
        "finance-and-accounting",
        "documents-and-administration",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; written reminder to pay or act"
      ],
      "collocations": [
        {
          "text": "eine Mahnung erhalten",
          "meaning": "to receive a reminder notice"
        },
        {
          "text": "eine Mahnung schicken",
          "meaning": "to send a reminder notice"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "mahnen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Mahngebühr",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تذكير بالدفع؛ إنذار"
        },
        {
          "language": "ckb",
          "text": "ئاگاداری پارەدان؛ بیرخستنەوە"
        },
        {
          "language": "en",
          "text": "payment reminder; reminder notice"
        },
        {
          "language": "fa",
          "text": "اخطار پرداخت؛ یادآوری رسمی"
        },
        {
          "language": "kmr",
          "text": "bîranîna dayînê; agahdariya fermî"
        },
        {
          "language": "pl",
          "text": "upomnienie; wezwanie do zapłaty"
        },
        {
          "language": "ro",
          "text": "notificare de plată; somație"
        },
        {
          "language": "ru",
          "text": "напоминание об оплате; претензия"
        },
        {
          "language": "sq",
          "text": "kujtesë pagese; paralajmërim"
        },
        {
          "language": "tr",
          "text": "ödeme hatırlatması; ihtar"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kundin hat eine Mahnung bekommen, weil die Rechnung noch offen ist.",
          "translations": [
            {
              "language": "ar",
              "text": "تلقت العميلة تذكيراً بالدفع لأن الفاتورة ما زالت غير مدفوعة."
            },
            {
              "language": "ckb",
              "text": "کڕیارە ژنەکە ئاگاداری پارەدانی وەرگرت، چونکە فاکتورەکە هێشتا کراوەیە."
            },
            {
              "language": "en",
              "text": "The customer received a payment reminder because the invoice is still unpaid."
            },
            {
              "language": "fa",
              "text": "مشتری یک اخطار پرداخت دریافت کرده، چون فاکتور هنوز پرداخت نشده است."
            },
            {
              "language": "kmr",
              "text": "Xerîdarê jin bîranîna dayînê wergirt, ji ber ku fatûre hîn vekirî ye."
            },
            {
              "language": "pl",
              "text": "Klientka otrzymała upomnienie, ponieważ faktura nadal nie jest opłacona."
            },
            {
              "language": "ro",
              "text": "Clienta a primit o notificare de plată deoarece factura este încă neachitată."
            },
            {
              "language": "ru",
              "text": "Клиентка получила напоминание об оплате, потому что счёт всё ещё не оплачен."
            },
            {
              "language": "sq",
              "text": "Klientja mori një kujtesë pagese sepse fatura është ende e papaguar."
            },
            {
              "language": "tr",
              "text": "Müşteri, fatura hâlâ ödenmediği için ödeme hatırlatması aldı."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie vor der Mahnung, ob die Zahlung vielleicht schon eingegangen ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق قبل إرسال التذكير مما إذا كانت الدفعة قد وصلت ربما."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش ناردنی ئاگادارییەکە بپشکنن ئایا پارەدانەکە ڕەنگە پێشتر گەیشتبێت."
            },
            {
              "language": "en",
              "text": "Please check before the reminder whether the payment may already have arrived."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از اخطار بررسی کنید که شاید پرداخت قبلاً دریافت شده باشد."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe berî bîranînê kontrol bikin ka dayîn belkî jixwe gihîştiye."
            },
            {
              "language": "pl",
              "text": "Proszę przed upomnieniem sprawdzić, czy płatność może już wpłynęła."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați înainte de notificare dacă plata poate a intrat deja."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, перед напоминанием проверьте, возможно, платёж уже поступил."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni para kujtesës nëse pagesa ndoshta ka ardhur tashmë."
            },
            {
              "language": "tr",
              "text": "İhtardan önce ödemenin belki gelmiş olup olmadığını kontrol edin."
            }
          ]
        }
      ]
    },
