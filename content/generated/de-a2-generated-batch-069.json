      "meanings": [
        {
          "language": "ar",
          "text": "حلوى؛ طبق تحلية"
        },
        {
          "language": "ckb",
          "text": "دێزێرت؛ شیرینی دوای خواردن"
        },
        {
          "language": "en",
          "text": "dessert"
        },
        {
          "language": "fa",
          "text": "دسر"
        },
        {
          "language": "kmr",
          "text": "şîrînahiya piştî xwarinê"
        },
        {
          "language": "pl",
          "text": "deser"
        },
        {
          "language": "ro",
          "text": "desert"
        },
        {
          "language": "ru",
          "text": "десерт"
        },
        {
          "language": "sq",
          "text": "ëmbëlsirë; desert"
        },
        {
          "language": "tr",
          "text": "tatlı; yemek sonrası tatlı"
        }
      ],
      "examples": [
        {
          "baseText": "Möchten Sie noch einen Nachtisch?",
          "translations": [
            {
              "language": "ar",
              "text": "هل ترغبون في حلوى أيضاً؟"
            },
            {
              "language": "ckb",
              "text": "ئایا دێزێرتێکتان دەوێت؟"
            },
            {
              "language": "en",
              "text": "Would you like a dessert as well?"
            },
            {
              "language": "fa",
              "text": "آیا دسر هم می‌خواهید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn hê jî şîrînahiyekê dixwazin?"
            },
            {
              "language": "pl",
              "text": "Czy chcą państwo jeszcze deser?"
            },
            {
              "language": "ro",
              "text": "Doriți și un desert?"
            },
            {
              "language": "ru",
              "text": "Хотите ещё десерт?"
            },
            {
              "language": "sq",
              "text": "A dëshironi edhe një ëmbëlsirë?"
            },
            {
              "language": "tr",
              "text": "Bir tatlı ister misiniz?"
            }
          ]
        },
        {
          "baseText": "Zum Nachtisch gibt es heute Eis.",
          "translations": [
            {
              "language": "ar",
              "text": "اليوم يوجد آيس كريم للتحلية."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ بۆ دێزێرت ئایسکریم هەیە."
            },
            {
              "language": "en",
              "text": "Today there is ice cream for dessert."
            },
            {
              "language": "fa",
              "text": "امروز برای دسر بستنی داریم."
            },
            {
              "language": "kmr",
              "text": "Îro ji bo şîrînahiyê qeşayê heye."
            },
            {
              "language": "pl",
              "text": "Na deser są dziś lody."
            },
            {
              "language": "ro",
              "text": "Astăzi la desert este înghețată."
            },
            {
              "language": "ru",
              "text": "Сегодня на десерт мороженое."
            },
            {
              "language": "sq",
              "text": "Sot për desert ka akullore."
            },
            {
              "language": "tr",
              "text": "Bugün tatlı olarak dondurma var."
            }
          ]
        }
      ]
