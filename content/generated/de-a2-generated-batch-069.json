        },
        {
          "language": "fa",
          "text": "پیام؛ خبر"
        },
        {
          "language": "kmr",
          "text": "peyamek; nûçe"
        },
        {
          "language": "pl",
          "text": "wiadomość"
        },
        {
          "language": "ro",
          "text": "mesaj; știre"
        },
        {
          "language": "ru",
          "text": "сообщение; новость"
        },
        {
          "language": "sq",
          "text": "mesazh; lajm"
        },
        {
          "language": "tr",
          "text": "mesaj; haber"
        }
      ],
      "examples": [
        {
          "baseText": "Ich schicke dir später eine Nachricht.",
          "translations": [
            {
              "language": "ar",
              "text": "سأرسل لك رسالة لاحقاً."
            },
            {
              "language": "ckb",
              "text": "دواتر پەیامێکت بۆ دەنێرم."
            },
            {
              "language": "en",
              "text": "I will send you a message later."
            },
            {
              "language": "fa",
              "text": "بعداً برایت پیام می‌فرستم."
            },
            {
              "language": "kmr",
              "text": "Ez paşê peyamekê ji te re dişînim."
            },
            {
              "language": "pl",
              "text": "Później wyślę ci wiadomość."
            },
            {
              "language": "ro",
              "text": "Îți trimit un mesaj mai târziu."
            },
            {
              "language": "ru",
              "text": "Я отправлю тебе сообщение позже."
            },
            {
              "language": "sq",
              "text": "Do të të dërgoj një mesazh më vonë."
            },
            {
              "language": "tr",
              "text": "Sana sonra bir mesaj göndereceğim."
            }
          ]
        },
        {
          "baseText": "Die Nachricht vom Arzt kam heute Morgen.",
          "translations": [
            {
              "language": "ar",
              "text": "رسالة الطبيب وصلت هذا الصباح."
            },
            {
              "language": "ckb",
              "text": "پەیامی پزیشک ئەم بەیانییە هات."
            },
            {
              "language": "en",
              "text": "The message from the doctor came this morning."
            },
            {
              "language": "fa",
              "text": "پیام پزشک امروز صبح آمد."
            },
            {
              "language": "kmr",
              "text": "Peyama bijîşk îro sibeh hat."
            },
            {
              "language": "pl",
              "text": "Wiadomość od lekarza przyszła dziś rano."
            },
            {
              "language": "ro",
              "text": "Mesajul de la medic a venit azi dimineață."
            },
            {
              "language": "ru",
              "text": "Сообщение от врача пришло сегодня утром."
            },
            {
              "language": "sq",
              "text": "Mesazhi nga mjeku erdhi sot në mëngjes."
            },
            {
              "language": "tr",
              "text": "Doktordan gelen mesaj bu sabah geldi."
            }
          ]
        }
      ]
    },
