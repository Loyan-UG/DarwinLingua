  "entries": [
    {
      "word": "niederkommen",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "niederkommen",
      "pronunciationIpa": null,
      "syllableBreak": "nie-der-kom-men",
      "topics": [
        "healthcare-and-appointments",
        "everyday-life",
        "culture-and-media"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong separable verb; can mean to give birth or to come down/fall"
      ],
      "collocations": [
        {
          "text": "mit einem Kind niederkommen",
          "meaning": "to give birth to a child"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kommen",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تلد؛ ينزل أو يهطل"
        },
        {
          "language": "ckb",
          "text": "منداڵ دەبێت؛ دادەبارێت/دادەکەوێت"
        },
        {
          "language": "en",
          "text": "to give birth; to come down/fall"
        },
        {
          "language": "fa",
          "text": "زاییدن؛ فرود آمدن/باریدن"
        },
        {
          "language": "kmr",
          "text": "zarok anîn; daketin/barîn"
        },
        {
          "language": "pl",
          "text": "urodzić; opaść/spaść"
        },
        {
          "language": "ro",
          "text": "a naște; a cădea/a coborî"
        },
        {
          "language": "ru",
          "text": "родить; опуститься/падать"
        },
        {
          "language": "sq",
          "text": "të lindësh; të zbresësh/bjerë"
        },
        {
          "language": "tr",
          "text": "doğurmak; inmek/yağmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Patientin kam in der Nacht mit einem gesunden Kind nieder.",
          "translations": [
            {
              "language": "ar",
              "text": "أنجبت المريضة في الليل طفلاً سليماً."
            },
            {
              "language": "ckb",
              "text": "نەخۆشەکە لە شەودا منداڵێکی تەندروستی بوو."
            },
            {
              "language": "en",
              "text": "The patient gave birth to a healthy child during the night."
            },
            {
              "language": "fa",
              "text": "بیمار شب هنگام فرزندی سالم به دنیا آورد."
            },
            {
              "language": "kmr",
              "text": "Nexweşê di şevê de zarokek sax anî dinyayê."
            },
            {
              "language": "pl",
              "text": "Pacjentka urodziła w nocy zdrowe dziecko."
            },
            {
              "language": "ro",
              "text": "Pacienta a născut noaptea un copil sănătos."
            },
            {
              "language": "ru",
              "text": "Пациентка ночью родила здорового ребенка."
            },
            {
              "language": "sq",
              "text": "Pacientja lindi natën një fëmijë të shëndetshëm."
            },
            {
              "language": "tr",
              "text": "Hasta gece sağlıklı bir çocuk doğurdu."
            }
          ]
        },
        {
          "baseText": "Der Regen kam so heftig nieder, dass die Straße innerhalb weniger Minuten überflutet war.",
          "translations": [
            {
              "language": "ar",
              "text": "هطل المطر بغزارة حتى غُمر الشارع خلال دقائق قليلة."
            },
            {
              "language": "ckb",
              "text": "بارانەکە بەوەندە توند داباری کە شەقامەکە لە چەند خولەکێکدا ئاوی لێدا."
            },
            {
              "language": "en",
              "text": "The rain came down so heavily that the street was flooded within minutes."
            },
            {
              "language": "fa",
              "text": "باران چنان شدید بارید که خیابان ظرف چند دقیقه آب گرفت."
            },
            {
              "language": "kmr",
              "text": "Baran ewqas bi tundî barî ku şeqam di çend xulekên kêm de av girt."
            },
            {
              "language": "pl",
              "text": "Deszcz padał tak intensywnie, że ulica została zalana w ciągu kilku minut."
            },
            {
              "language": "ro",
              "text": "Ploaia a căzut atât de puternic încât strada a fost inundată în câteva minute."
            },
            {
              "language": "ru",
              "text": "Дождь лил так сильно, что улицу затопило за несколько минут."
            },
            {
              "language": "sq",
              "text": "Shiu ra aq fort sa rruga u përmbyt brenda pak minutash."
            },
            {
              "language": "tr",
              "text": "Yağmur o kadar şiddetli indi ki cadde birkaç dakika içinde sular altında kaldı."
            }
          ]
        }
      ]
    },
    {
      "word": "niederschreiben",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "niederschreiben",
      "pronunciationIpa": null,
      "syllableBreak": "nie-der-schrei-ben",
      "topics": [
        "documents-and-administration",
        "business-communication",
        "culture-and-media"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "strong separable verb; means to write something down"
      ],
      "collocations": [
        {
          "text": "Gedanken niederschreiben",
          "meaning": "to write down thoughts"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schreiben",
          "relationLabel": "base verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدوّن؛ يكتب"
        },
        {
          "language": "ckb",
          "text": "دەنووسێتەوە؛ تۆمار دەکات"
        },
        {
          "language": "en",
          "text": "to write down; to put in writing"
        },
        {
          "language": "fa",
          "text": "نوشتن؛ مکتوب کردن"
        },
        {
          "language": "kmr",
          "text": "nivîsîn; tomar kirin"
        },
        {
          "language": "pl",
          "text": "spisać; zapisać"
        },
        {
          "language": "ro",
          "text": "a nota; a consemna"
        },
        {
          "language": "ru",
          "text": "записать; изложить письменно"
        },
        {
          "language": "sq",
          "text": "të shkruash; të shënosh"
        },
        {
          "language": "tr",
          "text": "yazıya dökmek; not etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schreiben Sie die vereinbarten Änderungen im Protokoll eindeutig nieder.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تدوين التغييرات المتفق عليها بوضوح في المحضر."
            },
            {
              "language": "ckb",
              "text": "تکایە گۆڕانکارییە ڕێککەوتووەکان بە ڕوونی لە پرۆتۆکۆڵەکەدا بنووسنەوە."
            },
            {
              "language": "en",
              "text": "Please write down the agreed changes clearly in the minutes."
            },
            {
              "language": "fa",
              "text": "لطفاً تغییرات توافق‌شده را به‌روشنی در صورت‌جلسه بنویسید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe guherînên lihevhatî bi zelalî di protokolê de binivîsin."
            },
            {
              "language": "pl",
              "text": "Proszę jasno spisać uzgodnione zmiany w protokole."
            },
            {
              "language": "ro",
              "text": "Vă rog să consemnați clar modificările convenite în procesul-verbal."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, четко зафиксируйте согласованные изменения в протоколе."
            },
            {
              "language": "sq",
              "text": "Ju lutem shkruani qartë në procesverbal ndryshimet e dakorduara."
            },
            {
              "language": "tr",
              "text": "Lütfen üzerinde anlaşılan değişiklikleri tutanağa açıkça yazın."
            }
          ]
        },
        {
          "baseText": "Nach der Reise schrieb sie ihre Eindrücke nieder, bevor die Erinnerungen verblassten.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الرحلة دوّنت انطباعاتها قبل أن تبهت الذكريات."
            },
            {
              "language": "ckb",
              "text": "دوای گەشتەکە هەستەکانی نووسیەوە پێش ئەوەی بیرەوەرییەکان کاڵ ببنەوە."
            },
            {
              "language": "en",
              "text": "After the trip, she wrote down her impressions before the memories faded."
            },
            {
              "language": "fa",
              "text": "پس از سفر، برداشت‌هایش را نوشت پیش از آنکه خاطره‌ها کم‌رنگ شوند."
            },
            {
              "language": "kmr",
              "text": "Piştî rêwîtiyê wê bandorên xwe nivîsandin berî ku bîranîn tarî bibin."
            },
            {
              "language": "pl",
              "text": "Po podróży spisała swoje wrażenia, zanim wspomnienia wyblakły."
            },
            {
              "language": "ro",
              "text": "După călătorie și-a notat impresiile înainte ca amintirile să se estompeze."
            },
            {
              "language": "ru",
              "text": "После поездки она записала свои впечатления, пока воспоминания не поблекли."
            },
            {
              "language": "sq",
              "text": "Pas udhëtimit ajo shkroi përshtypjet e saj para se kujtimet të zbeheshin."
            },
            {
              "language": "tr",
              "text": "Seyahatten sonra anıları solmadan izlenimlerini yazıya döktü."
            }
          ]
        }
      ]
    },
    {
      "word": "die Normabweichung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Normabweichungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Norm-ab-wei-chung",
      "topics": [
        "quality-and-risk",
        "law-and-compliance",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "eine Normabweichung dokumentieren",
          "meaning": "to document a deviation from a norm"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Norm",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "abweichen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "انحراف عن المعيار"
        },
        {
          "language": "ckb",
          "text": "لابردن لە ستاندارد؛ پەڕینەوە لە پێوەر"
        },
        {
          "language": "en",
          "text": "deviation from a norm"
        },
        {
          "language": "fa",
          "text": "انحراف از معیار/هنجار"
        },
        {
          "language": "kmr",
          "text": "derketina ji normê"
        },
        {
          "language": "pl",
          "text": "odchylenie od normy"
        },
        {
          "language": "ro",
          "text": "abatere de la normă"
        },
        {
          "language": "ru",
          "text": "отклонение от нормы"
        },
        {
          "language": "sq",
          "text": "devijim nga norma"
        },
        {
          "language": "tr",
          "text": "normdan sapma"
        }
      ],
      "examples": [
        {
          "baseText": "Jede Normabweichung in der Produktion muss begründet und dokumentiert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب تبرير وتوثيق كل انحراف عن المعيار في الإنتاج."
            },
            {
              "language": "ckb",
              "text": "هەر لابردنێک لە ستاندارد لە بەرهەمهێناندا دەبێت پاساو و تۆمار بکرێت."
            },
            {
              "language": "en",
              "text": "Every deviation from the norm in production must be justified and documented."
            },
            {
              "language": "fa",
              "text": "هر انحراف از معیار در تولید باید توجیه و مستند شود."
            },
            {
              "language": "kmr",
              "text": "Her derketinek ji normê di hilberînê de divê were sedemkirin û belgekirin."
            },
            {
              "language": "pl",
              "text": "Każde odchylenie od normy w produkcji musi być uzasadnione i udokumentowane."
            },
            {
              "language": "ro",
              "text": "Fiecare abatere de la normă în producție trebuie justificată și documentată."
            },
            {
              "language": "ru",
              "text": "Каждое отклонение от нормы в производстве должно быть обосновано и задокументировано."
            },
            {
              "language": "sq",
              "text": "Çdo devijim nga norma në prodhim duhet të arsyetohet dhe dokumentohet."
            },
            {
              "language": "tr",
              "text": "Üretimdeki her norm sapması gerekçelendirilmeli ve belgelenmelidir."
            }
          ]
        },
        {
          "baseText": "In der Statistik ist eine Normabweichung nicht automatisch ein Hinweis auf einen Fehler.",
          "translations": [
            {
              "language": "ar",
