      "examples": [
        {
          "baseText": "Die Inventurdaten werden vom Scanner direkt ins ERP übertragen.",
          "translations": [
            {
              "language": "ar",
              "text": "تُنقل بيانات الجرد من الماسح مباشرة إلى ERP."
            },
            {
              "language": "ckb",
              "text": "داتای ژماردنی کۆگا لە سکەنەرەوە ڕاستەوخۆ بۆ ERP دەگوازرێتەوە."
            },
            {
              "language": "en",
              "text": "The inventory count data is transferred from the scanner directly into the ERP."
            },
            {
              "language": "fa",
              "text": "داده‌های انبارگردانی از اسکنر مستقیماً به ERP منتقل می‌شود."
            },
            {
              "language": "kmr",
