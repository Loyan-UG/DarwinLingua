        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; physical stocktaking or inventory count"
      ],
      "collocations": [
        {
          "text": "eine Inventur durchführen",
          "meaning": "to carry out a stocktaking"
        },
        {
          "text": "die Inventur abschließen",
          "meaning": "to complete the inventory count"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "inventarisieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جرد المخزون"
        },
        {
          "language": "ckb",
          "text": "ژماردنی کۆگا"
        },
        {
          "language": "en",
          "text": "stocktaking; inventory count"
        },
        {
          "language": "fa",
          "text": "انبارگردانی؛ شمارش موجودی"
        },
        {
          "language": "kmr",
          "text": "jimartina stokê"
        },
        {
          "language": "pl",
          "text": "inwentaryzacja"
        },
        {
          "language": "ro",
          "text": "inventariere"
        },
        {
          "language": "ru",
          "text": "инвентаризация"
        },
        {
          "language": "sq",
          "text": "inventarizim"
        },
        {
          "language": "tr",
          "text": "envanter sayımı"
        }
      ],
      "examples": [
        {
          "baseText": "Während der Inventur werden die Bestände im ERP vorübergehend gesperrt.",
          "translations": [
            {
              "language": "ar",
              "text": "أثناء الجرد يتم حظر المخزون مؤقتًا في ERP."
            },
            {
              "language": "ckb",
              "text": "لە کاتی ژماردنی کۆگادا، کۆگا لە ERP دا کاتییەک قەدەغە دەکرێت."
            },
            {
              "language": "en",
              "text": "During the inventory count, the stock levels are temporarily blocked in the ERP."
            },
            {
              "language": "fa",
              "text": "در طول انبارگردانی، موجودی‌ها در ERP به‌صورت موقت مسدود می‌شوند."
            },
            {
              "language": "kmr",
              "text": "Di dema jimartina stokê de, astên stokê di ERP de demkî têne astengkirin."
            },
            {
              "language": "pl",
              "text": "Podczas inwentaryzacji stany magazynowe są tymczasowo blokowane w ERP."
            },
            {
              "language": "ro",
              "text": "În timpul inventarierii, stocurile sunt blocate temporar în ERP."
            },
            {
              "language": "ru",
              "text": "Во время инвентаризации запасы временно блокируются в ERP."
            },
            {
              "language": "sq",
              "text": "Gjatë inventarizimit, stoket bllokohen përkohësisht në ERP."
            },
            {
              "language": "tr",
              "text": "Envanter sayımı sırasında stoklar ERP’de geçici olarak bloke edilir."
            }
          ]
        },
        {
          "baseText": "Die Inventur dauert länger, weil mehrere Artikel ohne Etikett im Regal liegen.",
          "translations": [
            {
              "language": "ar",
              "text": "تستغرق عملية الجرد وقتًا أطول لأن عدة أصناف موجودة على الرف بدون ملصق."
            },
            {
              "language": "ckb",
              "text": "ژماردنی کۆگا زیاتر دەخایەنێت چونکە چەند ماددەیەک بەبێ لیبڵ لەسەر ڕەفەکە دانراون."
            },
            {
              "language": "en",
              "text": "The inventory count is taking longer because several items on the shelf have no label."
            },
            {
              "language": "fa",
              "text": "انبارگردانی بیشتر طول می‌کشد، چون چند کالا بدون برچسب در قفسه هستند."
            },
            {
              "language": "kmr",
              "text": "Jimartina stokê dirêjtir dibe, ji ber ku çend babet bê etîket li ser refê ne."
            },
            {
              "language": "pl",
              "text": "Inwentaryzacja trwa dłużej, ponieważ kilka artykułów na półce nie ma etykiety."
            },
            {
              "language": "ro",
              "text": "Inventarierea durează mai mult deoarece mai multe articole de pe raft nu au etichetă."
            },
            {
              "language": "ru",
              "text": "Инвентаризация занимает больше времени, потому что несколько товаров на полке без этикетки."
            },
            {
              "language": "sq",
              "text": "Inventarizimi zgjat më shumë sepse disa artikuj në raft janë pa etiketë."
            },
            {
              "language": "tr",
              "text": "Envanter sayımı daha uzun sürüyor, çünkü raftaki birkaç ürün etiketsiz."
            }
          ]
        }
      ]
    },
    {
      "word": "Inventurauftrag",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Inventuraufträge",
      "infinitive": null,
