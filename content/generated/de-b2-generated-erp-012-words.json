        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; work order for an inventory count"
      ],
      "collocations": [
        {
          "text": "einen Inventurauftrag anlegen",
          "meaning": "to create an inventory count order"
        },
        {
          "text": "einen Inventurauftrag freigeben",
          "meaning": "to release an inventory count order"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Inventur",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "der Auftrag",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أمر جرد"
        },
        {
          "language": "ckb",
          "text": "داواکاریی ژماردنی کۆگا"
        },
        {
          "language": "en",
          "text": "inventory count order"
        },
        {
          "language": "fa",
          "text": "دستور انبارگردانی؛ سفارش شمارش موجودی"
        },
        {
          "language": "kmr",
          "text": "fermana jimartina stokê"
        },
        {
          "language": "pl",
          "text": "zlecenie inwentaryzacyjne"
        },
        {
          "language": "ro",
          "text": "ordin de inventariere"
        },
        {
          "language": "ru",
          "text": "задание на инвентаризацию"
        },
        {
          "language": "sq",
          "text": "urdhër inventarizimi"
        },
        {
          "language": "tr",
          "text": "envanter sayım emri"
        }
      ],
      "examples": [
        {
          "baseText": "Der Inventurauftrag wird im ERP pro Lagerbereich erstellt.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم إنشاء أمر الجرد في ERP لكل منطقة مخزن."
            },
            {
              "language": "ckb",
              "text": "داواکاریی ژماردنی کۆگا لە ERP دا بۆ هەر بەشی کۆگا دروست دەکرێت."
            },
            {
              "language": "en",
              "text": "The inventory count order is created in the ERP for each warehouse area."
            },
            {
              "language": "fa",
              "text": "دستور انبارگردانی در ERP برای هر بخش انبار ایجاد می‌شود."
            },
            {
              "language": "kmr",
              "text": "Fermana jimartina stokê di ERP de ji bo her qada embarê tê çêkirin."
            },
            {
              "language": "pl",
              "text": "Zlecenie inwentaryzacyjne jest tworzone w ERP dla każdego obszaru magazynu."
            },
            {
              "language": "ro",
              "text": "Ordinul de inventariere este creat în ERP pentru fiecare zonă a depozitului."
            },
            {
              "language": "ru",
              "text": "Задание на инвентаризацию создается в ERP для каждой складской зоны."
            },
            {
              "language": "sq",
              "text": "Urdhri i inventarizimit krijohet në ERP për çdo zonë magazine."
            },
            {
              "language": "tr",
              "text": "Envanter sayım emri ERP’de her depo alanı için oluşturulur."
            }
          ]
        },
        {
          "baseText": "Bitte starten Sie den Inventurauftrag erst, wenn alle offenen Wareneingänge gebucht sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى بدء أمر الجرد فقط بعد ترحيل جميع استلامات البضائع المفتوحة."
            },
            {
              "language": "ckb",
              "text": "تکایە داواکاریی ژماردنی کۆگا تەنها کاتێک دەست پێبکەن کە هەموو وەرگرتنی کاڵای کراوە تۆمار کرابن."
            },
            {
              "language": "en",
              "text": "Please start the inventory count order only when all open goods receipts have been posted."
            },
            {
              "language": "fa",
              "text": "لطفاً دستور انبارگردانی را فقط وقتی شروع کنید که همه رسیدهای کالای باز ثبت شده باشند."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fermana jimartina stokê tenê dema hemû wergirtinên malan ên vekirî hatin tomarkirin dest pê bikin."
            },
            {
              "language": "pl",
              "text": "Proszę rozpocząć zlecenie inwentaryzacyjne dopiero po zaksięgowaniu wszystkich otwartych przyjęć towaru."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să porniți ordinul de inventariere doar după ce toate recepțiile deschise au fost înregistrate."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, запускайте задание на инвентаризацию только после проведения всех открытых поступлений товара."
            },
            {
              "language": "sq",
              "text": "Ju lutemi nisni urdhrin e inventarizimit vetëm pasi të jenë regjistruar të gjitha pranimet e hapura të mallrave."
            },
            {
              "language": "tr",
              "text": "Lütfen envanter sayım emrini ancak tüm açık mal kabulleri kaydedildikten sonra başlatın."
            }
          ]
        }
      ]
    },
