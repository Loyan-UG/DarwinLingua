      "meanings": [
        {
          "language": "ar",
          "text": "مدرس اللغة الألمانية"
        },
        {
          "language": "ckb",
          "text": "مامۆستای ئەڵمانی"
        },
        {
          "language": "en",
          "text": "male German teacher"
        },
        {
          "language": "fa",
          "text": "معلم مرد آلمانی"
        },
        {
          "language": "kmr",
          "text": "mamostayê Almanî yê mêr"
        },
        {
          "language": "pl",
          "text": "nauczyciel niemieckiego"
        },
        {
          "language": "ro",
          "text": "profesor de germană"
        },
        {
          "language": "ru",
          "text": "учитель немецкого языка"
        },
        {
          "language": "sq",
          "text": "mësues gjermanishteje"
        },
        {
          "language": "tr",
          "text": "Almanca öğretmeni"
        }
      ],
      "examples": [
        {
          "baseText": "Der Deutschlehrer erklärt die neue Grammatik.",
          "translations": [
            {
              "language": "ar",
              "text": "يشرح مدرس الألمانية القاعدة الجديدة."
            },
            {
              "language": "ckb",
              "text": "مامۆستای ئەڵمانی ڕێزمانە نوێیەکە ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The German teacher explains the new grammar."
            },
            {
              "language": "fa",
              "text": "معلم آلمانی دستور زبان جدید را توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Mamostayê Almanî rêzimana nû rave dike."
            },
            {
              "language": "pl",
              "text": "Nauczyciel niemieckiego wyjaśnia nową gramatykę."
            },
            {
              "language": "ro",
              "text": "Profesorul de germană explică noua gramatică."
            },
            {
              "language": "ru",
              "text": "Учитель немецкого объясняет новую грамматику."
            },
            {
              "language": "sq",
              "text": "Mësuesi i gjermanishtes shpjegon gramatikën e re."
            },
            {
              "language": "tr",
              "text": "Almanca öğretmeni yeni dil bilgisini açıklıyor."
            }
          ]
        },
        {
          "baseText": "Ich frage den Deutschlehrer nach den Hausaufgaben.",
          "translations": [
            {
              "language": "ar",
              "text": "أسأل مدرس الألمانية عن الواجبات."
            },
            {
              "language": "ckb",
              "text": "پرسیاری ئەرکی ماڵەوە لە مامۆستای ئەڵمانی دەکەم."
            },
            {
              "language": "en",
              "text": "I ask the German teacher about the homework."
            },
            {
              "language": "fa",
              "text": "از معلم آلمانی درباره تکالیف می‌پرسم."
            },
            {
              "language": "kmr",
              "text": "Ez ji mamostayê Almanî li ser erkên malê dipirsim."
            },
            {
              "language": "pl",
              "text": "Pytam nauczyciela niemieckiego o pracę domową."
            },
            {
              "language": "ro",
              "text": "Îl întreb pe profesorul de germană despre teme."
            },
            {
              "language": "ru",
              "text": "Я спрашиваю учителя немецкого о домашнем задании."
            },
            {
              "language": "sq",
              "text": "E pyes mësuesin e gjermanishtes për detyrat."
            },
            {
              "language": "tr",
              "text": "Almanca öğretmenine ödevleri soruyorum."
            }
          ]
        }
      ]
    },
