      "examples": [
        {
          "baseText": "Die Deutschlehrerin spricht langsam und deutlich.",
          "translations": [
            {
              "language": "ar",
              "text": "تتحدث مدرسة الألمانية ببطء ووضوح."
            },
            {
              "language": "ckb",
              "text": "مامۆستای ژنی ئەڵمانی هێواش و ڕوون قسە دەکات."
            },
            {
              "language": "en",
              "text": "The German teacher speaks slowly and clearly."
            },
            {
              "language": "fa",
              "text": "معلم آلمانی آرام و واضح صحبت می‌کند."
            },
