        {
          "language": "sq",
          "text": "vëllezër e motra"
        },
        {
          "language": "tr",
          "text": "kardeşler"
        }
      ],
      "examples": [
        {
          "baseText": "Hast du Geschwister?",
          "translations": [
            {
              "language": "ar",
              "text": "هل لديك إخوة أو أخوات؟"
            },
            {
              "language": "ckb",
              "text": "خوشک و برات هەیە؟"
            },
            {
              "language": "en",
              "text": "Do you have siblings?"
            },
            {
              "language": "fa",
              "text": "خواهر یا برادر داری؟"
            },
            {
              "language": "kmr",
              "text": "Xwişk û birayên te hene?"
            },
            {
              "language": "pl",
              "text": "Czy masz rodzeństwo?"
            },
            {
              "language": "ro",
              "text": "Ai frați sau surori?"
            },
            {
              "language": "ru",
              "text": "У тебя есть братья или сёстры?"
            },
            {
              "language": "sq",
              "text": "A ke vëllezër apo motra?"
            },
            {
              "language": "tr",
              "text": "Kardeşlerin var mı?"
            }
          ]
        },
        {
          "baseText": "Meine Geschwister wohnen in einer anderen Stadt.",
          "translations": [
            {
              "language": "ar",
              "text": "إخوتي يعيشون في مدينة أخرى."
            },
            {
              "language": "ckb",
              "text": "خوشک و براکانم لە شارێکی تر دەژین."
            },
            {
              "language": "en",
              "text": "My siblings live in another city."
            },
            {
              "language": "fa",
              "text": "خواهر و برادرهایم در شهر دیگری زندگی می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Xwişk û birayên min li bajarekî din dijîn."
            },
            {
              "language": "pl",
              "text": "Moje rodzeństwo mieszka w innym mieście."
            },
            {
              "language": "ro",
              "text": "Frații mei locuiesc în alt oraș."
            },
            {
              "language": "ru",
              "text": "Мои братья и сёстры живут в другом городе."
            },
            {
              "language": "sq",
              "text": "Vëllezërit dhe motrat e mia jetojnë në një qytet tjetër."
            },
            {
              "language": "tr",
              "text": "Kardeşlerim başka bir şehirde yaşıyor."
            }
          ]
        }
      ]
    },
