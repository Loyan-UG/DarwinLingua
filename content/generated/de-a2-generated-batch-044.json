            },
            {
              "language": "ru",
              "text": "Аптека сегодня закрыта."
            },
            {
              "language": "sq",
              "text": "Farmacia është e mbyllur sot."
            },
            {
              "language": "tr",
              "text": "Eczane bugün kapalı."
            }
          ]
        },
        {
          "baseText": "Der Schalter ist um 16 Uhr geschlossen.",
          "translations": [
