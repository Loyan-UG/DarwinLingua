            {
              "language": "en",
              "text": "The counter is closed at 4 p.m."
            },
            {
              "language": "fa",
              "text": "باجه ساعت ۱۶ بسته است."
            },
            {
              "language": "kmr",
              "text": "Mase di saet 16 de girtî ye."
            },
            {
              "language": "pl",
              "text": "Stanowisko jest zamknięte o 16."
            },
            {
              "language": "ro",
              "text": "Ghișeul este închis la ora 16."
            },
            {
              "language": "ru",
              "text": "Стойка закрыта в 16:00."
