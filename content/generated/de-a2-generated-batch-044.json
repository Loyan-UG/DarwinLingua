          "language": "ckb",
          "text": "خوشک و برا؛ برایان و خوشکان"
        },
        {
          "language": "en",
          "text": "siblings; brothers and sisters"
        },
        {
          "language": "fa",
          "text": "خواهر و برادرها"
        },
        {
          "language": "kmr",
          "text": "xwişk û bira"
        },
        {
          "language": "pl",
          "text": "rodzeństwo"
