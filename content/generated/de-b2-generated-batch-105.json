  "entries": [
    {
      "word": "auffliegen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auffliegen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-flie-gen",
      "topics": [
        "quality-and-risk",
        "work-and-jobs",
        "customer-service"
      ],
      "usageLabels": [
        "workplace",
        "analysis"
      ],
      "contextLabels": [
        "reporting",
        "software"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "به طور ناگهانی آشکار شدن"
        },
        {
          "language": "ckb",
          "text": "بەدوازی دەرکەوتن"
        },
        {
          "language": "en",
          "text": "to turn up; to come to light"
        },
        {
          "language": "fa",
          "text": "آشکار شدن"
        },
        {
          "language": "kmr",
          "text": "bihîstin; derketin"
        },
        {
          "language": "pl",
          "text": "wypłynąć na jaw; ujawnić się"
        },
        {
          "language": "ro",
          "text": "a ieși la iveală; a fi descoperit"
        },
        {
          "language": "ru",
          "text": "вскрыться; стать известным"
        },
        {
          "language": "sq",
          "text": "zbulohet; del në shesh"
        },
        {
          "language": "tr",
          "text": "göze çarpmak; ortaya çıkmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der unerwartete Lasttest ist im Monitoring erst heute auffliegen.",
          "translations": [
            {
              "language": "ar",
              "text": "بارگذاری غیرمنتظره فقط امروز در مانیتورینگ آشکار شد."
            },
            {
              "language": "ckb",
              "text": "بارکردنەوی نادیار تەنها ئەمڕۆ لە مۆنیتۆرینگدا دەرەوەیە."
            },
            {
              "language": "en",
              "text": "The unexpected load spike surfaced in monitoring only today."
            },
            {
              "language": "fa",
              "text": "افزایش بار غیرمنتظره فقط امروز در مانیتورینگ به آشکار شد."
            },
            {
              "language": "kmr",
              "text": "Pîvanbûna neabêrî tenê îro di monitoringê de derket."
            },
            {
              "language": "pl",
              "text": "Niespodziewany pik obciążenia ujawnił się w monitoringu dopiero dziś."
            },
            {
              "language": "ro",
              "text": "Pauza neașteptată de sarcină a ieșit la iveală în monitorizare abia azi."
            },
            {
              "language": "ru",
              "text": "Неожиданный пик нагрузки всплыл в мониторинге только сегодня."
            },
            {
              "language": "sq",
              "text": "Ngarkesa e papritur e pritjes u bë e dukshme në monitorim vetëm sot."
            },
            {
              "language": "tr",
              "text": "Beklenmeyen yük artışı yalnızca bugün izleme ekranında ortaya çıktı."
            }
          ]
        },
        {
          "baseText": "Der Compliance-Issue ist im Audit-Bericht zuerst auffliegen werden müssen.",
          "translations": [
            {
              "language": "ar",
              "text": "مسئله انطباق باید اول در گزارش حسابرسی دیده شود."
            },
            {
              "language": "ckb",
              "text": "پرسیاری گونجاویەک دەبێت یەکەنگە لە ڕاپۆرتی تاقیکردنەوەدا دیاری بکرێت."
            },
            {
              "language": "en",
              "text": "The compliance issue will need to surface first in the audit report."
            },
            {
              "language": "fa",
              "text": "مسئله انطباق باید ابتدا در گزارش حسابرسی آشکار شود."
            },
            {
              "language": "kmr",
              "text": "Pirsa compliance divê berê li raporta auditê derkeve."
            },
            {
              "language": "pl",
              "text": "Sprawa zgodności będzie musiała najpierw wyjść na jaw w raporcie audytu."
            },
            {
              "language": "ro",
              "text": "Problema de conformitate va trebui să apară mai întâi în raportul de audit."
            },
            {
              "language": "ru",
              "text": "Проблема комплаенса должна сначала проявиться в отчёте аудита."
            },
            {
              "language": "sq",
              "text": "Çështja e përputhshmërisë duhet së pari të dalë në shesh në raportin e auditimit."
            },
            {
              "language": "tr",
              "text": "Uyum sorunu önce denetim raporunda ortaya çıkmalıdır."
            }
          ]
        }
      ]
    },
    {
      "word": "auffressen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auffressen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-fres-sen",
      "topics": [
        "quality-and-risk",
        "public-services",
        "work-and-jobs"
      ],
      "usageLabels": [
        "workplace"
      ],
      "contextLabels": [
        "risk",
        "support"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "مصرف کردن تا حد نابودی"
        },
        {
          "language": "ckb",
          "text": "بە شێوەی زیانبەخش درێژەوە"
        },
        {
          "language": "en",
          "text": "to eat away; to erode"
        },
        {
          "language": "fa",
          "text": "خوران تا فرسودن/تخریب"
        },
        {
          "language": "kmr",
          "text": "xwarin û xêrkirin"
        },
        {
          "language": "pl",
          "text": "zjadać; niszczyć"
        },
        {
          "language": "ro",
          "text": "a devora, a roade"
        },
        {
          "language": "ru",
          "text": "поглощать; выедать"
        },
        {
          "language": "sq",
          "text": "të gllabëroj"
        },
        {
          "language": "tr",
          "text": "sivri yemlemek; aşındırmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die ständigen Zwischenlösungen haben das Budget langsam aufgefressen.",
          "translations": [
            {
              "language": "ar",
              "text": "راه‌حل‌های موقت مداوم بودجه را به‌تدریج خورده‌اند."
            },
            {
              "language": "ckb",
              "text": "چارەسەرییە هەموو کاتەکانی ناوخۆیی، بودجەکە بە هەڕەقەیەوە خواردووە."
            },
            {
              "language": "en",
              "text": "The constant temporary fixes have slowly eaten away the budget."
            },
            {
              "language": "fa",
              "text": "راهکارهای موقت پی‌درپی به‌تدریج بودجه را فرسوده کردند."
            },
            {
              "language": "kmr",
              "text": "Çareseriya demdemî yên berdewam bugetê bi hêvîk re xwarin."
            },
            {
              "language": "pl",
              "text": "Ciągłe obejścia czasowe powoli wyczerpywały budżet."
            },
            {
              "language": "ro",
              "text": "Soluțiile temporare repetate au consumat încet bugetul."
            },
            {
              "language": "ru",
              "text": "Постоянные временные решения постепенно разъели бюджет."
            },
            {
              "language": "sq",
              "text": "Zgjidhjet e përkohshme të vazhdueshme po e kanë gllabëruar ngadalë buxhetin."
            },
            {
              "language": "tr",
              "text": "Sürekli geçici çözümler bütçeyi yavaşça eritti."
            }
          ]
        },
        {
