      "examples": [
        {
          "baseText": "Ich nehme Honig in den Tee.",
          "translations": [
            {
              "language": "ar",
              "text": "أضع العسل في الشاي."
            },
            {
              "language": "ckb",
              "text": "هەنگوین دەخەمە ناو چا."
            },
            {
              "language": "en",
              "text": "I put honey in the tea."
            },
            {
              "language": "fa",
              "text": "در چای عسل می‌ریزم."
            },
            {
              "language": "kmr",
              "text": "Ez hingiv dixim nav çayê."
            },
            {
              "language": "pl",
              "text": "Dodaję miód do herbaty."
            },
            {
              "language": "ro",
              "text": "Pun miere în ceai."
            },
            {
              "language": "ru",
              "text": "Я кладу мёд в чай."
            },
            {
              "language": "sq",
              "text": "Vendos mjaltë në çaj."
            },
            {
              "language": "tr",
              "text": "Çaya bal koyuyorum."
            }
          ]
        },
        {
          "baseText": "Der Honig kostet vier Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "العسل يكلف أربعة يورو."
            },
            {
              "language": "ckb",
              "text": "هەنگوینەکە چوار یۆرۆیە."
            },
            {
              "language": "en",
              "text": "The honey costs four euros."
            },
            {
              "language": "fa",
              "text": "عسل چهار یورو قیمت دارد."
            },
            {
              "language": "kmr",
              "text": "Hingiv çar euro ye."
            },
            {
              "language": "pl",
              "text": "Miód kosztuje cztery euro."
            },
            {
              "language": "ro",
              "text": "Mierea costă patru euro."
            },
            {
              "language": "ru",
              "text": "Мёд стоит четыре евро."
            },
            {
              "language": "sq",
              "text": "Mjalti kushton katër euro."
            },
            {
              "language": "tr",
              "text": "Bal dört avro tutuyor."
            }
          ]
        }
