        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مواطن"
        },
        {
          "language": "ckb",
          "text": "هاووڵاتی"
        },
        {
          "language": "en",
          "text": "citizen"
        },
        {
          "language": "fa",
          "text": "شهروند"
        },
        {
          "language": "kmr",
          "text": "welatî"
        },
        {
          "language": "pl",
          "text": "obywatel"
        },
        {
          "language": "ro",
          "text": "cetățean"
        },
        {
          "language": "ru",
          "text": "гражданин"
        },
        {
          "language": "sq",
          "text": "qytetar"
        },
        {
          "language": "tr",
          "text": "vatandaş"
        }
      ],
      "examples": [
        {
          "baseText": "Jeder Bürger kann online einen Termin beim Bürgeramt buchen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن لكل مواطن حجز موعد عبر الإنترنت في مكتب شؤون المواطنين."
            },
            {
              "language": "ckb",
              "text": "هەر هاووڵاتییەک دەتوانێت بە ئۆنلاین کاتێک لە فەرمانگەی هاووڵاتیان بگرێت."
            },
            {
              "language": "en",
              "text": "Every citizen can book an appointment with the citizens’ office online."
            },
            {
              "language": "fa",
              "text": "هر شهروند می‌تواند آنلاین از اداره شهروندان وقت بگیرد."
            },
            {
              "language": "kmr",
              "text": "Her welatî dikare serhêl wextek li nivîsgeha welatiyan tomar bike."
            },
            {
              "language": "pl",
              "text": "Każdy obywatel może zarezerwować online termin w urzędzie obywatelskim."
            },
            {
              "language": "ro",
              "text": "Fiecare cetățean poate programa online o întâlnire la biroul pentru cetățeni."
            },
            {
              "language": "ru",
              "text": "Каждый гражданин может онлайн записаться в ведомство по делам граждан."
            },
            {
              "language": "sq",
              "text": "Çdo qytetar mund të rezervojë online një takim në zyrën e qytetarëve."
            },
            {
              "language": "tr",
              "text": "Her vatandaş vatandaşlık ofisinden çevrim içi randevu alabilir."
            }
          ]
        },
        {
          "baseText": "Der Bürger fragt, welche Unterlagen er für die Anmeldung braucht.",
          "translations": [
            {
              "language": "ar",
              "text": "يسأل المواطن عن المستندات التي يحتاجها للتسجيل."
            },
            {
              "language": "ckb",
              "text": "هاووڵاتییەکە دەپرسێت کام بەڵگەنامە بۆ تۆمارکردن پێویستە."
            },
            {
              "language": "en",
              "text": "The citizen asks which documents he needs for the registration."
            },
            {
              "language": "fa",
              "text": "شهروند می‌پرسد برای ثبت‌نام به چه مدارکی نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Welatî dipirse ka ji bo qeydkirinê kîjan belge pêwîst in."
            },
            {
              "language": "pl",
              "text": "Obywatel pyta, jakie dokumenty są potrzebne do zameldowania."
            },
            {
              "language": "ro",
              "text": "Cetățeanul întreabă ce documente îi trebuie pentru înregistrare."
            },
            {
              "language": "ru",
              "text": "Гражданин спрашивает, какие документы нужны для регистрации."
            },
            {
              "language": "sq",
              "text": "Qytetari pyet cilat dokumente i duhen për regjistrim."
            },
            {
              "language": "tr",
              "text": "Vatandaş kayıt için hangi belgelere ihtiyacı olduğunu soruyor."
            }
          ]
        }
      ]
    },
    {
      "word": "das Bürgeramt",
