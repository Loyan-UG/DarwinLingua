      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مكتب شؤون المواطنين"
        },
        {
          "language": "ckb",
          "text": "فەرمانگەی هاووڵاتیان"
        },
        {
          "language": "en",
          "text": "citizens’ office; municipal office"
        },
        {
          "language": "fa",
          "text": "اداره شهروندان؛ اداره خدمات شهری"
        },
        {
          "language": "kmr",
          "text": "nivîsgeha welatiyan"
        },
        {
          "language": "pl",
          "text": "urząd obywatelski; urząd mieszkańców"
        },
        {
          "language": "ro",
          "text": "birou pentru cetățeni"
        },
        {
          "language": "ru",
          "text": "ведомство по делам граждан; Bürgeramt"
        },
        {
          "language": "sq",
          "text": "zyra e qytetarëve"
        },
        {
          "language": "tr",
          "text": "vatandaşlık ofisi; nüfus/ belediye işleri ofisi"
        }
      ],
      "examples": [
        {
          "baseText": "Ich muss morgen zum Bürgeramt, weil mein Ausweis abläuft.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن أذهب غدًا إلى مكتب شؤون المواطنين لأن هويتي ستنتهي صلاحيتها."
            },
            {
              "language": "ckb",
              "text": "سبەی دەبێت بچم بۆ فەرمانگەی هاووڵاتیان چونکە ناسنامەکەم کۆتایی دێت."
            },
            {
              "language": "en",
              "text": "I have to go to the citizens’ office tomorrow because my ID is expiring."
            },
            {
              "language": "fa",
              "text": "فردا باید به اداره شهروندان بروم چون کارت شناسایی‌ام منقضی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Divê ez sibê biçim nivîsgeha welatiyan, ji ber ku nasnameya min diqede."
            },
            {
              "language": "pl",
              "text": "Jutro muszę iść do urzędu obywatelskiego, bo mój dowód traci ważność."
            },
            {
              "language": "ro",
              "text": "Mâine trebuie să merg la biroul pentru cetățeni, deoarece actul meu expiră."
            },
            {
              "language": "ru",
              "text": "Завтра мне нужно идти в Bürgeramt, потому что срок действия моего удостоверения истекает."
            },
            {
              "language": "sq",
              "text": "Nesër duhet të shkoj në zyrën e qytetarëve sepse karta ime e identitetit skadon."
            },
            {
              "language": "tr",
              "text": "Kimliğimin süresi dolduğu için yarın vatandaşlık ofisine gitmem gerekiyor."
            }
          ]
        },
        {
          "baseText": "Das Bürgeramt ist mittwochs nur mit Termin geöffnet.",
          "translations": [
            {
              "language": "ar",
              "text": "يفتح مكتب شؤون المواطنين يوم الأربعاء فقط بموعد."
            },
            {
              "language": "ckb",
              "text": "فەرمانگەی هاووڵاتیان ڕۆژانی چوارشەممە تەنها بە کاتگرتن کراوەیە."
            },
            {
              "language": "en",
              "text": "The citizens’ office is open on Wednesdays only by appointment."
            },
            {
              "language": "fa",
              "text": "اداره شهروندان چهارشنبه‌ها فقط با وقت قبلی باز است."
            },
            {
              "language": "kmr",
              "text": "Nivîsgeha welatiyan çarşeman tenê bi wextê ve vekirî ye."
            },
            {
              "language": "pl",
              "text": "Urząd obywatelski jest w środy otwarty tylko z terminem."
            },
            {
              "language": "ro",
              "text": "Biroul pentru cetățeni este deschis miercurea doar cu programare."
            },
            {
              "language": "ru",
              "text": "По средам Bürgeramt открыт только по записи."
            },
            {
              "language": "sq",
              "text": "Zyra e qytetarëve të mërkurave është e hapur vetëm me takim."
            },
            {
              "language": "tr",
              "text": "Vatandaşlık ofisi çarşamba günleri sadece randevuyla açıktır."
            }
          ]
        }
      ]
    },
