      "relations": [],
      "word": "die Beweisführung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Beweisführungen",
      "infinitive": null,
      "syllableBreak": "Be-weis-füh-rung",
      "topics": [
        "law-and-compliance",
        "advanced-analysis",
        "documents-and-administration"
      ],
      "usageLabels": [
        "legal",
        "formal",
        "written",
        "analysis"
      ],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "eine schlüssige Beweisführung",
          "meaning": "a coherent presentation of evidence"
        },
        {
          "text": "Mängel in der Beweisführung",
          "meaning": "flaws in the evidentiary argument"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Beweis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "führen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تقديم الأدلة؛ بناء الحجة الإثباتية"
        },
        {
          "language": "ckb",
          "text": "پێشکەشکردنی بەڵگە؛ ڕێکخستنی بەڵگەهێنانەوە"
        },
        {
          "language": "en",
          "text": "presentation of evidence; evidentiary argumentation"
        },
        {
          "language": "fa",
          "text": "ارائه ادله؛ استدلال اثباتی"
        },
        {
          "language": "kmr",
          "text": "pêşkêşkirina delîlan; argumana îsbatê"
        },
        {
          "language": "pl",
          "text": "przeprowadzenie dowodu; argumentacja dowodowa"
        },
        {
          "language": "ro",
          "text": "prezentarea probelor; argumentare probatorie"
        },
        {
          "language": "ru",
          "text": "доказывание; представление доказательств"
        },
        {
          "language": "sq",
          "text": "paraqitje provash; argumentim provues"
        },
        {
          "language": "tr",
          "text": "delil sunumu; ispat argümantasyonu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Beweisführung war lückenhaft, weil mehrere E-Mails nicht vollständig vorgelegt wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت الحجة الإثباتية ناقصة لأن عدة رسائل بريد إلكتروني لم تُقدَّم كاملة."
            },
            {
              "language": "ckb",
              "text": "بەڵگەهێنانەوەکە کەموکوڕی هەبوو چونکە چەند ئیمەیڵێک بە تەواوی پێشکەش نەکرابوون."
            },
            {
              "language": "en",
              "text": "The evidentiary argument was incomplete because several emails were not submitted in full."
            },
            {
              "language": "fa",
              "text": "استدلال اثباتی ناقص بود، چون چند ایمیل به‌طور کامل ارائه نشده بودند."
            },
            {
              "language": "kmr",
              "text": "Argumana îsbatê kêm bû, ji ber ku çend e-mail bi tevahî nehatibûn pêşkêşkirin."
            },
            {
              "language": "pl",
              "text": "Argumentacja dowodowa była niepełna, ponieważ kilku e-maili nie przedstawiono w całości."
            },
            {
              "language": "ro",
              "text": "Argumentarea probatorie era incompletă, deoarece mai multe e-mailuri nu au fost prezentate integral."
            },
            {
              "language": "ru",
              "text": "Доказательная база была неполной, потому что несколько писем не были представлены полностью."
            },
            {
              "language": "sq",
              "text": "Argumentimi provues ishte i mangët, sepse disa email-e nuk u paraqitën plotësisht."
            },
            {
              "language": "tr",
              "text": "Delil sunumu eksikti, çünkü birkaç e-posta tam olarak sunulmamıştı."
            }
          ]
        },
        {
          "baseText": "Für die interne Untersuchung brauchen wir eine nachvollziehbare Beweisführung statt bloßer Vermutungen.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة إلى التحقيق الداخلي نحتاج إلى عرض أدلة قابل للتتبع بدل مجرد افتراضات."
            },
            {
              "language": "ckb",
              "text": "بۆ لێکۆڵینەوەی ناوخۆیی پێویستمان بە بەڵگەهێنانەوەیەکی شوێنپێهەڵگرە نەک تەنها گومان."
            },
            {
              "language": "en",
              "text": "For the internal investigation, we need traceable evidence rather than mere assumptions."
            },
            {
              "language": "fa",
              "text": "برای تحقیق داخلی به ارائه ادله قابل پیگیری نیاز داریم، نه صرفاً حدس و گمان."
            },
            {
              "language": "kmr",
              "text": "Ji bo lêkolîna hundirîn, pêwîstiya me bi delîlên şopandinbar heye, ne tenê guman."
            },
            {
              "language": "pl",
              "text": "Do wewnętrznego dochodzenia potrzebujemy przejrzystej argumentacji dowodowej, a nie samych przypuszczeń."
            },
            {
              "language": "ro",
              "text": "Pentru investigația internă avem nevoie de o prezentare verificabilă a probelor, nu doar de presupuneri."
            },
            {
              "language": "ru",
              "text": "Для внутреннего расследования нужны прослеживаемые доказательства, а не простые предположения."
            },
            {
              "language": "sq",
              "text": "Për hetimin e brendshëm na duhet paraqitje e gjurmueshme provash, jo thjesht hamendësime."
            },
            {
              "language": "tr",
              "text": "İç soruşturma için yalnızca varsayımlar değil, izlenebilir bir delil sunumu gerekiyor."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Beweislast",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Beweislasten",
      "infinitive": null,
      "syllableBreak": "Be-weis-last",
      "topics": [
        "law-and-compliance",
        "contracts-and-negotiation",
        "advanced-analysis"
      ],
      "usageLabels": [
        "legal",
        "formal",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "feminine compound noun"
      ],
      "collocations": [
        {
          "text": "die Beweislast tragen",
          "meaning": "to bear the burden of proof"
        },
        {
          "text": "Umkehr der Beweislast",
          "meaning": "reversal of the burden of proof"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Beweis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Last",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "عبء الإثبات"
        },
        {
          "language": "ckb",
          "text": "باری بەڵگەهێنانەوە"
        },
        {
          "language": "en",
          "text": "burden of proof"
        },
        {
          "language": "fa",
          "text": "بار اثبات"
        },
        {
          "language": "kmr",
          "text": "bara îsbatê"
        },
        {
          "language": "pl",
          "text": "ciężar dowodu"
        },
        {
          "language": "ro",
          "text": "sarcina probei"
        },
        {
          "language": "ru",
          "text": "бремя доказывания"
        },
        {
          "language": "sq",
          "text": "barra e provës"
        },
        {
          "language": "tr",
          "text": "ispat yükü"
        }
      ],
      "examples": [
        {
          "baseText": "Im Streit um die mangelhafte Leistung trägt grundsätzlich der Auftragnehmer die Beweislast.",
          "translations": [
            {
              "language": "ar",
              "text": "في النزاع حول الخدمة المعيبة يتحمل المتعاقد من حيث المبدأ عبء الإثبات."
            },
            {
              "language": "ckb",
              "text": "لە ناکۆکی لەسەر خزمەتگوزاری کەموکوڕدا، بە گشتی جێبەجێکەر باری بەڵگەهێنانەوە دەگرێتە ئەستۆ."
            },
            {
              "language": "en",
              "text": "In the dispute about the defective service, the contractor generally bears the burden of proof."
            },
            {
              "language": "fa",
              "text": "در اختلاف درباره عملکرد ناقص، اصولاً پیمانکار بار اثبات را بر عهده دارد."
            },
            {
              "language": "kmr",
              "text": "Di nakokiya li ser xizmeta kêmasîdar de, bi giştî peymankar bara îsbatê digire ser xwe."
            },
            {
              "language": "pl",
              "text": "W sporze o wadliwą usługę zasadniczo wykonawca ponosi ciężar dowodu."
            },
            {
              "language": "ro",
              "text": "În disputa privind serviciul defectuos, contractantul poartă în principiu sarcina probei."
            },
            {
              "language": "ru",
              "text": "В споре о ненадлежащем исполнении подрядчик, как правило, несет бремя доказывания."
            },
            {
              "language": "sq",
              "text": "Në mosmarrëveshjen për shërbimin me mangësi, kontraktori zakonisht mban barrën e provës."
            },
            {
              "language": "tr",
              "text": "Kusurlu hizmet anlaşmazlığında ispat yükü kural olarak yüklenicidedir."
            }
          ]
        },
        {
          "baseText": "Die Klausel verschiebt die Beweislast zulasten des Verbrauchers und ist deshalb problematisch.",
          "translations": [
            {
              "language": "ar",
              "text": "ينقل البند عبء الإثبات على حساب المستهلك ولذلك فهو إشكالي."
            },
            {
              "language": "ckb",
              "text": "ماددەکە باری بەڵگەهێنانەوە دەخاتە سەر بەکارهێنەر و بۆیە کێشەدارە."
            },
            {
              "language": "en",
              "text": "The clause shifts the burden of proof to the consumer’s disadvantage and is therefore problematic."
            },
            {
              "language": "fa",
              "text": "این بند بار اثبات را به زیان مصرف‌کننده منتقل می‌کند و بنابراین مشکل‌ساز است."
            },
            {
              "language": "kmr",
              "text": "Bend bara îsbatê li dijî xerîdar diguhezîne û ji ber wê pirsgirêkdar e."
            },
            {
              "language": "pl",
              "text": "Klauzula przenosi ciężar dowodu na niekorzyść konsumenta i dlatego jest problematyczna."
            },
            {
              "language": "ro",
              "text": "Clauza mută sarcina probei în dezavantajul consumatorului și este de aceea problematică."
            },
            {
              "language": "ru",
              "text": "Пункт переносит бремя доказывания в ущерб потребителю и поэтому проблематичен."
            },
            {
              "language": "sq",
              "text": "Klauzola e zhvendos barrën e provës në dëm të konsumatorit dhe prandaj është problematike."
            },
            {
              "language": "tr",
              "text": "Madde ispat yükünü tüketici aleyhine kaydırıyor ve bu nedenle sorunlu."
            }
          ]
        }
      ]
    },
    {
