      "examples": [
        {
          "baseText": "Ohne gemeinsamen Bezugsrahmen bewertet jedes Team den Projekterfolg nach anderen Kriterien.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون إطار مرجعي مشترك يقيّم كل فريق نجاح المشروع بمعايير مختلفة."
            },
            {
              "language": "ckb",
              "text": "بەبێ چوارچێوەی هاوبەشی ئاماژە، هەر تیمێک سەرکەوتنی پڕۆژەکە بە پێوەری جیاواز هەڵدەسەنگێنێت."
            },
            {
              "language": "en",
              "text": "Without a shared frame of reference, each team evaluates project success by different criteria."
            },
            {
              "language": "fa",
              "text": "بدون چارچوب مرجع مشترک، هر تیم موفقیت پروژه را با معیارهای متفاوت ارزیابی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Bê çarçoveya referansê ya hevpar, her tîm serkeftina projeyê li gor pîvanên cuda dinirxîne."
            },
            {
              "language": "pl",
              "text": "Bez wspólnych ram odniesienia każdy zespół ocenia sukces projektu według innych kryteriów."
            },
            {
              "language": "ro",
              "text": "Fără un cadru comun de referință, fiecare echipă evaluează succesul proiectului după criterii diferite."
            },
            {
              "language": "ru",
              "text": "Без общей рамки отсчета каждая команда оценивает успех проекта по разным критериям."
            },
            {
              "language": "sq",
              "text": "Pa një kornizë të përbashkët reference, çdo ekip e vlerëson suksesin e projektit me kritere të ndryshme."
            },
            {
              "language": "tr",
              "text": "Ortak bir referans çerçevesi olmadan her ekip proje başarısını farklı ölçütlerle değerlendirir."
            }
          ]
        },
        {
          "baseText": "Der historische Bezugsrahmen hilft, die Entscheidung der damaligen Regierung besser zu verstehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يساعد الإطار التاريخي على فهم قرار الحكومة آنذاك بشكل أفضل."
            },
            {
              "language": "ckb",
              "text": "چوارچێوەی مێژوویی یارمەتی دەدات بڕیاری حکومەتی ئەوکات باشتر تێبگەین."
            },
            {
              "language": "en",
              "text": "The historical frame of reference helps us better understand the decision of the government at the time."
            },
            {
              "language": "fa",
              "text": "چارچوب تاریخی کمک می‌کند تصمیم دولت وقت را بهتر بفهمیم."
            },
            {
              "language": "kmr",
              "text": "Çarçoveya dîrokî alîkar dike ku biryara hukûmeta wê demê baştir were fêmkirin."
            },
            {
              "language": "pl",
              "text": "Historyczne ramy odniesienia pomagają lepiej zrozumieć decyzję ówczesnego rządu."
            },
            {
              "language": "ro",
              "text": "Cadrul istoric de referință ajută la înțelegerea mai bună a deciziei guvernului de atunci."
            },
            {
              "language": "ru",
              "text": "Исторический контекст помогает лучше понять решение тогдашнего правительства."
            },
            {
              "language": "sq",
              "text": "Korniza historike e referencës ndihmon të kuptohet më mirë vendimi i qeverisë së atëhershme."
            },
            {
              "language": "tr",
              "text": "Tarihsel referans çerçevesi dönemin hükümetinin kararını daha iyi anlamaya yardımcı olur."
            }
          ]
        }
