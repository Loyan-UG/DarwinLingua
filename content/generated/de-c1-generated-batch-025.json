        {
          "language": "ckb",
          "text": "هۆشیاری؛ ئاگایی"
        },
        {
          "language": "en",
          "text": "awareness; consciousness"
        },
        {
          "language": "fa",
          "text": "آگاهی؛ هوشیاری"
        },
        {
          "language": "kmr",
          "text": "hişyarî; agahî"
        },
        {
          "language": "pl",
          "text": "świadomość"
        },
        {
          "language": "ro",
          "text": "conștiință; conștientizare"
        },
        {
          "language": "ru",
          "text": "сознание; осведомленность"
        },
        {
          "language": "sq",
          "text": "vetëdije; ndërgjegjësim"
        },
        {
          "language": "tr",
          "text": "bilinç; farkındalık"
        }
      ],
      "examples": [
        {
          "baseText": "Die Schulung soll das Bewusstsein für Datenschutzrisiken im Alltag stärken.",
          "translations": [
            {
              "language": "ar",
              "text": "تهدف الدورة إلى تعزيز الوعي بمخاطر حماية البيانات في الحياة اليومية."
            },
            {
              "language": "ckb",
              "text": "ڕاهێنانەکە دەبێت هۆشیاری سەبارەت بە مەترسییەکانی پاراستنی داتا لە ڕۆژانەدا بەهێز بکات."
            },
            {
              "language": "en",
              "text": "The training is intended to strengthen awareness of data protection risks in everyday work."
            },
            {
              "language": "fa",
              "text": "آموزش قرار است آگاهی نسبت به ریسک‌های حفاظت از داده در کار روزمره را تقویت کند."
            },
            {
              "language": "kmr",
              "text": "Perwerde armanc dike hişyariya li ser xeterên parastina daneyan di karê rojane de xurt bike."
            },
            {
              "language": "pl",
              "text": "Szkolenie ma wzmocnić świadomość ryzyk związanych z ochroną danych w codziennej pracy."
            },
            {
              "language": "ro",
              "text": "Instruirea urmărește să consolideze conștientizarea riscurilor de protecție a datelor în munca zilnică."
            },
            {
              "language": "ru",
              "text": "Обучение должно повысить осведомленность о рисках защиты данных в повседневной работе."
            },
            {
              "language": "sq",
              "text": "Trajnimi synon të forcojë ndërgjegjësimin për rreziqet e mbrojtjes së të dhënave në punën e përditshme."
            },
            {
              "language": "tr",
              "text": "Eğitim, günlük işte veri koruma risklerine ilişkin farkındalığı güçlendirmeyi amaçlıyor."
            }
          ]
        },
        {
          "baseText": "In der Öffentlichkeit wächst das Bewusstsein dafür, dass bezahlbarer Wohnraum eine soziale Frage ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يزداد في الرأي العام الوعي بأن السكن الميسور قضية اجتماعية."
            },
            {
              "language": "ckb",
              "text": "لە گشتییدا هۆشیاری زیاد دەبێت کە نیشتەجێبوونی بە نرخێکی گونجاو پرسیارێکی کۆمەڵایەتییە."
            },
            {
              "language": "en",
              "text": "Public awareness is growing that affordable housing is a social issue."
            },
            {
              "language": "fa",
              "text": "در افکار عمومی آگاهی نسبت به اینکه مسکن مقرون‌به‌صرفه یک مسئله اجتماعی است رو به افزایش است."
            },
            {
              "language": "kmr",
              "text": "Di raya giştî de hişyarî zêde dibe ku xanîya bihayê guncaw pirseke civakî ye."
            },
            {
              "language": "pl",
              "text": "W opinii publicznej rośnie świadomość, że dostępne cenowo mieszkania są kwestią społeczną."
            },
            {
              "language": "ro",
              "text": "În public crește conștientizarea faptului că locuințele accesibile sunt o problemă socială."
            },
            {
              "language": "ru",
              "text": "В обществе растет понимание того, что доступное жилье является социальным вопросом."
            },
            {
              "language": "sq",
              "text": "Në publik po rritet vetëdija se banimi i përballueshëm është çështje sociale."
            },
            {
              "language": "tr",
              "text": "Kamuoyunda uygun fiyatlı konutun sosyal bir mesele olduğuna dair farkındalık artıyor."
            }
          ]
        }
