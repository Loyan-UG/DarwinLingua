      "examples": [
        {
          "baseText": "Die Binnenlogik des alten ERP-Systems ist für neue Mitarbeitende schwer nachvollziehbar.",
          "translations": [
            {
              "language": "ar",
              "text": "يصعب على الموظفين الجدد فهم المنطق الداخلي لنظام ERP القديم."
            },
            {
              "language": "ckb",
              "text": "لۆژیکی ناوخۆیی سیستەمی ERP کۆن بۆ کارمەندانی نوێ بە زەحمەت تێدەگەیەنرێت."
            },
            {
              "language": "en",
              "text": "The internal logic of the old ERP system is hard for new employees to understand."
            },
            {
              "language": "fa",
              "text": "منطق درونی سیستم ERP قدیمی برای کارکنان جدید دشوارفهم است."
            },
            {
              "language": "kmr",
              "text": "Lojiya hundirîn a pergala ERP ya kevn ji bo karmendên nû zehmet tê fêmkirin."
            },
