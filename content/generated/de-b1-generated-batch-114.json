  "entries": [
    {
      "word": "die Sachbearbeiterin",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Sachbearbeiterinnen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Sach-be-ar-bei-te-rin",
      "topics": [
        "documents-and-administration",
        "public-services",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; male form: der Sachbearbeiter"
      ],
      "collocations": [
        {
          "text": "die zuständige Sachbearbeiterin",
          "meaning": "the responsible case worker"
        },
        {
          "text": "mit der Sachbearbeiterin sprechen",
          "meaning": "to speak with the case worker"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Sachbearbeiter",
          "relationLabel": "male form",
          "note": null
        },
        {
          "lemma": "die Sachbearbeitung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موظفة مختصة؛ موظفة معالجة ملفات"
        },
        {
          "language": "ckb",
          "text": "کارمەندی ژنی بەرپرسی دۆسیە؛ مامەڵەکاری ژن"
        },
        {
          "language": "en",
          "text": "female case worker; clerk; administrator"
        },
        {
          "language": "fa",
          "text": "کارشناس پرونده زن؛ کارمند رسیدگی"
        },
        {
          "language": "kmr",
          "text": "karmenda dozê; karmenda rêvebirinê"
        },
        {
          "language": "pl",
          "text": "pracownica prowadząca sprawę; urzędniczka"
        },
        {
          "language": "ro",
          "text": "funcționară responsabilă; lucrătoare de caz"
        },
        {
          "language": "ru",
          "text": "ответственная сотрудница; специалистка по делу"
        },
        {
          "language": "sq",
          "text": "punonjëse përgjegjëse për rastin; nëpunëse"
        },
        {
          "language": "tr",
          "text": "kadın dosya sorumlusu; görevli memur"
        }
      ],
      "examples": [
        {
          "baseText": "Die Sachbearbeiterin prüft, ob alle Unterlagen vollständig sind.",
          "translations": [
            {
              "language": "ar",
              "text": "تتحقق الموظفة المختصة مما إذا كانت كل المستندات كاملة."
            },
            {
              "language": "ckb",
              "text": "کارمەندە ژنەکە دەپشکنێت ئایا هەموو بەڵگەنامەکان تەواون یان نا."
            },
            {
              "language": "en",
              "text": "The case worker checks whether all documents are complete."
            },
            {
              "language": "fa",
              "text": "کارشناس پرونده بررسی می‌کند که آیا همه مدارک کامل هستند یا نه."
            },
            {
              "language": "kmr",
              "text": "Karmenda dozê kontrol dike ka hemû belge temam in an na."
            },
            {
              "language": "pl",
              "text": "Pracownica prowadząca sprawę sprawdza, czy wszystkie dokumenty są kompletne."
            },
            {
              "language": "ro",
              "text": "Funcționara responsabilă verifică dacă toate documentele sunt complete."
            },
            {
              "language": "ru",
              "text": "Ответственная сотрудница проверяет, все ли документы полные."
            },
            {
              "language": "sq",
              "text": "Punonjësja përgjegjëse kontrollon nëse të gjitha dokumentet janë të plota."
            },
            {
              "language": "tr",
              "text": "Dosya sorumlusu tüm belgelerin eksiksiz olup olmadığını kontrol eder."
            }
          ]
        },
        {
          "baseText": "Unsere Sachbearbeiterin ruft Sie morgen wegen des Antrags zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "ستعاود موظفتنا المختصة الاتصال بكم غدًا بشأن الطلب."
            },
            {
              "language": "ckb",
              "text": "کارمەندە ژنەکەمان سبەی دەربارەی داواکارییەکە پەیوەندیتان پێوە دەکاتەوە."
            },
            {
              "language": "en",
              "text": "Our case worker will call you back tomorrow about the application."
            },
            {
              "language": "fa",
              "text": "کارشناس پرونده ما فردا درباره درخواست با شما تماس می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Karmenda me ya dozê sibê li ser daxwaznameyê telefonî we dike."
            },
            {
              "language": "pl",
              "text": "Nasza pracownica prowadząca sprawę oddzwoni do państwa jutro w sprawie wniosku."
            },
            {
              "language": "ro",
              "text": "Funcționara noastră responsabilă vă sună mâine în legătură cu cererea."
            },
            {
              "language": "ru",
              "text": "Наша специалистка по делу перезвонит вам завтра по поводу заявления."
            },
            {
              "language": "sq",
              "text": "Punonjësja jonë përgjegjëse do t’ju telefonojë nesër për kërkesën."
            },
            {
              "language": "tr",
              "text": "Dosya sorumlumuz başvuruyla ilgili yarın sizi geri arayacak."
            }
          ]
        }
      ]
    },
    {
      "word": "die Sachbearbeitung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Sach-be-ar-bei-tung",
      "topics": [
        "documents-and-administration",
        "public-services",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "written",
        "workplace"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "in der Sachbearbeitung arbeiten",
          "meaning": "to work in case processing/administration"
        },
        {
          "text": "die Sachbearbeitung dauert",
          "meaning": "case processing takes time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Sachbearbeiter",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Sachbearbeiterin",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "معالجة الملفات؛ العمل الإداري المختص"
        },
        {
          "language": "ckb",
          "text": "مامەڵەکردن بە دۆسیەکان؛ کارگێڕی دۆسیە"
        },
        {
          "language": "en",
          "text": "case processing; administrative processing"
        },
        {
          "language": "fa",
          "text": "رسیدگی اداری به پرونده؛ پردازش پرونده"
        },
        {
          "language": "kmr",
          "text": "xebitandina dozê; rêvebirina dozê"
        },
        {
          "language": "pl",
          "text": "obsługa spraw; praca administracyjna nad sprawami"
        },
        {
          "language": "ro",
          "text": "procesare administrativă; gestionarea dosarelor"
        },
        {
          "language": "ru",
          "text": "обработка дел; административное ведение дела"
        },
        {
          "language": "sq",
          "text": "përpunim rastesh; trajtim administrativ"
        },
        {
          "language": "tr",
          "text": "dosya işlemleri; idari işlem"
        }
      ],
      "examples": [
        {
          "baseText": "Die Sachbearbeitung kann wegen der vielen Anträge länger dauern.",
          "translations": [
            {
              "language": "ar",
              "text": "قد تستغرق معالجة الملفات وقتًا أطول بسبب كثرة الطلبات."
            },
            {
              "language": "ckb",
              "text": "مامەڵەکردن بە دۆسیەکان بەهۆی زۆری داواکارییەکان دەتوانێت درێژتر بخایەنێت."
            },
            {
              "language": "en",
              "text": "Case processing may take longer because of the many applications."
            },
            {
              "language": "fa",
              "text": "رسیدگی اداری به دلیل تعداد زیاد درخواست‌ها ممکن است بیشتر طول بکشد."
            },
            {
              "language": "kmr",
              "text": "Xebitandina dozê ji ber gelek daxwaznameyan dikare dirêjtir bibe."
            },
            {
              "language": "pl",
              "text": "Obsługa spraw może potrwać dłużej z powodu wielu wniosków."
            },
            {
              "language": "ro",
              "text": "Procesarea administrativă poate dura mai mult din cauza multor cereri."
            },
            {
              "language": "ru",
              "text": "Обработка дел может занять больше времени из-за большого количества заявлений."
            },
            {
              "language": "sq",
              "text": "Përpunimi i rasteve mund të zgjasë më shumë për shkak të shumë kërkesave."
            },
            {
              "language": "tr",
              "text": "Çok sayıda başvuru nedeniyle dosya işlemleri daha uzun sürebilir."
            }
          ]
        },
        {
          "baseText": "Sie arbeitet seit drei Jahren in der Sachbearbeitung.",
          "translations": [
            {
              "language": "ar",
              "text": "هي تعمل منذ ثلاث سنوات في معالجة الملفات."
            },
            {
              "language": "ckb",
              "text": "ئەو سێ ساڵە لە بەشی مامەڵەکردنی دۆسیەکان کار دەکات."
            },
            {
              "language": "en",
              "text": "She has worked in case processing for three years."
            },
            {
              "language": "fa",
              "text": "او سه سال است در بخش رسیدگی اداری کار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ew sê sal in di xebitandina dozan de dixebite."
            },
            {
              "language": "pl",
              "text": "Od trzech lat pracuje przy obsłudze spraw."
            },
            {
              "language": "ro",
              "text": "Ea lucrează de trei ani în procesarea administrativă."
            },
            {
              "language": "ru",
              "text": "Она уже три года работает в отделе обработки дел."
            },
            {
              "language": "sq",
