      "examples": [
        {
          "baseText": "Ich suche meinen Schlüssel.",
          "translations": [
            {
              "language": "ar",
              "text": "أبحث عن مفتاحي."
            },
            {
              "language": "ckb",
              "text": "بەدوای کلیلەکەمدا دەگەڕێم."
            },
            {
              "language": "en",
              "text": "I am looking for my key."
            },
            {
              "language": "fa",
              "text": "دنبال کلیدم می‌گردم."
            },
            {
              "language": "kmr",
              "text": "Ez li kilîta xwe digerim."
            },
            {
              "language": "pl",
              "text": "Szukam mojego klucza."
            },
            {
              "language": "ro",
              "text": "Îmi caut cheia."
            },
            {
              "language": "ru",
              "text": "Я ищу свой ключ."
            },
            {
              "language": "sq",
              "text": "Po kërkoj çelësin tim."
            },
            {
              "language": "tr",
              "text": "Anahtarımı arıyorum."
            }
          ]
        },
        {
          "baseText": "Suchen Sie ein Zimmer?",
          "translations": [
            {
              "language": "ar",
              "text": "هل تبحث عن غرفة؟"
            },
            {
              "language": "ckb",
              "text": "بەدوای ژوورێکدا دەگەڕێیت؟"
            },
            {
              "language": "en",
              "text": "Are you looking for a room?"
            },
            {
              "language": "fa",
              "text": "دنبال اتاق می‌گردید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn li odeyekê digerin?"
            },
            {
              "language": "pl",
              "text": "Czy szuka pan/pani pokoju?"
            },
            {
              "language": "ro",
              "text": "Căutați o cameră?"
            },
            {
              "language": "ru",
              "text": "Вы ищете комнату?"
            },
            {
              "language": "sq",
              "text": "A po kërkoni një dhomë?"
            },
            {
              "language": "tr",
              "text": "Bir oda mı arıyorsunuz?"
            }
          ]
        }
