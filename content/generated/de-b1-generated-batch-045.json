  "entries": [
    {
      "word": "eigentlich",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ei-gent-lich",
      "topics": [
        "everyday-life",
        "business-communication",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "administration",
        "customer-service"
      ],
      "grammarNotes": [
        "adverb; often softens a question or contrasts with expectations"
      ],
      "collocations": [
        {
          "text": "Was meinst du eigentlich?",
          "meaning": "What do you actually mean?"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "eigen",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "في الحقيقة؛ في الواقع؛ أصلاً"
        },
        {
          "language": "ckb",
          "text": "لە ڕاستیدا؛ بەڕاستی"
        },
        {
          "language": "en",
          "text": "actually; really; in fact"
        },
        {
          "language": "fa",
          "text": "در واقع؛ راستش؛ اصلاً"
        },
        {
          "language": "kmr",
          "text": "bi rastî; di rastiyê de"
        },
        {
          "language": "pl",
          "text": "właściwie; tak naprawdę"
        },
        {
          "language": "ro",
          "text": "de fapt; în realitate"
        },
        {
          "language": "ru",
          "text": "собственно; на самом деле"
        },
        {
          "language": "sq",
          "text": "në fakt; realisht"
        },
        {
          "language": "tr",
          "text": "aslında; gerçekten"
        }
      ],
      "examples": [
        {
          "baseText": "Was genau brauchen Sie eigentlich für die Anmeldung?",
          "translations": [
            {
              "language": "ar",
              "text": "ما الذي تحتاجه بالضبط في الحقيقة للتسجيل؟"
            },
            {
              "language": "ckb",
              "text": "لە ڕاستیدا بۆ تۆمارکردن چی بە وردی پێویستتانە؟"
            },
            {
              "language": "en",
              "text": "What exactly do you actually need for the registration?"
            },
            {
              "language": "fa",
              "text": "در واقع دقیقاً برای ثبت‌نام به چه چیزی نیاز دارید؟"
            },
            {
              "language": "kmr",
              "text": "Bi rastî ji bo qeydkirinê hûn rastî çi hewce ne?"
            },
            {
              "language": "pl",
              "text": "Czego właściwie dokładnie potrzebuje Pan/Pani do rejestracji?"
            },
            {
              "language": "ro",
              "text": "De fapt, de ce aveți nevoie exact pentru înscriere?"
            },
            {
              "language": "ru",
              "text": "Что именно вам, собственно, нужно для регистрации?"
            },
            {
              "language": "sq",
              "text": "Çfarë ju duhet saktësisht në fakt për regjistrimin?"
            },
            {
              "language": "tr",
              "text": "Kayıt için aslında tam olarak neye ihtiyacınız var?"
            }
          ]
        },
        {
          "baseText": "Ich wollte eigentlich früher gehen, aber das Meeting hat länger gedauert.",
          "translations": [
            {
              "language": "ar",
              "text": "كنت أريد في الحقيقة أن أغادر أبكر، لكن الاجتماع استغرق وقتًا أطول."
            },
            {
              "language": "ckb",
              "text": "لە ڕاستیدا دەمویست زووتر بچم، بەڵام کۆبوونەوەکە زیاتر خایاند."
            },
            {
              "language": "en",
              "text": "I actually wanted to leave earlier, but the meeting took longer."
            },
            {
              "language": "fa",
              "text": "راستش می‌خواستم زودتر بروم، اما جلسه بیشتر طول کشید."
            },
            {
              "language": "kmr",
              "text": "Bi rastî min dixwest zûtir biçim, lê civîn dirêjtir ajot."
            },
            {
              "language": "pl",
              "text": "Właściwie chciałem wyjść wcześniej, ale spotkanie trwało dłużej."
            },
            {
              "language": "ro",
              "text": "De fapt, voiam să plec mai devreme, dar ședința a durat mai mult."
            },
            {
              "language": "ru",
              "text": "Вообще-то я хотел уйти раньше, но встреча длилась дольше."
            },
            {
              "language": "sq",
              "text": "Në fakt doja të largohesha më herët, por takimi zgjati më shumë."
            },
            {
              "language": "tr",
              "text": "Aslında daha erken çıkmak istiyordum ama toplantı daha uzun sürdü."
            }
          ]
        }
      ]
    },
    {
      "word": "einbrechen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "einbrechen",
      "pronunciationIpa": null,
      "syllableBreak": "ein-bre-chen",
      "topics": [
        "law-and-compliance",
        "housing-and-real-estate",
        "quality-and-risk"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "formal"
      ],
      "contextLabels": [
        "security",
        "administration"
      ],
      "grammarNotes": [
        "separable strong verb: bricht ein, brach ein, ist eingebrochen; can also mean to drop sharply"
      ],
      "collocations": [
        {
          "text": "in eine Wohnung einbrechen",
          "meaning": "to break into an apartment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Einbruch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقتحم؛ ينخفض بشدة"
        },
        {
          "language": "ckb",
          "text": "شکانە ناو؛ دابەزینی توند"
        },
        {
          "language": "en",
          "text": "to break in; to drop sharply"
        },
        {
          "language": "fa",
          "text": "دستبرد زدن؛ به شدت افت کردن"
        },
        {
          "language": "kmr",
          "text": "bi zorê ketin hundir; bi tundî daketin"
        },
        {
          "language": "pl",
          "text": "włamać się; gwałtownie spaść"
        },
        {
          "language": "ro",
          "text": "a sparge; a scădea brusc"
        },
        {
          "language": "ru",
          "text": "взламывать; резко падать"
        },
        {
          "language": "sq",
          "text": "të thyesh për të hyrë; të bjerë ndjeshëm"
        },
        {
          "language": "tr",
          "text": "zorla girmek; sert düşmek"
        }
      ],
      "examples": [
        {
          "baseText": "Am Wochenende ist jemand in das Büro eingebrochen.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع اقتحم شخص ما المكتب."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا کەسێک شکاوەتە ناو ئۆفیسەکە."
            },
            {
              "language": "en",
              "text": "Someone broke into the office at the weekend."
            },
            {
              "language": "fa",
              "text": "آخر هفته کسی به دفتر دستبرد زده است."
            },
            {
              "language": "kmr",
              "text": "Dawiya hefteyê kesek bi zorê ketiye nivîsgehê."
            },
            {
              "language": "pl",
              "text": "W weekend ktoś włamał się do biura."
            },
            {
              "language": "ro",
