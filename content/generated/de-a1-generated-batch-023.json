          ]
        },
        {
          "baseText": "Wir danken für Ihre Hilfe.",
          "translations": [
            {
              "language": "ar",
              "text": "نشكرك على مساعدتك."
            },
            {
              "language": "ckb",
              "text": "سوپاس بۆ یارمەتیتان."
            },
            {
              "language": "en",
              "text": "We thank you for your help."
            },
            {
              "language": "fa",
              "text": "از کمک شما تشکر می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em ji bo alîkariya we spas dikin."
            },
            {
              "language": "pl",
              "text": "Dziękujemy za pomoc."
            },
            {
              "language": "ro",
              "text": "Vă mulțumim pentru ajutor."
            },
            {
              "language": "ru",
              "text": "Мы благодарим вас за помощь."
            },
            {
              "language": "sq",
              "text": "Ju falënderojmë për ndihmën tuaj."
            },
            {
              "language": "tr",
              "text": "Yardımınız için teşekkür ederiz."
            }
          ]
        }
      ]
