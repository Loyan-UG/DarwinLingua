  "entries": [
    {
      "word": "zusammenbringen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "zusammenbringen",
      "pronunciationIpa": null,
      "syllableBreak": "zu-sam-men-brin-gen",
      "topics": [
        "meetings-and-presentations",
        "management-and-leadership",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "management",
        "training",
        "customer-service"
      ],
      "grammarNotes": [
        "separable verb",
        "means to bring people, ideas, or information together"
      ],
      "collocations": [
        {
          "text": "Menschen zusammenbringen",
          "meaning": "to bring people together"
        },
        {
          "text": "Informationen zusammenbringen",
          "meaning": "to combine information"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zusammen",
          "relationLabel": "adverb",
          "note": null
        },
        {
          "lemma": "bringen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يجمع؛ يقرّب بين أشخاص أو أفكار"
        },
        {
          "language": "ckb",
          "text": "کۆکردنەوە؛ نزیککردنەوەی کەسان یان بیرۆکەکان"
        },
        {
          "language": "en",
          "text": "to bring together; to combine"
        },
        {
          "language": "fa",
          "text": "گرد هم آوردن؛ کنار هم قرار دادن"
        },
        {
          "language": "kmr",
          "text": "li hev anîn; kom kirin"
        },
        {
          "language": "pl",
          "text": "połączyć; zgromadzić; zbliżyć do siebie"
        },
        {
          "language": "ro",
          "text": "a aduce împreună; a combina"
        },
        {
          "language": "ru",
          "text": "сводить вместе; объединять; сопоставлять"
        },
        {
          "language": "sq",
          "text": "të bashkosh; të sjellësh së bashku"
        },
        {
          "language": "tr",
          "text": "bir araya getirmek; birleştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Workshop soll Vertrieb und Support zusammenbringen, damit beide Teams die Kundenprobleme besser verstehen.",
          "translations": [
            {
              "language": "ar",
              "text": "تهدف ورشة العمل إلى جمع فريقي المبيعات والدعم حتى يفهم الفريقان مشكلات العملاء بشكل أفضل."
            },
            {
              "language": "ckb",
              "text": "وۆرکشۆپەکە دەبێت تیمی فرۆشتن و پاڵپشتی کۆبکاتەوە، بۆ ئەوەی هەردوو تیم کێشەکانی کڕیار باشتر تێبگەن."
            },
            {
              "language": "en",
              "text": "The workshop is meant to bring sales and support together so both teams understand customer problems better."
            },
            {
              "language": "fa",
              "text": "هدف کارگاه این است که فروش و پشتیبانی را کنار هم بیاورد تا هر دو تیم مشکلات مشتریان را بهتر بفهمند."
            },
            {
              "language": "kmr",
              "text": "Armanca workshopê ew e ku firotan û piştgirî li hev bîne da ku her du tîm pirsgirêkên xerîdaran baştir fam bikin."
            },
            {
              "language": "pl",
              "text": "Warsztat ma połączyć sprzedaż i wsparcie, aby oba zespoły lepiej rozumiały problemy klientów."
            },
            {
              "language": "ro",
              "text": "Atelierul trebuie să aducă împreună vânzările și suportul, astfel încât ambele echipe să înțeleagă mai bine problemele clienților."
            },
            {
              "language": "ru",
              "text": "Воркшоп должен объединить отдел продаж и поддержку, чтобы обе команды лучше понимали проблемы клиентов."
            },
            {
              "language": "sq",
              "text": "Punëtoria duhet të bashkojë shitjet dhe mbështetjen, që të dy ekipet t’i kuptojnë më mirë problemet e klientëve."
            },
            {
              "language": "tr",
              "text": "Atölye, satış ve destek ekiplerini bir araya getirerek her iki ekibin müşteri sorunlarını daha iyi anlamasını sağlamalı."
            }
          ]
        },
        {
          "baseText": "Die neue Kollegin bringt viel Erfahrung und frische Ideen zusammen.",
          "translations": [
            {
              "language": "ar",
              "text": "تجمع الزميلة الجديدة بين خبرة كبيرة وأفكار جديدة."
            },
            {
              "language": "ckb",
              "text": "هاوکارە نوێیەکە ئەزموونی زۆر و بیرۆکەی تازە پێکەوە دەهێنێت."
            },
            {
              "language": "en",
              "text": "The new colleague combines a lot of experience with fresh ideas."
            },
            {
              "language": "fa",
              "text": "همکار جدید تجربه زیاد را با ایده‌های تازه ترکیب می‌کند."
            },
            {
              "language": "kmr",
              "text": "Hevkarê nû gelek ezmûn û ramana nû li hev tîne."
            },
            {
              "language": "pl",
              "text": "Nowa koleżanka łączy duże doświadczenie ze świeżymi pomysłami."
            },
            {
              "language": "ro",
              "text": "Noua colegă combină multă experiență cu idei proaspete."
            },
            {
              "language": "ru",
              "text": "Новая коллега сочетает большой опыт со свежими идеями."
            },
            {
              "language": "sq",
              "text": "Kolegia e re bashkon shumë përvojë me ide të freskëta."
            },
            {
              "language": "tr",
