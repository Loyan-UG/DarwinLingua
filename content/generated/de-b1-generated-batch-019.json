  "entries": [
    {
      "word": "der Ausbildungsplatz",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Ausbildungsplätze",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Aus-bil-dungs-platz",
      "topics": [
        "education-and-training",
        "work-and-jobs",
        "human-resources"
      ],
      "usageLabels": [
        "formal",
        "business",
        "spoken"
      ],
      "contextLabels": [
        "training",
        "hr"
      ],
      "grammarNotes": [
        "masculine noun",
        "vocational training position"
      ],
      "collocations": [
        {
          "text": "einen Ausbildungsplatz suchen",
          "meaning": "to look for a training position"
        },
        {
          "text": "sich um einen Ausbildungsplatz bewerben",
          "meaning": "to apply for a training position"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Ausbildung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "ausbilden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مكان تدريب مهني؛ فرصة تدريب"
        },
        {
          "language": "ckb",
          "text": "شوێنی فێرکاری پیشەیی"
        },
        {
          "language": "en",
          "text": "vocational training position; apprenticeship place"
        },
        {
          "language": "fa",
          "text": "جایگاه آموزش حرفه‌ای؛ موقعیت کارآموزی"
        },
        {
          "language": "kmr",
          "text": "cihê perwerdehiya pîşeyî"
        },
        {
          "language": "pl",
          "text": "miejsce szkolenia zawodowego; praktyka"
        },
        {
          "language": "ro",
          "text": "loc de formare profesională"
        },
        {
          "language": "ru",
          "text": "место профессионального обучения; место ученика"
        },
        {
          "language": "sq",
          "text": "vend për formim profesional"
        },
        {
          "language": "tr",
          "text": "mesleki eğitim yeri; çıraklık pozisyonu"
        }
      ],
      "examples": [
        {
          "baseText": "Viele Jugendliche suchen schon im Frühjahr einen Ausbildungsplatz.",
          "translations": [
            {
              "language": "ar",
              "text": "يبحث كثير من الشباب عن مكان تدريب مهني منذ الربيع."
            },
            {
              "language": "ckb",
              "text": "زۆر گەنج هەر لە بەهارەوە بەدوای شوێنی فێرکاری پیشەییدا دەگەڕێن."
            },
            {
              "language": "en",
              "text": "Many young people start looking for a training position in spring."
            },
            {
              "language": "fa",
              "text": "بسیاری از جوانان از بهار به دنبال موقعیت آموزش حرفه‌ای می‌گردند."
            },
            {
              "language": "kmr",
              "text": "Gelek ciwan ji biharê ve li cihê perwerdehiya pîşeyî digerin."
            },
            {
              "language": "pl",
              "text": "Wielu młodych ludzi już wiosną szuka miejsca szkolenia zawodowego."
            },
            {
              "language": "ro",
              "text": "Mulți tineri caută un loc de formare profesională încă din primăvară."
            },
            {
              "language": "ru",
              "text": "Многие молодые люди уже весной ищут место профессионального обучения."
            },
            {
              "language": "sq",
              "text": "Shumë të rinj kërkojnë një vend trajnimi profesional që në pranverë."
            },
            {
              "language": "tr",
              "text": "Birçok genç daha ilkbaharda mesleki eğitim yeri arar."
            }
          ]
        },
        {
          "baseText": "Die Firma bietet ab August zwei neue Ausbildungsplätze im IT-Bereich an.",
          "translations": [
            {
              "language": "ar",
              "text": "تقدم الشركة اعتبارًا من أغسطس مكانين جديدين للتدريب المهني في مجال تكنولوجيا المعلومات."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە لە ئابەوە دوو شوێنی نوێی فێرکاری پیشەیی لە بواری IT پێشکەش دەکات."
            },
            {
              "language": "en",
              "text": "Starting in August, the company is offering two new training positions in IT."
            },
            {
              "language": "fa",
              "text": "شرکت از ماه اوت دو موقعیت آموزش حرفه‌ای جدید در حوزه IT ارائه می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Şirket ji Tebaxê ve du cihên nû yên perwerdehiya pîşeyî di warê IT de pêşkêş dike."
            },
            {
              "language": "pl",
              "text": "Firma od sierpnia oferuje dwa nowe miejsca szkolenia w dziale IT."
            },
            {
              "language": "ro",
              "text": "Compania oferă din august două noi locuri de formare în domeniul IT."
            },
            {
              "language": "ru",
              "text": "С августа компания предлагает два новых места обучения в сфере IT."
            },
            {
              "language": "sq",
              "text": "Kompania ofron nga gushti dy vende të reja trajnimi në fushën e IT-së."
            },
            {
              "language": "tr",
              "text": "Şirket ağustostan itibaren IT alanında iki yeni mesleki eğitim pozisyonu sunuyor."
            }
          ]
        }
      ]
    },
    {
      "word": "ausdenken",
