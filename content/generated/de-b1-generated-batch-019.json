      "meanings": [
        {
          "language": "ar",
          "text": "يبتكر؛ يفكر في شيء؛ يختلق"
        },
        {
          "language": "ckb",
          "text": "داهێنان؛ بیرکردنەوە لە چارەسەر؛ هەڵبەستن"
        },
        {
          "language": "en",
          "text": "to think up; to come up with; to invent"
        },
        {
          "language": "fa",
