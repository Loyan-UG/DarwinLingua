      "examples": [
        {
          "baseText": "Die Rechnungsposition enthält im ERP Menge, Einzelpreis und Steuerkennzeichen.",
          "translations": [
            {
              "language": "ar",
              "text": "تحتوي بند الفاتورة في ERP على الكمية وسعر الوحدة ورمز الضريبة."
            },
            {
              "language": "ckb",
              "text": "بڕگەی فاکتورە لە ERP دا بڕ، نرخی تاک و نیشانەی باج لەخۆدەگرێت."
            },
            {
              "language": "en",
              "text": "The invoice line item in the ERP contains quantity, unit price, and tax code."
            },
            {
              "language": "fa",
              "text": "ردیف فاکتور در ERP شامل مقدار، قیمت واحد و کد مالیات است."
