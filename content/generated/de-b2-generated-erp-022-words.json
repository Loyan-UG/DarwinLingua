      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter compound noun; measuring or testing equipment used in quality control"
      ],
      "collocations": [
        {
          "text": "ein Prüfmittel kalibrieren",
          "meaning": "to calibrate testing equipment"
        },
        {
          "text": "Prüfmittel verwalten",
          "meaning": "to manage testing equipment"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "prüfen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "das Mittel",
          "relationLabel": "component noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أداة فحص؛ وسيلة اختبار"
        },
        {
          "language": "ckb",
          "text": "ئامرازی پشکنین"
        },
        {
          "language": "en",
          "text": "inspection equipment; testing device"
        },
        {
          "language": "fa",
          "text": "ابزار آزمون؛ وسیله بازرسی"
        },
        {
          "language": "kmr",
          "text": "amûra kontrolê"
        },
        {
          "language": "pl",
          "text": "przyrząd kontrolny"
        },
        {
          "language": "ro",
          "text": "echipament de inspecție"
        },
        {
          "language": "ru",
          "text": "средство контроля"
        },
        {
          "language": "sq",
          "text": "mjet kontrolli"
        },
        {
          "language": "tr",
          "text": "kontrol ekipmanı"
        }
      ],
      "examples": [
        {
          "baseText": "Das Prüfmittel ist im ERP gesperrt, weil die Kalibrierung abgelaufen ist.",
          "translations": [
            {
              "language": "ar",
              "text": "أداة الفحص محظورة في ERP لأن المعايرة انتهت صلاحيتها."
            },
            {
              "language": "ckb",
              "text": "ئامرازی پشکنین لە ERP دا قەدەغەیە چونکە کالیبراسیۆنەکە بەسەرچووە."
            },
            {
              "language": "en",
              "text": "The testing device is blocked in the ERP because its calibration has expired."
            },
            {
              "language": "fa",
              "text": "ابزار آزمون در ERP مسدود است، چون کالیبراسیون آن منقضی شده است."
            },
            {
              "language": "kmr",
              "text": "Amûra kontrolê di ERP de astengkirî ye, ji ber ku kalîbrasyona wê qediyaye."
            },
            {
              "language": "pl",
              "text": "Przyrząd kontrolny jest zablokowany w ERP, ponieważ kalibracja wygasła."
            },
            {
              "language": "ro",
              "text": "Echipamentul de inspecție este blocat în ERP deoarece calibrarea a expirat."
            },
            {
              "language": "ru",
              "text": "Средство контроля заблокировано в ERP, потому что срок калибровки истек."
            },
            {
              "language": "sq",
              "text": "Mjeti i kontrollit është i bllokuar në ERP sepse kalibrimi ka skaduar."
            },
            {
              "language": "tr",
              "text": "Kontrol ekipmanı ERP’de bloke, çünkü kalibrasyonu süresi dolmuş."
            }
          ]
        },
        {
          "baseText": "Die Qualitätssicherung nutzt dieses Prüfmittel für die Endkontrolle der Baugruppe.",
          "translations": [
            {
              "language": "ar",
              "text": "تستخدم إدارة الجودة أداة الفحص هذه للفحص النهائي للمجموعة التركيبية."
            },
            {
              "language": "ckb",
              "text": "دڵنیایی کوالیتی ئەم ئامرازی پشکنینە بۆ کۆنترۆڵی کۆتایی گرووپی پێکهاتە بەکاردەهێنێت."
            },
            {
              "language": "en",
              "text": "Quality assurance uses this testing device for the final inspection of the assembly."
            },
            {
              "language": "fa",
              "text": "تضمین کیفیت از این ابزار آزمون برای کنترل نهایی مجموعه قطعات استفاده می‌کند."
            },
            {
              "language": "kmr",
              "text": "Ewlekariya kalîteyê vê amûra kontrolê ji bo kontrola dawî ya koma parçeyan bi kar tîne."
            },
            {
              "language": "pl",
              "text": "Dział jakości używa tego przyrządu kontrolnego do kontroli końcowej podzespołu."
            },
            {
              "language": "ro",
              "text": "Asigurarea calității folosește acest echipament pentru controlul final al ansamblului."
            },
            {
              "language": "ru",
              "text": "Отдел качества использует это средство контроля для финальной проверки узла."
            },
            {
              "language": "sq",
              "text": "Sigurimi i cilësisë e përdor këtë mjet kontrolli për kontrollin final të asamblesë."
            },
            {
              "language": "tr",
              "text": "Kalite güvence bu kontrol ekipmanını montaj grubunun son kontrolü için kullanır."
            }
          ]
        }
      ]
    },
    {
      "word": "Rechnung erzeugen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "Rechnung erzeugen",
      "pronunciationIpa": null,
      "syllableBreak": "Rech-nung er-zeu-gen",
      "topics": [
        "finance-and-accounting",
        "erp-and-business-systems",
        "sales-and-customers"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "process",
        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "verb phrase used in ERP workflows; means to generate an invoice"
      ],
      "collocations": [
        {
          "text": "automatisch eine Rechnung erzeugen",
          "meaning": "to automatically generate an invoice"
        },
        {
          "text": "aus dem Auftrag eine Rechnung erzeugen",
          "meaning": "to generate an invoice from the order"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Rechnung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "erzeugen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إنشاء فاتورة"
        },
        {
          "language": "ckb",
          "text": "دروستکردنی فاکتورە"
        },
        {
          "language": "en",
          "text": "to generate an invoice"
        },
        {
          "language": "fa",
          "text": "ایجاد فاکتور"
        },
        {
          "language": "kmr",
          "text": "fatûreyê çêkirin"
        },
        {
          "language": "pl",
          "text": "wygenerować fakturę"
        },
        {
          "language": "ro",
          "text": "a genera o factură"
        },
        {
          "language": "ru",
          "text": "создать счет"
        },
        {
          "language": "sq",
          "text": "të krijosh faturë"
        },
        {
          "language": "tr",
          "text": "fatura oluşturmak"
        }
      ],
      "examples": [
        {
          "baseText": "Das ERP kann die Rechnung erzeugen, sobald der Lieferschein gebucht wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن لنظام ERP إنشاء الفاتورة بمجرد ترحيل سند التسليم."
            },
            {
              "language": "ckb",
              "text": "ERP دەتوانێت فاکتورە دروست بکات هەر کات پسوڵەی گەیاندن تۆمار کرا."
            },
            {
              "language": "en",
              "text": "The ERP can generate the invoice as soon as the delivery note has been posted."
            },
            {
              "language": "fa",
              "text": "ERP می‌تواند به‌محض ثبت برگه تحویل، فاکتور ایجاد کند."
            },
            {
              "language": "kmr",
              "text": "ERP dikare fatûreyê çêbike dema belgeya radestkirinê hatibe tomarkirin."
            },
            {
              "language": "pl",
              "text": "ERP może wygenerować fakturę, gdy tylko dokument dostawy zostanie zaksięgowany."
            },
            {
              "language": "ro",
              "text": "ERP poate genera factura imediat ce avizul de livrare a fost înregistrat."
            },
            {
              "language": "ru",
              "text": "ERP может создать счет, как только накладная будет проведена."
            },
            {
              "language": "sq",
              "text": "ERP mund ta krijojë faturën sapo fletëdorëzimi të jetë regjistruar."
            },
            {
              "language": "tr",
              "text": "ERP teslimat belgesi kaydedilir edilmez faturayı oluşturabilir."
            }
          ]
        },
        {
          "baseText": "Bitte erzeugen Sie die Rechnung erst, wenn der Kunde die geänderte Menge bestätigt hat.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إنشاء الفاتورة فقط بعد أن يؤكد العميل الكمية المعدلة."
            },
            {
              "language": "ckb",
              "text": "تکایە فاکتورەکە تەنها کاتێک دروست بکەن کە کڕیار بڕی گۆڕاو پشتڕاست بکاتەوە."
            },
            {
              "language": "en",
              "text": "Please generate the invoice only after the customer has confirmed the changed quantity."
            },
            {
              "language": "fa",
              "text": "لطفاً فاکتور را فقط وقتی ایجاد کنید که مشتری مقدار تغییر کرده را تأیید کرده باشد."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fatûreyê tenê dema çêbikin ku mişterî hejmara guhertî piştrast kiribe."
            },
            {
              "language": "pl",
              "text": "Proszę wygenerować fakturę dopiero po potwierdzeniu zmienionej ilości przez klienta."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să generați factura doar după ce clientul a confirmat cantitatea modificată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, создавайте счет только после того, как клиент подтвердит измененное количество."
            },
            {
              "language": "sq",
              "text": "Ju lutemi krijoni faturën vetëm pasi klienti të ketë konfirmuar sasinë e ndryshuar."
            },
            {
              "language": "tr",
              "text": "Lütfen faturayı ancak müşteri değişen miktarı onayladıktan sonra oluşturun."
            }
          ]
        }
      ]
    },
