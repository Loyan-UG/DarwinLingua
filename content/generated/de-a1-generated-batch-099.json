          "meaning": "a male relative from Berlin"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verwandt",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قريب؛ أحد الأقارب"
        },
        {
          "language": "ckb",
          "text": "خزم"
        },
        {
          "language": "en",
          "text": "male relative; relative"
        },
        {
          "language": "fa",
          "text": "خویشاوند؛ فامیل"
        },
        {
          "language": "kmr",
          "text": "xizm"
        },
        {
          "language": "pl",
          "text": "krewny"
        },
        {
          "language": "ro",
          "text": "rudă"
        },
        {
          "language": "ru",
          "text": "родственник"
        },
        {
          "language": "sq",
          "text": "i afërm"
        },
        {
          "language": "tr",
          "text": "akraba"
        }
      ],
      "examples": [
        {
          "baseText": "Ein Verwandter besucht uns heute.",
          "translations": [
            {
              "language": "ar",
              "text": "سيزورنا قريب اليوم."
            },
            {
              "language": "ckb",
              "text": "خزمێک ئەمڕۆ سەردانمان دەکات."
            },
            {
              "language": "en",
              "text": "A relative is visiting us today."
            },
            {
              "language": "fa",
              "text": "یک خویشاوند امروز به دیدن ما می‌آید."
            },
            {
              "language": "kmr",
              "text": "Xizmek îro serdana me dike."
            },
            {
              "language": "pl",
              "text": "Dziś odwiedza nas krewny."
            },
            {
              "language": "ro",
              "text": "O rudă ne vizitează astăzi."
            },
            {
              "language": "ru",
              "text": "Сегодня нас навещает родственник."
            },
            {
              "language": "sq",
              "text": "Një i afërm na viziton sot."
            },
            {
              "language": "tr",
              "text": "Bugün bir akrabamız bizi ziyaret ediyor."
            }
          ]
        },
        {
          "baseText": "Der Verwandte wohnt in Hamburg.",
          "translations": [
            {
              "language": "ar",
              "text": "القريب يسكن في هامبورغ."
            },
            {
              "language": "ckb",
              "text": "خزمەکە لە هامبۆرگ دەژیت."
            },
            {
              "language": "en",
              "text": "The relative lives in Hamburg."
            },
            {
              "language": "fa",
              "text": "آن خویشاوند در هامبورگ زندگی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Xizm li Hamburgê dijî."
            },
            {
              "language": "pl",
              "text": "Krewny mieszka w Hamburgu."
            },
            {
              "language": "ro",
              "text": "Ruda locuiește în Hamburg."
            },
            {
              "language": "ru",
              "text": "Родственник живёт в Гамбурге."
            },
            {
              "language": "sq",
              "text": "I afërmi jeton në Hamburg."
            },
            {
              "language": "tr",
              "text": "Akraba Hamburg’da yaşıyor."
            }
          ]
        }
      ]
    },
