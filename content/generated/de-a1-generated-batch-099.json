            {
              "language": "en",
              "text": "That costs a lot of money."
            },
            {
              "language": "fa",
              "text": "این پول زیادی هزینه دارد."
            },
            {
              "language": "kmr",
              "text": "Ev pir pere dixwaze."
            },
            {
              "language": "pl",
              "text": "To kosztuje dużo pieniędzy."
            },
            {
              "language": "ro",
              "text": "Asta costă mulți bani."
            },
            {
              "language": "ru",
              "text": "Это стоит много денег."
            },
            {
              "language": "sq",
              "text": "Kjo kushton shumë para."
            },
            {
              "language": "tr",
              "text": "Bu çok para tutuyor."
            }
          ]
        }
      ]
