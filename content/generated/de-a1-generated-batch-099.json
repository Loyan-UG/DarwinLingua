      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفهم"
        },
        {
          "language": "ckb",
          "text": "تێگەیشتن"
        },
        {
          "language": "en",
          "text": "to understand"
        },
        {
          "language": "fa",
          "text": "فهمیدن؛ متوجه شدن"
        },
        {
          "language": "kmr",
          "text": "fêm kirin"
        },
        {
          "language": "pl",
          "text": "rozumieć"
        },
        {
          "language": "ro",
          "text": "a înțelege"
        },
        {
          "language": "ru",
          "text": "понимать"
        },
        {
          "language": "sq",
          "text": "kuptoj"
        },
        {
          "language": "tr",
          "text": "anlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich verstehe die Frage.",
          "translations": [
            {
              "language": "ar",
              "text": "أفهم السؤال."
            },
            {
              "language": "ckb",
              "text": "پرسیارەکە تێدەگەم."
            },
            {
              "language": "en",
              "text": "I understand the question."
            },
            {
              "language": "fa",
              "text": "سؤال را می‌فهمم."
            },
            {
              "language": "kmr",
              "text": "Ez pirsê fêm dikim."
            },
            {
              "language": "pl",
              "text": "Rozumiem pytanie."
            },
            {
              "language": "ro",
              "text": "Înțeleg întrebarea."
            },
            {
              "language": "ru",
              "text": "Я понимаю вопрос."
            },
            {
              "language": "sq",
              "text": "E kuptoj pyetjen."
            },
            {
              "language": "tr",
              "text": "Soruyu anlıyorum."
            }
          ]
        },
        {
          "baseText": "Können Sie mich verstehen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك فهمي؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانن لێم تێبگەن؟"
            },
            {
              "language": "en",
              "text": "Can you understand me?"
            },
            {
              "language": "fa",
              "text": "می‌توانید حرفم را بفهمید؟"
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin min fêm bikin?"
            },
            {
              "language": "pl",
              "text": "Czy może mnie pan/pani zrozumieć?"
            },
            {
              "language": "ro",
              "text": "Mă puteți înțelege?"
            },
            {
              "language": "ru",
              "text": "Вы можете меня понять?"
            },
            {
              "language": "sq",
              "text": "A mund të më kuptoni?"
            },
            {
              "language": "tr",
              "text": "Beni anlayabiliyor musunuz?"
            }
          ]
        }
      ]
    },
