          "baseText": "Vielleicht komme ich später.",
          "translations": [
            {
              "language": "ar",
              "text": "ربما آتي لاحقًا."
            },
            {
              "language": "ckb",
              "text": "لەوانەیە دواتر بێم."
            },
            {
              "language": "en",
              "text": "Maybe I will come later."
            },
            {
              "language": "fa",
              "text": "شاید بعداً بیایم."
            },
            {
              "language": "kmr",
              "text": "Dibe ku ez paşê bêm."
            },
            {
              "language": "pl",
              "text": "Może przyjdę później."
            },
            {
              "language": "ro",
              "text": "Poate vin mai târziu."
            },
            {
              "language": "ru",
              "text": "Может быть, я приду позже."
            },
            {
              "language": "sq",
              "text": "Ndoshta vij më vonë."
            },
            {
              "language": "tr",
              "text": "Belki daha sonra gelirim."
            }
          ]
        },
        {
          "baseText": "Vielleicht ist der Termin morgen.",
          "translations": [
            {
              "language": "ar",
              "text": "ربما الموعد غدًا."
            },
