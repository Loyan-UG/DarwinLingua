  "entries": [
    {
      "word": "umwerfen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "umwerfen",
      "pronunciationIpa": null,
      "syllableBreak": "um-wer-fen",
      "topics": [
        "planning-and-projects",
        "everyday-life",
        "quality-and-risk"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "management",
        "risk"
      ],
      "grammarNotes": [
        "separable irregular verb: wirft um, warf um, hat umgeworfen; literal or figurative"
      ],
      "collocations": [
        {
          "text": "den Zeitplan umwerfen",
          "meaning": "to throw off the schedule"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "werfen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يقلب؛ يربك خطة"
        },
        {
          "language": "ckb",
          "text": "دەیخاتە خوارەوە؛ پلان تێکدەدات"
        },
        {
          "language": "en",
          "text": "to knock over; to disrupt a plan"
        },
        {
          "language": "fa",
          "text": "واژگون کردن؛ برنامه را به هم زدن"
        },
        {
          "language": "kmr",
          "text": "xistin; planek tevlihev kirin"
        },
        {
          "language": "pl",
          "text": "przewrócić; wywrócić plan"
        },
        {
          "language": "ro",
          "text": "a răsturna; a da peste cap un plan"
        },
        {
          "language": "ru",
          "text": "опрокинуть; сорвать план"
        },
        {
          "language": "sq",
          "text": "ta rrëzosh; ta prishësh planin"
        },
        {
          "language": "tr",
          "text": "devirmek; planı bozmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die kurzfristige Absage des Kunden hat unseren Zeitplan völlig umgeworfen.",
          "translations": [
            {
              "language": "ar",
              "text": "ألغى العميل الموعد في وقت قصير، مما قلب جدولنا بالكامل."
            },
            {
              "language": "ckb",
              "text": "هەڵوەشاندنەوەی کورتخایەنی کڕیارەکە خشتەی کاتمان بە تەواوی تێکدا."
            },
            {
              "language": "en",
              "text": "The customer’s short-notice cancellation completely threw off our schedule."
            },
            {
              "language": "fa",
              "text": "لغو ناگهانی مشتری برنامه زمانی ما را کاملاً به هم زد."
            },
            {
              "language": "kmr",
              "text": "Betalkirina lezgîn a xerîdar plana demê ya me bi tevahî tevlihev kir."
            },
            {
              "language": "pl",
              "text": "Nagłe odwołanie przez klienta całkowicie wywróciło nasz harmonogram."
            },
            {
              "language": "ro",
              "text": "Anularea de scurtă durată a clientului ne-a dat complet peste cap calendarul."
            },
            {
              "language": "ru",
              "text": "Внезапная отмена со стороны клиента полностью сорвала наш график."
            },
            {
              "language": "sq",
              "text": "Anulimi i papritur nga klienti e prishi plotësisht orarin tonë."
            },
            {
              "language": "tr",
              "text": "Müşterinin son dakika iptali zaman planımızı tamamen altüst etti."
            }
          ]
        },
        {
          "baseText": "Der Wind hat mehrere Schilder vor dem Eingang umgeworfen.",
          "translations": [
            {
              "language": "ar",
              "text": "أسقطت الرياح عدة لافتات أمام المدخل."
            },
            {
              "language": "ckb",
              "text": "با کەوتنی چەند نیشانەیەکی بەردەم دەروازەکەی خستە خوارەوە."
            },
            {
              "language": "en",
              "text": "The wind knocked over several signs in front of the entrance."
            },
            {
              "language": "fa",
              "text": "باد چند تابلو جلوی ورودی را واژگون کرد."
            },
            {
              "language": "kmr",
              "text": "Ba çend nîşaneyên li ber dergehê xistin."
            },
            {
              "language": "pl",
              "text": "Wiatr przewrócił kilka tablic przed wejściem."
            },
            {
              "language": "ro",
              "text": "Vântul a răsturnat mai multe panouri în fața intrării."
            },
            {
              "language": "ru",
              "text": "Ветер опрокинул несколько табличек перед входом."
            },
            {
              "language": "sq",
              "text": "Era rrëzoi disa tabela para hyrjes."
            },
            {
              "language": "tr",
              "text": "Rüzgar girişin önündeki birkaç tabelayı devirdi."
            }
          ]
        }
      ]
    },
    {
      "word": "unabhängig",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "un-ab-hän-gig",
      "topics": [
        "work-and-jobs",
        "law-and-compliance",
        "advanced-analysis"
      ],
      "usageLabels": [
        "business",
        "written"
      ],
      "contextLabels": [
        "management",
        "legal",
        "research"
      ],
      "grammarNotes": [
        "adjective; often used with von + dative"
      ],
      "collocations": [
        {
          "text": "unabhängig von der Entscheidung",
          "meaning": "regardless of the decision"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Unabhängigkeit",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "abhängig",
          "relationLabel": "antonym",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مستقل؛ بغض النظر عن"
        },
        {
          "language": "ckb",
          "text": "سەربەخۆ؛ بێ گوێدان بە"
        },
        {
          "language": "en",
          "text": "independent; regardless of"
        },
        {
          "language": "fa",
          "text": "مستقل؛ صرف‌نظر از"
        },
        {
          "language": "kmr",
          "text": "serbixwe; bê girêdan bi"
        },
        {
          "language": "pl",
          "text": "niezależny; niezależnie od"
        },
        {
          "language": "ro",
          "text": "independent; indiferent de"
        },
        {
          "language": "ru",
          "text": "независимый; независимо от"
        },
        {
          "language": "sq",
          "text": "i pavarur; pavarësisht nga"
        },
        {
          "language": "tr",
          "text": "bağımsız; -den bağımsız olarak"
        }
      ],
      "examples": [
        {
          "baseText": "Die externe Prüfung soll unabhängig von der Geschäftsführung durchgeführt werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب إجراء المراجعة الخارجية بشكل مستقل عن الإدارة."
            },
            {
              "language": "ckb",
              "text": "پشکنینی دەرەکی دەبێت بە سەربەخۆیی لە بەڕێوەبەرایەتی ئەنجام بدرێت."
            },
            {
              "language": "en",
              "text": "The external audit should be carried out independently of management."
            },
            {
              "language": "fa",
              "text": "بازرسی خارجی باید مستقل از مدیریت انجام شود."
            },
            {
              "language": "kmr",
              "text": "Kontrola derveyî divê ji rêveberiyê serbixwe were kirin."
            },
            {
              "language": "pl",
              "text": "Zewnętrzna kontrola powinna zostać przeprowadzona niezależnie od zarządu."
            },
            {
              "language": "ro",
              "text": "Auditul extern trebuie realizat independent de conducere."
            },
            {
              "language": "ru",
              "text": "Внешняя проверка должна проводиться независимо от руководства."
            },
            {
              "language": "sq",
              "text": "Kontrolli i jashtëm duhet të kryhet i pavarur nga drejtimi."
            },
            {
              "language": "tr",
              "text": "Dış denetim yönetimden bağımsız olarak yürütülmelidir."
            }
          ]
        },
        {
          "baseText": "Unabhängig vom Wetter findet die Veranstaltung in der Halle statt.",
          "translations": [
            {
              "language": "ar",
              "text": "بغض النظر عن الطقس ستقام الفعالية في القاعة."
            },
            {
              "language": "ckb",
