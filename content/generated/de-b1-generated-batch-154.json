  "entries": [
    {
      "word": "das Ziel",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Ziele",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ziel",
      "topics": [
        "planning-and-projects",
        "work-and-jobs",
        "everyday-life"
      ],
      "usageLabels": [
        "high-frequency",
        "business",
        "everyday"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun: das Ziel, die Ziele"
      ],
      "collocations": [
        {
          "text": "ein Ziel erreichen",
          "meaning": "to achieve a goal"
        },
        {
          "text": "ein klares Ziel haben",
          "meaning": "to have a clear goal"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zielen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "zielgerichtet",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "هدف؛ مقصد"
        },
        {
          "language": "ckb",
          "text": "ئامانج؛ مەبەست"
        },
        {
          "language": "en",
          "text": "goal; target; destination"
        },
        {
          "language": "fa",
          "text": "هدف؛ مقصد"
        },
        {
          "language": "kmr",
          "text": "armanc; hedef; cihê ku mirov dixwaze bigihîje"
        },
        {
          "language": "pl",
          "text": "cel; miejsce docelowe"
        },
        {
          "language": "ro",
          "text": "obiectiv; țintă; destinație"
        },
        {
          "language": "ru",
          "text": "цель; пункт назначения"
        },
        {
          "language": "sq",
          "text": "qëllim; objektiv; destinacion"
        },
        {
          "language": "tr",
          "text": "hedef; amaç; varış noktası"
        }
      ],
      "examples": [
        {
          "baseText": "Unser Ziel ist, den Kunden bis Freitag eine Lösung anzubieten.",
          "translations": [
            {
              "language": "ar",
              "text": "هدفنا هو أن نقدم للعملاء حلاً حتى يوم الجمعة."
            },
            {
              "language": "ckb",
              "text": "ئامانجمان ئەوەیە تا هەینی چارەسەرێک پێشکەشی کڕیارەکان بکەین."
            },
            {
              "language": "en",
              "text": "Our goal is to offer the customers a solution by Friday."
            },
            {
              "language": "fa",
              "text": "هدف ما این است که تا جمعه یک راه‌حل به مشتریان ارائه کنیم."
            },
            {
              "language": "kmr",
              "text": "Armanca me ew e ku em heta roja înê çareseriyekê pêşkêşî xerîdaran bikin."
            },
            {
              "language": "pl",
              "text": "Naszym celem jest zaproponowanie klientom rozwiązania do piątku."
            },
            {
              "language": "ro",
              "text": "Obiectivul nostru este să le oferim clienților o soluție până vineri."
            },
            {
              "language": "ru",
              "text": "Наша цель — предложить клиентам решение до пятницы."
            },
            {
              "language": "sq",
              "text": "Qëllimi ynë është t’u ofrojmë klientëve një zgjidhje deri të premten."
            },
            {
              "language": "tr",
              "text": "Hedefimiz, müşterilere cuma gününe kadar bir çözüm sunmak."
            }
          ]
        },
        {
          "baseText": "Nach zwei Stunden Wanderung hatten wir das Ziel fast erreicht.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد ساعتين من المشي كنا قد اقتربنا كثيراً من الوصول إلى الوجهة."
            },
            {
              "language": "ckb",
              "text": "دوای دوو کاتژمێر پیاسەکردن، نزیک بووین لە گەیشتن بە مەبەستەکە."
            },
            {
              "language": "en",
              "text": "After two hours of hiking, we had almost reached our destination."
            },
            {
              "language": "fa",
              "text": "بعد از دو ساعت پیاده‌روی، تقریباً به مقصد رسیده بودیم."
            },
            {
              "language": "kmr",
              "text": "Piştî du demjimêr meşê, em hema hema gihîştibûn cihê xwe."
            },
            {
              "language": "pl",
              "text": "Po dwóch godzinach wędrówki prawie dotarliśmy do celu."
            },
            {
              "language": "ro",
              "text": "După două ore de drumeție, aproape ajunseserăm la destinație."
            },
            {
              "language": "ru",
              "text": "После двух часов похода мы почти достигли цели."
            },
            {
              "language": "sq",
              "text": "Pas dy orësh ecjeje, pothuajse kishim arritur në destinacion."
            },
            {
              "language": "tr",
              "text": "İki saatlik yürüyüşten sonra hedefe neredeyse ulaşmıştık."
            }
          ]
        }
      ]
    },
    {
      "word": "die Zielgruppe",
      "language": "de",
