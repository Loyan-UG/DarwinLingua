      "meanings": [
        {
          "language": "ar",
          "text": "تغيير النظام"
        },
        {
          "language": "ckb",
          "text": "گۆڕینی سیستەم"
        },
        {
          "language": "en",
          "text": "system change; migration to another system"
        },
        {
          "language": "fa",
          "text": "تغییر سیستم"
        },
        {
          "language": "kmr",
          "text": "guherandina pergalê"
        },
        {
          "language": "pl",
          "text": "zmiana systemu"
        },
        {
          "language": "ro",
          "text": "schimbare de sistem"
        },
        {
          "language": "ru",
          "text": "смена системы"
        },
        {
          "language": "sq",
          "text": "ndryshim sistemi"
        },
        {
          "language": "tr",
          "text": "sistem değişikliği"
        }
      ],
      "examples": [
        {
          "baseText": "Der Systemwechsel auf die neue ERP-Lösung ist für Oktober geplant.",
          "translations": [
            {
              "language": "ar",
              "text": "من المقرر تغيير النظام إلى حل تخطيط موارد المؤسسة الجديد في أكتوبر."
            },
            {
              "language": "ckb",
              "text": "گۆڕینی سیستەم بۆ چارەسەری نوێی ERP بۆ ئۆکتۆبەر پلاندانراوە."
            },
            {
              "language": "en",
              "text": "The switch to the new ERP solution is planned for October."
            },
            {
              "language": "fa",
              "text": "تغییر سیستم به راهکار ERP جدید برای اکتبر برنامه‌ریزی شده است."
            },
            {
              "language": "kmr",
              "text": "Guherandina pergalê bo çareseriya ERP ya nû ji bo Cotmehê hatiye plansazkirin."
            },
            {
              "language": "pl",
              "text": "Zmiana systemu na nowe rozwiązanie ERP jest zaplanowana na październik."
            },
            {
              "language": "ro",
              "text": "Schimbarea la noua soluție ERP este planificată pentru octombrie."
            },
            {
              "language": "ru",
              "text": "Переход на новое ERP-решение запланирован на октябрь."
            },
            {
              "language": "sq",
              "text": "Kalimi në zgjidhjen e re ERP është planifikuar për tetor."
            },
            {
              "language": "tr",
              "text": "Yeni ERP çözümüne sistem geçişi ekim ayı için planlandı."
            }
          ]
        },
        {
          "baseText": "Nach dem Systemwechsel mussten alle Mitarbeiter ihre Passwörter neu setzen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد تغيير النظام، كان على جميع الموظفين إعادة تعيين كلمات المرور الخاصة بهم."
            },
            {
              "language": "ckb",
              "text": "دوای گۆڕینی سیستەم، هەموو کارمەندان پێویست بوو وشەی نهێنییان لە نوێوە دابنێن."
            },
            {
              "language": "en",
              "text": "After the system change, all employees had to reset their passwords."
            },
            {
              "language": "fa",
              "text": "بعد از تغییر سیستم، همه کارکنان باید رمزهای عبور خود را دوباره تنظیم می‌کردند."
            },
            {
              "language": "kmr",
              "text": "Piştî guherandina pergalê, hemû karmendan diviya şîfreyên xwe ji nû ve saz bikin."
            },
            {
              "language": "pl",
              "text": "Po zmianie systemu wszyscy pracownicy musieli ponownie ustawić hasła."
            },
            {
              "language": "ro",
              "text": "După schimbarea sistemului, toți angajații au trebuit să își reseteze parolele."
            },
            {
              "language": "ru",
              "text": "После смены системы всем сотрудникам пришлось заново установить пароли."
            },
            {
              "language": "sq",
              "text": "Pas ndryshimit të sistemit, të gjithë punonjësit duhej të rivendosnin fjalëkalimet."
            },
            {
              "language": "tr",
              "text": "Sistem değişikliğinden sonra tüm çalışanların şifrelerini yeniden belirlemesi gerekti."
            }
          ]
        }
      ]
    },
