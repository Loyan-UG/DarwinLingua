      ],
      "usageLabels": [
        "spoken",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "fixed phrase; superlative form used to express preference"
      ],
      "collocations": [
        {
          "text": "am liebsten Kaffee trinken",
          "meaning": "to prefer drinking coffee most"
        },
        {
          "text": "am liebsten zu Hause bleiben",
          "meaning": "to prefer staying at home"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "lieb",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "lieber",
          "relationLabel": "adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "أفضل شيء؛ أكثر ما أفضّل"
        },
        {
          "language": "ckb",
          "text": "لە هەموو شت زیاتر؛ بە دڵخوازی خۆم"
        },
        {
          "language": "en",
          "text": "most preferably; best of all"
        },
        {
          "language": "fa",
          "text": "بیشتر از همه؛ ترجیحاً"
        },
        {
          "language": "kmr",
          "text": "herî zêde; bi dilê xwe"
        },
        {
          "language": "pl",
          "text": "najchętniej"
        },
        {
          "language": "ro",
          "text": "cel mai mult; de preferat"
        },
        {
          "language": "ru",
          "text": "охотнее всего; больше всего"
        },
        {
          "language": "sq",
          "text": "më së shumti; më me dëshirë"
        },
        {
          "language": "tr",
          "text": "en çok; tercihen"
        }
      ],
      "examples": [
        {
          "baseText": "Am liebsten trinke ich Tee am Morgen.",
          "translations": [
            {
              "language": "ar",
              "text": "أكثر ما أفضّله هو شرب الشاي صباحاً."
            },
            {
              "language": "ckb",
              "text": "لە هەموو شت زیاتر بەیانی چا دەخۆمەوە."
            },
            {
              "language": "en",
              "text": "Best of all, I like drinking tea in the morning."
            },
            {
              "language": "fa",
              "text": "بیشتر از همه صبح‌ها چای می‌نوشم."
            },
            {
              "language": "kmr",
              "text": "Ez herî zêde sibehan çay vedixwim."
            },
            {
              "language": "pl",
              "text": "Najchętniej piję rano herbatę."
            },
            {
              "language": "ro",
              "text": "Cel mai mult îmi place să beau ceai dimineața."
            },
            {
              "language": "ru",
              "text": "Больше всего я люблю пить чай утром."
            },
            {
              "language": "sq",
              "text": "Më së shumti më pëlqen të pi çaj në mëngjes."
            },
            {
              "language": "tr",
              "text": "En çok sabahları çay içmeyi severim."
            }
          ]
        },
        {
          "baseText": "Ich bleibe heute am liebsten zu Hause.",
          "translations": [
            {
              "language": "ar",
              "text": "أفضل أن أبقى اليوم في البيت."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ زۆرتر پێم خۆشە لە ماڵەوە بمێنمەوە."
            },
            {
              "language": "en",
              "text": "Today I would prefer to stay at home."
            },
            {
              "language": "fa",
              "text": "امروز ترجیح می‌دهم در خانه بمانم."
            },
            {
              "language": "kmr",
              "text": "Îro ez herî zêde dixwazim li malê bimînim."
            },
            {
              "language": "pl",
              "text": "Dziś najchętniej zostanę w domu."
            },
            {
              "language": "ro",
              "text": "Astăzi prefer cel mai mult să rămân acasă."
            },
            {
              "language": "ru",
              "text": "Сегодня я охотнее всего останусь дома."
            },
            {
              "language": "sq",
              "text": "Sot preferoj më shumë të qëndroj në shtëpi."
            },
            {
              "language": "tr",
              "text": "Bugün en çok evde kalmak isterim."
            }
          ]
        }
      ]
    },
