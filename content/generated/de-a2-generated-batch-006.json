        },
        {
          "language": "ru",
          "text": "светофор"
        },
        {
          "language": "sq",
          "text": "semafor"
        },
        {
          "language": "tr",
          "text": "trafik ışığı"
        }
      ],
      "examples": [
        {
          "baseText": "An der Ampel müssen wir warten.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن ننتظر عند إشارة المرور."
            },
            {
              "language": "ckb",
              "text": "لە لای ئیشارەی هاتووچۆ دەبێت چاوەڕێ بکەین."
            },
            {
              "language": "en",
              "text": "We have to wait at the traffic light."
            },
            {
              "language": "fa",
              "text": "باید پشت چراغ راهنما صبر کنیم."
            },
            {
              "language": "kmr",
              "text": "Li ronahiya trafîkê divê em bisekinin."
            },
            {
              "language": "pl",
              "text": "Musimy czekać na światłach."
            },
            {
              "language": "ro",
              "text": "Trebuie să așteptăm la semafor."
            },
            {
              "language": "ru",
              "text": "Нам нужно ждать на светофоре."
            },
            {
              "language": "sq",
              "text": "Duhet të presim te semafori."
            },
            {
              "language": "tr",
              "text": "Trafik ışığında beklemeliyiz."
            }
          ]
        },
        {
          "baseText": "Die Ampel ist grün, wir können gehen.",
          "translations": [
            {
              "language": "ar",
              "text": "إشارة المرور خضراء، يمكننا أن نمشي."
            },
            {
              "language": "ckb",
              "text": "ئیشارەکە سەوزە، دەتوانین بڕۆین."
            },
            {
              "language": "en",
              "text": "The traffic light is green; we can go."
            },
            {
              "language": "fa",
              "text": "چراغ سبز است، می‌توانیم برویم."
            },
            {
              "language": "kmr",
              "text": "Ronahî kesk e, em dikarin biçin."
            },
            {
              "language": "pl",
              "text": "Światło jest zielone, możemy iść."
            },
            {
              "language": "ro",
              "text": "Semaforul este verde, putem merge."
            },
            {
              "language": "ru",
              "text": "Светофор зеленый, мы можем идти."
            },
            {
              "language": "sq",
              "text": "Semafori është jeshil, mund të shkojmë."
            },
            {
              "language": "tr",
              "text": "Işık yeşil, gidebiliriz."
            }
          ]
        }
      ]
