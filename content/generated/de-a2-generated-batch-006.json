      "examples": [
        {
          "baseText": "Wir bieten auch Lieferung nach Hause an.",
          "translations": [
            {
              "language": "ar",
              "text": "نقدم أيضاً خدمة التوصيل إلى المنزل."
            },
            {
              "language": "ckb",
              "text": "ئێمە گەیاندن بۆ ماڵیش پێشکەش دەکەین."
            },
            {
              "language": "en",
              "text": "We also offer home delivery."
            },
            {
              "language": "fa",
              "text": "ما ارسال به خانه را هم ارائه می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Em radestkirina malê jî pêşkêş dikin."
            },
            {
              "language": "pl",
              "text": "Oferujemy też dostawę do domu."
            },
            {
              "language": "ro",
              "text": "Oferim și livrare la domiciliu."
            },
            {
              "language": "ru",
              "text": "Мы также предлагаем доставку на дом."
            },
            {
              "language": "sq",
              "text": "Ne ofrojmë edhe dërgesë në shtëpi."
            },
            {
              "language": "tr",
              "text": "Eve teslimat da sunuyoruz."
            }
          ]
        },
        {
          "baseText": "Kann ich Ihnen einen Kaffee anbieten?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني أن أقدم لكم قهوة؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم قاوەیەکتان پێشکەش بکەم؟"
            },
            {
              "language": "en",
              "text": "Can I offer you a coffee?"
            },
            {
              "language": "fa",
              "text": "می‌توانم به شما قهوه تعارف کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim qehweyekê pêşkêşî we bikim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę zaproponować Panu/Pani kawę?"
            },
            {
              "language": "ro",
              "text": "Pot să vă ofer o cafea?"
            },
            {
              "language": "ru",
              "text": "Могу я предложить вам кофе?"
