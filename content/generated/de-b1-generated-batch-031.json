  "entries": [
    {
      "word": "beschäftigt",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "be-schäf-tigt",
      "topics": [
        "work-and-jobs",
        "everyday-life",
        "human-resources"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "hr",
        "administration"
      ],
      "grammarNotes": [
        "adjective; often used with sein"
      ],
      "collocations": [
        {
          "text": "sehr beschäftigt sein",
          "meaning": "to be very busy"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "beschäftigen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Beschäftigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مشغول؛ شاغل"
        },
        {
          "language": "ckb",
          "text": "سەرقاڵ؛ خاوەن کار"
        },
        {
          "language": "en",
          "text": "busy; employed"
        },
        {
          "language": "fa",
          "text": "مشغول؛ شاغل"
        },
        {
          "language": "kmr",
          "text": "mijûl; xwedî kar"
        },
        {
          "language": "pl",
          "text": "zajęty; zatrudniony"
        },
        {
          "language": "ro",
          "text": "ocupat; angajat"
        },
        {
          "language": "ru",
          "text": "занятый; трудоустроенный"
        },
        {
          "language": "sq",
          "text": "i zënë; i punësuar"
        },
        {
          "language": "tr",
          "text": "meşgul; çalışan"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin heute sehr beschäftigt und rufe Sie morgen zurück.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا مشغول جدًا اليوم وسأتصل بك غدًا."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ زۆر سەرقاڵم و سبەی پەیوەندیت پێوە دەکەمەوە."
            },
            {
              "language": "en",
              "text": "I am very busy today and will call you back tomorrow."
            },
            {
              "language": "fa",
              "text": "امروز خیلی مشغولم و فردا با شما تماس می‌گیرم."
            },
            {
              "language": "kmr",
              "text": "Ez îro pir mijûl im û sibê vedigerim we telefon dikim."
            },
            {
              "language": "pl",
              "text": "Dzisiaj jestem bardzo zajęty i oddzwonię jutro."
            },
            {
              "language": "ro",
              "text": "Sunt foarte ocupat astăzi și vă sun înapoi mâine."
            },
            {
              "language": "ru",
              "text": "Сегодня я очень занят и перезвоню вам завтра."
            },
            {
              "language": "sq",
              "text": "Sot jam shumë i zënë dhe do t’ju telefonoj nesër."
            },
            {
              "language": "tr",
              "text": "Bugün çok meşgulüm, sizi yarın geri arayacağım."
            }
          ]
        },
        {
          "baseText": "In der Firma sind zurzeit mehr als fünfzig Personen beschäftigt.",
          "translations": [
            {
              "language": "ar",
              "text": "يعمل في الشركة حاليًا أكثر من خمسين شخصًا."
            },
            {
              "language": "ckb",
              "text": "لە کۆمپانیاکەدا لە ئێستادا زیاتر لە پەنجا کەس کار دەکەن."
            },
            {
              "language": "en",
              "text": "More than fifty people are currently employed at the company."
            },
            {
              "language": "fa",
              "text": "در شرکت در حال حاضر بیش از پنجاه نفر شاغل هستند."
            },
            {
              "language": "kmr",
              "text": "Li şirkêtê niha zêdetirî pêncî kes dixebitin."
            },
            {
              "language": "pl",
              "text": "W firmie jest obecnie zatrudnionych ponad pięćdziesiąt osób."
            },
            {
              "language": "ro",
              "text": "În firmă sunt angajate în prezent peste cincizeci de persoane."
            },
            {
              "language": "ru",
              "text": "В компании сейчас занято более пятидесяти человек."
            },
            {
              "language": "sq",
              "text": "Në kompani aktualisht janë të punësuar më shumë se pesëdhjetë persona."
            },
            {
              "language": "tr",
              "text": "Şirkette şu anda elliden fazla kişi çalışıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Bescheinigung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Bescheinigungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-schei-ni-gung",
      "topics": [
        "documents-and-administration",
        "public-services",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written"
      ],
      "contextLabels": [
        "documents",
        "administration",
        "public-services"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Bescheinigung ausstellen",
          "meaning": "to issue a certificate or confirmation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bescheinigen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شهادة؛ إفادة رسمية"
        },
        {
          "language": "ckb",
          "text": "بڕوانامە؛ پشتڕاستکردنەوەی فەرمی"
        },
        {
          "language": "en",
          "text": "certificate; official confirmation"
        },
        {
          "language": "fa",
          "text": "گواهی؛ تأییدیه رسمی"
        },
        {
          "language": "kmr",
          "text": "belge; pejirandina fermî"
        },
        {
          "language": "pl",
          "text": "zaświadczenie"
        },
        {
          "language": "ro",
          "text": "adeverință; certificat"
        },
        {
          "language": "ru",
          "text": "справка; подтверждение"
        },
        {
          "language": "sq",
          "text": "vërtetim; certifikatë"
        },
        {
          "language": "tr",
          "text": "belge; resmi onay"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Anmeldung brauchen Sie eine Bescheinigung vom Arbeitgeber.",
          "translations": [
            {
              "language": "ar",
              "text": "للتسجيل تحتاج إلى إفادة من صاحب العمل."
            },
            {
              "language": "ckb",
              "text": "بۆ تۆمارکردن پێویستتان بە بڕوانامەیەک لە خاوەنکار هەیە."
            },
            {
              "language": "en",
              "text": "For the registration, you need a certificate from your employer."
            },
            {
              "language": "fa",
              "text": "برای ثبت‌نام به یک گواهی از کارفرما نیاز دارید."
            },
            {
              "language": "kmr",
              "text": "Ji bo qeydkirinê belgeyek ji kardêrê we divê."
            },
            {
              "language": "pl",
              "text": "Do rejestracji potrzebne jest zaświadczenie od pracodawcy."
            },
            {
              "language": "ro",
              "text": "Pentru înscriere aveți nevoie de o adeverință de la angajator."
            },
            {
              "language": "ru",
              "text": "Для регистрации вам нужна справка от работодателя."
            },
            {
              "language": "sq",
              "text": "Për regjistrim ju duhet një vërtetim nga punëdhënësi."
            },
            {
              "language": "tr",
              "text": "Kayıt için işverenden bir belgeye ihtiyacınız var."
            }
          ]
        },
        {
          "baseText": "Die Bescheinigung wird Ihnen per E-Mail zugeschickt.",
          "translations": [
            {
              "language": "ar",
              "text": "سيتم إرسال الشهادة إليك عبر البريد الإلكتروني."
            },
            {
              "language": "ckb",
              "text": "بڕوانامەکە بە ئیمەیڵ بۆتان دەنێردرێت."
            },
            {
              "language": "en",
              "text": "The certificate will be sent to you by email."
            },
            {
              "language": "fa",
