      "word": "der Verband",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Verbände",
      "infinitive": null,
      "syllableBreak": "Ver-band",
      "topics": [
        "business-communication",
        "law-and-compliance",
        "customer-service"
      ],
      "usageLabels": [
        "business",
        "administrative",
        "written"
      ],
      "grammarNotes": [
        "masculine noun; can mean association or bandage depending on context"
      ],
      "collocations": [
        {
          "text": "ein Verband von Unternehmen",
          "meaning": "an association of companies"
        },
        {
          "text": "Mitglied im Verband",
          "meaning": "member of the association"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verbinden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "جمعية؛ اتحاد؛ ضمادة"
        },
        {
          "language": "ckb",
          "text": "یەکێتی؛ کۆمەڵە؛ پەسار"
        },
        {
          "language": "en",
          "text": "association; federation; bandage"
        },
        {
          "language": "fa",
          "text": "انجمن؛ اتحادیه؛ باند زخم"
        },
        {
          "language": "kmr",
          "text": "yekîtî; komele; pêçan"
        },
        {
          "language": "pl",
          "text": "związek; stowarzyszenie; opatrunek"
        },
        {
          "language": "ro",
          "text": "asociație; federație; bandaj"
        },
        {
          "language": "ru",
          "text": "союз; ассоциация; повязка"
        },
        {
          "language": "sq",
          "text": "shoqatë; federatë; fashë"
        },
        {
          "language": "tr",
          "text": "birlik; dernek; bandaj"
        }
      ],
      "examples": [
        {
          "baseText": "Der Verband ist im ERP-System als Kunde angelegt.",
          "translations": [
            {
              "language": "ar",
              "text": "تم إنشاء الجمعية كعميل في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "یەکێتییەکە لە سیستەمی ERPدا وەک کڕیار دروست کراوە."
            },
            {
              "language": "en",
              "text": "The association is created as a customer in the ERP system."
            },
            {
              "language": "fa",
              "text": "انجمن در سیستم ERP به عنوان مشتری ثبت شده است."
            },
            {
              "language": "kmr",
              "text": "Yekîtî di pergala ERP de wekî xerîdar hatiye çêkirin."
            },
            {
              "language": "pl",
              "text": "Związek jest utworzony w systemie ERP jako klient."
            },
            {
              "language": "ro",
              "text": "Asociația este creată în sistemul ERP ca client."
            },
            {
              "language": "ru",
              "text": "Ассоциация заведена в ERP-системе как клиент."
            },
            {
              "language": "sq",
              "text": "Shoqata është krijuar në sistemin ERP si klient."
            },
            {
              "language": "tr",
              "text": "Dernek ERP sisteminde müşteri olarak açıldı."
            }
          ]
        },
        {
          "baseText": "Der Verband informiert seine Mitglieder über neue Regeln.",
          "translations": [
            {
              "language": "ar",
              "text": "تبلغ الجمعية أعضاءها بالقواعد الجديدة."
            },
            {
              "language": "ckb",
