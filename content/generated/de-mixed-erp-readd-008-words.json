      "word": "die Umlagerung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Umlagerungen",
      "infinitive": null,
      "syllableBreak": "Um-la-ge-rung",
      "topics": [
        "warehouse-and-logistics",
        "erp-and-business-systems",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "technical",
        "process"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Umlagerung buchen",
          "meaning": "to post a stock transfer"
        },
        {
          "text": "Umlagerung zwischen Lagern",
          "meaning": "stock transfer between warehouses"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "umlagern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "نقل مخزون داخلي"
        },
        {
          "language": "ckb",
          "text": "گواستنەوەی ناوخۆی کۆگا"
        },
        {
          "language": "en",
          "text": "stock transfer; internal relocation"
        },
        {
          "language": "fa",
          "text": "انتقال موجودی؛ جابه‌جایی انبار"
        },
        {
          "language": "kmr",
          "text": "veguhastina stokê"
        },
        {
          "language": "pl",
          "text": "przesunięcie magazynowe"
        },
        {
          "language": "ro",
          "text": "transfer de stoc"
        },
        {
          "language": "ru",
          "text": "перемещение запасов"
        },
        {
          "language": "sq",
          "text": "transfer stoku"
        },
        {
          "language": "tr",
          "text": "stok transferi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Umlagerung von Lager A nach Lager B wurde im ERP-System gebucht.",
          "translations": [
            {
              "language": "ar",
              "text": "تم تسجيل نقل المخزون من المستودع أ إلى المستودع ب في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "گواستنەوەکە لە کۆگای A بۆ کۆگای B لە سیستەمی ERPدا تۆمار کرا."
            },
            {
              "language": "en",
              "text": "The stock transfer from warehouse A to warehouse B was posted in the ERP system."
            },
            {
              "language": "fa",
              "text": "انتقال موجودی از انبار A به انبار B در سیستم ERP ثبت شد."
            },
            {
              "language": "kmr",
              "text": "Veguhastina stokê ji embar A bo embar B di pergala ERP de hate tomarkirin."
            },
            {
              "language": "pl",
              "text": "Przesunięcie z magazynu A do magazynu B zostało zaksięgowane w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Transferul de stoc din depozitul A în depozitul B a fost înregistrat în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Перемещение со склада A на склад B было проведено в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Transferi i stokut nga depoja A në depon B u regjistrua në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "A deposundan B deposuna stok transferi ERP sisteminde kaydedildi."
            }
          ]
        },
        {
          "baseText": "Für die Umlagerung brauchen wir einen freien Platz im zweiten Lager.",
          "translations": [
            {
              "language": "ar",
              "text": "لنقل المخزون نحتاج إلى مكان فارغ في المستودع الثاني."
            },
            {
              "language": "ckb",
              "text": "بۆ گواستنەوەکە پێویستمان بە شوێنێکی بەتاڵ لە کۆگای دووەمە."
            },
            {
              "language": "en",
              "text": "For the stock transfer, we need a free space in the second warehouse."
            },
            {
              "language": "fa",
              "text": "برای انتقال موجودی به یک جای خالی در انبار دوم نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo veguhastina stokê em hewceyê cihê vala di embara duyem de ne."
            },
            {
              "language": "pl",
              "text": "Do przesunięcia potrzebujemy wolnego miejsca w drugim magazynie."
            },
            {
              "language": "ro",
              "text": "Pentru transfer avem nevoie de un loc liber în al doilea depozit."
            },
            {
              "language": "ru",
              "text": "Для перемещения нам нужно свободное место на втором складе."
            },
            {
              "language": "sq",
              "text": "Për transferin na duhet një vend i lirë në depon e dytë."
            },
            {
              "language": "tr",
              "text": "Stok transferi için ikinci depoda boş bir yere ihtiyacımız var."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Umrechnung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Umrechnungen",
      "infinitive": null,
      "syllableBreak": "Um-rech-nung",
      "topics": [
        "finance-and-accounting",
        "data-and-reporting",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Umrechnung durchführen",
          "meaning": "to perform a conversion"
        },
        {
          "text": "Umrechnung in Euro",
          "meaning": "conversion into euros"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "umrechnen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تحويل؛ إعادة حساب"
        },
        {
          "language": "ckb",
          "text": "گۆڕینی ژماردن؛ هەژمارکردنەوە"
        },
        {
          "language": "en",
          "text": "conversion; recalculation"
        },
        {
          "language": "fa",
          "text": "تبدیل؛ محاسبه مجدد"
        },
        {
          "language": "kmr",
          "text": "veguherandina hesabê"
        },
        {
          "language": "pl",
          "text": "przeliczenie"
        },
        {
          "language": "ro",
          "text": "conversie; recalculare"
        },
        {
          "language": "ru",
          "text": "пересчет; конвертация"
        },
        {
          "language": "sq",
          "text": "konvertim; rillogaritje"
        },
        {
          "language": "tr",
          "text": "dönüştürme; yeniden hesaplama"
        }
      ],
      "examples": [
        {
          "baseText": "Die Umrechnung von Dollar in Euro erfolgt automatisch im ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "تتم عملية تحويل الدولار إلى اليورو تلقائيًا في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "گۆڕینی دۆلار بۆ یۆرۆ خۆکارانە لە سیستەمی ERPدا دەکرێت."
            },
            {
              "language": "en",
              "text": "The conversion from dollars to euros happens automatically in the ERP system."
            },
            {
              "language": "fa",
              "text": "تبدیل دلار به یورو در سیستم ERP به صورت خودکار انجام می‌شود."
            },
            {
              "language": "kmr",
              "text": "Veguherandina dolar bo euro di pergala ERP de bixweber pêk tê."
            },
            {
              "language": "pl",
              "text": "Przeliczenie dolarów na euro odbywa się automatycznie w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Conversia din dolari în euro se face automat în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Пересчет долларов в евро выполняется автоматически в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Konvertimi nga dollarë në euro bëhet automatikisht në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Doların euroya çevrilmesi ERP sisteminde otomatik yapılır."
            }
          ]
        },
        {
          "baseText": "Bitte prüfen Sie die Umrechnung der Mengen noch einmal.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق مرة أخرى من تحويل الكميات."
            },
            {
              "language": "ckb",
              "text": "تکایە جارێکی تر گۆڕینی بڕەکان بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the conversion of the quantities again."
            },
            {
              "language": "fa",
              "text": "لطفاً تبدیل مقدارها را دوباره بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe veguherandina hejmaran careke din kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę jeszcze raz sprawdzić przeliczenie ilości."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați încă o dată conversia cantităților."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, еще раз проверьте пересчет количеств."
            },
            {
              "language": "sq",
              "text": "Ju lutemi kontrolloni edhe një herë konvertimin e sasive."
            },
            {
              "language": "tr",
              "text": "Lütfen miktarların dönüşümünü tekrar kontrol edin."
            }
          ]
        }
      ]
    },
    {
