  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "beleihen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beleihen",
      "syllableBreak": "be-lei-hen",
      "topics": [
        "finance-and-accounting",
        "housing-and-real-estate",
        "contracts-and-negotiation"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong inseparable verb; used when an asset is used as loan collateral"
      ],
      "collocations": [
        {
          "text": "eine Immobilie beleihen",
          "meaning": "to borrow against a property"
        },
        {
          "text": "Wertpapiere beleihen",
          "meaning": "to use securities as collateral"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Beleihung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "leihen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يرهن للحصول على قرض؛ يستخدم كضمان"
        },
        {
          "language": "ckb",
          "text": "بە بارمتە دەیدات بۆ وەرگرتنی قەرز"
        },
        {
          "language": "en",
          "text": "to mortgage; to borrow against; to use as collateral"
        },
        {
          "language": "fa",
          "text": "وثیقه گذاشتن؛ در برابر دارایی وام گرفتن"
        },
        {
          "language": "kmr",
          "text": "wekî rehîn dan; li ser milkê deyn standin"
        },
        {
          "language": "pl",
          "text": "obciążyć kredytem; zastawić"
        },
        {
          "language": "ro",
          "text": "a ipoteca; a folosi drept garanție"
        },
        {
          "language": "ru",
          "text": "закладывать; брать кредит под залог"
        },
        {
          "language": "sq",
          "text": "të hipotekosh; të marrësh kredi mbi kolateral"
        },
        {
          "language": "tr",
          "text": "ipotek etmek; teminat göstererek kredi almak"
        }
      ],
      "examples": [
        {
          "baseText": "Das Unternehmen will die Lagerhalle beleihen, um die neue Produktionslinie zu finanzieren.",
          "translations": [
            {
              "language": "ar",
              "text": "تريد الشركة رهن قاعة التخزين لتمويل خط الإنتاج الجديد."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە دەیەوێت هۆڵی کۆگاکە بە بارمتە بدات بۆ دارایی کردنی هێڵی نوێی بەرهەمهێنان."
            },
            {
              "language": "en",
              "text": "The company wants to borrow against the warehouse to finance the new production line."
            },
            {
              "language": "fa",
              "text": "شرکت می‌خواهد سالن انبار را وثیقه بگذارد تا خط تولید جدید را تأمین مالی کند."
            },
            {
              "language": "kmr",
              "text": "Şirket dixwaze holê embarê wekî rehîn bide da ku xeta nû ya hilberînê fînanse bike."
            },
            {
              "language": "pl",
              "text": "Firma chce obciążyć halę magazynową kredytem, aby sfinansować nową linię produkcyjną."
            },
            {
              "language": "ro",
              "text": "Compania vrea să ipotecheze hala de depozitare pentru a finanța noua linie de producție."
            },
            {
              "language": "ru",
              "text": "Компания хочет заложить складской зал, чтобы профинансировать новую производственную линию."
            },
            {
              "language": "sq",
              "text": "Kompania dëshiron ta hipotekojë magazinën për të financuar linjën e re të prodhimit."
            },
            {
              "language": "tr",
              "text": "Şirket yeni üretim hattını finanse etmek için depo binasını teminat göstermeyi planlıyor."
            }
          ]
        },
        {
          "baseText": "Viele Eigentümer lassen ihre Wohnung nur bis zu einem konservativen Wert beleihen.",
          "translations": [
            {
              "language": "ar",
              "text": "كثير من المالكين يسمحون برهن شقتهم فقط حتى قيمة محافظة."
            },
            {
              "language": "ckb",
              "text": "زۆر خاوەندار خانووەکانیان تەنها تا نرخێکی پارێزکارانە بە بارمتە دەدەن."
            },
            {
              "language": "en",
              "text": "Many owners allow their apartment to be mortgaged only up to a conservative value."
            },
            {
              "language": "fa",
              "text": "بسیاری از مالکان خانه خود را فقط تا ارزشی محافظه‌کارانه وثیقه می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Gelek xwediyên malan xaniyê xwe tenê heta nirxekî parêzkar wekî rehîn didin."
            },
            {
              "language": "pl",
              "text": "Wielu właścicieli pozwala obciążyć mieszkanie tylko do konserwatywnej wartości."
            },
            {
              "language": "ro",
              "text": "Mulți proprietari își ipotechează locuința doar până la o valoare conservatoare."
            },
            {
              "language": "ru",
              "text": "Многие владельцы закладывают квартиру только до консервативной оценки."
            },
            {
              "language": "sq",
              "text": "Shumë pronarë e hipotekojnë banesën vetëm deri në një vlerë konservatore."
            },
            {
              "language": "tr",
              "text": "Birçok mülk sahibi dairesini yalnızca ihtiyatlı bir değere kadar ipotek ettirir."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "beleuchten",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beleuchten",
      "syllableBreak": "be-leuch-ten",
      "topics": [
        "advanced-analysis",
        "business-communication",
        "production-and-maintenance"
      ],
      "usageLabels": [
        "formal",
        "written",
        "analysis",
        "advanced"
      ],
      "grammarNotes": [
        "regular inseparable verb; literal lighting or figurative analysis"
      ],
      "collocations": [
        {
          "text": "einen Aspekt beleuchten",
          "meaning": "to examine an aspect"
        },
        {
          "text": "einen Raum beleuchten",
          "meaning": "to light a room"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Beleuchtung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يضيء؛ يسلّط الضوء على أو يحلل"
        },
        {
          "language": "ckb",
          "text": "ڕووناک دەکات؛ لایەنێک شیکار دەکات"
        },
        {
          "language": "en",
          "text": "to illuminate; to examine; to shed light on"
        },
        {
          "language": "fa",
          "text": "روشن کردن؛ بررسی و روشن کردن موضوع"
        },
        {
          "language": "kmr",
          "text": "ronî kirin; aliyek analîz kirin"
        },
        {
          "language": "pl",
          "text": "oświetlić; naświetlić"
        },
        {
          "language": "ro",
          "text": "a ilumina; a analiza"
        },
        {
          "language": "ru",
          "text": "освещать; рассматривать"
        },
        {
          "language": "sq",
          "text": "të ndriçosh; të shqyrtosh"
        },
        {
          "language": "tr",
          "text": "aydınlatmak; ele almak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bericht beleuchtet die Risiken der Migration aus technischer und organisatorischer Sicht.",
          "translations": [
            {
              "language": "ar",
              "text": "يسلط التقرير الضوء على مخاطر الترحيل من منظور تقني وتنظيمي."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتەکە مەترسییەکانی گواستنەوە لە ڕووی تەکنیکی و ڕێکخراوەییەوە شیکار دەکات."
            },
            {
              "language": "en",
              "text": "The report examines the risks of the migration from a technical and organizational perspective."
            },
            {
              "language": "fa",
              "text": "گزارش ریسک‌های مهاجرت را از منظر فنی و سازمانی بررسی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Rapor xeterên veguhestinê ji aliyê teknîkî û rêxistinî ve analîz dike."
            },
            {
              "language": "pl",
              "text": "Raport naświetla ryzyka migracji z perspektywy technicznej i organizacyjnej."
            },
            {
              "language": "ro",
              "text": "Raportul analizează riscurile migrării din perspectivă tehnică și organizațională."
            },
            {
              "language": "ru",
              "text": "Отчет рассматривает риски миграции с технической и организационной точки зрения."
            },
            {
              "language": "sq",
              "text": "Raporti shqyrton rreziqet e migrimit nga këndvështrimi teknik dhe organizativ."
            },
            {
              "language": "tr",
              "text": "Rapor geçişin risklerini teknik ve organizasyonel açıdan ele alıyor."
            }
          ]
        },
        {
          "baseText": "Die Werkstatt muss den Prüfbereich besser beleuchten, damit kleine Risse sichtbar werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب على الورشة إضاءة منطقة الفحص بشكل أفضل كي تظهر الشقوق الصغيرة."
            },
            {
              "language": "ckb",
              "text": "کارگەی چاککردنەوە دەبێت شوێنی پشکنین باشتر ڕووناک بکات بۆ ئەوەی درزی بچووک دیار بن."
            },
            {
              "language": "en",
              "text": "The workshop needs to light the inspection area better so small cracks become visible."
            },
            {
              "language": "fa",
              "text": "کارگاه باید بخش بازرسی را بهتر روشن کند تا ترک‌های کوچک دیده شوند."
            },
            {
              "language": "kmr",
              "text": "Atolyê divê qada kontrolê baştir ronî bike da ku dirzên biçûk xuya bibin."
            },
            {
              "language": "pl",
              "text": "Warsztat musi lepiej oświetlić obszar kontroli, aby drobne pęknięcia były widoczne."
            },
            {
              "language": "ro",
              "text": "Atelierul trebuie să ilumineze mai bine zona de verificare ca fisurile mici să devină vizibile."
            },
            {
              "language": "ru",
              "text": "Мастерская должна лучше осветить зону проверки, чтобы стали видны мелкие трещины."
            },
            {
              "language": "sq",
              "text": "Punishtja duhet ta ndriçojë më mirë zonën e kontrollit që çarjet e vogla të duken."
            },
            {
              "language": "tr",
              "text": "Atölye küçük çatlakların görünmesi için kontrol alanını daha iyi aydınlatmalı."
            }
          ]
        }
      ]
    },
