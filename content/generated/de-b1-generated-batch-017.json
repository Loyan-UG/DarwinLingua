  "entries": [
    {
      "word": "aufnehmen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufnehmen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-neh-men",
      "topics": [
        "work-and-jobs",
        "technology-and-it",
        "business-communication"
      ],
      "usageLabels": [
        "spoken",
        "business",
        "formal"
      ],
      "contextLabels": [
        "hr",
        "support",
        "documents"
      ],
      "grammarNotes": [
        "separable verb",
        "can mean to record, accept, include, or start contact"
      ],
      "collocations": [
        {
          "text": "Kontakt aufnehmen",
          "meaning": "to get in touch"
        },
        {
          "text": "ein Gespräch aufnehmen",
          "meaning": "to record a conversation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Aufnahme",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسجل؛ يستقبل؛ يدرج؛ يتواصل"
        },
        {
          "language": "ckb",
          "text": "تۆمارکردن؛ وەرگرتن؛ خستنە ناو؛ پەیوەندی کردن"
        },
        {
          "language": "en",
          "text": "to record; to accept; to include; to contact"
        },
        {
          "language": "fa",
          "text": "ضبط کردن؛ پذیرفتن؛ وارد کردن؛ تماس گرفتن"
        },
        {
          "language": "kmr",
          "text": "tomar kirin; qebûl kirin; têkilî danîn"
        },
        {
          "language": "pl",
          "text": "nagrać; przyjąć; uwzględnić; nawiązać kontakt"
        },
        {
          "language": "ro",
          "text": "a înregistra; a accepta; a include; a lua legătura"
        },
        {
          "language": "ru",
          "text": "записать; принять; включить; связаться"
        },
        {
          "language": "sq",
          "text": "të regjistrosh; të pranosh; të përfshish; të kontaktosh"
        },
        {
          "language": "tr",
          "text": "kaydetmek; kabul etmek; dahil etmek; iletişime geçmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte nehmen Sie Kontakt mit dem Kunden auf, sobald die Bestellung versendet wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التواصل مع العميل بمجرد إرسال الطلبية."
            },
            {
              "language": "ckb",
              "text": "تکایە هەر کات داواکارییەکە نێردرا، پەیوەندی بە کڕیارەکەوە بکەن."
            },
            {
              "language": "en",
              "text": "Please contact the customer as soon as the order has been shipped."
            },
            {
              "language": "fa",
              "text": "لطفاً به محض ارسال سفارش با مشتری تماس بگیرید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe gava ferman hate şandin, bi xerîdar re têkilî daynin."
            },
            {
              "language": "pl",
              "text": "Proszę skontaktować się z klientem, gdy tylko zamówienie zostanie wysłane."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să luați legătura cu clientul imediat ce comanda a fost expediată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, свяжитесь с клиентом, как только заказ будет отправлен."
            },
            {
              "language": "sq",
              "text": "Ju lutem kontaktoni klientin sapo porosia të jetë dërguar."
            },
            {
              "language": "tr",
              "text": "Sipariş gönderilir gönderilmez lütfen müşteriyle iletişime geçin."
            }
          ]
        },
        {
          "baseText": "Die App kann kurze Sprachnachrichten aufnehmen und direkt verschicken.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن للتطبيق تسجيل رسائل صوتية قصيرة وإرسالها مباشرة."
            },
            {
              "language": "ckb",
              "text": "ئەپەکە دەتوانێت پەیامی دەنگی کورت تۆمار بکات و راستەوخۆ بینێرێت."
            },
            {
              "language": "en",
              "text": "The app can record short voice messages and send them directly."
            },
            {
              "language": "fa",
              "text": "اپلیکیشن می‌تواند پیام‌های صوتی کوتاه ضبط کند و مستقیم بفرستد."
            },
            {
              "language": "kmr",
              "text": "App dikare peyamên dengî yên kurt tomar bike û rasterast bişîne."
            },
            {
              "language": "pl",
              "text": "Aplikacja może nagrywać krótkie wiadomości głosowe i od razu je wysyłać."
            },
            {
              "language": "ro",
              "text": "Aplicația poate înregistra mesaje vocale scurte și le poate trimite direct."
            },
            {
              "language": "ru",
              "text": "Приложение может записывать короткие голосовые сообщения и сразу отправлять их."
            },
            {
              "language": "sq",
              "text": "Aplikacioni mund të regjistrojë mesazhe të shkurtra zanore dhe t’i dërgojë direkt."
            },
            {
              "language": "tr",
              "text": "Uygulama kısa sesli mesajları kaydedip doğrudan gönderebilir."
            }
          ]
        }
      ]
    },
