        {
          "text": "Probleme verursachen",
          "meaning": "to cause problems"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Ursache",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسبب"
        },
        {
          "language": "ckb",
          "text": "هۆکار بوون؛ دروستکردن"
        },
        {
          "language": "en",
          "text": "to cause"
        },
        {
          "language": "fa",
          "text": "باعث شدن؛ ایجاد کردن"
        },
        {
          "language": "kmr",
          "text": "sedem bûn; çêkirin"
        },
        {
          "language": "pl",
          "text": "powodować"
        },
        {
          "language": "ro",
          "text": "a cauza"
        },
        {
          "language": "ru",
          "text": "вызывать; причинять"
        },
        {
          "language": "sq",
          "text": "të shkaktosh"
        },
        {
          "language": "tr",
          "text": "neden olmak; yol açmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Fehler im Formular hat zusätzliche Arbeit verursacht.",
          "translations": [
            {
              "language": "ar",
              "text": "تسبب الخطأ في النموذج في عمل إضافي."
            },
            {
              "language": "ckb",
              "text": "هەڵەکە لە فۆرمەکەدا کاری زیادەی دروست کرد."
            },
            {
              "language": "en",
              "text": "The error in the form caused extra work."
            },
            {
              "language": "fa",
              "text": "خطا در فرم باعث کار اضافی شد."
            },
            {
              "language": "kmr",
              "text": "Şaşiya di formê de karê zêde çêkir."
            },
            {
              "language": "pl",
              "text": "Błąd w formularzu spowodował dodatkową pracę."
            },
            {
              "language": "ro",
              "text": "Eroarea din formular a cauzat muncă suplimentară."
            },
            {
              "language": "ru",
              "text": "Ошибка в форме вызвала дополнительную работу."
            },
            {
              "language": "sq",
              "text": "Gabimi në formular shkaktoi punë shtesë."
            },
            {
              "language": "tr",
              "text": "Formdaki hata ek işe neden oldu."
            }
          ]
        },
        {
          "baseText": "Zu viel Verpackung verursacht unnötigen Müll.",
          "translations": [
            {
              "language": "ar",
              "text": "التغليف الزائد يسبب نفايات غير ضرورية."
            },
            {
              "language": "ckb",
              "text": "پاکەتکردنی زۆر خۆڵی ناپێویست دروست دەکات."
            },
            {
              "language": "en",
              "text": "Too much packaging causes unnecessary waste."
            },
            {
              "language": "fa",
              "text": "بسته‌بندی زیاد زباله غیرضروری ایجاد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Pakêtkirina zêde zibilê nepêwîst çêdike."
            },
            {
              "language": "pl",
              "text": "Zbyt dużo opakowań powoduje niepotrzebne odpady."
            },
            {
              "language": "ro",
              "text": "Prea mult ambalaj cauzează deșeuri inutile."
            },
            {
              "language": "ru",
              "text": "Слишком много упаковки создает лишний мусор."
            },
            {
              "language": "sq",
              "text": "Shumë paketim shkakton mbeturina të panevojshme."
            },
            {
              "language": "tr",
              "text": "Fazla ambalaj gereksiz atığa neden olur."
            }
          ]
        }
      ]
    },
