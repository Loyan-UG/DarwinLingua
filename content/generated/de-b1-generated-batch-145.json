  "entries": [
    {
      "word": "vertun",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "vertun",
      "pronunciationIpa": null,
      "syllableBreak": "ver-tun",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular/reflexive verb: sich vertun, vertut sich, vertat sich, hat sich vertan"
      ],
      "collocations": [
        {
          "text": "sich im Datum vertun",
          "meaning": "to get the date wrong"
        },
        {
          "text": "sich bei einer Zahl vertun",
          "meaning": "to make a mistake with a number"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "tun",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يخطئ؛ يلتبس عليه الأمر"
        },
        {
          "language": "ckb",
          "text": "هەڵەکردن؛ تێکەڵکردن"
        },
        {
          "language": "en",
          "text": "to make a mistake; to get something wrong"
        },
        {
          "language": "fa",
          "text": "اشتباه کردن؛ اشتباه گرفتن"
        },
        {
          "language": "kmr",
          "text": "şaş kirin; şaş têgihîştin"
        },
        {
          "language": "pl",
          "text": "pomylić się"
        },
        {
          "language": "ro",
          "text": "a se înșela; a greși"
        },
        {
          "language": "ru",
          "text": "ошибиться; перепутать"
        },
        {
          "language": "sq",
          "text": "të gabosh; të ngatërrosh"
        },
        {
          "language": "tr",
          "text": "yanılmak; hata yapmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe mich beim Termin vertan; die Besprechung ist erst morgen.",
          "translations": [
            {
              "language": "ar",
              "text": "لقد أخطأت في الموعد؛ الاجتماع غدًا فقط."
            },
            {
              "language": "ckb",
              "text": "لە کاتەکەدا هەڵەم کرد؛ کۆبوونەوەکە تەنها سبەیە."
            },
            {
              "language": "en",
              "text": "I got the appointment wrong; the meeting is not until tomorrow."
            },
            {
              "language": "fa",
              "text": "من در زمان قرار اشتباه کردم؛ جلسه تازه فرداست."
            },
            {
              "language": "kmr",
              "text": "Min di randevûyê de şaş kir; civîn tenê sibê ye."
            },
            {
              "language": "pl",
              "text": "Pomyliłem się co do terminu; spotkanie jest dopiero jutro."
            },
            {
              "language": "ro",
              "text": "M-am înșelat în privința programării; ședința este abia mâine."
            },
            {
              "language": "ru",
              "text": "Я ошибся со временем встречи; совещание только завтра."
            },
            {
              "language": "sq",
              "text": "U gabova me takimin; mbledhja është vetëm nesër."
            },
            {
              "language": "tr",
              "text": "Randevu konusunda yanılmışım; toplantı ancak yarın."
            }
          ]
        },
        {
          "baseText": "Bei der Artikelnummer hat sich der Mitarbeiter um eine Ziffer vertan.",
          "translations": [
            {
              "language": "ar",
              "text": "أخطأ الموظف في رقم واحد من رقم المنتج."
            },
            {
              "language": "ckb",
              "text": "کارمەندەکە لە ژمارەی کاڵاکەدا بە یەک ژمارە هەڵەی کرد."
            },
            {
              "language": "en",
              "text": "The employee got one digit wrong in the item number."
            },
            {
              "language": "fa",
              "text": "کارمند در شماره کالا یک رقم را اشتباه وارد کرد."
            },
            {
              "language": "kmr",
              "text": "Karmend di hejmarê hilberê de bi yek jimareyê şaş kir."
            },
            {
              "language": "pl",
              "text": "Pracownik pomylił jedną cyfrę w numerze artykułu."
            },
            {
              "language": "ro",
              "text": "Angajatul a greșit o cifră în numărul articolului."
            },
            {
              "language": "ru",
              "text": "Сотрудник ошибся на одну цифру в номере товара."
            },
            {
              "language": "sq",
              "text": "Punonjësi gaboi një shifër në numrin e artikullit."
            },
            {
              "language": "tr",
              "text": "Çalışan ürün numarasında bir rakamı yanlış girdi."
            }
          ]
        }
      ]
    },
    {
