  "entries": [
    {
      "word": "Schwund",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Schwundmengen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Schwund",
      "topics": [
        "warehouse-and-logistics",
        "finance-and-accounting",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "analysis",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; loss of stock due to damage, theft, shrinkage, or counting differences"
      ],
      "collocations": [
        {
          "text": "Schwund buchen",
          "meaning": "to post shrinkage"
        },
        {
          "text": "Schwund auswerten",
          "meaning": "to analyze stock loss"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schwinden",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "فقدان المخزون؛ نقص"
        },
        {
          "language": "ckb",
          "text": "کەمیی کۆگا؛ ونبوون"
        },
        {
          "language": "en",
          "text": "shrinkage; stock loss"
        },
        {
          "language": "fa",
          "text": "کسری موجودی؛ افت انبار"
        },
        {
          "language": "kmr",
          "text": "kêmbûna stokê"
        },
        {
          "language": "pl",
          "text": "ubytek; braki magazynowe"
        },
        {
          "language": "ro",
          "text": "pierdere de stoc"
        },
        {
          "language": "ru",
          "text": "усушка; недостача"
        },
        {
          "language": "sq",
          "text": "humbje stoku"
        },
        {
          "language": "tr",
          "text": "fire; stok kaybı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Schwund wird im ERP als Korrekturbuchung erfasst.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تسجيل نقص المخزون في ERP كقيد تصحيحي."
            },
            {
              "language": "ckb",
              "text": "کەمیی کۆگا لە ERP دا وەک تۆمارکردنی ڕاستکردنەوە تۆمار دەکرێت."
            },
            {
              "language": "en",
              "text": "The shrinkage is recorded in the ERP as a correction posting."
            },
            {
              "language": "fa",
              "text": "کسری موجودی در ERP به عنوان ثبت اصلاحی وارد می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kêmbûna stokê di ERP de wekî tomarkirina rastkirinê tê tomar kirin."
            },
            {
              "language": "pl",
              "text": "Ubytek jest rejestrowany w ERP jako księgowanie korygujące."
            },
            {
              "language": "ro",
              "text": "Pierderea de stoc este înregistrată în ERP ca înregistrare de corecție."
            },
            {
              "language": "ru",
              "text": "Недостача фиксируется в ERP как корректирующая проводка."
            },
            {
              "language": "sq",
              "text": "Humbja e stokut regjistrohet në ERP si regjistrim korrigjues."
            },
            {
              "language": "tr",
              "text": "Fire ERP’de düzeltme kaydı olarak girilir."
            }
          ]
        },
        {
          "baseText": "Nach der Inventur muss der Lagerleiter erklären, warum der Schwund so hoch ist.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الجرد يجب على مدير المستودع توضيح سبب ارتفاع النقص بهذا الشكل."
            },
            {
              "language": "ckb",
              "text": "دوای ژماردنی کۆگا، بەڕێوەبەری کۆگا پێویستە ڕوون بکاتەوە بۆچی کەمییەکە ئەوەندە بەرزە."
            },
            {
              "language": "en",
              "text": "After the inventory count, the warehouse manager must explain why the shrinkage is so high."
            },
            {
              "language": "fa",
              "text": "پس از انبارگردانی، مدیر انبار باید توضیح دهد چرا کسری موجودی اینقدر زیاد است."
            },
            {
              "language": "kmr",
              "text": "Piştî jimartina stokê, rêvebirê embarê divê rave bike çima kêmbûn ew qas zêde ye."
            },
            {
              "language": "pl",
              "text": "Po inwentaryzacji kierownik magazynu musi wyjaśnić, dlaczego ubytek jest tak wysoki."
            },
            {
              "language": "ro",
              "text": "După inventariere, șeful depozitului trebuie să explice de ce pierderea este atât de mare."
            },
            {
              "language": "ru",
              "text": "После инвентаризации заведующий складом должен объяснить, почему недостача такая большая."
            },
            {
              "language": "sq",
              "text": "Pas inventarizimit, drejtuesi i magazinës duhet të shpjegojë pse humbja është kaq e lartë."
            },
            {
              "language": "tr",
              "text": "Envanter sayımından sonra depo müdürü firenin neden bu kadar yüksek olduğunu açıklamalı."
            }
          ]
        }
      ]
    },
    {
      "word": "Sonderangebot",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "das",
      "plural": "Sonderangebote",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Son-der-an-ge-bot",
      "topics": [
        "sales-and-customers",
        "finance-and-accounting",
        "erp-and-business-systems"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "written",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter compound noun; special offer or promotional offer"
      ],
      "collocations": [
        {
          "text": "ein Sonderangebot erstellen",
          "meaning": "to create a special offer"
        },
        {
          "text": "ein Sonderangebot befristen",
          "meaning": "to limit a special offer in time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Angebot",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "sonder-",
          "relationLabel": "prefix",
          "note": "special"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عرض خاص"
        },
        {
          "language": "ckb",
          "text": "پێشنیاری تایبەت"
        },
        {
          "language": "en",
          "text": "special offer"
        },
        {
          "language": "fa",
          "text": "پیشنهاد ویژه"
        },
        {
          "language": "kmr",
          "text": "pêşniyara taybet"
        },
        {
          "language": "pl",
          "text": "oferta specjalna"
        },
        {
          "language": "ro",
          "text": "ofertă specială"
        },
        {
          "language": "ru",
          "text": "специальное предложение"
        },
        {
          "language": "sq",
          "text": "ofertë speciale"
        },
        {
          "language": "tr",
          "text": "özel teklif"
        }
      ],
      "examples": [
        {
          "baseText": "Das Sonderangebot ist im ERP nur bis Ende des Monats gültig.",
          "translations": [
            {
              "language": "ar",
              "text": "العرض الخاص في ERP صالح فقط حتى نهاية الشهر."
            },
            {
              "language": "ckb",
              "text": "پێشنیاری تایبەت لە ERP دا تەنها تا کۆتایی مانگ کارایە."
            },
            {
              "language": "en",
              "text": "The special offer is valid in the ERP only until the end of the month."
            },
            {
              "language": "fa",
              "text": "پیشنهاد ویژه در ERP فقط تا پایان ماه معتبر است."
            },
            {
              "language": "kmr",
              "text": "Pêşniyara taybet di ERP de tenê heta dawiya mehê derbasdar e."
            },
            {
              "language": "pl",
              "text": "Oferta specjalna jest ważna w ERP tylko do końca miesiąca."
            },
            {
              "language": "ro",
              "text": "Oferta specială este valabilă în ERP doar până la sfârșitul lunii."
            },
            {
              "language": "ru",
              "text": "Специальное предложение действует в ERP только до конца месяца."
            },
            {
              "language": "sq",
              "text": "Oferta speciale është e vlefshme në ERP vetëm deri në fund të muajit."
            },
            {
              "language": "tr",
              "text": "Özel teklif ERP’de yalnızca ay sonuna kadar geçerli."
            }
          ]
        },
        {
          "baseText": "Der Kunde möchte wissen, ob das Sonderangebot auch für kleine Mengen gilt.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد العميل معرفة ما إذا كان العرض الخاص ينطبق أيضًا على الكميات الصغيرة."
            },
            {
              "language": "ckb",
              "text": "کڕیار دەیەوێت بزانێت ئایا پێشنیاری تایبەت بۆ بڕی کەمیش کار دەکات."
            },
            {
              "language": "en",
              "text": "The customer wants to know whether the special offer also applies to small quantities."
            },
            {
              "language": "fa",
              "text": "مشتری می‌خواهد بداند پیشنهاد ویژه برای مقدارهای کم هم اعمال می‌شود یا نه."
            },
            {
              "language": "kmr",
              "text": "Mişterî dixwaze bizane gelo pêşniyara taybet ji bo hejmarên biçûk jî derbas e."
            },
            {
              "language": "pl",
              "text": "Klient chce wiedzieć, czy oferta specjalna obowiązuje także przy małych ilościach."
            },
            {
              "language": "ro",
              "text": "Clientul vrea să știe dacă oferta specială se aplică și pentru cantități mici."
            },
            {
              "language": "ru",
              "text": "Клиент хочет знать, действует ли специальное предложение также для малых количеств."
            },
            {
              "language": "sq",
              "text": "Klienti dëshiron të dijë nëse oferta speciale vlen edhe për sasi të vogla."
            },
            {
              "language": "tr",
              "text": "Müşteri özel teklifin küçük miktarlar için de geçerli olup olmadığını bilmek istiyor."
            }
          ]
        }
      ]
    },
