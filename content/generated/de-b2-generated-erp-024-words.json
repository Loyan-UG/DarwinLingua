      "meanings": [
        {
          "language": "ar",
          "text": "أمر شحن إلى شركة النقل"
        },
        {
          "language": "ckb",
          "text": "داواکاریی کۆمپانیای گواستنەوە"
        },
        {
          "language": "en",
          "text": "forwarding order; freight order"
        },
        {
          "language": "fa",
          "text": "سفارش حمل برای شرکت باربری"
        },
        {
          "language": "kmr",
          "text": "fermana barkirinê"
        },
        {
          "language": "pl",
          "text": "zlecenie spedycyjne"
        },
        {
          "language": "ro",
          "text": "ordin de expediție"
        },
        {
          "language": "ru",
          "text": "экспедиторское поручение"
        },
        {
          "language": "sq",
          "text": "urdhër transporti"
        },
        {
          "language": "tr",
          "text": "nakliye emri"
        }
      ],
      "examples": [
        {
          "baseText": "Der Speditionsauftrag wird im ERP erzeugt, sobald die Lieferung bereitsteht.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم إنشاء أمر الشحن في ERP بمجرد أن تكون الشحنة جاهزة."
            },
            {
              "language": "ckb",
              "text": "داواکاریی کۆمپانیای گواستنەوە لە ERP دا دروست دەکرێت هەر کات گەیاندنەکە ئامادە بێت."
            },
            {
              "language": "en",
              "text": "The forwarding order is created in the ERP as soon as the delivery is ready."
            },
            {
              "language": "fa",
              "text": "سفارش حمل در ERP به‌محض آماده شدن تحویل ایجاد می‌شود."
            },
            {
              "language": "kmr",
              "text": "Fermana barkirinê di ERP de tê çêkirin dema radestkirin amade be."
            },
            {
              "language": "pl",
