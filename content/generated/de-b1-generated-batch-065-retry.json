      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يسري؛ يكون صالحاً؛ ينطبق"
        },
        {
          "language": "ckb",
          "text": "کارپێکردن؛ ڕەوا بوون؛ پەیوەندیدار بوون"
        },
        {
          "language": "en",
          "text": "to apply; to be valid; to count as"
        },
        {
          "language": "fa",
          "text": "اعتبار داشتن؛ اعمال شدن؛ محسوب شدن"
        },
        {
          "language": "kmr",
          "text": "derbas bûn; lêhatin; wekî hatin hesibandin"
        },
        {
          "language": "pl",
          "text": "obowiązywać; być ważnym; uchodzić za"
        },
        {
          "language": "ro",
          "text": "a fi valabil; a se aplica; a fi considerat"
        },
        {
          "language": "ru",
          "text": "действовать; распространяться; считаться"
        },
        {
          "language": "sq",
          "text": "të vlejë; të zbatohet; të konsiderohet"
        },
        {
          "language": "tr",
          "text": "geçerli olmak; uygulanmak; sayılmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Regel gilt ab Montag für alle Mitarbeiter.",
          "translations": [
            {
              "language": "ar",
              "text": "تسري القاعدة الجديدة اعتباراً من يوم الاثنين على جميع الموظفين."
            },
            {
              "language": "ckb",
              "text": "یاسای نوێ لە دووشەممەوە بۆ هەموو کارمەندان کارپێدەکرێت."
            },
            {
              "language": "en",
              "text": "The new rule applies to all employees from Monday."
            },
            {
              "language": "fa",
              "text": "قانون جدید از دوشنبه برای همه کارکنان اعمال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Rêbaza nû ji roja duşemê ve ji bo hemû karmendan derbas dibe."
            },
            {
              "language": "pl",
              "text": "Nowa zasada obowiązuje wszystkich pracowników od poniedziałku."
            },
            {
              "language": "ro",
              "text": "Noua regulă se aplică tuturor angajaților începând de luni."
            },
            {
              "language": "ru",
              "text": "Новое правило действует для всех сотрудников с понедельника."
            },
            {
              "language": "sq",
              "text": "Rregulli i ri vlen për të gjithë punonjësit nga e hëna."
            },
            {
              "language": "tr",
              "text": "Yeni kural pazartesiden itibaren tüm çalışanlar için geçerlidir."
            }
          ]
        },
        {
          "baseText": "Das Angebot gilt nur noch bis Ende der Woche.",
          "translations": [
            {
              "language": "ar",
              "text": "العرض صالح فقط حتى نهاية الأسبوع."
            },
            {
              "language": "ckb",
              "text": "پێشنیارەکە تەنها تا کۆتایی هەفتەکە ڕەوایە."
            },
            {
              "language": "en",
              "text": "The offer is only valid until the end of the week."
            },
            {
              "language": "fa",
              "text": "این پیشنهاد فقط تا پایان هفته اعتبار دارد."
            },
            {
              "language": "kmr",
              "text": "Ev pêşniyar tenê heta dawiya hefteyê derbas e."
            },
            {
              "language": "pl",
              "text": "Oferta jest ważna tylko do końca tygodnia."
            },
            {
              "language": "ro",
              "text": "Oferta este valabilă doar până la sfârșitul săptămânii."
            },
            {
              "language": "ru",
              "text": "Предложение действительно только до конца недели."
            },
            {
              "language": "sq",
              "text": "Oferta vlen vetëm deri në fund të javës."
            },
            {
              "language": "tr",
              "text": "Teklif sadece haftanın sonuna kadar geçerlidir."
            }
          ]
        }
      ]
    }
  ],
