      ],
      "collocations": [
        {
          "text": "die Gehaltsabrechnung prüfen",
          "meaning": "to check the payslip"
        },
        {
          "text": "eine Gehaltsabrechnung herunterladen",
          "meaning": "to download a payslip"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Gehalt",
          "relationLabel": "base noun",
          "note": null
        },
        {
          "lemma": "abrechnen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قسيمة الراتب؛ كشف الراتب"
        },
        {
          "language": "ckb",
          "text": "پسوولەی مووچە؛ حسابی مووچە"
        },
        {
          "language": "en",
          "text": "payslip; salary statement"
        },
        {
          "language": "fa",
          "text": "فیش حقوقی؛ صورت‌حساب حقوق"
        },
        {
          "language": "kmr",
          "text": "belgeya meaşê; hesabnameya mûçeyê"
        },
        {
          "language": "pl",
          "text": "pasek płacowy; rozliczenie wynagrodzenia"
        },
        {
          "language": "ro",
          "text": "fluturaș de salariu; stat de plată"
        },
        {
          "language": "ru",
          "text": "расчетный листок; ведомость зарплаты"
        },
        {
          "language": "sq",
          "text": "fletëpagesë; llogaritje e pagës"
        },
        {
          "language": "tr",
          "text": "maaş bordrosu; ücret hesap pusulası"
        }
      ],
      "examples": [
        {
          "baseText": "In der Gehaltsabrechnung steht, wie viel Steuer abgezogen wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "يوضح كشف الراتب مقدار الضريبة التي تم خصمها."
            },
            {
              "language": "ckb",
              "text": "لە پسوولەی مووچەدا نووسراوە چەند باج کەمکراوەتەوە."
            },
            {
              "language": "en",
              "text": "The payslip shows how much tax was deducted."
            },
            {
              "language": "fa",
              "text": "در فیش حقوقی نوشته شده چه مقدار مالیات کسر شده است."
            },
            {
              "language": "kmr",
              "text": "Di belgeya meaşê de nivîsandî ye ka çiqas bac hatiye kêmkirin."
            },
            {
              "language": "pl",
              "text": "Na pasku płacowym jest napisane, ile podatku zostało potrącone."
            },
            {
              "language": "ro",
              "text": "Pe fluturașul de salariu scrie cât impozit a fost reținut."
            },
            {
              "language": "ru",
              "text": "В расчетном листке указано, сколько налога было удержано."
            },
            {
              "language": "sq",
              "text": "Në fletëpagesë shkruhet sa taksë është zbritur."
            },
            {
              "language": "tr",
              "text": "Maaş bordrosunda ne kadar vergi kesildiği yazıyor."
            }
          ]
        },
        {
          "baseText": "Die Mitarbeiter können ihre Gehaltsabrechnung im Portal herunterladen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكن للموظفين تنزيل قسيمة الراتب من البوابة."
            },
            {
              "language": "ckb",
              "text": "کارمەندان دەتوانن پسوولەی مووچەیان لە پۆرتاڵەکە دابگرن."
            },
            {
              "language": "en",
              "text": "Employees can download their payslip from the portal."
            },
            {
              "language": "fa",
              "text": "کارکنان می‌توانند فیش حقوقی خود را از پورتال دانلود کنند."
            },
            {
              "language": "kmr",
              "text": "Karmend dikarin belgeya meaşa xwe ji portalê daxînin."
            },
            {
              "language": "pl",
              "text": "Pracownicy mogą pobrać swoją listę płac z portalu."
            },
            {
              "language": "ro",
              "text": "Angajații își pot descărca fluturașul de salariu din portal."
            },
            {
              "language": "ru",
              "text": "Сотрудники могут скачать свой расчетный листок на портале."
            },
            {
              "language": "sq",
              "text": "Punonjësit mund ta shkarkojnë fletëpagesën e tyre nga portali."
            },
            {
              "language": "tr",
              "text": "Çalışanlar maaş bordrolarını portaldan indirebilir."
            }
          ]
        }
      ]
    },
