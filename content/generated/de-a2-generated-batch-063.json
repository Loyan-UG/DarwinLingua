            },
            {
              "language": "en",
              "text": "Please bring the folder to the appointment."
            },
            {
              "language": "fa",
              "text": "لطفاً پوشه را به وقت ملاقات بیاورید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe dosyayê bi xwe re bînin hevdîtinê."
            },
            {
              "language": "pl",
              "text": "Proszę przynieść teczkę na termin."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să aduceți mapa la programare."
