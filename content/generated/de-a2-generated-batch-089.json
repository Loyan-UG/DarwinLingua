      "examples": [
        {
          "baseText": "Ist dieser Sitzplatz noch frei?",
          "translations": [
            {
              "language": "ar",
              "text": "هل هذا المقعد ما زال شاغراً؟"
            },
            {
              "language": "ckb",
              "text": "ئایا ئەم شوێنی دانیشتنە هێشتا بەتاڵە؟"
            },
            {
              "language": "en",
              "text": "Is this seat still free?"
            },
            {
              "language": "fa",
              "text": "آیا این صندلی هنوز خالی است؟"
            },
            {
              "language": "kmr",
              "text": "Ma ev cihê rûniştinê hêj vala ye?"
            },
            {
              "language": "pl",
              "text": "Czy to miejsce jest jeszcze wolne?"
            },
            {
              "language": "ro",
              "text": "Este acest loc încă liber?"
            },
            {
              "language": "ru",
              "text": "Это место еще свободно?"
            },
            {
              "language": "sq",
              "text": "A është ende i lirë ky vend?"
            },
            {
              "language": "tr",
              "text": "Bu koltuk hâlâ boş mu?"
            }
          ]
        },
        {
          "baseText": "Ich habe einen Sitzplatz am Fenster reserviert.",
          "translations": [
            {
              "language": "ar",
              "text": "لقد حجزت مقعداً بجانب النافذة."
            },
            {
              "language": "ckb",
              "text": "من شوێنی دانیشتنێکم لە تەنیشت پەنجەرەکە حجز کردووە."
            },
            {
              "language": "en",
              "text": "I reserved a seat by the window."
            },
            {
              "language": "fa",
              "text": "من یک صندلی کنار پنجره رزرو کرده‌ام."
            },
            {
              "language": "kmr",
              "text": "Min cihê rûniştinê li kêleka paceyê veqetand."
            },
            {
              "language": "pl",
              "text": "Zarezerwowałem miejsce przy oknie."
            },
            {
              "language": "ro",
              "text": "Am rezervat un loc lângă fereastră."
            },
            {
              "language": "ru",
              "text": "Я забронировал место у окна."
            },
            {
              "language": "sq",
              "text": "Kam rezervuar një vend pranë dritares."
            },
            {
              "language": "tr",
              "text": "Pencere kenarında bir koltuk ayırttım."
            }
