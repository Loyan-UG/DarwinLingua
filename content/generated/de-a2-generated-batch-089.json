          "text": "të ulesh; të rrish ulur"
        },
        {
          "language": "tr",
          "text": "oturmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte sitzen Sie hier und warten Sie kurz.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الجلوس هنا والانتظار قليلاً."
            },
            {
              "language": "ckb",
              "text": "تکایە لێرە دابنیشن و کەمێک چاوەڕێ بکەن."
            },
            {
              "language": "en",
              "text": "Please sit here and wait a moment."
            },
            {
              "language": "fa",
              "text": "لطفاً اینجا بنشینید و کمی صبر کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li vir rûnin û demek kurt bisekinin."
            },
            {
              "language": "pl",
              "text": "Proszę usiąść tutaj i chwilę poczekać."
            },
            {
              "language": "ro",
              "text": "Vă rog să stați aici și să așteptați puțin."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сядьте здесь и немного подождите."
            },
            {
              "language": "sq",
              "text": "Ju lutem uluni këtu dhe prisni pak."
            },
            {
              "language": "tr",
              "text": "Lütfen buraya oturun ve kısa bir süre bekleyin."
            }
          ]
        },
        {
          "baseText": "Im Zug sitzen wir am Fenster.",
          "translations": [
            {
              "language": "ar",
              "text": "في القطار نجلس بجانب النافذة."
            },
            {
              "language": "ckb",
              "text": "لە شەمەندەفەردا لە تەنیشت پەنجەرەکە دادەنیشین."
            },
            {
              "language": "en",
              "text": "On the train, we sit by the window."
            },
            {
              "language": "fa",
              "text": "در قطار کنار پنجره می‌نشینیم."
            },
            {
              "language": "kmr",
              "text": "Di trênê de em li kêleka paceyê rûdinên."
            },
            {
              "language": "pl",
              "text": "W pociągu siedzimy przy oknie."
            },
            {
              "language": "ro",
              "text": "În tren stăm lângă fereastră."
            },
            {
              "language": "ru",
              "text": "В поезде мы сидим у окна."
            },
            {
              "language": "sq",
              "text": "Në tren ulemi pranë dritares."
            },
            {
              "language": "tr",
              "text": "Trende pencere kenarında oturuyoruz."
            }
          ]
        }
      ]
