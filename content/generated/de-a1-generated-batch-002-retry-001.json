      "examples": [
        {
          "baseText": "Meine Tochter ist achtzehn Jahre alt.",
          "translations": [
            {
              "language": "ar",
              "text": "ابنتي عمرها ثمانية عشر عاماً."
            },
            {
              "language": "ckb",
              "text": "کچەکەم هەژدە ساڵە."
            },
            {
              "language": "en",
              "text": "My daughter is eighteen years old."
            },
            {
              "language": "fa",
              "text": "دخترم هجده ساله است."
            },
            {
              "language": "kmr",
              "text": "Keça min hejdeh salî ye."
            },
            {
              "language": "pl",
              "text": "Moja córka ma osiemnaście lat."
            },
            {
              "language": "ro",
              "text": "Fiica mea are optsprezece ani."
            },
            {
              "language": "ru",
              "text": "Моей дочери восемнадцать лет."
            },
            {
              "language": "sq",
              "text": "Vajza ime është tetëmbëdhjetë vjeç."
            },
            {
              "language": "tr",
              "text": "Kızım on sekiz yaşında."
            }
          ]
        },
        {
          "baseText": "Der Termin ist um achtzehn Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "الموعد في الساعة الثامنة عشرة."
            },
            {
              "language": "ckb",
              "text": "کاتەکە کاتژمێر هەژدەیە."
            },
            {
              "language": "en",
              "text": "The appointment is at 18:00."
            },
            {
              "language": "fa",
              "text": "وقت ملاقات ساعت هجده است."
            },
            {
              "language": "kmr",
              "text": "Dem di saet hejdehan de ye."
            },
            {
              "language": "pl",
              "text": "Termin jest o osiemnastej."
            },
            {
              "language": "ro",
              "text": "Programarea este la ora optsprezece."
            },
            {
              "language": "ru",
              "text": "Встреча в восемнадцать часов."
            },
            {
              "language": "sq",
              "text": "Takimi është në orën tetëmbëdhjetë."
            },
            {
              "language": "tr",
              "text": "Randevu saat on sekizde."
            }
          ]
        }
      ]
    },
