      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb; means recently or the other day"
      ],
      "collocations": [
        {
          "text": "neulich im Kurs",
          "meaning": "recently in the course"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "neu",
          "relationLabel": "adjective",
          "note": "new"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مؤخراً؛ قبل أيام"
        },
        {
          "language": "ckb",
          "text": "دوایی؛ ئەم دواییانە"
        },
        {
          "language": "en",
          "text": "recently; the other day"
        },
        {
          "language": "fa",
          "text": "اخیراً؛ چند روز پیش"
        },
        {
          "language": "kmr",
          "text": "nêzîk de; vê dawiyê"
        },
        {
          "language": "pl",
          "text": "niedawno; ostatnio"
        },
        {
          "language": "ro",
          "text": "recent; zilele trecute"
        },
        {
          "language": "ru",
          "text": "недавно; на днях"
        },
        {
          "language": "sq",
          "text": "kohët e fundit; para pak ditësh"
        },
        {
          "language": "tr",
          "text": "geçenlerde; yakın zamanda"
        }
      ],
      "examples": [
        {
          "baseText": "Neulich habe ich meine alte Nachbarin getroffen.",
          "translations": [
            {
              "language": "ar",
              "text": "مؤخراً قابلت جارتي القديمة."
            },
            {
              "language": "ckb",
              "text": "ئەم دواییانە دراوسێ کۆنەکەم بینیم."
            },
            {
              "language": "en",
              "text": "Recently I met my old neighbor."
            },
            {
              "language": "fa",
              "text": "چند روز پیش همسایه قدیمی‌ام را دیدم."
            },
            {
              "language": "kmr",
              "text": "Vê dawiyê min cîrana xwe ya kevn dît."
            },
            {
              "language": "pl",
              "text": "Niedawno spotkałem moją dawną sąsiadkę."
            },
            {
              "language": "ro",
              "text": "Zilele trecute m-am întâlnit cu vechea mea vecină."
            },
            {
              "language": "ru",
              "text": "Недавно я встретил свою старую соседку."
            },
            {
              "language": "sq",
              "text": "Para pak ditësh takova fqinjen time të vjetër."
            },
            {
              "language": "tr",
              "text": "Geçenlerde eski komşumu gördüm."
            }
          ]
        },
        {
          "baseText": "Neulich war ich in einem neuen Café.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل أيام كنت في مقهى جديد."
            },
            {
              "language": "ckb",
              "text": "دوایی لە کافێیەکی نوێ بووم."
            },
            {
              "language": "en",
              "text": "The other day I was in a new café."
            },
            {
              "language": "fa",
              "text": "چند روز پیش در یک کافه جدید بودم."
            },
            {
              "language": "kmr",
              "text": "Nêzîk de ez li kafeyeke nû bûm."
            },
            {
              "language": "pl",
              "text": "Ostatnio byłem w nowej kawiarni."
            },
            {
              "language": "ro",
              "text": "Recent am fost într-o cafenea nouă."
            },
            {
              "language": "ru",
              "text": "На днях я был в новом кафе."
            },
            {
              "language": "sq",
              "text": "Para pak ditësh isha në një kafene të re."
            },
            {
              "language": "tr",
              "text": "Geçenlerde yeni bir kafedeydim."
            }
          ]
        }
      ]
    },
