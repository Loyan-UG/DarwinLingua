      ],
      "collocations": [
        {
          "text": "normalerweise morgens",
          "meaning": "usually in the morning"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "normal",
          "relationLabel": "adjective",
          "note": "normal"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عادةً؛ في العادة"
        },
        {
          "language": "ckb",
          "text": "بە ئاسایی؛ زۆرجار"
        },
        {
          "language": "en",
          "text": "usually; normally"
        },
        {
          "language": "fa",
          "text": "معمولاً؛ به طور معمول"
        },
        {
          "language": "kmr",
          "text": "bi gelemperî"
        },
        {
          "language": "pl",
          "text": "zwykle; normalnie"
        },
        {
          "language": "ro",
          "text": "de obicei; în mod normal"
        },
        {
          "language": "ru",
          "text": "обычно; как правило"
        },
        {
          "language": "sq",
          "text": "zakonisht; normalisht"
        },
        {
          "language": "tr",
          "text": "normalde; genellikle"
        }
      ],
      "examples": [
        {
          "baseText": "Normalerweise fahre ich mit dem Bus zur Arbeit.",
          "translations": [
            {
              "language": "ar",
              "text": "عادةً أذهب إلى العمل بالحافلة."
            },
            {
              "language": "ckb",
              "text": "بە ئاسایی بە پاس دەچم بۆ کار."
            },
            {
              "language": "en",
              "text": "I usually go to work by bus."
            },
            {
              "language": "fa",
              "text": "معمولاً با اتوبوس به محل کار می‌روم."
            },
            {
              "language": "kmr",
              "text": "Bi gelemperî ez bi otobusê diçim xebatê."
            },
            {
              "language": "pl",
              "text": "Zwykle jeżdżę do pracy autobusem."
            },
            {
              "language": "ro",
              "text": "De obicei merg la serviciu cu autobuzul."
            },
            {
              "language": "ru",
              "text": "Обычно я езжу на работу на автобусе."
            },
            {
              "language": "sq",
              "text": "Zakonisht shkoj në punë me autobus."
            },
            {
              "language": "tr",
              "text": "Normalde işe otobüsle giderim."
            }
          ]
        },
        {
          "baseText": "Der Kurs beginnt normalerweise um neun Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدأ الدورة عادةً في الساعة التاسعة."
            },
            {
              "language": "ckb",
              "text": "کۆرسەکە بە ئاسایی کاتژمێر نۆ دەست پێ دەکات."
            },
            {
              "language": "en",
              "text": "The course usually starts at nine o’clock."
            },
            {
              "language": "fa",
              "text": "کلاس معمولاً ساعت نه شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kurs bi gelemperî di saet nehê de dest pê dike."
            },
            {
              "language": "pl",
              "text": "Kurs zwykle zaczyna się o dziewiątej."
            },
            {
              "language": "ro",
              "text": "Cursul începe de obicei la ora nouă."
            },
            {
              "language": "ru",
              "text": "Курс обычно начинается в девять часов."
            },
            {
              "language": "sq",
              "text": "Kursi zakonisht fillon në orën nëntë."
            },
            {
              "language": "tr",
              "text": "Kurs normalde saat dokuzda başlar."
            }
          ]
        }
      ]
    },
