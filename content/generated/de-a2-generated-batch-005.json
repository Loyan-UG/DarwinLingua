      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عرض خاص؛ حملة؛ إجراء"
        },
        {
          "language": "ckb",
          "text": "داشکاندن؛ هەڵمەت؛ کردار"
        },
        {
          "language": "en",
          "text": "promotion; campaign; action"
        },
        {
          "language": "fa",
          "text": "تخفیف ویژه؛ کمپین؛ اقدام"
        },
        {
          "language": "kmr",
          "text": "kampanya; çalakî; kiryar"
        },
        {
          "language": "pl",
          "text": "promocja; akcja"
        },
        {
          "language": "ro",
          "text": "promoție; campanie; acțiune"
        },
        {
          "language": "ru",
          "text": "акция; кампания; действие"
        },
        {
          "language": "sq",
          "text": "aksion; fushatë; veprim"
        },
        {
          "language": "tr",
          "text": "kampanya; eylem; indirim"
        }
      ],
      "examples": [
        {
          "baseText": "Diese Woche gibt es eine Aktion für Kaffee.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا الأسبوع يوجد عرض خاص على القهوة."
            },
            {
              "language": "ckb",
              "text": "ئەم هەفتەیە داشکاندن بۆ قاوە هەیە."
            },
            {
              "language": "en",
              "text": "This week there is a promotion for coffee."
            },
            {
              "language": "fa",
              "text": "این هفته برای قهوه تخفیف ویژه وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Vê hefteyê ji bo qehweyê kampanyayek heye."
            },
            {
              "language": "pl",
              "text": "W tym tygodniu jest promocja na kawę."
            },
            {
              "language": "ro",
              "text": "Săptămâna aceasta este o promoție la cafea."
            },
            {
              "language": "ru",
              "text": "На этой неделе есть акция на кофе."
            },
            {
              "language": "sq",
              "text": "Këtë javë ka një ofertë për kafe."
            },
            {
              "language": "tr",
              "text": "Bu hafta kahve için kampanya var."
            }
          ]
        },
        {
          "baseText": "Viele Kunden fragen nach der neuen Aktion.",
          "translations": [
            {
              "language": "ar",
              "text": "يسأل كثير من العملاء عن العرض الجديد."
            },
            {
              "language": "ckb",
              "text": "زۆر کڕیار پرسیار لەسەر داشکاندنە نوێیەکە دەکەن."
            },
            {
              "language": "en",
              "text": "Many customers ask about the new promotion."
            },
            {
              "language": "fa",
              "text": "بسیاری از مشتریان درباره تخفیف جدید سؤال می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Gelek xerîdar li ser kampanyaya nû dipirsin."
            },
            {
              "language": "pl",
              "text": "Wielu klientów pyta o nową promocję."
            },
            {
              "language": "ro",
              "text": "Mulți clienți întreabă despre noua promoție."
            },
            {
              "language": "ru",
              "text": "Многие клиенты спрашивают о новой акции."
            },
            {
              "language": "sq",
              "text": "Shumë klientë pyesin për ofertën e re."
            },
            {
              "language": "tr",
              "text": "Birçok müşteri yeni kampanyayı soruyor."
            }
          ]
        }
      ]
    },
