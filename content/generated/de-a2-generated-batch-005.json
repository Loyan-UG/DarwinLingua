      "examples": [
        {
          "baseText": "Meine Großmutter ist noch sehr aktiv.",
          "translations": [
            {
              "language": "ar",
              "text": "جدتي ما زالت نشيطة جداً."
            },
            {
              "language": "ckb",
              "text": "داپیرەم هێشتا زۆر چالاکە."
            },
            {
              "language": "en",
              "text": "My grandmother is still very active."
            },
            {
              "language": "fa",
              "text": "مادربزرگم هنوز خیلی فعال است."
            },
            {
              "language": "kmr",
              "text": "Dapîra min hîn jî pir çalak e."
            },
            {
              "language": "pl",
              "text": "Moja babcia jest jeszcze bardzo aktywna."
            },
            {
              "language": "ro",
              "text": "Bunica mea este încă foarte activă."
            },
            {
              "language": "ru",
              "text": "Моя бабушка все еще очень активна."
            },
            {
              "language": "sq",
              "text": "Gjyshja ime është ende shumë aktive."
            },
            {
              "language": "tr",
              "text": "Büyükannem hâlâ çok aktif."
            }
          ]
        },
        {
          "baseText": "Im Team ist sie aktiv und hilft oft.",
          "translations": [
            {
              "language": "ar",
              "text": "في الفريق هي نشيطة وتساعد كثيراً."
            },
            {
              "language": "ckb",
              "text": "لە تیمەکەدا چالاکە و زۆرجار یارمەتی دەدات."
            },
            {
              "language": "en",
              "text": "In the team, she is active and often helps."
            },
            {
              "language": "fa",
              "text": "او در تیم فعال است و اغلب کمک می‌کند."
            },
            {
              "language": "kmr",
              "text": "Di tîmê de ew çalak e û gelek caran alîkarî dike."
            },
            {
              "language": "pl",
              "text": "W zespole jest aktywna i często pomaga."
            },
            {
              "language": "ro",
              "text": "În echipă este activă și ajută des."
            },
            {
              "language": "ru",
              "text": "В команде она активна и часто помогает."
            },
            {
              "language": "sq",
              "text": "Në ekip ajo është aktive dhe ndihmon shpesh."
            },
            {
              "language": "tr",
              "text": "Takımda aktif ve sık sık yardım ediyor."
            }
          ]
        }
