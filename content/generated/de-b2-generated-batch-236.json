        "human-resources",
        "social-and-relationships"
      ],
      "usageLabels": [
        "business",
        "spoken"
      ],
      "contextLabels": [
        "hr",
        "management"
      ],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "in Teilzeit arbeiten",
          "meaning": "to work part-time"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "teilzeitbeschäftigt",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دوام جزئي"
        },
        {
          "language": "ckb",
          "text": "کارکردن بە نیوەکات"
        },
        {
          "language": "en",
          "text": "part-time work"
        },
        {
          "language": "fa",
          "text": "کار پاره‌وقت"
        },
        {
          "language": "kmr",
          "text": "karê nîvdemî"
        },
        {
          "language": "pl",
          "text": "praca w niepełnym wymiarze"
        },
        {
          "language": "ro",
          "text": "muncă cu normă parțială"
        },
        {
          "language": "ru",
          "text": "неполная занятость"
        },
        {
          "language": "sq",
          "text": "punë me kohë të pjesshme"
        },
        {
          "language": "tr",
          "text": "yarı zamanlı çalışma"
        }
      ],
      "examples": [
        {
          "baseText": "Nach der Elternzeit möchte sie zunächst in Teilzeit zurückkommen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد إجازة رعاية الطفل تريد أن تعود في البداية بدوام جزئي."
            },
            {
              "language": "ckb",
              "text": "دوای مۆڵەتی دایک و باوکایەتی، سەرەتا دەیەوێت بە نیوەکات بگەڕێتەوە."
            },
            {
              "language": "en",
              "text": "After parental leave, she initially wants to return part-time."
            },
            {
              "language": "fa",
              "text": "بعد از مرخصی والدین، او ابتدا می‌خواهد به‌صورت پاره‌وقت برگردد."
            },
            {
              "language": "kmr",
              "text": "Piştî betlaneya dêûbavtiyê, ew dixwaze destpêkê bi nîvdemî vegere."
            },
            {
              "language": "pl",
              "text": "Po urlopie rodzicielskim chce najpierw wrócić do pracy w niepełnym wymiarze."
            },
            {
              "language": "ro",
              "text": "După concediul parental, vrea să revină inițial cu normă parțială."
            },
            {
              "language": "ru",
              "text": "После отпуска по уходу за ребенком она сначала хочет вернуться на неполный день."
            },
            {
              "language": "sq",
              "text": "Pas lejes prindërore, ajo dëshiron fillimisht të kthehet me kohë të pjesshme."
            },
            {
              "language": "tr",
              "text": "Ebeveyn izninden sonra başlangıçta yarı zamanlı dönmek istiyor."
            }
          ]
        },
        {
          "baseText": "In der Abteilung arbeiten mehrere Kollegen in Teilzeit, deshalb planen wir die Übergaben sehr genau.",
          "translations": [
            {
              "language": "ar",
              "text": "في القسم يعمل عدة زملاء بدوام جزئي، لذلك نخطط لعمليات التسليم بدقة كبيرة."
            },
            {
              "language": "ckb",
              "text": "لە بەشەکەدا چەند هاوکارێک بە نیوەکات کار دەکەن، بۆیە گواستنەوەی کارەکان بە وردی پلاندانێین."
            },
            {
              "language": "en",
              "text": "Several colleagues in the department work part-time, so we plan handovers very carefully."
            },
            {
              "language": "fa",
              "text": "در این بخش چند همکار پاره‌وقت کار می‌کنند، بنابراین تحویل کارها را خیلی دقیق برنامه‌ریزی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di beşê de çend hevkar bi nîvdemî dixebitin, ji ber vê yekê em radestkirinan pir bi baldarî plan dikin."
            },
            {
              "language": "pl",
              "text": "W dziale kilku kolegów pracuje w niepełnym wymiarze, dlatego bardzo dokładnie planujemy przekazanie zadań."
            },
            {
              "language": "ro",
              "text": "În departament, mai mulți colegi lucrează cu normă parțială, de aceea planificăm foarte atent predările."
            },
            {
              "language": "ru",
              "text": "В отделе несколько коллег работают неполный день, поэтому мы очень тщательно планируем передачу задач."
            },
            {
              "language": "sq",
              "text": "Në departament disa kolegë punojnë me kohë të pjesshme, prandaj i planifikojmë dorëzimet shumë saktë."
            },
            {
              "language": "tr",
              "text": "Bölümde birkaç çalışma arkadaşı yarı zamanlı çalışıyor, bu yüzden devir teslimleri çok dikkatli planlıyoruz."
            }
          ]
        }
      ]
    },
