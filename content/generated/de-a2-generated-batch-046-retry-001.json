      "examples": [
        {
          "baseText": "Im Kurs machen wir heute Gruppenarbeit.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدورة نقوم اليوم بعمل جماعي."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسەکەدا ئەمڕۆ کاری گرووپی دەکەین."
            },
            {
              "language": "en",
              "text": "In the course we are doing group work today."
            },
            {
              "language": "fa",
              "text": "امروز در کلاس کار گروهی انجام می‌دهیم."
            },
            {
              "language": "kmr",
              "text": "Di kursê de em îro xebata komê dikin."
            },
            {
              "language": "pl",
              "text": "Na kursie robimy dziś pracę grupową."
            },
            {
              "language": "ro",
              "text": "La curs facem astăzi lucru în grup."
            },
            {
              "language": "ru",
              "text": "На курсе мы сегодня делаем групповую работу."
            },
            {
              "language": "sq",
              "text": "Në kurs sot bëjmë punë në grup."
            },
            {
              "language": "tr",
              "text": "Kursta bugün grup çalışması yapıyoruz."
            }
          ]
        },
        {
          "baseText": "Die Gruppenarbeit dauert zwanzig Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "العمل الجماعي يستغرق عشرين دقيقة."
            },
            {
              "language": "ckb",
              "text": "کاری گرووپی بیست خولەک دەخایەنێت."
            },
            {
              "language": "en",
              "text": "The group work lasts twenty minutes."
            },
            {
              "language": "fa",
              "text": "کار گروهی بیست دقیقه طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Xebata komê bîst deqe dirêj dibe."
            },
            {
              "language": "pl",
              "text": "Praca grupowa trwa dwadzieścia minut."
            },
            {
              "language": "ro",
              "text": "Lucrul în grup durează douăzeci de minute."
            },
            {
              "language": "ru",
              "text": "Групповая работа длится двадцать минут."
            },
            {
              "language": "sq",
              "text": "Puna në grup zgjat njëzet minuta."
            },
            {
              "language": "tr",
              "text": "Grup çalışması yirmi dakika sürer."
