      "examples": [
        {
          "baseText": "Die Eigenschaften des Artikels stehen im ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "خصائص الصنف موجودة في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "تایبەتمەندییەکانی کاڵاکە لە سیستەمی ERPدا هەن."
            },
            {
              "language": "en",
              "text": "The item properties are in the ERP system."
            },
            {
              "language": "fa",
              "text": "ویژگی‌های کالا در سیستم ERP هستند."
            },
            {
              "language": "kmr",
              "text": "Taybetmendiyên tiştê di pergala ERP de ne."
            },
            {
              "language": "pl",
              "text": "Właściwości artykułu są w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Proprietățile articolului sunt în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Свойства товара находятся в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Veçoritë e artikullit janë në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Ürünün özellikleri ERP sisteminde yer alıyor."
            }
          ]
        },
        {
          "baseText": "Dieses Handy hat viele gute Eigenschaften.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا الهاتف لديه كثير من الخصائص الجيدة."
            },
            {
              "language": "ckb",
              "text": "ئەم مۆبایلە زۆر تایبەتمەندیی باشی هەیە."
            },
            {
              "language": "en",
              "text": "This phone has many good features."
            },
            {
              "language": "fa",
              "text": "این گوشی ویژگی‌های خوب زیادی دارد."
            },
            {
              "language": "kmr",
              "text": "Ev telefon gelek taybetmendiyên baş hene."
            },
            {
              "language": "pl",
              "text": "Ten telefon ma wiele dobrych cech."
            },
            {
              "language": "ro",
              "text": "Acest telefon are multe caracteristici bune."
            },
            {
              "language": "ru",
              "text": "У этого телефона много хороших характеристик."
            },
            {
              "language": "sq",
              "text": "Ky telefon ka shumë veçori të mira."
            },
            {
              "language": "tr",
              "text": "Bu telefonun birçok iyi özelliği var."
            }
          ]
        }
