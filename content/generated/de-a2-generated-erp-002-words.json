            {
              "language": "sq",
              "text": "Departamenti i blerjeve porosit mallin përmes sistemit ERP."
            },
            {
              "language": "tr",
              "text": "Satın alma, malı ERP sistemi üzerinden sipariş eder."
            }
          ]
        },
        {
          "baseText": "Ich mache den Einkauf am Samstag.",
          "translations": [
            {
              "language": "ar",
              "text": "من يوم السبت أقوم بالتسوق."
            },
            {
              "language": "ckb",
              "text": "من شەممە کڕین دەکەم."
            },
            {
              "language": "en",
              "text": "I do the shopping on Saturday."
            },
            {
              "language": "fa",
              "text": "من خرید را شنبه انجام می‌دهم."
            },
            {
              "language": "kmr",
              "text": "Ez roja şemiyê kirînê dikim."
            },
            {
              "language": "pl",
              "text": "Robię zakupy w sobotę."
            },
            {
              "language": "ro",
              "text": "Fac cumpărăturile sâmbătă."
