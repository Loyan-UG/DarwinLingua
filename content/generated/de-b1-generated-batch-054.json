  "entries": [
    {
      "word": "erschrecken",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "erschrecken",
      "pronunciationIpa": null,
      "syllableBreak": "er-schre-cken",
      "topics": [
        "everyday-life",
        "social-and-relationships",
        "customer-service"
      ],
      "usageLabels": [
        "spoken",
        "written"
      ],
      "contextLabels": [
        "customer-service",
        "support"
      ],
      "grammarNotes": [
        "can be weak when transitive: erschreckt, erschreckte, hat erschreckt; strong/intransitive: erschrickt, erschrak, ist erschrocken"
      ],
      "collocations": [
        {
          "text": "sich sehr erschrecken",
          "meaning": "to get very frightened"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Schreck",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يُفزع؛ يخاف فجأة"
        },
        {
          "language": "ckb",
          "text": "ترساندن؛ لەناکاو ترسان"
        },
        {
          "language": "en",
          "text": "to frighten; to get startled"
        },
        {
          "language": "fa",
          "text": "ترساندن؛ ناگهان ترسیدن"
        },
        {
          "language": "kmr",
          "text": "tirsandin; ji nişka ve tirsîn"
        },
        {
          "language": "pl",
          "text": "przestraszyć; wystraszyć się"
        },
        {
          "language": "ro",
          "text": "a speria; a se speria"
        },
        {
          "language": "ru",
          "text": "пугать; испугаться"
        },
        {
          "language": "sq",
          "text": "të trembësh; të trembesh"
        },
        {
          "language": "tr",
          "text": "korkutmak; irkilmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der laute Alarm hat die Kunden im Laden erschreckt.",
          "translations": [
            {
              "language": "ar",
              "text": "أفزع الإنذار العالي العملاء في المتجر."
            },
            {
              "language": "ckb",
              "text": "ئاگادارکەرەوەی بەرز کڕیارانی ناو دوکانەکەی ترساند."
            },
            {
              "language": "en",
              "text": "The loud alarm frightened the customers in the shop."
            },
            {
              "language": "fa",
              "text": "آژیر بلند مشتریان داخل فروشگاه را ترساند."
            },
            {
              "language": "kmr",
              "text": "Alarmê bilind xerîdarên di firoşgehê de tirsand."
            },
            {
              "language": "pl",
              "text": "Głośny alarm przestraszył klientów w sklepie."
            },
            {
              "language": "ro",
              "text": "Alarma puternică i-a speriat pe clienții din magazin."
            },
            {
              "language": "ru",
              "text": "Громкая сигнализация испугала клиентов в магазине."
            },
            {
              "language": "sq",
              "text": "Alarmi i fortë i trembi klientët në dyqan."
            },
            {
              "language": "tr",
              "text": "Yüksek alarm sesi mağazadaki müşterileri korkuttu."
            }
          ]
        },
        {
          "baseText": "Ich bin erschrocken, als plötzlich jemand an die Tür geklopft hat.",
          "translations": [
            {
              "language": "ar",
              "text": "خفت عندما طرق شخص ما الباب فجأة."
            },
            {
              "language": "ckb",
              "text": "ترسام کاتێک لەناکاو کەسێک لە دەرگاکەی دا."
            },
            {
              "language": "en",
              "text": "I got startled when someone suddenly knocked on the door."
            },
            {
              "language": "fa",
              "text": "وقتی ناگهان کسی در زد، ترسیدم."
            },
            {
              "language": "kmr",
              "text": "Ez tirsiyam dema ji nişka ve kesekî li derî xist."
            },
            {
              "language": "pl",
              "text": "Przestraszyłem się, gdy nagle ktoś zapukał do drzwi."
            },
            {
              "language": "ro",
              "text": "M-am speriat când cineva a bătut brusc la ușă."
            },
            {
              "language": "ru",
              "text": "Я испугался, когда кто-то внезапно постучал в дверь."
            },
            {
              "language": "sq",
              "text": "U tremba kur dikush trokiti papritur në derë."
            },
            {
              "language": "tr",
              "text": "Aniden biri kapıyı çalınca irkildim."
            }
          ]
        }
      ]
    },
    {
      "word": "erschweren",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "erschweren",
      "pronunciationIpa": null,
      "syllableBreak": "er-schwe-ren",
      "topics": [
        "work-and-jobs",
        "business-communication",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "formal",
        "written"
      ],
      "contextLabels": [
        "management",
        "risk",
        "support"
      ],
      "grammarNotes": [
        "regular verb"
      ],
      "collocations": [
        {
          "text": "die Arbeit erschweren",
          "meaning": "to make the work more difficult"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schwer",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصعّب؛ يجعل الأمر أصعب"
        },
        {
          "language": "ckb",
          "text": "قورسکردن؛ زەحمەتتر کردن"
        },
        {
          "language": "en",
          "text": "to make more difficult; to complicate"
        },
        {
          "language": "fa",
          "text": "دشوار کردن؛ سخت‌تر کردن"
        },
        {
          "language": "kmr",
          "text": "zehmettir kirin; girantir kirin"
        },
        {
          "language": "pl",
          "text": "utrudniać"
        },
        {
          "language": "ro",
          "text": "a îngreuna; a complica"
        },
        {
          "language": "ru",
          "text": "затруднять; усложнять"
        },
        {
          "language": "sq",
          "text": "të vështirësosh"
        },
        {
          "language": "tr",
          "text": "zorlaştırmak; güçleştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Fehlende Informationen erschweren die Bearbeitung der Anfrage.",
          "translations": [
            {
              "language": "ar",
              "text": "المعلومات الناقصة تصعّب معالجة الطلب."
            },
            {
              "language": "ckb",
              "text": "زانیارییە کەمەکان چارەسەرکردنی داواکارییەکە قورس دەکەن."
            },
            {
              "language": "en",
              "text": "Missing information makes processing the request more difficult."
            },
            {
              "language": "fa",
              "text": "اطلاعات ناقص رسیدگی به درخواست را دشوار می‌کند."
            },
            {
              "language": "kmr",
              "text": "Agahiyên kêm xebitandina daxwazê zehmettir dikin."
            },
            {
              "language": "pl",
              "text": "Brakujące informacje utrudniają obsługę zapytania."
            },
            {
              "language": "ro",
              "text": "Informațiile lipsă îngreunează procesarea cererii."
            },
            {
              "language": "ru",
