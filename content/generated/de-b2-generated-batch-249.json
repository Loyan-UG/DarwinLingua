        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يربط؛ يوصل"
        },
        {
          "language": "ckb",
          "text": "پەیوەست دەکات"
        },
        {
          "language": "en",
          "text": "to connect; to link"
        },
        {
          "language": "fa",
          "text": "وصل کردن؛ مرتبط کردن"
        },
        {
          "language": "kmr",
          "text": "girêdan; têkildar kirin"
        },
        {
          "language": "pl",
          "text": "połączyć"
        },
        {
          "language": "ro",
          "text": "a conecta; a lega"
        },
        {
          "language": "ru",
          "text": "соединять; связывать"
        },
        {
          "language": "sq",
          "text": "të lidhësh"
        },
        {
          "language": "tr",
          "text": "bağlamak; ilişkilendirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Schnittstelle verbindet das CRM-System mit dem ERP.",
          "translations": [
            {
              "language": "ar",
              "text": "تربط الواجهة الجديدة نظام إدارة علاقات العملاء بنظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "ڕووکاری پەیوەندیی نوێ سیستەمی CRM بە ERP پەیوەست دەکات."
            },
            {
              "language": "en",
              "text": "The new interface connects the CRM system with the ERP."
            },
            {
              "language": "fa",
              "text": "رابط جدید سیستم CRM را به ERP وصل می‌کند."
            },
            {
              "language": "kmr",
              "text": "Navrûya nû pergala CRM bi ERPê ve girê dide."
            },
            {
              "language": "pl",
              "text": "Nowy interfejs łączy system CRM z ERP."
            },
            {
              "language": "ro",
              "text": "Noua interfață conectează sistemul CRM cu ERP-ul."
            },
            {
              "language": "ru",
              "text": "Новый интерфейс соединяет CRM-систему с ERP."
            },
            {
              "language": "sq",
              "text": "Ndërfaqja e re lidh sistemin CRM me ERP-në."
            },
            {
              "language": "tr",
              "text": "Yeni arayüz CRM sistemini ERP’ye bağlar."
            }
          ]
        },
        {
          "baseText": "Die Veranstaltung verbindet fachliche Vorträge mit praktischen Übungen.",
          "translations": [
            {
              "language": "ar",
              "text": "تجمع الفعالية بين المحاضرات المتخصصة والتمارين العملية."
            },
            {
              "language": "ckb",
              "text": "بۆنەکە وانەی پسپۆڕی لەگەڵ ڕاهێنانی پراکتیکی پەیوەست دەکات."
            },
