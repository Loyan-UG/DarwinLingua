  "entries": [
    {
      "word": "die Weiterbildungsmaßnahme",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Weiterbildungsmaßnahmen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Wei-ter-bil-dungs-maß-nah-me",
      "topics": [
        "education-and-training",
        "work-and-jobs",
        "human-resources"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Weiterbildungsmaßnahme beantragen",
          "meaning": "to apply for a further training measure"
        },
        {
          "text": "an einer Weiterbildungsmaßnahme teilnehmen",
          "meaning": "to take part in a training measure"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Weiterbildung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Maßnahme",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "إجراء تدريب إضافي؛ برنامج تأهيل"
        },
        {
          "language": "ckb",
          "text": "ڕێکاری ڕاهێنانی زیاتر؛ بەرنامەی پەروەردەی پیشەیی"
        },
        {
          "language": "en",
          "text": "further training measure; professional development program"
        },
        {
          "language": "fa",
          "text": "اقدام آموزشی تکمیلی؛ برنامه Weiterbildung"
        },
        {
          "language": "kmr",
          "text": "tedbîra perwerdeya zêde; programa pêşveçûna pîşeyî"
        },
        {
          "language": "pl",
          "text": "działanie szkoleniowe; forma dokształcania"
        },
        {
          "language": "ro",
          "text": "măsură de formare continuă; program de perfecționare"
        },
        {
          "language": "ru",
          "text": "мероприятие по повышению квалификации; программа обучения"
        },
        {
          "language": "sq",
          "text": "masë trajnimi të mëtejshëm; program zhvillimi profesional"
        },
        {
          "language": "tr",
          "text": "mesleki gelişim önlemi; eğitim programı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Weiterbildungsmaßnahme soll die Mitarbeiter auf das neue System vorbereiten.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب أن تُعدّ دورة التأهيل الموظفين للنظام الجديد."
            },
            {
              "language": "ckb",
              "text": "ڕێکاری ڕاهێنانی زیاتر دەبێت کارمەندان بۆ سیستەمی نوێ ئامادە بکات."
            },
            {
              "language": "en",
              "text": "The training measure is intended to prepare employees for the new system."
            },
            {
              "language": "fa",
              "text": "این برنامه آموزشی باید کارکنان را برای سیستم جدید آماده کند."
            },
            {
              "language": "kmr",
              "text": "Tedbîra perwerdeya zêde divê karmendan ji bo sîstema nû amade bike."
            },
            {
              "language": "pl",
              "text": "Działanie szkoleniowe ma przygotować pracowników do nowego systemu."
            },
            {
              "language": "ro",
              "text": "Măsura de formare trebuie să pregătească angajații pentru noul sistem."
            },
            {
              "language": "ru",
              "text": "Мероприятие по обучению должно подготовить сотрудников к новой системе."
            },
            {
              "language": "sq",
              "text": "Masa e trajnimit duhet t’i përgatisë punonjësit për sistemin e ri."
            },
            {
              "language": "tr",
              "text": "Eğitim programı çalışanları yeni sisteme hazırlamalıdır."
            }
          ]
        },
        {
          "baseText": "Die Kosten der Weiterbildungsmaßnahme werden teilweise vom Arbeitgeber übernommen.",
          "translations": [
            {
              "language": "ar",
              "text": "يتحمل صاحب العمل جزءًا من تكاليف برنامج التدريب."
            },
            {
              "language": "ckb",
              "text": "تێچووی ڕێکاری ڕاهێنانەکە بەشێکی لەلایەن خاوەنکارەوە دەدرێت."
            },
            {
              "language": "en",
              "text": "The costs of the training measure are partly covered by the employer."
            },
            {
              "language": "fa",
              "text": "هزینه‌های برنامه آموزشی تا حدی توسط کارفرما پرداخت می‌شود."
            },
            {
              "language": "kmr",
              "text": "Lêçûnên tedbîra perwerdeyê beşek ji hêla kardêr ve têne dayîn."
            },
            {
              "language": "pl",
              "text": "Koszty działania szkoleniowego są częściowo pokrywane przez pracodawcę."
            },
            {
              "language": "ro",
              "text": "Costurile programului de formare sunt acoperite parțial de angajator."
            },
            {
              "language": "ru",
              "text": "Расходы на обучение частично оплачиваются работодателем."
            },
            {
              "language": "sq",
              "text": "Kostot e masës së trajnimit mbulohen pjesërisht nga punëdhënësi."
            },
            {
              "language": "tr",
              "text": "Eğitim programının masrafları kısmen işveren tarafından karşılanır."
            }
          ]
        }
      ]
    },
    {
      "word": "weitergeben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "weitergeben",
      "pronunciationIpa": null,
      "syllableBreak": "wei-ter-ge-ben",
      "topics": [
        "business-communication",
        "customer-service",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable irregular verb: gibt weiter, gab weiter, hat weitergegeben"
      ],
      "collocations": [
        {
          "text": "Informationen weitergeben",
          "meaning": "to pass on information"
        },
        {
          "text": "eine Nachricht weitergeben",
          "meaning": "to forward/pass on a message"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "geben",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينقل؛ يمرر؛ يشارك"
        },
        {
          "language": "ckb",
          "text": "گواستنەوە؛ پێدانەوە؛ هاوبەشکردن"
        },
        {
          "language": "en",
          "text": "to pass on; to forward; to share"
        },
        {
          "language": "fa",
          "text": "منتقل کردن؛ اطلاع دادن؛ به اشتراک گذاشتن"
        },
        {
          "language": "kmr",
          "text": "derbas kirin; ragihandin; parve kirin"
        },
        {
          "language": "pl",
          "text": "przekazać; przesłać dalej"
        },
        {
          "language": "ro",
          "text": "a transmite mai departe; a redirecționa"
        },
        {
          "language": "ru",
          "text": "передавать; пересылать"
        },
        {
          "language": "sq",
          "text": "të përcjellësh; të kalosh më tej"
        },
        {
          "language": "tr",
          "text": "iletmek; aktarmak; paylaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich gebe Ihre Nachricht an die zuständige Kollegin weiter.",
          "translations": [
            {
              "language": "ar",
              "text": "سأنقل رسالتك إلى الزميلة المسؤولة."
            },
            {
              "language": "ckb",
              "text": "پەیامەکەت بۆ هاوکارە ژنە بەرپرسیارەکە دەگوازمەوە."
            },
            {
              "language": "en",
              "text": "I will pass your message on to the responsible colleague."
            },
            {
              "language": "fa",
              "text": "پیام شما را به همکار مسئول منتقل می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez peyama we ji hevkara berpirsiyar re derbas dikim."
            },
            {
              "language": "pl",
              "text": "Przekażę Państwa wiadomość odpowiedniej koleżance."
            },
            {
              "language": "ro",
              "text": "Voi transmite mesajul dumneavoastră colegei responsabile."
            },
            {
              "language": "ru",
              "text": "Я передам ваше сообщение ответственной коллеге."
            },
            {
              "language": "sq",
              "text": "Do t’ia përcjell mesazhin tuaj koleges përgjegjëse."
            },
            {
              "language": "tr",
              "text": "Mesajınızı sorumlu kadın çalışma arkadaşıma ileteceğim."
            }
          ]
        },
        {
          "baseText": "Bitte geben Sie vertrauliche Daten nicht ohne Erlaubnis weiter.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى عدم نقل البيانات السرية دون إذن."
            },
            {
              "language": "ckb",
              "text": "تکایە داتای نهێنی بێ مۆڵەت بە کەسی تر مەدەن."
            },
            {
              "language": "en",
              "text": "Please do not share confidential data without permission."
            },
            {
              "language": "fa",
              "text": "لطفاً داده‌های محرمانه را بدون اجازه منتقل نکنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe daneyên nihênî bê destûr parve nekin."
            },
            {
              "language": "pl",
              "text": "Proszę nie przekazywać poufnych danych bez pozwolenia."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să nu transmiteți date confidențiale fără permisiune."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не передавайте конфиденциальные данные без разрешения."
            },
            {
              "language": "sq",
              "text": "Ju lutemi mos i përcillni të dhënat konfidenciale pa leje."
            },
            {
              "language": "tr",
              "text": "Lütfen gizli verileri izin olmadan paylaşmayın."
            }
          ]
        }
      ]
    },
