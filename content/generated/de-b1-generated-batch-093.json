      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يدوّن أثناء الاستماع؛ يكتب الملاحظات"
        },
        {
          "language": "ckb",
          "text": "تێبینی دەنووسێت لەکاتی گوێگرتن"
        },
        {
          "language": "en",
          "text": "to take notes; to write along"
        },
        {
          "language": "fa",
          "text": "یادداشت برداشتن؛ هم‌زمان نوشتن"
        },
        {
          "language": "kmr",
          "text": "not girtin; hevdem nivîsîn"
        },
        {
          "language": "pl",
          "text": "notować; pisać na bieżąco"
        },
        {
          "language": "ro",
          "text": "a lua notițe; a scrie în timp ce ascultă"
        },
        {
          "language": "ru",
          "text": "конспектировать; записывать по ходу"
        },
        {
          "language": "sq",
          "text": "të mbash shënime; të shkruash gjatë dëgjimit"
        },
        {
          "language": "tr",
          "text": "not almak; dinlerken yazmak"
        }
      ],
      "examples": [
        {
          "baseText": "Kannst du im Meeting die wichtigsten Punkte mitschreiben?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك تدوين أهم النقاط في الاجتماع؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت لە کۆبوونەوەکەدا گرنگترین خاڵەکان بنووسیت؟"
            },
            {
              "language": "en",
              "text": "Can you take notes on the most important points in the meeting?"
            },
            {
              "language": "fa",
              "text": "می‌توانی در جلسه مهم‌ترین نکات را یادداشت کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî di civînê de xalên herî girîng binivîsî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz zanotować najważniejsze punkty na spotkaniu?"
            },
            {
              "language": "ro",
              "text": "Poți să notezi cele mai importante puncte la ședință?"
            },
            {
              "language": "ru",
              "text": "Можешь записать самые важные пункты на встрече?"
            },
            {
              "language": "sq",
              "text": "A mund t’i shënosh pikat më të rëndësishme në takim?"
            },
            {
              "language": "tr",
              "text": "Toplantıda en önemli noktaları not alabilir misin?"
            }
          ]
        },
        {
          "baseText": "Im Deutschkurs schreibe ich neue Wörter immer mit.",
          "translations": [
            {
              "language": "ar",
              "text": "في دورة الألمانية أدوّن دائمًا الكلمات الجديدة."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسی ئەڵمانیدا هەمیشە وشە نوێیەکان تێبینی دەکەم."
            },
            {
              "language": "en",
              "text": "In the German course, I always write down new words."
            },
            {
              "language": "fa",
              "text": "در کلاس آلمانی همیشه واژه‌های جدید را یادداشت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Di qursa almanî de ez her gav peyvên nû dinivîsim."
            },
            {
              "language": "pl",
              "text": "Na kursie niemieckiego zawsze zapisuję nowe słowa."
            },
            {
              "language": "ro",
              "text": "La cursul de germană notez întotdeauna cuvintele noi."
            },
            {
              "language": "ru",
              "text": "На курсе немецкого я всегда записываю новые слова."
            },
            {
              "language": "sq",
              "text": "Në kursin e gjermanishtes i shënoj gjithmonë fjalët e reja."
            },
            {
              "language": "tr",
              "text": "Almanca kursunda yeni kelimeleri her zaman not alırım."
            }
          ]
        }
      ]
    },
