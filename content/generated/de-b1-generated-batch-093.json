          "text": "eine Mitgliedschaft abschließen",
          "meaning": "to take out a membership"
        },
        {
          "text": "die Mitgliedschaft kündigen",
          "meaning": "to cancel the membership"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Mitglied",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "Mitglied werden",
          "relationLabel": "phrase",
