        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عضوية"
        },
        {
          "language": "ckb",
          "text": "ئەندامێتی"
        },
        {
          "language": "en",
          "text": "membership"
        },
        {
          "language": "fa",
          "text": "عضویت"
        },
        {
          "language": "kmr",
          "text": "endamî"
        },
        {
          "language": "pl",
          "text": "członkostwo"
        },
        {
          "language": "ro",
          "text": "calitate de membru; abonament"
        },
        {
          "language": "ru",
          "text": "членство; абонемент"
        },
        {
          "language": "sq",
          "text": "anëtarësi"
        },
        {
          "language": "tr",
          "text": "üyelik"
        }
      ],
      "examples": [
        {
          "baseText": "Die Mitgliedschaft im Fitnessstudio kostet 30 Euro im Monat.",
          "translations": [
            {
              "language": "ar",
              "text": "تكلّف عضوية النادي الرياضي 30 يورو في الشهر."
            },
            {
              "language": "ckb",
              "text": "ئەندامێتی لە هۆڵی وەرزشدا مانگانە ٣٠ یۆرۆیە."
            },
            {
              "language": "en",
              "text": "The gym membership costs 30 euros per month."
            },
            {
              "language": "fa",
              "text": "عضویت باشگاه ورزشی ماهی ۳۰ یورو هزینه دارد."
            },
            {
              "language": "kmr",
              "text": "Endamîya salonê werzîşê mehane 30 euro ye."
            },
            {
              "language": "pl",
              "text": "Członkostwo w siłowni kosztuje 30 euro miesięcznie."
            },
            {
              "language": "ro",
              "text": "Abonamentul la sala de fitness costă 30 de euro pe lună."
            },
            {
              "language": "ru",
              "text": "Абонемент в спортзал стоит 30 евро в месяц."
            },
            {
              "language": "sq",
              "text": "Anëtarësia në palestër kushton 30 euro në muaj."
            },
            {
              "language": "tr",
              "text": "Spor salonu üyeliği ayda 30 avro tutuyor."
            }
          ]
        },
        {
          "baseText": "Bitte senden Sie uns die Kündigung der Mitgliedschaft schriftlich.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال إلغاء العضوية إلينا كتابيًا."
            },
            {
              "language": "ckb",
              "text": "تکایە هەڵوەشاندنەوەی ئەندامێتییەکەمان بە نووسراوی بۆ بنێرن."
            },
            {
              "language": "en",
              "text": "Please send us the cancellation of the membership in writing."
            },
            {
              "language": "fa",
              "text": "لطفاً لغو عضویت را به‌صورت کتبی برای ما ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe betalkirina endamîyê bi nivîskî ji me re bişînin."
            },
            {
              "language": "pl",
              "text": "Prosimy przesłać nam wypowiedzenie członkostwa na piśmie."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să ne trimiteți în scris anularea abonamentului."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте нам отмену членства в письменном виде."
            },
            {
              "language": "sq",
              "text": "Ju lutem na dërgoni me shkrim anulimin e anëtarësisë."
            },
            {
              "language": "tr",
              "text": "Lütfen üyelik iptalini bize yazılı olarak gönderin."
            }
          ]
        }
      ]
    },
