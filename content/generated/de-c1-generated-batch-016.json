  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "aufzwingen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufzwingen",
      "syllableBreak": "auf-zwin-gen",
      "topics": [
        "management-and-leadership",
        "business-communication",
        "social-and-relationships"
      ],
      "usageLabels": [
        "formal",
        "written",
        "sensitive",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; commonly jemandem etwas aufzwingen"
      ],
      "collocations": [
        {
          "text": "jemandem eine Lösung aufzwingen",
          "meaning": "to impose a solution on someone"
        },
        {
          "text": "Regeln aufzwingen",
          "meaning": "to impose rules"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "zwingen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يفرض على شخص شيئًا"
        },
        {
          "language": "ckb",
          "text": "بە زۆر شتێک بەسەر کەسێکدا دەسەپێنێت"
        },
        {
          "language": "en",
          "text": "to impose something on someone"
        },
        {
          "language": "fa",
          "text": "تحمیل کردن به کسی"
        },
        {
          "language": "kmr",
          "text": "bi zor li ser kesek danîn"
        },
        {
          "language": "pl",
          "text": "narzucić komuś coś"
        },
        {
          "language": "ro",
          "text": "a impune cuiva ceva"
        },
        {
          "language": "ru",
          "text": "навязывать кому-либо что-либо"
        },
        {
          "language": "sq",
          "text": "t’ia imponosh dikujt diçka"
        },
        {
          "language": "tr",
          "text": "birine bir şeyi dayatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Zentrale sollte den Filialen keine Standardlösung aufzwingen, die lokal nicht funktioniert.",
          "translations": [
            {
              "language": "ar",
              "text": "ينبغي ألا يفرض المركز على الفروع حلاً قياسيًا لا يعمل محليًا."
            },
            {
              "language": "ckb",
              "text": "ناوەند نابێت چارەسەرێکی ستاندارد بەسەر لقەکاندا بسەپێنێت کە لە ناوخۆ کار ناکات."
            },
            {
              "language": "en",
              "text": "Head office should not impose a standard solution on the branches that does not work locally."
            },
            {
              "language": "fa",
              "text": "دفتر مرکزی نباید راه‌حل استانداردی را به شعب تحمیل کند که در محل کار نمی‌کند."
            },
            {
              "language": "kmr",
              "text": "Navend divê çareseriyeke standard ku herêmî naxebite li şaxan neferz bike."
            },
            {
              "language": "pl",
              "text": "Centrala nie powinna narzucać oddziałom standardowego rozwiązania, które lokalnie nie działa."
            },
            {
              "language": "ro",
              "text": "Sediul central nu ar trebui să impună filialelor o soluție standard care nu funcționează local."
            },
            {
              "language": "ru",
              "text": "Центральный офис не должен навязывать филиалам стандартное решение, которое на местах не работает."
            },
            {
              "language": "sq",
              "text": "Qendra nuk duhet t’u imponojë degëve një zgjidhje standarde që nuk funksionon lokalisht."
            },
            {
              "language": "tr",
              "text": "Merkez, yerelde çalışmayan standart bir çözümü şubelere dayatmamalı."
            }
          ]
        },
        {
          "baseText": "In der Familie empfand sie es als belastend, dass ihr ständig fremde Erwartungen aufgezwungen wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "في العائلة كانت تشعر بأنه أمر مرهق أن تُفرض عليها باستمرار توقعات الآخرين."
            },
            {
              "language": "ckb",
              "text": "لە خێزاندا بۆی قورس بوو کە بەردەوام چاوەڕوانییەکانی خەڵکی تر بەسەریدا بسەپێندرێت."
            },
            {
              "language": "en",
              "text": "In the family, she found it burdensome that other people’s expectations were constantly imposed on her."
            },
            {
              "language": "fa",
              "text": "در خانواده برایش آزاردهنده بود که مدام انتظارات دیگران به او تحمیل می‌شد."
            },
            {
              "language": "kmr",
              "text": "Di malbatê de ji wê re giran bû ku hêviyên kesên din her tim lê werin ferzkirin."
            },
            {
              "language": "pl",
              "text": "W rodzinie odczuwała jako obciążające to, że stale narzucano jej cudze oczekiwania."
            },
            {
              "language": "ro",
              "text": "În familie, simțea ca pe o povară faptul că i se impuneau constant așteptările altora."
            },
            {
              "language": "ru",
              "text": "В семье ей было тяжело от того, что ей постоянно навязывали чужие ожидания."
            },
            {
              "language": "sq",
              "text": "Në familje ajo e përjetonte si barrë që vazhdimisht i imponoheshin pritjet e të tjerëve."
            },
            {
              "language": "tr",
              "text": "Aile içinde başkalarının beklentilerinin sürekli kendisine dayatılmasını yorucu buluyordu."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "ausbitten",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "ausbitten",
      "syllableBreak": "aus-bit-ten",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "polite",
        "spoken",
        "advanced"
      ],
      "grammarNotes": [
        "irregular/reflexive usage; sich etwas ausbitten means to ask for or insist on something"
      ],
      "collocations": [
        {
          "text": "sich Bedenkzeit ausbitten",
          "meaning": "to ask for time to consider"
        },
        {
          "text": "sich Respekt ausbitten",
          "meaning": "to insist on respect"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "bitten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يطلب بإصرار أو بلطف حقًا معينًا"
        },
        {
          "language": "ckb",
          "text": "داوای شتێک دەکات؛ پێداگری لەسەر ڕێز دەکات"
        },
        {
          "language": "en",
          "text": "to ask for; to insist on receiving"
        },
        {
          "language": "fa",
          "text": "درخواست کردن؛ برای خود خواستن"
        },
        {
          "language": "kmr",
          "text": "xwestin; bi tekezî daxwaz kirin"
        },
        {
          "language": "pl",
          "text": "poprosić o; zastrzec sobie"
        },
        {
          "language": "ro",
          "text": "a cere; a solicita pentru sine"
        },
        {
          "language": "ru",
          "text": "просить для себя; требовать"
        },
        {
          "language": "sq",
          "text": "të kërkosh për vete; të insistosh"
        },
        {
          "language": "tr",
          "text": "talep etmek; istemek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kundin bat sich zwei Tage Bedenkzeit aus, bevor sie den Vertrag unterschrieb.",
          "translations": [
            {
              "language": "ar",
              "text": "طلبت العميلة مهلة يومين للتفكير قبل أن توقع العقد."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە داوای دوو ڕۆژ کاتی بیرکردنەوەی کرد پێش ئەوەی گرێبەستەکە واژۆ بکات."
            },
            {
              "language": "en",
              "text": "The customer asked for two days to consider before signing the contract."
            },
            {
              "language": "fa",
              "text": "مشتری پیش از امضای قرارداد دو روز مهلت برای فکر کردن خواست."
            },
            {
              "language": "kmr",
              "text": "Xerîdarê jin berî îmzekirina peymanê du roj dem ji bo fikirînê xwest."
            },
            {
              "language": "pl",
              "text": "Klientka poprosiła o dwa dni do namysłu, zanim podpisała umowę."
            },
            {
              "language": "ro",
              "text": "Clienta a cerut două zile de gândire înainte să semneze contractul."
            },
            {
              "language": "ru",
              "text": "Клиентка попросила два дня на размышление перед подписанием договора."
            },
            {
              "language": "sq",
              "text": "Klientja kërkoi dy ditë kohë për t’u menduar para se të nënshkruante kontratën."
            },
            {
              "language": "tr",
              "text": "Müşteri sözleşmeyi imzalamadan önce düşünmek için iki gün süre istedi."
            }
          ]
        },
        {
          "baseText": "Im Meeting bat sich der Teamleiter einen sachlichen Ton aus.",
          "translations": [
            {
              "language": "ar",
              "text": "في الاجتماع طلب قائد الفريق الالتزام بنبرة موضوعية."
            },
            {
              "language": "ckb",
              "text": "لە کۆبوونەوەکەدا سەرکردەی تیم داوای تۆنێکی بابەتی کرد."
            },
            {
              "language": "en",
              "text": "In the meeting, the team lead insisted on an objective tone."
            },
            {
              "language": "fa",
              "text": "در جلسه، سرپرست تیم خواستار لحن حرفه‌ای و بی‌طرف شد."
            },
            {
              "language": "kmr",
              "text": "Di civînê de serokê tîmê daxwaza awazeke objektîf kir."
            },
            {
              "language": "pl",
              "text": "Na spotkaniu lider zespołu zażądał rzeczowego tonu."
            },
            {
              "language": "ro",
              "text": "În ședință, liderul echipei a cerut un ton obiectiv."
            },
            {
              "language": "ru",
              "text": "На совещании руководитель команды потребовал делового тона."
            },
            {
              "language": "sq",
              "text": "Në takim, drejtuesi i ekipit kërkoi një ton objektiv."
            },
            {
              "language": "tr",
              "text": "Toplantıda ekip lideri nesnel bir üslup talep etti."
            }
          ]
        }
      ]
    },
