  "entries": [
    {
      "word": "erziehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "erziehen",
      "pronunciationIpa": null,
      "syllableBreak": "er-zie-hen",
      "topics": [
        "education-and-training",
        "social-and-relationships",
