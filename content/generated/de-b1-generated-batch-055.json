          "meaning": "to work as an educator"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "erziehen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مربّي؛ معلم رياض أطفال"
        },
        {
          "language": "ckb",
          "text": "پەروەردەکار؛ مامۆستای باخچە"
        },
        {
          "language": "en",
          "text": "educator; childcare worker"
        },
        {
          "language": "fa",
          "text": "مربی کودک؛ مربی مهدکودک"
        },
        {
          "language": "kmr",
          "text": "perwerdekar; mamosteyê zarokan"
        },
        {
          "language": "pl",
          "text": "wychowawca; opiekun dziecięcy"
        },
        {
          "language": "ro",
          "text": "educator; îngrijitor copii"
        },
        {
          "language": "ru",
          "text": "воспитатель"
        },
        {
          "language": "sq",
          "text": "edukator; kujdestar fëmijësh"
        },
        {
          "language": "tr",
          "text": "eğitmen; çocuk bakıcısı"
        }
      ],
      "examples": [
        {
          "baseText": "Der Erzieher begrüßt die Kinder jeden Morgen an der Tür.",
          "translations": [
            {
              "language": "ar",
              "text": "يحيّي المربّي الأطفال كل صباح عند الباب."
            },
            {
              "language": "ckb",
              "text": "پەروەردەکارەکە هەموو بەیانییەک منداڵەکان لە دەرگاکەدا بەخێرهاتن دەکات."
            },
            {
              "language": "en",
              "text": "The educator greets the children at the door every morning."
            },
            {
              "language": "fa",
              "text": "مربی هر صبح کودکان را دم در خوش‌آمد می‌گوید."
            },
            {
              "language": "kmr",
              "text": "Perwerdekar her sibeh zarokan li ber derî silav dike."
            },
            {
              "language": "pl",
              "text": "Wychowawca wita dzieci co rano przy drzwiach."
            },
            {
              "language": "ro",
              "text": "Educatorul îi întâmpină pe copii în fiecare dimineață la ușă."
            },
            {
              "language": "ru",
              "text": "Воспитатель каждое утро встречает детей у двери."
            },
            {
              "language": "sq",
              "text": "Edukatori i përshëndet fëmijët çdo mëngjes te dera."
            },
            {
              "language": "tr",
              "text": "Eğitmen çocukları her sabah kapıda karşılar."
            }
          ]
        },
        {
          "baseText": "Für die neue Gruppe sucht die Einrichtung noch einen Erzieher.",
