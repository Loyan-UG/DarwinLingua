      ],
      "usageLabels": [
        "spoken",
        "written",
        "formal"
      ],
      "contextLabels": [
        "education",
        "training"
      ],
      "grammarNotes": [
        "irregular verb: erzieht, erzog, hat erzogen"
      ],
      "collocations": [
        {
          "text": "Kinder liebevoll erziehen",
          "meaning": "to raise children lovingly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erziehung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يربّي؛ ينشّئ"
        },
        {
          "language": "ckb",
          "text": "پەروەردە کردن؛ گەورەکردن"
        },
        {
          "language": "en",
          "text": "to raise; to educate; to bring up"
        },
        {
          "language": "fa",
          "text": "تربیت کردن؛ پرورش دادن"
        },
        {
          "language": "kmr",
          "text": "perwerde kirin; mezin kirin"
        },
        {
          "language": "pl",
          "text": "wychowywać"
        },
        {
          "language": "ro",
          "text": "a educa; a crește"
        },
        {
          "language": "ru",
          "text": "воспитывать"
        },
        {
          "language": "sq",
          "text": "të edukosh; të rrisësh"
        },
        {
          "language": "tr",
          "text": "yetiştirmek; eğitmek"
        }
      ],
      "examples": [
        {
          "baseText": "Eltern möchten ihre Kinder selbstständig und verantwortungsvoll erziehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد الآباء تربية أطفالهم ليكونوا مستقلين ومسؤولين."
            },
            {
              "language": "ckb",
              "text": "دایک و باوک دەیانەوێت منداڵەکانیان بە سەربەخۆیی و بەرپرسیارێتی پەروەردە بکەن."
            },
            {
              "language": "en",
              "text": "Parents want to raise their children to be independent and responsible."
            },
            {
              "language": "fa",
              "text": "والدین می‌خواهند فرزندانشان را مستقل و مسئولیت‌پذیر تربیت کنند."
            },
            {
              "language": "kmr",
              "text": "Dêûbav dixwazin zarokên xwe serbixwe û berpirsiyar perwerde bikin."
            },
            {
              "language": "pl",
              "text": "Rodzice chcą wychowywać dzieci na samodzielne i odpowiedzialne."
            },
            {
              "language": "ro",
              "text": "Părinții vor să-și educe copiii să fie independenți și responsabili."
            },
            {
              "language": "ru",
              "text": "Родители хотят воспитывать детей самостоятельными и ответственными."
            },
            {
              "language": "sq",
              "text": "Prindërit duan t’i rrisin fëmijët të pavarur dhe të përgjegjshëm."
            },
            {
              "language": "tr",
              "text": "Ebeveynler çocuklarını bağımsız ve sorumlu yetiştirmek ister."
            }
          ]
        },
        {
          "baseText": "In der Kita lernen wir, wie man Kinder ruhig und klar erziehen kann.",
          "translations": [
            {
              "language": "ar",
              "text": "في الروضة نتعلم كيف يمكن تربية الأطفال بهدوء ووضوح."
            },
            {
              "language": "ckb",
              "text": "لە باخچەی ساوایاندا فێر دەبین چۆن منداڵان بە ئارامی و ڕوونی پەروەردە بکەین."
            },
            {
              "language": "en",
              "text": "At the daycare center, we learn how to educate children calmly and clearly."
            },
            {
              "language": "fa",
              "text": "در مهدکودک یاد می‌گیریم چگونه کودکان را آرام و روشن تربیت کنیم."
            },
            {
              "language": "kmr",
              "text": "Li baxçeyê zarokan em fêr dibin ka çawa zarokan bi aramî û zelalî perwerde bikin."
            },
            {
              "language": "pl",
              "text": "W przedszkolu uczymy się, jak spokojnie i jasno wychowywać dzieci."
            },
            {
              "language": "ro",
              "text": "La grădiniță învățăm cum să educăm copiii calm și clar."
            },
            {
              "language": "ru",
              "text": "В детском саду мы учимся спокойно и ясно воспитывать детей."
            },
            {
              "language": "sq",
              "text": "Në kopsht mësojmë si t’i edukojmë fëmijët qetë dhe qartë."
            },
            {
              "language": "tr",
              "text": "Kreşte çocukları sakin ve net şekilde nasıl eğiteceğimizi öğreniyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "der Erzieher",
      "language": "de",
