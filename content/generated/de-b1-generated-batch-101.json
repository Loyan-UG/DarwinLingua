  "entries": [
    {
      "word": "die Öffnungszeiten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Öffnungszeiten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Öff-nungs-zei-ten",
      "topics": [
        "shopping-and-services",
        "customer-service",
        "public-services"
      ],
      "usageLabels": [
        "everyday",
        "customer-facing",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "plural noun; singular form die Öffnungszeit is possible but less common"
      ],
      "collocations": [
        {
          "text": "die Öffnungszeiten prüfen",
          "meaning": "to check the opening hours"
        },
        {
          "text": "geänderte Öffnungszeiten",
          "meaning": "changed opening hours"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "öffnen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "offen",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ساعات العمل؛ أوقات الفتح"
        },
        {
          "language": "ckb",
          "text": "کاتەکانی کردنەوە؛ کاتەکانی کارکردن"
        },
        {
          "language": "en",
          "text": "opening hours; business hours"
        },
        {
          "language": "fa",
          "text": "ساعات کاری؛ زمان باز بودن"
        },
        {
          "language": "kmr",
          "text": "demên vekirinê; demên kar"
        },
        {
          "language": "pl",
          "text": "godziny otwarcia"
        },
        {
          "language": "ro",
          "text": "program de lucru; ore de deschidere"
        },
        {
          "language": "ru",
          "text": "часы работы; время открытия"
        },
        {
          "language": "sq",
          "text": "orari i hapjes; orari i punës"
        },
        {
          "language": "tr",
          "text": "açılış saatleri; çalışma saatleri"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte prüfen Sie die Öffnungszeiten, bevor Sie zur Filiale fahren.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى التحقق من ساعات العمل قبل أن تذهبوا إلى الفرع."
            },
            {
              "language": "ckb",
              "text": "تکایە پێش ئەوەی بچن بۆ لقەکە کاتەکانی کردنەوە بپشکنن."
            },
            {
              "language": "en",
              "text": "Please check the opening hours before you go to the branch."
            },
            {
              "language": "fa",
              "text": "لطفاً قبل از رفتن به شعبه، ساعات کاری را بررسی کنید."
            },
            {
              "language": "kmr",
              "text": "Berî ku hûn biçin şaxê, ji kerema xwe demên vekirinê kontrol bikin."
            },
            {
              "language": "pl",
              "text": "Proszę sprawdzić godziny otwarcia przed wyjazdem do oddziału."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să verificați programul înainte să mergeți la filială."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, проверьте часы работы, прежде чем ехать в филиал."
            },
            {
              "language": "sq",
              "text": "Ju lutem kontrolloni orarin e hapjes para se të shkoni në degë."
            },
            {
              "language": "tr",
              "text": "Şubeye gitmeden önce lütfen çalışma saatlerini kontrol edin."
            }
          ]
        },
        {
          "baseText": "An Feiertagen gelten andere Öffnungszeiten.",
          "translations": [
            {
              "language": "ar",
              "text": "في أيام العطل تسري ساعات عمل مختلفة."
            },
            {
              "language": "ckb",
              "text": "لە ڕۆژانی پشوو کاتەکانی کردنەوە جیاوازن."
            },
            {
              "language": "en",
              "text": "Different opening hours apply on public holidays."
            },
            {
              "language": "fa",
              "text": "در روزهای تعطیل ساعات کاری متفاوتی اعمال می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di rojên betlaneyê de demên vekirinê cuda ne."
            },
            {
              "language": "pl",
              "text": "W święta obowiązują inne godziny otwarcia."
            },
            {
              "language": "ro",
              "text": "În zilele de sărbătoare se aplică un alt program."
            },
            {
              "language": "ru",
              "text": "В праздничные дни действуют другие часы работы."
            },
            {
              "language": "sq",
              "text": "Në ditët e festave vlejnë orare të tjera hapjeje."
            },
            {
              "language": "tr",
              "text": "Resmi tatillerde farklı çalışma saatleri geçerlidir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Onlinezeitung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Onlinezeitungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "On-line-zei-tung",
      "topics": [
        "culture-and-media",
        "technology-and-it",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Onlinezeitung lesen",
          "meaning": "to read an online newspaper"
        },
        {
          "text": "Artikel in einer Onlinezeitung",
          "meaning": "article in an online newspaper"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "online",
          "relationLabel": "adjective/adverb",
          "note": null
        },
        {
          "lemma": "die Zeitung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "صحيفة إلكترونية"
        },
        {
          "language": "ckb",
          "text": "ڕۆژنامەی ئۆنلاین"
        },
        {
          "language": "en",
          "text": "online newspaper"
        },
        {
          "language": "fa",
          "text": "روزنامه آنلاین"
        },
        {
          "language": "kmr",
          "text": "rojnameya online"
        },
        {
          "language": "pl",
          "text": "gazeta internetowa"
        },
        {
          "language": "ro",
          "text": "ziar online"
        },
        {
          "language": "ru",
          "text": "онлайн-газета"
        },
        {
          "language": "sq",
          "text": "gazetë online"
        },
        {
          "language": "tr",
          "text": "çevrim içi gazete"
        }
      ],
      "examples": [
        {
          "baseText": "Ich lese morgens eine Onlinezeitung auf dem Handy.",
          "translations": [
            {
              "language": "ar",
              "text": "أقرأ صباحًا صحيفة إلكترونية على الهاتف."
            },
            {
              "language": "ckb",
              "text": "بەیانیان ڕۆژنامەیەکی ئۆنلاین لەسەر مۆبایل دەخوێنم."
            },
            {
              "language": "en",
              "text": "In the morning, I read an online newspaper on my phone."
            },
            {
              "language": "fa",
              "text": "صبح‌ها یک روزنامه آنلاین را روی گوشی می‌خوانم."
            },
            {
              "language": "kmr",
              "text": "Serê sibê ez rojnameyeke online li ser telefonê dixwînim."
            },
            {
              "language": "pl",
              "text": "Rano czytam gazetę internetową na telefonie."
            },
            {
              "language": "ro",
              "text": "Dimineața citesc un ziar online pe telefon."
            },
            {
              "language": "ru",
              "text": "Утром я читаю онлайн-газету на телефоне."
            },
            {
              "language": "sq",
              "text": "Në mëngjes lexoj një gazetë online në telefon."
            },
            {
              "language": "tr",
              "text": "Sabahları telefonda çevrim içi gazete okurum."
            }
          ]
        },
        {
          "baseText": "Die Onlinezeitung berichtet über die neuen Regeln im Nahverkehr.",
          "translations": [
            {
              "language": "ar",
              "text": "تكتب الصحيفة الإلكترونية عن القواعد الجديدة في النقل المحلي."
            },
            {
              "language": "ckb",
              "text": "ڕۆژنامە ئۆنلاینەکە باس لە یاسا نوێیەکانی گواستنەوەی ناوخۆ دەکات."
            },
            {
              "language": "en",
              "text": "The online newspaper reports on the new rules for local transport."
            },
            {
              "language": "fa",
              "text": "روزنامه آنلاین درباره قوانین جدید حمل‌ونقل محلی گزارش می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Rojnameya online li ser qaîdeyên nû yên veguhestina herêmî radigihîne."
            },
            {
              "language": "pl",
              "text": "Gazeta internetowa informuje o nowych zasadach w komunikacji lokalnej."
            },
            {
              "language": "ro",
              "text": "Ziarul online relatează despre noile reguli din transportul local."
            },
            {
              "language": "ru",
              "text": "Онлайн-газета сообщает о новых правилах в местном транспорте."
            },
            {
              "language": "sq",
              "text": "Gazeta online raporton për rregullat e reja në transportin lokal."
            },
            {
              "language": "tr",
              "text": "Çevrim içi gazete yerel ulaşımdaki yeni kuralları bildiriyor."
            }
          ]
        }
      ]
    },
