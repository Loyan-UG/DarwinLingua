      "plural": "Jahresabschlüsse",
      "topics": ["work-and-jobs"],
      "usageLabels": ["business"],
      "contextLabels": ["finance", "reporting"],
      "meanings": [
        { "language": "en", "text": "annual financial statement; year-end closing" },
        { "language": "fa", "text": "بستن سال مالی، صورت‌های مالی سالانه" }
      ],
      "examples": [
        {
          "baseText": "Für den Jahresabschluss müssen alle offenen Buchungen rechtzeitig geklärt werden.",
          "translations": [
            { "language": "en", "text": "For the year-end closing, all open postings must be clarified in time." },
            { "language": "fa", "text": "برای بستن سال مالی، همه ثبت‌های باز باید به‌موقع روشن شوند." }
          ]
        }
      ]
    },
    {
