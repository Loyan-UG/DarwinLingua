  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "abtun",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "abtun",
      "syllableBreak": "ab-tun",
      "topics": [
        "management-and-leadership",
        "business-communication",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "spoken",
        "advanced"
      ],
      "grammarNotes": [
        "irregular separable verb; often used as etwas als etwas abtun"
      ],
      "collocations": [
        {
          "text": "etwas als Ausnahme abtun",
          "meaning": "to dismiss something as an exception"
        },
        {
          "text": "Bedenken vorschnell abtun",
          "meaning": "to dismiss concerns too quickly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "tun",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يرفض باعتباره غير مهم؛ يستخفّ به"
        },
        {
          "language": "ckb",
          "text": "بە گرنگی نادات؛ وەک شتێکی بچووک دەیبینێت"
        },
        {
          "language": "en",
          "text": "to dismiss; to play down"
        },
        {
          "language": "fa",
          "text": "بی‌اهمیت شمردن؛ ساده انگاشتن"
        },
        {
          "language": "kmr",
          "text": "bi girîngî negirtin; sivik dîtin"
        },
        {
          "language": "pl",
          "text": "zbywać; bagatelizować"
        },
        {
          "language": "ro",
          "text": "a respinge ca neimportant; a minimaliza"
        },
        {
          "language": "ru",
          "text": "отмахиваться; считать неважным"
        },
        {
          "language": "sq",
          "text": "ta hedhësh poshtë si të parëndësishme; ta nënvlerësosh"
        },
        {
          "language": "tr",
          "text": "önemsiz saymak; geçiştirmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die Projektleitung tat die Sicherheitsbedenken zunächst als theoretisches Problem ab.",
          "translations": [
            {
              "language": "ar",
              "text": "رفضت إدارة المشروع في البداية مخاوف الأمان باعتبارها مشكلة نظرية."
            },
            {
              "language": "ckb",
              "text": "سەرپەرشتی پڕۆژەکە سەرەتا نیگەرانییەکانی ئاسایشی وەک کێشەیەکی تیۆری بە گرنگی نەگرت."
            },
            {
              "language": "en",
              "text": "Project management initially dismissed the security concerns as a theoretical problem."
            },
            {
              "language": "fa",
              "text": "مدیریت پروژه ابتدا نگرانی‌های امنیتی را به‌عنوان مشکلی نظری بی‌اهمیت شمرد."
            },
            {
              "language": "kmr",
              "text": "Rêveberiya projeyê di destpêkê de fikarên ewlehiyê wek pirsgirêkeke teorîk sivik dît."
            },
            {
              "language": "pl",
              "text": "Kierownictwo projektu początkowo zbyło obawy dotyczące bezpieczeństwa jako problem teoretyczny."
            },
            {
              "language": "ro",
              "text": "Conducerea proiectului a respins inițial preocupările de securitate ca fiind o problemă teoretică."
            },
            {
              "language": "ru",
              "text": "Руководство проекта сначала отмахнулось от опасений по безопасности как от теоретической проблемы."
            },
            {
              "language": "sq",
              "text": "Drejtimi i projektit fillimisht i hodhi poshtë shqetësimet e sigurisë si problem teorik."
            },
            {
              "language": "tr",
              "text": "Proje yönetimi güvenlik endişelerini başlangıçta teorik bir sorun olarak geçiştirdi."
            }
          ]
        },
        {
          "baseText": "Man sollte die Beschwerde des Kunden nicht als bloßes Missverständnis abtun.",
          "translations": [
            {
              "language": "ar",
              "text": "لا ينبغي اعتبار شكوى العميل مجرد سوء فهم."
            },
            {
              "language": "ckb",
              "text": "نابێت سکاڵای کڕیارەکە وەک تەنها تێنەگەیشتنێک بە گرنگی نەگیرێت."
            },
            {
              "language": "en",
              "text": "The customer’s complaint should not be dismissed as a mere misunderstanding."
            },
            {
              "language": "fa",
              "text": "نباید شکایت مشتری را صرفاً یک سوءتفاهم تلقی و رد کرد."
            },
            {
              "language": "kmr",
              "text": "Divê gilîya xerîdar wek tenê şaşfêmkirinek neyê sivik dîtin."
            },
            {
              "language": "pl",
              "text": "Nie należy zbywać skargi klienta jako zwykłego nieporozumienia."
            },
            {
              "language": "ro",
              "text": "Reclamația clientului nu ar trebui respinsă ca o simplă neînțelegere."
            },
            {
              "language": "ru",
              "text": "Жалобу клиента не следует списывать на простое недоразумение."
            },
            {
              "language": "sq",
              "text": "Ankesa e klientit nuk duhet hedhur poshtë si thjesht keqkuptim."
            },
            {
              "language": "tr",
              "text": "Müşterinin şikayeti yalnızca bir yanlış anlama diye geçiştirilmemeli."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Abwägung",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Abwägungen",
      "infinitive": null,
      "syllableBreak": "Ab-wä-gung",
      "topics": [
        "management-and-leadership",
        "law-and-compliance",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "analysis",
        "advanced"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine sorgfältige Abwägung vornehmen",
          "meaning": "to carry out a careful weighing of options"
        },
        {
          "text": "nach gründlicher Abwägung",
          "meaning": "after careful consideration"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "abwägen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "موازنة؛ دراسة متأنية"
        },
        {
          "language": "ckb",
          "text": "هەڵسەنگاندن و بەراوردکردن"
        },
        {
          "language": "en",
          "text": "weighing; careful consideration"
        },
        {
          "language": "fa",
          "text": "سنجش؛ سبک‌سنگین کردن"
        },
        {
          "language": "kmr",
          "text": "nirxandin û berhevkirin"
        },
        {
          "language": "pl",
          "text": "rozważenie; wyważenie"
        },
        {
          "language": "ro",
          "text": "cântărire; analiză atentă"
        },
        {
          "language": "ru",
          "text": "взвешивание; тщательное рассмотрение"
        },
        {
          "language": "sq",
          "text": "peshim i kujdesshëm; vlerësim i balancuar"
        },
        {
          "language": "tr",
          "text": "değerlendirme; dikkatli tartma"
        }
      ],
      "examples": [
        {
          "baseText": "Nach sorgfältiger Abwägung entschied der Vorstand, den riskanten Markteintritt zu verschieben.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد موازنة دقيقة قرر مجلس الإدارة تأجيل دخول السوق المحفوف بالمخاطر."
            },
            {
              "language": "ckb",
              "text": "دوای هەڵسەنگاندنێکی ورد، دەستەی بەڕێوەبردن بڕیاری دا چوونە ناو بازاڕی پڕمەترسی دوا بخات."
            },
            {
              "language": "en",
              "text": "After careful consideration, the board decided to postpone the risky market entry."
            },
            {
              "language": "fa",
              "text": "پس از سنجش دقیق، هیئت‌مدیره تصمیم گرفت ورود پرریسک به بازار را به تعویق بیندازد."
            },
            {
              "language": "kmr",
              "text": "Piştî nirxandineke baldar, desteya rêveberiyê biryar da ku ketina bazara xeternak paş bixe."
            },
            {
              "language": "pl",
              "text": "Po starannym rozważeniu zarząd zdecydował odłożyć ryzykowne wejście na rynek."
            },
            {
              "language": "ro",
              "text": "După o analiză atentă, consiliul a decis să amâne intrarea riscantă pe piață."
            },
            {
              "language": "ru",
              "text": "После тщательного взвешивания совет директоров решил отложить рискованный выход на рынок."
            },
            {
              "language": "sq",
              "text": "Pas një vlerësimi të kujdesshëm, bordi vendosi ta shtyjë hyrjen e rrezikshme në treg."
            },
            {
              "language": "tr",
              "text": "Yönetim kurulu dikkatli değerlendirmeden sonra riskli pazara girişi ertelemeye karar verdi."
            }
          ]
        },
        {
          "baseText": "Bei Datenschutzfragen ist eine Abwägung zwischen Nutzerkomfort und rechtlichen Risiken nötig.",
          "translations": [
            {
              "language": "ar",
              "text": "في مسائل حماية البيانات يلزم موازنة بين راحة المستخدمين والمخاطر القانونية."
            },
            {
              "language": "ckb",
              "text": "لە پرسەکانی پاراستنی داتادا پێویستە لە نێوان ئاسانی بەکارهێنەر و مەترسی یاسایی هەڵسەنگاندن بکرێت."
            },
            {
              "language": "en",
              "text": "In data protection issues, a balance between user convenience and legal risks is necessary."
            },
            {
              "language": "fa",
              "text": "در مسائل حفاظت از داده، سنجش میان راحتی کاربر و ریسک‌های حقوقی لازم است."
            },
            {
              "language": "kmr",
              "text": "Di mijarên parastina daneyan de hewce ye di navbera rehetîya bikarhêner û xeterên qanûnî de nirxandin hebe."
            },
            {
              "language": "pl",
              "text": "W kwestiach ochrony danych potrzebne jest wyważenie wygody użytkownika i ryzyk prawnych."
            },
            {
              "language": "ro",
              "text": "În chestiunile de protecție a datelor este necesară o cântărire între confortul utilizatorului și riscurile juridice."
            },
            {
              "language": "ru",
              "text": "В вопросах защиты данных необходимо взвесить удобство пользователя и юридические риски."
            },
            {
              "language": "sq",
              "text": "Në çështjet e mbrojtjes së të dhënave duhet një peshim mes komoditetit të përdoruesit dhe rreziqeve ligjore."
            },
            {
              "language": "tr",
              "text": "Veri koruma konularında kullanıcı konforu ile hukuki riskler arasında değerlendirme gerekir."
            }
          ]
        }
      ]
    },
