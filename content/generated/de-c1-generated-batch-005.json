      "examples": [
        {
          "baseText": "Ein Wettbewerber versuchte, mehrere erfahrene Entwickler aus unserem Team abzuwerben.",
          "translations": [
            {
              "language": "ar",
              "text": "حاول منافس استقطاب عدة مطورين ذوي خبرة من فريقنا."
