      "examples": [
        {
          "baseText": "Meine Kollegin reist nächste Woche nach China.",
          "translations": [
            {
              "language": "ar",
              "text": "زميلتي تسافر إلى الصين الأسبوع القادم."
            },
            {
              "language": "ckb",
              "text": "هاوکارەکەم هەفتەی داهاتوو دەچێت بۆ چین."
            },
            {
              "language": "en",
              "text": "My colleague is traveling to China next week."
            },
            {
              "language": "fa",
              "text": "همکارم هفته آینده به چین سفر می‌کند."
            },
            {
              "language": "kmr",
              "text": "Hevkariya min hefteya bê diçe Çînê."
            },
            {
              "language": "pl",
              "text": "Moja koleżanka jedzie w przyszłym tygodniu do Chin."
            },
            {
              "language": "ro",
              "text": "Colega mea călătorește săptămâna viitoare în China."
            },
            {
              "language": "ru",
              "text": "Моя коллега на следующей неделе едет в Китай."
            },
            {
              "language": "sq",
              "text": "Kolegia ime udhëton javën tjetër në Kinë."
            },
            {
              "language": "tr",
              "text": "İş arkadaşım gelecek hafta Çin’e gidiyor."
            }
          ]
        },
        {
          "baseText": "Viele Produkte kommen aus China.",
          "translations": [
            {
              "language": "ar",
              "text": "تأتي كثير من المنتجات من الصين."
            },
            {
              "language": "ckb",
              "text": "زۆر بەرهەم لە چینەوە دێن."
            },
            {
              "language": "en",
              "text": "Many products come from China."
            },
            {
              "language": "fa",
              "text": "بسیاری از محصولات از چین می‌آیند."
            },
            {
              "language": "kmr",
              "text": "Gelek berhem ji Çînê tên."
            },
            {
              "language": "pl",
              "text": "Wiele produktów pochodzi z Chin."
            },
            {
              "language": "ro",
              "text": "Multe produse vin din China."
            },
            {
              "language": "ru",
              "text": "Многие товары приходят из Китая."
            },
            {
              "language": "sq",
              "text": "Shumë produkte vijnë nga Kina."
            },
            {
              "language": "tr",
              "text": "Birçok ürün Çin’den geliyor."
            }
          ]
        }
