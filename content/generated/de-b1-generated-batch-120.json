  "entries": [
    {
      "word": "sich ergeben",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "sich ergeben",
      "pronunciationIpa": null,
      "syllableBreak": "sich er-ge-ben",
      "topics": [
        "business-communication",
        "planning-and-projects",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive verb; irregular: ergibt sich, ergab sich, sich ergeben; often means to result from or arise"
      ],
      "collocations": [
        {
          "text": "sich aus den Zahlen ergeben",
          "meaning": "to result from the figures"
        },
        {
          "text": "es ergibt sich eine Frage",
          "meaning": "a question arises"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Ergebnis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "ergeben",
          "relationLabel": "verb/adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينتج؛ يتضح؛ ينشأ"
        },
        {
          "language": "ckb",
          "text": "دەردەکەوێت؛ لێ دەکەوێتەوە؛ پەیدا دەبێت"
        },
        {
          "language": "en",
          "text": "to result; to arise; to become clear"
        },
        {
          "language": "fa",
          "text": "نتیجه شدن؛ پیش آمدن؛ مشخص شدن"
        },
        {
          "language": "kmr",
          "text": "encam bûn; derketin; xuya bûn"
        },
        {
          "language": "pl",
          "text": "wynikać; pojawiać się"
        },
        {
          "language": "ro",
          "text": "a rezulta; a apărea"
        },
        {
          "language": "ru",
          "text": "получаться; вытекать; возникать"
        },
        {
          "language": "sq",
          "text": "të rezultojë; të dalë; të lindë"
        },
        {
          "language": "tr",
          "text": "ortaya çıkmak; sonuçlanmak; doğmak"
        }
      ],
      "examples": [
        {
          "baseText": "Aus den neuen Zahlen ergibt sich ein anderes Bild.",
          "translations": [
            {
              "language": "ar",
              "text": "من الأرقام الجديدة تتضح صورة مختلفة."
            },
            {
              "language": "ckb",
              "text": "لە ژمارە نوێیەکان وێنەیەکی جیاواز دەردەکەوێت."
            },
            {
              "language": "en",
              "text": "The new figures result in a different picture."
            },
            {
              "language": "fa",
              "text": "از اعداد جدید تصویر متفاوتی به دست می‌آید."
            },
            {
              "language": "kmr",
              "text": "Ji hejmarên nû wêneyekî cuda derdikeve."
            },
            {
              "language": "pl",
              "text": "Z nowych liczb wynika inny obraz sytuacji."
            },
            {
              "language": "ro",
              "text": "Din noile cifre rezultă o imagine diferită."
            },
            {
              "language": "ru",
              "text": "Из новых цифр складывается другая картина."
            },
            {
              "language": "sq",
              "text": "Nga shifrat e reja del një pamje tjetër."
            },
            {
              "language": "tr",
              "text": "Yeni rakamlardan farklı bir tablo ortaya çıkıyor."
            }
          ]
        },
        {
          "baseText": "Wenn sich Rückfragen ergeben, melden wir uns bei Ihnen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا ظهرت أسئلة إضافية، فسنتواصل معكم."
            },
            {
              "language": "ckb",
              "text": "ئەگەر پرسیاری زیاتر پەیدا بوو، پەیوەندیتان پێوە دەکەین."
            },
            {
              "language": "en",
              "text": "If follow-up questions arise, we will contact you."
            },
            {
              "language": "fa",
              "text": "اگر سؤال‌های تکمیلی پیش بیاید، با شما تماس می‌گیریم."
            },
            {
              "language": "kmr",
              "text": "Heke pirsên pêvek derkevin, em ê têkilî bi we re daynin."
            },
            {
              "language": "pl",
              "text": "Jeśli pojawią się dodatkowe pytania, skontaktujemy się z państwem."
            },
            {
              "language": "ro",
              "text": "Dacă apar întrebări suplimentare, vă vom contacta."
            },
            {
              "language": "ru",
              "text": "Если возникнут дополнительные вопросы, мы свяжемся с вами."
            },
            {
              "language": "sq",
              "text": "Nëse lindin pyetje shtesë, do t’ju kontaktojmë."
            },
            {
              "language": "tr",
              "text": "Ek sorular ortaya çıkarsa sizinle iletişime geçeriz."
            }
          ]
        }
      ]
    },
    {
      "word": "sich gewöhnen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "sich gewöhnen",
      "pronunciationIpa": null,
      "syllableBreak": "sich ge-wöh-nen",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "social-and-relationships"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "workplace",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "reflexive verb; often with an + accusative"
      ],
      "collocations": [
        {
          "text": "sich an die neue Arbeit gewöhnen",
          "meaning": "to get used to the new job"
        },
        {
          "text": "sich schnell gewöhnen",
          "meaning": "to get used to something quickly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Gewohnheit",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "gewohnt",
          "relationLabel": "adjective/participle",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يعتاد على؛ يتعود"
        },
        {
          "language": "ckb",
          "text": "ڕاهاتن بە؛ خووگرتن بە"
        },
        {
          "language": "en",
          "text": "to get used to; to become accustomed to"
        },
        {
          "language": "fa",
          "text": "عادت کردن؛ خو گرفتن"
        },
        {
          "language": "kmr",
          "text": "fêr bûn; adet kirin"
        },
        {
          "language": "pl",
          "text": "przyzwyczajać się"
        },
        {
          "language": "ro",
          "text": "a se obișnui"
        },
        {
          "language": "ru",
          "text": "привыкать"
        },
        {
          "language": "sq",
          "text": "të mësohesh; të përshtatesh"
        },
        {
          "language": "tr",
          "text": "alışmak"
        }
      ],
      "examples": [
        {
          "baseText": "Nach ein paar Wochen habe ich mich an die neue Arbeitszeit gewöhnt.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد بضعة أسابيع اعتدت على وقت العمل الجديد."
            },
            {
              "language": "ckb",
              "text": "دوای چەند هەفتەیەک بە کاتی کاری نوێ ڕاهاتم."
            },
            {
              "language": "en",
              "text": "After a few weeks, I got used to the new working hours."
            },
            {
              "language": "fa",
              "text": "بعد از چند هفته به ساعت کاری جدید عادت کردم."
            },
            {
              "language": "kmr",
              "text": "Piştî çend hefteyan ez bi demjimêrên karê nû re fêr bûm."
            },
            {
              "language": "pl",
              "text": "Po kilku tygodniach przyzwyczaiłem się do nowych godzin pracy."
            },
            {
              "language": "ro",
              "text": "După câteva săptămâni m-am obișnuit cu noul program de lucru."
            },
            {
              "language": "ru",
              "text": "Через несколько недель я привык к новому рабочему графику."
            },
            {
              "language": "sq",
              "text": "Pas disa javësh u mësova me orarin e ri të punës."
            },
            {
              "language": "tr",
              "text": "Birkaç hafta sonra yeni çalışma saatlerine alıştım."
            }
          ]
        },
        {
          "baseText": "Kinder gewöhnen sich oft schnell an eine neue Umgebung.",
          "translations": [
            {
              "language": "ar",
              "text": "غالبًا ما يعتاد الأطفال بسرعة على بيئة جديدة."
            },
            {
              "language": "ckb",
              "text": "منداڵان زۆرجار بە خێرایی بە ژینگەیەکی نوێ ڕادێن."
            },
            {
              "language": "en",
              "text": "Children often get used to a new environment quickly."
            },
            {
              "language": "fa",
              "text": "بچه‌ها اغلب سریع به محیط جدید عادت می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Zarok gelek caran zû bi hawîrdora nû re fêr dibin."
            },
            {
              "language": "pl",
              "text": "Dzieci często szybko przyzwyczajają się do nowego otoczenia."
            },
            {
              "language": "ro",
              "text": "Copiii se obișnuiesc adesea repede cu un mediu nou."
            },
            {
              "language": "ru",
              "text": "Дети часто быстро привыкают к новой среде."
            },
            {
              "language": "sq",
              "text": "Fëmijët shpesh mësohen shpejt me një mjedis të ri."
            },
            {
              "language": "tr",
              "text": "Çocuklar genellikle yeni bir ortama çabuk alışır."
            }
          ]
        }
      ]
    },
