    {
      "word": "verlieren",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verlieren",
      "pronunciationIpa": null,
      "syllableBreak": "ver-lie-ren",
      "topics": [
