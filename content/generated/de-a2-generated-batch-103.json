      "collocations": [
        {
          "text": "ein Medikament verschreiben",
          "meaning": "to prescribe a medicine"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Verschreibung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يصف دواءً"
        },
        {
          "language": "ckb",
          "text": "دەرمان دەنووسێت"
        },
        {
          "language": "en",
          "text": "to prescribe"
        },
        {
          "language": "fa",
          "text": "نسخه کردن؛ تجویز کردن"
        },
        {
          "language": "kmr",
          "text": "derman nivîsîn"
        },
        {
          "language": "pl",
          "text": "przepisywać"
        },
        {
          "language": "ro",
          "text": "a prescrie"
        },
        {
          "language": "ru",
          "text": "выписывать; назначать"
        },
        {
          "language": "sq",
          "text": "të përshkruash ilaç"
        },
        {
          "language": "tr",
          "text": "reçete etmek; yazmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Arzt verschreibt mir ein neues Medikament.",
          "translations": [
            {
              "language": "ar",
              "text": "يصف لي الطبيب دواءً جديداً."
            },
            {
              "language": "ckb",
              "text": "پزیشکەکە دەرمانێکی نوێم بۆ دەنووسێت."
            },
            {
              "language": "en",
              "text": "The doctor prescribes me a new medicine."
            },
            {
              "language": "fa",
              "text": "پزشک برایم یک داروی جدید تجویز می‌کند."
            },
            {
              "language": "kmr",
              "text": "Bijîşk dermanekî nû ji min re dinivîse."
            },
            {
              "language": "pl",
              "text": "Lekarz przepisuje mi nowy lek."
            },
            {
              "language": "ro",
              "text": "Medicul îmi prescrie un medicament nou."
            },
            {
              "language": "ru",
              "text": "Врач выписывает мне новое лекарство."
            },
            {
              "language": "sq",
              "text": "Mjeku më përshkruan një ilaç të ri."
            },
            {
              "language": "tr",
              "text": "Doktor bana yeni bir ilaç yazıyor."
            }
          ]
        },
        {
          "baseText": "Kann die Ärztin das Rezept auch online verschreiben?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكن للطبيبة أن تصف الوصفة أيضاً عبر الإنترنت؟"
            },
            {
              "language": "ckb",
              "text": "ئایا پزیشکە ژنەکە دەتوانێت ڕەچەتەکە بە ئۆنلاینیش بنووسێت؟"
            },
            {
              "language": "en",
              "text": "Can the doctor prescribe the prescription online too?"
            },
            {
              "language": "fa",
              "text": "آیا پزشک می‌تواند نسخه را آنلاین هم تجویز کند؟"
            },
            {
              "language": "kmr",
              "text": "Ma bijîşk dikare reçeteyê online jî binivîse?"
            },
            {
              "language": "pl",
              "text": "Czy lekarka może przepisać receptę także online?"
            },
            {
              "language": "ro",
              "text": "Poate doctorița să prescrie rețeta și online?"
            },
            {
              "language": "ru",
              "text": "Может ли врач выписать рецепт также онлайн?"
            },
            {
              "language": "sq",
              "text": "A mund ta përshkruajë mjekja recetën edhe online?"
            },
            {
              "language": "tr",
              "text": "Doktor reçeteyi çevrim içi de yazabilir mi?"
            }
          ]
        }
      ]
    },
