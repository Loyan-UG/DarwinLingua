        "transport-and-travel",
        "documents-and-administration"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "written",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: verliert, verlor, hat verloren"
      ],
      "collocations": [
        {
          "text": "den Ausweis verlieren",
          "meaning": "to lose the ID card"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Verlust",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفقد؛ يخسر"
        },
        {
          "language": "ckb",
          "text": "ون دەکات؛ دەدۆڕێت"
        },
        {
          "language": "en",
          "text": "to lose"
        },
        {
          "language": "fa",
          "text": "گم کردن؛ باختن"
        },
        {
          "language": "kmr",
          "text": "winda kirin; winda bûn"
        },
        {
          "language": "pl",
          "text": "zgubić; przegrać"
        },
        {
          "language": "ro",
          "text": "a pierde"
        },
        {
          "language": "ru",
          "text": "терять; проигрывать"
        },
        {
          "language": "sq",
          "text": "të humbasësh"
        },
        {
          "language": "tr",
          "text": "kaybetmek"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe meinen Ausweis im Zug verloren.",
          "translations": [
            {
              "language": "ar",
              "text": "فقدت هويتي في القطار."
            },
            {
              "language": "ckb",
              "text": "من ناسنامەکەم لە شەمەندەفەرەکەدا ون کرد."
            },
            {
              "language": "en",
              "text": "I lost my ID on the train."
            },
            {
              "language": "fa",
              "text": "کارت شناسایی‌ام را در قطار گم کردم."
            },
            {
              "language": "kmr",
              "text": "Min nasnameya xwe di trênê de winda kir."
            },
            {
              "language": "pl",
              "text": "Zgubiłem dowód w pociągu."
            },
            {
              "language": "ro",
              "text": "Mi-am pierdut actul de identitate în tren."
            },
            {
              "language": "ru",
              "text": "Я потерял удостоверение в поезде."
            },
            {
              "language": "sq",
              "text": "E humba dokumentin tim në tren."
            },
            {
              "language": "tr",
              "text": "Kimliğimi trende kaybettim."
            }
          ]
        },
        {
          "baseText": "Bitte verlieren Sie die Quittung nicht.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك لا تفقد الإيصال."
            },
            {
              "language": "ckb",
              "text": "تکایە پسوولەکە ون مەکەن."
            },
            {
              "language": "en",
              "text": "Please do not lose the receipt."
            },
            {
              "language": "fa",
              "text": "لطفاً رسید را گم نکنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe qebzê winda nekin."
            },
            {
              "language": "pl",
              "text": "Proszę nie zgubić paragonu."
            },
            {
              "language": "ro",
              "text": "Vă rog să nu pierdeți chitanța."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не потеряйте квитанцию."
            },
            {
              "language": "sq",
              "text": "Ju lutem mos e humbni faturën."
            },
            {
              "language": "tr",
              "text": "Lütfen fişi kaybetmeyin."
            }
          ]
        }
      ]
    },
    {
      "word": "verschlafen",
      "language": "de",
      "cefrLevel": "A2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verschlafen",
      "pronunciationIpa": null,
      "syllableBreak": "ver-schla-fen",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "education-and-training"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: verschläft, verschlief, hat verschlafen"
      ],
      "collocations": [
        {
          "text": "den Wecker verschlafen",
          "meaning": "to sleep through the alarm"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schlafen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ينام أكثر من اللازم؛ يفوّت بسبب النوم"
        },
        {
          "language": "ckb",
          "text": "خەوتنی زۆر دەکات؛ لەبەر خەو لەدەست دەدات"
        },
        {
          "language": "en",
          "text": "to oversleep"
        },
        {
          "language": "fa",
          "text": "خواب ماندن"
        },
        {
          "language": "kmr",
          "text": "ji xew dereng rabûn"
        },
        {
          "language": "pl",
          "text": "zaspać"
        },
        {
          "language": "ro",
          "text": "a dormi prea mult; a întârzia din cauza somnului"
        },
        {
          "language": "ru",
          "text": "проспать"
        },
        {
          "language": "sq",
          "text": "të flesh më shumë; të zgjohesh vonë"
        },
        {
          "language": "tr",
          "text": "uyuyakalmak; geç uyanmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe heute Morgen verschlafen.",
          "translations": [
            {
              "language": "ar",
              "text": "نمت أكثر من اللازم هذا الصباح."
            },
            {
              "language": "ckb",
              "text": "ئەم بەیانییە خەوم لێکەوت."
            },
            {
              "language": "en",
              "text": "I overslept this morning."
            },
            {
              "language": "fa",
              "text": "امروز صبح خواب ماندم."
            },
            {
              "language": "kmr",
              "text": "Ez vê sibehê dereng rabûm."
            },
            {
              "language": "pl",
              "text": "Zaspałem dziś rano."
            },
            {
              "language": "ro",
              "text": "Am dormit prea mult în această dimineață."
            },
            {
              "language": "ru",
              "text": "Сегодня утром я проспал."
            },
            {
              "language": "sq",
              "text": "Sot në mëngjes u zgjova vonë."
            },
            {
              "language": "tr",
              "text": "Bu sabah uyuyakaldım."
            }
          ]
        },
        {
          "baseText": "Er hat den ersten Bus verschlafen.",
          "translations": [
            {
              "language": "ar",
              "text": "فوّت الحافلة الأولى لأنه نام."
            },
            {
              "language": "ckb",
              "text": "ئەو پاسە یەکەمەکەی لەبەر خەو لەدەست دا."
            },
            {
              "language": "en",
              "text": "He slept through the first bus."
            },
            {
              "language": "fa",
              "text": "او به‌خاطر خواب ماندن اتوبوس اول را از دست داد."
            },
            {
              "language": "kmr",
              "text": "Wî otobûsa yekem ji ber xewê winda kir."
            },
            {
              "language": "pl",
              "text": "Zaspał na pierwszy autobus."
            },
            {
              "language": "ro",
              "text": "A pierdut primul autobuz pentru că a dormit prea mult."
            },
            {
              "language": "ru",
              "text": "Он проспал первый автобус."
            },
            {
              "language": "sq",
              "text": "Ai e humbi autobusin e parë sepse fjeti shumë."
            },
            {
              "language": "tr",
              "text": "İlk otobüsü uyuyakaldığı için kaçırdı."
            }
          ]
        }
      ]
    },
