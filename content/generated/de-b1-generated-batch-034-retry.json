  "entries": [
    {
      "word": "die Betriebsrätin",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Betriebsrätinnen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-triebs-rä-tin",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "business",
        "spoken"
      ],
      "contextLabels": [
        "hr",
        "compliance"
      ],
      "grammarNotes": [
        "feminine noun; female member of the works council"
      ],
      "collocations": [
        {
          "text": "mit der Betriebsrätin sprechen",
          "meaning": "to speak with the female works council representative"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Betriebsrat",
          "relationLabel": "masculine/person or body",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عضوة مجلس العمال"
        },
        {
          "language": "ckb",
          "text": "ئەندامی ژنی ئەنجومەنی کارمەندان"
        },
        {
          "language": "en",
          "text": "female works council member"
        },
        {
          "language": "fa",
          "text": "عضو زن شورای کارکنان"
        },
        {
          "language": "kmr",
          "text": "endamê jin ê encumena karmendan"
        },
        {
          "language": "pl",
          "text": "członkini rady zakładowej"
        },
        {
          "language": "ro",
          "text": "membră a consiliului angajaților"
        },
        {
          "language": "ru",
          "text": "член производственного совета; представительница работников"
        },
        {
          "language": "sq",
          "text": "anëtare e këshillit të punonjësve"
        },
        {
          "language": "tr",
          "text": "kadın işyeri temsilcisi; işçi konseyi üyesi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Betriebsrätin erklärt den neuen Mitarbeitenden ihre Rechte.",
          "translations": [
            {
              "language": "ar",
              "text": "تشرح عضوة مجلس العمال حقوقهم للموظفين الجدد."
            },
            {
              "language": "ckb",
              "text": "ئەندامی ژنی ئەنجومەنی کارمەندان مافەکانیان بۆ کارمەندانی نوێ ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The female works council member explains their rights to the new employees."
            },
            {
              "language": "fa",
              "text": "عضو زن شورای کارکنان حقوق کارکنان جدید را برایشان توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Endama jin a encumena karmendan mafên karmendên nû şirove dike."
            },
            {
              "language": "pl",
              "text": "Członkini rady zakładowej wyjaśnia nowym pracownikom ich prawa."
            },
            {
              "language": "ro",
              "text": "Membra consiliului angajaților le explică noilor angajați drepturile lor."
            },
            {
              "language": "ru",
              "text": "Представительница производственного совета объясняет новым сотрудникам их права."
            },
            {
              "language": "sq",
              "text": "Anëtarja e këshillit të punonjësve u shpjegon punonjësve të rinj të drejtat e tyre."
            },
            {
              "language": "tr",
              "text": "Kadın işyeri temsilcisi yeni çalışanlara haklarını açıklıyor."
            }
          ]
        },
        {
          "baseText": "Bei Konflikten im Team kann man die Betriebsrätin um Rat bitten.",
          "translations": [
            {
              "language": "ar",
              "text": "عند وجود نزاعات في الفريق يمكن طلب المشورة من عضوة مجلس العمال."
            },
            {
              "language": "ckb",
              "text": "لە کاتی ناکۆکی لە تیمدا دەتوانرێت داوای ڕاوێژ لە ئەندامی ژنی ئەنجومەنی کارمەندان بکرێت."
            },
            {
              "language": "en",
              "text": "In team conflicts, you can ask the female works council member for advice."
            },
            {
              "language": "fa",
              "text": "در اختلافات تیمی می‌توان از عضو زن شورای کارکنان مشورت گرفت."
            },
            {
              "language": "kmr",
              "text": "Di nakokiyên tîmê de mirov dikare ji endama jin a encumenê şîret bixwaze."
            },
            {
              "language": "pl",
              "text": "W konfliktach w zespole można poprosić członkinię rady zakładowej o radę."
            },
            {
              "language": "ro",
              "text": "În conflictele din echipă, se poate cere sfatul membrei consiliului angajaților."
            },
            {
              "language": "ru",
              "text": "При конфликтах в команде можно обратиться за советом к представительнице работников."
            },
            {
              "language": "sq",
              "text": "Në konfliktet brenda ekipit mund t’i kërkosh këshillë anëtares së këshillit."
            },
            {
              "language": "tr",
              "text": "Ekip içi çatışmalarda kadın işyeri temsilcisinden tavsiye istenebilir."
            }
          ]
        }
      ]
    },
    {
      "word": "der Betriebsrat",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Betriebsräte",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-triebs-rat",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "hr",
        "compliance"
      ],
      "grammarNotes": [
        "masculine noun; can mean the works council as a body or a male member"
      ],
      "collocations": [
        {
          "text": "den Betriebsrat informieren",
          "meaning": "to inform the works council"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Betriebsrätin",
          "relationLabel": "feminine person",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مجلس العمال؛ ممثل العمال"
        },
        {
          "language": "ckb",
          "text": "ئەنجومەنی کارمەندان؛ نوێنەری کارمەندان"
        },
        {
          "language": "en",
          "text": "works council; employee representative body"
        },
        {
          "language": "fa",
          "text": "شورای کارکنان؛ نماینده کارکنان"
        },
        {
          "language": "kmr",
          "text": "encumena karmendan; nûneriya karmendan"
        },
        {
          "language": "pl",
          "text": "rada zakładowa; przedstawiciel pracowników"
        },
        {
          "language": "ro",
          "text": "consiliul angajaților; reprezentant al angajaților"
        },
        {
          "language": "ru",
          "text": "производственный совет; представитель работников"
        },
        {
          "language": "sq",
          "text": "këshilli i punonjësve; përfaqësues i punonjësve"
        },
        {
          "language": "tr",
          "text": "işyeri temsilciliği; işçi konseyi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Betriebsrat muss vor der Änderung der Arbeitszeiten informiert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب إبلاغ مجلس العمال قبل تغيير أوقات العمل."
            },
            {
              "language": "ckb",
              "text": "پێویستە پێش گۆڕینی کاتەکانی کار ئەنجومەنی کارمەندان ئاگادار بکرێتەوە."
            },
            {
              "language": "en",
              "text": "The works council must be informed before the working hours are changed."
            },
            {
              "language": "fa",
              "text": "قبل از تغییر ساعت‌های کاری باید شورای کارکنان مطلع شود."
            },
            {
              "language": "kmr",
              "text": "Divê berî guherandina demên karê encumena karmendan were agahdarkirin."
            },
            {
              "language": "pl",
              "text": "Rada zakładowa musi zostać poinformowana przed zmianą godzin pracy."
            },
            {
              "language": "ro",
              "text": "Consiliul angajaților trebuie informat înainte de modificarea programului de lucru."
            },
            {
              "language": "ru",
              "text": "Производственный совет должен быть проинформирован до изменения рабочего времени."
            },
            {
              "language": "sq",
              "text": "Këshilli i punonjësve duhet të informohet para ndryshimit të orarit të punës."
            },
            {
              "language": "tr",
              "text": "Çalışma saatleri değiştirilmeden önce işçi konseyi bilgilendirilmelidir."
            }
          ]
        },
        {
          "baseText": "Viele Beschäftigte wenden sich mit Fragen zum Urlaub an den Betriebsrat.",
          "translations": [
            {
              "language": "ar",
              "text": "يتوجه كثير من العاملين بأسئلة حول الإجازة إلى مجلس العمال."
            },
            {
              "language": "ckb",
              "text": "زۆر کارمەند بە پرسیار دەربارەی پشوویان پەیوەندی بە ئەنجومەنی کارمەندان دەکەن."
            },
            {
              "language": "en",
              "text": "Many employees contact the works council with questions about vacation."
            },
            {
              "language": "fa",
              "text": "بسیاری از کارکنان با پرسش‌هایی درباره مرخصی به شورای کارکنان مراجعه می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Gelek karmend bi pirsên li ser betlaneyê serî li encumena karmendan didin."
            },
            {
              "language": "pl",
              "text": "Wielu pracowników zwraca się do rady zakładowej z pytaniami o urlop."
            },
            {
              "language": "ro",
              "text": "Mulți angajați se adresează consiliului angajaților cu întrebări despre concediu."
            },
            {
              "language": "ru",
              "text": "Многие сотрудники обращаются в производственный совет с вопросами об отпуске."
            },
            {
              "language": "sq",
              "text": "Shumë punonjës i drejtohen këshillit të punonjësve me pyetje për pushimet."
            },
            {
              "language": "tr",
              "text": "Birçok çalışan izinle ilgili sorular için işçi konseyine başvuruyor."
            }
          ]
        }
      ]
    },
    {
