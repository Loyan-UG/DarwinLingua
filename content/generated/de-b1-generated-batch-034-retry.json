      "meanings": [
        {
          "language": "ar",
          "text": "اتفاقية عمل داخلية؛ اتفاقية شركة"
        },
        {
          "language": "ckb",
          "text": "ڕێککەوتنی ناوخۆی دامەزراوە"
        },
        {
          "language": "en",
          "text": "company agreement; works agreement"
        },
        {
          "language": "fa",
          "text": "توافق‌نامه داخلی شرکت؛ توافق‌نامه کاری"
        },
        {
          "language": "kmr",
          "text": "peymana navxweyî ya kargehê"
        },
        {
          "language": "pl",
          "text": "porozumienie zakładowe"
        },
        {
          "language": "ro",
          "text": "acord intern al companiei"
        },
        {
          "language": "ru",
          "text": "производственное соглашение; локальное соглашение"
        },
        {
          "language": "sq",
          "text": "marrëveshje e brendshme e kompanisë"
        },
        {
          "language": "tr",
          "text": "işyeri sözleşmesi; şirket içi anlaşma"
        }
      ],
      "examples": [
        {
          "baseText": "Die neue Betriebsvereinbarung regelt das Arbeiten im Homeoffice.",
          "translations": [
            {
              "language": "ar",
              "text": "تنظم اتفاقية العمل الداخلية الجديدة العمل من المنزل."
            },
            {
              "language": "ckb",
              "text": "ڕێککەوتنی ناوخۆی نوێ کاری لە ماڵەوە ڕێک دەخات."
            },
            {
              "language": "en",
              "text": "The new company agreement regulates working from home."
            },
            {
              "language": "fa",
              "text": "توافق‌نامه داخلی جدید شرکت، کار از خانه را تنظیم می‌کند."
            },
