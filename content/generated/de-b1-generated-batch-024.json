          "note": "formal: to require"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "حاجة؛ طلب؛ احتياج"
        },
        {
          "language": "ckb",
          "text": "پێویستی؛ داواکاری"
        },
        {
          "language": "en",
          "text": "need; demand; requirement"
        },
        {
          "language": "fa",
          "text": "نیاز؛ تقاضا"
        },
        {
          "language": "kmr",
          "text": "hewcehî; daxwaz"
        },
        {
          "language": "pl",
          "text": "zapotrzebowanie; potrzeba"
        },
        {
          "language": "ro",
          "text": "nevoie; cerere"
        },
        {
          "language": "ru",
          "text": "потребность; спрос"
        },
        {
          "language": "sq",
          "text": "nevojë; kërkesë"
        },
        {
          "language": "tr",
          "text": "ihtiyaç; talep"
        }
      ],
      "examples": [
        {
          "baseText": "Wir prüfen zuerst den Bedarf, bevor wir neue Lizenzen kaufen.",
          "translations": [
            {
              "language": "ar",
              "text": "نفحص أولًا الحاجة قبل أن نشتري تراخيص جديدة."
            },
            {
              "language": "ckb",
              "text": "سەرەتا پێویستییەکە دەپشکنین پێش ئەوەی مۆڵەتی نوێ بکڕین."
            },
            {
              "language": "en",
              "text": "We first check the need before buying new licenses."
            },
            {
              "language": "fa",
              "text": "قبل از خرید لایسنس‌های جدید، ابتدا نیاز را بررسی می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em pêşî hewcehiyê kontrol dikin berî ku lîsansên nû bikirin."
            },
            {
              "language": "pl",
              "text": "Najpierw sprawdzamy zapotrzebowanie, zanim kupimy nowe licencje."
            },
            {
              "language": "ro",
              "text": "Mai întâi verificăm necesarul înainte să cumpărăm licențe noi."
            },
            {
              "language": "ru",
              "text": "Сначала мы проверяем потребность, прежде чем покупать новые лицензии."
            },
            {
              "language": "sq",
              "text": "Së pari kontrollojmë nevojën para se të blejmë licenca të reja."
            },
            {
              "language": "tr",
              "text": "Yeni lisanslar almadan önce ihtiyacı kontrol ediyoruz."
            }
          ]
        },
        {
          "baseText": "Bei Bedarf können Sie einen zweiten Termin mit der Ärztin vereinbaren.",
          "translations": [
            {
              "language": "ar",
              "text": "عند الحاجة يمكنكم تحديد موعد ثانٍ مع الطبيبة."
            },
            {
              "language": "ckb",
