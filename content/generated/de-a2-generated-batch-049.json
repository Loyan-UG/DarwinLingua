        },
        {
          "language": "kmr",
          "text": "germkirin; soba"
        },
        {
          "language": "pl",
          "text": "ogrzewanie; grzejnik"
        },
        {
          "language": "ro",
          "text": "încălzire; calorifer"
        },
        {
          "language": "ru",
          "text": "отопление; батарея"
        },
        {
          "language": "sq",
          "text": "ngrohje; radiator"
        },
        {
          "language": "tr",
          "text": "ısıtma; kalorifer"
        }
      ],
      "examples": [
        {
          "baseText": "Die Heizung ist im Wohnzimmer kaputt.",
          "translations": [
            {
              "language": "ar",
              "text": "التدفئة في غرفة المعيشة معطلة."
            },
            {
              "language": "ckb",
              "text": "گەرماکەرەوەکە لە ژووری دانیشتن تێکچووە."
            },
            {
              "language": "en",
              "text": "The heating in the living room is broken."
            },
            {
              "language": "fa",
              "text": "بخاری اتاق نشیمن خراب است."
            },
            {
              "language": "kmr",
              "text": "Germkirin li odeya rûniştinê xerab e."
            },
            {
              "language": "pl",
              "text": "Ogrzewanie w salonie jest zepsute."
            },
            {
              "language": "ro",
              "text": "Încălzirea din sufragerie este stricată."
            },
            {
              "language": "ru",
              "text": "Отопление в гостиной сломано."
            },
            {
              "language": "sq",
              "text": "Ngrohja në dhomën e ndenjjes është prishur."
            },
            {
              "language": "tr",
              "text": "Oturma odasındaki kalorifer bozuk."
            }
          ]
        },
        {
          "baseText": "Kannst du bitte die Heizung anmachen?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك تشغيل التدفئة من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "تکایە دەتوانیت گەرماکەرەوەکە بکەیتەوە؟"
            },
            {
              "language": "en",
              "text": "Can you please turn on the heating?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً بخاری را روشن کنی؟"
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe dikarî germkirinê vekî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz włączyć ogrzewanie?"
            },
            {
              "language": "ro",
              "text": "Poți să pornești încălzirea, te rog?"
            },
            {
              "language": "ru",
              "text": "Можешь, пожалуйста, включить отопление?"
            },
            {
              "language": "sq",
              "text": "A mund ta ndezësh ngrohjen, të lutem?"
            },
            {
              "language": "tr",
              "text": "Lütfen kaloriferi açabilir misin?"
            }
          ]
        }
      ]
    },
