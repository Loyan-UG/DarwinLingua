      ],
      "collocations": [
        {
          "text": "in die Heimatstadt fahren",
          "meaning": "to travel to one’s hometown"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Heimat",
          "relationLabel": "noun",
          "note": "home; homeland"
        },
        {
          "lemma": "die Stadt",
          "relationLabel": "noun",
          "note": "city"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مسقط الرأس؛ المدينة الأصلية"
        },
        {
          "language": "ckb",
          "text": "شاری زێد؛ شاری خۆی"
        },
        {
          "language": "en",
          "text": "hometown"
        },
        {
          "language": "fa",
          "text": "زادگاه؛ شهر اصلی"
        },
        {
          "language": "kmr",
          "text": "bajarê dayikbûnê"
        },
        {
          "language": "pl",
          "text": "rodzinne miasto"
        },
        {
          "language": "ro",
          "text": "oraș natal"
        },
        {
          "language": "ru",
          "text": "родной город"
        },
        {
          "language": "sq",
          "text": "qytet i lindjes"
        },
        {
          "language": "tr",
          "text": "memleket; doğup büyüdüğü şehir"
        }
      ],
      "examples": [
        {
          "baseText": "Meine Heimatstadt liegt am Rhein.",
          "translations": [
            {
              "language": "ar",
              "text": "مدينتي الأصلية تقع على نهر الراين."
            },
            {
              "language": "ckb",
              "text": "شاری زێدم لەسەر ڕووباری ڕاینە."
            },
            {
              "language": "en",
              "text": "My hometown is on the Rhine."
            },
            {
              "language": "fa",
              "text": "زادگاهم کنار رود راین است."
            },
            {
              "language": "kmr",
              "text": "Bajarê min ê dayikbûnê li ser Rênê ye."
            },
            {
              "language": "pl",
              "text": "Moje rodzinne miasto leży nad Renem."
            },
            {
              "language": "ro",
              "text": "Orașul meu natal este pe Rin."
            },
            {
              "language": "ru",
              "text": "Мой родной город находится на Рейне."
            },
            {
              "language": "sq",
              "text": "Qyteti im i lindjes është pranë Rinit."
            },
            {
              "language": "tr",
              "text": "Memleketim Ren Nehri kıyısında."
            }
          ]
        },
        {
          "baseText": "Im Sommer besuche ich meine Heimatstadt.",
          "translations": [
            {
              "language": "ar",
              "text": "في الصيف أزور مدينتي الأصلية."
            },
            {
              "language": "ckb",
              "text": "لە هاویندا سەردانی شاری زێدم دەکەم."
            },
            {
              "language": "en",
              "text": "In summer I visit my hometown."
            },
            {
              "language": "fa",
              "text": "در تابستان به زادگاهم سر می‌زنم."
            },
            {
              "language": "kmr",
              "text": "Havînê ez serdana bajarê xwe yê dayikbûnê dikim."
            },
            {
              "language": "pl",
              "text": "Latem odwiedzam rodzinne miasto."
            },
            {
              "language": "ro",
              "text": "Vara îmi vizitez orașul natal."
            },
            {
              "language": "ru",
              "text": "Летом я навещаю свой родной город."
            },
            {
              "language": "sq",
              "text": "Në verë vizitoj qytetin tim të lindjes."
            },
            {
              "language": "tr",
              "text": "Yazın memleketimi ziyaret ederim."
            }
          ]
        }
      ]
    },
