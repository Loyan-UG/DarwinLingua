      "meanings": [
        {
          "language": "ar",
          "text": "تدفئة؛ جهاز التدفئة"
        },
        {
          "language": "ckb",
          "text": "گەرماکەرەوە؛ سیستەمی گەرما"
        },
        {
          "language": "en",
