      "examples": [
        {
          "baseText": "Der Musiker spielt heute Abend im Café.",
          "translations": [
            {
              "language": "ar",
              "text": "الموسيقي يعزف هذا المساء في المقهى."
            },
            {
              "language": "ckb",
              "text": "مۆسیقارەکە ئەم ئێوارەیە لە کافێ دەژەنێت."
            },
            {
              "language": "en",
              "text": "The musician is playing at the café this evening."
            },
            {
              "language": "fa",
              "text": "موسیقی‌دان امشب در کافه می‌نوازد."
            },
            {
              "language": "kmr",
              "text": "Muzîkvan îvarê li kafeyê dilîze."
            },
            {
              "language": "pl",
              "text": "Muzyk gra dziś wieczorem w kawiarni."
            },
            {
              "language": "ro",
              "text": "Muzicianul cântă în seara aceasta la cafenea."
            },
            {
              "language": "ru",
              "text": "Музыкант сегодня вечером играет в кафе."
            },
            {
              "language": "sq",
              "text": "Muzikanti luan sonte në kafene."
            },
            {
              "language": "tr",
              "text": "Müzisyen bu akşam kafede çalıyor."
            }
          ]
        },
        {
          "baseText": "Mein Bruder möchte Musiker werden.",
          "translations": [
            {
              "language": "ar",
              "text": "أخي يريد أن يصبح موسيقياً."
            },
            {
              "language": "ckb",
              "text": "براکەم دەیەوێت ببێتە مۆسیقار."
            },
            {
              "language": "en",
              "text": "My brother wants to become a musician."
            },
            {
              "language": "fa",
              "text": "برادرم می‌خواهد موسیقی‌دان شود."
            },
            {
              "language": "kmr",
              "text": "Birayê min dixwaze bibe muzîkvan."
            },
            {
              "language": "pl",
              "text": "Mój brat chce zostać muzykiem."
            },
            {
              "language": "ro",
              "text": "Fratele meu vrea să devină muzician."
            },
            {
              "language": "ru",
              "text": "Мой брат хочет стать музыкантом."
            },
            {
              "language": "sq",
              "text": "Vëllai im dëshiron të bëhet muzikant."
            },
            {
              "language": "tr",
              "text": "Erkek kardeşim müzisyen olmak istiyor."
            }
