      "examples": [
        {
          "baseText": "Meine Tochter geht jeden Mittwoch in die Musikschule.",
          "translations": [
            {
              "language": "ar",
              "text": "ابنتي تذهب كل أربعاء إلى مدرسة الموسيقى."
            },
            {
              "language": "ckb",
              "text": "کچەکەم هەموو چوارشەممە دەچێت بۆ قوتابخانەی مۆسیقا."
            },
            {
              "language": "en",
              "text": "My daughter goes to music school every Wednesday."
            },
            {
              "language": "fa",
              "text": "دخترم هر چهارشنبه به آموزشگاه موسیقی می‌رود."
            },
            {
              "language": "kmr",
              "text": "Keça min her çarşemê diçe dibistana muzîkê."
            },
            {
              "language": "pl",
              "text": "Moja córka chodzi w każdą środę do szkoły muzycznej."
            },
            {
              "language": "ro",
              "text": "Fiica mea merge în fiecare miercuri la școala de muzică."
            },
            {
              "language": "ru",
              "text": "Моя дочь каждую среду ходит в музыкальную школу."
            },
            {
              "language": "sq",
              "text": "Vajza ime shkon çdo të mërkurë në shkollën e muzikës."
            },
            {
              "language": "tr",
              "text": "Kızım her çarşamba müzik okuluna gidiyor."
            }
          ]
        },
        {
          "baseText": "Die Musikschule ist neben der Bibliothek.",
