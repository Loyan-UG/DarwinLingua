  "entries": [
    {
      "word": "aufblasen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufblasen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-blah-sen",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "finance-and-accounting"
      ],
      "usageLabels": [
        "workplace",
        "formal",
        "written"
      ],
      "contextLabels": [
        "management",
        "documents"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "نفخ دادن؛ اغراق کردن"
        },
        {
          "language": "ckb",
          "text": "بەستراو/خەسەکردن"
        },
        {
          "language": "en",
          "text": "to inflate; to overstate"
        },
        {
          "language": "fa",
          "text": "بزرگ‌نمایی کردن؛ پف کردن"
        },
        {
          "language": "kmr",
          "text": "balindarkirin; neynandin zêde"
        },
        {
          "language": "pl",
          "text": "pompując, przesadzać"
        },
        {
          "language": "ro",
          "text": "a umfla; a exagera"
        },
        {
          "language": "ru",
          "text": "раздувать; преувеличивать"
        },
        {
          "language": "sq",
          "text": "të fryjë; të ekzagjerojë"
        },
        {
          "language": "tr",
          "text": "şişirmek; abartmak"
        }
      ],
      "examples": [
        {
          "baseText": "Wir dürfen die Zahl der offenen Punkte nicht aufblasen, sondern nur nachweisbar dokumentieren.",
          "translations": [
            {
              "language": "ar",
              "text": "نباید تعداد موارد باز را بزرگنمایی کنیم، فقط باید با اثبات مستند کنیم."
            },
            {
              "language": "ckb",
              "text": "ناتوانینەوە ئەم ژمارەی خاڵە کراوەکانە بە قەیراغ نەکەین و تەنها بە بەڵگەی دڵنیابوو بڵێین."
            },
            {
              "language": "en",
              "text": "We must not inflate the number of open items, only document it with evidence."
            },
            {
              "language": "fa",
              "text": "نمی‌توانیم تعداد موارد باز را اغراق‌آمیز گزارش کنیم؛ باید فقط با سند قابل اتکا ثبت کنیم."
            },
            {
              "language": "kmr",
              "text": "Ji ne rewşên vekirî qirçî nekin, tenê bi belgeyên çalakiyê tomar bikin."
            },
            {
              "language": "pl",
              "text": "Nie możemy naciągać liczby otwartych punktów, tylko udokumentować ją udokumentowanie."
            },
            {
              "language": "ro",
              "text": "Nu trebuie să supraestimăm numărul punctelor deschise, ci doar să-l documentăm justificat."
            },
            {
              "language": "ru",
              "text": "Мы не должны завышать число открытых вопросов, а только документировать его на основе фактов."
            },
            {
              "language": "sq",
              "text": "Nuk duhet të fryjmë numrin e rasteve aktive, por ta dokumentojmë vetëm me prova."
            },
            {
              "language": "tr",
              "text": "Açık kalem sayısını şişirmemeliyiz, yalnızca kanıtla belgelenmelidir."
            }
          ]
        },
        {
          "baseText": "Der Berater hat im Präsentationsbericht die Risiken nicht übertrieben aufgeblaut.",
          "translations": [
            {
              "language": "ar",
              "text": "مشاور در گزارش ارائه، ریسک‌ها را بیش از حد بزرگنمایی نکرد."
            },
            {
              "language": "ckb",
              "text": "ڕاهێنەر لە ڕاپۆرتی پێشکەش نەگەیە تەواوەتیەکانی بەرەو خەریکی کەمە."
            },
            {
              "language": "en",
              "text": "The consultant did not exaggerate the risks in the presentation report."
            },
            {
              "language": "fa",
              "text": "مشاور در گزارش ارائه، ریسک‌ها را اغراق نکرد."
            },
            {
              "language": "kmr",
              "text": "ڕاپێی کارە پێشکەشەکەدا تۆخماریەکان زۆرجێگیر نەکرد."
            },
            {
              "language": "pl",
              "text": "Konsultant nie wyolbrzymił ryzyk w raporcie prezentacji."
            },
            {
              "language": "ro",
              "text": "Consultantul nu a exagerat riscurile în raportul de prezentare."
            },
            {
              "language": "ru",
              "text": "Консультант не преувеличил риски в презентационном отчёте."
            },
            {
              "language": "sq",
              "text": "Konsulenti nuk i ekzagjeroi rreziqet në raportin e prezantimit."
            },
            {
              "language": "tr",
              "text": "Danışman sunum raporunda riskleri abartmadı."
            }
          ]
        }
      ]
    },
    {
      "word": "aufbrechen",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufbrechen",
      "pronunciationIpa": null,
      "syllableBreak": "auf-bre-chen",
      "topics": [
        "work-and-jobs",
        "documents-and-administration",
        "public-services"
      ],
      "usageLabels": [
        "workplace",
        "formal",
        "written"
      ],
      "contextLabels": [
        "documents",
        "public-services",
        "management"
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "شروع/آغاز؛ شکافتن"
        },
        {
          "language": "ckb",
          "text": "دەستپێکردن/بەشکردن"
        },
        {
          "language": "en",
          "text": "to break/open (something open)"
        },
        {
          "language": "fa",
          "text": "باز کردن؛ شروع کردن"
        },
        {
          "language": "kmr",
          "text": "vekirin; dest pê kirin"
        },
        {
          "language": "pl",
          "text": "otwierać; rozpoczynać"
        },
        {
          "language": "ro",
          "text": "a deschide; a începe"
        },
        {
          "language": "ru",
          "text": "открывать; начинать"
        },
        {
          "language": "sq",
          "text": "me hapur; me nisur"
        },
        {
          "language": "tr",
          "text": "açmak; başlatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Prüfung der Unterlagen für das Förderverfahren ist am Montag aufgebrochen worden, nachdem die Freigabe kam.",
          "translations": [
            {
              "language": "ar",
              "text": "بازبینی مدارک برنامه حمایت مالی روز دوشنبه شروع شد بعد از تأیید."
            },
            {
              "language": "ckb",
              "text": "پشکنینەوەی بەڵگەنامە بۆ پڕۆگرامەکی پشتگیری لە دووشەممەوە لە دوای وەرگرتنی ڕێگەدانەوە دەستپێکرد."
            },
            {
              "language": "en",
              "text": "The document review for the subsidy process was started on Monday after approval came through."
            },
            {
              "language": "fa",
              "text": "بازرسی اسناد برای فرآیند حمایت در روز دوشنبه پس از دریافت مجوز شروع شد."
            },
            {
              "language": "kmr",
