        },
        {
          "language": "en",
          "text": "holiday apartment; vacation rental"
        },
        {
          "language": "fa",
          "text": "آپارتمان تعطیلات"
        },
        {
          "language": "kmr",
          "text": "apartmana betlaneyê"
        },
        {
          "language": "pl",
