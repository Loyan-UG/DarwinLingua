        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بيت عطلات"
        },
        {
          "language": "ckb",
          "text": "ماڵی پشوو"
        },
        {
          "language": "en",
          "text": "holiday house; vacation home"
        },
        {
          "language": "fa",
          "text": "خانه تعطیلات؛ ویلا"
        },
        {
          "language": "kmr",
          "text": "mala betlaneyê"
        },
        {
          "language": "pl",
          "text": "dom wakacyjny"
        },
        {
          "language": "ro",
          "text": "casă de vacanță"
        },
        {
          "language": "ru",
          "text": "дом для отпуска"
        },
        {
          "language": "sq",
          "text": "shtëpi pushimi"
        },
        {
          "language": "tr",
          "text": "tatil evi"
        }
      ],
      "examples": [
        {
          "baseText": "Wir mieten im Sommer ein Ferienhaus am See.",
          "translations": [
            {
              "language": "ar",
              "text": "نستأجر في الصيف بيت عطلات عند البحيرة."
            },
            {
              "language": "ckb",
              "text": "لە هاویندا ماڵێکی پشوو لە کنار دەریاچە دەگرین."
            },
            {
              "language": "en",
              "text": "We rent a holiday house by the lake in summer."
            },
            {
              "language": "fa",
              "text": "تابستان یک خانه تعطیلات کنار دریاچه اجاره می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em di havînê de malek betlaneyê li kêleka golê digirin."
            },
            {
              "language": "pl",
              "text": "Latem wynajmujemy dom wakacyjny nad jeziorem."
            },
            {
              "language": "ro",
              "text": "Vara închiriem o casă de vacanță lângă lac."
            },
            {
              "language": "ru",
              "text": "Летом мы арендуем дом для отпуска у озера."
            },
            {
              "language": "sq",
              "text": "Në verë marrim me qira një shtëpi pushimi pranë liqenit."
            },
            {
              "language": "tr",
              "text": "Yazın göl kenarında bir tatil evi kiralıyoruz."
            }
          ]
        },
        {
          "baseText": "Das Ferienhaus hat drei Zimmer und eine kleine Küche.",
          "translations": [
            {
              "language": "ar",
              "text": "بيت العطلات فيه ثلاث غرف ومطبخ صغير."
            },
            {
              "language": "ckb",
              "text": "ماڵی پشووکە سێ ژوور و چێشتخانەیەکی بچووکی هەیە."
            },
            {
              "language": "en",
              "text": "The holiday house has three rooms and a small kitchen."
            },
            {
              "language": "fa",
              "text": "خانه تعطیلات سه اتاق و یک آشپزخانه کوچک دارد."
            },
            {
              "language": "kmr",
              "text": "Mala betlaneyê sê ode û metbexek biçûk heye."
            },
            {
              "language": "pl",
              "text": "Dom wakacyjny ma trzy pokoje i małą kuchnię."
            },
            {
              "language": "ro",
              "text": "Casa de vacanță are trei camere și o bucătărie mică."
            },
            {
              "language": "ru",
              "text": "В доме для отпуска три комнаты и маленькая кухня."
            },
            {
              "language": "sq",
              "text": "Shtëpia e pushimit ka tre dhoma dhe një kuzhinë të vogël."
            },
            {
              "language": "tr",
              "text": "Tatil evinde üç oda ve küçük bir mutfak var."
            }
          ]
        }
      ]
    },
