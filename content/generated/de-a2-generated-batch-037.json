        }
      ],
      "examples": [
        {
          "baseText": "Die Ferienwohnung ist nur fünf Minuten vom Strand entfernt.",
          "translations": [
            {
              "language": "ar",
              "text": "شقة العطلات تبعد خمس دقائق فقط عن الشاطئ."
            },
            {
              "language": "ckb",
              "text": "شوقەی پشووکە تەنها پێنج خولەک لە کەناراوە دوورە."
            },
            {
              "language": "en",
              "text": "The holiday apartment is only five minutes from the beach."
            },
            {
              "language": "fa",
              "text": "آپارتمان تعطیلات فقط پنج دقیقه از ساحل فاصله دارد."
            },
            {
              "language": "kmr",
              "text": "Apartmana betlaneyê tenê pênc xulek ji qeraxê dûr e."
            },
            {
              "language": "pl",
              "text": "Apartament wakacyjny jest tylko pięć minut od plaży."
            },
            {
              "language": "ro",
              "text": "Apartamentul de vacanță este la doar cinci minute de plajă."
            },
            {
              "language": "ru",
              "text": "Квартира для отпуска всего в пяти минутах от пляжа."
            },
            {
              "language": "sq",
              "text": "Apartamenti i pushimit është vetëm pesë minuta nga plazhi."
            },
            {
              "language": "tr",
              "text": "Tatil dairesi plaja sadece beş dakika uzaklıkta."
            }
          ]
        },
        {
          "baseText": "Wir buchen die Ferienwohnung online.",
          "translations": [
            {
              "language": "ar",
              "text": "نحجز شقة العطلات عبر الإنترنت."
            },
            {
              "language": "ckb",
              "text": "شوقەی پشووکە ئۆنلاین دەگرین."
            },
            {
              "language": "en",
              "text": "We book the holiday apartment online."
            },
            {
              "language": "fa",
              "text": "آپارتمان تعطیلات را آنلاین رزرو می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em apartmana betlaneyê online veqetînin."
            },
            {
              "language": "pl",
              "text": "Rezerwujemy apartament wakacyjny online."
            },
            {
              "language": "ro",
              "text": "Rezervăm online apartamentul de vacanță."
            },
            {
              "language": "ru",
              "text": "Мы бронируем квартиру для отпуска онлайн."
            },
            {
              "language": "sq",
              "text": "E rezervojmë apartamentin e pushimit online."
            },
            {
              "language": "tr",
              "text": "Tatil dairesini çevrim içi rezerve ediyoruz."
            }
          ]
        }
      ]
