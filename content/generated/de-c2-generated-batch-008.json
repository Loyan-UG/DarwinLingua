  "entries": [
    {
      "word": "der Argwohn",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Arg-wohn",
      "topics": [
        "social-and-relationships",
        "business-communication",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun; usually singular; means suspicion or distrust"
      ],
      "collocations": [
        {
          "text": "Argwohn wecken",
          "meaning": "to arouse suspicion"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "argwöhnisch",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ارتياب؛ سوء ظن"
        },
        {
          "language": "ckb",
          "text": "گومان؛ بێمتمانەیی"
        },
        {
          "language": "en",
          "text": "suspicion; distrust"
        },
        {
          "language": "fa",
          "text": "بدگمانی؛ سوءظن"
        },
        {
          "language": "kmr",
          "text": "guman; bêbawerî"
        },
        {
          "language": "pl",
          "text": "podejrzliwość; nieufność"
        },
        {
          "language": "ro",
          "text": "suspiciune; neîncredere"
        },
        {
          "language": "ru",
          "text": "подозрение; недоверие"
        },
        {
          "language": "sq",
          "text": "dyshim; mosbesim"
        },
        {
          "language": "tr",
          "text": "kuşku; güvensizlik"
        }
      ],
      "examples": [
        {
          "baseText": "Die ungewöhnlich späte Änderung im Vertrag weckte bei der Einkaufsabteilung sofort Argwohn.",
          "translations": [
            {
              "language": "ar",
              "text": "أثار التغيير المتأخر وغير المعتاد في العقد ارتياب قسم المشتريات فوراً."
            },
            {
              "language": "ckb",
              "text": "گۆڕانکارییە نائاسایی و درەنگەکە لە گرێبەستەکەدا دەستبەجێ گومانی لای بەشی کڕین دروست کرد."
            },
            {
              "language": "en",
              "text": "The unusually late change in the contract immediately aroused suspicion in the purchasing department."
            },
            {
              "language": "fa",
              "text": "تغییر غیرمعمول و دیرهنگام در قرارداد فوراً بدگمانی بخش خرید را برانگیخت."
            },
            {
              "language": "kmr",
              "text": "Guhertina neasayî ya dereng di peymanê de yekser guman li beşa kirînê çêkir."
            },
            {
              "language": "pl",
              "text": "Nietypowo późna zmiana w umowie natychmiast wzbudziła podejrzenia działu zakupów."
            },
            {
              "language": "ro",
              "text": "Modificarea neobișnuit de târzie din contract a trezit imediat suspiciuni în departamentul de achiziții."
            },
            {
              "language": "ru",
              "text": "Необычно позднее изменение в договоре сразу вызвало подозрение у отдела закупок."
            },
            {
              "language": "sq",
              "text": "Ndryshimi jashtëzakonisht i vonë në kontratë ngjalli menjëherë dyshim te departamenti i blerjeve."
            },
            {
              "language": "tr",
              "text": "Sözleşmedeki olağandışı geç değişiklik satın alma departmanında hemen kuşku uyandırdı."
            }
          ]
        },
        {
          "baseText": "Ihr Argwohn war nicht unbegründet, doch er erschwerte jedes offene Gespräch.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يكن ارتيابها بلا أساس، لكنه جعل كل حوار صريح أكثر صعوبة."
            },
            {
              "language": "ckb",
              "text": "گومانەکەی بێبنەما نەبوو، بەڵام هەر گفتوگۆیەکی کراوەی قورس کرد."
            },
            {
              "language": "en",
              "text": "Her suspicion was not unfounded, but it made every open conversation more difficult."
            },
            {
              "language": "fa",
              "text": "بدگمانی او بی‌اساس نبود، اما هر گفت‌وگوی صریحی را دشوارتر می‌کرد."
            },
            {
              "language": "kmr",
              "text": "Gumana wê bêbingeh nebû, lê her axaftineke vekirî dijwartir dikir."
            },
            {
              "language": "pl",
              "text": "Jej podejrzliwość nie była bezpodstawna, lecz utrudniała każdą otwartą rozmowę."
            },
            {
              "language": "ro",
              "text": "Suspiciunea ei nu era nefondată, dar îngreuna orice conversație deschisă."
            },
            {
              "language": "ru",
              "text": "Её подозрение не было беспочвенным, но оно затрудняло любой открытый разговор."
            },
            {
              "language": "sq",
              "text": "Dyshimi i saj nuk ishte i pabazë, por e vështirësonte çdo bisedë të hapur."
            },
            {
              "language": "tr",
              "text": "Kuşkusu temelsiz değildi, ama her açık konuşmayı zorlaştırıyordu."
            }
          ]
        }
      ]
    },
    {
      "word": "artifiziell",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ar-ti-fi-zi-ell",
      "topics": [
        "culture-and-media",
        "advanced-analysis",
        "technology-and-it"
      ],
      "usageLabels": [
        "formal",
        "written",
        "academic",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; means artificial, deliberately constructed, or not naturally developed"
      ],
      "collocations": [
        {
          "text": "artifiziell wirken",
          "meaning": "to appear artificial"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Artefakt",
          "relationLabel": "noun",
          "note": "related in meaning of artificial product"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مصطنع؛ غير طبيعي؛ مصنوع بعناية"
        },
        {
          "language": "ckb",
          "text": "دەستکرد؛ نەسروشتی؛ بە ئاگاداری دروستکراو"
        },
        {
          "language": "en",
          "text": "artificial; contrived; deliberately constructed"
        },
        {
          "language": "fa",
          "text": "مصنوعی؛ ساختگی؛ آگاهانه ساخته‌شده"
        },
        {
          "language": "kmr",
          "text": "çêkirî; ne xwezayî; bi zanebûn avakirî"
        },
        {
          "language": "pl",
          "text": "sztuczny; wykoncypowany"
        },
        {
          "language": "ro",
          "text": "artificial; construit; nenatural"
        },
        {
          "language": "ru",
          "text": "искусственный; нарочитый; сконструированный"
        },
        {
          "language": "sq",
          "text": "artificial; i sajuar; i ndërtuar qëllimisht"
        },
        {
          "language": "tr",
          "text": "yapay; kurgulanmış; doğal olmayan"
        }
      ],
      "examples": [
        {
          "baseText": "Die Dialoge der Demo wirkten artifiziell, weil echte Kundeneinwände nicht berücksichtigt wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "بدت حوارات العرض التوضيحي مصطنعة لأن اعتراضات العملاء الحقيقية لم تؤخذ في الحسبان."
            },
            {
              "language": "ckb",
              "text": "دیالۆگەکانی دیمۆکە دەستکرد دیار بوون، چونکە ناڕەزاییە ڕاستەقینەکانی کڕیاران لەبەرچاو نەگیرابوون."
            },
            {
              "language": "en",
              "text": "The demo dialogues felt artificial because real customer objections had not been considered."
            },
            {
              "language": "fa",
              "text": "گفت‌وگوهای دمو مصنوعی به نظر می‌رسیدند، چون اعتراض‌های واقعی مشتریان در نظر گرفته نشده بود."
            },
            {
              "language": "kmr",
              "text": "Diyalogên demoyê çêkirî xuya dikirin, ji ber ku nerazîbûnên rastîn ên xerîdaran nehatibûn hesibandin."
            },
            {
              "language": "pl",
              "text": "Dialogi w wersji demonstracyjnej brzmiały sztucznie, ponieważ nie uwzględniono rzeczywistych zastrzeżeń klientów."
            },
            {
              "language": "ro",
              "text": "Dialogurile din demo păreau artificiale, deoarece obiecțiile reale ale clienților nu fuseseră luate în considerare."
            },
            {
              "language": "ru",
              "text": "Диалоги в демо выглядели искусственными, потому что реальные возражения клиентов не были учтены."
            },
            {
              "language": "sq",
              "text": "Dialogët e demos dukeshin artificialë sepse kundërshtimet reale të klientëve nuk ishin marrë parasysh."
            },
            {
              "language": "tr",
              "text": "Demodaki diyaloglar yapay görünüyordu çünkü gerçek müşteri itirazları dikkate alınmamıştı."
            }
          ]
        },
        {
          "baseText": "Der Film setzt bewusst auf eine artifizielle Farbgebung, um jede Illusion von Natürlichkeit zu vermeiden.",
          "translations": [
            {
              "language": "ar",
              "text": "يعتمد الفيلم عمداً على ألوان مصطنعة لتجنب أي وهم بالطبيعية."
            },
            {
              "language": "ckb",
              "text": "فیلمەکە بە ئاگاداری ڕەنگدانەوەیەکی دەستکرد بەکاردەهێنێت بۆ ئەوەی هەر خەیاڵێکی سروشتیبوون نەهێڵێت."
            },
            {
              "language": "en",
              "text": "The film deliberately uses an artificial color scheme to avoid any illusion of naturalness."
            },
            {
              "language": "fa",
              "text": "فیلم آگاهانه از رنگ‌پردازی مصنوعی استفاده می‌کند تا هر توهم طبیعی بودن را از بین ببرد."
            },
            {
              "language": "kmr",
              "text": "Fîlm bi zanebûn rengdaneke çêkirî bi kar tîne da ku her xeyala xwezayîbûnê dûr bike."
            },
            {
              "language": "pl",
              "text": "Film świadomie korzysta ze sztucznej kolorystyki, aby uniknąć iluzji naturalności."
            },
            {
              "language": "ro",
              "text": "Filmul folosește deliberat o cromatică artificială pentru a evita orice iluzie de naturalețe."
            },
            {
              "language": "ru",
              "text": "Фильм сознательно использует искусственную цветовую гамму, чтобы избежать всякой иллюзии естественности."
            },
            {
              "language": "sq",
              "text": "Filmi përdor qëllimisht një skemë ngjyrash artificiale për të shmangur çdo iluzion natyrshmërie."
            },
            {
              "language": "tr",
              "text": "Film, doğallık yanılsamasından kaçınmak için bilinçli olarak yapay bir renk düzeni kullanır."
            }
          ]
        }
      ]
    },
