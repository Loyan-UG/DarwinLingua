  "entries": [
    {
      "word": "erkenntnisleitend",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "er-kennt-nis-lei-tend",
      "topics": [
        "advanced-analysis",
        "education-and-training",
        "data-and-reporting"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; mainly used in academic and analytical contexts"
      ],
      "collocations": [
        {
          "text": "eine erkenntnisleitende Frage",
          "meaning": "a question that guides inquiry"
        },
        {
          "text": "erkenntnisleitende Annahmen",
          "meaning": "assumptions guiding the analysis"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erkenntnis",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "leiten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "موجّه للمعرفة؛ يقود عملية الفهم أو البحث"
        },
        {
          "language": "ckb",
          "text": "زانین-ڕێبەر؛ ڕێنمایی شیکردنەوە یان تێگەیشتن دەکات"
        },
        {
          "language": "en",
          "text": "guiding inquiry; knowledge-guiding"
        },
        {
          "language": "fa",
          "text": "راهنمای شناخت؛ جهت‌دهنده به تحلیل یا پژوهش"
        },
        {
          "language": "kmr",
          "text": "rêberê zanînê; rêvebirê lêkolînê"
        },
        {
          "language": "pl",
          "text": "ukierunkowujący poznanie; prowadzący analizę"
        },
        {
          "language": "ro",
          "text": "care ghidează cunoașterea; orientativ pentru analiză"
        },
        {
          "language": "ru",
          "text": "направляющий познание; задающий ход исследования"
        },
        {
          "language": "sq",
          "text": "që udhëheq njohjen; orientues për analizën"
        },
        {
          "language": "tr",
          "text": "bilgiye yön veren; araştırmayı yönlendirici"
        }
      ],
      "examples": [
        {
          "baseText": "Die erkenntnisleitende Frage der Studie lautet, warum Kunden trotz höherer Preise bleiben.",
          "translations": [
            {
              "language": "ar",
              "text": "السؤال الموجّه للدراسة هو لماذا يبقى العملاء رغم ارتفاع الأسعار."
            },
            {
              "language": "ckb",
              "text": "پرسیاری ڕێبەری توێژینەوەکە ئەوەیە بۆچی کڕیاران سەرەڕای نرخە بەرزترەکان دەمێننەوە."
            },
            {
              "language": "en",
              "text": "The guiding question of the study is why customers stay despite higher prices."
            },
            {
              "language": "fa",
              "text": "پرسش راهنمای مطالعه این است که چرا مشتریان با وجود قیمت‌های بالاتر می‌مانند."
            },
            {
              "language": "kmr",
              "text": "Pirsa rêber a lêkolînê ev e ku çima xerîdar tevî bihayên bilindtir dimînin."
            },
            {
              "language": "pl",
              "text": "Pytanie ukierunkowujące badanie brzmi, dlaczego klienci zostają mimo wyższych cen."
            },
            {
              "language": "ro",
              "text": "Întrebarea care ghidează studiul este de ce clienții rămân în ciuda prețurilor mai mari."
            },
            {
              "language": "ru",
              "text": "Ведущий вопрос исследования звучит так: почему клиенты остаются, несмотря на более высокие цены."
            },
            {
              "language": "sq",
              "text": "Pyetja udhëheqëse e studimit është pse klientët qëndrojnë pavarësisht çmimeve më të larta."
            },
            {
              "language": "tr",
              "text": "Çalışmanın yönlendirici sorusu, müşterilerin daha yüksek fiyatlara rağmen neden kaldığıdır."
            }
          ]
        },
        {
          "baseText": "Vor der Datenanalyse sollten die erkenntnisleitenden Annahmen ausdrücklich dokumentiert werden.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل تحليل البيانات ينبغي توثيق الافتراضات الموجّهة للمعرفة صراحة."
            },
            {
              "language": "ckb",
              "text": "پێش شیکردنەوەی داتا، دەبێت گریمانە ڕێبەرەکانی زانین بە ڕوونی تۆمار بکرێن."
            },
            {
              "language": "en",
              "text": "Before data analysis, the assumptions guiding the inquiry should be documented explicitly."
            },
            {
              "language": "fa",
              "text": "پیش از تحلیل داده‌ها، فرض‌های راهنمای شناخت باید صریحاً مستند شوند."
            },
            {
              "language": "kmr",
              "text": "Berî analîza daneyan, divê texmînên rêber ên zanînê bi eşkere bên belgekirin."
            },
            {
              "language": "pl",
              "text": "Przed analizą danych należy wyraźnie udokumentować założenia ukierunkowujące poznanie."
            },
            {
              "language": "ro",
              "text": "Înainte de analiza datelor, ipotezele care ghidează cercetarea ar trebui documentate explicit."
            },
            {
              "language": "ru",
              "text": "Перед анализом данных следует явно задокументировать предпосылки, направляющие исследование."
            },
            {
              "language": "sq",
              "text": "Para analizës së të dhënave, supozimet udhëheqëse të njohjes duhet të dokumentohen qartë."
            },
            {
              "language": "tr",
              "text": "Veri analizinden önce araştırmayı yönlendiren varsayımlar açıkça belgelenmelidir."
            }
          ]
        }
      ]
    },
    {
      "word": "erklärungsbedürftig",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Adjective",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "er-klä-rungs-be-dürf-tig",
      "topics": [
        "business-communication",
        "documents-and-administration",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "business",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; means that something requires explanation or justification"
      ],
      "collocations": [
        {
          "text": "ein erklärungsbedürftiger Sachverhalt",
          "meaning": "a matter requiring explanation"
        },
        {
          "text": "besonders erklärungsbedürftig sein",
          "meaning": "to particularly require explanation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Erklärung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "bedürfen",
          "relationLabel": "verb",
          "note": "to require"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يحتاج إلى شرح؛ يتطلب توضيحًا"
        },
        {
          "language": "ckb",
          "text": "پێویستی بە ڕوونکردنەوە هەیە؛ ڕوونکردنەوە دەخوازێت"
        },
        {
          "language": "en",
          "text": "requiring explanation; in need of clarification"
        },
        {
          "language": "fa",
          "text": "نیازمند توضیح؛ قابل توضیح و توجیه"
        },
        {
          "language": "kmr",
          "text": "hewceyê ravekirinê; pêdivî bi zelalkirinê heye"
        },
        {
          "language": "pl",
          "text": "wymagający wyjaśnienia; wymagający uzasadnienia"
        },
        {
          "language": "ro",
          "text": "care necesită explicații; de clarificat"
        },
        {
          "language": "ru",
          "text": "требующий объяснения; нуждающийся в разъяснении"
        },
        {
          "language": "sq",
          "text": "që kërkon shpjegim; që duhet sqaruar"
        },
        {
          "language": "tr",
          "text": "açıklama gerektiren; izaha muhtaç"
        }
      ],
      "examples": [
        {
          "baseText": "Die stark abweichenden Zahlen im Monatsbericht sind erklärungsbedürftig.",
          "translations": [
            {
              "language": "ar",
              "text": "الأرقام المنحرفة بشدة في التقرير الشهري تحتاج إلى توضيح."
            },
            {
              "language": "ckb",
              "text": "ژمارە زۆر جیاوازەکانی ڕاپۆرتی مانگانە پێویستیان بە ڕوونکردنەوە هەیە."
            },
            {
              "language": "en",
              "text": "The strongly deviating figures in the monthly report require explanation."
            },
            {
              "language": "fa",
              "text": "ارقام بسیار متفاوت در گزارش ماهانه نیازمند توضیح هستند."
            },
            {
              "language": "kmr",
              "text": "Hejmarên pir cuda di raporta mehane de hewceyê ravekirinê ne."
            },
            {
              "language": "pl",
              "text": "Silnie odbiegające liczby w raporcie miesięcznym wymagają wyjaśnienia."
            },
            {
              "language": "ro",
              "text": "Cifrele puternic divergente din raportul lunar necesită explicații."
            },
            {
              "language": "ru",
              "text": "Сильно отклоняющиеся цифры в месячном отчете требуют объяснения."
            },
            {
              "language": "sq",
              "text": "Shifrat shumë të devijuara në raportin mujor kërkojnë shpjegim."
            },
            {
              "language": "tr",
              "text": "Aylık rapordaki ciddi sapma gösteren rakamlar açıklama gerektiriyor."
            }
          ]
        },
        {
          "baseText": "Für neue Nutzer ist dieser Schritt im Bestellprozess besonders erklärungsbedürftig.",
          "translations": [
            {
              "language": "ar",
              "text": "بالنسبة للمستخدمين الجدد، هذه الخطوة في عملية الطلب تحتاج إلى شرح خاص."
            },
            {
              "language": "ckb",
              "text": "بۆ بەکارهێنەرانی نوێ، ئەم هەنگاوە لە پرۆسەی داواکردندا بە تایبەتی پێویستی بە ڕوونکردنەوە هەیە."
            },
            {
              "language": "en",
              "text": "For new users, this step in the ordering process particularly needs explanation."
            },
            {
              "language": "fa",
              "text": "برای کاربران جدید، این مرحله در فرایند سفارش به‌ویژه نیازمند توضیح است."
            },
            {
              "language": "kmr",
              "text": "Ji bo bikarhênerên nû, ev gav di pêvajoya fermankirinê de bi taybetî hewceyê ravekirinê ye."
            },
            {
              "language": "pl",
              "text": "Dla nowych użytkowników ten krok w procesie zamówienia szczególnie wymaga wyjaśnienia."
            },
            {
              "language": "ro",
              "text": "Pentru utilizatorii noi, acest pas din procesul de comandă necesită explicații speciale."
            },
            {
              "language": "ru",
              "text": "Для новых пользователей этот шаг в процессе заказа особенно нуждается в пояснении."
            },
            {
              "language": "sq",
              "text": "Për përdoruesit e rinj, ky hap në procesin e porosisë kërkon veçanërisht shpjegim."
            },
            {
              "language": "tr",
              "text": "Yeni kullanıcılar için sipariş sürecindeki bu adım özellikle açıklama gerektirir."
            }
          ]
        }
      ]
    },
