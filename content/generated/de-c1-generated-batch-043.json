      "examples": [
        {
          "baseText": "Das Modell hat eine hohe Erklärungskraft für wiederkehrende Kündigungen im ersten Vertragsjahr.",
          "translations": [
            {
              "language": "ar",
              "text": "يمتلك النموذج قوة تفسيرية عالية لحالات الإلغاء المتكررة في السنة الأولى من العقد."
            },
            {
              "language": "ckb",
              "text": "مۆدێلەکە هێزی ڕوونکردنەوەیەکی بەرزی هەیە بۆ هەڵوەشاندنەوە دووبارەبووەکان لە ساڵی یەکەمی گرێبەستدا."
            },
            {
              "language": "en",
              "text": "The model has strong explanatory power for recurring cancellations in the first contract year."
            },
            {
              "language": "fa",
              "text": "این مدل برای لغوهای تکرارشونده در سال اول قرارداد قدرت تبیینی بالایی دارد."
            },
            {
              "language": "kmr",
              "text": "Model ji bo betalkirinên dubare di sala yekem a peymanê de hêza ravekirineke bilind heye."
            },
            {
              "language": "pl",
              "text": "Model ma dużą siłę wyjaśniającą dla powtarzających się rezygnacji w pierwszym roku umowy."
            },
            {
              "language": "ro",
              "text": "Modelul are o putere explicativă ridicată pentru anulările recurente din primul an contractual."
            },
            {
              "language": "ru",
              "text": "Модель обладает высокой объяснительной силой для повторяющихся отказов в первый год договора."
            },
            {
              "language": "sq",
              "text": "Modeli ka fuqi të lartë shpjeguese për anulimet e përsëritura në vitin e parë të kontratës."
            },
            {
              "language": "tr",
              "text": "Model, sözleşmenin ilk yılındaki tekrarlayan iptaller için yüksek açıklama gücüne sahiptir."
            }
          ]
        },
        {
          "baseText": "Eine Korrelation allein hat noch keine ausreichende Erklärungskraft für die beobachtete Entwicklung.",
          "translations": [
            {
              "language": "ar",
              "text": "الارتباط وحده لا يملك بعد قوة تفسيرية كافية للتطور المرصود."
            },
            {
              "language": "ckb",
              "text": "پەیوەندیی ئاماری بە تەنها هێزی ڕوونکردنەوەی پێویستی بۆ گەشەی بینراو نییە."
            },
            {
              "language": "en",
              "text": "A correlation alone does not yet have sufficient explanatory power for the observed development."
            },
            {
              "language": "fa",
              "text": "همبستگی به‌تنهایی هنوز قدرت تبیینی کافی برای روند مشاهده‌شده ندارد."
            },
            {
              "language": "kmr",
              "text": "Têkiliyek bi tenê hêza ravekirina têr ji bo pêşketina dîtî nîne."
            },
            {
              "language": "pl",
              "text": "Sama korelacja nie ma jeszcze wystarczającej siły wyjaśniającej dla obserwowanego rozwoju."
            },
            {
              "language": "ro",
              "text": "O corelație singură nu are încă putere explicativă suficientă pentru evoluția observată."
            },
            {
              "language": "ru",
              "text": "Одна лишь корреляция еще не обладает достаточной объяснительной силой для наблюдаемого развития."
            },
            {
              "language": "sq",
              "text": "Vetëm një korrelacion nuk ka ende fuqi të mjaftueshme shpjeguese për zhvillimin e vërejtur."
            },
            {
              "language": "tr",
              "text": "Tek başına bir korelasyon gözlenen gelişme için henüz yeterli açıklama gücüne sahip değildir."
            }
          ]
        }
      ]
