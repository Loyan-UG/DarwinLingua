      "examples": [
        {
          "baseText": "Ich frühstücke um sieben Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "أتناول الفطور الساعة السابعة."
            },
            {
              "language": "ckb",
              "text": "من کاتژمێر حەوت نانی بەیانی دەخۆم."
            },
            {
              "language": "en",
              "text": "I have breakfast at seven o’clock."
            },
            {
              "language": "fa",
              "text": "من ساعت هفت صبحانه می‌خورم."
            },
            {
              "language": "kmr",
              "text": "Ez saet heftê taştê dikim."
            },
            {
              "language": "pl",
              "text": "Jem śniadanie o siódmej."
            },
            {
              "language": "ro",
              "text": "Iau micul dejun la ora șapte."
            },
            {
              "language": "ru",
              "text": "Я завтракаю в семь часов."
            },
            {
              "language": "sq",
              "text": "Ha mëngjes në orën shtatë."
            },
            {
              "language": "tr",
              "text": "Saat yedide kahvaltı yapıyorum."
            }
          ]
        },
        {
          "baseText": "Wir frühstücken im Café.",
          "translations": [
            {
              "language": "ar",
              "text": "نتناول الفطور في المقهى."
            },
            {
              "language": "ckb",
              "text": "ئێمە لە کافێ نانی بەیانی دەخۆین."
            },
            {
              "language": "en",
              "text": "We have breakfast in the café."
            },
            {
              "language": "fa",
              "text": "ما در کافه صبحانه می‌خوریم."
            },
            {
              "language": "kmr",
              "text": "Em li kafeyê taştê dikin."
            },
            {
              "language": "pl",
              "text": "Jemy śniadanie w kawiarni."
            },
            {
              "language": "ro",
              "text": "Luăm micul dejun la cafenea."
            },
            {
              "language": "ru",
              "text": "Мы завтракаем в кафе."
            },
            {
              "language": "sq",
              "text": "Hamë mëngjes në kafene."
            },
            {
              "language": "tr",
              "text": "Kafede kahvaltı yapıyoruz."
            }
          ]
