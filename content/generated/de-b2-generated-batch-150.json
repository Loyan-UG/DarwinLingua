      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يفسر؛ يدل على"
        },
        {
          "language": "ckb",
          "text": "لێکدەداتەوە؛ ئاماژە دەکات بە"
        },
        {
          "language": "en",
          "text": "to interpret; to indicate"
        },
        {
          "language": "fa",
          "text": "تفسیر کردن؛ دلالت داشتن بر"
        },
        {
          "language": "kmr",
          "text": "şîrove kirin; nîşan dan"
        },
        {
          "language": "pl",
          "text": "interpretować; wskazywać na"
        },
        {
          "language": "ro",
          "text": "a interpreta; a indica"
        },
        {
          "language": "ru",
          "text": "толковать; указывать на"
        },
        {
          "language": "sq",
          "text": "të interpretosh; të tregosh"
        },
        {
          "language": "tr",
          "text": "yorumlamak; işaret etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Die sinkenden Anmeldezahlen deuten darauf hin, dass wir die Kampagne überarbeiten müssen.",
          "translations": [
            {
              "language": "ar",
              "text": "تشير أعداد التسجيل المتراجعة إلى أننا يجب أن نراجع الحملة."
            },
            {
              "language": "ckb",
              "text": "ژمارەی کەمبووی ناونووسین ئاماژە دەکات بەوەی دەبێت کەمپەینەکە پێداچوونەوە بکەین."
            },
            {
              "language": "en",
              "text": "The falling registration numbers indicate that we need to revise the campaign."
            },
            {
              "language": "fa",
              "text": "کاهش تعداد ثبت‌نام‌ها نشان می‌دهد که باید کمپین را بازنگری کنیم."
            },
            {
              "language": "kmr",
              "text": "Hejmarên qeydkirinê yên kêm dibin nîşan didin ku divê em kampanyayê ji nû ve binirxînin."
            },
            {
              "language": "pl",
              "text": "Spadająca liczba rejestracji wskazuje, że musimy przerobić kampanię."
            },
            {
              "language": "ro",
              "text": "Numărul în scădere al înscrierilor indică faptul că trebuie să revizuim campania."
            },
            {
              "language": "ru",
              "text": "Снижающееся число регистраций указывает на то, что нам нужно переработать кампанию."
            },
            {
              "language": "sq",
              "text": "Numri në rënie i regjistrimeve tregon se duhet ta rishikojmë fushatën."
            },
            {
              "language": "tr",
              "text": "Düşen kayıt sayıları kampanyayı yeniden gözden geçirmemiz gerektiğine işaret ediyor."
            }
          ]
        },
        {
          "baseText": "Man sollte die Aussage des Kunden nicht sofort negativ deuten; vielleicht war die Formulierung nur unklar.",
          "translations": [
            {
              "language": "ar",
              "text": "لا ينبغي تفسير كلام العميل فورًا بشكل سلبي؛ ربما كانت الصياغة فقط غير واضحة."
            },
            {
              "language": "ckb",
              "text": "نابێت وتەی کڕیارەکە دەستبەجێ بە شێوەی نەرێنی لێکبدرێتەوە؛ لەوانەیە تەنها دەربڕینەکە ناڕوون بووبێت."
            },
            {
              "language": "en",
              "text": "You should not immediately interpret the customer’s statement negatively; perhaps the wording was simply unclear."
            },
            {
              "language": "fa",
              "text": "نباید حرف مشتری را فوراً منفی تفسیر کرد؛ شاید فقط بیانش نامشخص بوده است."
            },
            {
              "language": "kmr",
              "text": "Divê mirov gotina xerîdarê tavilê neyînî şîrove neke; dibe ku tenê awayê gotinê nezelal bûbe."
            },
            {
              "language": "pl",
              "text": "Nie należy od razu interpretować wypowiedzi klienta negatywnie; być może sformułowanie było po prostu niejasne."
            },
            {
              "language": "ro",
              "text": "Nu ar trebui să interpretezi imediat negativ afirmația clientului; poate formularea a fost doar neclară."
            },
            {
              "language": "ru",
              "text": "Не стоит сразу толковать высказывание клиента негативно; возможно, формулировка была просто неясной."
            },
            {
              "language": "sq",
              "text": "Nuk duhet ta interpretosh menjëherë negativisht deklaratën e klientit; ndoshta formulimi ishte thjesht i paqartë."
            },
            {
              "language": "tr",
              "text": "Müşterinin ifadesini hemen olumsuz yorumlamamak gerekir; belki sadece ifade biçimi belirsizdi."
            }
          ]
        }
      ]
    }
