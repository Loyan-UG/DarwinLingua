  "entries": [
    {
      "word": "verraten",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "verraten",
      "pronunciationIpa": null,
      "syllableBreak": "ver-ra-ten",
      "topics": [
        "business-communication",
        "law-and-compliance",
        "social-and-relationships"
      ],
      "usageLabels": [
        "spoken",
        "business"
      ],
      "contextLabels": [
        "compliance",
        "management",
        "customer-service"
      ],
      "grammarNotes": [
        "irregular verb: verrät, verriet, hat verraten; means to reveal, disclose, or betray"
      ],
      "collocations": [
        {
          "text": "ein Geheimnis verraten",
          "meaning": "to reveal a secret"
        },
        {
          "text": "vertrauliche Informationen verraten",
          "meaning": "to disclose confidential information"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Verrat",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "verräterisch",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يكشف؛ يخون"
        },
        {
          "language": "ckb",
          "text": "ئاشکرا دەکات؛ خیانەت دەکات"
        },
        {
          "language": "en",
          "text": "to reveal; to disclose; to betray"
        },
        {
          "language": "fa",
          "text": "فاش کردن؛ خیانت کردن"
        },
        {
          "language": "kmr",
          "text": "eşkere kirin; xiyanet kirin"
        },
        {
          "language": "pl",
          "text": "zdradzić; ujawnić"
        },
        {
          "language": "ro",
          "text": "a dezvălui; a trăda"
        },
        {
          "language": "ru",
          "text": "выдать; раскрыть; предать"
        },
        {
          "language": "sq",
          "text": "të zbulosh; të tradhtosh"
        },
        {
          "language": "tr",
          "text": "açıklamak; ihanet etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte verraten Sie keine Kundendaten am Telefon, wenn die Identität nicht geprüft wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى عدم كشف بيانات العملاء عبر الهاتف إذا لم يتم التحقق من الهوية."
            },
            {
              "language": "ckb",
              "text": "تکایە داتای کڕیاران لە تەلەفۆندا ئاشکرا مەکەن ئەگەر ناسنامە پشتڕاست نەکراوەتەوە."
            },
            {
              "language": "en",
              "text": "Please do not disclose customer data by phone if the identity has not been verified."
            },
            {
              "language": "fa",
              "text": "لطفاً اگر هویت بررسی نشده است، داده‌های مشتری را تلفنی فاش نکنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe ger nasname nehatiye piştrastkirin, daneyên xerîdar bi telefonê eşkere nekin."
            },
            {
              "language": "pl",
              "text": "Proszę nie ujawniać danych klientów przez telefon, jeśli tożsamość nie została sprawdzona."
            },
            {
              "language": "ro",
              "text": "Vă rog să nu dezvăluiți datele clienților la telefon dacă identitatea nu a fost verificată."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не раскрывайте данные клиентов по телефону, если личность не проверена."
            },
            {
              "language": "sq",
              "text": "Ju lutem mos zbuloni të dhënat e klientëve në telefon nëse identiteti nuk është verifikuar."
            },
            {
              "language": "tr",
              "text": "Kimlik doğrulanmadıysa lütfen müşteri verilerini telefonda açıklamayın."
            }
          ]
        },
        {
          "baseText": "Seine Reaktion verriet, dass er mit der Entscheidung nicht einverstanden war.",
          "translations": [
            {
              "language": "ar",
              "text": "كشف رد فعله أنه لم يكن موافقًا على القرار."
            },
            {
              "language": "ckb",
              "text": "وەڵامدانەوەکەی ئاشکرا کرد کە لەگەڵ بڕیارەکەدا ڕازی نەبوو."
            },
            {
              "language": "en",
              "text": "His reaction revealed that he did not agree with the decision."
            },
            {
              "language": "fa",
              "text": "واکنش او نشان داد که با تصمیم موافق نبوده است."
            },
            {
              "language": "kmr",
              "text": "Bersiva wî eşkere kir ku ew bi biryarê razî nebû."
            },
            {
              "language": "pl",
              "text": "Jego reakcja zdradziła, że nie zgadzał się z decyzją."
            },
            {
              "language": "ro",
              "text": "Reacția lui a arătat că nu era de acord cu decizia."
            },
            {
              "language": "ru",
              "text": "Его реакция показала, что он не согласен с решением."
            },
            {
              "language": "sq",
              "text": "Reagimi i tij zbuloi se ai nuk ishte dakord me vendimin."
            },
            {
              "language": "tr",
              "text": "Tepkisi kararla aynı fikirde olmadığını ele verdi."
            }
          ]
        }
      ]
    },
