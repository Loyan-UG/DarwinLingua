  "entries": [
    {
      "word": "entlassen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "entlassen",
      "pronunciationIpa": null,
      "syllableBreak": "ent-las-sen",
      "topics": [
        "human-resources",
        "healthcare-and-appointments",
        "work-and-jobs"
      ],
      "usageLabels": [
        "formal",
        "written",
        "spoken"
      ],
      "contextLabels": [
        "hr",
        "healthcare",
        "administration"
      ],
      "grammarNotes": [
        "strong verb: entlässt, entließ, hat entlassen; means to dismiss or discharge"
      ],
      "collocations": [
        {
          "text": "aus dem Krankenhaus entlassen werden",
          "meaning": "to be discharged from hospital"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Entlassung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفصل من العمل؛ يخرج من المستشفى"
        },
        {
          "language": "ckb",
          "text": "دەرکردن؛ ڕەوانەکردنەوە لە نەخۆشخانە"
        },
        {
          "language": "en",
          "text": "to dismiss; to discharge"
        },
        {
          "language": "fa",
          "text": "اخراج کردن؛ مرخص کردن از بیمارستان"
        },
        {
          "language": "kmr",
          "text": "ji kar derxistin; ji nexweşxaneyê derxistin"
        },
        {
          "language": "pl",
          "text": "zwolnić; wypisać ze szpitala"
        },
        {
          "language": "ro",
          "text": "a concedia; a externa"
        },
        {
          "language": "ru",
          "text": "увольнять; выписывать из больницы"
        },
        {
          "language": "sq",
          "text": "të pushosh nga puna; të nxjerrësh nga spitali"
        },
        {
          "language": "tr",
          "text": "işten çıkarmak; taburcu etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Patient wurde gestern aus dem Krankenhaus entlassen.",
          "translations": [
            {
              "language": "ar",
              "text": "تم إخراج المريض من المستشفى أمس."
            },
            {
              "language": "ckb",
              "text": "نەخۆشەکە دوێنێ لە نەخۆشخانە ڕەوانەکرایەوە."
            },
            {
              "language": "en",
              "text": "The patient was discharged from the hospital yesterday."
            },
            {
              "language": "fa",
              "text": "بیمار دیروز از بیمارستان مرخص شد."
            },
            {
              "language": "kmr",
              "text": "Nexweş duh ji nexweşxaneyê hate derxistin."
            },
            {
              "language": "pl",
              "text": "Pacjent został wczoraj wypisany ze szpitala."
            },
            {
              "language": "ro",
              "text": "Pacientul a fost externat ieri din spital."
            },
            {
              "language": "ru",
              "text": "Пациента вчера выписали из больницы."
            },
            {
              "language": "sq",
              "text": "Pacienti u lirua dje nga spitali."
            },
            {
              "language": "tr",
              "text": "Hasta dün hastaneden taburcu edildi."
            }
          ]
        },
        {
          "baseText": "Die Firma will niemanden entlassen, sondern die Arbeitszeiten reduzieren.",
          "translations": [
            {
              "language": "ar",
              "text": "لا تريد الشركة فصل أي شخص، بل تقليل ساعات العمل."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە نایەوێت هیچ کەسێک دەربکات، بەڵکو کاتەکانی کار کەم دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The company does not want to dismiss anyone, but to reduce working hours."
            },
            {
              "language": "fa",
              "text": "شرکت نمی‌خواهد کسی را اخراج کند، بلکه می‌خواهد ساعت کاری را کاهش دهد."
            },
            {
              "language": "kmr",
              "text": "Şirket naxwaze tu kesî ji kar derxe, lê demên karê kêm bike."
            },
            {
              "language": "pl",
              "text": "Firma nie chce nikogo zwalniać, lecz zmniejszyć czas pracy."
            },
            {
              "language": "ro",
              "text": "Firma nu vrea să concedieze pe nimeni, ci să reducă programul de lucru."
            },
            {
              "language": "ru",
              "text": "Компания не хочет никого увольнять, а хочет сократить рабочее время."
            },
            {
              "language": "sq",
              "text": "Kompania nuk do të pushojë askënd, por të ulë orarin e punës."
            },
            {
              "language": "tr",
              "text": "Şirket kimseyi işten çıkarmak istemiyor, çalışma saatlerini azaltmak istiyor."
            }
          ]
        }
      ]
    },
    {
      "word": "die Entscheidungsfrist",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Entscheidungsfristen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ent-schei-dungs-frist",
      "topics": [
        "documents-and-administration",
        "contracts-and-negotiation",
