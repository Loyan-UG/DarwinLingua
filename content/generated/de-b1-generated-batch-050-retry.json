      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Entscheidungsfrist verlängern",
          "meaning": "to extend a decision deadline"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Entscheidung",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Frist",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مهلة اتخاذ القرار"
        },
        {
          "language": "ckb",
          "text": "ماوەی بڕیاردان"
        },
        {
          "language": "en",
          "text": "decision deadline; decision period"
        },
        {
          "language": "fa",
          "text": "مهلت تصمیم‌گیری"
        },
        {
          "language": "kmr",
          "text": "demê biryardanê"
        },
        {
          "language": "pl",
          "text": "termin na decyzję"
        },
        {
          "language": "ro",
          "text": "termen de decizie"
        },
        {
          "language": "ru",
          "text": "срок принятия решения"
        },
        {
          "language": "sq",
          "text": "afati i vendimit"
        },
        {
          "language": "tr",
          "text": "karar süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Entscheidungsfrist für das Angebot endet am Montag.",
          "translations": [
            {
              "language": "ar",
              "text": "تنتهي مهلة اتخاذ القرار بشأن العرض يوم الاثنين."
            },
            {
              "language": "ckb",
              "text": "ماوەی بڕیاردان بۆ پێشنیارەکە ڕۆژی دووشەممە کۆتایی دێت."
            },
            {
              "language": "en",
              "text": "The decision deadline for the offer ends on Monday."
            },
            {
              "language": "fa",
              "text": "مهلت تصمیم‌گیری برای پیشنهاد روز دوشنبه تمام می‌شود."
            },
            {
              "language": "kmr",
              "text": "Demê biryardanê ji bo pêşniyarê roja duşemê diqede."
            },
            {
              "language": "pl",
              "text": "Termin decyzji dotyczącej oferty kończy się w poniedziałek."
            },
            {
              "language": "ro",
              "text": "Termenul de decizie pentru ofertă se încheie luni."
            },
            {
              "language": "ru",
              "text": "Срок принятия решения по предложению истекает в понедельник."
            },
            {
              "language": "sq",
              "text": "Afati për vendimin mbi ofertën përfundon të hënën."
            },
            {
              "language": "tr",
              "text": "Teklif için karar süresi pazartesi günü bitiyor."
            }
          ]
        },
        {
          "baseText": "Wir bitten um eine kurze Verlängerung der Entscheidungsfrist.",
          "translations": [
            {
              "language": "ar",
              "text": "نطلب تمديدًا قصيرًا لمهلة اتخاذ القرار."
            },
            {
              "language": "ckb",
              "text": "داوای درێژکردنەوەیەکی کورتی ماوەی بڕیاردان دەکەین."
            },
            {
              "language": "en",
              "text": "We ask for a short extension of the decision deadline."
            },
            {
              "language": "fa",
              "text": "درخواست تمدید کوتاه مهلت تصمیم‌گیری را داریم."
            },
            {
              "language": "kmr",
              "text": "Em daxwaza dirêjkirineke kurt a demê biryardanê dikin."
            },
            {
              "language": "pl",
              "text": "Prosimy o krótkie przedłużenie terminu decyzji."
            },
            {
              "language": "ro",
              "text": "Solicităm o scurtă prelungire a termenului de decizie."
            },
            {
              "language": "ru",
              "text": "Мы просим кратко продлить срок принятия решения."
            },
            {
              "language": "sq",
              "text": "Kërkojmë një zgjatje të shkurtër të afatit të vendimit."
            },
            {
              "language": "tr",
              "text": "Karar süresinin kısa süreli uzatılmasını rica ediyoruz."
            }
          ]
        }
      ]
    }
  ],
