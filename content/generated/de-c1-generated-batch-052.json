        },
        {
          "language": "ru",
          "text": "сфера действия; пределы применимости"
        },
        {
          "language": "sq",
          "text": "shtrirje vlefshmërie; fushë zbatimi"
        },
        {
          "language": "tr",
          "text": "geçerlilik kapsamı; uygulanma alanı"
        }
      ],
      "examples": [
        {
          "baseText": "Die Geltungsreichweite der Richtlinie ist auf europäische Niederlassungen beschränkt.",
          "translations": [
            {
              "language": "ar",
              "text": "يقتصر نطاق سريان التوجيه على الفروع الأوروبية."
            },
