      "meanings": [
        {
          "language": "ar",
          "text": "نطاق السريان؛ مدى الصلاحية"
        },
        {
          "language": "ckb",
          "text": "مەودای ڕەوایی؛ سنووری کاریگەری یاسا"
        },
        {
          "language": "en",
          "text": "scope of validity; range of applicability"
        },
        {
          "language": "fa",
          "text": "دامنه اعتبار؛ گستره شمول"
        },
        {
          "language": "kmr",
          "text": "qada derbasdariyê; asta bikaranînê"
        },
        {
          "language": "pl",
