  "entries": [
    {
      "word": "die Geldpolitik",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Geldpolitiken",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Geld-po-li-tik",
      "topics": [
        "finance-and-accounting",
        "public-services",
        "advanced-analysis"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; plural can refer to different monetary policy approaches"
      ],
      "collocations": [
        {
          "text": "restriktive Geldpolitik",
          "meaning": "restrictive monetary policy"
        },
        {
          "text": "expansive Geldpolitik",
          "meaning": "expansionary monetary policy"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "geldpolitisch",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "das Geld",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "السياسة النقدية"
        },
        {
          "language": "ckb",
          "text": "سیاسەتی پارەیی"
        },
        {
          "language": "en",
          "text": "monetary policy"
        },
        {
          "language": "fa",
          "text": "سیاست پولی"
        },
        {
          "language": "kmr",
          "text": "siyaseta pereyî"
        },
        {
          "language": "pl",
          "text": "polityka pieniężna"
        },
        {
          "language": "ro",
          "text": "politică monetară"
        },
        {
          "language": "ru",
          "text": "денежно-кредитная политика"
        },
        {
          "language": "sq",
          "text": "politikë monetare"
        },
        {
          "language": "tr",
          "text": "para politikası"
        }
      ],
      "examples": [
        {
          "baseText": "Die Zentralbank hält an einer restriktiven Geldpolitik fest, um die Inflation zu senken.",
          "translations": [
            {
              "language": "ar",
              "text": "يتمسك البنك المركزي بسياسة نقدية تقييدية لخفض التضخم."
            },
            {
              "language": "ckb",
              "text": "بانکی ناوەندی بە سیاسەتی پارەیی سنووردارەوە پابەندە بۆ کەمکردنەوەی هەڵئاوسان."
            },
            {
              "language": "en",
              "text": "The central bank is maintaining a restrictive monetary policy to reduce inflation."
            },
            {
              "language": "fa",
              "text": "بانک مرکزی برای کاهش تورم به سیاست پولی انقباضی پایبند است."
            },
            {
              "language": "kmr",
              "text": "Banka navendî ji bo kêmkirina enflasyonê li siyaseta pereyî ya tengkirî dimîne."
            },
            {
              "language": "pl",
              "text": "Bank centralny utrzymuje restrykcyjną politykę pieniężną, aby obniżyć inflację."
            },
            {
              "language": "ro",
              "text": "Banca centrală menține o politică monetară restrictivă pentru a reduce inflația."
            },
            {
              "language": "ru",
              "text": "Центральный банк придерживается жесткой денежно-кредитной политики, чтобы снизить инфляцию."
            },
            {
              "language": "sq",
              "text": "Banka qendrore i përmbahet një politike monetare kufizuese për të ulur inflacionin."
            },
            {
              "language": "tr",
              "text": "Merkez bankası enflasyonu düşürmek için sıkı para politikasını sürdürüyor."
            }
          ]
        },
        {
          "baseText": "Die Wirkung der Geldpolitik erreicht kleine Unternehmen oft erst mit Verzögerung.",
          "translations": [
            {
              "language": "ar",
              "text": "يصل أثر السياسة النقدية إلى الشركات الصغيرة غالبًا بتأخير."
            },
            {
              "language": "ckb",
              "text": "کاریگەری سیاسەتی پارەیی زۆرجار بە دواخستنێک دەگاتە کۆمپانیا بچووکەکان."
            },
            {
              "language": "en",
              "text": "The effect of monetary policy often reaches small companies only with a delay."
            },
            {
              "language": "fa",
              "text": "اثر سیاست پولی معمولاً با تأخیر به شرکت‌های کوچک می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Bandora siyaseta pereyî gelek caran bi derengî digihîje şîrketên biçûk."
            },
            {
              "language": "pl",
              "text": "Wpływ polityki pieniężnej często dociera do małych firm z opóźnieniem."
            },
            {
              "language": "ro",
              "text": "Efectul politicii monetare ajunge adesea la firmele mici cu întârziere."
            },
            {
              "language": "ru",
              "text": "Эффект денежно-кредитной политики часто доходит до малых компаний с задержкой."
            },
            {
              "language": "sq",
              "text": "Efekti i politikës monetare shpesh arrin te bizneset e vogla me vonesë."
            },
            {
              "language": "tr",
              "text": "Para politikasının etkisi küçük şirketlere çoğu zaman gecikmeli ulaşır."
            }
          ]
        }
      ]
    },
    {
      "word": "der Geltungsanspruch",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Geltungsansprüche",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Gel-tungs-an-spruch",
      "topics": [
        "advanced-analysis",
        "law-and-compliance",
        "business-communication"
      ],
      "usageLabels": [
        "academic",
        "formal",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine compound noun; plural: die Geltungsansprüche"
      ],
      "collocations": [
        {
          "text": "einen Geltungsanspruch erheben",
          "meaning": "to claim validity"
        },
        {
          "text": "universaler Geltungsanspruch",
          "meaning": "universal claim to validity"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "gelten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "der Anspruch",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ادعاء الصلاحية؛ Anspruch بالاعتراف"
        },
        {
          "language": "ckb",
          "text": "داوای گشتگیری یان دروستی؛ بانگەشەی ڕەوایی"
        },
        {
          "language": "en",
          "text": "claim to validity; claim to recognition"
        },
        {
          "language": "fa",
          "text": "ادعای اعتبار؛ دعوی شمول یا مشروعیت"
        },
        {
          "language": "kmr",
          "text": "daxwaza derbasdariyê; îdîaya rewayetiyê"
        },
        {
          "language": "pl",
          "text": "roszczenie do ważności; pretensja do obowiązywania"
        },
        {
          "language": "ro",
          "text": "pretenție de validitate; revendicare de valabilitate"
        },
        {
          "language": "ru",
          "text": "претензия на значимость; притязание на действительность"
        },
        {
          "language": "sq",
          "text": "pretendim vlefshmërie; pretendim për njohje"
        },
        {
          "language": "tr",
          "text": "geçerlilik iddiası; tanınma iddiası"
        }
      ],
      "examples": [
        {
          "baseText": "Der Bericht erhebt keinen universalen Geltungsanspruch, sondern beschreibt einen spezifischen Markt.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يدعي التقرير صلاحية عالمية، بل يصف سوقًا محددة."
            },
            {
              "language": "ckb",
              "text": "ڕاپۆرتەکە بانگەشەی گشتگیریی جیهانی ناکات، بەڵکو بازاڕێکی دیاریکراو باس دەکات."
            },
            {
              "language": "en",
              "text": "The report does not claim universal validity but describes a specific market."
            },
            {
              "language": "fa",
              "text": "گزارش ادعای اعتبار جهانی ندارد، بلکه یک بازار مشخص را توصیف می‌کند."
            },
            {
              "language": "kmr",
              "text": "Rapor daxwaza derbasdariya gerdûnî nake, lê bazareke taybet rave dike."
            },
            {
              "language": "pl",
              "text": "Raport nie rości sobie uniwersalnej ważności, lecz opisuje konkretny rynek."
            },
            {
              "language": "ro",
              "text": "Raportul nu revendică validitate universală, ci descrie o piață specifică."
            },
            {
              "language": "ru",
              "text": "Отчет не претендует на универсальную значимость, а описывает конкретный рынок."
            },
            {
              "language": "sq",
              "text": "Raporti nuk pretendon vlefshmëri universale, por përshkruan një treg specifik."
            },
            {
              "language": "tr",
              "text": "Rapor evrensel geçerlilik iddiasında bulunmaz, belirli bir pazarı tanımlar."
            }
          ]
        },
        {
          "baseText": "Der Geltungsanspruch der neuen Regel muss im Verhältnis zu bestehenden Verträgen geprüft werden.",
          "translations": [
            {
              "language": "ar",
              "text": "يجب فحص ادعاء صلاحية القاعدة الجديدة بالنسبة إلى العقود القائمة."
            },
            {
              "language": "ckb",
              "text": "داوای ڕەوایی یاسای نوێ دەبێت بە پەیوەندی لەگەڵ گرێبەستە هەبووەکان پشکنرێت."
            },
            {
              "language": "en",
              "text": "The validity claim of the new rule must be examined in relation to existing contracts."
            },
            {
              "language": "fa",
              "text": "ادعای اعتبار قاعده جدید باید در نسبت با قراردادهای موجود بررسی شود."
            },
            {
              "language": "kmr",
              "text": "Daxwaza derbasdariya rêgeza nû divê li gor peymanên heyî were kontrolkirin."
            },
            {
              "language": "pl",
              "text": "Roszczenie ważności nowej zasady trzeba sprawdzić w odniesieniu do istniejących umów."
            },
            {
              "language": "ro",
              "text": "Pretenția de validitate a noii reguli trebuie verificată în raport cu contractele existente."
            },
            {
              "language": "ru",
              "text": "Претензия нового правила на действительность должна быть проверена в отношении существующих договоров."
            },
            {
              "language": "sq",
              "text": "Pretendimi i vlefshmërisë së rregullit të ri duhet shqyrtuar në raport me kontratat ekzistuese."
            },
            {
              "language": "tr",
              "text": "Yeni kuralın geçerlilik iddiası mevcut sözleşmelerle ilişkili olarak incelenmelidir."
            }
          ]
        }
      ]
    },
