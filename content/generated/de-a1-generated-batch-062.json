        {
          "language": "sq",
          "text": "mësuese"
        },
        {
          "language": "tr",
          "text": "kadın öğretmen"
        }
      ],
      "examples": [
        {
          "baseText": "Die Lehrerin erklärt die Aufgabe.",
          "translations": [
            {
              "language": "ar",
              "text": "المعلّمة تشرح الواجب."
            },
            {
              "language": "ckb",
              "text": "مامۆستا ژنەکە ئەرکەکە ڕوون دەکاتەوە."
            },
            {
              "language": "en",
              "text": "The teacher explains the task."
            },
            {
              "language": "fa",
              "text": "معلم تمرین را توضیح می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Mamoste erkê rave dike."
            },
            {
              "language": "pl",
              "text": "Nauczycielka wyjaśnia zadanie."
            },
            {
              "language": "ro",
              "text": "Profesoara explică sarcina."
            },
            {
              "language": "ru",
              "text": "Учительница объясняет задание."
            },
            {
              "language": "sq",
              "text": "Mësuesja shpjegon detyrën."
            },
            {
              "language": "tr",
              "text": "Öğretmen görevi açıklıyor."
            }
          ]
        },
        {
          "baseText": "Ich frage die Lehrerin.",
          "translations": [
            {
              "language": "ar",
              "text": "أسأل المعلّمة."
            },
            {
              "language": "ckb",
              "text": "من پرسیار لە مامۆستا ژنەکە دەکەم."
            },
            {
              "language": "en",
              "text": "I ask the teacher."
            },
            {
              "language": "fa",
              "text": "من از معلم می‌پرسم."
            },
            {
              "language": "kmr",
              "text": "Ez ji mamosteyê dipirsim."
            },
            {
              "language": "pl",
              "text": "Pytam nauczycielkę."
            },
            {
              "language": "ro",
              "text": "O întreb pe profesoară."
            },
            {
              "language": "ru",
              "text": "Я спрашиваю учительницу."
            },
            {
              "language": "sq",
              "text": "Pyes mësuesen."
            },
            {
              "language": "tr",
              "text": "Öğretmene soruyorum."
            }
          ]
        }
