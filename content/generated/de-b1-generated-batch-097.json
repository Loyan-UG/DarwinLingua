  "entries": [
    {
      "word": "nachsehen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "nachsehen",
      "pronunciationIpa": null,
      "syllableBreak": "nach-se-hen",
      "topics": [
        "customer-service",
        "business-communication",
        "everyday-life"
      ],
      "usageLabels": [
        "everyday",
        "customer-facing",
        "polite",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: sieht nach, sah nach, nachgesehen"
      ],
      "collocations": [
        {
          "text": "im System nachsehen",
          "meaning": "to check in the system"
        },
        {
          "text": "kurz nachsehen",
          "meaning": "to check quickly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sehen",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "das Nachsehen",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتحقق؛ ينظر للتأكد"
        },
        {
          "language": "ckb",
          "text": "دەبینێت؛ پشکنین دەکات"
        },
        {
          "language": "en",
          "text": "to check; to look and verify"
        },
        {
          "language": "fa",
          "text": "بررسی کردن؛ نگاه کردن برای اطمینان"
        },
        {
          "language": "kmr",
          "text": "kontrol kirin; lê nihêrîn"
        },
        {
          "language": "pl",
          "text": "sprawdzić; zajrzeć"
        },
        {
          "language": "ro",
          "text": "a verifica; a se uita"
        },
        {
          "language": "ru",
          "text": "проверить; посмотреть"
        },
        {
          "language": "sq",
          "text": "të kontrollosh; të shikosh"
        },
        {
          "language": "tr",
          "text": "kontrol etmek; bakmak"
        }
      ],
      "examples": [
        {
          "baseText": "Ich sehe kurz im System nach, ob Ihre Bestellung schon versendet wurde.",
          "translations": [
            {
              "language": "ar",
              "text": "سأتحقق بسرعة في النظام مما إذا كان طلبكم قد أُرسل بالفعل."
            },
            {
              "language": "ckb",
              "text": "بە خێرایی لە سیستەمەکە دەبینم ئایا داواکارییەکەتان نێردراوە یان نا."
            },
            {
              "language": "en",
              "text": "I will quickly check in the system whether your order has already been shipped."
            },
            {
              "language": "fa",
              "text": "سریع در سیستم بررسی می‌کنم که آیا سفارش شما ارسال شده است یا نه."
            },
            {
              "language": "kmr",
              "text": "Ez ê bi lez di pergalê de kontrol bikim ka siparişa we hatiye şandin an na."
            },
            {
              "language": "pl",
              "text": "Szybko sprawdzę w systemie, czy państwa zamówienie zostało już wysłane."
            },
            {
              "language": "ro",
              "text": "Verific rapid în sistem dacă comanda dumneavoastră a fost deja trimisă."
            },
            {
              "language": "ru",
              "text": "Я быстро проверю в системе, был ли ваш заказ уже отправлен."
            },
            {
              "language": "sq",
              "text": "Do ta kontrolloj shpejt në sistem nëse porosia juaj është dërguar tashmë."
            },
            {
              "language": "tr",
              "text": "Siparişinizin gönderilip gönderilmediğini sistemden hızlıca kontrol edeceğim."
            }
          ]
        },
        {
          "baseText": "Kannst du bitte nachsehen, ob das Fenster geschlossen ist?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك من فضلك التحقق مما إذا كانت النافذة مغلقة؟"
            },
            {
              "language": "ckb",
              "text": "تکایە دەتوانیت ببینیت پەنجەرەکە داخراوە یان نا؟"
            },
            {
              "language": "en",
              "text": "Can you please check whether the window is closed?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً بررسی کنی که پنجره بسته است یا نه؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî ji kerema xwe kontrol bikî ka pace girtî ye an na?"
            },
            {
              "language": "pl",
              "text": "Czy możesz sprawdzić, czy okno jest zamknięte?"
            },
            {
              "language": "ro",
              "text": "Poți, te rog, să verifici dacă fereastra este închisă?"
            },
            {
              "language": "ru",
              "text": "Можешь, пожалуйста, проверить, закрыто ли окно?"
            },
            {
              "language": "sq",
              "text": "A mund të kontrollosh, të lutem, nëse dritarja është e mbyllur?"
            },
            {
              "language": "tr",
              "text": "Pencerenin kapalı olup olmadığını kontrol edebilir misin?"
            }
          ]
        }
      ]
    },
    {
      "word": "nachsprechen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "nachsprechen",
      "pronunciationIpa": null,
      "syllableBreak": "nach-spre-chen",
      "topics": [
        "education-and-training",
        "everyday-life",
        "business-communication"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb: spricht nach, sprach nach, nachgesprochen"
      ],
      "collocations": [
        {
          "text": "einen Satz nachsprechen",
          "meaning": "to repeat a sentence"
        },
        {
          "text": "langsam nachsprechen",
          "meaning": "to repeat slowly"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sprechen",
          "relationLabel": "base verb",
          "note": null
        },
        {
          "lemma": "die Aussprache",
          "relationLabel": "related noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يردّد بعد شخص؛ يكرر الكلام"
        },
        {
          "language": "ckb",
          "text": "دوای کەسێک دەڵێتەوە؛ دووبارە دەکاتەوە"
        },
        {
          "language": "en",
          "text": "to repeat after someone; to imitate speech"
        },
        {
          "language": "fa",
          "text": "بعد از کسی تکرار کردن؛ بازگفتن"
        },
        {
          "language": "kmr",
          "text": "piştî kesekî dubare kirin; gotinê şibandin"
        },
        {
          "language": "pl",
          "text": "powtarzać po kimś"
        },
        {
          "language": "ro",
          "text": "a repeta după cineva"
        },
        {
          "language": "ru",
          "text": "повторять за кем-то"
        },
        {
          "language": "sq",
          "text": "të përsërisësh pas dikujt"
        },
        {
          "language": "tr",
          "text": "birinin ardından tekrar etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte sprechen Sie den Satz langsam nach.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلكم رددوا الجملة ببطء."
            },
            {
              "language": "ckb",
              "text": "تکایە ڕستەکە بە هێواشی دووبارە بکەنەوە."
            },
            {
              "language": "en",
              "text": "Please repeat the sentence slowly."
            },
            {
              "language": "fa",
              "text": "لطفاً جمله را آرام تکرار کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe hevokê hêdî dubare bikin."
            },
            {
              "language": "pl",
              "text": "Proszę powtórzyć zdanie powoli."
            },
            {
              "language": "ro",
              "text": "Vă rog să repetați propoziția încet."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, повторите предложение медленно."
            },
            {
              "language": "sq",
              "text": "Ju lutem përsëriteni fjalinë ngadalë."
            },
            {
              "language": "tr",
              "text": "Lütfen cümleyi yavaşça tekrar edin."
            }
          ]
        },
        {
          "baseText": "Im Sprachkurs sprechen wir die neuen Wörter gemeinsam nach.",
          "translations": [
            {
              "language": "ar",
              "text": "في دورة اللغة نردد الكلمات الجديدة معًا."
            },
            {
              "language": "ckb",
              "text": "لە کۆرسی زماندا وشە نوێیەکان پێکەوە دووبارە دەکەینەوە."
            },
            {
              "language": "en",
              "text": "In the language course, we repeat the new words together."
            },
            {
              "language": "fa",
              "text": "در کلاس زبان، واژه‌های جدید را با هم تکرار می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Di qursa ziman de em peyvên nû bi hev re dubare dikin."
            },
            {
              "language": "pl",
              "text": "Na kursie językowym wspólnie powtarzamy nowe słowa."
            },
            {
              "language": "ro",
              "text": "La cursul de limbă repetăm împreună cuvintele noi."
            },
            {
              "language": "ru",
              "text": "На языковом курсе мы вместе повторяем новые слова."
            },
            {
              "language": "sq",
              "text": "Në kursin e gjuhës i përsërisim së bashku fjalët e reja."
            },
            {
              "language": "tr",
              "text": "Dil kursunda yeni kelimeleri birlikte tekrar ederiz."
            }
          ]
        }
      ]
    },
