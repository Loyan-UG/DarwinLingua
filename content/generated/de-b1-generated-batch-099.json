  "entries": [
    {
      "word": "die Nebenbeschäftigung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Nebenbeschäftigungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ne-ben-be-schäf-ti-gung",
      "topics": [
        "work-and-jobs",
        "human-resources",
        "law-and-compliance"
      ],
      "usageLabels": [
        "formal",
        "administrative",
        "workplace",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Nebenbeschäftigung anmelden",
          "meaning": "to register or report a side job"
        },
        {
          "text": "eine Nebenbeschäftigung genehmigen",
          "meaning": "to approve a side job"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "beschäftigen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Beschäftigung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "عمل جانبي؛ وظيفة إضافية"
        },
        {
          "language": "ckb",
          "text": "کاری لاوەکی؛ پیشەی دووەم"
        },
        {
          "language": "en",
          "text": "side job; secondary employment"
        },
        {
          "language": "fa",
          "text": "شغل جانبی؛ کار دوم"
        },
        {
          "language": "kmr",
          "text": "karê alî; xebata duyem"
        },
        {
          "language": "pl",
          "text": "zajęcie dodatkowe; praca dodatkowa"
        },
        {
          "language": "ro",
          "text": "activitate secundară; job suplimentar"
        },
        {
          "language": "ru",
          "text": "подработка; дополнительная работа"
        },
        {
          "language": "sq",
          "text": "punë anësore; punësim dytësor"
        },
        {
          "language": "tr",
          "text": "yan iş; ek çalışma"
        }
      ],
      "examples": [
        {
          "baseText": "Eine Nebenbeschäftigung muss oft beim Arbeitgeber gemeldet werden.",
          "translations": [
            {
              "language": "ar",
              "text": "غالبًا يجب إبلاغ صاحب العمل بالعمل الجانبي."
            },
            {
              "language": "ckb",
              "text": "زۆرجار پێویستە کاری لاوەکی بە خاوەنکار ڕابگەیەندرێت."
            },
            {
              "language": "en",
              "text": "A side job often has to be reported to the employer."
            },
            {
              "language": "fa",
              "text": "شغل جانبی اغلب باید به کارفرما اعلام شود."
            },
            {
              "language": "kmr",
              "text": "Karê alî gelek caran divê ji xwediyê kar re were ragihandin."
            },
            {
              "language": "pl",
              "text": "Pracę dodatkową często trzeba zgłosić pracodawcy."
            },
            {
              "language": "ro",
              "text": "O activitate secundară trebuie adesea anunțată angajatorului."
            },
            {
              "language": "ru",
              "text": "О подработке часто нужно сообщить работодателю."
            },
            {
              "language": "sq",
              "text": "Një punë anësore shpesh duhet t’i njoftohet punëdhënësit."
            },
            {
              "language": "tr",
              "text": "Yan iş çoğu zaman işverene bildirilmelidir."
            }
          ]
        },
        {
          "baseText": "Sie hat am Wochenende eine Nebenbeschäftigung in einer Bäckerei.",
          "translations": [
            {
              "language": "ar",
              "text": "لديها عمل جانبي في مخبز في عطلة نهاية الأسبوع."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا کاری لاوەکییەکی لە نانەواخانەیەک هەیە."
            },
            {
              "language": "en",
              "text": "She has a side job in a bakery on weekends."
            },
            {
              "language": "fa",
              "text": "او آخر هفته‌ها در یک نانوایی شغل جانبی دارد."
            },
            {
              "language": "kmr",
              "text": "Ew dawiya hefteyê li firinekê karekî alî heye."
            },
            {
              "language": "pl",
              "text": "W weekendy ma dodatkową pracę w piekarni."
            },
            {
              "language": "ro",
              "text": "Ea are un job suplimentar într-o brutărie în weekend."
            },
            {
              "language": "ru",
              "text": "По выходным у неё подработка в пекарне."
            },
            {
              "language": "sq",
              "text": "Ajo ka një punë anësore në një furrë buke gjatë fundjavës."
            },
            {
              "language": "tr",
              "text": "Hafta sonları bir fırında yan işi var."
            }
          ]
        }
      ]
    },
    {
      "word": "nebeneinander",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Adverb",
      "article": null,
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "ne-ben-ei-nan-der",
      "topics": [
        "everyday-life",
        "work-and-jobs",
        "housing-and-real-estate"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adverb meaning side by side or next to each other"
      ],
      "collocations": [
        {
          "text": "nebeneinander sitzen",
          "meaning": "to sit next to each other"
        },
        {
          "text": "nebeneinander arbeiten",
          "meaning": "to work side by side"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "neben",
          "relationLabel": "preposition",
          "note": null
        },
        {
          "lemma": "einander",
          "relationLabel": "pronoun/adverb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جنبًا إلى جنب؛ بجانب بعض"
        },
        {
          "language": "ckb",
          "text": "لە تەنیشت یەکتر؛ پێکەوە بە تەنیشت"
        },
        {
          "language": "en",
          "text": "next to each other; side by side"
        },
        {
          "language": "fa",
          "text": "کنار هم؛ پهلو به پهلو"
        },
        {
          "language": "kmr",
          "text": "li kêleka hev; tenişta hev"
        },
        {
          "language": "pl",
          "text": "obok siebie"
        },
        {
          "language": "ro",
          "text": "unul lângă altul; alături"
        },
        {
          "language": "ru",
          "text": "рядом друг с другом; бок о бок"
        },
        {
          "language": "sq",
          "text": "pranë njëri-tjetrit; krah për krah"
        },
        {
          "language": "tr",
          "text": "yan yana; birbirinin yanında"
        }
      ],
      "examples": [
        {
          "baseText": "Die beiden Schreibtische stehen direkt nebeneinander.",
          "translations": [
            {
              "language": "ar",
              "text": "المكتبان موضوعان مباشرة بجانب بعضهما."
            },
            {
              "language": "ckb",
              "text": "هەردوو مێزە نووسینەکە ڕاستەوخۆ لە تەنیشت یەکترن."
            },
            {
              "language": "en",
              "text": "The two desks are right next to each other."
            },
            {
              "language": "fa",
              "text": "دو میز کار درست کنار هم قرار دارند."
            },
            {
              "language": "kmr",
              "text": "Her du maseyên nivîsînê rasterast li kêleka hev in."
            },
            {
              "language": "pl",
              "text": "Oba biurka stoją bezpośrednio obok siebie."
            },
            {
              "language": "ro",
              "text": "Cele două birouri sunt chiar unul lângă altul."
            },
            {
              "language": "ru",
              "text": "Два письменных стола стоят прямо рядом друг с другом."
            },
            {
              "language": "sq",
              "text": "Dy tavolinat e punës janë direkt pranë njëra-tjetrës."
            },
            {
              "language": "tr",
              "text": "İki çalışma masası tam yan yana duruyor."
            }
          ]
        },
        {
          "baseText": "Im Zug saßen wir nebeneinander und konnten gut sprechen.",
          "translations": [
            {
              "language": "ar",
              "text": "جلسنا في القطار جنبًا إلى جنب واستطعنا التحدث جيدًا."
            },
            {
              "language": "ckb",
              "text": "لە شەمەندەفەرەکەدا لە تەنیشت یەکتر دانیشتین و توانیمان باش قسە بکەین."
            },
            {
              "language": "en",
              "text": "On the train we sat next to each other and could talk easily."
            },
            {
              "language": "fa",
              "text": "در قطار کنار هم نشستیم و توانستیم راحت صحبت کنیم."
            },
            {
              "language": "kmr",
              "text": "Di trênê de em li kêleka hev rûniştin û baş axivîn."
            },
            {
              "language": "pl",
              "text": "W pociągu siedzieliśmy obok siebie i mogliśmy swobodnie rozmawiać."
            },
            {
              "language": "ro",
              "text": "În tren am stat unul lângă altul și am putut vorbi bine."
            },
            {
              "language": "ru",
              "text": "В поезде мы сидели рядом и могли спокойно поговорить."
            },
            {
              "language": "sq",
              "text": "Në tren u ulëm pranë njëri-tjetrit dhe mundëm të flisnim mirë."
            },
            {
              "language": "tr",
              "text": "Trende yan yana oturduk ve rahatça konuşabildik."
            }
          ]
        }
      ]
    },
