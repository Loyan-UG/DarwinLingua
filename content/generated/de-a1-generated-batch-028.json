      "examples": [
        {
          "baseText": "Darf ich hier warten?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنني الانتظار هنا؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانم لێرە چاوەڕێ بکەم؟"
            },
            {
              "language": "en",
              "text": "May I wait here?"
            },
            {
              "language": "fa",
              "text": "می‌توانم اینجا منتظر بمانم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim li vir li bendê bimînim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę tutaj poczekać?"
            },
            {
              "language": "ro",
