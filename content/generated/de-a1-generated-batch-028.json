            {
              "language": "sq",
              "text": "A mund të pres këtu?"
            },
            {
              "language": "tr",
              "text": "Burada bekleyebilir miyim?"
            }
          ]
        },
        {
          "baseText": "Sie dürfen jetzt gehen.",
          "translations": [
            {
              "language": "ar",
              "text": "يمكنكم الذهاب الآن."
            },
            {
              "language": "ckb",
              "text": "ئێستا دەتوانن بڕۆن."
            },
            {
              "language": "en",
              "text": "You may go now."
            },
            {
              "language": "fa",
              "text": "اکنون می‌توانید بروید."
            },
            {
              "language": "kmr",
              "text": "Hûn dikarin niha biçin."
            },
            {
              "language": "pl",
              "text": "Może pan teraz iść."
            },
            {
              "language": "ro",
              "text": "Acum aveți voie să plecați."
            },
            {
              "language": "ru",
              "text": "Теперь вы можете идти."
