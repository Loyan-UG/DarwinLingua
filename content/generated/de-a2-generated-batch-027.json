      "meanings": [
        {
          "language": "ar",
          "text": "إعلان صوتي؛ نداء"
        },
        {
          "language": "ckb",
          "text": "ڕاگەیاندنی دەنگی"
        },
        {
          "language": "en",
          "text": "announcement; public announcement"
        },
        {
          "language": "fa",
          "text": "اعلان صوتی؛ پیام بلندگو"
        },
        {
          "language": "kmr",
          "text": "ragihandina dengî"
        },
        {
          "language": "pl",
          "text": "komunikat; ogłoszenie"
        },
        {
          "language": "ro",
          "text": "anunț; mesaj public"
        },
        {
          "language": "ru",
          "text": "объявление"
        },
        {
          "language": "sq",
          "text": "njoftim publik"
        },
        {
          "language": "tr",
          "text": "anons; duyuru"
        }
      ],
      "examples": [
        {
          "baseText": "Am Bahnhof hören wir eine Durchsage.",
          "translations": [
            {
              "language": "ar",
              "text": "في محطة القطار نسمع إعلاناً صوتياً."
            },
            {
              "language": "ckb",
              "text": "لە وێستگەی شەمەندەفەر ڕاگەیاندنێک دەبیستین."
            },
            {
              "language": "en",
              "text": "At the station, we hear an announcement."
            },
            {
              "language": "fa",
              "text": "در ایستگاه قطار یک اعلان می‌شنویم."
            },
            {
              "language": "kmr",
              "text": "Li stasyona trênê em ragihandinekê dibihîzin."
            },
            {
              "language": "pl",
              "text": "Na dworcu słyszymy komunikat."
            },
            {
              "language": "ro",
              "text": "La gară auzim un anunț."
            },
            {
              "language": "ru",
              "text": "На вокзале мы слышим объявление."
            },
            {
              "language": "sq",
              "text": "Në stacion dëgjojmë një njoftim."
            },
            {
              "language": "tr",
              "text": "İstasyonda bir anons duyuyoruz."
            }
          ]
        },
        {
          "baseText": "Die Durchsage sagt, dass der Zug später kommt.",
          "translations": [
            {
              "language": "ar",
              "text": "يقول الإعلان إن القطار سيأتي متأخراً."
            },
            {
              "language": "ckb",
              "text": "ڕاگەیاندنەکە دەڵێت شەمەندەفەرەکە درەنگتر دێت."
            },
            {
              "language": "en",
              "text": "The announcement says that the train will arrive later."
            },
            {
              "language": "fa",
              "text": "اعلان می‌گوید قطار دیرتر می‌آید."
            },
            {
              "language": "kmr",
              "text": "Ragihandin dibêje ku trên derengtir tê."
            },
            {
              "language": "pl",
              "text": "Komunikat mówi, że pociąg przyjedzie później."
            },
            {
              "language": "ro",
              "text": "Anunțul spune că trenul vine mai târziu."
            },
            {
              "language": "ru",
              "text": "Объявление говорит, что поезд придет позже."
            },
            {
              "language": "sq",
              "text": "Njoftimi thotë se treni vjen më vonë."
            },
            {
              "language": "tr",
              "text": "Anons trenin daha geç geleceğini söylüyor."
            }
          ]
        }
      ]
    },
