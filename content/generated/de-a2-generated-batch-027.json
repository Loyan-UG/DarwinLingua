      "examples": [
        {
          "baseText": "Kannst du die Tickets bitte drucken?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يمكنك طباعة التذاكر من فضلك؟"
            },
            {
              "language": "ckb",
              "text": "دەتوانیت تکایە بلیتەکان چاپ بکەیت؟"
            },
            {
              "language": "en",
              "text": "Can you please print the tickets?"
            },
            {
              "language": "fa",
              "text": "می‌توانی لطفاً بلیط‌ها را چاپ کنی؟"
            },
            {
              "language": "kmr",
              "text": "Tu dikarî ji kerema xwe bilêtan çap bikî?"
            },
            {
              "language": "pl",
              "text": "Czy możesz wydrukować bilety?"
            },
            {
              "language": "ro",
              "text": "Poți, te rog, să tipărești biletele?"
            },
            {
              "language": "ru",
              "text": "Можешь, пожалуйста, распечатать билеты?"
            },
            {
              "language": "sq",
              "text": "A mund t’i printosh biletat, të lutem?"
            },
            {
              "language": "tr",
              "text": "Biletleri lütfen yazdırabilir misin?"
            }
          ]
        },
        {
          "baseText": "Wir drucken die Liste im Büro.",
          "translations": [
            {
              "language": "ar",
              "text": "نطبع القائمة في المكتب."
            },
            {
              "language": "ckb",
              "text": "لیستەکە لە ئۆفیس چاپ دەکەین."
            },
            {
              "language": "en",
              "text": "We print the list in the office."
            },
            {
              "language": "fa",
              "text": "ما فهرست را در دفتر چاپ می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em lîsteyê li nivîsgehê çap dikin."
            },
            {
              "language": "pl",
              "text": "Drukujemy listę w biurze."
            },
            {
              "language": "ro",
              "text": "Tipărim lista la birou."
            },
            {
              "language": "ru",
              "text": "Мы печатаем список в офисе."
            },
            {
              "language": "sq",
              "text": "E printojmë listën në zyrë."
            },
            {
              "language": "tr",
              "text": "Listeyi ofiste yazdırıyoruz."
            }
          ]
        }
      ]
