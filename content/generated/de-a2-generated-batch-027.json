        {
          "language": "tr",
          "text": "baskı; basınç"
        }
      ],
      "examples": [
        {
          "baseText": "Der Druck des Dokuments dauert nur eine Minute.",
          "translations": [
            {
              "language": "ar",
              "text": "طباعة المستند تستغرق دقيقة واحدة فقط."
            },
            {
              "language": "ckb",
              "text": "چاپی بەڵگەنامەکە تەنها خولەکێک دەخایەنێت."
            },
            {
              "language": "en",
              "text": "Printing the document takes only one minute."
            },
            {
              "language": "fa",
              "text": "چاپ سند فقط یک دقیقه طول می‌کشد."
            },
            {
              "language": "kmr",
              "text": "Çapa belgeyê tenê xulekekê diajo."
            },
            {
              "language": "pl",
              "text": "Druk dokumentu trwa tylko minutę."
            },
            {
              "language": "ro",
              "text": "Tipărirea documentului durează doar un minut."
            },
            {
              "language": "ru",
              "text": "Печать документа занимает всего одну минуту."
            },
            {
              "language": "sq",
              "text": "Printimi i dokumentit zgjat vetëm një minutë."
            },
            {
              "language": "tr",
              "text": "Belgenin yazdırılması sadece bir dakika sürer."
            }
          ]
        },
        {
          "baseText": "Vor der Prüfung steht sie unter großem Druck.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل الامتحان هي تحت ضغط كبير."
            },
            {
              "language": "ckb",
              "text": "پێش تاقیکردنەوەکە لە ژێر فشارێکی زۆردایە."
            },
            {
              "language": "en",
              "text": "Before the exam, she is under a lot of pressure."
            },
            {
              "language": "fa",
              "text": "قبل از امتحان تحت فشار زیادی است."
            },
            {
              "language": "kmr",
              "text": "Berî ezmûnê ew di bin zexta mezin de ye."
            },
            {
              "language": "pl",
              "text": "Przed egzaminem jest pod dużą presją."
            },
            {
              "language": "ro",
              "text": "Înainte de examen este sub mare presiune."
            },
            {
              "language": "ru",
              "text": "Перед экзаменом она находится под большим давлением."
            },
            {
              "language": "sq",
              "text": "Para provimit ajo është nën presion të madh."
            },
            {
              "language": "tr",
              "text": "Sınavdan önce büyük baskı altında."
            }
          ]
        }
      ]
    },
