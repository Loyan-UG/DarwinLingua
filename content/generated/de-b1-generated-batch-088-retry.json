      "examples": [
        {
          "baseText": "Die Leitung des Projekts liegt ab Mai bei Frau Schneider.",
          "translations": [
            {
              "language": "ar",
              "text": "ستكون إدارة المشروع ابتداءً من مايو لدى السيدة شنايدر."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبردنی پڕۆژەکە لە مانگی ئایارەوە لەلایەن خانمی شنایدەرەوە دەبێت."
            },
            {
              "language": "en",
              "text": "The project management will be with Ms. Schneider from May."
            },
            {
              "language": "fa",
              "text": "مدیریت پروژه از ماه مه بر عهده خانم اشنایدر خواهد بود."
            },
            {
              "language": "kmr",
              "text": "Rêveberiya projeyê ji gulanê ve li cem Xanim Schneider e."
            },
            {
              "language": "pl",
              "text": "Kierownictwo projektu od maja będzie należeć do pani Schneider."
            },
            {
              "language": "ro",
              "text": "Conducerea proiectului va fi la doamna Schneider începând din mai."
            },
            {
              "language": "ru",
              "text": "Руководство проектом с мая будет у госпожи Шнайдер."
            },
            {
              "language": "sq",
              "text": "Drejtimi i projektit nga maji do të jetë te zonja Schneider."
            },
            {
              "language": "tr",
              "text": "Projenin yönetimi mayıs ayından itibaren Bayan Schneider’de olacak."
            }
          ]
        },
        {
          "baseText": "Die Internetverbindung ist langsam, vielleicht ist die Leitung beschädigt.",
          "translations": [
            {
              "language": "ar",
              "text": "اتصال الإنترنت بطيء، ربما يكون الخط تالفاً."
            },
            {
              "language": "ckb",
              "text": "پەیوەندی ئینتەرنێت خاوە، ڕەنگە هێڵەکە زیانی پێگەیشتبێت."
            },
            {
              "language": "en",
              "text": "The internet connection is slow; maybe the line is damaged."
            },
            {
              "language": "fa",
              "text": "اتصال اینترنت کند است، شاید خط آسیب دیده باشد."
            },
            {
              "language": "kmr",
              "text": "Girêdana înternetê hêdî ye; dibe ku xet zirar dîtibe."
            },
            {
              "language": "pl",
              "text": "Połączenie internetowe jest wolne, może linia jest uszkodzona."
            },
            {
              "language": "ro",
              "text": "Conexiunea la internet este lentă; poate linia este deteriorată."
            },
            {
              "language": "ru",
              "text": "Интернет-соединение медленное, возможно, линия повреждена."
            },
            {
              "language": "sq",
              "text": "Lidhja e internetit është e ngadaltë; ndoshta linja është dëmtuar."
            },
            {
              "language": "tr",
              "text": "İnternet bağlantısı yavaş, belki hat hasarlıdır."
            }
          ]
        }
      ]
