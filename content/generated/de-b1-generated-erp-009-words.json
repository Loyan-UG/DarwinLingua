      "word": "der Verfall",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": null,
      "infinitive": null,
      "syllableBreak": "Ver-fall",
      "topics": [
        "warehouse-and-logistics",
        "finance-and-accounting",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "masculine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "Verfall von Waren",
          "meaning": "expiry of goods"
        },
        {
          "text": "kurz vor dem Verfall",
          "meaning": "shortly before expiry"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verfallen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "انتهاء الصلاحية؛ تدهور"
        },
        {
          "language": "ckb",
          "text": "بەسەرچوون؛ داڕمان"
        },
        {
          "language": "en",
          "text": "expiry; deterioration"
        },
        {
          "language": "fa",
          "text": "انقضا؛ زوال"
        },
        {
          "language": "kmr",
          "text": "dawîbûn; xirabûn"
        },
        {
          "language": "pl",
          "text": "wygaśnięcie; przeterminowanie; upadek"
        },
        {
          "language": "ro",
          "text": "expirare; degradare"
        },
        {
          "language": "ru",
          "text": "истечение срока; упадок"
        },
        {
          "language": "sq",
          "text": "skadim; rënie"
        },
        {
          "language": "tr",
          "text": "son kullanma; bozulma"
        }
      ],
      "examples": [
        {
          "baseText": "Der Verfall der Charge wird im ERP-System automatisch angezeigt.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم عرض انتهاء صلاحية الدفعة تلقائيًا في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "بەسەرچوونی بچەکە خۆکارانە لە سیستەمی ERPدا پیشان دەدرێت."
            },
            {
              "language": "en",
              "text": "The expiry of the batch is shown automatically in the ERP system."
            },
            {
              "language": "fa",
              "text": "انقضای بچ در سیستم ERP به صورت خودکار نمایش داده می‌شود."
            },
            {
              "language": "kmr",
              "text": "Dawîbûna partiyê di pergala ERP de bixweber tê nîşandan."
            },
            {
              "language": "pl",
              "text": "Wygaśnięcie partii jest automatycznie pokazywane w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Expirarea lotului este afișată automat în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Истечение срока партии автоматически отображается в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Skadimi i serisë shfaqet automatikisht në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Partinin son kullanma tarihi ERP sisteminde otomatik gösterilir."
            }
          ]
        },
        {
          "baseText": "Nach dem Verfall dürfen wir die Ware nicht mehr verkaufen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد انتهاء الصلاحية لا يجوز لنا بيع البضاعة."
            },
            {
              "language": "ckb",
              "text": "دوای بەسەرچوون نابێت کاڵاکە چیتر بفرۆشین."
            },
            {
              "language": "en",
              "text": "After expiry, we may no longer sell the goods."
            },
            {
              "language": "fa",
              "text": "بعد از انقضا دیگر اجازه فروش کالا را نداریم."
            },
            {
              "language": "kmr",
              "text": "Piştî dawîbûnê em êdî nikarin malê bifiroşin."
            },
            {
              "language": "pl",
              "text": "Po upływie terminu nie wolno nam już sprzedawać towaru."
            },
            {
              "language": "ro",
              "text": "După expirare nu mai avem voie să vindem marfa."
            },
            {
              "language": "ru",
              "text": "После истечения срока мы больше не можем продавать товар."
            },
            {
              "language": "sq",
              "text": "Pas skadimit nuk mund ta shesim më mallin."
            },
            {
              "language": "tr",
              "text": "Son kullanma tarihinden sonra ürünü artık satamayız."
            }
          ]
        }
      ]
    },
    {
