          "text": "ein Vertreter des Kunden",
          "meaning": "a representative of the customer"
        },
        {
          "text": "den Vertreter kontaktieren",
          "meaning": "to contact the representative"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "vertreten",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Vertretung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ممثل؛ مندوب"
        },
        {
          "language": "ckb",
          "text": "نوێنەر"
        },
        {
          "language": "en",
          "text": "representative"
        },
        {
          "language": "fa",
          "text": "نماینده"
        },
        {
          "language": "kmr",
          "text": "nûner"
        },
        {
          "language": "pl",
          "text": "przedstawiciel"
        },
        {
          "language": "ro",
          "text": "reprezentant"
        },
        {
          "language": "ru",
          "text": "представитель"
        },
        {
          "language": "sq",
          "text": "përfaqësues"
        },
        {
          "language": "tr",
          "text": "temsilci"
        }
      ],
      "examples": [
        {
          "baseText": "Der Vertreter des Kunden ist im ERP-System als Ansprechpartner hinterlegt.",
          "translations": [
            {
              "language": "ar",
              "text": "تم حفظ ممثل العميل كشخص اتصال في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "نوێنەری کڕیارەکە لە سیستەمی ERPدا وەک کەسی پەیوەندی تۆمارکراوە."
            },
            {
              "language": "en",
              "text": "The customer representative is stored as a contact person in the ERP system."
            },
            {
              "language": "fa",
              "text": "نماینده مشتری در سیستم ERP به عنوان شخص تماس ثبت شده است."
            },
            {
              "language": "kmr",
              "text": "Nûnerê xerîdar di pergala ERP de wekî kesê têkilî hatiye tomarkirin."
            },
            {
              "language": "pl",
              "text": "Przedstawiciel klienta jest zapisany w systemie ERP jako osoba kontaktowa."
            },
            {
              "language": "ro",
              "text": "Reprezentantul clientului este salvat în sistemul ERP ca persoană de contact."
            },
            {
              "language": "ru",
              "text": "Представитель клиента сохранен в ERP-системе как контактное лицо."
            },
            {
              "language": "sq",
              "text": "Përfaqësuesi i klientit është ruajtur në sistemin ERP si person kontakti."
            },
            {
              "language": "tr",
              "text": "Müşteri temsilcisi ERP sisteminde irtibat kişisi olarak kayıtlı."
            }
          ]
        },
        {
          "baseText": "Unser Vertreter besucht morgen drei Kunden in München.",
          "translations": [
            {
              "language": "ar",
              "text": "يزور مندوبنا غدًا ثلاثة عملاء في ميونخ."
            },
            {
              "language": "ckb",
              "text": "نوێنەرەکەمان سبەی سێ کڕیار لە مونیخ سەردان دەکات."
            },
            {
              "language": "en",
              "text": "Our representative is visiting three customers in Munich tomorrow."
