            },
            {
              "language": "en",
              "text": "May I charge my phone here?"
            },
            {
              "language": "fa",
              "text": "می‌توانم موبایلم را اینجا شارژ کنم؟"
            },
            {
              "language": "kmr",
              "text": "Ez dikarim telefonê xwe li vir şarj bikim?"
            },
            {
              "language": "pl",
              "text": "Czy mogę tutaj naładować telefon?"
            },
            {
              "language": "ro",
              "text": "Pot să-mi încarc telefonul aici?"
            },
            {
              "language": "ru",
              "text": "Можно зарядить здесь телефон?"
