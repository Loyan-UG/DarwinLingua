  "entries": [
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "die Ernte",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Ernten",
      "infinitive": null,
      "syllableBreak": "Ern-te",
      "topics": [
        "environment-and-sustainability",
        "production-and-maintenance",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "spoken"
      ],
      "contextLabels": [
        "sustainability",
        "quality"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Ernte einbringen",
          "meaning": "to bring in the harvest"
        },
        {
          "text": "eine gute Ernte",
          "meaning": "a good harvest"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "ernten",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "الحصاد"
        },
        {
          "language": "ckb",
          "text": "دروێنە"
        },
        {
          "language": "en",
          "text": "harvest"
        },
        {
          "language": "fa",
          "text": "برداشت محصول"
        },
        {
          "language": "kmr",
          "text": "çinîn; berhem"
        },
        {
          "language": "pl",
          "text": "zbiory; plon"
        },
        {
          "language": "ro",
          "text": "recoltă"
        },
        {
          "language": "ru",
          "text": "урожай"
        },
        {
          "language": "sq",
          "text": "korrje"
        },
        {
          "language": "tr",
          "text": "hasat"
        }
      ],
      "examples": [
        {
          "baseText": "Wegen der langen Trockenheit fällt die Ernte in diesem Jahr kleiner aus.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب الجفاف الطويل سيكون الحصاد هذا العام أقل."
            },
            {
              "language": "ckb",
              "text": "بەهۆی وشکەساڵیی درێژەوە دروێنەی ئەمساڵ کەمتر دەبێت."
            },
            {
              "language": "en",
              "text": "Because of the long drought, the harvest is smaller this year."
            },
            {
              "language": "fa",
              "text": "به دلیل خشکسالی طولانی، برداشت امسال کمتر خواهد بود."
            },
            {
              "language": "kmr",
              "text": "Ji ber ziwabûna dirêj, çinîna îsal kêmtir e."
            },
            {
              "language": "pl",
              "text": "Z powodu długiej suszy tegoroczne zbiory są mniejsze."
            },
            {
              "language": "ro",
              "text": "Din cauza secetei îndelungate, recolta din acest an este mai mică."
            },
            {
              "language": "ru",
              "text": "Из-за длительной засухи урожай в этом году меньше."
            },
            {
              "language": "sq",
              "text": "Për shkak të thatësirës së gjatë, korrja këtë vit është më e vogël."
            },
            {
              "language": "tr",
              "text": "Uzun kuraklık nedeniyle bu yıl hasat daha düşük."
            }
          ]
        },
        {
          "baseText": "Der Hof verkauft einen Teil der Ernte direkt im eigenen Laden.",
          "translations": [
            {
              "language": "ar",
              "text": "تبيع المزرعة جزءًا من الحصاد مباشرة في متجرها الخاص."
            },
            {
              "language": "ckb",
              "text": "کێڵگەکە بەشێک لە دروێنەکە ڕاستەوخۆ لە دووکانی خۆیدا دەفرۆشێت."
            },
            {
              "language": "en",
              "text": "The farm sells part of the harvest directly in its own shop."
            },
            {
              "language": "fa",
              "text": "مزرعه بخشی از محصول را مستقیم در فروشگاه خودش می‌فروشد."
            },
            {
              "language": "kmr",
              "text": "Çiftgeh beşek ji çinînê rasterast di dikana xwe de difroşe."
            },
            {
              "language": "pl",
              "text": "Gospodarstwo sprzedaje część zbiorów bezpośrednio we własnym sklepie."
            },
            {
              "language": "ro",
              "text": "Ferma vinde o parte din recoltă direct în propriul magazin."
            },
            {
              "language": "ru",
              "text": "Ферма продает часть урожая напрямую в собственном магазине."
            },
            {
              "language": "sq",
              "text": "Ferma shet një pjesë të korrjes drejtpërdrejt në dyqanin e vet."
            },
            {
              "language": "tr",
              "text": "Çiftlik hasadın bir kısmını doğrudan kendi dükkanında satıyor."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B2",
      "pronunciationIpa": null,
      "relations": [],
      "word": "die Erreichbarkeit",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Erreichbarkeiten",
      "infinitive": null,
      "syllableBreak": "Er-reich-bar-keit",
      "topics": [
        "customer-service",
        "business-communication",
        "transport-and-travel"
      ],
      "usageLabels": [
        "business",
        "formal"
      ],
      "contextLabels": [
        "customer-service",
        "support"
      ],
      "grammarNotes": [
        "feminine noun; plural is uncommon"
      ],
      "collocations": [
        {
          "text": "telefonische Erreichbarkeit",
          "meaning": "availability by phone"
        },
        {
          "text": "die Erreichbarkeit verbessern",
          "meaning": "to improve reachability"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "erreichbar",
          "relationLabel": "adjective",
          "note": null
        },
        {
          "lemma": "erreichen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "إمكانية الوصول؛ التوفر للتواصل"
        },
        {
          "language": "ckb",
          "text": "دەستگەیشتن؛ توانای پەیوەندیکردن"
        },
        {
          "language": "en",
          "text": "reachability; availability"
        },
        {
          "language": "fa",
          "text": "دسترس‌پذیری؛ امکان تماس"
        },
        {
          "language": "kmr",
          "text": "gihîştin; berdestbûn"
        },
        {
          "language": "pl",
          "text": "dostępność; osiągalność"
        },
        {
          "language": "ro",
          "text": "accesibilitate; disponibilitate"
        },
        {
          "language": "ru",
          "text": "доступность; досягаемость"
        },
        {
          "language": "sq",
          "text": "arritshmëri; disponueshmëri"
        },
        {
          "language": "tr",
          "text": "ulaşılabilirlik; erişilebilirlik"
        }
      ],
      "examples": [
        {
          "baseText": "Die Erreichbarkeit des Supports hat sich durch den Rückrufservice verbessert.",
          "translations": [
            {
              "language": "ar",
              "text": "تحسنت إمكانية الوصول إلى الدعم بفضل خدمة معاودة الاتصال."
            },
            {
              "language": "ckb",
              "text": "دەستگەیشتن بە پشتگیری بەهۆی خزمەتی پەیوەندیی گەڕاوە باشتر بووە."
            },
            {
              "language": "en",
              "text": "Support reachability has improved thanks to the callback service."
            },
            {
              "language": "fa",
              "text": "دسترسی به پشتیبانی با سرویس تماس برگشتی بهتر شده است."
            },
            {
              "language": "kmr",
              "text": "Gihîştina piştgiriyê bi xizmeta vegerandina bangê baştir bûye."
            },
            {
              "language": "pl",
              "text": "Dostępność wsparcia poprawiła się dzięki usłudze oddzwaniania."
            },
            {
              "language": "ro",
              "text": "Accesibilitatea suportului s-a îmbunătățit datorită serviciului de apelare înapoi."
            },
            {
              "language": "ru",
              "text": "Доступность поддержки улучшилась благодаря услуге обратного звонка."
            },
            {
              "language": "sq",
              "text": "Arritshmëria e suportit është përmirësuar falë shërbimit të kthimit të telefonatës."
            },
            {
              "language": "tr",
              "text": "Geri arama hizmeti sayesinde desteğe ulaşılabilirlik iyileşti."
            }
          ]
        },
        {
          "baseText": "Die Erreichbarkeit des Dorfes ist im Winter wegen Schnee oft eingeschränkt.",
          "translations": [
            {
              "language": "ar",
