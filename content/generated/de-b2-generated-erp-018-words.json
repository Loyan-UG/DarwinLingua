          "note": null
        },
        {
          "lemma": "erzeugen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تم إنشاء سند التسليم"
        },
        {
          "language": "ckb",
          "text": "پسوڵەی گەیاندن دروستکراوە"
        },
        {
          "language": "en",
          "text": "delivery note created"
        },
        {
          "language": "fa",
          "text": "برگه تحویل ایجاد شده"
        },
        {
          "language": "kmr",
          "text": "belgeya radestkirinê hatiye çêkirin"
        },
        {
          "language": "pl",
          "text": "dokument dostawy utworzony"
        },
        {
          "language": "ro",
          "text": "aviz de livrare creat"
        },
        {
          "language": "ru",
          "text": "накладная создана"
        },
        {
          "language": "sq",
          "text": "fletëdorëzimi u krijua"
        },
        {
          "language": "tr",
          "text": "teslimat belgesi oluşturuldu"
        }
      ],
      "examples": [
        {
          "baseText": "Der Auftrag steht im ERP auf „Lieferschein erzeugt“, aber die Ware wurde noch nicht verladen.",
          "translations": [
            {
              "language": "ar",
              "text": "الطلب في ERP على حالة \"تم إنشاء سند التسليم\"، لكن البضاعة لم تُحمّل بعد."
            },
            {
              "language": "ckb",
              "text": "داواکارییەکە لە ERP دا لە دۆخی \"پسوڵەی گەیاندن دروستکراوە\" دایە، بەڵام کاڵاکە هێشتا بارنەکراوە."
            },
            {
              "language": "en",
              "text": "The order is marked “delivery note created” in the ERP, but the goods have not been loaded yet."
            },
            {
              "language": "fa",
              "text": "سفارش در ERP در وضعیت «برگه تحویل ایجاد شده» است، اما کالا هنوز بارگیری نشده است."
            },
            {
              "language": "kmr",
              "text": "Ferman di ERP de wekî \"belgeya radestkirinê hatiye çêkirin\" hatiye nîşankirin, lê mal hîn nehatiye barkirin."
            },
            {
              "language": "pl",
              "text": "Zamówienie ma w ERP status „dokument dostawy utworzony”, ale towar nie został jeszcze załadowany."
            },
            {
              "language": "ro",
              "text": "Comanda este în ERP pe statusul „aviz de livrare creat”, dar marfa nu a fost încă încărcată."
            },
            {
              "language": "ru",
              "text": "Заказ в ERP имеет статус «накладная создана», но товар еще не загружен."
            },
            {
              "language": "sq",
              "text": "Porosia është në ERP me statusin “fletëdorëzimi u krijua”, por malli ende nuk është ngarkuar."
            },
            {
              "language": "tr",
              "text": "Sipariş ERP’de “teslimat belgesi oluşturuldu” durumunda, ancak mal henüz yüklenmedi."
            }
          ]
        },
        {
          "baseText": "Wenn der Status „Lieferschein erzeugt“ fehlt, kann die Spedition die Sendung nicht übernehmen.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا كانت حالة \"تم إنشاء سند التسليم\" غير موجودة، فلا تستطيع شركة النقل استلام الشحنة."
            },
            {
              "language": "ckb",
              "text": "ئەگەر دۆخی \"پسوڵەی گەیاندن دروستکراوە\" نەبێت، کۆمپانیای گواستنەوە ناتوانێت ناردنەکە وەربگرێت."
            },
            {
              "language": "en",
              "text": "If the status “delivery note created” is missing, the carrier cannot take over the shipment."
            },
            {
              "language": "fa",
              "text": "اگر وضعیت «برگه تحویل ایجاد شده» وجود نداشته باشد، شرکت حمل‌ونقل نمی‌تواند محموله را تحویل بگیرد."
            },
            {
              "language": "kmr",
              "text": "Heke rewşa \"belgeya radestkirinê hatiye çêkirin\" tune be, şirketa barkirinê nikare şandinê bistîne."
            },
            {
              "language": "pl",
              "text": "Jeśli brakuje statusu „dokument dostawy utworzony”, spedytor nie może przejąć przesyłki."
            },
            {
              "language": "ro",
              "text": "Dacă lipsește statusul „aviz de livrare creat”, transportatorul nu poate prelua expediția."
            },
            {
              "language": "ru",
              "text": "Если статус «накладная создана» отсутствует, перевозчик не может принять отправку."
            },
            {
              "language": "sq",
              "text": "Nëse mungon statusi “fletëdorëzimi u krijua”, transportuesi nuk mund ta marrë dërgesën."
            },
            {
              "language": "tr",
              "text": "“Teslimat belgesi oluşturuldu” durumu yoksa nakliye firması sevkiyatı devralamaz."
            }
          ]
        }
      ]
    },
