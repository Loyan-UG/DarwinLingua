      "examples": [
        {
          "baseText": "Wenn der Bestand unter den Meldebestand fällt, erstellt das ERP einen Bestellvorschlag.",
          "translations": [
            {
              "language": "ar",
              "text": "عندما ينخفض المخزون تحت حد إعادة الطلب، ينشئ ERP اقتراح طلب شراء."
            },
            {
              "language": "ckb",
              "text": "کاتێک کۆگا لە خوار ئاستی ئاگادارکردنەوە دادەبەزێت، ERP پێشنیاری داواکاریی کڕین دروست دەکات."
            },
            {
              "language": "en",
              "text": "When stock falls below the reorder point, the ERP creates a purchase proposal."
            },
            {
              "language": "fa",
              "text": "وقتی موجودی از نقطه سفارش مجدد کمتر شود، ERP پیشنهاد سفارش خرید ایجاد می‌کند."
            },
            {
              "language": "kmr",
              "text": "Dema stok ji asta hişyarkirinê kêmtir dibe, ERP pêşniyara fermana kirînê çêdike."
            },
            {
              "language": "pl",
              "text": "Gdy stan spadnie poniżej punktu ponownego zamówienia, ERP tworzy propozycję zakupu."
            },
            {
              "language": "ro",
              "text": "Când stocul scade sub nivelul de reaprovizionare, ERP creează o propunere de comandă."
            },
            {
              "language": "ru",
              "text": "Когда запас падает ниже точки заказа, ERP создает предложение закупки."
            },
            {
              "language": "sq",
              "text": "Kur stoku bie nën nivelin e ri-porosisë, ERP krijon një propozim blerjeje."
            },
            {
              "language": "tr",
              "text": "Stok yeniden sipariş seviyesinin altına düşerse ERP bir satın alma önerisi oluşturur."
            }
          ]
        },
        {
          "baseText": "Der Meldebestand wurde erhöht, weil der Lieferant längere Lieferzeiten hat.",
          "translations": [
            {
              "language": "ar",
              "text": "تم رفع حد إعادة الطلب لأن المورد لديه أوقات تسليم أطول."
            },
            {
              "language": "ckb",
              "text": "ئاستی ئاگادارکردنەوەی کۆگا زیادکرا چونکە دابینکەر کاتی گەیاندنی درێژتری هەیە."
            },
            {
              "language": "en",
              "text": "The reorder point was increased because the supplier has longer delivery times."
            },
            {
              "language": "fa",
              "text": "نقطه سفارش مجدد افزایش یافت، چون زمان تحویل تأمین‌کننده طولانی‌تر شده است."
            },
            {
              "language": "kmr",
              "text": "Asta hişyarkirina stokê hate bilindkirin, ji ber ku dema radestkirina dabînker dirêjtir e."
            },
            {
              "language": "pl",
              "text": "Punkt ponownego zamówienia został podniesiony, ponieważ dostawca ma dłuższe terminy dostaw."
            },
            {
              "language": "ro",
              "text": "Nivelul de reaprovizionare a fost mărit deoarece furnizorul are termene de livrare mai lungi."
            },
            {
              "language": "ru",
              "text": "Точка заказа была повышена, потому что у поставщика более длительные сроки поставки."
            },
            {
              "language": "sq",
              "text": "Niveli i ri-porosisë u rrit sepse furnitori ka afate më të gjata dorëzimi."
            },
            {
              "language": "tr",
              "text": "Tedarikçinin teslim süreleri daha uzun olduğu için yeniden sipariş seviyesi artırıldı."
            }
          ]
        }
