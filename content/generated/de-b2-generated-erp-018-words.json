        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "status phrase used in ERP workflows; means that the delivery note has already been generated"
      ],
      "collocations": [
        {
          "text": "Status „Lieferschein erzeugt“",
          "meaning": "status “delivery note created”"
        },
        {
          "text": "als Lieferschein erzeugt markiert",
          "meaning": "marked as delivery note created"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Lieferschein",
