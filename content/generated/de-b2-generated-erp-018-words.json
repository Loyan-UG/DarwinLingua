      "meanings": [
        {
          "language": "ar",
          "text": "سند التسليم"
        },
        {
          "language": "ckb",
          "text": "پسوڵەی گەیاندن"
        },
        {
          "language": "en",
          "text": "delivery note"
        },
        {
          "language": "fa",
          "text": "برگه تحویل؛ حواله ارسال"
        },
        {
          "language": "kmr",
          "text": "belgeya radestkirinê"
        },
        {
          "language": "pl",
          "text": "dokument dostawy; WZ"
        },
        {
          "language": "ro",
          "text": "aviz de livrare"
        },
        {
          "language": "ru",
          "text": "накладная поставки"
        },
        {
          "language": "sq",
          "text": "fletëdorëzim"
        },
        {
          "language": "tr",
          "text": "teslimat belgesi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Lieferschein wird im ERP erzeugt, sobald die Lieferung freigegeben ist.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم إنشاء سند التسليم في ERP بمجرد تحرير التسليم."
            },
            {
              "language": "ckb",
              "text": "پسوڵەی گەیاندن لە ERP دا دروست دەکرێت هەر کات گەیاندنەکە ئازاد کرابێت."
            },
            {
              "language": "en",
              "text": "The delivery note is created in the ERP as soon as the delivery is released."
            },
            {
              "language": "fa",
              "text": "برگه تحویل به‌محض آزاد شدن تحویل در ERP ایجاد می‌شود."
            },
            {
              "language": "kmr",
              "text": "Belgeya radestkirinê di ERP de tê çêkirin dema radestkirin hatibe berdan."
            },
            {
              "language": "pl",
              "text": "Dokument dostawy jest tworzony w ERP, gdy tylko dostawa zostanie zwolniona."
            },
            {
              "language": "ro",
              "text": "Avizul de livrare este creat în ERP imediat ce livrarea este aprobată."
            },
            {
              "language": "ru",
              "text": "Накладная создается в ERP, как только поставка разблокирована."
            },
            {
              "language": "sq",
              "text": "Fletëdorëzimi krijohet në ERP sapo dorëzimi të lirohet."
            },
            {
              "language": "tr",
              "text": "Teslimat belgesi, teslimat serbest bırakılır bırakılmaz ERP’de oluşturulur."
            }
          ]
        },
        {
          "baseText": "Der Fahrer braucht den Lieferschein, bevor er das Werk verlässt.",
          "translations": [
            {
              "language": "ar",
              "text": "يحتاج السائق إلى سند التسليم قبل أن يغادر المصنع."
            },
            {
              "language": "ckb",
              "text": "شۆفێر پێویستی بە پسوڵەی گەیاندن هەیە پێش ئەوەی کارگە بەجێبهێڵێت."
            },
            {
              "language": "en",
              "text": "The driver needs the delivery note before leaving the plant."
            },
            {
              "language": "fa",
              "text": "راننده قبل از خروج از کارخانه به برگه تحویل نیاز دارد."
            },
            {
              "language": "kmr",
              "text": "Ajokar berî ku fabrîkayê bihêle hewceyê belgeya radestkirinê ye."
            },
            {
              "language": "pl",
              "text": "Kierowca potrzebuje dokumentu dostawy, zanim opuści zakład."
            },
            {
              "language": "ro",
              "text": "Șoferul are nevoie de avizul de livrare înainte să părăsească fabrica."
            },
            {
              "language": "ru",
              "text": "Водителю нужна накладная перед выездом с завода."
            },
            {
              "language": "sq",
              "text": "Shoferit i duhet fletëdorëzimi para se të largohet nga fabrika."
            },
            {
              "language": "tr",
              "text": "Şoför fabrikadan ayrılmadan önce teslimat belgesine ihtiyaç duyar."
            }
          ]
        }
      ]
    },
