  "entries": [
    {
      "word": "die Reisekosten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Reisekosten",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Rei-se-kos-ten",
      "topics": [
        "finance-and-accounting",
        "transport-and-travel",
        "work-and-jobs"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "administrative",
        "written"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "plural noun; singular die Reisekosten is used as a collective term"
      ],
      "collocations": [
        {
          "text": "Reisekosten abrechnen",
          "meaning": "to settle travel expenses"
        },
        {
          "text": "Reisekosten erstatten",
          "meaning": "to reimburse travel expenses"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Reise",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Kosten",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تكاليف السفر؛ مصاريف السفر"
        },
        {
          "language": "ckb",
          "text": "تێچووی گەشت؛ خەرجییەکانی گەشت"
        },
        {
          "language": "en",
          "text": "travel expenses; travel costs"
        },
        {
          "language": "fa",
          "text": "هزینه‌های سفر؛ مخارج سفر"
        },
        {
          "language": "kmr",
          "text": "lêçûnên rêwîtiyê"
        },
        {
          "language": "pl",
          "text": "koszty podróży"
        },
        {
          "language": "ro",
          "text": "cheltuieli de călătorie"
        },
        {
          "language": "ru",
          "text": "командировочные расходы; дорожные расходы"
        },
        {
          "language": "sq",
          "text": "shpenzime udhëtimi"
        },
        {
          "language": "tr",
          "text": "seyahat masrafları"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte reichen Sie die Reisekosten bis Freitag in der Buchhaltung ein.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى تقديم مصاريف السفر إلى المحاسبة حتى يوم الجمعة."
            },
            {
              "language": "ckb",
              "text": "تکایە خەرجییەکانی گەشت تا هەینی بۆ ژمێریاری پێشکەش بکەن."
            },
            {
              "language": "en",
              "text": "Please submit the travel expenses to accounting by Friday."
            },
            {
              "language": "fa",
              "text": "لطفاً هزینه‌های سفر را تا جمعه به حسابداری ارائه کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe lêçûnên rêwîtiyê heta înê radestî hesabdarî bikin."
            },
            {
              "language": "pl",
              "text": "Proszę złożyć koszty podróży w księgowości do piątku."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să depuneți cheltuielile de călătorie la contabilitate până vineri."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, подайте командировочные расходы в бухгалтерию до пятницы."
            },
            {
              "language": "sq",
              "text": "Ju lutem dorëzoni shpenzimet e udhëtimit në kontabilitet deri të premten."
            },
            {
              "language": "tr",
              "text": "Lütfen seyahat masraflarını cumaya kadar muhasebeye teslim edin."
            }
          ]
        },
        {
          "baseText": "Die Firma übernimmt die Reisekosten für das Seminar.",
          "translations": [
            {
              "language": "ar",
              "text": "تتحمل الشركة تكاليف السفر للندوة."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە تێچووی گەشت بۆ سیمینارەکە وەردەگرێت."
            },
            {
              "language": "en",
              "text": "The company covers the travel expenses for the seminar."
            },
            {
              "language": "fa",
              "text": "شرکت هزینه‌های سفر برای سمینار را پرداخت می‌کند."
            },
            {
              "language": "kmr",
              "text": "Şîrket lêçûnên rêwîtiyê ji bo semînerê digire ser xwe."
            },
            {
              "language": "pl",
              "text": "Firma pokrywa koszty podróży na seminarium."
            },
            {
              "language": "ro",
              "text": "Firma acoperă cheltuielile de călătorie pentru seminar."
            },
            {
              "language": "ru",
              "text": "Компания покрывает дорожные расходы на семинар."
            },
            {
              "language": "sq",
              "text": "Kompania mbulon shpenzimet e udhëtimit për seminarin."
            },
            {
              "language": "tr",
              "text": "Şirket seminer için seyahat masraflarını karşılıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "reiten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "reiten",
      "pronunciationIpa": null,
      "syllableBreak": "rei-ten",
      "topics": [
        "everyday-life",
        "social-and-relationships",
        "transport-and-travel"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "irregular verb: reitet, ritt, geritten"
      ],
      "collocations": [
        {
          "text": "ein Pferd reiten",
          "meaning": "to ride a horse"
        },
        {
          "text": "reiten lernen",
          "meaning": "to learn horse riding"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Reiter",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Reiterin",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يركب الخيل"
        },
        {
          "language": "ckb",
          "text": "سواری ئەسپ دەکات"
        },
        {
          "language": "en",
          "text": "to ride a horse"
        },
        {
          "language": "fa",
          "text": "اسب‌سواری کردن"
        },
        {
          "language": "kmr",
          "text": "hesp siwar bûn"
        },
        {
          "language": "pl",
          "text": "jeździć konno"
        },
        {
          "language": "ro",
          "text": "a călări"
        },
        {
          "language": "ru",
          "text": "ездить верхом; кататься на лошади"
        },
        {
          "language": "sq",
          "text": "të kalërosh"
        },
        {
          "language": "tr",
          "text": "ata binmek"
        }
      ],
      "examples": [
        {
          "baseText": "Am Wochenende lernt meine Tochter reiten.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع تتعلم ابنتي ركوب الخيل."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا کچەکەم فێری سواری ئەسپ دەبێت."
            },
            {
              "language": "en",
              "text": "On weekends, my daughter learns to ride horses."
            },
            {
              "language": "fa",
              "text": "آخر هفته‌ها دخترم اسب‌سواری یاد می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Dawiya hefteyê keça min fêrî hesp siwarbûnê dibe."
            },
            {
              "language": "pl",
              "text": "W weekend moja córka uczy się jeździć konno."
            },
            {
              "language": "ro",
              "text": "În weekend, fiica mea învață să călărească."
            },
            {
              "language": "ru",
              "text": "По выходным моя дочь учится ездить верхом."
            },
            {
              "language": "sq",
              "text": "Në fundjavë vajza ime mëson të kalërojë."
            },
            {
              "language": "tr",
              "text": "Kızım hafta sonları ata binmeyi öğreniyor."
            }
          ]
        },
        {
          "baseText": "Im Urlaub sind wir einmal am Strand geritten.",
          "translations": [
            {
              "language": "ar",
              "text": "في الإجازة ركبنا الخيل مرة على الشاطئ."
            },
            {
              "language": "ckb",
              "text": "لە پشوودا جارێک لە کەنار دەریا سواری ئەسپ بووین."
            },
            {
              "language": "en",
              "text": "On vacation, we once rode horses on the beach."
            },
            {
              "language": "fa",
              "text": "در تعطیلات یک بار کنار ساحل اسب‌سواری کردیم."
            },
            {
              "language": "kmr",
              "text": "Di betlaneyê de carekê li peravê me hesp siwar bû."
            },
            {
              "language": "pl",
              "text": "Na urlopie raz jeździliśmy konno po plaży."
            },
            {
              "language": "ro",
              "text": "În vacanță am călărit o dată pe plajă."
            },
            {
              "language": "ru",
              "text": "В отпуске мы однажды катались на лошадях по пляжу."
            },
            {
              "language": "sq",
              "text": "Në pushime kalëruam një herë në plazh."
            },
            {
              "language": "tr",
              "text": "Tatilde bir kez sahilde ata bindik."
            }
          ]
        }
      ]
    },
