  "entries": [
    {
      "word": "die Lieferengpässe",
      "language": "de",
      "cefrLevel": "B2",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Lieferengpässe",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Lie-fer-eng-päs-se",
      "topics": [
        "procurement-and-suppliers",
        "warehouse-and-logistics",
        "quality-and-risk"
      ],
      "usageLabels": [
        "business",
        "formal",
        "reporting"
      ],
      "contextLabels": [
        "procurement",
        "logistics",
        "risk"
      ],
      "grammarNotes": [
        "plural noun; singular: der Lieferengpass",
        "used for shortages or bottlenecks in delivery"
      ],
      "collocations": [
        {
          "text": "Lieferengpässe vermeiden",
          "meaning": "to avoid supply bottlenecks"
        },
        {
          "text": "wegen Lieferengpässen",
          "meaning": "due to supply shortages"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Lieferengpass",
          "relationLabel": "singular",
          "note": null
        },
        {
          "lemma": "liefern",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "اختناقات في التسليم؛ نقص في الإمدادات"
        },
        {
          "language": "ckb",
          "text": "کێشەی گەیاندن؛ کەمی دابینکردن"
        },
        {
          "language": "en",
          "text": "supply bottlenecks; delivery shortages"
        },
        {
          "language": "fa",
          "text": "تنگناهای تأمین؛ کمبود در تحویل"
        },
        {
          "language": "kmr",
          "text": "astengiyên radestkirinê"
        },
        {
          "language": "pl",
          "text": "wąskie gardła dostaw; braki w dostawach"
        },
        {
          "language": "ro",
          "text": "blocaje de livrare; lipsuri de aprovizionare"
        },
        {
          "language": "ru",
          "text": "перебои с поставками; дефицит поставок"
        },
        {
          "language": "sq",
          "text": "ngushtica furnizimi; vonesa në dërgesa"
        },
        {
          "language": "tr",
          "text": "tedarik darboğazları; teslimat sıkıntıları"
        }
      ],
      "examples": [
        {
          "baseText": "Wegen Lieferengpässen kann der Hersteller die Ersatzteile erst nächste Woche schicken.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب اختناقات في التسليم لا يستطيع المصنّع إرسال قطع الغيار إلا الأسبوع القادم."
            },
            {
              "language": "ckb",
              "text": "بەهۆی کێشەی گەیاندن، بەرهەمهێنەر تەنها هەفتەی داهاتوو دەتوانێت پارچەی یەدەک بنێرێت."
            },
            {
              "language": "en",
              "text": "Due to supply bottlenecks, the manufacturer can only send the spare parts next week."
            },
            {
              "language": "fa",
              "text": "به دلیل تنگناهای تأمین، تولیدکننده فقط هفته آینده می‌تواند قطعات یدکی را ارسال کند."
            },
            {
              "language": "kmr",
              "text": "Ji ber astengiyên radestkirinê, hilberîner dikare parçeyên yedek tenê hefteya bê bişîne."
            },
            {
              "language": "pl",
              "text": "Z powodu braków w dostawach producent może wysłać części zamienne dopiero w przyszłym tygodniu."
            },
            {
              "language": "ro",
              "text": "Din cauza blocajelor de livrare, producătorul poate trimite piesele de schimb abia săptămâna viitoare."
            },
            {
              "language": "ru",
              "text": "Из-за перебоев с поставками производитель сможет отправить запчасти только на следующей неделе."
            },
            {
              "language": "sq",
              "text": "Për shkak të ngushticave të furnizimit, prodhuesi mund t’i dërgojë pjesët rezervë vetëm javën tjetër."
            },
            {
              "language": "tr",
              "text": "Tedarik darboğazları nedeniyle üretici yedek parçaları ancak gelecek hafta gönderebilir."
            }
          ]
        },
        {
          "baseText": "Der Einkauf informiert die Kunden frühzeitig über mögliche Lieferengpässe.",
          "translations": [
            {
              "language": "ar",
              "text": "يبلغ قسم المشتريات العملاء مبكرًا باحتمال حدوث اختناقات في التسليم."
            },
            {
              "language": "ckb",
              "text": "بەشی کڕین کڕیاران زوو ئاگادار دەکاتەوە لەسەر ئەگەری کێشەی گەیاندن."
            },
            {
              "language": "en",
              "text": "Procurement informs customers early about possible supply bottlenecks."
            },
            {
              "language": "fa",
              "text": "واحد خرید مشتریان را زودهنگام از تنگناهای احتمالی تأمین مطلع می‌کند."
            },
            {
              "language": "kmr",
              "text": "Beşa kirînê xerîdaran zû li ser astengiyên gengaz ên radestkirinê agahdar dike."
            },
            {
              "language": "pl",
              "text": "Dział zakupów wcześnie informuje klientów o możliwych brakach w dostawach."
            },
            {
              "language": "ro",
              "text": "Departamentul de achiziții informează din timp clienții despre posibile blocaje de livrare."
            },
            {
              "language": "ru",
              "text": "Отдел закупок заранее информирует клиентов о возможных перебоях с поставками."
            },
            {
              "language": "sq",
              "text": "Departamenti i blerjeve i informon herët klientët për ngushtica të mundshme furnizimi."
            },
            {
              "language": "tr",
              "text": "Satın alma bölümü müşterileri olası tedarik darboğazları hakkında erkenden bilgilendirir."
            }
          ]
        }
      ]
    },
