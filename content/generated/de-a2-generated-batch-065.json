        {
          "baseText": "Der Tisch ist zwei Meter lang.",
          "translations": [
            {
              "language": "ar",
              "text": "الطاولة طولها متران."
            },
            {
              "language": "ckb",
              "text": "مێزەکە دوو مەتر درێژە."
            },
            {
              "language": "en",
              "text": "The table is two meters long."
            },
            {
              "language": "fa",
              "text": "میز دو متر طول دارد."
            },
            {
              "language": "kmr",
              "text": "Mase du metre dirêj e."
            },
            {
              "language": "pl",
              "text": "Stół ma dwa metry długości."
            },
            {
              "language": "ro",
              "text": "Masa are doi metri lungime."
            },
            {
              "language": "ru",
              "text": "Стол длиной два метра."
            },
            {
              "language": "sq",
              "text": "Tavolina është dy metra e gjatë."
            },
            {
              "language": "tr",
              "text": "Masa iki metre uzunluğunda."
            }
          ]
        },
        {
          "baseText": "Ich brauche drei Meter Stoff.",
          "translations": [
            {
              "language": "ar",
              "text": "أحتاج إلى ثلاثة أمتار من القماش."
            },
            {
              "language": "ckb",
              "text": "پێویستم بە سێ مەتر قوماش هەیە."
            },
            {
              "language": "en",
              "text": "I need three meters of fabric."
            },
            {
              "language": "fa",
              "text": "به سه متر پارچه نیاز دارم."
            },
            {
              "language": "kmr",
              "text": "Ez hewceyê sê metre qumaş im."
            },
            {
              "language": "pl",
              "text": "Potrzebuję trzech metrów materiału."
            },
            {
              "language": "ro",
              "text": "Am nevoie de trei metri de material."
            },
            {
              "language": "ru",
              "text": "Мне нужно три метра ткани."
            },
            {
              "language": "sq",
              "text": "Më duhen tre metra pëlhurë."
            },
            {
              "language": "tr",
              "text": "Üç metre kumaşa ihtiyacım var."
            }
