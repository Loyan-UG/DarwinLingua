  "entries": [
    {
      "word": "die Abteilung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Abteilungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ab-tei-lung",
      "topics": [
        "work-and-jobs",
        "business-communication",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "formal",
        "spoken"
      ],
      "contextLabels": [
        "management",
        "hr",
        "administration"
      ],
      "grammarNotes": [
        "feminine noun",
        "means a department or division in an organization"
      ],
      "collocations": [
        {
          "text": "in einer Abteilung arbeiten",
          "meaning": "to work in a department"
        },
        {
          "text": "die zuständige Abteilung",
          "meaning": "the responsible department"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "abteilen",
          "relationLabel": "verb",
          "note": "less common in everyday use"
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قسم؛ إدارة؛ وحدة داخل مؤسسة"
        },
        {
          "language": "ckb",
          "text": "بەش؛ بەشی ناو دامەزراوە"
        },
        {
          "language": "en",
          "text": "department; division"
        },
        {
          "language": "fa",
          "text": "بخش؛ دپارتمان؛ واحد سازمانی"
        },
        {
          "language": "kmr",
          "text": "beş; yekîneya rêxistinê"
        },
        {
          "language": "pl",
          "text": "dział; oddział"
        },
        {
          "language": "ro",
          "text": "departament; secție"
        },
        {
          "language": "ru",
          "text": "отдел; подразделение"
        },
        {
          "language": "sq",
          "text": "departament; sektor"
        },
        {
          "language": "tr",
          "text": "bölüm; departman"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schicken Sie die Rechnung an die zuständige Abteilung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال الفاتورة إلى القسم المسؤول."
            },
            {
              "language": "ckb",
              "text": "تکایە فاکتورەکە بۆ بەشی بەرپرسیار بنێرن."
            },
            {
              "language": "en",
              "text": "Please send the invoice to the responsible department."
            },
            {
              "language": "fa",
              "text": "لطفاً فاکتور را برای بخش مسئول ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fatûreyê ji beşa berpirsiyar re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę wysłać fakturę do właściwego działu."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să trimiteți factura departamentului responsabil."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте счёт в ответственный отдел."
            },
            {
              "language": "sq",
              "text": "Ju lutem dërgojeni faturën te departamenti përgjegjës."
            },
            {
              "language": "tr",
              "text": "Lütfen faturayı sorumlu departmana gönderin."
            }
          ]
        },
        {
          "baseText": "In unserer Abteilung arbeiten zwölf Personen im Schichtdienst.",
          "translations": [
            {
              "language": "ar",
              "text": "يعمل في قسمنا اثنا عشر شخصًا بنظام المناوبات."
            },
            {
              "language": "ckb",
              "text": "لە بەشەکەماندا دوازدە کەس بە سیستەمی شیفت کار دەکەن."
            },
            {
              "language": "en",
              "text": "Twelve people work shifts in our department."
            },
            {
              "language": "fa",
              "text": "در بخش ما دوازده نفر به‌صورت شیفتی کار می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Di beşa me de diwanzdeh kes bi nobet dixebitin."
            },
            {
              "language": "pl",
              "text": "W naszym dziale dwanaście osób pracuje zmianowo."
            },
            {
              "language": "ro",
              "text": "În departamentul nostru lucrează douăsprezece persoane în ture."
            },
            {
              "language": "ru",
              "text": "В нашем отделе двенадцать человек работают посменно."
            },
            {
              "language": "sq",
              "text": "Në departamentin tonë punojnë dymbëdhjetë persona me turne."
            },
            {
              "language": "tr",
              "text": "Bizim bölümde on iki kişi vardiyalı çalışıyor."
            }
          ]
        }
      ]
    },
    {
      "word": "der Abteilungsleiter",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Abteilungsleiter",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Ab-tei-lungs-lei-ter",
      "topics": [
        "work-and-jobs",
        "management-and-leadership",
        "business-communication"
      ],
      "usageLabels": [
        "business",
        "formal"
      ],
      "contextLabels": [
        "management",
        "hr"
      ],
      "grammarNotes": [
        "masculine noun",
        "male head of a department; plural unchanged"
      ],
      "collocations": [
        {
          "text": "mit dem Abteilungsleiter sprechen",
          "meaning": "to speak with the department head"
        },
        {
          "text": "der neue Abteilungsleiter",
          "meaning": "the new department head"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Abteilungsleiterin",
          "relationLabel": "feminine form",
          "note": null
        },
        {
          "lemma": "die Abteilung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "رئيس القسم؛ مدير القسم"
        },
        {
          "language": "ckb",
          "text": "بەڕێوەبەری بەش؛ سەرۆکی بەش"
        },
        {
          "language": "en",
          "text": "department head; department manager"
        },
        {
          "language": "fa",
          "text": "مدیر بخش؛ رئیس دپارتمان"
        },
        {
          "language": "kmr",
          "text": "serokê beşê; rêveberê beşê"
        },
        {
          "language": "pl",
          "text": "kierownik działu"
        },
        {
          "language": "ro",
          "text": "șef de departament; manager de departament"
        },
        {
          "language": "ru",
          "text": "руководитель отдела; начальник отдела"
        },
        {
          "language": "sq",
          "text": "drejtues departamenti; shef sektori"
        },
        {
          "language": "tr",
          "text": "bölüm müdürü; departman yöneticisi"
        }
      ],
      "examples": [
        {
          "baseText": "Der Abteilungsleiter entscheidet, wer an der Schulung teilnimmt.",
          "translations": [
            {
              "language": "ar",
              "text": "يقرر مدير القسم من سيشارك في التدريب."
            },
            {
              "language": "ckb",
              "text": "بەڕێوەبەری بەش بڕیار دەدات کێ بەشداری راهێنانەکە دەکات."
            },
            {
              "language": "en",
              "text": "The department manager decides who takes part in the training."
            },
            {
              "language": "fa",
              "text": "مدیر بخش تصمیم می‌گیرد چه کسی در دوره آموزشی شرکت کند."
            },
            {
              "language": "kmr",
              "text": "Rêveberê beşê biryar dide ka kî beşdarî perwerdehiyê dibe."
            },
            {
