      ],
      "grammarNotes": [
        "neuter noun"
      ],
      "collocations": [
        {
          "text": "das Journal prüfen",
          "meaning": "to check the journal"
        },
        {
          "text": "ein Journal exportieren",
          "meaning": "to export a journal"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دفتر اليومية؛ سجل"
        },
        {
          "language": "ckb",
          "text": "ژوورنال؛ تۆمار"
        },
        {
          "language": "en",
          "text": "journal; log"
        },
        {
          "language": "fa",
          "text": "دفتر روزنامه؛ گزارش ثبت"
        },
        {
          "language": "kmr",
          "text": "rojnameya hesabê; tomar"
        },
        {
          "language": "pl",
          "text": "dziennik; rejestr"
        },
        {
          "language": "ro",
          "text": "jurnal; registru"
        },
        {
          "language": "ru",
          "text": "журнал; регистр"
        },
        {
          "language": "sq",
          "text": "ditar; regjistër"
        },
        {
          "language": "tr",
          "text": "yevmiye defteri; kayıt günlüğü"
        }
      ],
      "examples": [
        {
          "baseText": "Die Buchungen stehen im Journal des ERP-Systems.",
          "translations": [
            {
              "language": "ar",
              "text": "القيود موجودة في دفتر اليومية في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "تۆمارکردنەکان لە ژوورنالی سیستەمی ERPدا هەن."
            },
            {
              "language": "en",
              "text": "The postings are in the ERP system journal."
            },
            {
              "language": "fa",
              "text": "ثبت‌ها در ژورنال سیستم ERP هستند."
            },
            {
              "language": "kmr",
              "text": "Tomarkirin di journala pergala ERP de ne."
            },
            {
              "language": "pl",
              "text": "Księgowania są w dzienniku systemu ERP."
            },
            {
              "language": "ro",
              "text": "Înregistrările sunt în jurnalul sistemului ERP."
            },
            {
              "language": "ru",
              "text": "Проводки находятся в журнале ERP-системы."
            },
            {
              "language": "sq",
              "text": "Regjistrimet janë në ditarin e sistemit ERP."
            },
            {
              "language": "tr",
              "text": "Kayıtlar ERP sisteminin yevmiye defterinde yer alıyor."
            }
          ]
        },
        {
          "baseText": "Ich notiere die wichtigsten Punkte in meinem Journal.",
          "translations": [
            {
              "language": "ar",
              "text": "أدوّن أهم النقاط في دفتري."
            },
            {
              "language": "ckb",
              "text": "گرنگترین خاڵەکان لە ژوورنالەکەمدا دەنوسم."
            },
            {
              "language": "en",
              "text": "I write the most important points in my journal."
            },
            {
              "language": "fa",
              "text": "مهم‌ترین نکات را در دفترم یادداشت می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez xalên herî girîng di deftera xwe de dinivîsim."
            },
            {
              "language": "pl",
              "text": "Zapisuję najważniejsze punkty w swoim dzienniku."
            },
            {
              "language": "ro",
              "text": "Notez cele mai importante puncte în jurnalul meu."
            },
            {
              "language": "ru",
              "text": "Я записываю самые важные пункты в своем журнале."
            },
            {
              "language": "sq",
              "text": "I shënoj pikat më të rëndësishme në ditarin tim."
            },
            {
              "language": "tr",
              "text": "En önemli noktaları günlüğüme not ediyorum."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "B1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "die Kalkulation",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Kalkulationen",
      "infinitive": null,
      "syllableBreak": "Kal-ku-la-ti-on",
      "topics": [
        "finance-and-accounting",
        "sales-and-customers",
        "data-and-reporting"
      ],
      "usageLabels": [
        "business",
        "technical",
        "written"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Kalkulation erstellen",
          "meaning": "to create a calculation or cost estimate"
        },
        {
          "text": "die Kalkulation prüfen",
          "meaning": "to check the calculation"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "kalkulieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "حساب؛ تقدير تكلفة"
        },
        {
          "language": "ckb",
          "text": "خەمڵاندنی تێچوو؛ حیسابکردن"
        },
        {
          "language": "en",
          "text": "calculation; cost estimate"
        },
        {
          "language": "fa",
          "text": "محاسبه؛ برآورد هزینه"
        },
        {
          "language": "kmr",
          "text": "hesabkirin; texmîna mesrefê"
        },
        {
          "language": "pl",
          "text": "kalkulacja; wycena"
        },
        {
          "language": "ro",
          "text": "calculație; estimare de cost"
        },
        {
          "language": "ru",
          "text": "калькуляция; расчет"
        },
        {
          "language": "sq",
          "text": "kalkulim; vlerësim kostoje"
        },
        {
          "language": "tr",
          "text": "hesaplama; maliyet tahmini"
        }
      ],
      "examples": [
        {
          "baseText": "Die Kalkulation für den Auftrag ist im ERP-System gespeichert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم حفظ حساب تكلفة الطلب في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "خەمڵاندنی تێچووی داواکارییەکە لە سیستەمی ERPدا پاشەکەوت کراوە."
            },
            {
              "language": "en",
              "text": "The cost estimate for the order is saved in the ERP system."
            },
            {
              "language": "fa",
              "text": "برآورد هزینه سفارش در سیستم ERP ذخیره شده است."
            },
            {
              "language": "kmr",
              "text": "Texmîna mesrefê ya fermarişê di pergala ERP de hatiye tomarkirin."
            },
            {
              "language": "pl",
              "text": "Kalkulacja dla zamówienia jest zapisana w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Calculația pentru comandă este salvată în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Калькуляция по заказу сохранена в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Kalkulimi për porosinë është ruajtur në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Sipariş için maliyet hesabı ERP sisteminde kayıtlı."
            }
          ]
        },
        {
          "baseText": "Vor dem Angebot brauchen wir eine genaue Kalkulation.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل العرض نحتاج إلى حساب دقيق للتكلفة."
            },
            {
              "language": "ckb",
              "text": "پێش پێشنیارەکە پێویستمان بە خەمڵاندنێکی وردە."
            },
            {
              "language": "en",
              "text": "Before the offer, we need an exact cost estimate."
            },
            {
              "language": "fa",
              "text": "قبل از ارائه پیشنهاد، به یک برآورد دقیق نیاز داریم."
            },
            {
              "language": "kmr",
              "text": "Berî pêşniyarê em hewceyê texmînek rast in."
            },
            {
              "language": "pl",
              "text": "Przed ofertą potrzebujemy dokładnej kalkulacji."
            },
            {
              "language": "ro",
              "text": "Înainte de ofertă avem nevoie de o calculație exactă."
            },
            {
              "language": "ru",
              "text": "Перед предложением нам нужен точный расчет."
            },
            {
              "language": "sq",
              "text": "Para ofertës na duhet një kalkulim i saktë."
            },
            {
              "language": "tr",
              "text": "Tekliften önce kesin bir maliyet hesabına ihtiyacımız var."
            }
          ]
        }
      ]
    },
