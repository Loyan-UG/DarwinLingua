      ],
      "examples": [
        {
          "baseText": "Nach dem Wareneingang erzeugt das ERP automatisch eine Bestandsbuchung.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد استلام البضائع ينشئ ERP قيد مخزون تلقائيًا."
            },
            {
              "language": "ckb",
