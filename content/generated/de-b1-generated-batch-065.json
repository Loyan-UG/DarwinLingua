      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "neuter noun; often used with haben"
      ],
      "collocations": [
        {
          "text": "ein gutes Gefühl haben",
          "meaning": "to have a good feeling"
        },
        {
          "text": "das Gefühl haben, dass ...",
          "meaning": "to feel that ..."
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fühlen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "gefühlvoll",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "شعور؛ إحساس"
        },
        {
          "language": "ckb",
          "text": "هەست؛ سۆز"
        },
        {
          "language": "en",
          "text": "feeling; emotion"
        },
        {
          "language": "fa",
          "text": "احساس؛ حس"
        },
        {
          "language": "kmr",
          "text": "hest; hes"
        },
        {
          "language": "pl",
          "text": "uczucie; odczucie"
        },
        {
          "language": "ro",
          "text": "sentiment; senzație"
        },
        {
          "language": "ru",
          "text": "чувство; ощущение"
        },
        {
          "language": "sq",
          "text": "ndjenjë; përshtypje"
        },
        {
          "language": "tr",
          "text": "duygu; his"
        }
      ],
      "examples": [
        {
          "baseText": "Ich habe das Gefühl, dass der Kunde noch unsicher ist.",
          "translations": [
            {
              "language": "ar",
              "text": "لدي شعور بأن العميل ما زال غير متأكد."
            },
            {
              "language": "ckb",
              "text": "هەستم وایە کڕیارەکە هێشتا دڵنیا نییە."
            },
            {
              "language": "en",
              "text": "I have the feeling that the customer is still unsure."
            },
            {
              "language": "fa",
              "text": "احساس می‌کنم مشتری هنوز مطمئن نیست."
            },
            {
              "language": "kmr",
              "text": "Hesta min ew e ku xerîdar hîn ne bawer e."
            },
            {
              "language": "pl",
              "text": "Mam wrażenie, że klient nadal nie jest pewien."
            },
            {
              "language": "ro",
              "text": "Am sentimentul că clientul este încă nesigur."
            },
            {
              "language": "ru",
              "text": "У меня ощущение, что клиент всё еще не уверен."
            },
            {
              "language": "sq",
              "text": "Kam ndjesinë se klienti është ende i pasigurt."
            },
            {
              "language": "tr",
              "text": "Müşterinin hâlâ emin olmadığını hissediyorum."
            }
          ]
        },
        {
          "baseText": "Nach dem Gespräch hatte sie ein besseres Gefühl.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد المحادثة أصبح لديها شعور أفضل."
            },
            {
              "language": "ckb",
              "text": "دوای گفتوگۆکە هەستێکی باشتر هەبوو."
            },
            {
              "language": "en",
              "text": "After the conversation, she felt better about it."
            },
            {
              "language": "fa",
              "text": "بعد از گفت‌وگو احساس بهتری داشت."
            },
            {
              "language": "kmr",
              "text": "Piştî axaftinê wê hesteke çêtir hebû."
            },
            {
              "language": "pl",
              "text": "Po rozmowie miała lepsze odczucie."
            },
            {
              "language": "ro",
              "text": "După discuție, ea a avut un sentiment mai bun."
            },
            {
              "language": "ru",
              "text": "После разговора у неё было лучшее чувство."
            },
            {
              "language": "sq",
              "text": "Pas bisedës ajo kishte një ndjenjë më të mirë."
            },
            {
              "language": "tr",
              "text": "Görüşmeden sonra daha iyi hissetti."
            }
          ]
        }
      ]
    },
