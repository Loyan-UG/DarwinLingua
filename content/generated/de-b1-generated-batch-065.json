      "examples": [
        {
          "baseText": "Das Gehalt wird immer am Ende des Monats überwiesen.",
          "translations": [
            {
              "language": "ar",
              "text": "يتم تحويل الراتب دائماً في نهاية الشهر."
            },
            {
              "language": "ckb",
              "text": "مووچەکە هەمیشە لە کۆتایی مانگدا دەگوازرێتەوە."
            },
            {
              "language": "en",
              "text": "The salary is always transferred at the end of the month."
            },
            {
              "language": "fa",
              "text": "حقوق همیشه در پایان ماه واریز می‌شود."
            },
            {
              "language": "kmr",
              "text": "Meaş her tim di dawiya mehê de tê veguhestin."
            },
            {
              "language": "pl",
              "text": "Pensja jest zawsze przelewana pod koniec miesiąca."
            },
            {
              "language": "ro",
              "text": "Salariul este virat întotdeauna la sfârșitul lunii."
            },
            {
              "language": "ru",
              "text": "Зарплата всегда перечисляется в конце месяца."
            },
