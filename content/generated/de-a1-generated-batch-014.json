          "language": "sq",
          "text": "të fillosh"
        },
        {
          "language": "tr",
          "text": "başlamak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kurs beginnt um neun Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "تبدأ الدورة في الساعة التاسعة."
            },
            {
              "language": "ckb",
              "text": "خولەکە کاتژمێر نۆ دەست پێدەکات."
            },
            {
              "language": "en",
              "text": "The course starts at nine o’clock."
            },
            {
              "language": "fa",
              "text": "دوره ساعت نه شروع می‌شود."
            },
            {
              "language": "kmr",
              "text": "Kurs di saet nehan de dest pê dike."
            },
            {
              "language": "pl",
              "text": "Kurs zaczyna się o dziewiątej."
            },
            {
              "language": "ro",
              "text": "Cursul începe la ora nouă."
            },
            {
              "language": "ru",
              "text": "Курс начинается в девять часов."
            },
            {
              "language": "sq",
              "text": "Kursi fillon në orën nëntë."
            },
            {
              "language": "tr",
              "text": "Kurs saat dokuzda başlıyor."
            }
          ]
        },
        {
          "baseText": "Wir beginnen jetzt mit der Aufgabe.",
          "translations": [
            {
              "language": "ar",
              "text": "نبدأ الآن بالمهمة."
            },
            {
              "language": "ckb",
              "text": "ئێستا بە ئەرکەکە دەست پێدەکەین."
            },
            {
              "language": "en",
              "text": "We are starting the task now."
            },
            {
              "language": "fa",
              "text": "الان تمرین را شروع می‌کنیم."
            },
            {
              "language": "kmr",
              "text": "Em niha bi erkê dest pê dikin."
            },
            {
              "language": "pl",
              "text": "Zaczynamy teraz zadanie."
            },
            {
              "language": "ro",
              "text": "Începem acum sarcina."
            },
            {
              "language": "ru",
              "text": "Мы сейчас начинаем задание."
            },
            {
              "language": "sq",
              "text": "Po fillojmë tani me detyrën."
            },
            {
              "language": "tr",
              "text": "Şimdi göreve başlıyoruz."
            }
          ]
        }
      ]
    },
