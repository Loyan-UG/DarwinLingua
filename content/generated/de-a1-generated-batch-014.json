      "meanings": [
        {
          "language": "ar",
          "text": "يبدأ"
        },
        {
          "language": "ckb",
          "text": "دەست پێدەکات"
        },
        {
          "language": "en",
          "text": "to begin; to start"
        },
        {
          "language": "fa",
          "text": "شروع شدن؛ آغاز کردن"
        },
        {
