        },
        {
          "language": "fa",
          "text": "خطر؛ ریسک"
        },
        {
          "language": "kmr",
          "text": "metirsî"
        },
        {
          "language": "pl",
          "text": "niebezpieczeństwo; zagrożenie"
        },
        {
          "language": "ro",
          "text": "pericol; risc"
        },
        {
          "language": "ru",
          "text": "опасность; риск"
        },
        {
          "language": "sq",
          "text": "rrezik"
        },
        {
          "language": "tr",
          "text": "tehlike; risk"
        }
      ],
      "examples": [
        {
          "baseText": "Bei starkem Regen besteht Gefahr auf der Straße.",
          "translations": [
            {
              "language": "ar",
              "text": "في المطر الشديد يوجد خطر على الطريق."
            },
            {
              "language": "ckb",
              "text": "لە بارانی زۆردا لەسەر ڕێگا مەترسی هەیە."
            },
            {
              "language": "en",
              "text": "In heavy rain there is danger on the road."
            },
            {
              "language": "fa",
              "text": "در باران شدید در جاده خطر وجود دارد."
            },
            {
              "language": "kmr",
              "text": "Di barana zêde de li ser rê metirsî heye."
            },
            {
              "language": "pl",
              "text": "Przy silnym deszczu na drodze jest niebezpiecznie."
            },
            {
              "language": "ro",
              "text": "Pe ploaie puternică există pericol pe drum."
            },
            {
              "language": "ru",
              "text": "При сильном дожде на дороге есть опасность."
            },
            {
              "language": "sq",
              "text": "Në shi të fortë ka rrezik në rrugë."
            },
            {
              "language": "tr",
              "text": "Şiddetli yağmurda yolda tehlike vardır."
            }
          ]
        },
        {
          "baseText": "Bitte bleiben Sie hier, es gibt keine Gefahr.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى البقاء هنا، لا يوجد خطر."
            },
            {
              "language": "ckb",
              "text": "تکایە لێرە بمێننەوە، هیچ مەترسییەک نییە."
            },
            {
              "language": "en",
              "text": "Please stay here; there is no danger."
            },
            {
              "language": "fa",
              "text": "لطفاً اینجا بمانید، خطری وجود ندارد."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li vir bimînin, metirsî tune ye."
            },
            {
              "language": "pl",
              "text": "Proszę zostać tutaj, nie ma niebezpieczeństwa."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să rămâneți aici, nu există pericol."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, оставайтесь здесь, опасности нет."
            },
            {
              "language": "sq",
              "text": "Ju lutemi qëndroni këtu, nuk ka rrezik."
            },
            {
              "language": "tr",
              "text": "Lütfen burada kalın, tehlike yok."
            }
          ]
        }
      ]
    },
