      ],
      "examples": [
        {
          "baseText": "Das neue Sofa gefällt mir sehr.",
          "translations": [
            {
              "language": "ar",
              "text": "الأريكة الجديدة تعجبني كثيراً."
            },
            {
              "language": "ckb",
              "text": "قەنەفە نوێیەکە زۆر پێم خۆشە."
            },
            {
              "language": "en",
              "text": "I really like the new sofa."
            },
            {
              "language": "fa",
              "text": "مبل جدید خیلی به من می‌آید/خوشم می‌آید."
            },
            {
              "language": "kmr",
              "text": "Kanepeya nû gelek li min xweş tê."
            },
            {
              "language": "pl",
              "text": "Nowa sofa bardzo mi się podoba."
            },
            {
              "language": "ro",
              "text": "Îmi place foarte mult canapeaua nouă."
            },
            {
              "language": "ru",
              "text": "Мне очень нравится новый диван."
            },
            {
              "language": "sq",
              "text": "Më pëlqen shumë divani i ri."
            },
            {
              "language": "tr",
              "text": "Yeni kanepe çok hoşuma gidiyor."
            }
          ]
        },
        {
          "baseText": "Gefällt Ihnen die Farbe?",
          "translations": [
            {
              "language": "ar",
              "text": "هل يعجبك اللون؟"
            },
            {
              "language": "ckb",
              "text": "ڕەنگەکە پێتان خۆشە؟"
            },
            {
              "language": "en",
              "text": "Do you like the color?"
            },
            {
              "language": "fa",
              "text": "رنگش را می‌پسندید؟"
            },
            {
              "language": "kmr",
              "text": "Ev reng li we xweş tê?"
            },
            {
              "language": "pl",
              "text": "Czy podoba się pani/panu kolor?"
            },
            {
              "language": "ro",
              "text": "Vă place culoarea?"
            },
            {
              "language": "ru",
              "text": "Вам нравится цвет?"
            },
            {
              "language": "sq",
              "text": "A ju pëlqen ngjyra?"
            },
            {
              "language": "tr",
              "text": "Rengi beğendiniz mi?"
            }
          ]
        }
      ]
