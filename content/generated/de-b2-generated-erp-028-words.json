      "examples": [
        {
          "baseText": "Die Verladung wird im ERP erst abgeschlossen, wenn alle Ladeeinheiten gescannt wurden.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يتم إكمال التحميل في ERP إلا بعد مسح جميع وحدات التحميل."
            },
            {
              "language": "ckb",
              "text": "بارکردن لە ERP دا تەنها کاتێک تەواو دەکرێت کە هەموو یەکەکانی بارکردن سکان کرابن."
            },
            {
              "language": "en",
              "text": "Loading is completed in the ERP only when all loading units have been scanned."
            },
            {
              "language": "fa",
              "text": "بارگیری در ERP فقط وقتی تکمیل می‌شود که همه واحدهای بارگیری اسکن شده باشند."
            },
            {
              "language": "kmr",
              "text": "Barkirin di ERP de tenê dema hemû yekîneyên barkirinê hatine skenkirin tê qedandin."
            },
            {
              "language": "pl",
              "text": "Załadunek jest zamykany w ERP dopiero po zeskanowaniu wszystkich jednostek ładunkowych."
            },
            {
              "language": "ro",
              "text": "Încărcarea este finalizată în ERP doar după scanarea tuturor unităților de încărcare."
            },
            {
              "language": "ru",
              "text": "Погрузка завершается в ERP только после сканирования всех грузовых единиц."
            },
            {
              "language": "sq",
