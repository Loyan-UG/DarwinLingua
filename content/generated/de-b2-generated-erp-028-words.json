        "technical"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "adjective; describes goods or deliveries ready for loading"
      ],
      "collocations": [
        {
          "text": "verladebereit melden",
          "meaning": "to report as ready for loading"
        },
        {
          "text": "verladebereite Ware",
          "meaning": "goods ready for loading"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "verladen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "bereit",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "جاهز للتحميل"
        },
        {
          "language": "ckb",
          "text": "ئامادە بۆ بارکردن"
        },
        {
          "language": "en",
          "text": "ready for loading"
        },
        {
          "language": "fa",
          "text": "آماده بارگیری"
        },
        {
          "language": "kmr",
          "text": "amade ji bo barkirinê"
        },
        {
          "language": "pl",
          "text": "gotowy do załadunku"
        },
        {
          "language": "ro",
          "text": "gata de încărcare"
        },
        {
          "language": "ru",
          "text": "готовый к погрузке"
        },
        {
          "language": "sq",
          "text": "gati për ngarkim"
        },
        {
          "language": "tr",
          "text": "yüklemeye hazır"
        }
      ],
      "examples": [
        {
          "baseText": "Die Lieferung ist im ERP als verladebereit markiert.",
          "translations": [
            {
              "language": "ar",
              "text": "تم وسم التسليم في ERP بأنه جاهز للتحميل."
            },
            {
              "language": "ckb",
              "text": "گەیاندنەکە لە ERP دا وەک ئامادە بۆ بارکردن نیشان کراوە."
            },
            {
              "language": "en",
              "text": "The delivery is marked as ready for loading in the ERP."
            },
            {
              "language": "fa",
              "text": "تحویل در ERP به عنوان آماده بارگیری علامت خورده است."
            },
            {
              "language": "kmr",
              "text": "Radestkirin di ERP de wekî amade ji bo barkirinê hatiye nîşankirin."
            },
            {
              "language": "pl",
              "text": "Dostawa jest oznaczona w ERP jako gotowa do załadunku."
            },
            {
              "language": "ro",
              "text": "Livrarea este marcată în ERP ca gata de încărcare."
            },
            {
              "language": "ru",
              "text": "Поставка отмечена в ERP как готовая к погрузке."
            },
            {
              "language": "sq",
              "text": "Dërgesa është shënuar në ERP si gati për ngarkim."
            },
            {
              "language": "tr",
              "text": "Teslimat ERP’de yüklemeye hazır olarak işaretlendi."
            }
          ]
        },
        {
          "baseText": "Bitte rufen Sie die Spedition erst an, wenn alle Paletten verladebereit sind.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى الاتصال بشركة النقل فقط عندما تكون جميع المنصات جاهزة للتحميل."
            },
            {
              "language": "ckb",
              "text": "تکایە تەنها کاتێک پەیوەندی بە کۆمپانیای گواستنەوە بکەن کە هەموو پالێتەکان ئامادەی بارکردن بن."
            },
            {
              "language": "en",
              "text": "Please call the carrier only when all pallets are ready for loading."
            },
            {
              "language": "fa",
              "text": "لطفاً فقط وقتی با شرکت حمل‌ونقل تماس بگیرید که همه پالت‌ها آماده بارگیری باشند."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe tenê dema hemû palet amade ji bo barkirinê bin bi şirketa barkirinê re telefon bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zadzwonić do spedytora dopiero, gdy wszystkie palety będą gotowe do załadunku."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să sunați transportatorul doar când toți paleții sunt gata de încărcare."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, звоните перевозчику только когда все палеты готовы к погрузке."
            },
            {
              "language": "sq",
              "text": "Ju lutemi telefononi transportuesin vetëm kur të gjitha paletat të jenë gati për ngarkim."
            },
            {
              "language": "tr",
              "text": "Lütfen nakliye firmasını yalnızca tüm paletler yüklemeye hazır olduğunda arayın."
            }
          ]
        }
      ]
    },
    {
      "word": "Verladerampe",
      "language": "de",
      "cefrLevel": "B2",
