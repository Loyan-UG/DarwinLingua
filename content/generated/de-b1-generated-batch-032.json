  "entries": [
    {
      "word": "die Beschwerdestelle",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Beschwerdestellen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Be-schwer-de-stel-le",
      "topics": [
        "customer-service",
        "public-services",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "written"
      ],
      "contextLabels": [
        "customer-service",
        "support",
        "administration"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "sich an die Beschwerdestelle wenden",
          "meaning": "to contact the complaints office"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Beschwerde",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Stelle",
          "relationLabel": "compound part",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مكتب الشكاوى؛ جهة الشكاوى"
        },
        {
          "language": "ckb",
          "text": "شوێنی سکاڵا؛ بەشی سکاڵا"
        },
        {
          "language": "en",
          "text": "complaints office; complaints department"
        },
        {
          "language": "fa",
          "text": "مرکز رسیدگی به شکایات؛ واحد شکایات"
        },
        {
          "language": "kmr",
          "text": "beşa gilîyan; nivîsgeha gilîyan"
        },
        {
          "language": "pl",
          "text": "dział skarg; punkt przyjmowania skarg"
        },
        {
          "language": "ro",
          "text": "birou de reclamații; departament de reclamații"
        },
        {
          "language": "ru",
          "text": "отдел жалоб; служба по рассмотрению жалоб"
        },
        {
          "language": "sq",
          "text": "zyra e ankesave; departamenti i ankesave"
        },
        {
          "language": "tr",
          "text": "şikayet birimi; şikayet ofisi"
        }
      ],
      "examples": [
        {
          "baseText": "Wenn das Problem nicht gelöst wird, können Sie sich an die Beschwerdestelle wenden.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا لم تُحل المشكلة، يمكنك التوجه إلى مكتب الشكاوى."
            },
            {
              "language": "ckb",
              "text": "ئەگەر کێشەکە چارەسەر نەکرا، دەتوانیت پەیوەندی بە بەشی سکاڵا بکەیت."
            },
            {
              "language": "en",
              "text": "If the problem is not solved, you can contact the complaints office."
            },
            {
              "language": "fa",
              "text": "اگر مشکل حل نشود، می‌توانید به واحد شکایات مراجعه کنید."
            },
            {
              "language": "kmr",
              "text": "Heke pirsgirêk neyê çareserkirin, hûn dikarin serî li beşa gilîyan bidin."
            },
            {
              "language": "pl",
              "text": "Jeśli problem nie zostanie rozwiązany, można zwrócić się do działu skarg."
            },
            {
              "language": "ro",
              "text": "Dacă problema nu se rezolvă, vă puteți adresa biroului de reclamații."
            },
            {
              "language": "ru",
              "text": "Если проблема не будет решена, вы можете обратиться в отдел жалоб."
            },
            {
              "language": "sq",
              "text": "Nëse problemi nuk zgjidhet, mund t’i drejtoheni zyrës së ankesave."
            },
            {
              "language": "tr",
              "text": "Sorun çözülmezse şikayet birimine başvurabilirsiniz."
            }
          ]
        },
        {
          "baseText": "Die Beschwerdestelle hat meine E-Mail innerhalb von zwei Tagen beantwortet.",
          "translations": [
            {
              "language": "ar",
              "text": "أجاب مكتب الشكاوى على بريدي الإلكتروني خلال يومين."
            },
            {
              "language": "ckb",
              "text": "بەشی سکاڵا لە ماوەی دوو ڕۆژدا وەڵامی ئیمەیڵەکەمی دایەوە."
            },
            {
              "language": "en",
              "text": "The complaints office answered my email within two days."
            },
            {
              "language": "fa",
              "text": "واحد شکایات ظرف دو روز به ایمیل من پاسخ داد."
            },
            {
              "language": "kmr",
              "text": "Beşa gilîyan di nav du rojan de bersiva e-nameya min da."
            },
            {
              "language": "pl",
              "text": "Dział skarg odpowiedział na mój e-mail w ciągu dwóch dni."
            },
            {
              "language": "ro",
              "text": "Biroul de reclamații mi-a răspuns la e-mail în două zile."
            },
            {
              "language": "ru",
              "text": "Отдел жалоб ответил на мое письмо в течение двух дней."
            },
            {
              "language": "sq",
              "text": "Zyra e ankesave iu përgjigj emailit tim brenda dy ditësh."
            },
            {
              "language": "tr",
              "text": "Şikayet birimi e-postama iki gün içinde cevap verdi."
            }
          ]
        }
      ]
    },
    {
      "word": "beschweren",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beschweren",
      "pronunciationIpa": null,
      "syllableBreak": "be-schwe-ren",
      "topics": [
        "customer-service",
        "shopping-and-services",
        "business-communication"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "formal"
      ],
      "contextLabels": [
        "customer-service",
        "support"
      ],
      "grammarNotes": [
        "reflexive use: sich beschweren über + accusative"
      ],
      "collocations": [
        {
          "text": "sich über den Service beschweren",
          "meaning": "to complain about the service"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Beschwerde",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يشتكي؛ يتذمر"
        },
        {
          "language": "ckb",
          "text": "سکاڵا کردن؛ گازندە کردن"
        },
        {
          "language": "en",
          "text": "to complain"
        },
        {
          "language": "fa",
          "text": "شکایت کردن"
        },
        {
          "language": "kmr",
          "text": "gilî kirin; gazin kirin"
        },
        {
          "language": "pl",
          "text": "skarżyć się; reklamować"
        },
        {
          "language": "ro",
          "text": "a se plânge; a reclama"
        },
        {
          "language": "ru",
          "text": "жаловаться"
        },
        {
          "language": "sq",
          "text": "të ankohesh"
        },
        {
          "language": "tr",
          "text": "şikayet etmek"
        }
      ],
      "examples": [
        {
          "baseText": "Der Kunde möchte sich über die falsche Rechnung beschweren.",
          "translations": [
            {
              "language": "ar",
              "text": "يريد العميل أن يشتكي من الفاتورة الخاطئة."
            },
            {
              "language": "ckb",
              "text": "کڕیارەکە دەیەوێت لەسەر پسوولەی هەڵە سکاڵا بکات."
            },
            {
              "language": "en",
              "text": "The customer wants to complain about the incorrect invoice."
            },
            {
              "language": "fa",
              "text": "مشتری می‌خواهد درباره فاکتور اشتباه شکایت کند."
            },
            {
              "language": "kmr",
              "text": "Xerîdar dixwaze li ser fatûreya şaş gilî bike."
            },
            {
              "language": "pl",
              "text": "Klient chce złożyć skargę na błędną fakturę."
            },
            {
              "language": "ro",
              "text": "Clientul dorește să reclame factura greșită."
            },
            {
              "language": "ru",
              "text": "Клиент хочет пожаловаться на неправильный счет."
            },
            {
              "language": "sq",
              "text": "Klienti dëshiron të ankohet për faturën e gabuar."
            },
            {
              "language": "tr",
              "text": "Müşteri yanlış fatura hakkında şikayet etmek istiyor."
            }
          ]
        },
        {
          "baseText": "Ich beschwere mich nicht gern, aber das Paket ist wieder zu spät angekommen.",
          "translations": [
            {
              "language": "ar",
