  "entries": [
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "aufschreien",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufschreien",
      "syllableBreak": "auf-schrei-en",
      "topics": [
        "social-and-relationships",
        "public-services",
        "business-communication"
      ],
      "usageLabels": [
        "written",
        "spoken",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; literal or figurative public reaction"
      ],
      "collocations": [
        {
          "text": "vor Schmerz aufschreien",
          "meaning": "to cry out in pain"
        },
        {
          "text": "öffentlich aufschreien",
          "meaning": "to react with public outrage"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schreien",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يصرخ فجأة؛ يحتج بصوت عالٍ"
        },
        {
          "language": "ckb",
          "text": "لەناکاو هاوار دەکات؛ بە توندی ناڕەزایی دەردەبڕێت"
        },
        {
          "language": "en",
          "text": "to cry out; to protest loudly"
        },
        {
          "language": "fa",
          "text": "فریاد زدن؛ با اعتراض شدید واکنش نشان دادن"
        },
        {
          "language": "kmr",
          "text": "qîrîn; bi tundî nerazîbûn nîşan dan"
        },
        {
          "language": "pl",
          "text": "krzyknąć; głośno zaprotestować"
        },
        {
          "language": "ro",
          "text": "a striga; a protesta puternic"
        },
        {
          "language": "ru",
          "text": "вскрикнуть; громко возмутиться"
        },
        {
          "language": "sq",
          "text": "të bërtasësh; të protestosh fuqishëm"
        },
        {
          "language": "tr",
          "text": "çığlık atmak; yüksek sesle tepki göstermek"
        }
      ],
      "examples": [
        {
          "baseText": "Als die Kürzungen bekannt wurden, schrie die Belegschaft in der Betriebsversammlung förmlich auf.",
          "translations": [
            {
              "language": "ar",
              "text": "عندما أصبحت التخفيضات معروفة، احتج الموظفون بشدة في اجتماع العاملين."
            },
            {
              "language": "ckb",
              "text": "کاتێک کەمکردنەوەکان ئاشکرا بوون، کارمەندان لە کۆبوونەوەی کارگەدا بە توندی هاواری ناڕەزاییان کرد."
            },
            {
              "language": "en",
              "text": "When the cuts became known, the workforce virtually cried out in protest at the works meeting."
            },
            {
              "language": "fa",
              "text": "وقتی کاهش‌ها اعلام شد، کارکنان در مجمع شرکت عملاً با اعتراض شدید واکنش نشان دادند."
            },
            {
              "language": "kmr",
              "text": "Dema kêmkirin eşkere bûn, karmendan di civîna kargehê de bi rastî qîrîna nerazîbûnê kir."
            },
            {
              "language": "pl",
              "text": "Gdy cięcia stały się znane, załoga podczas zebrania zakładowego głośno zaprotestowała."
            },
            {
              "language": "ro",
              "text": "Când reducerile au devenit cunoscute, personalul a protestat puternic în adunarea de lucru."
            },
            {
              "language": "ru",
              "text": "Когда стало известно о сокращениях, сотрудники на собрании буквально вскрикнули от возмущения."
            },
            {
              "language": "sq",
              "text": "Kur shkurtimet u bënë të njohura, punonjësit reaguan me protestë të fortë në mbledhjen e kompanisë."
            },
            {
              "language": "tr",
              "text": "Kesintiler duyulunca çalışanlar işyeri toplantısında adeta yüksek sesle tepki gösterdi."
            }
          ]
        },
        {
          "baseText": "Der Patient schrie kurz auf, als die Ärztin die Wunde reinigte.",
          "translations": [
            {
              "language": "ar",
              "text": "صرخ المريض للحظة عندما نظفت الطبيبة الجرح."
            },
            {
              "language": "ckb",
              "text": "نەخۆشەکە کەمێک هاواری کرد کاتێک پزیشکەکە برینەکەی پاک کردەوە."
            },
            {
              "language": "en",
              "text": "The patient cried out briefly when the doctor cleaned the wound."
            },
            {
              "language": "fa",
              "text": "بیمار وقتی پزشک زخم را تمیز کرد، لحظه‌ای فریاد زد."
            },
            {
              "language": "kmr",
              "text": "Nexweş demeke kurt qîrî dema bijîşkê jin birîn paqij kir."
            },
            {
              "language": "pl",
              "text": "Pacjent krzyknął krótko, gdy lekarka oczyszczała ranę."
            },
            {
              "language": "ro",
              "text": "Pacientul a strigat scurt când doctorița a curățat rana."
            },
            {
              "language": "ru",
              "text": "Пациент коротко вскрикнул, когда врач очищала рану."
            },
            {
              "language": "sq",
              "text": "Pacienti bërtiti shkurt kur mjekja pastroi plagën."
            },
            {
              "language": "tr",
              "text": "Doktor yarayı temizlerken hasta kısa bir çığlık attı."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "aufsitzen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufsitzen",
      "syllableBreak": "auf-sit-zen",
      "topics": [
        "business-communication",
        "social-and-relationships",
        "quality-and-risk"
      ],
      "usageLabels": [
        "spoken",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; often idiomatic jemandem/etwas aufsitzen means to be taken in"
      ],
      "collocations": [
        {
          "text": "einem Irrtum aufsitzen",
          "meaning": "to fall for an error"
        },
        {
          "text": "einer Masche aufsitzen",
          "meaning": "to fall for a scheme"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "sitzen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "ينخدع بشيء؛ يركب أو يجلس فوق شيء حسب السياق"
        },
        {
          "language": "ckb",
          "text": "بە هەڵەیەک دەخەڵەتێت؛ لەسەر شتێک دادەنیشێت"
        },
        {
          "language": "en",
          "text": "to fall for; to be taken in; to sit/mount on"
        },
        {
          "language": "fa",
          "text": "فریب چیزی را خوردن؛ سوار/نشستن روی چیزی"
        },
        {
          "language": "kmr",
          "text": "xapandinê qebûl kirin; li ser rûniştin"
        },
        {
          "language": "pl",
          "text": "dać się nabrać; usiąść na czymś"
        },
        {
          "language": "ro",
          "text": "a cădea în capcană; a se așeza pe ceva"
        },
        {
          "language": "ru",
          "text": "попасться на; сесть верхом"
        },
        {
          "language": "sq",
          "text": "të biesh pre; të ulesh mbi diçka"
        },
        {
          "language": "tr",
          "text": "kanmak; üstüne oturmak/binmek"
        }
      ],
      "examples": [
        {
          "baseText": "Mehrere Kunden saßen der irreführenden Preiswerbung auf und beschwerten sich später beim Support.",
          "translations": [
            {
              "language": "ar",
              "text": "انخدع عدة عملاء بالإعلان السعري المضلل واشتَكوا لاحقًا للدعم."
            },
            {
              "language": "ckb",
              "text": "چەند کڕیارێک بە ڕیکلامی نرخی چەواشەکار خەڵەتان و دواتر لە پاڵپشتی سکاڵایان کرد."
            },
            {
              "language": "en",
              "text": "Several customers fell for the misleading price advertising and later complained to support."
            },
            {
              "language": "fa",
              "text": "چند مشتری فریب تبلیغ قیمت گمراه‌کننده را خوردند و بعداً به پشتیبانی شکایت کردند."
            },
            {
              "language": "kmr",
              "text": "Çend xerîdar ketin xapandina reklama bihayê şaşker û paşê gilî li piştgiriyê kirin."
            },
            {
              "language": "pl",
              "text": "Kilku klientów dało się nabrać na mylącą reklamę cenową i później złożyło skargę do supportu."
            },
            {
              "language": "ro",
              "text": "Mai mulți clienți au căzut în capcana reclamei de preț înșelătoare și s-au plâns ulterior la suport."
            },
            {
              "language": "ru",
              "text": "Несколько клиентов попались на вводящую в заблуждение ценовую рекламу и позже пожаловались в поддержку."
            },
            {
              "language": "sq",
              "text": "Disa klientë ranë pre e reklamës mashtruese të çmimit dhe më vonë u ankuan te suporti."
            },
            {
              "language": "tr",
              "text": "Birkaç müşteri yanıltıcı fiyat reklamına kandı ve daha sonra desteğe şikayette bulundu."
            }
          ]
        },
        {
          "baseText": "Die Ermittler gingen davon aus, dass der Zeuge einem weit verbreiteten Gerücht aufgesessen war.",
          "translations": [
            {
              "language": "ar",
              "text": "افترض المحققون أن الشاهد انخدع بشائعة منتشرة على نطاق واسع."
            },
            {
              "language": "ckb",
              "text": "لێکۆڵەرەکان پێیان وابوو شایەتەکە بە دەنگۆیەکی بەربڵاو خەڵەتاوە."
            },
            {
              "language": "en",
              "text": "The investigators assumed that the witness had fallen for a widely spread rumor."
            },
            {
              "language": "fa",
              "text": "بازرسان فرض کردند شاهد فریب یک شایعه گسترده را خورده است."
            },
            {
              "language": "kmr",
              "text": "Lêkolîneran wisa texmîn kir ku şahid ketibû xapandina gotegoteke belavbûyî."
            },
            {
              "language": "pl",
              "text": "Śledczy zakładali, że świadek dał się nabrać na szeroko rozpowszechnioną plotkę."
            },
            {
              "language": "ro",
              "text": "Anchetatorii au presupus că martorul căzuse în capcana unui zvon larg răspândit."
            },
            {
              "language": "ru",
              "text": "Следователи предположили, что свидетель поверил широко распространенному слуху."
            },
            {
              "language": "sq",
              "text": "Hetuesit supozuan se dëshmitari kishte rënë pre e një thashethemi të përhapur gjerësisht."
            },
            {
              "language": "tr",
              "text": "Soruşturmacılar tanığın yaygın bir söylentiye kandığını varsaydı."
            }
          ]
        }
      ]
    },
    {
      "language": "de",
      "cefrLevel": "C1",
      "pronunciationIpa": null,
      "contextLabels": [],
      "relations": [],
      "word": "aufstechen",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aufstechen",
      "syllableBreak": "auf-ste-chen",
      "topics": [
        "healthcare-and-appointments",
        "production-and-maintenance",
        "everyday-life"
      ],
      "usageLabels": [
        "technical",
        "written",
        "advanced"
      ],
      "grammarNotes": [
        "strong separable verb; means to pierce/open by puncturing"
      ],
      "collocations": [
        {
          "text": "eine Blase aufstechen",
          "meaning": "to puncture a blister"
        },
        {
          "text": "eine Verpackung aufstechen",
          "meaning": "to pierce open packaging"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "stechen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "يثقب ويفتح؛ يفقأ"
        },
        {
          "language": "ckb",
          "text": "کون دەکات و دەیکاتەوە؛ دەتەقێنێت"
        },
        {
          "language": "en",
          "text": "to pierce open; to puncture"
        },
        {
          "language": "fa",
          "text": "سوراخ و باز کردن؛ ترکاندن"
        },
        {
          "language": "kmr",
          "text": "qul kirin û vekirin"
        },
        {
          "language": "pl",
          "text": "przekłuć; nakłuć"
        },
        {
          "language": "ro",
          "text": "a perfora; a sparge prin înțepare"
        },
        {
          "language": "ru",
          "text": "проколоть; вскрыть проколом"
        },
        {
          "language": "sq",
          "text": "të shposh; të hapësh me shpim"
        },
        {
          "language": "tr",
          "text": "delip açmak; patlatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Die Ärztin riet davon ab, die Brandblase selbst aufzustechen.",
          "translations": [
            {
              "language": "ar",
              "text": "نصحت الطبيبة بعدم فقء فقاعة الحرق بنفسك."
            },
            {
