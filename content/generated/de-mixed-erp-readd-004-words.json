          "meaning": "to change a classification"
        },
        {
          "text": "die Klassifizierung prüfen",
          "meaning": "to check the classification"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "klassifizieren",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "meanings": [
        {
          "language": "ar",
          "text": "تصنيف"
        },
        {
          "language": "ckb",
          "text": "پۆلێنکردن"
        },
        {
          "language": "en",
          "text": "classification"
        },
        {
          "language": "fa",
          "text": "طبقه‌بندی"
        },
        {
          "language": "kmr",
          "text": "polandin"
        },
        {
          "language": "pl",
          "text": "klasyfikacja"
        },
        {
          "language": "ro",
          "text": "clasificare"
        },
        {
          "language": "ru",
          "text": "классификация"
        },
        {
          "language": "sq",
          "text": "klasifikim"
        },
        {
          "language": "tr",
          "text": "sınıflandırma"
        }
      ],
      "examples": [
        {
          "baseText": "Die Klassifizierung des Artikels ist im ERP-System falsch.",
          "translations": [
            {
              "language": "ar",
              "text": "تصنيف الصنف في نظام تخطيط موارد المؤسسة غير صحيح."
            },
            {
              "language": "ckb",
              "text": "پۆلێنکردنی کاڵاکە لە سیستەمی ERPدا هەڵەیە."
            },
            {
              "language": "en",
              "text": "The classification of the item is wrong in the ERP system."
            },
            {
              "language": "fa",
              "text": "طبقه‌بندی کالا در سیستم ERP اشتباه است."
            },
            {
              "language": "kmr",
              "text": "Polandina tiştê di pergala ERP de şaş e."
            },
            {
              "language": "pl",
              "text": "Klasyfikacja artykułu w systemie ERP jest błędna."
            },
            {
              "language": "ro",
              "text": "Clasificarea articolului este greșită în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Классификация товара в ERP-системе неверная."
            },
            {
              "language": "sq",
              "text": "Klasifikimi i artikullit në sistemin ERP është i gabuar."
            },
            {
              "language": "tr",
              "text": "Ürünün ERP sistemindeki sınıflandırması yanlış."
            }
          ]
        },
        {
          "baseText": "Nach der Prüfung bekommt jeder Antrag eine neue Klassifizierung.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الفحص يحصل كل طلب على تصنيف جديد."
            },
            {
              "language": "ckb",
              "text": "دوای پشکنین هەر داواکارییەک پۆلێنکردنێکی نوێ وەردەگرێت."
            },
            {
              "language": "en",
              "text": "After the review, each request gets a new classification."
            },
            {
              "language": "fa",
              "text": "بعد از بررسی، هر درخواست یک طبقه‌بندی جدید می‌گیرد."
            },
            {
              "language": "kmr",
              "text": "Piştî kontrolê her daxwaz klasîfîkasyonek nû werdigire."
            },
            {
              "language": "pl",
              "text": "Po kontroli każdy wniosek otrzymuje nową klasyfikację."
            },
            {
              "language": "ro",
              "text": "După verificare, fiecare cerere primește o nouă clasificare."
            },
            {
              "language": "ru",
              "text": "После проверки каждая заявка получает новую классификацию."
            },
            {
              "language": "sq",
              "text": "Pas kontrollit, çdo kërkesë merr një klasifikim të ri."
            },
            {
              "language": "tr",
              "text": "Kontrolden sonra her başvuru yeni bir sınıflandırma alır."
            }
          ]
        }
      ]
    },
