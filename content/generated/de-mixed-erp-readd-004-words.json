      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Konversation führen",
          "meaning": "to have a conversation"
        },
        {
          "text": "die Konversation dokumentieren",
          "meaning": "to document the conversation"
        }
      ],
      "wordFamilies": [],
      "meanings": [
        {
          "language": "ar",
          "text": "محادثة"
        },
        {
          "language": "ckb",
          "text": "گفتوگۆ"
        },
        {
          "language": "en",
          "text": "conversation"
        },
        {
          "language": "fa",
          "text": "گفتگو"
        },
        {
          "language": "kmr",
          "text": "axaftin; danûstandin"
        },
        {
          "language": "pl",
          "text": "konwersacja; rozmowa"
        },
        {
          "language": "ro",
          "text": "conversație"
        },
        {
          "language": "ru",
          "text": "разговор; беседа"
        },
        {
          "language": "sq",
          "text": "bisedë"
        },
        {
          "language": "tr",
          "text": "konuşma"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte speichern Sie die Konversation mit dem Kunden im ERP-System.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى حفظ المحادثة مع العميل في نظام تخطيط موارد المؤسسة."
            },
            {
              "language": "ckb",
              "text": "تکایە گفتوگۆکە لەگەڵ کڕیارەکە لە سیستەمی ERPدا پاشەکەوت بکەن."
            },
            {
              "language": "en",
              "text": "Please save the conversation with the customer in the ERP system."
            },
            {
              "language": "fa",
              "text": "لطفاً گفتگوی با مشتری را در سیستم ERP ذخیره کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe axaftina bi xerîdar re di pergala ERP de tomar bikin."
            },
            {
              "language": "pl",
              "text": "Proszę zapisać rozmowę z klientem w systemie ERP."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să salvați conversația cu clientul în sistemul ERP."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, сохраните разговор с клиентом в ERP-системе."
            },
            {
              "language": "sq",
              "text": "Ju lutemi ruajeni bisedën me klientin në sistemin ERP."
            },
            {
              "language": "tr",
              "text": "Lütfen müşteriyle yapılan konuşmayı ERP sistemine kaydedin."
            }
          ]
        },
        {
          "baseText": "Die Konversation war kurz, aber sehr freundlich.",
          "translations": [
            {
              "language": "ar",
              "text": "كانت المحادثة قصيرة لكنها ودية جدًا."
            },
            {
              "language": "ckb",
              "text": "گفتوگۆکە کورت بوو، بەڵام زۆر دۆستانە بوو."
            },
            {
              "language": "en",
              "text": "The conversation was short but very friendly."
            },
            {
              "language": "fa",
              "text": "گفتگو کوتاه بود، اما بسیار دوستانه بود."
            },
            {
              "language": "kmr",
              "text": "Axaftin kurt bû, lê pir dostane bû."
            },
            {
              "language": "pl",
              "text": "Rozmowa była krótka, ale bardzo przyjazna."
            },
            {
              "language": "ro",
              "text": "Conversația a fost scurtă, dar foarte prietenoasă."
            },
            {
              "language": "ru",
              "text": "Разговор был коротким, но очень дружелюбным."
            },
            {
              "language": "sq",
              "text": "Biseda ishte e shkurtër, por shumë miqësore."
            },
            {
              "language": "tr",
              "text": "Konuşma kısaydı ama çok samimiydi."
            }
          ]
        }
      ]
    },
