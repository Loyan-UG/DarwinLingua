      "examples": [
        {
          "baseText": "Im Bericht darf niemand lügen, auch wenn ein Fehler passiert ist.",
          "translations": [
            {
              "language": "ar",
              "text": "لا يجوز لأحد أن يكذب في التقرير، حتى إذا حدث خطأ."
            },
            {
              "language": "ckb",
              "text": "لە ڕاپۆرتەکەدا نابێت هیچ کەسێک درۆ بکات، تەنانەت ئەگەر هەڵەیەک ڕوویدابێت."
            },
            {
              "language": "en",
              "text": "No one may lie in the report, even if a mistake happened."
            },
            {
              "language": "fa",
              "text": "در گزارش هیچ‌کس نباید دروغ بگوید، حتی اگر اشتباهی رخ داده باشد."
            },
            {
              "language": "kmr",
              "text": "Di raporê de kesek nikare derew bike, heta heke şaşitiyek çêbûbe."
            },
            {
              "language": "pl",
              "text": "W raporcie nikt nie może kłamać, nawet jeśli zdarzył się błąd."
            },
            {
              "language": "ro",
              "text": "În raport nu are voie nimeni să mintă, chiar dacă s-a întâmplat o greșeală."
            },
            {
              "language": "ru",
              "text": "В отчёте никто не должен лгать, даже если произошла ошибка."
            },
            {
              "language": "sq",
              "text": "Në raport askush nuk duhet të gënjejë, edhe nëse ka ndodhur një gabim."
            },
            {
              "language": "tr",
              "text": "Raporda kimse yalan söylememeli, bir hata olmuş olsa bile."
            }
          ]
        },
        {
          "baseText": "Kinder lernen früh, dass man Vertrauen verliert, wenn man lügt.",
          "translations": [
            {
              "language": "ar",
              "text": "يتعلم الأطفال مبكراً أن المرء يفقد الثقة عندما يكذب."
            },
            {
              "language": "ckb",
              "text": "منداڵان زوو فێر دەبن کە ئەگەر کەس درۆ بکات متمانە لەدەست دەدات."
            },
            {
              "language": "en",
              "text": "Children learn early that you lose trust when you lie."
            },
            {
              "language": "fa",
              "text": "کودکان زود یاد می‌گیرند که اگر دروغ بگویند اعتماد را از دست می‌دهند."
            },
            {
              "language": "kmr",
              "text": "Zarok zû hîn dibin ku heke mirov derew bike, bawerî wenda dike."
            },
            {
              "language": "pl",
              "text": "Dzieci wcześnie uczą się, że gdy się kłamie, traci się zaufanie."
            },
            {
              "language": "ro",
              "text": "Copiii învață devreme că pierzi încrederea atunci când minți."
            },
            {
              "language": "ru",
              "text": "Дети рано узнают, что, когда врёшь, теряешь доверие."
            },
            {
              "language": "sq",
              "text": "Fëmijët mësojnë herët se kur gënjen humbet besimin."
            },
            {
              "language": "tr",
              "text": "Çocuklar yalan söyleyince güvenin kaybedildiğini erken öğrenir."
            }
          ]
        }
      ]
