      "examples": [
        {
          "baseText": "Der Eintritt ins Museum kostet fünf Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "تكلفة الدخول إلى المتحف خمسة يورو."
            },
            {
              "language": "ckb",
              "text": "چوونەژوورەوە بۆ مۆزەخانە پێنج یۆرۆیە."
            },
            {
              "language": "en",
              "text": "Admission to the museum costs five euros."
            },
            {
              "language": "fa",
              "text": "ورود به موزه پنج یورو هزینه دارد."
            },
            {
              "language": "kmr",
              "text": "Ketin bo muzeyê pênc euro ye."
            },
            {
              "language": "pl",
              "text": "Wstęp do muzeum kosztuje pięć euro."
            },
            {
              "language": "ro",
              "text": "Intrarea la muzeu costă cinci euro."
            },
            {
              "language": "ru",
              "text": "Вход в музей стоит пять евро."
            },
            {
              "language": "sq",
              "text": "Hyrja në muze kushton pesë euro."
            },
            {
              "language": "tr",
              "text": "Müzeye giriş beş avro."
            }
          ]
        },
        {
          "baseText": "Für Kinder ist der Eintritt frei.",
          "translations": [
            {
              "language": "ar",
              "text": "الدخول مجاني للأطفال."
            },
            {
              "language": "ckb",
              "text": "بۆ منداڵان چوونەژوورەوە بەخۆڕاییە."
            },
            {
              "language": "en",
              "text": "Admission is free for children."
            },
            {
              "language": "fa",
              "text": "ورود برای کودکان رایگان است."
            },
            {
              "language": "kmr",
              "text": "Ji bo zarokan ketin belaş e."
            },
            {
              "language": "pl",
              "text": "Dla dzieci wstęp jest bezpłatny."
            },
            {
              "language": "ro",
              "text": "Pentru copii intrarea este gratuită."
            },
            {
              "language": "ru",
              "text": "Для детей вход бесплатный."
            },
            {
              "language": "sq",
              "text": "Për fëmijët hyrja është falas."
            },
            {
              "language": "tr",
              "text": "Çocuklar için giriş ücretsizdir."
            }
          ]
