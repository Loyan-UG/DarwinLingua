      "meanings": [
        {
          "language": "ar",
          "text": "يدخل بيانات؛ يسجل"
        },
        {
          "language": "ckb",
          "text": "تۆمارکردن؛ نووسینەوە"
        },
        {
          "language": "en",
          "text": "to enter; to register; to add"
        },
        {
          "language": "fa",
          "text": "وارد کردن؛ ثبت کردن"
        },
        {
          "language": "kmr",
          "text": "tomar kirin; têxistin"
        },
        {
          "language": "pl",
          "text": "wpisać; zarejestrować"
        },
        {
          "language": "ro",
          "text": "a introduce; a înscrie"
        },
        {
          "language": "ru",
          "text": "вносить; записывать"
        },
        {
          "language": "sq",
          "text": "të shënosh; të regjistrosh"
        },
        {
          "language": "tr",
          "text": "girmek; kaydetmek"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte tragen Sie Ihren Namen in die Liste ein.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى كتابة اسمكم في القائمة."
            },
            {
              "language": "ckb",
              "text": "تکایە ناوتان لە لیستەکەدا بنووسن."
            },
            {
              "language": "en",
              "text": "Please enter your name in the list."
            },
            {
              "language": "fa",
              "text": "لطفاً نام خود را در فهرست وارد کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe navê xwe têxin lîsteyê."
            },
            {
              "language": "pl",
              "text": "Proszę wpisać swoje imię na listę."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să vă treceți numele pe listă."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, внесите свое имя в список."
            },
            {
              "language": "sq",
              "text": "Ju lutem shënoni emrin tuaj në listë."
            },
            {
              "language": "tr",
              "text": "Lütfen adınızı listeye yazın."
            }
          ]
        },
        {
          "baseText": "Ich trage den Termin gleich in den Kalender ein.",
          "translations": [
            {
              "language": "ar",
              "text": "سأدخل الموعد فوراً في التقويم."
            },
            {
              "language": "ckb",
              "text": "کاتەکە ئێستا لە ڕۆژژمێرەکەدا تۆمار دەکەم."
            },
            {
              "language": "en",
              "text": "I will enter the appointment in the calendar right away."
            },
            {
              "language": "fa",
              "text": "وقت را همین الان در تقویم وارد می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez ê wextê niha têxim salnameyê."
            },
            {
              "language": "pl",
              "text": "Zaraz wpiszę termin do kalendarza."
            },
            {
              "language": "ro",
              "text": "Trec imediat programarea în calendar."
            },
            {
              "language": "ru",
              "text": "Я сразу внесу встречу в календарь."
            },
            {
              "language": "sq",
              "text": "Do ta shënoj takimin menjëherë në kalendar."
            },
            {
              "language": "tr",
              "text": "Randevuyu hemen takvime giriyorum."
            }
          ]
        }
      ]
    },
