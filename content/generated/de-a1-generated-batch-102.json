      "examples": [
        {
          "baseText": "Bitte warten Sie hier.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك انتظر هنا."
            },
            {
              "language": "ckb",
              "text": "تکایە لێرە چاوەڕێ بکە."
            },
            {
              "language": "en",
              "text": "Please wait here."
            },
            {
              "language": "fa",
              "text": "لطفاً اینجا منتظر بمانید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe li vir li bendê bin."
            },
            {
              "language": "pl",
              "text": "Proszę tutaj poczekać."
            },
            {
              "language": "ro",
              "text": "Vă rog să așteptați aici."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, подождите здесь."
            },
            {
              "language": "sq",
              "text": "Ju lutem prisni këtu."
            },
            {
              "language": "tr",
              "text": "Lütfen burada bekleyin."
            }
          ]
        },
        {
          "baseText": "Ich warte auf den Bus.",
          "translations": [
            {
              "language": "ar",
              "text": "أنتظر الحافلة."
            },
            {
              "language": "ckb",
              "text": "چاوەڕێی پاسەکەم."
            },
            {
              "language": "en",
              "text": "I am waiting for the bus."
            },
            {
              "language": "fa",
              "text": "منتظر اتوبوس هستم."
            },
            {
              "language": "kmr",
              "text": "Ez li benda otobusê me."
            },
            {
              "language": "pl",
              "text": "Czekam na autobus."
            },
            {
              "language": "ro",
              "text": "Aștept autobuzul."
            },
            {
              "language": "ru",
              "text": "Я жду автобус."
