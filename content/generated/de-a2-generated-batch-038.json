      "meanings": [
        {
          "language": "ar",
          "text": "مرن؛ قابل للتكيّف"
        },
        {
          "language": "ckb",
          "text": "نەرم؛ گونجاو"
        },
        {
          "language": "en",
          "text": "flexible; adaptable"
        },
        {
          "language": "fa",
          "text": "انعطاف‌پذیر؛ قابل تنظیم"
        },
        {
          "language": "kmr",
          "text": "nerm; li gor rewşê tê guhertin"
        },
        {
          "language": "pl",
          "text": "elastyczny; dostosowujący się"
        },
        {
          "language": "ro",
          "text": "flexibil; adaptabil"
        },
        {
          "language": "ru",
          "text": "гибкий; приспосабливаемый"
        },
        {
          "language": "sq",
          "text": "fleksibël; i përshtatshëm"
        },
        {
          "language": "tr",
          "text": "esnek; uyarlanabilir"
        }
      ],
      "examples": [
        {
          "baseText": "Ich bin bei der Uhrzeit flexibel.",
          "translations": [
            {
              "language": "ar",
              "text": "أنا مرن بخصوص الوقت."
            },
            {
              "language": "ckb",
              "text": "لە کاتەکەدا گونجاوم."
            },
            {
              "language": "en",
              "text": "I am flexible about the time."
            },
            {
              "language": "fa",
              "text": "من درباره زمان انعطاف‌پذیر هستم."
            },
            {
              "language": "kmr",
              "text": "Ez li ser demê nerm im."
            },
            {
              "language": "pl",
              "text": "Jestem elastyczny co do godziny."
            },
            {
              "language": "ro",
              "text": "Sunt flexibil în privința orei."
            },
            {
              "language": "ru",
              "text": "Я гибко подхожу ко времени."
            },
            {
              "language": "sq",
              "text": "Jam fleksibël për orarin."
            },
            {
              "language": "tr",
              "text": "Saat konusunda esneğim."
            }
          ]
        },
        {
          "baseText": "Unsere Arbeitszeiten sind flexibel.",
          "translations": [
            {
              "language": "ar",
              "text": "ساعات عملنا مرنة."
            },
            {
              "language": "ckb",
              "text": "کاتەکانی کارمان گونجاون."
            },
            {
              "language": "en",
              "text": "Our working hours are flexible."
            },
            {
              "language": "fa",
              "text": "ساعت‌های کاری ما انعطاف‌پذیر است."
            },
            {
              "language": "kmr",
              "text": "Demên xebata me nerm in."
            },
            {
              "language": "pl",
              "text": "Nasze godziny pracy są elastyczne."
            },
            {
              "language": "ro",
              "text": "Programul nostru de lucru este flexibil."
            },
            {
              "language": "ru",
              "text": "У нас гибкий рабочий график."
            },
            {
              "language": "sq",
              "text": "Orari ynë i punës është fleksibël."
            },
            {
              "language": "tr",
              "text": "Çalışma saatlerimiz esnektir."
            }
          ]
        }
      ]
