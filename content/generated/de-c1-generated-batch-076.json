  "entries": [
    {
      "word": "die Messgenauigkeit",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Mess-ge-nau-ig-keit",
      "topics": [
        "data-and-reporting",
        "quality-and-risk",
        "advanced-analysis"
      ],
      "usageLabels": [
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "die Messgenauigkeit erhöhen",
          "meaning": "to increase measurement accuracy"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "messen",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "genau",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "دقة القياس"
        },
        {
          "language": "ckb",
          "text": "وردیی پێوانەکردن"
        },
        {
          "language": "en",
          "text": "measurement accuracy"
        },
        {
          "language": "fa",
          "text": "دقت اندازه‌گیری"
        },
        {
          "language": "kmr",
          "text": "rastbûna pîvandinê"
        },
        {
          "language": "pl",
          "text": "dokładność pomiaru"
        },
        {
          "language": "ro",
          "text": "precizie de măsurare"
        },
        {
          "language": "ru",
          "text": "точность измерения"
        },
        {
          "language": "sq",
          "text": "saktësi matjeje"
        },
        {
          "language": "tr",
          "text": "ölçüm doğruluğu"
        }
      ],
      "examples": [
        {
          "baseText": "Die Messgenauigkeit reicht für eine grobe Tendenz, aber nicht für eine belastbare Prognose.",
          "translations": [
            {
              "language": "ar",
              "text": "تكفي دقة القياس لاتجاه عام، لكنها لا تكفي لتوقع موثوق."
            },
            {
              "language": "ckb",
              "text": "وردیی پێوانەکردنەکە بۆ ئاراستەیەکی گشتی بەسە، بەڵام بۆ پێشبینیی پشتپێبەست نا."
            },
            {
              "language": "en",
              "text": "The measurement accuracy is sufficient for a rough trend, but not for a reliable forecast."
            },
            {
              "language": "fa",
              "text": "دقت اندازه‌گیری برای یک روند کلی کافی است، اما برای پیش‌بینی قابل اتکا کافی نیست."
            },
            {
              "language": "kmr",
              "text": "Rastbûna pîvandinê ji bo rêçikeke giştî bes e, lê ji bo pêşbîniyeke bawerbar na."
            },
            {
              "language": "pl",
              "text": "Dokładność pomiaru wystarcza do ogólnego trendu, ale nie do wiarygodnej prognozy."
            },
            {
              "language": "ro",
              "text": "Precizia de măsurare este suficientă pentru o tendință brută, dar nu pentru o prognoză solidă."
            },
            {
              "language": "ru",
              "text": "Точности измерения достаточно для общей тенденции, но не для надежного прогноза."
            },
            {
              "language": "sq",
              "text": "Saktësia e matjes mjafton për një prirje të përgjithshme, por jo për një parashikim të besueshëm."
            },
            {
              "language": "tr",
              "text": "Ölçüm doğruluğu kaba bir eğilim için yeterli, ancak güvenilir bir tahmin için yeterli değildir."
            }
          ]
        },
        {
          "baseText": "Vor der Abnahme wurde die Messgenauigkeit der Sensoren noch einmal überprüft.",
          "translations": [
            {
              "language": "ar",
              "text": "قبل القبول النهائي تم فحص دقة قياس الحساسات مرة أخرى."
            },
            {
              "language": "ckb",
              "text": "پێش وەرگرتنی کۆتایی وردیی پێوانەکردنی سێنسەرەکان جارێکی تر پشکنرا."
            },
            {
              "language": "en",
              "text": "Before acceptance, the measurement accuracy of the sensors was checked again."
            },
            {
              "language": "fa",
              "text": "پیش از تحویل نهایی، دقت اندازه‌گیری حسگرها دوباره بررسی شد."
            },
            {
              "language": "kmr",
              "text": "Berî pejirandina dawî rastbûna pîvandinê ya sensoran careke din hate kontrol kirin."
            },
            {
              "language": "pl",
              "text": "Przed odbiorem ponownie sprawdzono dokładność pomiaru czujników."
            },
            {
              "language": "ro",
              "text": "Înainte de recepție, precizia de măsurare a senzorilor a fost verificată încă o dată."
            },
            {
              "language": "ru",
              "text": "Перед приемкой точность измерения датчиков проверили еще раз."
            },
            {
              "language": "sq",
              "text": "Para pranimit, saktësia e matjes së sensorëve u kontrollua edhe një herë."
            },
            {
              "language": "tr",
              "text": "Kabulden önce sensörlerin ölçüm doğruluğu bir kez daha kontrol edildi."
            }
          ]
        }
      ]
    },
    {
      "word": "die Messung",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Messungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Mes-sung",
      "topics": [
        "data-and-reporting",
        "quality-and-risk",
        "advanced-analysis"
      ],
      "usageLabels": [
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Messung durchführen",
          "meaning": "to conduct a measurement"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "messen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قياس"
        },
        {
          "language": "ckb",
          "text": "پێوانەکردن"
        },
        {
          "language": "en",
          "text": "measurement"
        },
        {
          "language": "fa",
          "text": "اندازه‌گیری"
        },
        {
          "language": "kmr",
          "text": "pîvandin"
        },
        {
          "language": "pl",
          "text": "pomiar"
        },
        {
          "language": "ro",
          "text": "măsurare"
        },
        {
          "language": "ru",
          "text": "измерение"
        },
        {
          "language": "sq",
          "text": "matje"
        },
        {
          "language": "tr",
          "text": "ölçüm"
        }
      ],
      "examples": [
        {
          "baseText": "Die Messung wurde wiederholt, weil der erste Wert außerhalb des erwarteten Bereichs lag.",
          "translations": [
            {
              "language": "ar",
              "text": "أُعيد القياس لأن القيمة الأولى كانت خارج النطاق المتوقع."
            },
            {
              "language": "ckb",
              "text": "پێوانەکردنەکە دووبارە کرایەوە چونکە نرخی یەکەم لە دەرەوەی مەودای چاوەڕوانکراودا بوو."
            },
            {
              "language": "en",
              "text": "The measurement was repeated because the first value was outside the expected range."
            },
            {
              "language": "fa",
              "text": "اندازه‌گیری تکرار شد، چون مقدار اول خارج از محدوده مورد انتظار بود."
            },
            {
              "language": "kmr",
              "text": "Pîvandin hate dubarekirin, ji ber ku nirxa yekem derveyî qada hêvîkirî bû."
            },
            {
              "language": "pl",
              "text": "Pomiar powtórzono, ponieważ pierwsza wartość była poza oczekiwanym zakresem."
            },
            {
              "language": "ro",
              "text": "Măsurarea a fost repetată deoarece prima valoare era în afara intervalului așteptat."
            },
            {
              "language": "ru",
              "text": "Измерение повторили, потому что первое значение находилось вне ожидаемого диапазона."
            },
            {
              "language": "sq",
              "text": "Matja u përsërit sepse vlera e parë ishte jashtë intervalit të pritur."
            },
            {
              "language": "tr",
              "text": "İlk değer beklenen aralığın dışında olduğu için ölçüm tekrarlandı."
            }
          ]
        },
        {
          "baseText": "Für die Bewertung der Luftqualität ist eine Messung zu einem einzigen Zeitpunkt nicht ausreichend.",
          "translations": [
            {
              "language": "ar",
              "text": "لتقييم جودة الهواء لا يكفي قياس واحد في لحظة واحدة."
            },
            {
              "language": "ckb",
              "text": "بۆ هەڵسەنگاندنی کوالیتی هەوا پێوانەکردنێک لە یەک کاتدا بەس نییە."
            },
            {
              "language": "en",
              "text": "For assessing air quality, a measurement at a single point in time is not sufficient."
            },
            {
              "language": "fa",
              "text": "برای ارزیابی کیفیت هوا، اندازه‌گیری در یک زمان واحد کافی نیست."
            },
            {
              "language": "kmr",
              "text": "Ji bo nirxandina kalîteya hewayê, pîvandinek di yek demê de bes nîne."
            },
            {
              "language": "pl",
              "text": "Do oceny jakości powietrza pomiar w jednym momencie nie jest wystarczający."
            },
            {
              "language": "ro",
              "text": "Pentru evaluarea calității aerului, o măsurare la un singur moment nu este suficientă."
            },
            {
              "language": "ru",
              "text": "Для оценки качества воздуха измерения в один момент времени недостаточно."
            },
            {
              "language": "sq",
              "text": "Për vlerësimin e cilësisë së ajrit, një matje në një moment të vetëm nuk mjafton."
            },
            {
              "language": "tr",
              "text": "Hava kalitesini değerlendirmek için tek bir zamandaki ölçüm yeterli değildir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Metaanalyse",
      "language": "de",
      "cefrLevel": "C1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Metaanalysen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Me-ta-a-na-ly-se",
      "topics": [
        "advanced-analysis",
        "data-and-reporting",
        "education-and-training"
      ],
      "usageLabels": [
        "academic",
        "analysis",
        "written",
        "advanced"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; research term"
      ],
      "collocations": [
        {
          "text": "eine Metaanalyse auswerten",
          "meaning": "to evaluate a meta-analysis"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Analyse",
          "relationLabel": "base noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "تحليل تلوي؛ مراجعة كمية للدراسات"
        },
        {
          "language": "ckb",
          "text": "مێتا-شیکردنەوە؛ شیکردنەوەی کۆی توێژینەوەکان"
        },
        {
          "language": "en",
          "text": "meta-analysis"
        },
        {
          "language": "fa",
          "text": "فراتحلیل"
        },
        {
          "language": "kmr",
          "text": "meta-analîz"
        },
        {
          "language": "pl",
          "text": "metaanaliza"
        },
        {
          "language": "ro",
          "text": "metaanaliză"
        },
        {
          "language": "ru",
          "text": "метаанализ"
        },
        {
          "language": "sq",
          "text": "metaanalizë"
        },
        {
          "language": "tr",
          "text": "meta-analiz"
        }
      ],
      "examples": [
        {
          "baseText": "Die Metaanalyse fasst die Ergebnisse von 42 Studien zusammen und bewertet ihre methodische Qualität.",
          "translations": [
            {
              "language": "ar",
              "text": "يلخص التحليل التلوي نتائج 42 دراسة ويقيّم جودتها المنهجية."
            },
            {
              "language": "ckb",
              "text": "مێتا-شیکردنەوەکە ئەنجامی ٤٢ توێژینەوە کورت دەکاتەوە و کوالیتی میتۆدییان هەڵدەسەنگێنێت."
            },
            {
              "language": "en",
              "text": "The meta-analysis summarizes the results of 42 studies and evaluates their methodological quality."
            },
            {
              "language": "fa",
              "text": "این فراتحلیل نتایج ۴۲ مطالعه را جمع‌بندی می‌کند و کیفیت روش‌شناختی آن‌ها را می‌سنجد."
            },
            {
              "language": "kmr",
              "text": "Meta-analîz encamên 42 lêkolînan kom dike û kalîteya metodîk a wan dinirxîne."
            },
            {
              "language": "pl",
              "text": "Metaanaliza podsumowuje wyniki 42 badań i ocenia ich jakość metodologiczną."
            },
            {
              "language": "ro",
              "text": "Metaanaliza sintetizează rezultatele a 42 de studii și le evaluează calitatea metodologică."
            },
            {
              "language": "ru",
              "text": "Метаанализ обобщает результаты 42 исследований и оценивает их методологическое качество."
            },
            {
              "language": "sq",
              "text": "Metaanaliza përmbledh rezultatet e 42 studimeve dhe vlerëson cilësinë e tyre metodologjike."
            },
            {
              "language": "tr",
              "text": "Meta-analiz 42 çalışmanın sonuçlarını özetler ve metodolojik kalitelerini değerlendirir."
            }
          ]
        },
        {
          "baseText": "Für die Leitlinie war die Metaanalyse wichtiger als einzelne Fallberichte.",
          "translations": [
            {
              "language": "ar",
              "text": "كان التحليل التلوي أهم للإرشاد من تقارير الحالات الفردية."
            },
            {
              "language": "ckb",
              "text": "بۆ ڕێنماییەکە مێتا-شیکردنەوە گرنگتر بوو لە ڕاپۆرتی حاڵەتە تاکەکان."
            },
            {
              "language": "en",
              "text": "For the guideline, the meta-analysis was more important than individual case reports."
            },
            {
              "language": "fa",
