              "language": "ar",
              "text": "غسالتنا معطلة، سنتصل بالفني."
            },
            {
              "language": "ckb",
              "text": "ماشینی جلشۆرینەکەمان خراپە، تەکنیککار بانگ دەکەین."
            },
            {
              "language": "en",
              "text": "Our washing machine is broken; we are calling the technician."
            },
            {
              "language": "fa",
              "text": "ماشین لباسشویی ما خراب است، با تکنسین تماس می‌گیریم."
            },
            {
              "language": "kmr",
              "text": "Maşîna me ya cilşûştinê xerab e, em teknîsyenê bang dikin."
            },
            {
              "language": "pl",
              "text": "Nasza pralka jest zepsuta, dzwonimy po technika."
            },
            {
              "language": "ro",
              "text": "Mașina noastră de spălat este stricată, chemăm tehnicianul."
            },
            {
              "language": "ru",
              "text": "Наша стиральная машина сломана, мы вызываем техника."
            },
            {
              "language": "sq",
              "text": "Makina jonë larëse është prishur, po thërrasim teknikun."
            },
            {
              "language": "tr",
              "text": "Çamaşır makinemiz bozuk, teknisyeni arıyoruz."
            }
          ]
        }
