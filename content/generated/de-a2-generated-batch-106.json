          "note": null
        },
        {
          "lemma": "die Zeit",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "وقت الانتظار"
        },
        {
          "language": "ckb",
          "text": "کاتی چاوەڕوانی"
        },
        {
          "language": "en",
          "text": "waiting time"
        },
        {
          "language": "fa",
          "text": "زمان انتظار"
        },
        {
          "language": "kmr",
          "text": "dema bendewarî"
        },
        {
          "language": "pl",
          "text": "czas oczekiwania"
        },
        {
          "language": "ro",
          "text": "timp de așteptare"
        },
        {
          "language": "ru",
          "text": "время ожидания"
        },
        {
          "language": "sq",
          "text": "kohë pritjeje"
        },
        {
          "language": "tr",
          "text": "bekleme süresi"
        }
      ],
      "examples": [
        {
          "baseText": "Die Wartezeit beträgt heute etwa 20 Minuten.",
          "translations": [
            {
              "language": "ar",
              "text": "وقت الانتظار اليوم حوالي 20 دقيقة."
            },
            {
              "language": "ckb",
              "text": "کاتی چاوەڕوانی ئەمڕۆ نزیکەی ٢٠ خولەکە."
            },
            {
              "language": "en",
              "text": "The waiting time today is about 20 minutes."
            },
            {
              "language": "fa",
              "text": "زمان انتظار امروز حدود ۲۰ دقیقه است."
            },
            {
              "language": "kmr",
              "text": "Dema bendewarî îro qasî 20 deqe ye."
            },
            {
              "language": "pl",
              "text": "Czas oczekiwania wynosi dziś około 20 minut."
            },
            {
              "language": "ro",
              "text": "Timpul de așteptare este astăzi de aproximativ 20 de minute."
            },
            {
              "language": "ru",
              "text": "Время ожидания сегодня около 20 минут."
            },
            {
              "language": "sq",
              "text": "Koha e pritjes sot është rreth 20 minuta."
            },
            {
              "language": "tr",
              "text": "Bugünkü bekleme süresi yaklaşık 20 dakika."
            }
          ]
        },
        {
          "baseText": "Gibt es eine kurze Wartezeit beim Arzt?",
          "translations": [
            {
              "language": "ar",
              "text": "هل هناك وقت انتظار قصير عند الطبيب؟"
            },
            {
              "language": "ckb",
              "text": "ئایا لای پزیشک کاتی چاوەڕوانی کورتە؟"
            },
            {
              "language": "en",
              "text": "Is there a short waiting time at the doctor’s office?"
            },
            {
              "language": "fa",
              "text": "آیا زمان انتظار نزد پزشک کوتاه است؟"
            },
            {
              "language": "kmr",
              "text": "Ma li cem bijîşk dema bendewarî kurt e?"
            },
            {
              "language": "pl",
              "text": "Czy u lekarza jest krótki czas oczekiwania?"
            },
            {
              "language": "ro",
              "text": "Este un timp scurt de așteptare la medic?"
            },
            {
              "language": "ru",
              "text": "У врача короткое время ожидания?"
            },
            {
              "language": "sq",
              "text": "A ka kohë të shkurtër pritjeje te mjeku?"
            },
            {
              "language": "tr",
              "text": "Doktorda bekleme süresi kısa mı?"
            }
          ]
        }
      ]
    },
