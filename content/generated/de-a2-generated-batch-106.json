      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بطاقة غسيل"
        },
        {
          "language": "ckb",
          "text": "کارتی جلشۆرین"
        },
        {
          "language": "en",
          "text": "laundry card; wash card"
        },
        {
          "language": "fa",
          "text": "کارت شست‌وشو"
        },
        {
          "language": "kmr",
          "text": "karta cilşûştinê"
        },
        {
          "language": "pl",
          "text": "karta do prania"
        },
        {
          "language": "ro",
          "text": "card de spălat"
        },
        {
          "language": "ru",
          "text": "карта для стирки"
        },
        {
          "language": "sq",
          "text": "kartë larjeje"
        },
        {
          "language": "tr",
          "text": "çamaşır kartı"
        }
      ],
      "examples": [
        {
          "baseText": "Ich lade die Waschkarte an der Kasse auf.",
          "translations": [
            {
              "language": "ar",
              "text": "أشحن بطاقة الغسيل عند الصندوق."
            },
            {
              "language": "ckb",
              "text": "من کارتی جلشۆرینەکە لە لای کاشە بار دەکەم."
            },
            {
              "language": "en",
              "text": "I top up the laundry card at the register."
            },
            {
              "language": "fa",
              "text": "کارت شست‌وشو را در صندوق شارژ می‌کنم."
            },
            {
              "language": "kmr",
              "text": "Ez karta cilşûştinê li kasa tijî dikim."
            },
            {
              "language": "pl",
              "text": "Doładowuję kartę do prania przy kasie."
            },
            {
              "language": "ro",
              "text": "Încarc cardul de spălat la casă."
            },
            {
              "language": "ru",
              "text": "Я пополняю карту для стирки на кассе."
            },
            {
              "language": "sq",
              "text": "E mbush kartën e larjes te kasa."
            },
            {
              "language": "tr",
              "text": "Çamaşır kartını kasada yüklüyorum."
            }
          ]
        },
        {
          "baseText": "Ohne Waschkarte kann ich die Maschine nicht starten.",
          "translations": [
            {
              "language": "ar",
              "text": "من دون بطاقة الغسيل لا أستطيع تشغيل الآلة."
            },
            {
              "language": "ckb",
              "text": "بەبێ کارتی جلشۆرین ناتوانم ئامێرەکە دەست پێبکەم."
            },
            {
              "language": "en",
              "text": "Without a laundry card, I cannot start the machine."
            },
            {
              "language": "fa",
              "text": "بدون کارت شست‌وشو نمی‌توانم ماشین را روشن کنم."
            },
            {
              "language": "kmr",
              "text": "Bê karta cilşûştinê ez nikarim maşînê bidim destpêkirin."
            },
            {
              "language": "pl",
              "text": "Bez karty do prania nie mogę uruchomić maszyny."
            },
            {
              "language": "ro",
              "text": "Fără cardul de spălat nu pot porni mașina."
            },
            {
              "language": "ru",
              "text": "Без карты для стирки я не могу запустить машину."
            },
            {
              "language": "sq",
              "text": "Pa kartën e larjes nuk mund ta ndez makinën."
            },
            {
              "language": "tr",
              "text": "Çamaşır kartı olmadan makineyi başlatamam."
            }
          ]
        }
      ]
    },
