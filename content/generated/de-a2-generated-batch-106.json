      "examples": [
        {
          "baseText": "Die Waschmaschine ist im Keller.",
          "translations": [
            {
              "language": "ar",
              "text": "الغسالة في القبو."
            },
            {
              "language": "ckb",
              "text": "ماشینی جلشۆرینەکە لە ژێرزەمینەکەدایە."
            },
            {
              "language": "en",
              "text": "The washing machine is in the basement."
            },
            {
              "language": "fa",
              "text": "ماشین لباسشویی در زیرزمین است."
            },
            {
              "language": "kmr",
              "text": "Maşîna cilşûştinê li bodrumê ye."
            },
