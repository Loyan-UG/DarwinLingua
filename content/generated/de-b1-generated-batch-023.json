  "entries": [
    {
      "word": "beachten",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "beachten",
      "pronunciationIpa": null,
      "syllableBreak": "be-ach-ten",
      "topics": [
        "work-and-jobs",
        "law-and-compliance",
        "documents-and-administration"
      ],
      "usageLabels": [
        "formal",
        "business",
        "written"
      ],
      "contextLabels": [
        "compliance",
        "documents",
        "management"
      ],
      "grammarNotes": [
        "regular verb",
        "means to pay attention to or observe rules/instructions"
      ],
      "collocations": [
        {
          "text": "Regeln beachten",
          "meaning": "to observe rules"
        },
        {
          "text": "Hinweise beachten",
          "meaning": "to follow instructions"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Beachtung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يراعي؛ ينتبه إلى؛ يلتزم بـ"
        },
        {
          "language": "ckb",
          "text": "ڕەچاوکردن؛ ئاگاداربوون؛ پابەندبوون"
        },
        {
          "language": "en",
          "text": "to observe; to pay attention to; to follow"
        },
        {
          "language": "fa",
          "text": "رعایت کردن؛ توجه کردن"
        },
        {
          "language": "kmr",
          "text": "li ber çavan girtin; bal dan"
        },
        {
          "language": "pl",
          "text": "przestrzegać; zwracać uwagę"
        },
        {
          "language": "ro",
          "text": "a respecta; a lua în considerare"
        },
        {
          "language": "ru",
          "text": "соблюдать; учитывать"
        },
        {
          "language": "sq",
          "text": "të respektosh; të marrësh parasysh"
        },
        {
          "language": "tr",
          "text": "dikkate almak; uymak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte beachten Sie die neuen Datenschutzregeln im Kundenportal.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى مراعاة قواعد حماية البيانات الجديدة في بوابة العملاء."
            },
            {
              "language": "ckb",
              "text": "تکایە یاسا نوێیەکانی پاراستنی داتا لە پۆرتاڵی کڕیاردا ڕەچاو بکەن."
            },
            {
              "language": "en",
              "text": "Please observe the new data protection rules in the customer portal."
            },
            {
              "language": "fa",
              "text": "لطفاً قوانین جدید حفاظت از داده‌ها را در پورتال مشتری رعایت کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe rêzikên nû yên parastina daneyan di portala xerîdar de li ber çavan bigirin."
            },
            {
              "language": "pl",
              "text": "Proszę przestrzegać nowych zasad ochrony danych w portalu klienta."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să respectați noile reguli de protecție a datelor în portalul pentru clienți."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, соблюдайте новые правила защиты данных в клиентском портале."
            },
            {
              "language": "sq",
              "text": "Ju lutem respektoni rregullat e reja të mbrojtjes së të dhënave në portalin e klientit."
            },
            {
              "language": "tr",
              "text": "Lütfen müşteri portalındaki yeni veri koruma kurallarına uyun."
            }
          ]
        },
        {
          "baseText": "Beim Aufbau des Regals müssen Sie die Hinweise in der Anleitung genau beachten.",
          "translations": [
            {
              "language": "ar",
              "text": "عند تركيب الرف يجب اتباع التعليمات الموجودة في الدليل بدقة."
            },
            {
              "language": "ckb",
              "text": "لە کاتی دانانی ڕەفەکەدا دەبێت تێبینییەکانی ڕێبەرەکە بە وردی ڕەچاو بکەن."
            },
            {
              "language": "en",
              "text": "When assembling the shelf, you must follow the instructions in the manual carefully."
            },
            {
              "language": "fa",
              "text": "هنگام نصب قفسه باید نکات راهنما را دقیق رعایت کنید."
            },
            {
              "language": "kmr",
              "text": "Dema refê datînin, divê hûn agahdariyên di rêberê de bi hûrgilî li ber çavan bigirin."
            },
            {
              "language": "pl",
              "text": "Podczas montażu regału trzeba dokładnie przestrzegać wskazówek w instrukcji."
            },
            {
