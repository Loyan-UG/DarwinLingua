      ],
      "usageLabels": [
        "formal",
        "administrative",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "den Personalausweis vorzeigen",
          "meaning": "to show the ID card"
        },
        {
          "text": "einen Personalausweis beantragen",
          "meaning": "to apply for an ID card"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Person",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Ausweis",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "بطاقة الهوية الشخصية"
        },
        {
          "language": "ckb",
          "text": "ناسنامەی کەسی"
        },
        {
          "language": "en",
          "text": "identity card; ID card"
        },
        {
          "language": "fa",
          "text": "کارت شناسایی؛ کارت ملی/هویت"
        },
        {
          "language": "kmr",
          "text": "nasnameya kesane"
        },
        {
          "language": "pl",
          "text": "dowód osobisty"
        },
        {
          "language": "ro",
          "text": "carte de identitate"
        },
        {
          "language": "ru",
          "text": "удостоверение личности; паспорт гражданина"
        },
        {
          "language": "sq",
          "text": "kartë identiteti"
        },
        {
          "language": "tr",
          "text": "kimlik kartı"
        }
      ],
      "examples": [
        {
          "baseText": "Für die Anmeldung brauchen Sie Ihren Personalausweis.",
          "translations": [
            {
              "language": "ar",
              "text": "تحتاجون إلى بطاقة الهوية للتسجيل."
            },
            {
              "language": "ckb",
              "text": "بۆ تۆمارکردن پێویستتان بە ناسنامەی کەسی هەیە."
            },
            {
              "language": "en",
              "text": "For registration, you need your ID card."
            },
            {
              "language": "fa",
              "text": "برای ثبت‌نام به کارت شناسایی خود نیاز دارید."
            },
            {
              "language": "kmr",
              "text": "Ji bo qeydkirinê hûn hewceyê nasnameya xwe ne."
            },
            {
              "language": "pl",
              "text": "Do rejestracji potrzebny jest dowód osobisty."
            },
            {
              "language": "ro",
              "text": "Pentru înregistrare aveți nevoie de cartea de identitate."
            },
            {
              "language": "ru",
              "text": "Для регистрации вам нужно удостоверение личности."
            },
            {
              "language": "sq",
              "text": "Për regjistrim ju duhet karta e identitetit."
            },
            {
              "language": "tr",
              "text": "Kayıt için kimlik kartınıza ihtiyacınız var."
            }
          ]
        },
        {
          "baseText": "Mein Personalausweis läuft nächsten Monat ab.",
          "translations": [
            {
              "language": "ar",
              "text": "ستنتهي صلاحية بطاقة هويتي الشهر القادم."
            },
            {
              "language": "ckb",
              "text": "ناسنامەی کەسیم مانگی داهاتوو بەسەر دەچێت."
            },
            {
              "language": "en",
              "text": "My ID card expires next month."
            },
            {
              "language": "fa",
              "text": "کارت شناسایی من ماه آینده منقضی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Nasnameya min meha bê qedî dibe."
            },
            {
              "language": "pl",
              "text": "Mój dowód osobisty traci ważność w przyszłym miesiącu."
            },
            {
              "language": "ro",
              "text": "Cartea mea de identitate expiră luna viitoare."
            },
            {
              "language": "ru",
              "text": "Моё удостоверение личности истекает в следующем месяце."
            },
            {
              "language": "sq",
              "text": "Karta ime e identitetit skadon muajin tjetër."
            },
            {
              "language": "tr",
              "text": "Kimlik kartım gelecek ay sona eriyor."
            }
          ]
        }
      ]
    },
