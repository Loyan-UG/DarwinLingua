  "entries": [
    {
      "word": "die Personalabteilung",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Personalabteilungen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Per-so-nal-ab-tei-lung",
      "topics": [
        "human-resources",
        "work-and-jobs",
        "documents-and-administration"
      ],
      "usageLabels": [
        "business",
        "workplace",
        "formal",
        "administrative"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "die Personalabteilung informieren",
          "meaning": "to inform HR"
        },
        {
          "text": "bei der Personalabteilung nachfragen",
          "meaning": "to ask HR"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "das Personal",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "die Abteilung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قسم الموارد البشرية؛ قسم شؤون الموظفين"
        },
        {
          "language": "ckb",
          "text": "بەشی کارمەندان؛ بەشی سەرچاوە مرۆییەکان"
        },
        {
          "language": "en",
          "text": "HR department; personnel department"
        },
        {
          "language": "fa",
          "text": "بخش منابع انسانی؛ اداره پرسنل"
        },
        {
          "language": "kmr",
          "text": "beşa karmendan; beşa çavkaniyên mirovî"
        },
        {
          "language": "pl",
          "text": "dział kadr; dział personalny"
        },
        {
          "language": "ro",
          "text": "departamentul de resurse umane; departamentul de personal"
        },
        {
          "language": "ru",
          "text": "отдел кадров; HR-отдел"
        },
        {
          "language": "sq",
          "text": "departamenti i burimeve njerëzore; zyra e personelit"
        },
        {
          "language": "tr",
          "text": "insan kaynakları departmanı; personel bölümü"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schicken Sie die Krankmeldung an die Personalabteilung.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى إرسال الإجازة المرضية إلى قسم الموارد البشرية."
            },
            {
              "language": "ckb",
              "text": "تکایە ڕاپۆرتی نەخۆشییەکە بۆ بەشی کارمەندان بنێرن."
            },
            {
              "language": "en",
              "text": "Please send the sick note to the HR department."
            },
            {
              "language": "fa",
              "text": "لطفاً گواهی بیماری را به بخش منابع انسانی ارسال کنید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe belgeya nexweşiyê ji beşa karmendan re bişînin."
            },
            {
              "language": "pl",
              "text": "Proszę wysłać zwolnienie lekarskie do działu kadr."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să trimiteți concediul medical la departamentul de resurse umane."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, отправьте больничный лист в отдел кадров."
            },
            {
              "language": "sq",
              "text": "Ju lutem dërgoni raportin mjekësor te departamenti i burimeve njerëzore."
            },
            {
              "language": "tr",
              "text": "Lütfen hastalık raporunu insan kaynakları departmanına gönderin."
            }
          ]
        },
        {
          "baseText": "Die Personalabteilung beantwortet Fragen zum Arbeitsvertrag.",
          "translations": [
            {
              "language": "ar",
              "text": "يجيب قسم الموارد البشرية عن الأسئلة المتعلقة بعقد العمل."
            },
            {
              "language": "ckb",
              "text": "بەشی کارمەندان وەڵامی پرسیارەکانی گرێبەستی کار دەداتەوە."
            },
            {
              "language": "en",
              "text": "The HR department answers questions about the employment contract."
            },
            {
              "language": "fa",
              "text": "بخش منابع انسانی به سؤال‌های مربوط به قرارداد کار پاسخ می‌دهد."
            },
            {
              "language": "kmr",
              "text": "Beşa karmendan bersiva pirsên li ser peymana kar dide."
            },
            {
              "language": "pl",
              "text": "Dział kadr odpowiada na pytania dotyczące umowy o pracę."
            },
            {
              "language": "ro",
              "text": "Departamentul de resurse umane răspunde la întrebări despre contractul de muncă."
            },
            {
              "language": "ru",
              "text": "Отдел кадров отвечает на вопросы о трудовом договоре."
            },
            {
              "language": "sq",
              "text": "Departamenti i burimeve njerëzore u përgjigjet pyetjeve për kontratën e punës."
            },
            {
              "language": "tr",
              "text": "İnsan kaynakları departmanı iş sözleşmesiyle ilgili soruları yanıtlar."
            }
          ]
        }
      ]
    },
    {
      "word": "der Personalausweis",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Personalausweise",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Per-so-nal-aus-weis",
      "topics": [
        "public-services",
        "documents-and-administration",
