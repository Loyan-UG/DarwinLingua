      "meanings": [
        {
          "language": "ar",
          "text": "إمداد المياه"
        },
        {
          "language": "ckb",
          "text": "دابینکردنی ئاو"
        },
        {
          "language": "en",
          "text": "water supply"
        },
        {
          "language": "fa",
          "text": "تأمین آب"
        },
        {
          "language": "kmr",
          "text": "dabînkirina avê"
        },
        {
          "language": "pl",
          "text": "zaopatrzenie w wodę"
        },
        {
          "language": "ro",
          "text": "aprovizionare cu apă"
        },
        {
          "language": "ru",
          "text": "водоснабжение"
        },
        {
          "language": "sq",
          "text": "furnizim me ujë"
        },
        {
          "language": "tr",
          "text": "su temini"
        }
      ],
      "examples": [
        {
          "baseText": "Die Stadt investiert in die Wasserversorgung, damit es auch in trockenen Sommern genug Trinkwasser gibt.",
          "translations": [
            {
              "language": "ar",
              "text": "تستثمر المدينة في إمداد المياه حتى يتوفر ما يكفي من مياه الشرب حتى في الصيف الجاف."
            },
            {
              "language": "ckb",
              "text": "شار وەبەرهێنان لە دابینکردنی ئاو دەکات بۆ ئەوەی تەنانەت لە هاوینی وشکیشدا ئاوی خواردنەوەی پێویست هەبێت."
            },
            {
              "language": "en",
              "text": "The city is investing in the water supply so there is enough drinking water even in dry summers."
            },
            {
              "language": "fa",
              "text": "شهر در تأمین آب سرمایه‌گذاری می‌کند تا حتی در تابستان‌های خشک هم آب آشامیدنی کافی وجود داشته باشد."
            },
            {
              "language": "kmr",
              "text": "Bajar di dabînkirina avê de veberhênan dike da ku di havînên hişk de jî ava vexwarinê têr hebe."
            },
            {
              "language": "pl",
              "text": "Miasto inwestuje w zaopatrzenie w wodę, aby nawet w suche lata było dość wody pitnej."
            },
            {
              "language": "ro",
              "text": "Orașul investește în aprovizionarea cu apă, ca să existe suficientă apă potabilă și în verile secetoase."
            },
            {
              "language": "ru",
              "text": "Город инвестирует в водоснабжение, чтобы даже сухим летом было достаточно питьевой воды."
            },
            {
              "language": "sq",
              "text": "Qyteti investon në furnizimin me ujë, që edhe në verëra të thata të ketë mjaft ujë të pijshëm."
            },
            {
              "language": "tr",
              "text": "Şehir, kurak yazlarda bile yeterli içme suyu olması için su teminine yatırım yapıyor."
            }
          ]
        },
        {
          "baseText": "Nach dem Rohrbruch war die Wasserversorgung im Gebäude für mehrere Stunden unterbrochen.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد كسر الأنبوب انقطع إمداد المياه في المبنى لعدة ساعات."
            },
            {
              "language": "ckb",
              "text": "دوای شکاوی لوولەکە، دابینکردنی ئاو لە بیناکەدا بۆ چەند کاتژمێر پچڕا."
            },
            {
              "language": "en",
              "text": "After the pipe burst, the water supply in the building was interrupted for several hours."
            },
            {
              "language": "fa",
              "text": "پس از ترکیدگی لوله، تأمین آب ساختمان برای چند ساعت قطع شد."
