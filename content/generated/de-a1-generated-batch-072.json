      "examples": [
        {
          "baseText": "Das kostet neunzig Euro.",
          "translations": [
            {
              "language": "ar",
              "text": "هذا يكلف تسعين يورو."
            },
            {
              "language": "ckb",
              "text": "ئەمە نەوەد یۆرۆیە."
            },
            {
              "language": "en",
              "text": "That costs ninety euros."
            },
            {
              "language": "fa",
              "text": "این نود یورو قیمت دارد."
            },
            {
              "language": "kmr",
              "text": "Ev nod euro ye."
            },
            {
              "language": "pl",
              "text": "To kosztuje dziewięćdziesiąt euro."
            },
            {
              "language": "ro",
              "text": "Aceasta costă nouăzeci de euro."
            },
            {
              "language": "ru",
              "text": "Это стоит девяносто евро."
            },
            {
              "language": "sq",
              "text": "Kjo kushton nëntëdhjetë euro."
            },
            {
              "language": "tr",
              "text": "Bu doksan avro tutuyor."
            }
          ]
        },
        {
          "baseText": "Meine Oma ist neunzig Jahre alt.",
          "translations": [
            {
              "language": "ar",
              "text": "جدتي عمرها تسعون عامًا."
            },
            {
              "language": "ckb",
              "text": "داپیرەم نەوەد ساڵەیە."
            },
            {
              "language": "en",
              "text": "My grandma is ninety years old."
            },
            {
              "language": "fa",
              "text": "مادربزرگم نود ساله است."
            },
            {
              "language": "kmr",
              "text": "Dayika diya min nod salî ye."
            },
            {
              "language": "pl",
              "text": "Moja babcia ma dziewięćdziesiąt lat."
            },
            {
              "language": "ro",
              "text": "Bunica mea are nouăzeci de ani."
            },
            {
              "language": "ru",
              "text": "Моей бабушке девяносто лет."
            },
            {
              "language": "sq",
              "text": "Gjyshja ime është nëntëdhjetë vjeç."
            },
            {
              "language": "tr",
              "text": "Büyükannem doksan yaşında."
            }
          ]
        }
      ]
