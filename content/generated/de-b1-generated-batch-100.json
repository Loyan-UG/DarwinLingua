  "entries": [
    {
      "word": "die Notaufnahme",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": "Notaufnahmen",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Not-auf-nah-me",
      "topics": [
        "healthcare-and-appointments",
        "public-services",
        "everyday-life"
      ],
      "usageLabels": [
        "formal",
        "everyday",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "in die Notaufnahme gehen",
          "meaning": "to go to the emergency room"
        },
        {
          "text": "die Notaufnahme ist voll",
          "meaning": "the emergency room is full"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Notfall",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "aufnehmen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قسم الطوارئ"
        },
        {
          "language": "ckb",
          "text": "بەشی فریاکەوتن"
        },
        {
          "language": "en",
          "text": "emergency room; emergency department"
        },
        {
          "language": "fa",
          "text": "اورژانس بیمارستان؛ بخش فوریت‌ها"
        },
        {
          "language": "kmr",
          "text": "beşa lezgîn; acîl"
        },
        {
          "language": "pl",
          "text": "izba przyjęć; oddział ratunkowy"
        },
        {
          "language": "ro",
          "text": "camera de gardă; urgențe"
        },
        {
          "language": "ru",
          "text": "приёмное отделение; отделение неотложной помощи"
        },
        {
          "language": "sq",
          "text": "urgjenca; reparti i emergjencës"
        },
        {
          "language": "tr",
          "text": "acil servis"
        }
      ],
      "examples": [
        {
          "baseText": "Nach dem Unfall wurde er direkt in die Notaufnahme gebracht.",
          "translations": [
            {
              "language": "ar",
              "text": "بعد الحادث نُقل مباشرة إلى قسم الطوارئ."
            },
            {
              "language": "ckb",
              "text": "دوای ڕووداوەکە ڕاستەوخۆ بردرایە بەشی فریاکەوتن."
            },
            {
              "language": "en",
              "text": "After the accident, he was taken directly to the emergency room."
            },
            {
              "language": "fa",
              "text": "بعد از حادثه، او مستقیم به اورژانس برده شد."
            },
            {
              "language": "kmr",
              "text": "Piştî qezayê ew rasterast birin beşa lezgîn."
            },
            {
              "language": "pl",
              "text": "Po wypadku zabrano go bezpośrednio na izbę przyjęć."
            },
            {
              "language": "ro",
              "text": "După accident, a fost dus direct la camera de gardă."
            },
            {
              "language": "ru",
              "text": "После аварии его сразу отвезли в приёмное отделение."
            },
            {
              "language": "sq",
              "text": "Pas aksidentit, ai u dërgua direkt në urgjencë."
            },
            {
              "language": "tr",
              "text": "Kazadan sonra doğrudan acil servise götürüldü."
            }
          ]
        },
        {
          "baseText": "Bei starken Schmerzen sollten Sie die Notaufnahme aufsuchen.",
          "translations": [
            {
              "language": "ar",
              "text": "عند وجود آلام شديدة ينبغي التوجه إلى قسم الطوارئ."
            },
            {
              "language": "ckb",
              "text": "لە کاتی ئازاری زۆردا پێویستە سەردانی بەشی فریاکەوتن بکەن."
            },
            {
              "language": "en",
              "text": "If you have severe pain, you should go to the emergency room."
            },
            {
              "language": "fa",
              "text": "در صورت درد شدید باید به اورژانس مراجعه کنید."
            },
            {
              "language": "kmr",
              "text": "Heke êşa we zêde be, divê hûn biçin beşa lezgîn."
            },
            {
              "language": "pl",
              "text": "Przy silnym bólu należy udać się na izbę przyjęć."
            },
            {
              "language": "ro",
              "text": "În caz de dureri puternice, ar trebui să mergeți la urgențe."
            },
            {
              "language": "ru",
              "text": "При сильной боли следует обратиться в приёмное отделение."
            },
            {
              "language": "sq",
              "text": "Në rast dhimbjeje të fortë, duhet të shkoni në urgjencë."
            },
            {
              "language": "tr",
              "text": "Şiddetli ağrı durumunda acil servise gitmelisiniz."
            }
          ]
        }
      ]
    },
    {
      "word": "der Notdienst",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "der",
      "plural": "Notdienste",
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Not-dienst",
      "topics": [
        "healthcare-and-appointments",
        "public-services",
        "customer-service"
      ],
      "usageLabels": [
        "formal",
        "customer-facing",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "masculine noun"
      ],
      "collocations": [
        {
          "text": "den ärztlichen Notdienst anrufen",
          "meaning": "to call the out-of-hours medical service"
        },
        {
          "text": "der Notdienst ist erreichbar",
          "meaning": "the emergency service is reachable"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "der Notfall",
          "relationLabel": "noun",
          "note": null
        },
        {
          "lemma": "der Dienst",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "خدمة الطوارئ؛ خدمة مناوبة للحالات العاجلة"
        },
        {
          "language": "ckb",
          "text": "خزمەتی فریاکەوتن؛ خزمەتی کاتی ناچاری"
        },
        {
          "language": "en",
          "text": "emergency service; out-of-hours service"
        },
        {
          "language": "fa",
          "text": "خدمات اضطراری؛ سرویس کشیک"
        },
        {
          "language": "kmr",
          "text": "xizmeta lezgîn; xizmeta derveyî demê"
        },
        {
          "language": "pl",
          "text": "dyżur awaryjny; pogotowie"
        },
        {
          "language": "ro",
          "text": "serviciu de urgență; serviciu de gardă"
        },
        {
          "language": "ru",
          "text": "дежурная аварийная служба; неотложная служба"
        },
        {
          "language": "sq",
          "text": "shërbim emergjence; shërbim kujdestarie"
        },
        {
          "language": "tr",
          "text": "acil hizmet; nöbetçi servis"
        }
      ],
      "examples": [
        {
          "baseText": "Am Wochenende erreichen Sie den ärztlichen Notdienst unter dieser Nummer.",
          "translations": [
            {
              "language": "ar",
              "text": "في عطلة نهاية الأسبوع يمكنكم الوصول إلى خدمة الطوارئ الطبية على هذا الرقم."
            },
            {
              "language": "ckb",
              "text": "لە کۆتایی هەفتەدا دەتوانن بەو ژمارەیە پەیوەندی بە خزمەتی فریاکەوتنی پزیشکی بکەن."
            },
            {
              "language": "en",
              "text": "On weekends, you can reach the out-of-hours medical service at this number."
            },
            {
              "language": "fa",
              "text": "آخر هفته‌ها می‌توانید با این شماره با خدمات پزشکی کشیک تماس بگیرید."
            },
            {
              "language": "kmr",
              "text": "Dawiya hefteyê hûn dikarin bi vê hejmarê bigihîjin xizmeta bijîşkî ya lezgîn."
            },
            {
              "language": "pl",
              "text": "W weekend można skontaktować się z dyżurem lekarskim pod tym numerem."
            },
            {
              "language": "ro",
              "text": "În weekend puteți contacta serviciul medical de gardă la acest număr."
            },
            {
              "language": "ru",
              "text": "В выходные вы можете связаться с дежурной медицинской службой по этому номеру."
            },
            {
              "language": "sq",
              "text": "Në fundjavë mund të kontaktoni shërbimin mjekësor të urgjencës në këtë numër."
            },
            {
              "language": "tr",
              "text": "Hafta sonu nöbetçi sağlık hizmetine bu numaradan ulaşabilirsiniz."
            }
          ]
        },
        {
          "baseText": "Für den Wasserschaden rufen wir sofort den Notdienst an.",
          "translations": [
            {
              "language": "ar",
              "text": "بسبب ضرر المياه سنتصل فورًا بخدمة الطوارئ."
            },
            {
              "language": "ckb",
              "text": "بۆ زیانی ئاوەکە دەستبەجێ پەیوەندی بە خزمەتی فریاکەوتن دەکەین."
            },
            {
              "language": "en",
              "text": "For the water damage, we will call the emergency service immediately."
            },
            {
              "language": "fa",
              "text": "برای خسارت آب، فوراً با سرویس اضطراری تماس می‌گیریم."
            },
            {
              "language": "kmr",
              "text": "Ji bo zirara avê em tavilê telefonî xizmeta lezgîn dikin."
            },
            {
              "language": "pl",
              "text": "W sprawie szkody wodnej natychmiast dzwonimy po pogotowie."
            },
            {
              "language": "ro",
              "text": "Pentru dauna cauzată de apă sunăm imediat la serviciul de urgență."
            },
            {
              "language": "ru",
              "text": "Из-за ущерба от воды мы сразу вызываем аварийную службу."
            },
            {
              "language": "sq",
              "text": "Për dëmin nga uji, telefonojmë menjëherë shërbimin e emergjencës."
            },
            {
              "language": "tr",
              "text": "Su hasarı için hemen acil servisi arıyoruz."
            }
          ]
        }
      ]
    },
    {
      "word": "notwendig",
      "language": "de",
