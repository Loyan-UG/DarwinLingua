      "examples": [
        {
          "baseText": "Die Ankunft ist um zehn Uhr.",
          "translations": [
            {
              "language": "ar",
              "text": "الوصول في الساعة العاشرة."
            },
            {
              "language": "ckb",
              "text": "گەیشتنەکە کاتژمێر دەیە."
            },
            {
              "language": "en",
              "text": "The arrival is at ten o’clock."
            },
            {
              "language": "fa",
              "text": "ورود ساعت ده است."
            },
            {
              "language": "kmr",
              "text": "Gihîştin di saet dehan de ye."
            },
            {
              "language": "pl",
              "text": "Przyjazd jest o dziesiątej."
            },
            {
              "language": "ro",
              "text": "Sosirea este la ora zece."
            },
            {
              "language": "ru",
              "text": "Прибытие в десять часов."
            },
            {
              "language": "sq",
              "text": "Mbërritja është në orën dhjetë."
            },
            {
              "language": "tr",
              "text": "Varış saat onda."
            }
          ]
        },
        {
          "baseText": "Wir warten auf die Ankunft von Frau Müller.",
          "translations": [
            {
              "language": "ar",
              "text": "ننتظر وصول السيدة مولر."
            },
            {
              "language": "ckb",
              "text": "چاوەڕێی گەیشتنی خانمی مولەر دەکەین."
            },
            {
              "language": "en",
              "text": "We are waiting for Ms. Müller’s arrival."
            },
            {
              "language": "fa",
              "text": "ما منتظر ورود خانم مولر هستیم."
            },
            {
              "language": "kmr",
              "text": "Em li benda gihîştina xanim Müller in."
            },
            {
              "language": "pl",
              "text": "Czekamy na przyjazd pani Müller."
            },
            {
              "language": "ro",
              "text": "Așteptăm sosirea doamnei Müller."
            },
            {
              "language": "ru",
              "text": "Мы ждем прибытия госпожи Мюллер."
            },
            {
              "language": "sq",
              "text": "Po presim mbërritjen e zonjës Müller."
            },
            {
              "language": "tr",
              "text": "Bayan Müller’in varışını bekliyoruz."
            }
          ]
        }
