          "text": "varmak; ulaşmak"
        }
      ],
      "examples": [
        {
          "baseText": "Der Zug kommt um acht Uhr an.",
          "translations": [
            {
              "language": "ar",
              "text": "يصل القطار في الساعة الثامنة."
            },
            {
              "language": "ckb",
              "text": "شەمەندەفەرەکە کاتژمێر هەشت دەگات."
            },
            {
              "language": "en",
              "text": "The train arrives at eight o’clock."
            },
            {
              "language": "fa",
              "text": "قطار ساعت هشت می‌رسد."
            },
            {
              "language": "kmr",
              "text": "Trên di saet heştan de digihîje."
            },
            {
              "language": "pl",
              "text": "Pociąg przyjeżdża o ósmej."
            },
            {
              "language": "ro",
              "text": "Trenul ajunge la ora opt."
            },
            {
              "language": "ru",
              "text": "Поезд прибывает в восемь часов."
            },
            {
              "language": "sq",
              "text": "Treni arrin në orën tetë."
            },
            {
              "language": "tr",
              "text": "Tren saat sekizde varıyor."
            }
          ]
        },
        {
          "baseText": "Ich komme heute später an.",
          "translations": [
            {
              "language": "ar",
              "text": "سأصل اليوم متأخراً."
            },
            {
              "language": "ckb",
              "text": "ئەمڕۆ درەنگتر دەگەم."
            },
            {
              "language": "en",
              "text": "I will arrive later today."
            },
            {
              "language": "fa",
              "text": "امروز دیرتر می‌رسم."
            },
            {
              "language": "kmr",
              "text": "Ez îro derengtir digihîjim."
            },
            {
              "language": "pl",
              "text": "Dzisiaj przyjadę później."
            },
            {
              "language": "ro",
              "text": "Astăzi ajung mai târziu."
            },
            {
              "language": "ru",
              "text": "Сегодня я приеду позже."
            },
            {
              "language": "sq",
              "text": "Sot arrij më vonë."
            },
            {
              "language": "tr",
              "text": "Bugün daha geç varıyorum."
            }
          ]
        }
      ]
    },
