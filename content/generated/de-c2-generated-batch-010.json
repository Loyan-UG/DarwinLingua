  "entries": [
    {
      "word": "aushöhlen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "aushöhlen",
      "pronunciationIpa": null,
      "syllableBreak": "aus-höh-len",
      "topics": [
        "law-and-compliance",
        "management-and-leadership",
        "advanced-analysis"
      ],
      "usageLabels": [
        "formal",
        "written",
        "advanced",
        "analysis"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; höhlt aus, höhlte aus, hat ausgehöhlt; literal or figurative"
      ],
      "collocations": [
        {
          "text": "Rechte aushöhlen",
          "meaning": "to undermine or hollow out rights"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "die Aushöhlung",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يفرغ من المضمون؛ يقوّض تدريجياً"
        },
        {
          "language": "ckb",
          "text": "ناوەڕۆک بەتەواوی لاواز بکات؛ بنبڕ بکات"
        },
        {
          "language": "en",
          "text": "to hollow out; to undermine gradually"
        },
        {
          "language": "fa",
          "text": "تهی کردن؛ به‌تدریج تضعیف کردن"
        },
        {
          "language": "kmr",
          "text": "navê vala kirin; hêdî hêdî lawaz kirin"
        },
        {
          "language": "pl",
          "text": "wydrążać; stopniowo podważać"
        },
        {
          "language": "ro",
          "text": "a goli de conținut; a submina treptat"
        },
        {
          "language": "ru",
          "text": "выхолащивать; постепенно подрывать"
        },
        {
          "language": "sq",
          "text": "ta zbrazësh nga përmbajtja; ta minosh gradualisht"
        },
        {
          "language": "tr",
          "text": "içini boşaltmak; giderek zayıflatmak"
        }
      ],
      "examples": [
        {
          "baseText": "Mehrere Ausnahmeregelungen höhlten den ursprünglich strengen Datenschutzstandard faktisch aus.",
          "translations": [
            {
              "language": "ar",
              "text": "أفرغت عدة قواعد استثنائية معيار حماية البيانات الصارم أصلاً من مضمونه عملياً."
            },
            {
              "language": "ckb",
              "text": "چەند ڕێسای تایبەت ستانداردی سەرەتایی توندی پاراستنی داتایان بە کردەوە لاواز کرد."
            },
            {
              "language": "en",
              "text": "Several exceptions effectively hollowed out the originally strict data protection standard."
            },
            {
              "language": "fa",
              "text": "چند مقرره استثنایی عملاً استاندارد سخت‌گیرانه اولیه حفاظت از داده را تهی کرد."
            },
            {
              "language": "kmr",
              "text": "Çend rêzikên îstîsna standarda parastina daneyan a destpêkê hişk bi rastî vala kirin."
            },
            {
              "language": "pl",
              "text": "Kilka wyjątków faktycznie wydrążyło pierwotnie surowy standard ochrony danych."
            },
            {
              "language": "ro",
              "text": "Mai multe excepții au golit practic de conținut standardul inițial strict de protecție a datelor."
            },
            {
              "language": "ru",
              "text": "Несколько исключений фактически выхолостили изначально строгий стандарт защиты данных."
            },
            {
              "language": "sq",
              "text": "Disa rregulla përjashtuese e zbrazën praktikisht standardin fillimisht të rreptë të mbrojtjes së të dhënave."
            },
            {
              "language": "tr",
              "text": "Birkaç istisna kuralı, başlangıçta katı olan veri koruma standardının fiilen içini boşalttı."
            }
          ]
        },
        {
          "baseText": "Wenn zentrale Entscheidungen nur noch informell fallen, wird die Rolle des Parlaments ausgehöhlt.",
          "translations": [
            {
              "language": "ar",
              "text": "إذا أصبحت القرارات المركزية تُتخذ فقط بشكل غير رسمي، فإن دور البرلمان يُفرغ من مضمونه."
            },
            {
              "language": "ckb",
              "text": "ئەگەر بڕیارە سەرەکییەکان تەنها بە نافەرمی بدرێن، ڕۆڵی پەرلەمان لاواز دەکرێت."
            },
            {
              "language": "en",
              "text": "If key decisions are made only informally, the role of parliament is hollowed out."
            },
            {
              "language": "fa",
              "text": "اگر تصمیم‌های اصلی فقط به‌صورت غیررسمی گرفته شوند، نقش پارلمان تهی می‌شود."
            },
            {
              "language": "kmr",
              "text": "Ger biryarên sereke tenê bi awayekî nefermî bên dayîn, rola parlamentoyê vala dibe."
            },
            {
              "language": "pl",
              "text": "Jeśli kluczowe decyzje zapadają już tylko nieformalnie, rola parlamentu zostaje wydrążona."
            },
            {
              "language": "ro",
              "text": "Dacă deciziile centrale sunt luate doar informal, rolul parlamentului este golit de conținut."
            },
            {
              "language": "ru",
              "text": "Если ключевые решения принимаются лишь неформально, роль парламента выхолащивается."
            },
            {
              "language": "sq",
              "text": "Nëse vendimet qendrore merren vetëm në mënyrë informale, roli i parlamentit zbrazet nga përmbajtja."
            },
            {
              "language": "tr",
              "text": "Merkezi kararlar yalnızca gayriresmî biçimde alınırsa parlamentonun rolü içi boşaltılmış hale gelir."
            }
          ]
        }
      ]
    },
    {
      "word": "auskneifen",
      "language": "de",
      "cefrLevel": "C2",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "auskneifen",
      "pronunciationIpa": null,
      "syllableBreak": "aus-knei-fen",
      "topics": [
        "social-and-relationships",
        "work-and-jobs",
        "everyday-life"
      ],
      "usageLabels": [
        "informal",
        "sensitive"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable informal verb; kneift aus, kniff aus, ist ausgekniffen; means to back out or avoid responsibility"
      ],
      "collocations": [
        {
          "text": "im letzten Moment auskneifen",
          "meaning": "to back out at the last moment"
        }
      ],
      "wordFamilies": [],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يتهرب؛ يتراجع خوفاً"
        },
        {
          "language": "ckb",
          "text": "خۆ لە بەرپرسیارێتی بدزێتەوە؛ لە کۆتا ساتدا پاشگەز ببێتەوە"
        },
        {
          "language": "en",
          "text": "to chicken out; to back out"
        },
        {
          "language": "fa",
          "text": "جا زدن؛ از زیر مسئولیت در رفتن"
        },
        {
          "language": "kmr",
          "text": "paşve kişandin; ji berpirsiyariyê revîn"
        },
        {
          "language": "pl",
          "text": "stchórzyć; wymigać się"
        },
        {
          "language": "ro",
          "text": "a da înapoi; a se eschiva"
        },
        {
          "language": "ru",
          "text": "струсить; уклониться"
        },
        {
          "language": "sq",
          "text": "të tërhiqesh nga frika; të shmangesh"
        },
        {
          "language": "tr",
          "text": "vazgeçmek; korkup kaçmak"
        }
      ],
      "examples": [
        {
          "baseText": "Beim Kundentermin durfte niemand auskneifen, weil die offenen Fragen nur gemeinsam zu klären waren.",
          "translations": [
            {
              "language": "ar",
              "text": "لم يكن مسموحاً لأحد بالتهرب في موعد العميل، لأن الأسئلة المفتوحة كان لا بد من توضيحها معاً."
            },
            {
              "language": "ckb",
              "text": "لە کاتی دیداری کڕیاردا کەس نەیدەتوانی خۆی بدزێتەوە، چونکە پرسیارە کراوەکان تەنها بە هاوبەشی ڕوون دەکرانەوە."
            },
            {
              "language": "en",
              "text": "No one was allowed to back out of the customer meeting because the open questions could only be clarified together."
            },
            {
              "language": "fa",
              "text": "در جلسه با مشتری هیچ‌کس نباید جا می‌زد، چون پرسش‌های باز فقط به‌صورت مشترک قابل روشن شدن بودند."
            },
            {
              "language": "kmr",
              "text": "Di civîna xerîdar de tu kes nedikarî paşve bikeve, ji ber ku pirsên vekirî tenê bi hev re zelal dibûn."
            },
            {
              "language": "pl",
              "text": "Nikt nie mógł wymigać się ze spotkania z klientem, ponieważ otwarte kwestie można było wyjaśnić tylko wspólnie."
            },
            {
              "language": "ro",
              "text": "Nimeni nu avea voie să se eschiveze de la întâlnirea cu clientul, deoarece întrebările deschise puteau fi clarificate doar împreună."
            },
            {
              "language": "ru",
              "text": "На встрече с клиентом никто не мог уклониться, потому что открытые вопросы можно было прояснить только вместе."
            },
            {
              "language": "sq",
              "text": "Askush nuk duhej të shmangej nga takimi me klientin, sepse çështjet e hapura mund të sqaroheshin vetëm së bashku."
            },
            {
              "language": "tr",
              "text": "Müşteri toplantısından kimse kaçamazdı, çünkü açık sorular ancak birlikte netleştirilebilirdi."
            }
          ]
        },
        {
          "baseText": "Er hatte die Wanderung selbst vorgeschlagen und wollte nun wegen des Regens auskneifen.",
          "translations": [
            {
              "language": "ar",
              "text": "كان هو من اقترح الرحلة سيراً، والآن أراد التراجع بسبب المطر."
            },
            {
              "language": "ckb",
              "text": "خۆی پێشنیاری پیاسەکەی کردبوو و ئێستا بەهۆی بارانەوە دەیویست پاشگەز ببێتەوە."
            },
            {
              "language": "en",
              "text": "He had suggested the hike himself and now wanted to back out because of the rain."
            },
            {
              "language": "fa",
