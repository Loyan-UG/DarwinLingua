      ],
      "examples": [
        {
          "baseText": "Meine Schwester wohnt in Köln.",
          "translations": [
            {
              "language": "ar",
              "text": "أختي تسكن في كولن."
            },
            {
              "language": "ckb",
              "text": "خوشکم لە کۆلن دەژیت."
            },
            {
              "language": "en",
              "text": "My sister lives in Cologne."
            },
            {
              "language": "fa",
              "text": "خواهرم در کلن زندگی می‌کند."
            },
            {
              "language": "kmr",
              "text": "Xwişka min li Kölnê dijî."
            },
            {
              "language": "pl",
              "text": "Moja siostra mieszka w Kolonii."
            },
            {
              "language": "ro",
              "text": "Sora mea locuiește în Köln."
            },
            {
              "language": "ru",
              "text": "Моя сестра живёт в Кёльне."
            },
            {
              "language": "sq",
              "text": "Motra ime jeton në Këln."
            },
            {
              "language": "tr",
              "text": "Kız kardeşim Köln’de yaşıyor."
            }
          ]
        },
        {
          "baseText": "Die Schwester kommt heute zu Besuch.",
          "translations": [
            {
              "language": "ar",
              "text": "الأخت تأتي للزيارة اليوم."
            },
            {
              "language": "ckb",
              "text": "خوشکەکە ئەمڕۆ بۆ سەردان دێت."
            },
            {
              "language": "en",
              "text": "The sister is coming to visit today."
            },
            {
              "language": "fa",
              "text": "خواهر امروز به دیدن می‌آید."
            },
            {
              "language": "kmr",
              "text": "Xwişk îro tê serdanê."
            },
            {
              "language": "pl",
              "text": "Siostra przychodzi dziś w odwiedziny."
            },
            {
              "language": "ro",
              "text": "Sora vine astăzi în vizită."
            },
            {
              "language": "ru",
              "text": "Сестра сегодня придёт в гости."
            },
            {
              "language": "sq",
              "text": "Motra vjen sot për vizitë."
            },
            {
              "language": "tr",
              "text": "Kız kardeş bugün ziyarete geliyor."
            }
          ]
