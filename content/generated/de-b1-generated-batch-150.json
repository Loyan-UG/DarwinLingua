      "examples": [
        {
          "baseText": "Werfen Sie die Rechnung bitte nicht weg, falls es eine Reklamation gibt.",
          "translations": [
            {
              "language": "ar",
              "text": "من فضلك لا ترمِ الفاتورة في حال وُجدت شكوى."
            },
            {
              "language": "ckb",
              "text": "تکایە پسووڵەکە فڕێ مەدەن ئەگەر سکاڵایەک هەبوو."
            },
            {
              "language": "en",
              "text": "Please do not throw away the receipt in case there is a complaint."
            },
            {
              "language": "fa",
              "text": "لطفاً فاکتور را دور نیندازید، اگر شکایتی پیش آمد."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe fatûreyê dûr neavêjin heke gilîkirinek hebe."
            },
            {
              "language": "pl",
              "text": "Proszę nie wyrzucać rachunku, gdyby była reklamacja."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să nu aruncați factura în caz că există o reclamație."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не выбрасывайте чек на случай рекламации."
            },
            {
