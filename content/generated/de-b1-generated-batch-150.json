  "entries": [
    {
      "word": "die Wasserknappheit",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Noun",
      "article": "die",
      "plural": null,
      "infinitive": null,
      "pronunciationIpa": null,
      "syllableBreak": "Was-ser-knapp-heit",
      "topics": [
        "environment-and-sustainability",
        "public-services",
        "quality-and-risk"
      ],
      "usageLabels": [
        "formal",
        "written",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "feminine noun; usually singular"
      ],
      "collocations": [
        {
          "text": "unter Wasserknappheit leiden",
          "meaning": "to suffer from water shortage"
        },
        {
          "text": "Wasserknappheit vermeiden",
          "meaning": "to avoid water shortage"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "knapp",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "ندرة المياه؛ نقص المياه"
        },
        {
          "language": "ckb",
          "text": "کەمئاوی؛ کەمی ئاو"
        },
        {
          "language": "en",
          "text": "water shortage; water scarcity"
        },
        {
          "language": "fa",
          "text": "کمبود آب؛ بحران کم‌آبی"
        },
        {
          "language": "kmr",
          "text": "kêmbûna avê; kêmasiya avê"
        },
        {
          "language": "pl",
          "text": "niedobór wody"
        },
        {
          "language": "ro",
          "text": "lipsă de apă; penurie de apă"
        },
        {
          "language": "ru",
          "text": "нехватка воды; дефицит воды"
        },
        {
          "language": "sq",
          "text": "mungesë uji; pakicë uji"
        },
        {
          "language": "tr",
          "text": "su kıtlığı; su yetersizliği"
        }
      ],
      "examples": [
        {
          "baseText": "In heißen Sommern wird Wasserknappheit für viele Gemeinden zum Problem.",
          "translations": [
            {
              "language": "ar",
              "text": "في فصول الصيف الحارة تصبح ندرة المياه مشكلة لكثير من البلديات."
            },
            {
              "language": "ckb",
              "text": "لە هاوینی گەرمدا کەمئاوی بۆ زۆر شارەوانی دەبێتە کێشە."
            },
            {
              "language": "en",
              "text": "In hot summers, water shortage becomes a problem for many municipalities."
            },
            {
              "language": "fa",
              "text": "در تابستان‌های گرم، کمبود آب برای بسیاری از شهرداری‌ها مشکل می‌شود."
            },
            {
              "language": "kmr",
              "text": "Di havînên germ de kêmbûna avê ji bo gelek şaredariyan dibe pirsgirêk."
            },
            {
              "language": "pl",
              "text": "W gorące lata niedobór wody staje się problemem dla wielu gmin."
            },
            {
              "language": "ro",
              "text": "În verile fierbinți, lipsa de apă devine o problemă pentru multe comune."
            },
            {
              "language": "ru",
              "text": "В жаркое лето нехватка воды становится проблемой для многих муниципалитетов."
            },
            {
              "language": "sq",
              "text": "Në verat e nxehta mungesa e ujit bëhet problem për shumë komuna."
            },
            {
              "language": "tr",
              "text": "Sıcak yazlarda su kıtlığı birçok belediye için sorun haline gelir."
            }
          ]
        },
        {
          "baseText": "Die Firma sammelt Regenwasser, um bei Wasserknappheit weniger Trinkwasser zu verbrauchen.",
          "translations": [
            {
              "language": "ar",
              "text": "تجمع الشركة مياه الأمطار لتستهلك ماء شرب أقل عند نقص المياه."
            },
            {
              "language": "ckb",
              "text": "کۆمپانیاکە ئاوی باران کۆدەکاتەوە بۆ ئەوەی لە کاتی کەمئاوی ئاوی خواردنەوەی کەمتر بەکاربهێنێت."
            },
            {
              "language": "en",
              "text": "The company collects rainwater to use less drinking water during water shortages."
            },
            {
              "language": "fa",
              "text": "شرکت آب باران جمع می‌کند تا هنگام کمبود آب، آب آشامیدنی کمتری مصرف کند."
            },
            {
              "language": "kmr",
              "text": "Şirket ava baranê kom dike da ku di kêmbûna avê de ava vexwarinê kêmتر bikar bîne."
            },
            {
              "language": "pl",
              "text": "Firma zbiera deszczówkę, aby przy niedoborze wody zużywać mniej wody pitnej."
            },
            {
              "language": "ro",
              "text": "Firma colectează apă de ploaie ca să consume mai puțină apă potabilă în caz de penurie."
            },
            {
              "language": "ru",
              "text": "Компания собирает дождевую воду, чтобы при нехватке воды расходовать меньше питьевой воды."
            },
            {
              "language": "sq",
              "text": "Kompania mbledh ujë shiu që gjatë mungesës së ujit të përdorë më pak ujë të pijshëm."
            },
            {
              "language": "tr",
              "text": "Şirket, su kıtlığında daha az içme suyu kullanmak için yağmur suyu topluyor."
            }
          ]
        }
      ]
    },
    {
      "word": "wegschmeißen",
      "language": "de",
      "cefrLevel": "B1",
      "partOfSpeech": "Verb",
      "article": null,
      "plural": null,
      "infinitive": "wegschmeißen",
      "pronunciationIpa": null,
      "syllableBreak": "weg-schmei-ßen",
      "topics": [
        "everyday-life",
        "environment-and-sustainability",
        "shopping-and-services"
      ],
      "usageLabels": [
        "everyday",
        "spoken",
        "high-frequency"
      ],
      "contextLabels": [],
      "grammarNotes": [
        "separable verb; colloquial synonym of wegwerfen"
      ],
      "collocations": [
        {
          "text": "alte Unterlagen wegschmeißen",
          "meaning": "to throw away old documents"
        },
        {
          "text": "Essen nicht wegschmeißen",
          "meaning": "not to throw away food"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "schmeißen",
          "relationLabel": "verb",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "يرمي؛ يتخلص من"
        },
        {
          "language": "ckb",
          "text": "فڕێدان؛ لابردن"
        },
        {
          "language": "en",
          "text": "to throw away; to discard"
        },
        {
          "language": "fa",
          "text": "دور انداختن"
        },
        {
          "language": "kmr",
          "text": "avêtin; dûr xistin"
        },
        {
          "language": "pl",
          "text": "wyrzucić"
        },
        {
          "language": "ro",
          "text": "a arunca"
        },
        {
          "language": "ru",
          "text": "выбрасывать"
        },
        {
          "language": "sq",
          "text": "të hedhësh"
        },
        {
          "language": "tr",
          "text": "atmak; çöpe atmak"
        }
      ],
      "examples": [
        {
          "baseText": "Bitte schmeißen Sie die alten Verträge nicht weg, bevor wir sie digital gespeichert haben.",
          "translations": [
            {
              "language": "ar",
              "text": "يرجى عدم رمي العقود القديمة قبل أن نحفظها رقميًا."
            },
            {
              "language": "ckb",
              "text": "تکایە گرێبەستە کۆنەکان فڕێ مەدەن پێش ئەوەی بە دیجیتاڵی پاشەکەوتیان بکەین."
            },
            {
              "language": "en",
              "text": "Please do not throw away the old contracts before we have saved them digitally."
            },
            {
              "language": "fa",
              "text": "لطفاً قراردادهای قدیمی را قبل از ذخیره دیجیتال دور نیندازید."
            },
            {
              "language": "kmr",
              "text": "Ji kerema xwe peymanên kevn berî ku em wan dijîtal tomar bikin dûr neavêjin."
            },
            {
              "language": "pl",
              "text": "Proszę nie wyrzucać starych umów, zanim zapiszemy je cyfrowo."
            },
            {
              "language": "ro",
              "text": "Vă rugăm să nu aruncați contractele vechi înainte să le salvăm digital."
            },
            {
              "language": "ru",
              "text": "Пожалуйста, не выбрасывайте старые договоры, пока мы не сохраним их в цифровом виде."
            },
            {
              "language": "sq",
              "text": "Ju lutemi mos i hidhni kontratat e vjetra para se t’i ruajmë digjitalisht."
            },
            {
              "language": "tr",
              "text": "Eski sözleşmeleri dijital olarak kaydetmeden lütfen atmayın."
            }
          ]
        },
        {
          "baseText": "Wir schmeißen zu Hause weniger Essen weg als früher.",
          "translations": [
            {
              "language": "ar",
              "text": "نرمي في البيت طعامًا أقل مما كنا نفعل سابقًا."
            },
            {
              "language": "ckb",
              "text": "لە ماڵەوە خواردنی کەمتر لە جاران فڕێ دەدەین."
            },
            {
              "language": "en",
              "text": "At home, we throw away less food than before."
            },
            {
              "language": "fa",
              "text": "در خانه نسبت به قبل غذای کمتری دور می‌ریزیم."
            },
            {
              "language": "kmr",
              "text": "Li malê em ji berê kêmتر xwarinê dûr diavêjin."
            },
            {
              "language": "pl",
              "text": "W domu wyrzucamy mniej jedzenia niż kiedyś."
            },
            {
              "language": "ro",
              "text": "Acasă aruncăm mai puțină mâncare decât înainte."
            },
            {
              "language": "ru",
              "text": "Дома мы выбрасываем меньше еды, чем раньше."
            },
            {
              "language": "sq",
              "text": "Në shtëpi hedhim më pak ushqim se më parë."
            },
            {
              "language": "tr",
              "text": "Evde eskisine göre daha az yemek atıyoruz."
            }
          ]
        }
      ]
    },
