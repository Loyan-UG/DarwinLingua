        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine Fahrgemeinschaft bilden",
          "meaning": "to form a carpool"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fahren",
          "relationLabel": "verb",
          "note": null
        },
        {
          "lemma": "die Gemeinschaft",
          "relationLabel": "noun",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "مشاركة السيارة؛ مجموعة تنقل مشتركة"
        },
        {
          "language": "ckb",
          "text": "هاوبەشی سەفەر بە ئۆتۆمبێل"
        },
        {
          "language": "en",
          "text": "carpool; ride-sharing group"
        },
        {
          "language": "fa",
          "text": "هم‌سفری با خودرو؛ کارپول"
        },
        {
          "language": "kmr",
          "text": "hevpariya ajotinê"
        },
        {
          "language": "pl",
          "text": "wspólne dojazdy; carpooling"
        },
        {
          "language": "ro",
          "text": "grup de navetă; carpool"
        },
        {
          "language": "ru",
          "text": "совместные поездки; карпул"
        },
        {
          "language": "sq",
          "text": "udhëtim i përbashkët me makinë"
        },
        {
          "language": "tr",
          "text": "araç paylaşımı; ortak yolculuk"
        }
      ],
      "examples": [
        {
          "baseText": "Drei Kollegen haben für den Weg zur Arbeit eine Fahrgemeinschaft gebildet.",
          "translations": [
            {
              "language": "ar",
              "text": "شكّل ثلاثة زملاء مجموعة تنقل مشتركة إلى العمل."
            },
            {
              "language": "ckb",
              "text": "سێ هاوکار بۆ ڕێگای کارکردن هاوبەشی سەفەر بە ئۆتۆمبێلیان دروست کرد."
            },
            {
              "language": "en",
              "text": "Three colleagues formed a carpool for the commute to work."
            },
            {
              "language": "fa",
