        "management"
      ],
      "grammarNotes": [
        "feminine noun"
      ],
      "collocations": [
        {
          "text": "eine wichtige Fähigkeit entwickeln",
          "meaning": "to develop an important skill"
        }
      ],
      "wordFamilies": [
        {
          "lemma": "fähig",
          "relationLabel": "adjective",
          "note": null
        }
      ],
      "relations": [],
      "meanings": [
        {
          "language": "ar",
          "text": "قدرة؛ مهارة"
        },
        {
          "language": "ckb",
          "text": "توانا؛ لێهاتوویی"
        },
        {
          "language": "en",
          "text": "ability; skill"
        },
        {
          "language": "fa",
          "text": "توانایی؛ مهارت"
        },
        {
          "language": "kmr",
          "text": "şiyan; jêhatîbûn"
        },
        {
          "language": "pl",
          "text": "umiejętność; zdolność"
        },
        {
          "language": "ro",
          "text": "abilitate; capacitate"
        },
        {
          "language": "ru",
          "text": "способность; навык"
        },
        {
          "language": "sq",
          "text": "aftësi; zotësi"
        },
        {
          "language": "tr",
          "text": "yetenek; beceri"
        }
      ],
      "examples": [
        {
          "baseText": "Teamfähigkeit ist in dieser Position eine wichtige Fähigkeit.",
          "translations": [
            {
              "language": "ar",
              "text": "القدرة على العمل ضمن فريق مهارة مهمة في هذا المنصب."
            },
            {
              "language": "ckb",
              "text": "توانای کارکردن لە تیمدا لەم پۆستەدا تواناێکی گرنگە."
            },
            {
              "language": "en",
              "text": "Teamwork is an important skill in this position."
            },
            {
              "language": "fa",
              "text": "توانایی کار تیمی در این موقعیت یک مهارت مهم است."
            },
            {
              "language": "kmr",
              "text": "Şiyana karê tîmê di vê pozîsyonê de şiyaneke girîng e."
            },
            {
              "language": "pl",
              "text": "Umiejętność pracy zespołowej jest na tym stanowisku ważna."
            },
            {
              "language": "ro",
              "text": "Capacitatea de a lucra în echipă este o abilitate importantă în acest post."
            },
            {
              "language": "ru",
              "text": "Умение работать в команде является важным навыком на этой должности."
            },
            {
              "language": "sq",
              "text": "Aftësia për punë në ekip është e rëndësishme në këtë pozicion."
            },
            {
              "language": "tr",
              "text": "Takım çalışması bu pozisyonda önemli bir beceridir."
            }
          ]
        },
        {
          "baseText": "Im Kurs verbessern die Teilnehmenden ihre Fähigkeit, frei zu sprechen.",
          "translations": [
            {
              "language": "ar",
              "text": "في الدورة يحسن المشاركون قدرتهم على التحدث بحرية."
            },
            {
              "language": "ckb",
              "text": "لە خولەکەدا بەشداران توانای قسەکردنی ئازادانەیان باشتر دەکەن."
            },
            {
              "language": "en",
              "text": "In the course, participants improve their ability to speak freely."
            },
            {
              "language": "fa",
              "text": "در دوره، شرکت‌کنندگان توانایی آزاد صحبت کردن خود را بهتر می‌کنند."
            },
            {
              "language": "kmr",
              "text": "Di kursê de beşdar şiyana xwe ya axaftina azad baştir dikin."
            },
            {
              "language": "pl",
              "text": "Na kursie uczestnicy poprawiają umiejętność swobodnego mówienia."
            },
            {
              "language": "ro",
              "text": "În curs, participanții își îmbunătățesc abilitatea de a vorbi liber."
            },
            {
              "language": "ru",
              "text": "На курсе участники улучшают способность свободно говорить."
            },
            {
              "language": "sq",
              "text": "Në kurs, pjesëmarrësit përmirësojnë aftësinë për të folur lirshëm."
            },
            {
              "language": "tr",
              "text": "Kursta katılımcılar serbest konuşma becerilerini geliştirir."
            }
          ]
        }
      ]
    },
    {
      "word": "die Fahrgemeinschaft",
      "language": "de",
      "cefrLevel": "B1",
