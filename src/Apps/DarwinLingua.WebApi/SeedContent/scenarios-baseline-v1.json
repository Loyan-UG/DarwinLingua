{
  "scenarios": [
    {
      "slug": "a1-cafe-order",
      "title": "Im Cafe bestellen",
      "description": "A practical cafe conversation for ordering a drink, asking the price, and paying politely.",
      "learnerGoal": "Order a drink in German and complete a short payment exchange.",
      "cefrLevel": "A1",
      "category": "daily-life",
      "publicationStatus": "Active",
      "topics": [ "customer-service", "shopping-and-services" ],
      "sortOrder": 10,
      "dialogueTurns": [
        {
          "sortOrder": 1,
          "speakerRole": "staff",
          "baseText": "Guten Morgen. Was moechten Sie?",
          "translations": [
            { "languageCode": "ar", "text": "صباح الخير. ماذا تريد؟" },
            { "languageCode": "ckb", "text": "بەیانی باش. چیت دەوێت؟" },
            { "languageCode": "en", "text": "Good morning. What would you like?" },
            { "languageCode": "fa", "text": "صبح بخیر. چه چیزی میل دارید؟" },
            { "languageCode": "kmr", "text": "Beyaniya te bixêr. Tu çi dixwazî?" },
            { "languageCode": "pl", "text": "Dzien dobry. Co Pan/Pani chce?" },
            { "languageCode": "ro", "text": "Buna dimineata. Ce doriti?" },
            { "languageCode": "ru", "text": "Доброе утро. Что бы вы хотели?" },
            { "languageCode": "sq", "text": "Miremengjes. Cfare deshironi?" },
            { "languageCode": "tr", "text": "Gunaydin. Ne istersiniz?" }
          ]
        },
        {
          "sortOrder": 2,
          "speakerRole": "learner",
          "baseText": "Ich moechte einen Kaffee, bitte.",
          "translations": [
            { "languageCode": "ar", "text": "أريد قهوة من فضلك." },
            { "languageCode": "ckb", "text": "تکایە قاوەیەکم دەوێت." },
            { "languageCode": "en", "text": "I would like a coffee, please." },
            { "languageCode": "fa", "text": "لطفا یک قهوه می‌خواهم." },
            { "languageCode": "kmr", "text": "Ji kerema xwe, qehweyek dixwazim." },
            { "languageCode": "pl", "text": "Poprosze kawe." },
            { "languageCode": "ro", "text": "As dori o cafea, va rog." },
            { "languageCode": "ru", "text": "Я хотел бы кофе, пожалуйста." },
            { "languageCode": "sq", "text": "Dua nje kafe, ju lutem." },
            { "languageCode": "tr", "text": "Bir kahve istiyorum, lutfen." }
          ]
        },
        {
          "sortOrder": 3,
          "speakerRole": "staff",
          "baseText": "Gerne. Das macht drei Euro.",
          "translations": [
            { "languageCode": "ar", "text": "بكل سرور. المبلغ ثلاثة يورو." },
            { "languageCode": "ckb", "text": "بەدڵنیایی. دەکاتە سێ یۆرۆ." },
            { "languageCode": "en", "text": "Sure. That is three euros." },
            { "languageCode": "fa", "text": "حتما. می‌شود سه یورو." },
            { "languageCode": "kmr", "text": "Bi kêfxweşî. Ew sê euro ye." },
            { "languageCode": "pl", "text": "Oczywiscie. To bedzie trzy euro." },
            { "languageCode": "ro", "text": "Sigur. Costa trei euro." },
            { "languageCode": "ru", "text": "Конечно. Это три евро." },
            { "languageCode": "sq", "text": "Sigurisht. Bejne tre euro." },
            { "languageCode": "tr", "text": "Tabii. Uc euro." }
          ]
        },
        {
          "sortOrder": 4,
          "speakerRole": "learner",
          "baseText": "Hier, bitte. Danke schoen.",
          "translations": [
            { "languageCode": "ar", "text": "تفضل. شكرا جزيلا." },
            { "languageCode": "ckb", "text": "فەرموو. زۆر سوپاس." },
            { "languageCode": "en", "text": "Here you are. Thank you very much." },
            { "languageCode": "fa", "text": "بفرمایید. خیلی ممنون." },
            { "languageCode": "kmr", "text": "Ev e, ji kerema xwe. Gelek spas." },
            { "languageCode": "pl", "text": "Prosze. Dziekuje bardzo." },
            { "languageCode": "ro", "text": "Poftiti. Multumesc mult." },
            { "languageCode": "ru", "text": "Вот, пожалуйста. Большое спасибо." },
            { "languageCode": "sq", "text": "Urdheroni. Faleminderit shume." },
            { "languageCode": "tr", "text": "Buyurun. Cok tesekkur ederim." }
          ]
        }
      ],
      "usefulPhrases": [
        {
          "sortOrder": 1,
          "baseText": "Ich moechte ..., bitte.",
          "usageNote": "Polite standard phrase for ordering.",
          "translations": [
            { "languageCode": "ar", "text": "أريد ... من فضلك." },
            { "languageCode": "ckb", "text": "تکایە ...م دەوێت." },
            { "languageCode": "en", "text": "I would like ..., please." },
            { "languageCode": "fa", "text": "لطفا ... می‌خواهم." },
            { "languageCode": "kmr", "text": "Ji kerema xwe, ... dixwazim." },
            { "languageCode": "pl", "text": "Poprosze ..." },
            { "languageCode": "ro", "text": "As dori ..., va rog." },
            { "languageCode": "ru", "text": "Я хотел бы ..., пожалуйста." },
            { "languageCode": "sq", "text": "Dua ..., ju lutem." },
            { "languageCode": "tr", "text": "... istiyorum, lutfen." }
          ]
        },
        {
          "sortOrder": 2,
          "baseText": "Was kostet das?",
          "usageNote": "Use this when you need the price.",
          "translations": [
            { "languageCode": "ar", "text": "كم سعر هذا؟" },
            { "languageCode": "ckb", "text": "ئەمە بە چەندە؟" },
            { "languageCode": "en", "text": "How much does that cost?" },
            { "languageCode": "fa", "text": "قیمتش چقدر است؟" },
            { "languageCode": "kmr", "text": "Ev çiqas e?" },
            { "languageCode": "pl", "text": "Ile to kosztuje?" },
            { "languageCode": "ro", "text": "Cat costa asta?" },
            { "languageCode": "ru", "text": "Сколько это стоит?" },
            { "languageCode": "sq", "text": "Sa kushton kjo?" },
            { "languageCode": "tr", "text": "Bu ne kadar?" }
          ]
        }
      ],
      "questions": [
        {
          "sortOrder": 1,
          "prompt": "Welche Antwort ist beim Bestellen passend?",
          "translations": [
            { "languageCode": "ar", "text": "أي جواب مناسب عند الطلب؟" },
            { "languageCode": "ckb", "text": "کامیان وەڵامی گونجاوە بۆ داواکردن؟" },
            { "languageCode": "en", "text": "Which answer fits when ordering?" },
            { "languageCode": "fa", "text": "کدام پاسخ هنگام سفارش دادن مناسب است؟" },
            { "languageCode": "kmr", "text": "Kîjan bersiv ji bo siparîşê guncan e?" },
            { "languageCode": "pl", "text": "Ktora odpowiedz pasuje przy zamawianiu?" },
            { "languageCode": "ro", "text": "Care raspuns se potriveste cand comanzi?" },
            { "languageCode": "ru", "text": "Какой ответ подходит при заказе?" },
            { "languageCode": "sq", "text": "Cila pergjigje eshte e pershtatshme kur porosit?" },
            { "languageCode": "tr", "text": "Siparis verirken hangi cevap uygundur?" }
          ],
          "answers": [
            {
              "sortOrder": 1,
              "text": "Ich moechte einen Kaffee, bitte.",
              "isCorrect": true,
              "feedback": "This is polite and clear.",
              "translations": [
                { "languageCode": "ar", "text": "أريد قهوة من فضلك." },
                { "languageCode": "ckb", "text": "تکایە قاوەیەکم دەوێت." },
                { "languageCode": "en", "text": "I would like a coffee, please." },
                { "languageCode": "fa", "text": "لطفا یک قهوه می‌خواهم." },
                { "languageCode": "kmr", "text": "Ji kerema xwe, qehweyek dixwazim." },
                { "languageCode": "pl", "text": "Poprosze kawe." },
                { "languageCode": "ro", "text": "As dori o cafea, va rog." },
                { "languageCode": "ru", "text": "Я хотел бы кофе, пожалуйста." },
                { "languageCode": "sq", "text": "Dua nje kafe, ju lutem." },
                { "languageCode": "tr", "text": "Bir kahve istiyorum, lutfen." }
              ]
            },
            {
              "sortOrder": 2,
              "text": "Ich bin Kaffee.",
              "isCorrect": false,
              "feedback": "Use moechte for ordering, not bin.",
              "translations": [
                { "languageCode": "ar", "text": "أنا قهوة." },
                { "languageCode": "ckb", "text": "من قاوەم." },
                { "languageCode": "en", "text": "I am coffee." },
                { "languageCode": "fa", "text": "من قهوه هستم." },
                { "languageCode": "kmr", "text": "Ez qehwe me." },
                { "languageCode": "pl", "text": "Jestem kawa." },
                { "languageCode": "ro", "text": "Eu sunt cafea." },
                { "languageCode": "ru", "text": "Я кофе." },
                { "languageCode": "sq", "text": "Une jam kafe." },
                { "languageCode": "tr", "text": "Ben kahveyim." }
              ]
            }
          ]
        }
      ]
    },
    {
      "slug": "a1-ask-for-directions",
      "title": "Nach dem Weg fragen",
      "description": "A short street conversation for asking where the station is and understanding simple directions.",
      "learnerGoal": "Ask for directions and follow basic left/right instructions.",
      "cefrLevel": "A1",
      "category": "travel",
      "publicationStatus": "Active",
      "topics": [ "transport-and-travel", "public-services" ],
      "sortOrder": 20,
      "dialogueTurns": [
        {
          "sortOrder": 1,
          "speakerRole": "learner",
          "baseText": "Entschuldigung, wo ist der Bahnhof?",
          "translations": [
            { "languageCode": "ar", "text": "عذرا، أين محطة القطار؟" },
            { "languageCode": "ckb", "text": "ببوورە، وێستگەی شەمەندەفەر لە کوێیە؟" },
            { "languageCode": "en", "text": "Excuse me, where is the train station?" },
            { "languageCode": "fa", "text": "ببخشید، ایستگاه قطار کجاست؟" },
            { "languageCode": "kmr", "text": "Bibore, stasyona trenê li ku ye?" },
            { "languageCode": "pl", "text": "Przepraszam, gdzie jest dworzec?" },
            { "languageCode": "ro", "text": "Scuzati-ma, unde este gara?" },
            { "languageCode": "ru", "text": "Извините, где вокзал?" },
            { "languageCode": "sq", "text": "Me falni, ku eshte stacioni i trenit?" },
            { "languageCode": "tr", "text": "Affedersiniz, tren istasyonu nerede?" }
          ]
        },
        {
          "sortOrder": 2,
          "speakerRole": "local",
          "baseText": "Gehen Sie geradeaus und dann links.",
          "translations": [
            { "languageCode": "ar", "text": "اذهب مباشرة ثم يسارا." },
            { "languageCode": "ckb", "text": "ڕاستەوخۆ بڕۆ، پاشان بۆ چەپ." },
            { "languageCode": "en", "text": "Go straight ahead and then left." },
            { "languageCode": "fa", "text": "مستقیم بروید و بعد چپ." },
            { "languageCode": "kmr", "text": "Rast here û paşê çepê." },
            { "languageCode": "pl", "text": "Prosze isc prosto, a potem w lewo." },
            { "languageCode": "ro", "text": "Mergeti drept inainte si apoi la stanga." },
            { "languageCode": "ru", "text": "Идите прямо, а потом налево." },
            { "languageCode": "sq", "text": "Shkoni drejt dhe pastaj majtas." },
            { "languageCode": "tr", "text": "Duz gidin, sonra sola donun." }
          ]
        },
        {
          "sortOrder": 3,
          "speakerRole": "learner",
          "baseText": "Ist es weit?",
          "translations": [
            { "languageCode": "ar", "text": "هل هو بعيد؟" },
            { "languageCode": "ckb", "text": "دوورە؟" },
            { "languageCode": "en", "text": "Is it far?" },
            { "languageCode": "fa", "text": "دور است؟" },
            { "languageCode": "kmr", "text": "Ew dûr e?" },
            { "languageCode": "pl", "text": "Czy to daleko?" },
            { "languageCode": "ro", "text": "Este departe?" },
            { "languageCode": "ru", "text": "Это далеко?" },
            { "languageCode": "sq", "text": "A eshte larg?" },
            { "languageCode": "tr", "text": "Uzak mi?" }
          ]
        },
        {
          "sortOrder": 4,
          "speakerRole": "local",
          "baseText": "Nein, nur fuenf Minuten zu Fuss.",
          "translations": [
            { "languageCode": "ar", "text": "لا، فقط خمس دقائق مشيا." },
            { "languageCode": "ckb", "text": "نەخێر، تەنها پێنج خولەک بە پێ." },
            { "languageCode": "en", "text": "No, only five minutes on foot." },
            { "languageCode": "fa", "text": "نه، فقط پنج دقیقه پیاده." },
            { "languageCode": "kmr", "text": "Na, tenê pênc xulek bi piyan." },
            { "languageCode": "pl", "text": "Nie, tylko piec minut pieszo." },
            { "languageCode": "ro", "text": "Nu, doar cinci minute pe jos." },
            { "languageCode": "ru", "text": "Нет, всего пять минут пешком." },
            { "languageCode": "sq", "text": "Jo, vetem pese minuta ne kembe." },
            { "languageCode": "tr", "text": "Hayir, yuruyerek sadece bes dakika." }
          ]
        }
      ],
      "usefulPhrases": [
        {
          "sortOrder": 1,
          "baseText": "Wo ist ...?",
          "usageNote": "Basic question for asking location.",
          "translations": [
            { "languageCode": "ar", "text": "أين ...؟" },
            { "languageCode": "ckb", "text": "... لە کوێیە؟" },
            { "languageCode": "en", "text": "Where is ...?" },
            { "languageCode": "fa", "text": "... کجاست؟" },
            { "languageCode": "kmr", "text": "... li ku ye?" },
            { "languageCode": "pl", "text": "Gdzie jest ...?" },
            { "languageCode": "ro", "text": "Unde este ...?" },
            { "languageCode": "ru", "text": "Где ...?" },
            { "languageCode": "sq", "text": "Ku eshte ...?" },
            { "languageCode": "tr", "text": "... nerede?" }
          ]
        },
        {
          "sortOrder": 2,
          "baseText": "Gehen Sie geradeaus.",
          "usageNote": "Common direction instruction.",
          "translations": [
            { "languageCode": "ar", "text": "اذهب مباشرة." },
            { "languageCode": "ckb", "text": "ڕاستەوخۆ بڕۆ." },
            { "languageCode": "en", "text": "Go straight ahead." },
            { "languageCode": "fa", "text": "مستقیم بروید." },
            { "languageCode": "kmr", "text": "Rast here." },
            { "languageCode": "pl", "text": "Prosze isc prosto." },
            { "languageCode": "ro", "text": "Mergeti drept inainte." },
            { "languageCode": "ru", "text": "Идите прямо." },
            { "languageCode": "sq", "text": "Shkoni drejt." },
            { "languageCode": "tr", "text": "Duz gidin." }
          ]
        }
      ],
      "questions": [
        {
          "sortOrder": 1,
          "prompt": "Was bedeutet 'geradeaus'?",
          "translations": [
            { "languageCode": "ar", "text": "ماذا تعني كلمة 'geradeaus'؟" },
            { "languageCode": "ckb", "text": "'geradeaus' واتە چی؟" },
            { "languageCode": "en", "text": "What does 'geradeaus' mean?" },
            { "languageCode": "fa", "text": "'geradeaus' یعنی چه؟" },
            { "languageCode": "kmr", "text": "'geradeaus' tê çi wateyê?" },
            { "languageCode": "pl", "text": "Co znaczy 'geradeaus'?" },
            { "languageCode": "ro", "text": "Ce inseamna 'geradeaus'?" },
            { "languageCode": "ru", "text": "Что значит 'geradeaus'?" },
            { "languageCode": "sq", "text": "Cfare do te thote 'geradeaus'?" },
            { "languageCode": "tr", "text": "'geradeaus' ne demek?" }
          ],
          "answers": [
            {
              "sortOrder": 1,
              "text": "geradeaus",
              "isCorrect": true,
              "feedback": "It means straight ahead.",
              "translations": [
                { "languageCode": "ar", "text": "مباشرة إلى الأمام" },
                { "languageCode": "ckb", "text": "ڕاستەوخۆ" },
                { "languageCode": "en", "text": "straight ahead" },
                { "languageCode": "fa", "text": "مستقیم" },
                { "languageCode": "kmr", "text": "rast" },
                { "languageCode": "pl", "text": "prosto" },
                { "languageCode": "ro", "text": "drept inainte" },
                { "languageCode": "ru", "text": "прямо" },
                { "languageCode": "sq", "text": "drejt" },
                { "languageCode": "tr", "text": "duz ileri" }
              ]
            },
            {
              "sortOrder": 2,
              "text": "rechts",
              "isCorrect": false,
              "feedback": "Rechts means right.",
              "translations": [
                { "languageCode": "ar", "text": "يمين" },
                { "languageCode": "ckb", "text": "ڕاست" },
                { "languageCode": "en", "text": "right" },
                { "languageCode": "fa", "text": "راست" },
                { "languageCode": "kmr", "text": "rast" },
                { "languageCode": "pl", "text": "w prawo" },
                { "languageCode": "ro", "text": "dreapta" },
                { "languageCode": "ru", "text": "направо" },
                { "languageCode": "sq", "text": "djathtas" },
                { "languageCode": "tr", "text": "sag" }
              ]
            }
          ]
        }
      ]
    },
    {
      "slug": "a2-doctor-appointment",
      "title": "Einen Arzttermin vereinbaren",
      "description": "A useful phone conversation for making a doctor's appointment and explaining a simple symptom.",
      "learnerGoal": "Make an appointment, state the problem, and confirm the time.",
      "cefrLevel": "A2",
      "category": "health",
      "publicationStatus": "Active",
      "topics": [ "healthcare-and-appointments", "public-services" ],
      "sortOrder": 30,
      "dialogueTurns": [
        {
          "sortOrder": 1,
          "speakerRole": "reception",
          "baseText": "Praxis Dr. Weber, guten Tag.",
          "translations": [
            { "languageCode": "ar", "text": "عيادة الدكتور فيبر، نهارك سعيد." },
            { "languageCode": "ckb", "text": "کلینیکی دکتۆر ڤێبەر، ڕۆژ باش." },
            { "languageCode": "en", "text": "Dr. Weber's practice, good day." },
            { "languageCode": "fa", "text": "مطب دکتر وبر، روز بخیر." },
            { "languageCode": "kmr", "text": "Nexweşxaneya Dr. Weber, roj baş." },
            { "languageCode": "pl", "text": "Przychodnia doktora Webera, dzien dobry." },
            { "languageCode": "ro", "text": "Cabinetul Dr. Weber, buna ziua." },
            { "languageCode": "ru", "text": "Практика доктора Вебера, добрый день." },
            { "languageCode": "sq", "text": "Kabineti i Dr. Weber, miredita." },
            { "languageCode": "tr", "text": "Dr. Weber muayenehanesi, iyi gunler." }
          ]
        },
        {
          "sortOrder": 2,
          "speakerRole": "learner",
          "baseText": "Guten Tag, ich brauche einen Termin.",
          "translations": [
            { "languageCode": "ar", "text": "نهارك سعيد، أحتاج إلى موعد." },
            { "languageCode": "ckb", "text": "ڕۆژ باش، پێویستم بە کاتێکە." },
            { "languageCode": "en", "text": "Good day, I need an appointment." },
            { "languageCode": "fa", "text": "روز بخیر، من به یک وقت ملاقات نیاز دارم." },
            { "languageCode": "kmr", "text": "Roj baş, min hewceyê randevuyekê heye." },
            { "languageCode": "pl", "text": "Dzien dobry, potrzebuje terminu." },
            { "languageCode": "ro", "text": "Buna ziua, am nevoie de o programare." },
            { "languageCode": "ru", "text": "Добрый день, мне нужна запись." },
            { "languageCode": "sq", "text": "Miredita, me duhet nje takim." },
            { "languageCode": "tr", "text": "Iyi gunler, bir randevuya ihtiyacim var." }
          ]
        },
        {
          "sortOrder": 3,
          "speakerRole": "reception",
          "baseText": "Was fehlt Ihnen?",
          "translations": [
            { "languageCode": "ar", "text": "ما المشكلة لديك؟" },
            { "languageCode": "ckb", "text": "کێشەت چییە؟" },
            { "languageCode": "en", "text": "What is the problem?" },
            { "languageCode": "fa", "text": "مشکل شما چیست؟" },
            { "languageCode": "kmr", "text": "Pirsgirêka we çi ye?" },
            { "languageCode": "pl", "text": "Co Panu/Pani dolega?" },
            { "languageCode": "ro", "text": "Ce problema aveti?" },
            { "languageCode": "ru", "text": "Что у вас болит?" },
            { "languageCode": "sq", "text": "Cfare problemi keni?" },
            { "languageCode": "tr", "text": "Sorununuz nedir?" }
          ]
        },
        {
          "sortOrder": 4,
          "speakerRole": "learner",
          "baseText": "Ich habe seit gestern Halsschmerzen.",
          "translations": [
            { "languageCode": "ar", "text": "لدي ألم في الحلق منذ أمس." },
            { "languageCode": "ckb", "text": "لە دوێنێوە ئازاری قوڕگم هەیە." },
            { "languageCode": "en", "text": "I have had a sore throat since yesterday." },
            { "languageCode": "fa", "text": "از دیروز گلودرد دارم." },
            { "languageCode": "kmr", "text": "Ji duh ve êşa qirika min heye." },
            { "languageCode": "pl", "text": "Od wczoraj boli mnie gardlo." },
            { "languageCode": "ro", "text": "Ma doare gatul de ieri." },
            { "languageCode": "ru", "text": "У меня болит горло со вчерашнего дня." },
            { "languageCode": "sq", "text": "Kam dhimbje fyti qe nga dje." },
            { "languageCode": "tr", "text": "Dunden beri bogazim agriyor." }
          ]
        }
      ],
      "usefulPhrases": [
        {
          "sortOrder": 1,
          "baseText": "Ich brauche einen Termin.",
