@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = T["Password reset email"];
}

<section class="panel stack-lg auth-intro">
    <span class="eyebrow">@T["Account recovery"]</span>
    <h1 class="headline-md">@T["Check your email"]</h1>
    <p class="body-lg">@T["If the email belongs to an account that can be reset, a recovery link has been sent."]</p>
    <p class="body-sm">@T["For privacy, Darwin Lingua shows this same message whether an account exists or not."]</p>
    <div class="action-row">
        <a class="button button--primary" asp-area="Identity" asp-page="/Account/Login">@T["Back to sign in"]</a>
    </div>
</section>
