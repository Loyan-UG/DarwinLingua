@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
}

<section class="panel stack-lg">
    <span class="eyebrow">Account security</span>
    <h1 class="headline-md">Change password</h1>
    <p class="body-lg">Update your password and keep this account protected.</p>
</section>

<section class="panel stack-md">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <p class="body-sm">@Model.StatusMessage</p>
    }
    <form method="post" class="form-grid">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <label asp-for="Input.CurrentPassword"></label>
        <input asp-for="Input.CurrentPassword" autocomplete="current-password" />
        <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
        <label asp-for="Input.NewPassword"></label>
        <input asp-for="Input.NewPassword" autocomplete="new-password" />
        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
        <label asp-for="Input.ConfirmPassword"></label>
        <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        <div class="action-row">
            <button type="submit" class="button button--primary">Change password</button>
            <a class="button button--secondary" asp-area="" asp-controller="Account" asp-action="Index">Back to account</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
