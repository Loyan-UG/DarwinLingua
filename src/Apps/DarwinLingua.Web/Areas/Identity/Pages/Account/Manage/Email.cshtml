@page
@model EmailModel
@{
    ViewData["Title"] = T["Change email"];
}

<div class="auth-page">
    <section class="panel stack-lg auth-intro">
        <span class="eyebrow">@T["Account security"]</span>
        <h1 class="headline-md">@T["Change email"]</h1>
        <p class="body-lg">@T["Current email"]: <strong>@Model.CurrentEmail</strong></p>
    </section>

    <section class="panel stack-md auth-card">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <p class="status-banner status-banner--success">@Model.StatusMessage</p>
        }
        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="field">
                <label asp-for="Input.NewEmail"></label>
                <input asp-for="Input.NewEmail" autocomplete="email" />
                <span asp-validation-for="Input.NewEmail" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Input.CurrentPassword"></label>
                <input asp-for="Input.CurrentPassword" autocomplete="current-password" />
                <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
            </div>

            <div class="action-row auth-actions">
                <button type="submit" class="button button--primary">@T["Send confirmation"]</button>
                <a class="button button--secondary" asp-area="" asp-controller="Account" asp-action="Index">@T["Back to account"]</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
