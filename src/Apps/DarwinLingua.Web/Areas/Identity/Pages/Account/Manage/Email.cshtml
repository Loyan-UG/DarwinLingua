@page
@model EmailModel
@{
    ViewData["Title"] = "Change email";
}

<section class="panel stack-lg">
    <span class="eyebrow">Account security</span>
    <h1 class="headline-md">Change email</h1>
    <p class="body-lg">Current email: <strong>@Model.CurrentEmail</strong></p>
</section>

<section class="panel stack-md">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <p class="body-sm">@Model.StatusMessage</p>
    }
    <form method="post" class="form-grid">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <label asp-for="Input.NewEmail"></label>
        <input asp-for="Input.NewEmail" autocomplete="email" />
        <span asp-validation-for="Input.NewEmail" class="text-danger"></span>
        <div class="action-row">
            <button type="submit" class="button button--primary">Send confirmation</button>
            <a class="button button--secondary" asp-area="" asp-controller="Account" asp-action="Index">Back to account</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
