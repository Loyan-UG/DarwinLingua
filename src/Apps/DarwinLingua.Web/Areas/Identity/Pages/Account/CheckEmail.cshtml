@page
@model CheckEmailModel
@{
    ViewData["Title"] = T["Check your email"];
}

<section class="panel stack-lg auth-intro">
    <span class="eyebrow">@T["Account email"]</span>
    <h1 class="headline-md">@T["Check your email"]</h1>
    <p class="body-lg">@T["If the address can receive account email, a Darwin Lingua message has been sent with the next step."]</p>
    <p class="body-sm">@T["The message may be a confirmation or account recovery email depending on the action requested. Links expire automatically."]</p>
    <p class="body-sm">@T["If it does not arrive, check spam or request a new confirmation email."]</p>
    <div class="action-row">
        <a class="button button--primary" asp-area="Identity" asp-page="/Account/Login">@T["Sign in"]</a>
        <a class="button button--secondary" asp-area="Identity" asp-page="/Account/ResendEmailConfirmation">@T["Resend confirmation"]</a>
        <a class="button button--secondary" asp-area="Identity" asp-page="/Account/ForgotPassword">@T["Reset password"]</a>
    </div>
</section>
