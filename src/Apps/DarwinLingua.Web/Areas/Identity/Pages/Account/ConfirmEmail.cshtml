@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = Model.Succeeded ? T["Email confirmed"] : T["Email confirmation failed"];
}

<section class="panel stack-lg auth-intro">
    <span class="eyebrow">@T["Account email"]</span>
    @if (Model.Succeeded)
    {
        <h1 class="headline-md">@T["Email confirmed"]</h1>
        <p class="body-lg">@T["Your Darwin Lingua account is ready to use."]</p>
        <div class="action-row">
            <a class="button button--primary" asp-area="Identity" asp-page="/Account/Login">@T["Sign in"]</a>
            <a class="button button--secondary" asp-area="" asp-controller="Browse" asp-action="Index">@T["Browse"]</a>
        </div>
    }
    else
    {
        <h1 class="headline-md">@T["This confirmation link cannot be used"]</h1>
        <p class="body-lg">@T["The link may be expired, already used, or malformed."]</p>
        <div class="action-row">
            <a class="button button--primary" asp-area="Identity" asp-page="/Account/ResendEmailConfirmation">@T["Send a new link"]</a>
            <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Login">@T["Sign in"]</a>
        </div>
    }
</section>
