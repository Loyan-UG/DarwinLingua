@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password reset complete";
}

<section class="panel stack-lg auth-intro">
    <span class="eyebrow">Account recovery</span>
    <h1 class="headline-md">Password reset complete</h1>
    <p class="body-lg">Your password has been updated. You can now sign in with the new password.</p>
    <div class="action-row">
        <a class="button button--primary" asp-area="Identity" asp-page="/Account/Login">Sign in</a>
    </div>
</section>
