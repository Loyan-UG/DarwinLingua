@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="auth-page">
    <section class="panel stack-lg auth-intro">
        <span class="eyebrow">Account recovery</span>
        <h1 class="headline-md">Reset your password</h1>
        <p class="body-lg">Choose a new password for your Darwin Lingua account. If this link does not work, request a new reset email.</p>
    </section>

    <section class="panel stack-md auth-card">
        <form method="post" class="auth-form">
            <input asp-for="Input.Code" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="action-row auth-actions">
                <button type="submit" class="button button--primary">Reset password</button>
                <a class="button button--secondary" asp-area="Identity" asp-page="/Account/ForgotPassword">Request new link</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
