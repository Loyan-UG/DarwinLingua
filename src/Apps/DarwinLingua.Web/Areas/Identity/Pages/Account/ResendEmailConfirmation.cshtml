@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = T["Resend confirmation"];
}

<div class="auth-page">
    <section class="panel stack-lg auth-intro">
        <span class="eyebrow">@T["Account email"]</span>
        <h1 class="headline-md">@T["Resend confirmation email"]</h1>
        <p class="body-lg">@T["Enter your account email and Darwin Lingua will send another confirmation link if one is needed."]</p>
    </section>

    <section class="panel stack-md auth-card">
        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="action-row auth-actions">
                <button type="submit" class="button button--primary">@T["Send confirmation"]</button>
                <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Login">@T["Back to sign in"]</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
