@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend confirmation";
}

<section class="panel stack-lg">
    <span class="eyebrow">Account email</span>
    <h1 class="headline-md">Resend confirmation email</h1>
    <p class="body-lg">Enter your account email and Darwin Lingua will send another confirmation link if one is needed.</p>
</section>

<section class="panel stack-md">
    <form method="post" class="form-grid">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <label asp-for="Input.Email"></label>
        <input asp-for="Input.Email" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
        <div class="action-row">
            <button type="submit" class="button button--primary">Send confirmation</button>
            <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Login">Back to sign in</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
