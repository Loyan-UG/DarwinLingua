@page
@model RegisterModel
@{
    ViewData["Title"] = T["Register"];
}

<div class="auth-page">
    <section class="panel stack-lg auth-intro">
        <span class="eyebrow">@T["Create account"]</span>
        <h1 class="headline-md">@T["Register for Darwin Lingua"]</h1>
        <p class="body-lg">@T["Enter your email and choose a password. If the address can be used, Darwin Lingua will send the next account step."]</p>
    </section>

    <section class="panel stack-md auth-card">
        <form method="post" class="auth-form">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="field field--checkbox">
                <input asp-for="Input.AcceptTermsOfUse" />
                <span>
                    @T["I agree to the Terms of Use."]
                    <a asp-controller="Home" asp-action="Terms" target="_blank" rel="noopener">@T["Read Terms of Use"]</a>
                </span>
                <span asp-validation-for="Input.AcceptTermsOfUse" class="text-danger"></span>
            </div>

            <div class="field field--checkbox">
                <input asp-for="Input.AcknowledgePrivacyNotice" />
                <span>
                    @T["I understand that Darwin Lingua processes account and learning data as described in the Privacy Policy."]
                    <a asp-controller="Home" asp-action="Privacy" target="_blank" rel="noopener">@T["Read Privacy Policy"]</a>
                </span>
                <span asp-validation-for="Input.AcknowledgePrivacyNotice" class="text-danger"></span>
            </div>

            <p class="body-sm">
                @T["Sensitive Educational Language is off by default and can be enabled later in Settings. This preference is not age verification and does not unlock explicit adult content."]
            </p>

            <div class="action-row auth-actions">
                <button type="submit" class="button button--primary">@T["Continue"]</button>
                <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Login">@T["Sign in"]</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
