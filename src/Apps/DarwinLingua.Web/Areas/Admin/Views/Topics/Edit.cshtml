@model DarwinLingua.Web.Models.AdminTopicEditViewModel
@{
    ViewData["Title"] = Model.IsNew ? "New topic" : "Edit topic";
    var mergeTargets = ViewData["MergeTargets"] as IReadOnlyList<DarwinLingua.Web.Models.AdminTopicItemViewModel> ?? [];
}

<div class="admin-summary-grid">
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Mode", Model.IsNew ? "Create" : "Edit", "Managed topic taxonomy.")' />
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Key", string.IsNullOrWhiteSpace(Model.Key) ? "New" : Model.Key, "Stable normalized identifier.")' />
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Merge targets", mergeTargets.Count.ToString(), "Available duplicate consolidation targets.")' />
</div>

<nav class="admin-anchor-nav" aria-label="Topic editor sections">
    <a href="#topic-definition">Definition</a>
    <a href="#topic-localization">Localization</a>
    @if (!Model.IsNew)
    {
        <a href="#topic-merge">Merge</a>
    }
</nav>

<section id="topic-definition" class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(Model.IsNew ? "New topic" : Model.Key, "Topic editor", "Use lowercase kebab-case keys and localized names for learner-facing topic labels.")' />
        <a class="button button--secondary" asp-action="Index">Back to topics</a>
    </div>
    @if (TempData["AdminStatusMessage"] is string statusMessage)
    {
        <div class="state-panel state-panel--success">@statusMessage</div>
    }
    @if (TempData["AdminErrorMessage"] is string errorMessage)
    {
        <div class="state-panel state-panel--warning">@errorMessage</div>
    }

    <form class="stack-md" method="post" data-confirm-submit="Save this topic definition?">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TopicId" />
        <div asp-validation-summary="ModelOnly" class="validation-message"></div>
        <div class="form-grid">
            <label class="form-field">
                <span>Key</span>
                <input asp-for="Key" placeholder="work-meetings" />
                <span asp-validation-for="Key" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Sort order</span>
                <input asp-for="SortOrder" type="number" min="0" />
                <span asp-validation-for="SortOrder" class="validation-message"></span>
            </label>
            <label class="form-field form-field--check">
                <input asp-for="IsSystem" />
                <span>System topic</span>
            </label>
        </div>

        <div id="topic-localization" class="admin-two-column">
            <div class="admin-inline-panel stack-sm">
                <strong>Primary localization</strong>
                <label class="form-field">
                    <span>Language</span>
                    <input asp-for="PrimaryLanguageCode" placeholder="en" />
                </label>
                <label class="form-field">
                    <span>Display name</span>
                    <input asp-for="PrimaryDisplayName" />
                </label>
            </div>
            <div class="admin-inline-panel stack-sm">
                <strong>Secondary localization</strong>
                <label class="form-field">
                    <span>Language</span>
                    <input asp-for="SecondaryLanguageCode" placeholder="fa" />
                </label>
                <label class="form-field">
                    <span>Display name</span>
                    <input asp-for="SecondaryDisplayName" />
                </label>
            </div>
        </div>

        <button class="button" type="submit">Save topic</button>
    </form>
</section>

@if (!Model.IsNew)
{
    <section id="topic-merge" class="panel stack-md">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Merge", "Consolidate duplicate topics", "Move words, dialogues, conversation starters, and event preparation packs from this topic into another topic safely.")' />
        <form class="admin-inline-panel stack-sm" method="post" asp-action="Merge" asp-route-topicId="@Model.TopicId" data-confirm-submit="Merge this topic into the selected target?">
            @Html.AntiForgeryToken()
            <div class="admin-inline-form-grid">
                <label class="form-field">
                    <span>Target topic</span>
                    <select name="targetTopicId" required>
                        <option value="">Select target topic</option>
                        @foreach (var topic in mergeTargets)
                        {
                            <option value="@topic.TopicId">@topic.Key (@topic.WordCount words)</option>
                        }
                    </select>
                </label>
                <button class="button button--secondary button--compact" type="submit" disabled="@(mergeTargets.Count == 0)">Merge into target</button>
            </div>
        </form>
    </section>
}
