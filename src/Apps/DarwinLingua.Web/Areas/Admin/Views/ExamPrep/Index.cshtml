@model DarwinLingua.Web.Models.AdminExamPrepPageViewModel
@{
    ViewData["Title"] = T["Exam Prep"];
}

<section class="admin-panel stack-md">
    <div class="admin-section-heading">
        <div>
            <span class="eyebrow">@T["Content"]</span>
            <h1>@T["Exam Prep"]</h1>
        </div>
        <a class="button button--secondary button--compact" asp-area="" asp-controller="ExamPrep" asp-action="Index">@T["Open learner view"]</a>
    </div>

    <h2>@T["Exam profiles"]</h2>
    <p>@T["Profiles"]: @Model.Profiles.Count</p>

    @if (Model.Units.Count == 0)
    {
        <p>@T["No exam prep units have been imported yet."]</p>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>@T["Title"]</th>
                        <th>@T["Exam profile"]</th>
                        <th>@T["CEFR level"]</th>
                        <th>@T["Exam section"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var unit in Model.Units)
                    {
                        <tr>
                            <td>
                                <a asp-area="" asp-controller="ExamPrep" asp-action="Detail" asp-route-slug="@unit.Slug">@unit.Title</a>
                                <small>@unit.Slug</small>
                            </td>
                            <td>@unit.ExamProfileKey</td>
                            <td>@unit.CefrLevel</td>
                            <td>@T[unit.ExamSection]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
