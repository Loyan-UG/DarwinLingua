@model DarwinLingua.Web.Models.AdminCulturalNotesPageViewModel
@{
    ViewData["Title"] = T["Life in Germany"];
}

<section class="admin-panel stack-md">
    <div class="admin-section-heading">
        <div>
            <span class="eyebrow">@T["Content"]</span>
            <h1>@T["Life in Germany"]</h1>
        </div>
        <a class="button button--secondary button--compact" asp-area="" asp-controller="CulturalNotes" asp-action="Index">@T["Open learner view"]</a>
    </div>

    @if (Model.Notes.Count == 0)
    {
        <p>@T["No Life in Germany notes have been imported yet."]</p>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>@T["Title"]</th>
                        <th>@T["CEFR level"]</th>
                        <th>@T["Category"]</th>
                        <th>@T["Context"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var note in Model.Notes)
                    {
                        <tr>
                            <td>
                                <a asp-area="" asp-controller="CulturalNotes" asp-action="Detail" asp-route-slug="@note.Slug">@note.Title</a>
                                <small>@note.Slug</small>
                            </td>
                            <td>@note.CefrLevel</td>
                            <td>@T[note.Category]</td>
                            <td>@note.Context</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
