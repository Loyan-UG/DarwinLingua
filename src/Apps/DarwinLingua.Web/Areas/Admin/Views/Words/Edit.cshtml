@model DarwinLingua.Web.Models.AdminWordEditViewModel
@{
    ViewData["Title"] = Model.IsNew ? "New word" : $"Edit {Model.Lemma}";
    string[] cefrLevels = ["A1", "A2", "B1", "B2", "C1", "C2"];
    string[] partsOfSpeech = ["Noun", "Verb", "Adjective", "Adverb", "Pronoun", "Preposition", "Conjunction", "Interjection", "Numeral", "Phrase", "Expression", "Other"];
    string[] statuses = ["Draft", "Active", "Archived", "Deprecated"];
    string[] sourceTypes = ["Manual", "AiAssisted", "Hybrid", "ExternalCurated"];
    string heading = Model.IsNew ? "New word" : Model.Lemma;
    string actionName = Model.IsNew ? "New" : "Edit";
    string saveText = Model.IsNew ? "Create word" : "Save changes";
}

<section class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(heading, Model.IsNew ? "Create word" : "Edit word metadata", "Manage the core lexical record. Sense, topic, and translation editing are handled in separate focused panels.")' />
        @if (Model.IsNew)
        {
            <a class="button button--secondary" asp-action="Index">Cancel</a>
        }
        else
        {
            <a class="button button--secondary" asp-action="Details" asp-route-publicId="@Model.PublicId">Cancel</a>
        }
    </div>

    <form class="admin-edit-form stack-lg" method="post" asp-action="@actionName" asp-route-publicId="@Model.PublicId" data-confirm-submit="Save this word?">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PublicId" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <label class="form-field field--wide">
                <span>Lemma</span>
                <input asp-for="Lemma" />
                <span asp-validation-for="Lemma" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Language code</span>
                <input asp-for="LanguageCode" />
                <span asp-validation-for="LanguageCode" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>CEFR</span>
                <select asp-for="CefrLevel">
                    @foreach (string level in cefrLevels)
                    {
                        <option value="@level">@level</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>Part of speech</span>
                <select asp-for="PartOfSpeech">
                    @foreach (string partOfSpeech in partsOfSpeech)
                    {
                        <option value="@partOfSpeech">@partOfSpeech</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>Status</span>
                <select asp-for="PublicationStatus">
                    @foreach (string status in statuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>Source type</span>
                <select asp-for="ContentSourceType">
                    @foreach (string sourceType in sourceTypes)
                    {
                        <option value="@sourceType">@sourceType</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>Article</span>
                <input asp-for="Article" />
                <span asp-validation-for="Article" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Plural form</span>
                <input asp-for="PluralForm" />
                <span asp-validation-for="PluralForm" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Infinitive form</span>
                <input asp-for="InfinitiveForm" />
                <span asp-validation-for="InfinitiveForm" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Pronunciation IPA</span>
                <input asp-for="PronunciationIpa" />
                <span asp-validation-for="PronunciationIpa" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Syllable break</span>
                <input asp-for="SyllableBreak" />
                <span asp-validation-for="SyllableBreak" class="validation-message"></span>
            </label>
            <label class="form-field field--wide">
                <span>Source reference</span>
                <input asp-for="SourceReference" />
                <span asp-validation-for="SourceReference" class="validation-message"></span>
            </label>
        </div>

        <div class="cluster">
            <button class="button" type="submit">@saveText</button>
            @if (Model.IsNew)
            {
                <a class="button button--secondary" asp-action="Index">Cancel</a>
            }
            else
            {
                <a class="button button--secondary" asp-action="Details" asp-route-publicId="@Model.PublicId">Cancel</a>
            }
        </div>
    </form>
</section>
