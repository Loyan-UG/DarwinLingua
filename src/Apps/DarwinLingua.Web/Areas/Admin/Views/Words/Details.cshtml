@model DarwinLingua.Web.Models.AdminWordDetailViewModel
@{
    ViewData["Title"] = Model.Lemma;
    var availableTopics = ViewData["AdminTopics"] as DarwinLingua.Web.Models.AdminTopicsPageViewModel;
    var availableLabels = ViewData["AdminLabels"] as DarwinLingua.Web.Models.AdminLabelsPageViewModel;
    var assignedTopicIds = Model.Topics.Select(topic => topic.TopicId).ToHashSet();
    var unassignedTopics = availableTopics?.Topics
        .Where(topic => !assignedTopicIds.Contains(topic.TopicId))
        .OrderBy(topic => topic.SortOrder)
        .ThenBy(topic => topic.Key)
        .ToArray() ?? [];
    var assignedLabelKeys = Model.Labels
        .Select(label => $"{label.Kind}::{label.Key}")
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    var unassignedLabels = availableLabels?.Labels
        .Where(label => !assignedLabelKeys.Contains($"{label.Kind}::{label.Key}"))
        .OrderBy(label => label.Kind)
        .ThenBy(label => label.SortOrder)
        .ThenBy(label => label.DisplayName)
        .ToArray() ?? [];
    string[] partOfSpeechOptions = ["Noun", "Verb", "Adjective", "Adverb", "Pronoun", "Preposition", "Conjunction", "Interjection", "Numeral", "Phrase", "Expression", "Other"];
    string[] cefrOptions = ["A1", "A2", "B1", "B2", "C1", "C2"];
    string[] statusOptions = ["Draft", "Active", "Archived", "Deprecated"];
    string[] sourceOptions = ["Manual", "AiAssisted", "Hybrid", "ExternalCurated"];
}

<section class="panel stack-lg admin-word-editor">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(Model.Lemma, T["Word editor"].Value, T["Edit the full admin record. Learner language preferences do not limit the languages shown here."].Value)' />
        <div class="cluster">
            <a class="button button--secondary" asp-action="Index">@T["Back to words"]</a>
            <a class="button button--secondary" asp-area="" asp-controller="Words" asp-action="Detail" asp-route-id="@Model.PublicId">@T["View learner page"]</a>
        </div>
    </div>

    @if (TempData["AdminStatusMessage"] is string statusMessage)
    {
        <div class="state-panel state-panel--success">@statusMessage</div>
    }
    @if (TempData["AdminErrorMessage"] is string errorMessage)
    {
        <div class="state-panel state-panel--warning">@errorMessage</div>
    }

    <form class="admin-editor-card stack-md" method="post" asp-action="Edit" asp-route-publicId="@Model.PublicId" data-confirm-submit="@T["Save word metadata?"]">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PublicId" value="@Model.PublicId" />
        <div class="admin-editor-section-header">
            <div>
                <h2 class="headline-sm">@T["Core metadata"]</h2>
                <p class="muted-text">@T["Status, CEFR, source, forms, and pronunciation are editable here."]</p>
            </div>
            <button class="button button--compact" type="submit">@T["Save metadata"]</button>
        </div>
        <div class="form-grid admin-metadata-grid">
            <label class="form-field">
                <span>@T["Lemma"]</span>
                <input name="Lemma" maxlength="256" value="@Model.Lemma" required />
            </label>
            <label class="form-field">
                <span>@T["Language"]</span>
                <input name="LanguageCode" maxlength="16" value="@Model.LanguageCode" required />
            </label>
            <label class="form-field">
                <span>@T["Status"]</span>
                <select name="PublicationStatus" required>
                    @foreach (var status in statusOptions)
                    {
                        <option value="@status" selected="@(status == Model.PublicationStatus)">@status</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>@T["CEFR"]</span>
                <select name="CefrLevel" required>
                    @foreach (var cefr in cefrOptions)
                    {
                        <option value="@cefr" selected="@(cefr == Model.CefrLevel)">@cefr</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>@T["Part of speech"]</span>
                <select name="PartOfSpeech" required>
                    @foreach (var pos in partOfSpeechOptions)
                    {
                        <option value="@pos" selected="@(pos == Model.PartOfSpeech)">@pos</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>@T["Source type"]</span>
                <select name="ContentSourceType" required>
                    @foreach (var source in sourceOptions)
                    {
                        <option value="@source" selected="@(source == Model.ContentSourceType)">@source</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>@T["Article"]</span>
                <input name="Article" maxlength="32" value="@Model.Article" />
            </label>
            <label class="form-field">
                <span>@T["Plural form"]</span>
                <input name="PluralForm" maxlength="256" value="@Model.PluralForm" />
            </label>
            <label class="form-field">
                <span>@T["Infinitive form"]</span>
                <input name="InfinitiveForm" maxlength="256" value="@Model.InfinitiveForm" />
            </label>
            <label class="form-field">
                <span>@T["Pronunciation IPA"]</span>
                <input name="PronunciationIpa" maxlength="256" value="@Model.PronunciationIpa" />
            </label>
            <label class="form-field">
                <span>@T["Syllable break"]</span>
                <input name="SyllableBreak" maxlength="256" value="@Model.SyllableBreak" />
            </label>
            <label class="form-field">
                <span>@T["Source reference"]</span>
                <input name="SourceReference" maxlength="512" value="@Model.SourceReference" />
            </label>
        </div>
        <div class="admin-static-meta">
            <span>@T["Public ID"]: @Model.PublicId</span>
            <span>@T["Normalized"]: @Model.NormalizedLemma</span>
            <span>@T["Updated"]: @Model.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</span>
        </div>
    </form>

    <div class="admin-summary-grid">
        <a href="#word-taxonomy" class="admin-summary-tile"><span class="eyebrow">@T["Topics"]</span><strong>@Model.Topics.Count</strong></a>
        <a href="#word-taxonomy" class="admin-summary-tile"><span class="eyebrow">@T["Labels"]</span><strong>@Model.Labels.Count</strong></a>
        <a href="#word-senses" class="admin-summary-tile"><span class="eyebrow">@T["Senses"]</span><strong>@Model.Senses.Count</strong></a>
    </div>
</section>

<section id="word-taxonomy" class="admin-two-column">
    <div class="panel stack-md">
        <div class="cluster cluster--between">
            <h2 class="headline-sm">@T["Topics"]</h2>
            <a class="button button--secondary button--compact" asp-controller="Topics" asp-action="Index">@T["Manage topics"]</a>
        </div>
        @if (Model.Topics.Count == 0)
        {
            <p>@T["No topics assigned."]</p>
        }
        else
        {
            <div class="tag-list">
                @foreach (var topic in Model.Topics)
                {
                    <form class="tag-form" method="post" asp-action="DeleteTopic" asp-route-publicId="@Model.PublicId" asp-route-topicId="@topic.TopicId" data-confirm-submit="@T["Remove this topic from the word?"]">
                        @Html.AntiForgeryToken()
                        <span class="tag">@topic.Key@(topic.IsPrimaryTopic ? $" {T["primary"]}" : null)</span>
                        <button class="tag-remove" type="submit" aria-label="@T["Remove {0}", topic.Key]">x</button>
                    </form>
                }
            </div>
        }
        <details class="admin-inline-panel stack-sm">
            <summary>@T["Attach topic"]</summary>
            <form method="post" asp-action="AddTopic" asp-route-publicId="@Model.PublicId" data-confirm-submit="@T["Add this topic to the word?"]">
                @Html.AntiForgeryToken()
                <div class="admin-inline-form-grid admin-inline-form-grid--topic">
                    <label class="form-field">
                        <span>@T["Topic"]</span>
                        <select name="topicId" required>
                            <option value="">@T["Select topic"]</option>
                            @foreach (var topic in unassignedTopics)
                            {
                                <option value="@topic.TopicId">@topic.Key (@T["{0} words", topic.WordCount])</option>
                            }
                        </select>
                    </label>
                    <label class="admin-toggle-field">
                        <input type="checkbox" name="isPrimaryTopic" value="true" />
                        <input type="hidden" name="isPrimaryTopic" value="false" />
                        <span>@T["Primary topic"]</span>
                    </label>
                    <button class="button button--compact" type="submit" disabled="@(unassignedTopics.Length == 0)">@T["Add"]</button>
                </div>
            </form>
        </details>
    </div>

    <div class="panel stack-md">
        <div class="cluster cluster--between">
            <h2 class="headline-sm">@T["Labels"]</h2>
            <a class="button button--secondary button--compact" asp-controller="Labels" asp-action="Index">@T["Manage labels"]</a>
        </div>
        @if (Model.Labels.Count == 0)
        {
            <p>@T["No labels assigned."]</p>
        }
        else
        {
            <div class="tag-list">
                @foreach (var label in Model.Labels)
                {
                    <form class="tag-form" method="post" asp-action="DeleteLabel" asp-route-publicId="@Model.PublicId" asp-route-kind="@label.Kind" asp-route-key="@label.Key" data-confirm-submit="@T["Remove this label from the word?"]">
                        @Html.AntiForgeryToken()
                        <span class="tag">@label.DisplayName <small>@label.Kind/@label.Key</small></span>
                        <button class="tag-remove" type="submit" aria-label="@T["Remove {0}", label.DisplayName]">x</button>
                    </form>
                }
            </div>
        }
        <details class="admin-inline-panel stack-sm">
            <summary>@T["Attach label"]</summary>
            <form method="post" asp-action="AddLabel" asp-route-publicId="@Model.PublicId" data-confirm-submit="@T["Add this label to the word?"]">
                @Html.AntiForgeryToken()
                <div class="admin-inline-form-grid admin-inline-form-grid--label">
                    <label class="form-field">
                        <span>@T["Label"]</span>
                        <select name="labelKey" required>
                            <option value="">@T["Select label"]</option>
                            @foreach (var label in unassignedLabels)
                            {
                                <option value="@($"{label.Kind}::{label.Key}")">@label.DisplayName (@label.Kind/@label.Key)</option>
                            }
                        </select>
                    </label>
                    <button class="button button--compact" type="submit" disabled="@(unassignedLabels.Length == 0)">@T["Add"]</button>
                </div>
            </form>
        </details>
    </div>
</section>

<section id="word-senses" class="panel stack-lg">
    <div class="cluster cluster--between">
        <div>
            <h2 class="headline-sm">@T["Meanings and examples"]</h2>
            <p class="muted-text">@T["All stored languages are shown here. The primary switches only choose the default item shown first; they do not hide other languages."]</p>
        </div>
        <span class="eyebrow">@T["{0} total", Model.Senses.Count]</span>
    </div>

    @if (Model.Senses.Count == 0)
    {
        <p>@T["No senses recorded."]</p>
    }
    else
    {
        @foreach (var sense in Model.Senses)
        {
            <article class="admin-record-card admin-sense-editor stack-md">
                <div class="admin-editor-section-header">
                    <div>
                        <h3 class="headline-sm">@T["Sense {0}", sense.SenseOrder]</h3>
                        <p class="muted-text">@sense.PublicationStatus - @(sense.ShortDefinitionDe ?? sense.ShortGloss ?? T["No short definition."])</p>
                    </div>
                    @if (sense.IsPrimarySense)
                    {
                        <span class="status-pill">@T["Primary sense"]</span>
                    }
                </div>

                <div class="admin-editor-subsection">
                    <div class="admin-editor-section-header">
                        <h4 class="admin-subhead">@T["Meanings in all languages"]</h4>
                        <span class="eyebrow">@T["{0} items", sense.Translations.Count]</span>
                    </div>
                    <div class="admin-translation-editor-grid">
                        @foreach (var translation in sense.Translations)
                        {
                            <div class="admin-editor-card admin-editor-card--flat">
                                <form class="admin-row-form" method="post" asp-action="UpdateSenseTranslation" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" asp-route-translationId="@translation.TranslationId" data-confirm-submit="@T["Save this sense translation?"]">
                                    @Html.AntiForgeryToken()
                                    <label class="form-field">
                                        <span>@T["Language"]</span>
                                        <input name="LanguageCode" maxlength="16" value="@translation.LanguageCode" required />
                                    </label>
                                    <label class="form-field field--wide">
                                        <span>@T["Meaning"]</span>
                                        <input name="TranslationText" maxlength="512" value="@translation.TranslationText" required />
                                    </label>
                                    <label class="admin-toggle-field">
                                        <input type="checkbox" name="IsPrimary" value="true" checked="@translation.IsPrimary" />
                                        <input type="hidden" name="IsPrimary" value="false" />
                                        <span>@T["Primary meaning"]</span>
                                    </label>
                                    <button class="button button--compact" type="submit">@T["Save"]</button>
                                </form>
                                <form class="inline-form" method="post" asp-action="DeleteSenseTranslation" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" asp-route-translationId="@translation.TranslationId" data-confirm-submit="@T["Delete this translation?"]">
                                    @Html.AntiForgeryToken()
                                    <button class="button button--secondary button--compact" type="submit">@T["Delete"]</button>
                                </form>
                            </div>
                        }
                    </div>
                    <form class="admin-inline-panel stack-sm" method="post" asp-action="AddSenseTranslation" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" data-confirm-submit="@T["Add this sense translation?"]">
                        @Html.AntiForgeryToken()
                        <strong>@T["Add meaning"]</strong>
                        <div class="admin-inline-form-grid">
                            <label class="form-field">
                                <span>@T["Language"]</span>
                                <input name="LanguageCode" maxlength="16" value="en" required />
                            </label>
                            <label class="form-field field--wide">
                                <span>@T["Meaning"]</span>
                                <input name="TranslationText" maxlength="512" required />
                            </label>
                            <label class="admin-toggle-field">
                                <input type="checkbox" name="IsPrimary" value="true" />
                                <input type="hidden" name="IsPrimary" value="false" />
                                <span>@T["Primary meaning"]</span>
                            </label>
                            <button class="button button--compact" type="submit">@T["Add"]</button>
                        </div>
                    </form>
                </div>

                <div class="admin-editor-subsection">
                    <div class="admin-editor-section-header">
                        <h4 class="admin-subhead">@T["Examples and translations"]</h4>
                        <span class="eyebrow">@T["{0} items", sense.Examples.Count]</span>
                    </div>
                    <div class="admin-example-list">
                        @foreach (var example in sense.Examples)
                        {
                            <div class="admin-example-editor admin-editor-card admin-editor-card--flat">
                                <form class="admin-row-form admin-row-form--example" method="post" asp-action="UpdateSenseExample" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" asp-route-exampleId="@example.ExampleId" data-confirm-submit="@T["Save this example?"]">
                                    @Html.AntiForgeryToken()
                                    <label class="form-field field--wide">
                                        <span>@T["German example"]</span>
                                        <input name="GermanText" maxlength="2000" value="@example.GermanText" required />
                                    </label>
                                    <label class="admin-toggle-field">
                                        <input type="checkbox" name="IsPrimaryExample" value="true" checked="@example.IsPrimaryExample" />
                                        <input type="hidden" name="IsPrimaryExample" value="false" />
                                        <span>@T["Primary example"]</span>
                                    </label>
                                    <button class="button button--compact" type="submit">@T["Save example"]</button>
                                </form>

                                <div class="admin-example-translation-list">
                                    @if (example.Translations.Count == 0)
                                    {
                                        <p class="muted-text">@T["No translations for this example yet."]</p>
                                    }
                                    @foreach (var translation in example.Translations)
                                    {
                                        <div class="admin-editor-card admin-editor-card--nested">
                                            <form class="admin-row-form" method="post" asp-action="UpdateSenseExampleTranslation" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" asp-route-exampleId="@example.ExampleId" asp-route-translationId="@translation.TranslationId" data-confirm-submit="@T["Save this example translation?"]">
                                                @Html.AntiForgeryToken()
                                                <label class="form-field">
                                                    <span>@T["Language"]</span>
                                                    <input name="LanguageCode" maxlength="16" value="@translation.LanguageCode" required />
                                                </label>
                                                <label class="form-field field--wide">
                                                    <span>@T["Example translation"]</span>
                                                    <input name="TranslationText" maxlength="2000" value="@translation.TranslationText" required />
                                                </label>
                                                <button class="button button--compact" type="submit">@T["Save"]</button>
                                            </form>
                                            <form class="inline-form" method="post" asp-action="DeleteSenseExampleTranslation" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" asp-route-exampleId="@example.ExampleId" asp-route-translationId="@translation.TranslationId" data-confirm-submit="@T["Delete this example translation?"]">
                                                @Html.AntiForgeryToken()
                                                <button class="button button--secondary button--compact" type="submit">@T["Delete"]</button>
                                            </form>
                                        </div>
                                    }
                                </div>

                                <form class="admin-inline-panel stack-sm" method="post" asp-action="AddSenseExampleTranslation" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" asp-route-exampleId="@example.ExampleId" data-confirm-submit="@T["Add this example translation?"]">
                                    @Html.AntiForgeryToken()
                                    <strong>@T["Add example translation"]</strong>
                                    <div class="admin-inline-form-grid admin-inline-form-grid--example-translation">
                                        <label class="form-field">
                                            <span>@T["Language"]</span>
                                            <input name="LanguageCode" maxlength="16" value="en" required />
                                        </label>
                                        <label class="form-field field--wide">
                                            <span>@T["Translation"]</span>
                                            <input name="TranslationText" maxlength="2000" required />
                                        </label>
                                        <button class="button button--compact" type="submit">@T["Add"]</button>
                                    </div>
                                </form>

                                <form class="inline-form" method="post" asp-action="DeleteSenseExample" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" asp-route-exampleId="@example.ExampleId" data-confirm-submit="@T["Delete this example and its translations?"]">
                                    @Html.AntiForgeryToken()
                                    <button class="button button--secondary button--compact" type="submit">@T["Delete example"]</button>
                                </form>
                            </div>
                        }
                    </div>

                    <form class="admin-inline-panel stack-sm" method="post" asp-action="AddSenseExample" asp-route-publicId="@Model.PublicId" asp-route-senseId="@sense.SenseId" data-confirm-submit="@T["Add this sense example?"]">
                        @Html.AntiForgeryToken()
                        <strong>@T["Add example"]</strong>
                        <div class="admin-inline-form-grid admin-inline-form-grid--example">
                            <label class="form-field field--wide">
                                <span>@T["German text"]</span>
                                <input name="GermanText" maxlength="2000" required />
                            </label>
                            <label class="form-field">
                                <span>@T["Translation language"]</span>
                                <input name="TranslationLanguageCode" maxlength="16" placeholder="en" />
                            </label>
                            <label class="form-field">
                                <span>@T["Translation"]</span>
                                <input name="TranslationText" maxlength="2000" />
                            </label>
                            <label class="admin-toggle-field">
                                <input type="checkbox" name="IsPrimaryExample" value="true" />
                                <input type="hidden" name="IsPrimaryExample" value="false" />
                                <span>@T["Primary example"]</span>
                            </label>
                            <button class="button button--compact" type="submit">@T["Add"]</button>
                        </div>
                    </form>
                </div>
            </article>
        }
    }

    <details class="admin-inline-panel admin-sense-form stack-md">
        <summary>@T["Add sense"]</summary>
        <form method="post" asp-action="AddSense" asp-route-publicId="@Model.PublicId" data-confirm-submit="@T["Add this word sense?"]">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <label class="form-field">
                    <span>@T["Status"]</span>
                    <select name="PublicationStatus">
                        @foreach (var status in statusOptions)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </label>
                <label class="admin-toggle-field">
                    <input type="checkbox" name="IsPrimarySense" value="true" />
                    <input type="hidden" name="IsPrimarySense" value="false" />
                    <span>@T["Primary sense"]</span>
                </label>
                <label class="form-field">
                    <span>@T["German definition"]</span>
                    <input name="ShortDefinitionDe" maxlength="512" />
                </label>
                <label class="form-field">
                    <span>@T["Short gloss"]</span>
                    <input name="ShortGloss" maxlength="512" />
                </label>
                <label class="form-field">
                    <span>@T["Translation language"]</span>
                    <input name="TranslationLanguageCode" maxlength="16" placeholder="en" />
                </label>
                <label class="form-field">
                    <span>@T["Translation"]</span>
                    <input name="TranslationText" maxlength="512" />
                </label>
                <label class="admin-toggle-field">
                    <input type="checkbox" name="IsPrimaryTranslation" value="true" checked />
                    <input type="hidden" name="IsPrimaryTranslation" value="false" />
                    <span>@T["Primary meaning"]</span>
                </label>
                <label class="form-field field--wide">
                    <span>@T["Example German text"]</span>
                    <input name="ExampleGermanText" maxlength="2000" />
                </label>
                <label class="form-field">
                    <span>@T["Example translation language"]</span>
                    <input name="ExampleTranslationLanguageCode" maxlength="16" placeholder="en" />
                </label>
                <label class="form-field">
                    <span>@T["Example translation"]</span>
                    <input name="ExampleTranslationText" maxlength="2000" />
                </label>
                <label class="admin-toggle-field">
                    <input type="checkbox" name="IsPrimaryExample" value="true" checked />
                    <input type="hidden" name="IsPrimaryExample" value="false" />
                    <span>@T["Primary example"]</span>
                </label>
            </div>
            <button class="button" type="submit">@T["Add sense"]</button>
        </form>
    </details>
</section>

<section id="word-assets" class="admin-two-column">
    <div class="panel stack-md">
        <h2 class="headline-sm">@T["Lexical forms"]</h2>
        @if (Model.LexicalForms.Count == 0)
        {
            <p>@T["No lexical forms recorded."]</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table admin-data-grid">
                    <thead>
                        <tr><th>@T["POS"]</th><th>@T["Article"]</th><th>@T["Plural"]</th><th>@T["Infinitive"]</th><th>@T["Primary"]</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var form in Model.LexicalForms)
                        {
                            <tr>
                                <td>@form.PartOfSpeech</td>
                                <td>@(form.Article ?? "-")</td>
                                <td>@(form.PluralForm ?? "-")</td>
                                <td>@(form.InfinitiveForm ?? "-")</td>
                                <td>@(form.IsPrimary ? T["Yes"] : T["No"])</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="panel stack-md">
        <h2 class="headline-sm">@T["Usage assets"]</h2>
        @if (Model.GrammarNotes.Count == 0 && Model.Collocations.Count == 0)
        {
            <p>@T["No grammar notes or collocations recorded."]</p>
        }
        else
        {
            <div class="stack-sm">
                @foreach (var note in Model.GrammarNotes)
                {
                    <p><strong>@T["Grammar"]:</strong> @note.Text</p>
                }
                @foreach (var collocation in Model.Collocations)
                {
                    <p><strong>@T["Collocation"]:</strong> @collocation.Text @(!string.IsNullOrWhiteSpace(collocation.Meaning) ? $" - {collocation.Meaning}" : null)</p>
                }
            </div>
        }
    </div>
</section>
