@model DarwinLingua.Web.Models.AdminCoursesPageViewModel
@{
    ViewData["Title"] = T["Courses"];
}

<section class="admin-panel stack-md">
    <div class="admin-section-heading">
        <div>
            <span class="eyebrow">@T["Content"]</span>
            <h1>@T["Courses"]</h1>
        </div>
        <a class="button button--secondary button--compact" asp-area="" asp-controller="Courses" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Open learner view"]</a>
    </div>

    @if (Model.Courses.Count == 0)
    {
        <p>@T["No courses have been imported yet."]</p>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>@T["Title"]</th>
                        <th>@T["CEFR level"]</th>
                        <th>@T["Modules"]</th>
                        <th>@T["Lessons"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model.Courses)
                    {
                        <tr>
                            <td>
                                <a asp-area="" asp-controller="Courses" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Detail" asp-route-slug="@course.Slug">@course.Title</a>
                                <small>@course.Slug</small>
                            </td>
                            <td>@(course.CefrLevel ?? course.CefrRange)</td>
                            <td>@course.ModuleCount</td>
                            <td>@course.LessonCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
