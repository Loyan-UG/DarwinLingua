@model DarwinLingua.Web.Models.AdminScenariosPageViewModel
@{
    ViewData["Title"] = "Scenarios";
    var query = ViewData["AdminScenarioQuery"] as string ?? string.Empty;
    var selectedStatus = ViewData["AdminScenarioStatus"] as string ?? string.Empty;
    var selectedCefr = ViewData["AdminScenarioCefr"] as string ?? string.Empty;
    var selectedCategory = ViewData["AdminScenarioCategory"] as string ?? string.Empty;
    var selectedSort = ViewData["AdminScenarioSort"] as string ?? "sortOrder";
    var statuses = ViewData["AdminScenarioStatuses"] as string[] ?? [];
    var cefrLevels = ViewData["AdminScenarioCefrLevels"] as string[] ?? [];
    var categories = ViewData["AdminScenarioCategories"] as string[] ?? [];
    var totalCount = ViewData["AdminScenarioTotalCount"] as int? ?? Model.Scenarios.Count;
    int activeCount = Model.Scenarios.Count(scenario => string.Equals(scenario.PublicationStatus, "Active", StringComparison.OrdinalIgnoreCase));
    int assetCount = Model.Scenarios.Sum(scenario => scenario.DialogueTurnCount + scenario.PhraseCount + scenario.QuestionCount);
}

<section class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Scenarios", "Conversation practice", "Manage scenario lessons used for learner-facing guided dialogue and roleplay.")' />
        <div class="cluster">
            <a class="button button--secondary" asp-action="Import">Import JSON</a>
            <a class="button" asp-action="New">New scenario</a>
        </div>
    </div>
    @if (TempData["AdminStatusMessage"] is string statusMessage)
    {
        <div class="state-panel state-panel--success">@statusMessage</div>
    }
    <div class="admin-summary-grid">
        <a href="#scenarios-table" class="admin-summary-tile">
            <span class="eyebrow">Scenarios shown</span>
            <strong>@Model.Scenarios.Count</strong>
        </a>
        <a href="#scenarios-table" class="admin-summary-tile">
            <span class="eyebrow">Active</span>
            <strong>@activeCount</strong>
        </a>
        <a href="#scenarios-table" class="admin-summary-tile">
            <span class="eyebrow">Content assets</span>
            <strong>@assetCount</strong>
        </a>
    </div>
    <nav class="admin-anchor-nav" aria-label="Scenario catalog sections">
        <a href="#scenarios-filter">Filter</a>
        <a href="#scenarios-table">Scenarios</a>
    </nav>
</section>

<section class="panel stack-md">
    <form id="scenarios-filter" class="admin-filter-panel" method="get">
        <label class="form-field">
            <span>Search</span>
            <input name="q" type="search" value="@query" placeholder="Title, slug, category" />
        </label>
        <label class="form-field">
            <span>Status</span>
            <select name="status">
                <option value="">All statuses</option>
                @foreach (var status in statuses)
                {
                    <option value="@status" selected="@(string.Equals(status, selectedStatus, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@status</option>
                }
            </select>
        </label>
        <label class="form-field">
            <span>CEFR</span>
            <select name="cefr">
                <option value="">All levels</option>
                @foreach (var level in cefrLevels)
                {
                    <option value="@level" selected="@(string.Equals(level, selectedCefr, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@level</option>
                }
            </select>
        </label>
        <label class="form-field">
            <span>Category</span>
            <select name="category">
                <option value="">All categories</option>
                @foreach (var category in categories)
                {
                    <option value="@category" selected="@(string.Equals(category, selectedCategory, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@category</option>
                }
            </select>
        </label>
        <label class="form-field">
            <span>Sort</span>
            <select name="sort">
                <option value="sortOrder" selected="@(selectedSort == "sortOrder" ? "selected" : null)">Sort order</option>
                <option value="title" selected="@(selectedSort == "title" ? "selected" : null)">Title</option>
                <option value="updated" selected="@(selectedSort == "updated" ? "selected" : null)">Recently updated</option>
                <option value="assets" selected="@(selectedSort == "assets" ? "selected" : null)">Most content</option>
            </select>
        </label>
        <button class="button button--compact" type="submit">Apply</button>
        <a class="button button--secondary button--compact" asp-action="Index">Reset</a>
    </form>
    <div class="cluster cluster--between">
        <span class="eyebrow">@Model.Scenarios.Count of @totalCount scenarios</span>
    </div>
    <div id="scenarios-table" class="table-scroll">
        <table class="data-table admin-data-grid">
            <thead>
                <tr>
                    <th>Title</th><th>Slug</th><th>CEFR</th><th>Category</th><th>Status</th><th>Assets</th><th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Scenarios.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <div class="state-panel">No scenarios match the current filters.</div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var scenario in Model.Scenarios)
                    {
                        <tr>
                            <td><strong>@scenario.Title</strong></td>
                            <td>@scenario.Slug</td>
                            <td>@scenario.CefrLevel</td>
                            <td>@scenario.Category</td>
                            <td><span class="status-pill">@scenario.PublicationStatus</span></td>
                            <td>@scenario.DialogueTurnCount turns, @scenario.PhraseCount phrases, @scenario.QuestionCount questions</td>
                            <td><a class="button button--compact" asp-action="Details" asp-route-scenarioId="@scenario.ScenarioId">Open</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
