@model DarwinLingua.Web.Models.AdminScenarioAddTranslationFormViewModel

<details class="admin-inline-panel stack-sm">
    <summary>@Model.Summary</summary>
    <form method="post" action="@Url.Action(Model.AddAction, Model.GetAddRouteValues())" data-confirm-submit="@Model.ConfirmationMessage">
        @Html.AntiForgeryToken()
        <div class="admin-inline-form-grid admin-inline-form-grid--label">
            <label class="form-field">
                <span>Language</span>
                <input name="languageCode" value="en" required maxlength="16" />
            </label>
            <label class="form-field">
                <span>@Model.TextLabel</span>
                <input name="text" required maxlength="2000" />
            </label>
            <button class="button button--compact" type="submit">Add</button>
        </div>
    </form>
</details>
