@model DarwinLingua.Web.Models.AdminBulkScenarioImportResponse
@{
    ViewData["Title"] = "Import scenarios";
}

<div class="admin-summary-grid">
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Import type", "Scenarios", "Bulk practice content.")' />
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Format", "JSON", "Complete scenario lessons.")' />
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Result", Model is null ? "Pending" : Model.ImportedCount.ToString(), "Imported rows in the latest upload.")' />
</div>

<nav class="admin-anchor-nav" aria-label="Scenario import sections">
    <a href="#scenario-import-upload">Upload</a>
    @if (Model is not null)
    {
        <a href="#scenario-import-result">Result</a>
    }
    <a href="#scenario-import-format">JSON shape</a>
</nav>

<section id="scenario-import-upload" class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Import scenarios", "Bulk JSON", "Upload complete scenario lessons with dialogue turns, phrases, questions, answers, and translations.")' />
        <a class="button button--secondary" asp-action="Index">Back to scenarios</a>
    </div>

    <form class="stack-md" method="post" enctype="multipart/form-data" asp-action="Import" data-confirm-submit="Import these scenarios from JSON?">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-message"></div>
        <label class="form-field">
            <span>JSON file</span>
            <input type="file" name="JsonFile" accept="application/json,.json" required />
        </label>
        <button class="button" type="submit">Import JSON</button>
    </form>
</section>

@if (Model is not null)
{
    <section id="scenario-import-result" class="panel stack-md">
        <div class="admin-detail-grid">
            <div><span class="eyebrow">Total</span><strong>@Model.TotalCount</strong></div>
            <div><span class="eyebrow">Imported</span><strong>@Model.ImportedCount</strong></div>
            <div><span class="eyebrow">Skipped</span><strong>@Model.SkippedCount</strong></div>
            <div><span class="eyebrow">Failed</span><strong>@Model.FailedCount</strong></div>
        </div>

        <div class="table-scroll">
            <table class="data-table admin-data-grid">
                <thead>
                    <tr><th>Row</th><th>Slug</th><th>Status</th><th>Message</th><th>Scenario</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.RowNumber</td>
                            <td>@(item.Slug ?? "-")</td>
                            <td><span class="status-pill">@item.Status</span></td>
                            <td>@item.Message</td>
                            <td>
                                @if (item.ScenarioId is Guid scenarioId)
                                {
                                    <a class="button button--compact" asp-action="Details" asp-route-scenarioId="@scenarioId">Open</a>
                                }
                                else
                                {
                                    <span class="muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

<section id="scenario-import-format" class="panel stack-md">
    <h2 class="headline-sm">Expected JSON shape</h2>
    <pre class="code-sample"><code>{
  "scenarios": [
    {
      "slug": "booking-an-appointment-a2",
      "title": "Booking an appointment",
      "description": "Practice arranging a simple appointment.",
      "learnerGoal": "Ask for a time and confirm the appointment.",
      "cefrLevel": "A2",
      "category": "daily-life",
      "publicationStatus": "Published",
      "sortOrder": 10,
      "dialogueTurns": [
        {
          "sortOrder": 1,
          "speakerRole": "learner",
          "baseText": "Ich moechte einen Termin vereinbaren.",
          "translations": [{ "languageCode": "en", "text": "I would like to make an appointment." }]
        }
      ],
      "usefulPhrases": [
        {
          "sortOrder": 1,
          "baseText": "Passt Ihnen Montag?",
          "usageNote": "Use for checking availability.",
          "translations": [{ "languageCode": "en", "text": "Does Monday work for you?" }]
        }
      ],
      "questions": [
        {
          "sortOrder": 1,
          "prompt": "Which sentence asks for an appointment?",
          "answers": [
            { "sortOrder": 1, "text": "Ich moechte einen Termin vereinbaren.", "isCorrect": true },
            { "sortOrder": 2, "text": "Ich habe keinen Ausweis.", "isCorrect": false }
          ]
        }
      ]
    }
  ]
}</code></pre>
</section>
