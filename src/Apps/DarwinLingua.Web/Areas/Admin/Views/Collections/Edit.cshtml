@model DarwinLingua.Web.Models.AdminCollectionEditViewModel
@{
    ViewData["Title"] = Model.IsNew ? "New collection" : $"Edit {Model.Name}";
    string[] statuses = ["Draft", "Active", "Archived", "Deprecated"];
    string actionName = Model.IsNew ? "New" : "Edit";
}

<section class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(Model.IsNew ? "New collection" : Model.Name, "Collection metadata", "Create and maintain curated word packs.")' />
        <a class="button button--secondary" asp-action="Index">Back</a>
    </div>

    <form class="admin-edit-form stack-lg" method="post" asp-action="@actionName" asp-route-collectionId="@Model.CollectionId" data-confirm-submit="Save this collection?">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CollectionId" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <label class="form-field">
                <span>Slug</span>
                <input asp-for="Slug" readonly="@(!Model.IsNew)" />
                <span asp-validation-for="Slug" class="validation-message"></span>
            </label>
            <label class="form-field field--wide">
                <span>Name</span>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Status</span>
                <select asp-for="PublicationStatus">
                    @foreach (string status in statuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>Sort order</span>
                <input asp-for="SortOrder" type="number" min="0" />
            </label>
            <label class="form-field field--wide">
                <span>Image URL</span>
                <input asp-for="ImageUrl" />
                <span asp-validation-for="ImageUrl" class="validation-message"></span>
            </label>
            <label class="form-field field--wide">
                <span>Description</span>
                <textarea asp-for="Description" rows="4"></textarea>
                <span asp-validation-for="Description" class="validation-message"></span>
            </label>
        </div>

        <div class="cluster">
            <button class="button" type="submit">Save</button>
            <a class="button button--secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>
