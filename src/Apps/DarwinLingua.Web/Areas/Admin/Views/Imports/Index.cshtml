@model DarwinLingua.Web.Models.AdminImportsPageViewModel
@{
    ViewData["Title"] = "Imports";
    int warningPackageCount = Model.Packages.Count(package => package.WarningCount > 0 || package.InvalidEntries > 0);
    int failedPackageCount = Model.Packages.Count(package => string.Equals(package.Status, "Failed", StringComparison.OrdinalIgnoreCase));
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Imports", "Content import dashboard", "Filter package imports inline and inspect their current processing status.")' />
    <div class="admin-summary-grid">
        <a href="#imports-table" class="admin-summary-tile">
            <span class="eyebrow">Packages shown</span>
            <strong>@Model.Packages.Count</strong>
        </a>
        <a href="#imports-table" class="admin-summary-tile">
            <span class="eyebrow">With warnings</span>
            <strong>@warningPackageCount</strong>
        </a>
        <a href="#imports-table" class="admin-summary-tile">
            <span class="eyebrow">Failed</span>
            <strong>@failedPackageCount</strong>
        </a>
    </div>
    <nav class="admin-anchor-nav" aria-label="Import sections">
        <a href="#imports-filter">Filter</a>
        <a href="#imports-table">Packages</a>
    </nav>
    <form id="imports-filter" class="search-form" method="get" asp-action="Index">
        <input class="search-input"
               type="search"
               name="status"
               value="@Model.StatusFilter"
               placeholder="Filter by status"
               hx-get="@Url.Action("Table", "Imports", new { area = "Admin" })"
               hx-trigger="keyup changed delay:250ms, search"
               hx-target="#imports-table"
               hx-indicator="#imports-indicator" />
        <button type="submit" class="button button--secondary">Filter</button>
    </form>
    <div id="imports-indicator" class="eyebrow htmx-indicator">Updating imports…</div>
</section>

<div id="imports-table">
    <partial name="_ImportsTable" model="Model" />
</div>
