@model DarwinLingua.Web.Models.AdminBillingDiagnosticsPageViewModel
@{
    ViewData["Title"] = T["Billing diagnostics"];
    int failedEventCount = Model.Events.Count(billingEvent => string.Equals(billingEvent.Status, "Failed", StringComparison.OrdinalIgnoreCase));
    int warningCount = Model.Readiness.Warnings.Count;
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Diagnostics"]</span>
    <h1 class="headline-md">@T["Billing and Stripe events"]</h1>
    <p class="body-lg">@T["Stripe customer, subscription, and webhook state for entitlement reconciliation."]</p>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }

    <div class="admin-summary-grid">
        <a href="#billing-readiness" class="admin-summary-tile">
            <span class="eyebrow">@T["Readiness warnings"]</span>
            <strong>@warningCount</strong>
        </a>
        <a href="#billing-profiles" class="admin-summary-tile">
            <span class="eyebrow">@T["Profiles"]</span>
            <strong>@Model.Profiles.Count</strong>
        </a>
        <a href="#billing-events" class="admin-summary-tile">
            <span class="eyebrow">@T["Failed events"]</span>
            <strong>@failedEventCount</strong>
        </a>
    </div>

    <nav class="admin-anchor-nav" aria-label="@T["Billing diagnostics sections"]">
        <a href="#billing-readiness">@T["Readiness"]</a>
        <a href="#billing-filters">@T["Filters"]</a>
        @if (User.IsInRole("Admin"))
        {
            <a href="#billing-reconcile">@T["Reconcile"]</a>
        }
        <a href="#billing-profiles">@T["Profiles"]</a>
        <a href="#billing-events">@T["Events"]</a>
    </nav>
</section>

<section id="billing-readiness" class="panel stack-md">
    <div class="cluster cluster--between">
        <h2 class="headline-sm">@T["Readiness"]</h2>
        <span class="status-pill">@(warningCount == 0 ? T["Ready"] : T["{0} warning(s)", warningCount])</span>
    </div>
    <div class="metric-grid">
        <article class="metric-card">
            <span class="metric-card__label">@T["Stripe"]</span>
            <strong>@(Model.Readiness.StripeEnabled ? T["Enabled"] : T["Disabled"])</strong>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">@T["Price id"]</span>
            <strong>@(Model.Readiness.HasPremiumMonthlyPriceId ? T["Configured"] : T["Missing"])</strong>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">@T["Webhook secret"]</span>
            <strong>@(Model.Readiness.HasStripeWebhookSecret ? T["Configured"] : T["Missing"])</strong>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">@T["Tolerance"]</span>
            <strong>@T["{0} min", Model.Readiness.WebhookToleranceMinutes]</strong>
        </article>
    </div>
    <ul class="feature-list">
        <li>@T["Public base URL"]: @(string.IsNullOrWhiteSpace(Model.Readiness.PublicBaseUrl) ? T["Missing"] : Model.Readiness.PublicBaseUrl)</li>
        <li>@T["Stripe API base URL"]: @Model.Readiness.StripeApiBaseUrl</li>
        <li>@T["Stripe secret key"]: @(Model.Readiness.HasStripeSecretKey ? T["Configured"] : T["Missing"])</li>
        <li>@T["Premium plan key"]: @Model.Readiness.PremiumPlanKey</li>
    </ul>
    @if (Model.Readiness.Warnings.Count == 0)
    {
        <p class="body-sm">@T["No billing configuration warnings detected. Stripe dashboard settings still require external verification."]</p>
    }
    else
    {
        <div class="status-banner status-banner--error">
            <strong>@T["Readiness warnings"]</strong>
            <ul>
                @foreach (string warning in Model.Readiness.Warnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </div>
    }
</section>

<section id="billing-filters" class="panel stack-md">
    <h2 class="headline-sm">@T["Filters"]</h2>
    <form method="get" class="filter-bar">
        <label>
            @T["Status"]
            <select name="status">
                <option value="">@T["All"]</option>
                @foreach (string status in new[] { "Received", "Processed", "Failed" })
                {
                    <option value="@status" selected="@(string.Equals(Model.Status, status, StringComparison.OrdinalIgnoreCase))">@status</option>
                }
            </select>
        </label>
        <label>
            @T["Event type"]
            <select name="eventType">
                <option value="">@T["All"]</option>
                @foreach (string eventType in new[] { "checkout.session.completed", "customer.subscription.created", "customer.subscription.updated", "customer.subscription.deleted" })
                {
                    <option value="@eventType" selected="@(string.Equals(Model.EventType, eventType, StringComparison.OrdinalIgnoreCase))">@eventType</option>
                }
            </select>
        </label>
        <label>
            @T["User id"]
            <input name="userId" value="@Model.UserId" autocomplete="off" />
        </label>
        <label>
            @T["Customer id"]
            <input name="providerCustomerId" value="@Model.ProviderCustomerId" autocomplete="off" />
        </label>
        <label>
            @T["Subscription id"]
            <input name="providerSubscriptionId" value="@Model.ProviderSubscriptionId" autocomplete="off" />
        </label>
        <label>
            @T["Limit"]
            <input name="take" value="@Model.Take" type="number" min="1" max="200" />
        </label>
        <button type="submit" class="button button--primary">@T["Filter"]</button>
        <a class="button button--secondary" asp-area="Admin" asp-controller="BillingDiagnostics" asp-action="Index">@T["Clear"]</a>
    </form>
</section>

@if (User.IsInRole("Admin"))
{
    <section id="billing-reconcile" class="panel stack-md">
        <div class="cluster cluster--between">
            <h2 class="headline-sm">@T["Manual Stripe reconciliation"]</h2>
            <span class="status-pill">@T["Admin only"]</span>
        </div>
        <p class="body-sm">@T["Refresh one subscription directly from Stripe when a webhook is delayed, missed, or failed. This calls Stripe and may update local entitlement state."]</p>
        <form method="post" asp-action="ReconcileStripeSubscription" class="filter-bar" data-confirm-submit="@T["Refresh this subscription from Stripe and reconcile the local entitlement state?"]">
            @Html.AntiForgeryToken()
            <label>
                @T["Subscription id"]
                <input name="providerSubscriptionId" value="@Model.ProviderSubscriptionId" autocomplete="off" placeholder="sub_..." />
            </label>
            <button type="submit" class="button button--primary">@T["Reconcile subscription"]</button>
        </form>
    </section>
}

<section id="billing-profiles" class="panel stack-md">
    <div class="cluster cluster--between">
        <h2 class="headline-sm">@T["Billing profiles"]</h2>
        <span class="status-pill">@T["{0} shown", Model.Profiles.Count]</span>
    </div>
    @if (Model.Profiles.Count == 0)
    {
        <p class="body-sm">@T["No billing profiles have been recorded yet."]</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table admin-data-grid">
                <thead>
                    <tr>
                        <th>@T["Updated"]</th>
                        <th>@T["User"]</th>
                        <th>@T["Provider"]</th>
                        <th>@T["Status"]</th>
                        <th>@T["Plan"]</th>
                        <th>@T["Customer"]</th>
                        <th>@T["Subscription"]</th>
                        <th>@T["Period end"]</th>
                        <th>@T["Action"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var profile in Model.Profiles)
                    {
                        <tr>
                            <td>@profile.UpdatedAtUtc.UtcDateTime.ToString("u")</td>
                            <td><code>@profile.UserId</code></td>
                            <td>@profile.ProviderName</td>
                            <td>@profile.Status</td>
                            <td>@profile.PlanKey</td>
                            <td><code>@(profile.ProviderCustomerId ?? T["none"].Value)</code></td>
                            <td><code>@(profile.ProviderSubscriptionId ?? T["none"].Value)</code></td>
                            <td>@(profile.CurrentPeriodEndsAtUtc?.UtcDateTime.ToString("u") ?? T["none"])</td>
                            <td>
                                @if (User.IsInRole("Admin") && !string.IsNullOrWhiteSpace(profile.ProviderSubscriptionId))
                                {
                                    <form method="post" asp-action="ReconcileStripeSubscription" class="inline-form" data-confirm-submit="@T["Refresh this subscription from Stripe and reconcile the local entitlement state?"]">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="providerSubscriptionId" value="@profile.ProviderSubscriptionId" />
                                        <button type="submit" class="button button--secondary">@T["Reconcile"]</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="body-sm">@T["None"]</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="billing-events" class="panel stack-md">
    <div class="cluster cluster--between">
        <h2 class="headline-sm">@T["Recent billing events"]</h2>
        <span class="status-pill">@T["{0} shown", Model.Events.Count]</span>
    </div>
    @if (Model.Events.Count == 0)
    {
        <p class="body-sm">@T["No Stripe billing events have been recorded yet."]</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table admin-data-grid">
                <thead>
                    <tr>
                        <th>@T["Created"]</th>
                        <th>@T["Status"]</th>
                        <th>@T["Type"]</th>
                        <th>@T["Provider event"]</th>
                        <th>@T["User"]</th>
                        <th>@T["Customer"]</th>
                        <th>@T["Subscription"]</th>
                        <th>@T["Error"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var billingEvent in Model.Events)
                    {
                        <tr>
                            <td>@billingEvent.CreatedAtUtc.UtcDateTime.ToString("u")</td>
                            <td>@billingEvent.Status</td>
                            <td>@billingEvent.EventType</td>
                            <td><code>@billingEvent.ProviderEventId</code></td>
                            <td><code>@(billingEvent.UserId ?? T["none"].Value)</code></td>
                            <td><code>@(billingEvent.ProviderCustomerId ?? T["none"].Value)</code></td>
                            <td><code>@(billingEvent.ProviderSubscriptionId ?? T["none"].Value)</code></td>
                            <td>@(billingEvent.ErrorSummary ?? T["none"])</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
