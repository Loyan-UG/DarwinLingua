@model DarwinLingua.Web.Models.AdminModerationPageViewModel
@{
    ViewData["Title"] = "Moderation";
    int pendingCount = Model.Reports.Count(report => string.Equals(report.Status, "pending", StringComparison.OrdinalIgnoreCase));
    int actionableCount = Model.Reports.Count(report =>
        string.Equals(report.Status, "pending", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(report.Status, "reviewed", StringComparison.OrdinalIgnoreCase));
}

<section class="panel stack-lg">
    <span class="eyebrow">Admin</span>
    <h1 class="headline-md">Moderation queue</h1>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }

    <div class="admin-summary-grid">
        <a href="#moderation-reports" class="admin-summary-tile">
            <span class="eyebrow">Reports shown</span>
            <strong>@Model.Reports.Count</strong>
        </a>
        <a href="#moderation-reports" class="admin-summary-tile">
            <span class="eyebrow">Pending</span>
            <strong>@pendingCount</strong>
        </a>
        <a href="#moderation-audit" class="admin-summary-tile">
            <span class="eyebrow">Audit entries</span>
            <strong>@Model.Audits.Count</strong>
        </a>
    </div>

    <nav class="admin-anchor-nav" aria-label="Moderation sections">
        <a href="#moderation-filter">Filter</a>
        <a href="#moderation-reports">Reports</a>
        <a href="#moderation-audit">Audit</a>
    </nav>

    <form id="moderation-filter" method="get" asp-action="Index" class="action-row">
        <select name="status" aria-label="Status">
            <option value="">All statuses</option>
            <option value="pending" selected="@(Model.StatusFilter == "pending")">Pending</option>
            <option value="reviewed" selected="@(Model.StatusFilter == "reviewed")">Reviewed</option>
            <option value="dismissed" selected="@(Model.StatusFilter == "dismissed")">Dismissed</option>
            <option value="action-taken" selected="@(Model.StatusFilter == "action-taken")">Action taken</option>
        </select>
        <select name="reason" aria-label="Reason">
            <option value="">All reasons</option>
            <option value="inaccurate-listing" selected="@(Model.ReasonFilter == "inaccurate-listing")">Inaccurate listing</option>
            <option value="spam" selected="@(Model.ReasonFilter == "spam")">Spam</option>
            <option value="harassment" selected="@(Model.ReasonFilter == "harassment")">Harassment</option>
            <option value="unsafe-contact" selected="@(Model.ReasonFilter == "unsafe-contact")">Unsafe contact</option>
            <option value="impersonation" selected="@(Model.ReasonFilter == "impersonation")">Impersonation</option>
            <option value="other" selected="@(Model.ReasonFilter == "other")">Other</option>
        </select>
        <select name="targetType" aria-label="Target type">
            <option value="">All targets</option>
            <option value="conversation-event" selected="@(Model.TargetTypeFilter == "conversation-event")">Conversation event</option>
            <option value="learner-profile" selected="@(Model.TargetTypeFilter == "learner-profile")">Learner profile</option>
            <option value="partner-request" selected="@(Model.TargetTypeFilter == "partner-request")">Partner request</option>
            <option value="organizer-profile" selected="@(Model.TargetTypeFilter == "organizer-profile")">Organizer profile</option>
        </select>
        <select name="assignedState" aria-label="Decision owner">
            <option value="">Any decision owner</option>
            <option value="unassigned" selected="@(Model.AssignedStateFilter == "unassigned")">No decision owner</option>
            <option value="assigned" selected="@(Model.AssignedStateFilter == "assigned")">Has decision owner</option>
        </select>
        <button type="submit" class="button button--secondary">Filter</button>
    </form>
</section>

<section id="moderation-reports" class="panel stack-lg">
    <div class="cluster cluster--between">
        <h2 class="headline-sm">Reports</h2>
        <span class="status-pill">@actionableCount actionable</span>
    </div>
    @if (Model.Reports.Count == 0)
    {
        <p class="body-sm">No reports match the selected filter.</p>
    }
    else
    {
        <div class="stack-md">
            @foreach (var report in Model.Reports)
            {
                bool canDecide = string.Equals(report.Status, "pending", StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(report.Status, "reviewed", StringComparison.OrdinalIgnoreCase);
                <article class="panel stack-md">
                    <div class="grid-two-col">
                        <div>
                            <h3 class="headline-sm">@report.TargetType: @report.TargetKey</h3>
                            <p class="body-sm">Status: @report.Status · Reason: @report.Reason</p>
                            <p class="body-sm">Reporter: @report.ReporterEmail</p>
                            @if (!string.IsNullOrWhiteSpace(report.ReportedUserEmail))
                            {
                                <p class="body-sm">Reported user: @report.ReportedUserEmail</p>
                            }
                            <p class="body-sm">@report.Details</p>
                            @if (!string.IsNullOrWhiteSpace(report.DecisionNote))
                            {
                                <p class="body-sm">Decision: @report.DecisionNote</p>
                            }
                        </div>
                        @if (canDecide)
                        {
                            <form method="post" asp-action="Decide" asp-route-reportId="@report.Id" class="stack-sm" data-confirm-submit="Save this moderation decision?">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnStatus" value="@Model.StatusFilter" />
                                <input type="hidden" name="returnReason" value="@Model.ReasonFilter" />
                                <input type="hidden" name="returnTargetType" value="@Model.TargetTypeFilter" />
                                <input type="hidden" name="returnAssignedState" value="@Model.AssignedStateFilter" />
                                <label class="form-field">
                                    <span>Status</span>
                                    <select name="Status">
                                        <option value="reviewed" selected="@(string.Equals(report.Status, "reviewed", StringComparison.OrdinalIgnoreCase))">Reviewed</option>
                                        <option value="dismissed">Dismissed</option>
                                        <option value="action-taken">Action taken</option>
                                    </select>
                                </label>
                                <label class="form-field">
                                    <span>Decision note</span>
                                    <textarea name="DecisionNote" rows="3" maxlength="1000"></textarea>
                                </label>
                                <button type="submit" class="button button--primary">Save decision</button>
                            </form>
                        }
                        else
                        {
                            <div class="status-banner status-banner--success">Decision recorded. Further changes require a new moderation report.</div>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>

<section id="moderation-audit" class="panel stack-lg">
    <div class="cluster cluster--between">
        <h2 class="headline-sm">Decision audit</h2>
        <span class="status-pill">@Model.Audits.Count entries</span>
    </div>
    @if (Model.Audits.Count == 0)
    {
        <p class="body-sm">No moderation decisions have been recorded yet.</p>
    }
    else
    {
        <div class="stack-sm">
            @foreach (var audit in Model.Audits)
            {
                <p class="body-sm">@audit.CreatedAtUtc.ToString("u") · @audit.DecisionStatus · @audit.DecidedBy · @audit.UserReportId</p>
            }
        </div>
    }
</section>
