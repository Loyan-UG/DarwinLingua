@model DarwinLingua.Web.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin";
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Admin overview", "Operator shell is backed by live catalog metrics and management workflows.", "Use this area for catalog operations, event and organizer management, moderation, reporting, user entitlements, and diagnostics.")' />
</section>

<section class="grid-three-col">
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Active", Model.ActiveWordCount.ToString(), "Published learner-visible words.")' />
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Draft", Model.DraftWordCount.ToString(), "Words still outside the active learner catalog.")' />
    <partial name="~/Views/Shared/_MetricCard.cshtml" model='new DarwinLingua.Web.Models.MetricCardViewModel("Packages", Model.ImportedPackageCount.ToString(), "Imported content packages recorded so far.")' />
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">Management areas</h2>
        <ul class="feature-list">
            <li><a asp-area="Admin" asp-controller="Imports" asp-action="Index">Imports</a></li>
            <li><a asp-area="Admin" asp-controller="Drafts" asp-action="Index">Drafts</a></li>
            <li><a asp-area="Admin" asp-controller="Publishing" asp-action="Index">Publishing</a></li>
            <li><a asp-area="Admin" asp-controller="Reports" asp-action="Index">System report</a></li>
            <li><a asp-area="Admin" asp-controller="Moderation" asp-action="Index">Moderation</a></li>
            <li><a asp-area="Admin" asp-controller="Users" asp-action="Index">Users and entitlements</a></li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">Current operational snapshot</h2>
        <ul class="feature-list">
            <li>Topics: @Model.TotalTopicCount</li>
            <li>Failed imports: @Model.FailedPackageCount</li>
            <li>Last import: @(Model.LastImportAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "No imports yet")</li>
        </ul>
    </article>
</section>
