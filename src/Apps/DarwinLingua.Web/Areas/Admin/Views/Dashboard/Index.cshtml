@{
    ViewData["Title"] = "Admin";
}

<section class="panel stack-lg">
    <span class="eyebrow">Admin Area</span>
    <h1 class="headline-md">Operator shell baseline is now in place.</h1>
    <p class="body-lg">
        This is the first <code>Areas/Admin</code> placeholder for Darwin Lingua. The next slices will add authorization,
        draft inspection, publish history, rollback controls, and package diagnostics without mixing those concepts
        into the learner-facing root site.
    </p>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">Planned admin workflows</h2>
        <ul class="feature-list">
            <li>Draft batch inspection</li>
            <li>Publish and rollback actions</li>
            <li>Publication history and audit review</li>
            <li>Package and manifest diagnostics</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">Boundary rule</h2>
        <p class="body-lg">
            The admin area stays operational and content-focused. Learner-facing navigation, browse flows, and account
            surfaces remain in the root site.
        </p>
    </article>
</section>
