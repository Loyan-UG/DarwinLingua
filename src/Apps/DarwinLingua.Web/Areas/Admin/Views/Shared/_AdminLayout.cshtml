<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Darwin Lingua Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DarwinLingua.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-body admin-body">
    <div class="shell-backdrop" aria-hidden="true"></div>
    <header class="shell-header admin-header">
        <div class="shell-container shell-nav">
            <a class="brand-mark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <span class="brand-mark__icon">AD</span>
                <span class="brand-mark__text">
                    <strong>Darwin Lingua Admin</strong>
                    <span>Operator surface</span>
                </span>
            </a>
            <nav class="shell-links" aria-label="Admin">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Overview</a>
                <a asp-area="Admin" asp-controller="Publishing" asp-action="Index">Publishing</a>
                <a asp-area="Admin" asp-controller="Diagnostics" asp-action="Index">Diagnostics</a>
                <a asp-area="" asp-controller="Home" asp-action="Index">Learner site</a>
            </nav>
        </div>
    </header>
    <main class="shell-container shell-main">
        @RenderBody()
    </main>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
