@model DarwinLingua.Web.Models.AdminDialogueTranslationListViewModel

@if (Model.Translations.Count > 0)
{
    <div class="admin-translation-list">
        @foreach (var translation in Model.Translations)
        {
            <div class="admin-translation-row">
                <p><strong>@translation.LanguageCode</strong><span>@translation.Text</span></p>
                <form class="inline-form" method="post" action="@Url.Action(Model.DeleteAction, Model.GetDeleteRouteValues(translation.TranslationId))" data-confirm-submit="@Model.ConfirmationMessage">
                    @Html.AntiForgeryToken()
                    <button class="button button--secondary button--compact" type="submit">Remove</button>
                </form>
            </div>
        }
    </div>
}
