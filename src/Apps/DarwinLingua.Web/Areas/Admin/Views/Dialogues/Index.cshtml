@model DarwinLingua.Web.Models.AdminDialoguesPageViewModel
@{
    ViewData["Title"] = "Dialogues";
    var query = ViewData["AdminDialogueQuery"] as string ?? string.Empty;
    var selectedStatus = ViewData["AdminDialogueStatus"] as string ?? string.Empty;
    var selectedCefr = ViewData["AdminDialogueCefr"] as string ?? string.Empty;
    var selectedCategory = ViewData["AdminDialogueCategory"] as string ?? string.Empty;
    var selectedSort = ViewData["AdminDialogueSort"] as string ?? "sortOrder";
    var statuses = ViewData["AdminDialogueStatuses"] as string[] ?? [];
    var cefrLevels = ViewData["AdminDialogueCefrLevels"] as string[] ?? [];
    var categories = ViewData["AdminDialogueCategories"] as string[] ?? [];
    var totalCount = ViewData["AdminDialogueTotalCount"] as int? ?? Model.Dialogues.Count;
    int activeCount = Model.Dialogues.Count(dialogue => string.Equals(dialogue.PublicationStatus, "Active", StringComparison.OrdinalIgnoreCase));
    int assetCount = Model.Dialogues.Sum(dialogue => dialogue.DialogueTurnCount + dialogue.PhraseCount + dialogue.QuestionCount);
}

<section class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Dialogues", "Conversation practice", "Manage dialogue lessons used for learner-facing guided dialogue and roleplay.")' />
        <div class="cluster">
            <a class="button button--secondary" asp-action="Import">Import JSON</a>
            <a class="button" asp-action="New">New dialogue</a>
        </div>
    </div>
    @if (TempData["AdminStatusMessage"] is string statusMessage)
    {
        <div class="state-panel state-panel--success">@statusMessage</div>
    }
    <div class="admin-summary-grid">
        <a href="#dialogues-table" class="admin-summary-tile">
            <span class="eyebrow">Dialogues shown</span>
            <strong>@Model.Dialogues.Count</strong>
        </a>
        <a href="#dialogues-table" class="admin-summary-tile">
            <span class="eyebrow">Active</span>
            <strong>@activeCount</strong>
        </a>
        <a href="#dialogues-table" class="admin-summary-tile">
            <span class="eyebrow">Content assets</span>
            <strong>@assetCount</strong>
        </a>
    </div>
    <nav class="admin-anchor-nav" aria-label="Dialogue catalog sections">
        <a href="#dialogues-filter">Filter</a>
        <a href="#dialogues-table">Dialogues</a>
    </nav>
</section>

<section class="panel stack-md">
    <form id="dialogues-filter" class="admin-filter-panel" method="get">
        <label class="form-field">
            <span>Search</span>
            <input name="q" type="search" value="@query" placeholder="Title, slug, category" />
        </label>
        <label class="form-field">
            <span>Status</span>
            <select name="status">
                <option value="">All statuses</option>
                @foreach (var status in statuses)
                {
                    <option value="@status" selected="@(string.Equals(status, selectedStatus, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@status</option>
                }
            </select>
        </label>
        <label class="form-field">
            <span>CEFR</span>
            <select name="cefr">
                <option value="">All levels</option>
                @foreach (var level in cefrLevels)
                {
                    <option value="@level" selected="@(string.Equals(level, selectedCefr, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@level</option>
                }
            </select>
        </label>
        <label class="form-field">
            <span>Category</span>
            <select name="category">
                <option value="">All categories</option>
                @foreach (var category in categories)
                {
                    <option value="@category" selected="@(string.Equals(category, selectedCategory, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@category</option>
                }
            </select>
        </label>
        <label class="form-field">
            <span>Sort</span>
            <select name="sort">
                <option value="sortOrder" selected="@(selectedSort == "sortOrder" ? "selected" : null)">Sort order</option>
                <option value="title" selected="@(selectedSort == "title" ? "selected" : null)">Title</option>
                <option value="updated" selected="@(selectedSort == "updated" ? "selected" : null)">Recently updated</option>
                <option value="assets" selected="@(selectedSort == "assets" ? "selected" : null)">Most content</option>
            </select>
        </label>
        <button class="button button--compact" type="submit">Apply</button>
        <a class="button button--secondary button--compact" asp-action="Index">Reset</a>
    </form>
    <div class="cluster cluster--between">
        <span class="eyebrow">@Model.Dialogues.Count of @totalCount dialogues</span>
    </div>
    <div id="dialogues-table" class="table-scroll">
        <table class="data-table admin-data-grid">
            <thead>
                <tr>
                    <th>Title</th><th>Slug</th><th>CEFR</th><th>Category</th><th>Status</th><th>Assets</th><th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Dialogues.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <div class="state-panel">No dialogues match the current filters.</div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var dialogue in Model.Dialogues)
                    {
                        <tr>
                            <td><strong>@dialogue.Title</strong></td>
                            <td>@dialogue.Slug</td>
                            <td>@dialogue.CefrLevel</td>
                            <td>@dialogue.Category</td>
                            <td><span class="status-pill">@dialogue.PublicationStatus</span></td>
                            <td>@dialogue.DialogueTurnCount turns, @dialogue.PhraseCount phrases, @dialogue.QuestionCount questions</td>
                            <td><a class="button button--compact" asp-action="Details" asp-route-dialogueId="@dialogue.DialogueId">Open</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
