@model DarwinLingua.Web.Models.AdminLearningPortalIssuesPageViewModel
@{
    ViewData["Title"] = "Learning Portal issues";
}

<section class="panel stack-lg">
    <span class="eyebrow">Admin</span>
    <h1 class="headline-md">Learning Portal issue drill-down</h1>
    <p class="body-lg">Full operator view for unresolved links and quality issue rows generated by the Learning Portal report pipeline.</p>
    <div class="admin-summary-grid">
        <a href="#learning-portal-issues-table" class="admin-summary-tile">
            <span class="eyebrow">Total issues</span>
            <strong>@Model.TotalCount</strong>
        </a>
        <a href="#learning-portal-issues-table" class="admin-summary-tile">
            <span class="eyebrow">Filtered</span>
            <strong>@Model.FilteredCount</strong>
        </a>
        <a href="#learning-portal-issues-filter" class="admin-summary-tile">
            <span class="eyebrow">Shown</span>
            <strong>@Model.Issues.Count</strong>
        </a>
    </div>
</section>

<section class="panel stack-lg">
    <h2 id="learning-portal-issues-filter" class="headline-sm">Filters</h2>
    <form method="get" action="@Url.RouteUrl("Admin_Reports_LearningPortalIssues")" class="action-row" aria-label="Filter Learning Portal issue drill-down">
        <select class="form-select" name="area" aria-label="Issue area">
            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.AreaFilter))">All areas</option>
            @foreach (var area in Model.Areas)
            {
                <option value="@area" selected="@(string.Equals(Model.AreaFilter, area, StringComparison.OrdinalIgnoreCase))">@area</option>
            }
        </select>
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="Search area, owner, issue, or target" aria-label="Search Learning Portal issues" />
        <select class="form-select" name="take" aria-label="Rows to show">
            @foreach (var takeOption in new[] { 100, 250, 500, 1000 })
            {
                <option value="@takeOption" selected="@(Model.Take == takeOption)">@takeOption rows</option>
            }
        </select>
        <button class="button button--primary button--compact" type="submit">Filter</button>
        <button class="button button--secondary button--compact" type="submit" name="export" value="csv">Export CSV</button>
        <a class="button button--secondary button--compact" href="@Url.RouteUrl("Admin_Reports_LearningPortalIssues")">Reset</a>
        <a class="button button--secondary button--compact" href="@($"{Url.RouteUrl("Admin_Reports_Index")}#learning-portal-issues")">Back to report</a>
    </form>
</section>

<section class="panel stack-lg">
    <h2 id="learning-portal-issues-table" class="headline-sm">Issue rows</h2>
    @if (Model.Issues.Count == 0)
    {
        <p class="body-sm">No Learning Portal issues match the current filter.</p>
    }
    else
    {
        <p class="body-sm">Showing @Model.Issues.Count of @Model.FilteredCount filtered issues. Adjust the row limit if more rows are available.</p>
        <div class="table-scroll">
            <table class="data-table admin-data-grid">
                <thead>
                    <tr>
                        <th>Area</th>
                        <th>Owner</th>
                        <th>Issue</th>
                        <th>Target</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in Model.Issues)
                    {
                        <tr>
                            <td>@issue.Area</td>
                            <td>@issue.Owner</td>
                            <td>@issue.Issue</td>
                            <td>@(issue.Target ?? "n/a")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
