@model DarwinLingua.Web.Models.AdminRollbackPageViewModel
@{
    ViewData["Title"] = "Rollback";
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Rollback", "Protected rollback review", "Use this screen to review catalog state and confirm rollback intent before any destructive operational action.")' />
    <ul class="feature-list">
        <li>Draft words currently present: @Model.DraftWordCount</li>
        <li>Imported packages tracked: @Model.ImportedPackageCount</li>
    </ul>
    <div class="action-row">
        <button type="button" class="button button--secondary" data-modal-open="rollback-confirmation">Review rollback warning</button>
    </div>
</section>

<partial name="~/Views/Shared/_ConfirmActionModal.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel("Confirm rollback review", Model.WarningMessage, "warning")' />
