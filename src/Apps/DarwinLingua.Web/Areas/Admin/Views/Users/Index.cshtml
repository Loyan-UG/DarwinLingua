@using DarwinLingua.Identity
@model DarwinLingua.Web.Models.AdminUsersPageViewModel
@{
    ViewData["Title"] = "Users";
    int adminCount = Model.Users.Count(user => user.Roles.Contains(DarwinLinguaRoles.Admin, StringComparer.Ordinal));
    int premiumCount = Model.Users.Count(user => string.Equals(user.EntitlementTier, DarwinLinguaEntitlementTiers.Premium, StringComparison.OrdinalIgnoreCase));
    int trialCount = Model.Users.Count(user => string.Equals(user.EntitlementTier, DarwinLinguaEntitlementTiers.Trial, StringComparison.OrdinalIgnoreCase));
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Users", "Account management", "Review account status quickly, then open a user profile for full details and changes.")' />
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }

    <div class="admin-summary-grid">
        <a href="#users-table" class="admin-summary-tile">
            <span class="eyebrow">Users shown</span>
            <strong>@Model.Users.Count</strong>
        </a>
        <a href="#users-table" class="admin-summary-tile">
            <span class="eyebrow">Premium</span>
            <strong>@premiumCount</strong>
        </a>
        <a href="#users-table" class="admin-summary-tile">
            <span class="eyebrow">Trial</span>
            <strong>@trialCount</strong>
        </a>
        <a href="#users-table" class="admin-summary-tile">
            <span class="eyebrow">Admins</span>
            <strong>@adminCount</strong>
        </a>
    </div>
</section>

@if (Model.Users.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel("No users found", "Identity bootstrap has not created or registered any users yet.")' />
}
else
{
    <section id="users-table" class="panel stack-md">
        <div class="cluster cluster--between">
            <h2 class="headline-sm">User overview</h2>
            <span class="status-pill">@trialCount trial / @premiumCount premium</span>
        </div>
        <p class="body-sm">This table intentionally shows only the fields needed for scanning. Open a user to review identifiers, enabled features, audit history, roles, and entitlement controls.</p>
        <div class="table-scroll">
            <table class="data-table admin-data-grid">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Roles</th>
                        <th>Plan</th>
                        <th>Expires</th>
                        <th>Last entitlement event</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        DateTimeOffset? expiresAt = user.PremiumEndsAtUtc ?? user.TrialEndsAtUtc;
                        var latestEvent = user.RecentEntitlementEvents.OrderByDescending(item => item.CreatedAtUtc).FirstOrDefault();
                        <tr>
                            <td>
                                <strong>@user.Email</strong>
                                <div class="muted-text">@(user.UserName ?? "No username")@(user.EmailConfirmed ? null : " - unconfirmed")</div>
                            </td>
                            <td>
                                @if (user.Roles.Count == 0)
                                {
                                    <span class="muted-text">No roles</span>
                                }
                                else
                                {
                                    <div class="tag-list">
                                        @foreach (string role in user.Roles)
                                        {
                                            <span class="tag">@role</span>
                                        }
                                    </div>
                                }
                            </td>
                            <td><span class="status-pill">@user.EntitlementTier</span></td>
                            <td>
                                @if (expiresAt is null)
                                {
                                    <span class="muted-text">No expiry</span>
                                }
                                else
                                {
                                    @expiresAt.Value.UtcDateTime.ToString("yyyy-MM-dd HH:mm") <span class="muted-text">UTC</span>
                                }
                            </td>
                            <td>
                                @if (latestEvent is null)
                                {
                                    <span class="muted-text">None</span>
                                }
                                else
                                {
                                    <span>@latestEvent.EventType</span>
                                    <div class="muted-text">@latestEvent.CreatedAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</div>
                                }
                            </td>
                            <td class="table-actions">
                                <a class="button button--secondary button--compact" asp-action="Details" asp-route-userId="@user.UserId">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}
