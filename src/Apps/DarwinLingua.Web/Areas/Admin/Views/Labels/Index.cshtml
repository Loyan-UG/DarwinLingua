@model DarwinLingua.Web.Models.AdminLabelsPageViewModel
@{
    ViewData["Title"] = "Labels";
    var query = ViewData["AdminLabelQuery"] as string ?? string.Empty;
    var selectedKind = ViewData["AdminLabelKind"] as string ?? string.Empty;
    var selectedSystem = ViewData["AdminLabelSystem"] as string ?? string.Empty;
    var selectedSort = ViewData["AdminLabelSort"] as string ?? "sortOrder";
    var kinds = ViewData["AdminLabelKinds"] as string[] ?? [];
    var totalCount = ViewData["AdminLabelTotalCount"] as int? ?? Model.Labels.Count;
    int systemCount = Model.Labels.Count(label => label.IsSystem);
    int wordCount = Model.Labels.Sum(label => label.WordCount);
}

<section class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Labels", "Managed label taxonomy", "Maintain normalized usage and context labels for catalog filtering, imports, and admin word editing.")' />
        <a class="button" asp-action="New">New label</a>
    </div>
    @if (TempData["AdminStatusMessage"] is string statusMessage)
    {
        <div class="state-panel state-panel--success">@statusMessage</div>
    }
    <div class="admin-summary-grid">
        <a href="#labels-table" class="admin-summary-tile">
            <span class="eyebrow">Labels shown</span>
            <strong>@Model.Labels.Count</strong>
        </a>
        <a href="#labels-table" class="admin-summary-tile">
            <span class="eyebrow">System</span>
            <strong>@systemCount</strong>
        </a>
        <a href="#labels-table" class="admin-summary-tile">
            <span class="eyebrow">Word links</span>
            <strong>@wordCount</strong>
        </a>
    </div>
    <nav class="admin-anchor-nav" aria-label="Label taxonomy sections">
        <a href="#labels-filter">Filter</a>
        <a href="#labels-table">Labels</a>
    </nav>
</section>

<section class="panel stack-md">
    <form id="labels-filter" class="admin-filter-panel" method="get">
        <label class="form-field">
            <span>Search</span>
            <input name="q" type="search" value="@query" placeholder="Display name or key" />
        </label>
        <label class="form-field">
            <span>Kind</span>
            <select name="kind">
                <option value="">All kinds</option>
                @foreach (var kind in kinds)
                {
                    <option value="@kind" selected="@(string.Equals(kind, selectedKind, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@kind</option>
                }
            </select>
        </label>
        <label class="form-field">
            <span>System</span>
            <select name="system">
                <option value="">All labels</option>
                <option value="true" selected="@(string.Equals(selectedSystem, "true", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">System</option>
                <option value="false" selected="@(string.Equals(selectedSystem, "false", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Custom</option>
            </select>
        </label>
        <label class="form-field">
            <span>Sort</span>
            <select name="sort">
                <option value="sortOrder" selected="@(selectedSort == "sortOrder" ? "selected" : null)">Sort order</option>
                <option value="displayName" selected="@(selectedSort == "displayName" ? "selected" : null)">Display name</option>
                <option value="kind" selected="@(selectedSort == "kind" ? "selected" : null)">Kind</option>
                <option value="updated" selected="@(selectedSort == "updated" ? "selected" : null)">Recently updated</option>
                <option value="words" selected="@(selectedSort == "words" ? "selected" : null)">Most words</option>
            </select>
        </label>
        <button class="button button--compact" type="submit">Apply</button>
        <a class="button button--secondary button--compact" asp-action="Index">Reset</a>
    </form>
    <div class="cluster cluster--between">
        <span class="eyebrow">@Model.Labels.Count of @totalCount labels</span>
    </div>
    <div id="labels-table" class="table-scroll">
        <table class="data-table admin-data-grid">
            <thead>
                <tr>
                    <th>Display name</th>
                    <th>Kind</th>
                    <th>Key</th>
                    <th>Words</th>
                    <th>Sort</th>
                    <th>System</th>
                    <th>Updated</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Labels.Count == 0)
                {
                    <tr>
                        <td colspan="8">
                            <div class="state-panel">No labels match the current filters.</div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var label in Model.Labels)
                    {
                        <tr>
                            <td><strong>@label.DisplayName</strong></td>
                            <td>@label.Kind</td>
                            <td><code>@label.Key</code></td>
                            <td>@label.WordCount</td>
                            <td>@label.SortOrder</td>
                            <td>@(label.IsSystem ? "Yes" : "No")</td>
                            <td>@label.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td><a class="button button--secondary button--sm" asp-action="Edit" asp-route-labelId="@label.LabelId">Edit</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
