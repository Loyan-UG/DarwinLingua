@model DarwinLingua.Web.Models.AdminLabelEditViewModel
@{
    ViewData["Title"] = Model.IsNew ? "New label" : "Edit label";
    var mergeTargets = ViewData["MergeTargets"] as IReadOnlyList<DarwinLingua.Web.Models.AdminLabelItemViewModel> ?? [];
}

<section class="panel stack-lg">
    <div class="cluster cluster--between">
        <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(Model.IsNew ? "New label" : Model.DisplayName, "Label editor", "Use managed labels to keep word metadata consistent across imports, browse filters, and admin editing.")' />
        <a class="button button--secondary" asp-action="Index">Back to labels</a>
    </div>
    @if (TempData["AdminStatusMessage"] is string statusMessage)
    {
        <div class="state-panel state-panel--success">@statusMessage</div>
    }
    @if (TempData["AdminErrorMessage"] is string errorMessage)
    {
        <div class="state-panel state-panel--warning">@errorMessage</div>
    }

    <form class="stack-md" method="post" data-confirm-submit="Save this label definition?">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="LabelId" />
        <div asp-validation-summary="ModelOnly" class="validation-message"></div>
        <div class="form-grid">
            <label class="form-field">
                <span>Kind</span>
                <select asp-for="Kind" disabled="@(!Model.IsNew)">
                    <option value="Usage">Usage</option>
                    <option value="Context">Context</option>
                </select>
                @if (!Model.IsNew)
                {
                    <input type="hidden" asp-for="Kind" />
                }
                <span asp-validation-for="Kind" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Key</span>
                <input asp-for="Key" placeholder="business-email" readonly="@(!Model.IsNew)" />
                <span asp-validation-for="Key" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Display name</span>
                <input asp-for="DisplayName" placeholder="Business email" />
                <span asp-validation-for="DisplayName" class="validation-message"></span>
            </label>
            <label class="form-field">
                <span>Sort order</span>
                <input asp-for="SortOrder" type="number" min="0" />
                <span asp-validation-for="SortOrder" class="validation-message"></span>
            </label>
            <label class="form-field form-field--check">
                <input asp-for="IsSystem" />
                <span>System label</span>
            </label>
        </div>

        <button class="button" type="submit">Save label</button>
    </form>
</section>

@if (!Model.IsNew)
{
    <section class="admin-two-column">
        <div class="panel stack-md">
            <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Rename", "Move attached words", "Change the label kind or key and update every attached word label in one operation.")' />
            <form class="stack-md" method="post" asp-action="Rename" asp-route-labelId="@Model.LabelId" data-confirm-submit="Rename this label and update attached words?">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="LabelId" />
                <input type="hidden" asp-for="DisplayName" />
                <input type="hidden" asp-for="SortOrder" />
                <input type="hidden" name="IsSystem" value="@Model.IsSystem.ToString().ToLowerInvariant()" />
                <div class="form-grid">
                    <label class="form-field">
                        <span>New kind</span>
                        <select asp-for="Kind">
                            <option value="Usage">Usage</option>
                            <option value="Context">Context</option>
                        </select>
                    </label>
                    <label class="form-field">
                        <span>New key</span>
                        <input asp-for="Key" placeholder="business-email" />
                    </label>
                </div>
                <button class="button button--secondary" type="submit">Rename label</button>
            </form>
        </div>

        <div class="panel stack-md">
            <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Merge", "Consolidate duplicates", "Move this label into another label and remove duplicate word-label links safely.")' />
            <form class="stack-md" method="post" asp-action="Merge" asp-route-labelId="@Model.LabelId" data-confirm-submit="Merge this label into the selected target?">
                @Html.AntiForgeryToken()
                <label class="form-field">
                    <span>Target label</span>
                    <select name="targetLabelId" required>
                        <option value="">Select target label</option>
                        @foreach (var label in mergeTargets)
                        {
                            <option value="@label.LabelId">@label.DisplayName (@label.Kind/@label.Key, @label.WordCount words)</option>
                        }
                    </select>
                </label>
                <button class="button button--secondary" type="submit" disabled="@(mergeTargets.Count == 0)">Merge into target</button>
            </form>
        </div>
    </section>
}
