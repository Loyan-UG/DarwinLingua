@model DarwinLingua.Web.Models.OrganizerProfileIndexPageViewModel
@{
    ViewData["Title"] = T["Organizers"];
    string FormatCefrLevel(string level, string? targetLearningLanguageCode) =>
        LearningPortalFilterConventions.FormatCefrLevelOption(level, targetLearningLanguageCode, key => T[key].Value);
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(T["Organizers"].Value, T["Conversation hosts"].Value, T["Find clubs, teachers, cafes, and organizations that host German practice opportunities."].Value)' />
</section>

<section class="grid-two-col">
    @if (Model.Profiles.Count == 0)
    {
        <article class="panel stack-md">
            <h2 class="headline-sm">@T["No organizers yet"]</h2>
            <p>@T["Organizer profiles will appear here after they are reviewed."]</p>
        </article>
    }
    else
    {
        @foreach (var profile in Model.Profiles)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@profile.OrganizerType · @(profile.IsOnlineAvailable ? T["Online available"] : profile.CityRegion)</span>
                <h2 class="headline-sm">
                    <a asp-controller="OrganizerProfiles" asp-action="Detail" asp-route-targetLearningLanguageCode="@profile.TargetLearningLanguageCode" asp-route-slug="@profile.Slug">@profile.DisplayName</a>
                </h2>
                <p>@profile.Description</p>
                <div class="chip-grid">
                    @foreach (string level in profile.SupportedLearnerLevels)
                    {
                        <span class="chip-link">@FormatCefrLevel(level, profile.TargetLearningLanguageCode)</span>
                    }
                    @foreach (string languageCode in profile.HelperLanguageCodes)
                    {
                        <span class="chip-link">@languageCode</span>
                    }
                    @if (profile.VerificationStatus is "verified" or "reviewed")
                    {
                        <span class="chip-link">@profile.VerificationStatus</span>
                    }
                </div>
                <p>@T["{0} active events", profile.ActiveEventCount] · @T["{0} historical events", profile.HistoricalEventCount]</p>
            </article>
        }
    }
</section>
