@model DarwinLingua.Web.Models.OrganizerProfileClaimPageViewModel
@{
    ViewData["Title"] = T["Claim {0}", Model.Profile.DisplayName];
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Profile.OrganizerType · @Model.Profile.VerificationStatus</span>
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Detail" asp-route-targetLearningLanguageCode="@Model.Profile.TargetLearningLanguageCode" asp-route-slug="@Model.Profile.Slug">@T["Organizer page"]</a>
        </div>
    </div>
    <h1 class="headline-md">@T["Claim {0}", Model.Profile.DisplayName]</h1>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Request review"]</h2>
    <p class="body-lg">@T["Tell us how you are connected to this organizer so the listing can be assigned safely."]</p>
    <form method="post" class="form-grid">
        @Html.AntiForgeryToken()
        <label class="field">
            <span>@T["Name"]</span>
            <input name="RequesterName" value="@Model.Input.RequesterName" />
        </label>
        <label class="field">
            <span>@T["Email"]</span>
            <input name="RequesterEmail" value="@Model.Input.RequesterEmail" type="email" />
        </label>
        <label class="field">
            <span>@T["Relationship"]</span>
            <input name="RelationshipToOrganizer" value="@Model.Input.RelationshipToOrganizer" placeholder="@T["Owner, staff, teacher, volunteer"]" />
        </label>
        <label class="field field--wide">
            <span>@T["Evidence"]</span>
            <textarea name="EvidenceText" rows="6">@Model.Input.EvidenceText</textarea>
        </label>
        <div class="action-row">
            <button type="submit" class="button button--primary">@T["Submit claim"]</button>
        </div>
    </form>
</section>
