@model DarwinLingua.Web.Models.OrganizerProfileDetailPageViewModel
@{
    ViewData["Title"] = Model.Profile.DisplayName;
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Profile.OrganizerType · @(Model.Profile.IsOnlineAvailable ? T["Online available"] : Model.Profile.CityRegion)</span>
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Index" asp-route-targetLearningLanguageCode="@Model.Profile.TargetLearningLanguageCode">@T["All organizers"]</a>
        </div>
    </div>
    <h1 class="headline-md">@Model.Profile.DisplayName</h1>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }
    <p class="body-lg">@Model.Profile.Description</p>
    <dl class="detail-list">
        <div>
            <dt>@T["Status"]</dt>
            <dd>@Model.Profile.VerificationStatus</dd>
        </div>
        <div>
            <dt>@T["Plan"]</dt>
            <dd>@Model.Profile.PlanKey</dd>
        </div>
        <div>
            <dt>@T["Events"]</dt>
            <dd>@T["{0} active", Model.Profile.ActiveEvents.Count] · @T["{0} historical", Model.Profile.HistoricalEventCount]</dd>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Profile.PublicContactMethod))
        {
            <div>
                <dt>@T["Contact"]</dt>
                <dd>@Model.Profile.PublicContactMethod</dd>
            </div>
        }
    </dl>
    <div class="chip-grid">
        @foreach (string level in Model.Profile.SupportedLearnerLevels)
        {
            <span class="chip-link">@level</span>
        }
        @foreach (string languageCode in Model.Profile.HelperLanguageCodes)
        {
            <span class="chip-link">@languageCode</span>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Profile.WebsiteUrl))
    {
        <div class="detail-toolbar__actions">
            <a class="button button--primary button--compact" href="@Model.Profile.WebsiteUrl" rel="noopener noreferrer" target="_blank">@T["Website"]</a>
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Claim" asp-route-targetLearningLanguageCode="@Model.Profile.TargetLearningLanguageCode" asp-route-slug="@Model.Profile.Slug">@T["Claim profile"]</a>
        </div>
    }
    else
    {
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Claim" asp-route-targetLearningLanguageCode="@Model.Profile.TargetLearningLanguageCode" asp-route-slug="@Model.Profile.Slug">@T["Claim profile"]</a>
        </div>
    }
    <form method="post" asp-controller="Moderation" asp-action="Report" class="panel report-panel stack-sm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TargetType" value="organizer-profile" />
        <input type="hidden" name="TargetKey" value="@Model.Profile.Slug" />
        <input type="hidden" name="ReturnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
        <label class="form-field">
            <span>@T["Report this organizer"]</span>
            <select name="Reason">
                <option value="inaccurate-listing">@T["Inaccurate listing"]</option>
                <option value="impersonation">@T["Impersonation"]</option>
                <option value="spam">@T["Spam"]</option>
                <option value="unsafe-contact">@T["Unsafe contact"]</option>
                <option value="other">@T["Other"]</option>
            </select>
        </label>
        <label class="form-field">
            <span>@T["Report details"]</span>
            <textarea name="Details" rows="2" maxlength="2000"></textarea>
        </label>
        <button type="submit" class="button button--secondary button--compact">@T["Send report"]</button>
    </form>
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Active events"]</h2>
    @if (Model.Profile.ActiveEvents.Count == 0)
    {
        <p>@T["This organizer does not have any active events right now."]</p>
    }
    else
    {
        <div class="grid-two-col">
            @foreach (var item in Model.Profile.ActiveEvents)
            {
                <article class="panel stack-md">
                    <span class="eyebrow">@item.Category · @(item.IsOnline ? T["Online"] : item.City ?? item.CountryRegion)</span>
                    <h3 class="headline-sm">
                        <a asp-controller="ConversationEvents" asp-action="Detail" asp-route-targetLearningLanguageCode="@item.TargetLearningLanguageCode" asp-route-slug="@item.Slug">@item.Name</a>
                    </h3>
                    <p>@item.Description</p>
                    <p>@item.ScheduleText</p>
                </article>
            }
        </div>
    }
</section>
