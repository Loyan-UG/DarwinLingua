@model DarwinLingua.Web.Models.OrganizerProfileDetailPageViewModel
@{
    ViewData["Title"] = Model.Profile.DisplayName;
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Profile.OrganizerType · @(Model.Profile.IsOnlineAvailable ? "Online available" : Model.Profile.CityRegion)</span>
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Index">All organizers</a>
        </div>
    </div>
    <h1 class="headline-md">@Model.Profile.DisplayName</h1>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }
    <p class="body-lg">@Model.Profile.Description</p>
    <dl class="detail-list">
        <div>
            <dt>Status</dt>
            <dd>@Model.Profile.VerificationStatus</dd>
        </div>
        <div>
            <dt>Plan</dt>
            <dd>@Model.Profile.PlanKey</dd>
        </div>
        <div>
            <dt>Events</dt>
            <dd>@Model.Profile.ActiveEvents.Count active · @Model.Profile.HistoricalEventCount historical</dd>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Profile.PublicContactMethod))
        {
            <div>
                <dt>Contact</dt>
                <dd>@Model.Profile.PublicContactMethod</dd>
            </div>
        }
    </dl>
    <div class="chip-grid">
        @foreach (string level in Model.Profile.SupportedLearnerLevels)
        {
            <span class="chip-link">@level</span>
        }
        @foreach (string languageCode in Model.Profile.HelperLanguageCodes)
        {
            <span class="chip-link">@languageCode</span>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Profile.WebsiteUrl))
    {
        <div class="detail-toolbar__actions">
            <a class="button button--primary button--compact" href="@Model.Profile.WebsiteUrl" rel="noopener noreferrer" target="_blank">Website</a>
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Claim" asp-route-slug="@Model.Profile.Slug">Claim profile</a>
        </div>
    }
    else
    {
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Claim" asp-route-slug="@Model.Profile.Slug">Claim profile</a>
        </div>
    }
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">Active events</h2>
    @if (Model.Profile.ActiveEvents.Count == 0)
    {
        <p>No active events are linked to this organizer yet.</p>
    }
    else
    {
        <div class="grid-two-col">
            @foreach (var item in Model.Profile.ActiveEvents)
            {
                <article class="panel stack-md">
                    <span class="eyebrow">@item.Category · @(item.IsOnline ? "Online" : item.City ?? item.CountryRegion)</span>
                    <h3 class="headline-sm">
                        <a asp-controller="ConversationEvents" asp-action="Detail" asp-route-slug="@item.Slug">@item.Name</a>
                    </h3>
                    <p>@item.Description</p>
                    <p>@item.ScheduleText</p>
                </article>
            }
        </div>
    }
</section>
