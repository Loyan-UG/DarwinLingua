@using DarwinLingua.SharedKernel.Lexicon
@model DarwinLingua.Web.Models.RoleplayDetailPageViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DarwinLingua.Web.Localization.SharedResource> T

@{
    ViewData["Title"] = Model.Roleplay.Title;
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Roleplay.CefrLevel · @T[Model.Roleplay.Category] · @T[Model.Roleplay.TaskType]</span>
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="Roleplays" asp-action="Index">@T["All Roleplays"]</a>
        </div>
    </div>
    <h1 class="headline-md">@Model.Roleplay.Title</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Roleplay.LearnerLanguageTitle))
    {
        <p class="scenario-translation-line" dir="@primaryMeaningDirection">@Model.Roleplay.LearnerLanguageTitle</p>
    }
    <p class="body-lg">@Model.Roleplay.Description</p>
    @if (!string.IsNullOrWhiteSpace(Model.Roleplay.LearnerLanguageDescription))
    {
        <p class="scenario-translation-line" dir="@primaryMeaningDirection">@Model.Roleplay.LearnerLanguageDescription</p>
    }
    <div class="chip-grid">
        <span class="chip-link chip-link--static">@T[Model.Roleplay.InteractionMode]</span>
        <span class="chip-link chip-link--static">@T[Model.Roleplay.Register]</span>
        <span class="chip-link chip-link--static">@Model.Roleplay.EstimatedPracticeMinutes @T["minutes"]</span>
        @foreach (string topicKey in Model.Roleplay.TopicKeys)
        {
            <span class="chip-link chip-link--static">@topicKey</span>
        }
        @foreach (string examProfile in Model.Roleplay.ExamProfiles)
        {
            <span class="chip-link chip-link--static">@examProfile</span>
        }
    </div>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Goal"]</h2>
        <p>@Model.Roleplay.LearnerGoal</p>
        @if (!string.IsNullOrWhiteSpace(Model.Roleplay.LearnerLanguageGoal))
        {
            <p class="scenario-translation-line" dir="@primaryMeaningDirection">@Model.Roleplay.LearnerLanguageGoal</p>
        }
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Roles"]</h2>
        <div class="chip-grid">
            @foreach (var role in Model.Roleplay.Roles)
            {
                <span class="chip-link chip-link--static">
                    @role.DisplayName
                    @if (!string.IsNullOrWhiteSpace(role.LearnerLanguageDisplayName))
                    {
                        <span dir="@primaryMeaningDirection">&nbsp;· @role.LearnerLanguageDisplayName</span>
                    }
                </span>
            }
        </div>
    </article>
</section>

@if (Model.Roleplay.ImageSlots.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Scene"]</h2>
        <div class="grid-two-col">
            @foreach (var imageSlot in Model.Roleplay.ImageSlots)
            {
                <article class="grammar-image-slot">
                    @if (!string.IsNullOrWhiteSpace(imageSlot.AssetPath))
                    {
                        <img src="@imageSlot.AssetPath" alt="@(imageSlot.LearnerLanguageAltText ?? imageSlot.AltText)" />
                    }
                    else
                    {
                        <strong>@imageSlot.AltText</strong>
                        @if (!string.IsNullOrWhiteSpace(imageSlot.LearnerLanguageAltText))
                        {
                            <p dir="@primaryMeaningDirection">@imageSlot.LearnerLanguageAltText</p>
                        }
                    }
                </article>
            }
        </div>
    </section>
}

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Script"]</h2>
    <div class="stack-md">
        @foreach (var turn in Model.Roleplay.Turns.OrderBy(turn => turn.SortOrder))
        {
            bool isLearnerTurn = string.Equals(turn.SpeakerRole, "learner", StringComparison.OrdinalIgnoreCase);
            var choices = Model.Roleplay.AnswerChoices.FirstOrDefault(group => group.TurnSortOrder == turn.SortOrder);
            var weakerChoices = choices?.Choices.Where(choice => !choice.IsCorrect).ToArray() ?? [];
            var feedbackItems = Model.Roleplay.StaticFeedback.Where(feedback => feedback.TurnSortOrder == turn.SortOrder).ToArray();

            <article class="scenario-dialogue-turn @(isLearnerTurn ? "scenario-dialogue-turn--secondary" : "scenario-dialogue-turn--primary")">
                <div class="detail-example">
                    <span class="status-pill">@T[turn.SpeakerRole]</span>
                    <div class="stack-sm">
                        <strong class="scenario-german-text">@turn.BaseText</strong>
                        @if (!string.IsNullOrWhiteSpace(turn.LearnerLanguageText))
                        {
                            <div class="scenario-translation-line" dir="@primaryMeaningDirection">
                                <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                                <span>@turn.LearnerLanguageText</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(turn.ToneNote))
                        {
                            <p>@turn.ToneNote</p>
                        }
                    </div>
                </div>

                @if (weakerChoices.Length > 0)
                {
                    <div class="stack-sm">
                        <span class="eyebrow">@T["Not recommended answer"]</span>
                        @foreach (var choice in weakerChoices)
                        {
                            <div class="choice-row">
                                <div class="stack-sm">
                                    <strong>@choice.Text</strong>
                                    @if (!string.IsNullOrWhiteSpace(choice.LearnerLanguageText))
                                    {
                                        <p dir="@primaryMeaningDirection">@choice.LearnerLanguageText</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(choice.Feedback))
                                    {
                                        <p>@choice.Feedback</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(choice.LearnerLanguageFeedback))
                                    {
                                        <p dir="@primaryMeaningDirection">@choice.LearnerLanguageFeedback</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                @foreach (var feedback in feedbackItems)
                {
                    <div class="status-banner">
                        <strong>@T[feedback.FeedbackType]</strong>
                        <p>@feedback.Text</p>
                        @if (!string.IsNullOrWhiteSpace(feedback.LearnerLanguageText))
                        {
                            <p dir="@primaryMeaningDirection">@feedback.LearnerLanguageText</p>
                        }
                    </div>
                }
            </article>
        }
    </div>
</section>
