@model DarwinLingua.Web.Models.RoleplayIndexPageViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DarwinLingua.Web.Localization.SharedResource> T

@{
    ViewData["Title"] = T["Roleplays"];
}

<section class="page-section">
    <div class="page-section__header">
        <div>
            <p class="eyebrow">@T["Learning Portal"]</p>
            <h1>@T["Roleplays"]</h1>
            <p>@T["Practice scripted situations with deterministic answer choices and static feedback."]</p>
        </div>
    </div>

    <form method="get" class="filter-bar">
        <label>
            <span>@T["CEFR"]</span>
            <select name="cefrLevel">
                <option value="">@T["All"]</option>
                @foreach (string level in new[] { "A1", "A2", "B1", "B2", "C1", "C2" })
                {
                    <option value="@level" selected="@(string.Equals(Model.Filter.CefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
                }
            </select>
        </label>
        <label>
            <span>@T["Category"]</span>
            <input name="category" value="@Model.Filter.Category" />
        </label>
        <label>
            <span>@T["Exam profile"]</span>
            <input name="examProfile" value="@Model.Filter.ExamProfile" />
        </label>
        <label>
            <span>@T["Task type"]</span>
            <input name="taskType" value="@Model.Filter.TaskType" />
        </label>
        <label>
            <span>@T["Search"]</span>
            <input name="q" value="@Model.Filter.Query" />
        </label>
        <button type="submit" class="button button--primary">@T["Apply filters"]</button>
    </form>

    @if (Model.Roleplays.Count == 0)
    {
        <p class="muted">@T["No roleplays match these filters yet."]</p>
    }
    else
    {
        <div class="card-grid">
            @foreach (var roleplay in Model.Roleplays)
            {
                <article class="content-card">
                    <div class="content-card__meta">
                        <span>@roleplay.CefrLevel</span>
                        <span>@roleplay.Category</span>
                        <span>@roleplay.TaskType</span>
                    </div>
                    <h2><a asp-controller="Roleplays" asp-action="Detail" asp-route-slug="@roleplay.Slug">@roleplay.Title</a></h2>
                    <p>@roleplay.Description</p>
                    <p class="muted">@roleplay.LearnerGoal</p>
                </article>
            }
        </div>
    }
</section>
