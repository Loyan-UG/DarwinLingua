@model DarwinLingua.Web.Models.ScenarioIndexPageViewModel
@{
    ViewData["Title"] = T["Scenarios"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Scenarios"]</span>
    <h1 class="headline-md">@T["Practical German situations"]</h1>
    <p class="body-lg">@T["Practice dialogue, useful phrases, and quick checks for real-life tasks."]</p>
    @if (Model.TopicKeys.Count > 0)
    {
        <div class="chip-grid">
            <a class="chip-link @(string.IsNullOrWhiteSpace(Model.SelectedTopicKey) ? "is-active" : string.Empty)"
               asp-controller="Scenarios"
               asp-action="Index"
               asp-route-q="@Model.Query">@T["All topics"]</a>
            @foreach (string topicKey in Model.TopicKeys)
            {
                <a class="chip-link @(string.Equals(Model.SelectedTopicKey, topicKey, StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty)"
                   asp-controller="Scenarios"
                   asp-action="Index"
                   asp-route-topic="@topicKey"
                   asp-route-q="@Model.Query">@topicKey</a>
            }
        </div>
    }
    <form class="search-form" method="get" asp-controller="Scenarios" asp-action="Index">
        @if (!string.IsNullOrWhiteSpace(Model.SelectedTopicKey))
        {
            <input type="hidden" name="topic" value="@Model.SelectedTopicKey" />
        }
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search scenarios"]" />
        <button type="submit" class="button button--secondary">@T["Search"]</button>
    </form>
</section>

@if (Model.Scenarios.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Scenarios are being prepared"].Value, T["Guided practice situations will appear here when they are ready for study."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var scenario in Model.Scenarios)
        {
            <article class="panel stack-md">
                <div class="action-row collection-card__meta">
                    <span class="eyebrow">@scenario.CefrLevel · @scenario.Category</span>
                    <span>@T["{0} topics", scenario.TopicKeys.Count]</span>
                </div>
                <h2 class="headline-sm">
                    <a asp-controller="Scenarios" asp-action="Detail" asp-route-slug="@scenario.Slug">@scenario.Title</a>
                </h2>
                <p>@scenario.Description</p>
                <p class="body-lg">@scenario.LearnerGoal</p>
                @if (scenario.TopicKeys.Count > 0)
                {
                    <div class="chip-grid">
                        @foreach (string topicKey in scenario.TopicKeys)
                        {
                            <a class="chip-link" asp-controller="Scenarios" asp-action="Index" asp-route-topic="@topicKey">@topicKey</a>
                        }
                    </div>
                }
                <div class="action-row">
                    <a class="button button--secondary" asp-controller="Scenarios" asp-action="Detail" asp-route-slug="@scenario.Slug">@T["Open scenario"]</a>
                </div>
            </article>
        }
    </section>
}
