@model DarwinLingua.Web.Models.ScenarioDetailPageViewModel
@{
    ViewData["Title"] = Model.Scenario.Title;
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Scenario.CefrLevel · @Model.Scenario.Category</span>
        <div class="detail-toolbar__actions">
            <a class="button button--primary button--compact" asp-controller="Scenarios" asp-action="Roleplay" asp-route-slug="@Model.Scenario.Slug">Start roleplay</a>
            <a class="button button--secondary button--compact" asp-controller="Scenarios" asp-action="Index">All scenarios</a>
        </div>
    </div>
    <h1 class="headline-md">@Model.Scenario.Title</h1>
    <p class="body-lg">@Model.Scenario.Description</p>
    <p class="body-lg">@Model.Scenario.LearnerGoal</p>
    @if (Model.Scenario.TopicKeys.Count > 0)
    {
        <div class="chip-grid">
            @foreach (string topicKey in Model.Scenario.TopicKeys)
            {
                <a class="chip-link" asp-controller="Browse" asp-action="Topic" asp-route-id="@topicKey">@topicKey</a>
            }
        </div>
    }
</section>

@if (Model.RelatedStarterPacks.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Conversation starters</h2>
        <div class="grid-two-col">
            @foreach (var starterPack in Model.RelatedStarterPacks)
            {
                <article class="panel stack-md">
                    <span class="eyebrow">@starterPack.CefrLevel · @starterPack.Situation · @starterPack.Tone</span>
                    <h3 class="headline-sm">
                        <a asp-controller="ConversationStarters" asp-action="Detail" asp-route-slug="@starterPack.Slug">@starterPack.Title</a>
                    </h3>
                    <p>@starterPack.Description</p>
                    <a class="button button--secondary button--compact" asp-controller="ConversationStarters" asp-action="Detail" asp-route-slug="@starterPack.Slug">Open starters</a>
                </article>
            }
        </div>
    </section>
}

@if (Model.RelatedEventPreparationPacks.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Preparation packs</h2>
        <div class="grid-two-col">
            @foreach (var preparationPack in Model.RelatedEventPreparationPacks)
            {
                <article class="panel stack-md">
                    <span class="eyebrow">@preparationPack.CefrLevel · @preparationPack.EventType · @preparationPack.Category</span>
                    <h3 class="headline-sm">
                        <a asp-controller="EventPreparationPacks" asp-action="Detail" asp-route-slug="@preparationPack.Slug">@preparationPack.Title</a>
                    </h3>
                    <p>@preparationPack.Description</p>
                    <a class="button button--secondary button--compact" asp-controller="EventPreparationPacks" asp-action="Detail" asp-route-slug="@preparationPack.Slug">Prepare for this event</a>
                    @if (preparationPack.LinkedConversationStarterPackSlugs.Count > 0)
                    {
                        <div class="chip-grid">
                            @foreach (string starterPackSlug in preparationPack.LinkedConversationStarterPackSlugs)
                            {
                                <a class="chip-link" asp-controller="ConversationStarters" asp-action="Detail" asp-route-slug="@starterPackSlug">@starterPackSlug</a>
                            }
                        </div>
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.Scenario.DialogueTurns.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Dialogue</h2>
        <div class="stack-md">
            @foreach (var turn in Model.Scenario.DialogueTurns)
            {
                <article class="detail-row">
                    <strong>@turn.SpeakerRole</strong>
                    <div class="stack-md">
                        <div class="detail-example">
                            <span>@turn.BaseText</span>
                            <button type="button" class="button button--secondary button--compact" data-speak-text="@turn.BaseText" data-speak-lang="de-DE">Hear</button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(turn.PrimaryMeaning))
                        {
                            <div class="meaning-block meaning-block--primary">
                                <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                                <div>@turn.PrimaryMeaning</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(turn.SecondaryMeaning))
                        {
                            <div class="meaning-block">
                                <span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span>
                                <div>@turn.SecondaryMeaning</div>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>
    </section>
}

@if (Model.Scenario.UsefulPhrases.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Useful phrases</h2>
        <div class="grid-two-col">
            @foreach (var phrase in Model.Scenario.UsefulPhrases)
            {
                <article class="panel stack-md">
                    <div class="detail-example">
                        <strong>@phrase.BaseText</strong>
                        <button type="button" class="button button--secondary button--compact" data-speak-text="@phrase.BaseText" data-speak-lang="de-DE">Hear</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(phrase.PrimaryMeaning))
                    {
                        <div class="meaning-block meaning-block--primary">
                            <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                            <div>@phrase.PrimaryMeaning</div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(phrase.SecondaryMeaning))
                    {
                        <div class="meaning-block">
                            <span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span>
                            <div>@phrase.SecondaryMeaning</div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(phrase.UsageNote))
                    {
                        <p>@phrase.UsageNote</p>
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.Scenario.Questions.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Quick check</h2>
        <div class="stack-md">
            @foreach (var question in Model.Scenario.Questions)
            {
                <article class="panel stack-md">
                    <strong>@question.Prompt</strong>
                    @if (!string.IsNullOrWhiteSpace(question.PrimaryMeaning))
                    {
                        <div class="meaning-block meaning-block--primary">
                            <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                            <div>@question.PrimaryMeaning</div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(question.SecondaryMeaning))
                    {
                        <div class="meaning-block">
                            <span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span>
                            <div>@question.SecondaryMeaning</div>
                        </div>
                    }
                    <ul class="feature-list">
                        @foreach (var answer in question.Answers)
                        {
                            <li>
                                <strong>@answer.Text@(answer.IsCorrect ? " · correct" : string.Empty)</strong>
                                @if (!string.IsNullOrWhiteSpace(answer.PrimaryMeaning))
                                {
                                    <div>@answer.PrimaryMeaning</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(answer.SecondaryMeaning))
                                {
                                    <div>@answer.SecondaryMeaning</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(answer.Feedback))
                                {
                                    <div>@answer.Feedback</div>
                                }
                            </li>
                        }
                    </ul>
                </article>
            }
        </div>
    </section>
}
