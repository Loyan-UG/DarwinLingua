@model DarwinLingua.Web.Models.ScenarioDetailPageViewModel
@{
    ViewData["Title"] = Model.Scenario.Title;
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
    string secondaryMeaningDirection = string.IsNullOrWhiteSpace(Model.SecondaryMeaningLanguageCode)
        ? "ltr"
        : TextDirection.FromLanguageCode(Model.SecondaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Scenario.CefrLevel · @Model.Scenario.Category</span>
        <div class="detail-toolbar__actions">
            <a class="button button--primary button--compact" asp-controller="Scenarios" asp-action="Roleplay" asp-route-slug="@Model.Scenario.Slug">@T["Start roleplay"]</a>
            <a class="button button--secondary button--compact" asp-controller="Scenarios" asp-action="Index">@T["All scenarios"]</a>
        </div>
    </div>
    <h1 class="headline-md">@Model.Scenario.Title</h1>
    <p class="body-lg">@Model.Scenario.Description</p>
    <p class="body-lg">@Model.Scenario.LearnerGoal</p>
    @if (Model.Scenario.TopicKeys.Count > 0)
    {
        <div class="chip-grid">
            @foreach (string topicKey in Model.Scenario.TopicKeys)
            {
                <a class="chip-link" asp-controller="Scenarios" asp-action="Index" asp-route-topic="@topicKey">@topicKey</a>
            }
        </div>
    }
</section>

@if (Model.RelatedStarterPacks.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Conversation starters"]</h2>
        <div class="grid-two-col">
            @foreach (var starterPack in Model.RelatedStarterPacks)
            {
                <article class="panel stack-md">
                    <span class="eyebrow">@starterPack.CefrLevel · @starterPack.Situation · @starterPack.Tone</span>
                    <h3 class="headline-sm">
                        <a asp-controller="ConversationStarters" asp-action="Detail" asp-route-slug="@starterPack.Slug">@starterPack.Title</a>
                    </h3>
                    <p>@starterPack.Description</p>
                    <a class="button button--secondary button--compact" asp-controller="ConversationStarters" asp-action="Detail" asp-route-slug="@starterPack.Slug">@T["Open starters"]</a>
                </article>
            }
        </div>
    </section>
}

@if (Model.RelatedEventPreparationPacks.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Preparation packs"]</h2>
        <div class="grid-two-col">
            @foreach (var preparationPack in Model.RelatedEventPreparationPacks)
            {
                <article class="panel stack-md">
                    <span class="eyebrow">@preparationPack.CefrLevel · @preparationPack.EventType · @preparationPack.Category</span>
                    <h3 class="headline-sm">
                        <a asp-controller="EventPreparationPacks" asp-action="Detail" asp-route-slug="@preparationPack.Slug">@preparationPack.Title</a>
                    </h3>
                    <p>@preparationPack.Description</p>
                    <a class="button button--secondary button--compact" asp-controller="EventPreparationPacks" asp-action="Detail" asp-route-slug="@preparationPack.Slug">@T["Prepare for this event"]</a>
                    @if (preparationPack.LinkedConversationStarterPackSlugs.Count > 0)
                    {
                        <div class="chip-grid">
                            @foreach (string starterPackSlug in preparationPack.LinkedConversationStarterPackSlugs)
                            {
                                <a class="chip-link" asp-controller="ConversationStarters" asp-action="Detail" asp-route-slug="@starterPackSlug">@starterPackSlug</a>
                            }
                        </div>
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.Scenario.DialogueTurns.Count > 0)
{
    string firstSpeakerRole = Model.Scenario.DialogueTurns[0].SpeakerRole;
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Dialogue"]</h2>
        <div class="stack-md">
            @foreach (var turn in Model.Scenario.DialogueTurns)
            {
                string turnAlignmentClass = string.Equals(turn.SpeakerRole, firstSpeakerRole, StringComparison.OrdinalIgnoreCase)
                    ? "scenario-dialogue-turn--primary"
                    : "scenario-dialogue-turn--secondary";
                <article class="detail-row scenario-dialogue-turn @turnAlignmentClass">
                    <strong>@turn.SpeakerRole</strong>
                    <div class="stack-md">
                        <div class="detail-example">
                            <button type="button" class="icon-button icon-button--sm" data-speak-text="@turn.BaseText" data-speak-lang="de-DE" aria-label="@T["Hear sentence"]" title="@T["Hear sentence"]">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M4 9.2v5.6h3.4L12.5 19V5L7.4 9.2H4Z" />
                                    <path d="M16 8.2a5.4 5.4 0 0 1 0 7.6" />
                                    <path d="M18.8 5.4a9.3 9.3 0 0 1 0 13.2" />
                                </svg>
                                <span class="sr-only">@T["Hear sentence"]</span>
                            </button>
                            <strong class="scenario-german-text">@turn.BaseText</strong>
                        </div>
                        <div class="scenario-translation-list">
                            @if (!string.IsNullOrWhiteSpace(turn.PrimaryMeaning))
                            {
                                <div class="scenario-translation-line" dir="@primaryMeaningDirection">
                                    <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                                    <span>@turn.PrimaryMeaning</span>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(turn.SecondaryMeaning))
                            {
                                <div class="scenario-translation-line" dir="@secondaryMeaningDirection">
                                    <span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span>
                                    <span>@turn.SecondaryMeaning</span>
                                </div>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>
}

@if (Model.Scenario.UsefulPhrases.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Useful phrases"]</h2>
        <div class="grid-two-col">
            @foreach (var phrase in Model.Scenario.UsefulPhrases)
            {
                <article class="panel stack-md">
                    <div class="detail-example">
                        <button type="button" class="icon-button icon-button--sm" data-speak-text="@phrase.BaseText" data-speak-lang="de-DE" aria-label="@T["Hear phrase"]" title="@T["Hear phrase"]">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M4 9.2v5.6h3.4L12.5 19V5L7.4 9.2H4Z" />
                                <path d="M16 8.2a5.4 5.4 0 0 1 0 7.6" />
                                <path d="M18.8 5.4a9.3 9.3 0 0 1 0 13.2" />
                            </svg>
                            <span class="sr-only">@T["Hear phrase"]</span>
                        </button>
                        <strong class="scenario-german-text">@phrase.BaseText</strong>
                    </div>
                    <div class="scenario-translation-list">
                        @if (!string.IsNullOrWhiteSpace(phrase.PrimaryMeaning))
                        {
                            <div class="scenario-translation-line" dir="@primaryMeaningDirection">
                                <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                                <span>@phrase.PrimaryMeaning</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(phrase.SecondaryMeaning))
                        {
                            <div class="scenario-translation-line" dir="@secondaryMeaningDirection">
                                <span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span>
                                <span>@phrase.SecondaryMeaning</span>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(phrase.UsageNote))
                    {
                        <p>@phrase.UsageNote</p>
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.Scenario.Questions.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Quick check"]</h2>
        <div class="stack-md">
            @foreach (var question in Model.Scenario.Questions)
            {
                <article class="panel stack-md">
                    <strong class="scenario-german-text">@question.Prompt</strong>
                    <div class="scenario-translation-list">
                        @if (!string.IsNullOrWhiteSpace(question.PrimaryMeaning))
                        {
                            <div class="scenario-translation-line" dir="@primaryMeaningDirection">
                                <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                                <span>@question.PrimaryMeaning</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(question.SecondaryMeaning))
                        {
                            <div class="scenario-translation-line" dir="@secondaryMeaningDirection">
                                <span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span>
                                <span>@question.SecondaryMeaning</span>
                            </div>
                        }
                    </div>
                    <ul class="feature-list">
                        @foreach (var answer in question.Answers)
                        {
                            <li>
                                <strong class="scenario-german-text">@answer.Text@(answer.IsCorrect ? $" · {T["correct"]}" : string.Empty)</strong>
                                <div class="scenario-translation-list">
                                    @if (!string.IsNullOrWhiteSpace(answer.PrimaryMeaning))
                                    {
                                        <div class="scenario-translation-line" dir="@primaryMeaningDirection">
                                            <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                                            <span>@answer.PrimaryMeaning</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(answer.SecondaryMeaning))
                                    {
                                        <div class="scenario-translation-line" dir="@secondaryMeaningDirection">
                                            <span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span>
                                            <span>@answer.SecondaryMeaning</span>
                                        </div>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(answer.Feedback))
                                {
                                    <div>@answer.Feedback</div>
                                }
                            </li>
                        }
                    </ul>
                </article>
            }
        </div>
    </section>
}
