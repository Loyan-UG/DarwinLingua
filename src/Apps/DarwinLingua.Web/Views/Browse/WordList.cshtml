@model DarwinLingua.Web.Models.WordBrowsePageViewModel
@{
    ViewData["Title"] = Model.Title;
    string browseAction = Model.TopicKey is not null ? "Topic" : "Cefr";
    string? browseRouteId = Model.TopicKey ?? Model.CefrLevel;
    int currentPage = (Model.Skip / Model.Take) + 1;
    int lastKnownPage = currentPage + (Model.HasMore ? 1 : 0);
    int firstPageInWindow = Math.Max(1, currentPage - 2);
    int lastPageInWindow = Math.Max(lastKnownPage, currentPage + 2);
    if (!Model.HasMore)
    {
        lastPageInWindow = currentPage;
    }
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Browse words"]</span>
    <h1 class="headline-md">@Model.Title</h1>
    <p class="body-lg">@Model.Description</p>
</section>

@if (Model.Words.Count == 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["No words found"]</h2>
        <p class="body-lg">@T["Try a broader level or topic to continue browsing."]</p>
    </section>
}
else
{
    <section class="grid-two-col" data-word-list-container>
        @foreach (var word in Model.Words)
        {
            <partial name="_WordCard" model="word" />
        }
    </section>

    <section class="panel pagination-panel">
        <div class="pagination">
            <div class="pagination__summary">
                @T["Page"] @currentPage
            </div>
            <nav class="pagination__links" aria-label="@T["Word list pages"]">
                @if (currentPage > 1)
                {
                    <a class="button button--secondary button--compact"
                       asp-action="@browseAction"
                       asp-route-id="@browseRouteId"
                       asp-route-skip="0">
                        @T["First"]
                    </a>
                }
            @if (Model.Skip > 0)
            {
                <a class="button button--secondary"
                   asp-action="@browseAction"
                   asp-route-id="@browseRouteId"
                   asp-route-skip="@(Math.Max(0, Model.Skip - Model.Take))">
                    @T["Previous"]
                </a>
            }
                @if (firstPageInWindow > 1)
                {
                    <span class="pagination__ellipsis">...</span>
                }
                @for (int pageNumber = firstPageInWindow; pageNumber <= lastPageInWindow; pageNumber++)
                {
                    int pageSkip = (pageNumber - 1) * Model.Take;
                    if (pageNumber == currentPage)
                    {
                        <span class="pagination__page is-current" aria-current="page">@pageNumber</span>
                    }
                    else
                    {
                        <a class="pagination__page"
                           asp-action="@browseAction"
                           asp-route-id="@browseRouteId"
                           asp-route-skip="@pageSkip">
                            @pageNumber
                        </a>
                    }
                }
            @if (Model.HasMore)
            {
                <a class="button button--primary"
                   asp-action="@browseAction"
                   asp-route-id="@browseRouteId"
                   asp-route-skip="@(Model.Skip + Model.Take)">
                    @T["Next"]
                </a>
            }
            </nav>
        </div>
    </section>
}
