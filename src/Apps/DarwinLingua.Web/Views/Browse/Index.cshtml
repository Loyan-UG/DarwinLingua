@model DarwinLingua.Web.Models.BrowseIndexViewModel
@{
    ViewData["Title"] = "Browse";
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel("Browse", "Explore the catalog by topic or CEFR level.", $"Primary meaning language: {Model.MeaningLanguageCode}")' />
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">CEFR levels</h2>
        <div class="chip-grid">
            @foreach (string level in Model.CefrLevels)
            {
                <a class="chip-link"
                   asp-action="Cefr"
                   asp-route-id="@level"
                   hx-get="@Url.Action("Cefr", "Browse", new { id = level })"
                   hx-target="#browse-results"
                   hx-swap="innerHTML">@level</a>
            }
        </div>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">Topics</h2>
        @if (Model.Topics.Count == 0)
        {
            <p class="body-lg">No topics are available yet.</p>
        }
        else
        {
            <div class="chip-grid">
                @foreach (var topic in Model.Topics)
                {
                    <a class="chip-link"
                       asp-action="Topic"
                       asp-route-id="@topic.Key"
                       hx-get="@Url.Action("Topic", "Browse", new { id = topic.Key })"
                       hx-target="#browse-results"
                       hx-swap="innerHTML">@topic.DisplayName</a>
                }
            </div>
        }
    </article>
</section>

<div id="browse-results">
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel("Choose a filter", "Select a CEFR level or topic to load words inline.")' />
</div>
