@model DarwinLingua.Web.Models.BrowseIndexViewModel
@{
    ViewData["Title"] = T["Browse"];
    string targetLearningLanguageCode = LearningRouteConventions.ResolveTargetLearningLanguageCode(Context);
    string FormatCefrLevel(string level) => LearningPortalFilterConventions.FormatCefrLevelOption(level, targetLearningLanguageCode, key => T[key].Value);
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(T["Browse"].Value, T["Choose a level or topic"].Value, T["Start from the vocabulary set that matches today&apos;s goal, then open individual words for examples, pronunciation, and study actions."].Value)' />
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["CEFR levels"]</h2>
        <div class="chip-grid">
            @foreach (string level in Model.CefrLevels)
            {
                <a class="chip-link"
                   asp-action="Cefr"
                   asp-route-id="@level"
                   hx-get="@Url.Action("Cefr", "Browse", new { targetLearningLanguageCode, id = level })"
                   hx-target="#browse-results"
                   hx-swap="innerHTML">@FormatCefrLevel(level)</a>
            }
        </div>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Topics"]</h2>
        @if (Model.Topics.Count == 0)
        {
            <p class="body-lg">@T["Topics will appear here as curated vocabulary becomes available."]</p>
        }
        else
        {
            <div class="chip-grid">
                @foreach (var topic in Model.Topics)
                {
                    <a class="chip-link"
                       asp-action="Topic"
                       asp-route-id="@topic.Key"
                       hx-get="@Url.Action("Topic", "Browse", new { id = topic.Key })"
                       hx-target="#browse-results"
                       hx-swap="innerHTML">@topic.DisplayName</a>
                }
            </div>
        }
    </article>
</section>

<div id="browse-results">
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Choose a starting point"].Value, T["Select a CEFR level or topic to preview matching words here."].Value)' />
</div>
