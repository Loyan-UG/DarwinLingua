@model DarwinLingua.Web.Models.AccountPageViewModel
@{
    ViewData["Title"] = "Account";
}

<section class="panel stack-lg">
    <span class="eyebrow">Account</span>
    <h1 class="headline-md">Your workspace</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Email))
    {
        <p class="body-lg">@Model.Email</p>
    }
    <div class="chip-grid">
        @foreach (string role in Model.Roles)
        {
            <span class="chip-link chip-link--static">@role</span>
        }
    </div>
    <div class="action-row">
        <a class="button button--primary" asp-controller="Settings" asp-action="Index">Language preferences</a>
        <a class="button button--secondary" asp-controller="LearnerConversationProfiles" asp-action="Edit">Profile details</a>
        <a class="button button--secondary" asp-controller="PartnerMatching" asp-action="Index">Partners</a>
        <a class="button button--secondary" asp-controller="Billing" asp-action="Index">Billing</a>
        <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Manage/Email">Change email</a>
        <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">Change password</a>
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" class="inline-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="button button--secondary">Sign out</button>
        </form>
    </div>
</section>

<section class="grid-three-col">
    <article class="panel stack-md account-action-card">
        <span class="eyebrow">Step 1</span>
        <h2 class="headline-sm">Set languages</h2>
        <p class="body-sm">Choose the site language and the primary and secondary meaning languages used across word details, scenarios, and practice content.</p>
        <div class="meta-grid">
            <span class="meta-chip"><strong>@Model.Profile.UiLanguageCode</strong><span>UI</span></span>
            <span class="meta-chip"><strong>@Model.Profile.PreferredMeaningLanguage1</strong><span>Primary meanings</span></span>
            <span class="meta-chip"><strong>@(Model.Profile.PreferredMeaningLanguage2 ?? "None")</strong><span>Second meanings</span></span>
        </div>
        <a class="button button--primary" asp-controller="Settings" asp-action="Index">Edit languages</a>
    </article>
    <article class="panel stack-md account-action-card">
        <span class="eyebrow">Step 2</span>
        <h2 class="headline-sm">Complete profile</h2>
        <p class="body-sm">Set your display name, location, German level, helper languages, goals, availability, and visibility for conversation practice.</p>
        <a class="button button--secondary" asp-controller="LearnerConversationProfiles" asp-action="Edit">Edit profile</a>
    </article>
    <article class="panel stack-md account-action-card">
        <span class="eyebrow">Step 3</span>
        <h2 class="headline-sm">Manage plan</h2>
        <p class="body-sm">Review trial or premium access, start checkout, open Stripe subscription management, and check billing status.</p>
        <a class="button button--secondary" asp-controller="Billing" asp-action="Index">Open billing</a>
    </article>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">Language settings</h2>
        <ul class="feature-list">
            <li>UI language: @Model.Profile.UiLanguageCode</li>
            <li>Primary meaning language: @Model.Profile.PreferredMeaningLanguage1</li>
            <li>Secondary meaning language: @(Model.Profile.PreferredMeaningLanguage2 ?? "None")</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">Plan</h2>
        <ul class="feature-list">
            <li>Current tier: @Model.Entitlement.Tier</li>
            @if (Model.Entitlement.TrialEndsAtUtc is not null)
            {
                <li>Trial ends: @Model.Entitlement.TrialEndsAtUtc.Value.UtcDateTime.ToString("u")</li>
            }
            @if (Model.Entitlement.PremiumEndsAtUtc is not null)
            {
                <li>Premium ends: @Model.Entitlement.PremiumEndsAtUtc.Value.UtcDateTime.ToString("u")</li>
            }
        </ul>
        <div class="chip-grid">
            @foreach (var feature in Model.Entitlement.EnabledFeatures)
            {
                <span class="chip-link chip-link--static">@feature</span>
            }
        </div>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">Security</h2>
        <ul class="feature-list">
            <li>Use a strong password and keep your account email up to date.</li>
            <li>Administrative tools are only shown to accounts with the right permissions.</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">Plan history</h2>
        @if (Model.EntitlementAuditEvents.Count == 0)
        {
            <p class="body-sm">No plan events have been recorded yet.</p>
        }
        else
        {
            <ul class="feature-list">
                @foreach (var auditEvent in Model.EntitlementAuditEvents)
                {
                    <li>@auditEvent.CreatedAtUtc.UtcDateTime.ToString("u"): @auditEvent.EventType (@(auditEvent.PreviousTier ?? "none") -> @auditEvent.NewTier)</li>
                }
            </ul>
        }
    </article>
</section>
