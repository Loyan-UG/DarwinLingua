@model DarwinLingua.Web.Models.AccountPageViewModel
@{
    ViewData["Title"] = T["Account"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Account"]</span>
    <h1 class="headline-md">@T["Your workspace"]</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Email))
    {
        <p class="body-lg">@Model.Email</p>
    }
    <div class="chip-grid">
        @foreach (string role in Model.Roles)
        {
            <span class="chip-link chip-link--static">@role</span>
        }
    </div>
    <div class="action-row">
        <a class="button button--primary" asp-controller="Settings" asp-action="Index">@T["Language preferences"]</a>
        <a class="button button--secondary" asp-controller="LearnerConversationProfiles" asp-action="Edit">@T["Profile details"]</a>
        <a class="button button--secondary" asp-controller="PartnerMatching" asp-action="Index">@T["Partners"]</a>
        <a class="button button--secondary" asp-controller="Billing" asp-action="Index">@T["Billing"]</a>
        <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Manage/Email">@T["Change email"]</a>
        <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">@T["Change password"]</a>
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" class="inline-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="button button--secondary">@T["Sign out"]</button>
        </form>
    </div>
</section>

<section class="grid-three-col">
    <article class="panel stack-md account-action-card">
        <span class="eyebrow">@T["Step 1"]</span>
        <h2 class="headline-sm">@T["Set languages"]</h2>
        <p class="body-sm">@T["Choose the site language and the primary and secondary meaning languages used across word details, dialogues, and practice content."]</p>
        <div class="meta-grid">
            <span class="meta-chip"><strong>@Model.Profile.UiLanguageCode</strong><span>@T["UI"]</span></span>
            <span class="meta-chip"><strong>@Model.Profile.PreferredMeaningLanguage1</strong><span>@T["Primary meanings"]</span></span>
            <span class="meta-chip"><strong>@(Model.Profile.PreferredMeaningLanguage2 ?? T["None"].Value)</strong><span>@T["Second meanings"]</span></span>
        </div>
        <a class="button button--primary" asp-controller="Settings" asp-action="Index">@T["Edit languages"]</a>
    </article>
    <article class="panel stack-md account-action-card">
        <span class="eyebrow">@T["Step 2"]</span>
        <h2 class="headline-sm">@T["Complete profile"]</h2>
        <p class="body-sm">@T["Set your display name, location, German level, helper languages, goals, availability, and visibility for conversation practice."]</p>
        <a class="button button--secondary" asp-controller="LearnerConversationProfiles" asp-action="Edit">@T["Edit profile"]</a>
    </article>
    <article class="panel stack-md account-action-card">
        <span class="eyebrow">@T["Step 3"]</span>
        <h2 class="headline-sm">@T["Manage plan"]</h2>
        <p class="body-sm">@T["Review trial or premium access, start checkout, open Stripe subscription management, and check billing status."]</p>
        <a class="button button--secondary" asp-controller="Billing" asp-action="Index">@T["Open billing"]</a>
    </article>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Language settings"]</h2>
        <ul class="feature-list">
            <li>@T["UI language"]: @Model.Profile.UiLanguageCode</li>
            <li>@T["Primary meaning language"]: @Model.Profile.PreferredMeaningLanguage1</li>
            <li>@T["Secondary meaning language"]: @(Model.Profile.PreferredMeaningLanguage2 ?? T["None"].Value)</li>
            <li>@T["Rude/slang learning preference"]: @(Model.Profile.AllowsRudeSlangContent ? T["Enabled"].Value : T["Disabled"].Value)</li>
            <li>@T["Adult content access state"]: @Model.Profile.AdultContentAccessState</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Plan"]</h2>
        <ul class="feature-list">
            <li>@T["Current tier"]: @Model.Entitlement.Tier</li>
            @if (Model.Entitlement.TrialEndsAtUtc is not null)
            {
                <li>@T["Trial ends"]: @Model.Entitlement.TrialEndsAtUtc.Value.UtcDateTime.ToString("u")</li>
            }
            @if (Model.Entitlement.PremiumEndsAtUtc is not null)
            {
                <li>@T["Premium ends"]: @Model.Entitlement.PremiumEndsAtUtc.Value.UtcDateTime.ToString("u")</li>
            }
        </ul>
        <div class="chip-grid">
            @foreach (var feature in Model.Entitlement.EnabledFeatures)
            {
                <span class="chip-link chip-link--static">@feature</span>
            }
        </div>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Security"]</h2>
        <ul class="feature-list">
            <li>@T["Use a strong password and keep your account email up to date."]</li>
            <li>@T["Administrative tools are only shown to accounts with the right permissions."]</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Plan history"]</h2>
        @if (Model.EntitlementAuditEvents.Count == 0)
        {
            <p class="body-sm">@T["No plan events have been recorded yet."]</p>
        }
        else
        {
            <ul class="feature-list">
                @foreach (var auditEvent in Model.EntitlementAuditEvents)
                {
                    <li>@auditEvent.CreatedAtUtc.UtcDateTime.ToString("u"): @auditEvent.EventType (@(auditEvent.PreviousTier ?? T["None"].Value) -> @auditEvent.NewTier)</li>
                }
            </ul>
        }
    </article>
</section>

<section class="panel stack-lg">
    <span class="eyebrow">@T["Privacy"]</span>
    <h2 class="headline-sm">@T["Account data"]</h2>
    <p class="body-sm">@T["You can export your account and learning data, correct your profile details, or delete your account from this workspace. Export your data before deletion if you need a copy."]</p>
    <div class="grid-two-col">
        <article class="account-action-card stack-md">
            <h3 class="headline-xs">@T["Export data"]</h3>
            <p class="body-sm">@T["Download a machine-readable JSON file with account, preference, progress, practice, billing-summary, and operational email-log data connected to your user id."]</p>
            <a class="button button--primary" asp-controller="Account" asp-action="ExportData">@T["Download JSON export"]</a>
        </article>
        <article class="account-action-card stack-md">
            <h3 class="headline-xs">@T["Correct data"]</h3>
            <p class="body-sm">@T["Use the profile, language, email, and password settings above to correct account data directly. For data that is not editable here, contact support from the legal contact page."]</p>
            <div class="action-row">
                <a class="button button--secondary" asp-controller="Settings" asp-action="Index">@T["Language preferences"]</a>
                <a class="button button--secondary" asp-controller="LearnerConversationProfiles" asp-action="Edit">@T["Profile details"]</a>
                <a class="button button--secondary" asp-area="Identity" asp-page="/Account/Manage/Email">@T["Change email"]</a>
                <a class="button button--secondary" asp-controller="Home" asp-action="Contact">@T["Contact support"]</a>
            </div>
        </article>
    </div>
    <article class="panel panel--danger stack-md">
        <h3 class="headline-xs">@T["Delete account"]</h3>
        <p class="body-sm">@T["Deleting your account removes or anonymizes learning progress, preferences, conversation profile data, partner requests, and identity access. Some billing, email-delivery, policy-acceptance, security, and backup records may be retained where legal or operational duties require it."]</p>
        <form method="post" asp-controller="Account" asp-action="Delete" class="stack-md">
            @Html.AntiForgeryToken()
            <label class="form-field">
                <span>@T["Current password"]</span>
                <input type="password" name="currentPassword" autocomplete="current-password" />
            </label>
            <label class="form-field">
                <span>@T["Type DELETE to confirm"]</span>
                <input name="confirmationPhrase" autocomplete="off" inputmode="latin" maxlength="16" />
            </label>
            <p class="body-xs">@T["Confirmation phrase"]: <code>@Model.DeleteConfirmationPhrase</code></p>
            <button type="submit" class="button button--danger">@T["Delete my account"]</button>
        </form>
    </article>
</section>
