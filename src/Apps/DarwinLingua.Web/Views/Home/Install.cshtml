@{
    ViewData["Title"] = "Install";
}

<section class="panel stack-lg">
    <span class="eyebrow">Installable Web App</span>
    <h1 class="headline-md">Install Darwin Lingua on desktop or mobile.</h1>
    <p class="body-lg">
        The first web slice is a PWA-capable MVC application. It supports install prompts where the browser allows them,
        caches app shell assets, and keeps the learner experience fast without trying to clone the MAUI offline model in the browser.
    </p>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">What works now</h2>
        <ul class="feature-list">
            <li>Install prompt baseline for Chromium browsers</li>
            <li>PWA manifest and service worker registration</li>
            <li>Responsive learner shell</li>
            <li>Admin area kept separate from public learner pages</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">What comes next</h2>
        <ul class="feature-list">
            <li>Identity-based registration and sign-in</li>
            <li>Browse, search, and word-detail pages</li>
            <li>Favorites and recent activity persistence</li>
            <li>htmx-powered partial updates for fast interactions</li>
        </ul>
    </article>
</section>
