@{
    ViewData["Title"] = "Install";
}

<section class="panel stack-lg">
    <span class="eyebrow">Installable Web App</span>
    <h1 class="headline-md">Install Darwin Lingua on desktop or mobile.</h1>
    <p class="body-lg">
        Add Darwin Lingua to your device for a cleaner full-screen learning experience, quicker access from your home screen,
        and a familiar app-like workspace in supported browsers.
    </p>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">Why install it</h2>
        <ul class="feature-list">
            <li>Launch directly from your desktop or mobile home screen</li>
            <li>Use a focused full-screen learning window</li>
            <li>Keep vocabulary, collections, and practice tools one tap away</li>
            <li>Stay signed in on devices you trust</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">How to install</h2>
        <ul class="feature-list">
            <li>Open Darwin Lingua in a supported browser</li>
            <li>Use the browser install option when it appears</li>
            <li>Pin the app to your taskbar, dock, or home screen</li>
            <li>Return here if the install prompt is not visible</li>
        </ul>
    </article>
</section>
