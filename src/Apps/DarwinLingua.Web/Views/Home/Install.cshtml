@{
    ViewData["Title"] = T["Install"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Installable Web App"]</span>
    <h1 class="headline-md">@T["Install Darwin Lingua on desktop or mobile."]</h1>
    <p class="body-lg">
        @T["Add Darwin Lingua to your device for a cleaner full-screen learning experience, quicker access from your home screen, and a familiar app-like workspace in supported browsers."]
    </p>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Why install it"]</h2>
        <ul class="feature-list">
            <li>@T["Launch directly from your desktop or mobile home screen"]</li>
            <li>@T["Use a focused full-screen learning window"]</li>
            <li>@T["Keep vocabulary, collections, and practice tools one tap away"]</li>
            <li>@T["Stay signed in on devices you trust"]</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["How to install"]</h2>
        <ul class="feature-list">
            <li>@T["Open Darwin Lingua in a supported browser"]</li>
            <li>@T["Use the browser install option when it appears"]</li>
            <li>@T["Pin the app to your taskbar, dock, or home screen"]</li>
            <li>@T["Return here if the install prompt is not visible"]</li>
        </ul>
    </article>
</section>
