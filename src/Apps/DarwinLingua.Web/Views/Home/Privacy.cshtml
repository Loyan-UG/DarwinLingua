@{
    ViewData["Title"] = T["Privacy Policy"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Privacy"]</span>
    <h1 class="headline-md">@T["Privacy Policy"]</h1>
    <p class="body-lg">@T["Darwin Lingua uses account, learning, organizer, moderation, and operational data to run the language-learning service, protect users, and support account recovery."]</p>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Account and learning data"]</h2>
        <ul class="feature-list">
            <li>@T["Account email addresses are used for sign-in, email confirmation, password reset, security notifications, and support workflows."]</li>
            <li>@T["Learning preferences, favorites, recent activity, learner profiles, organizer claims, partner requests, RSVP records, and moderation reports are stored to provide requested product features."]</li>
            <li>@T["Policy acceptance records store the policy key, version, timestamp, source, and locale needed to prove account registration acknowledgements."]</li>
            <li>@T["The Sensitive Educational Language preference is stored only as a reversible learning preference. It does not store a full birth date, identity document, or age-verification claim."]</li>
            <li>@T["Admin and operator access is limited by role-based authorization and is used for support, moderation, publishing, diagnostics, and operational review."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Your data controls"]</h2>
        <ul class="feature-list">
            <li>@T["Signed-in users can download an account-data export from the Account page. The export includes account, learning, entitlement, support, and safe operational email-delivery summaries."]</li>
            <li>@T["Signed-in users can request correction by updating account settings and learner profile settings, or by contacting support for data that cannot be edited directly."]</li>
            <li>@T["Signed-in users can delete their account from the Account page. Password accounts must confirm the current password and type DELETE before deletion."]</li>
            <li>@T["Deletion removes account-linked learning state where possible and detaches or anonymizes operational audit records that may need to be retained for legal, accounting, security, or abuse-prevention reasons."]</li>
            <li>@T["Backups are restored and expired under the operational backup policy; they are not edited record by record."]</li>
        </ul>
        <p class="body-sm"><a asp-controller="Account" asp-action="Index">@T["Open account data controls"]</a></p>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Transactional emails"]</h2>
        <ul class="feature-list">
            <li>@T["Darwin Lingua sends transactional emails for registration confirmation, password reset, email change, organizer claims, RSVP confirmations, partner-request outcomes, moderation alerts, and account security events."]</li>
            <li>@T["Transactional emails are not marketing emails and are not used for newsletters or promotional campaigns."]</li>
            <li>@T["Production and staging email delivery may be processed by an external email provider configured by the operator."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Email diagnostics"]</h2>
        <ul class="feature-list">
            <li>@T["Delivery diagnostics store scenario, template, culture, provider, status, safe failure summaries, timestamps, and a hashed recipient email value."]</li>
            <li>@T["Reset tokens, confirmation tokens, full recovery links, and full magic links are not stored in delivery logs."]</li>
            <li>@T["Delivery logs are retained only for the configured operational retention period and can be cleaned up by authorized admins."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Provider and support processing"]</h2>
        <ul class="feature-list">
            <li>@T["Email providers may process recipient email addresses, message metadata, and message content strictly to deliver transactional emails and report delivery status."]</li>
            <li>@T["Support contact addresses are monitored for account recovery and operational support."]</li>
            <li>@T["Before public production launch, the production email provider and any required data-processing agreement must be reviewed by the release owner."]</li>
        </ul>
    </article>
</section>
