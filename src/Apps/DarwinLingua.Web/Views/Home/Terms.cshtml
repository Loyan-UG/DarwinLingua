@{
    ViewData["Title"] = T["Terms of Use"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Legal"]</span>
    <h1 class="headline-md">@T["Terms of Use"]</h1>
    <p class="body-lg">@T["These draft operational terms describe the basic rules for using Darwin Lingua while the service is prepared for production legal review."]</p>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Account rules"]</h2>
        <ul class="feature-list">
            <li>@T["Use your own email address and keep your password secure."]</li>
            <li>@T["Do not try to access another account, bypass security controls, or misuse admin or organizer features."]</li>
            <li>@T["Account features may change as the service evolves."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Educational service"]</h2>
        <ul class="feature-list">
            <li>@T["Darwin Lingua provides language-learning content and practice tools, not legal, medical, immigration, or financial advice."]</li>
            <li>@T["Life in Germany content may explain everyday civic, social, and administrative topics for learning purposes, but it does not replace official guidance or legal advice."]</li>
            <li>@T["Learning content may contain mistakes during development and should be reviewed before production use."]</li>
            <li>@T["Do not use the service to harass, threaten, discriminate, or facilitate illegal activity."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Sensitive Educational Language"]</h2>
        <ul class="feature-list">
            <li>@T["Sensitive Educational Language is for comprehension of rude words, slang, insults, and mild social or emotional expressions."]</li>
            <li>@T["It is off by default, includes warnings, and is not pornographic or explicit adult content."]</li>
            <li>@T["The setting is a learner preference, not age verification. Explicit adult content remains blocked."]</li>
            <li>@T["Content that promotes hatred, extremist propaganda, sexual exploitation, harm, fraud, or other illegal activity is not allowed."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Privacy and contact"]</h2>
        <ul class="feature-list">
            <li>@T["Account and learning data are processed as described in the Privacy Policy."]</li>
            <li>@T["Transactional emails may be sent for registration, security, account recovery, billing, and important service events."]</li>
            <li>@T["Production legal contact, imprint, and final terms text must be reviewed before public launch."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Billing status during development"]</h2>
        <ul class="feature-list">
            <li>@T["Public self-service billing is currently disabled while the Web product is still being prepared for real user testing."]</li>
            <li>@T["Premium access may be granted manually for testing. Public paid subscriptions require a separate production billing review before they are enabled."]</li>
        </ul>
    </article>
</section>
