@inject IConfiguration Configuration
@{
    ViewData["Title"] = T["Legal Notice"];

    static string? ReadConfiguredValue(IConfiguration configuration, string key) =>
        string.IsNullOrWhiteSpace(configuration[key])
            ? null
            : configuration[key]!;

    string missing = "Not configured - legal review required before production.";
    string providerName = ReadConfiguredValue(Configuration, "LegalNotice:ProviderName") ?? missing;
    string address = ReadConfiguredValue(Configuration, "LegalNotice:Address") ?? missing;
    string email = ReadConfiguredValue(Configuration, "LegalNotice:Email") ?? missing;
    string? phone = ReadConfiguredValue(Configuration, "LegalNotice:Phone");
    string responsiblePerson = ReadConfiguredValue(Configuration, "LegalNotice:ResponsiblePerson") ?? missing;
    string? registerInfo = ReadConfiguredValue(Configuration, "LegalNotice:RegisterInfo");
    string? vatId = ReadConfiguredValue(Configuration, "LegalNotice:VatId");
    string dataProtectionContact = ReadConfiguredValue(Configuration, "LegalNotice:DataProtectionContact") ?? missing;
    bool hasCoreProviderData = !string.IsNullOrWhiteSpace(providerName) &&
        !string.IsNullOrWhiteSpace(address) &&
        !string.IsNullOrWhiteSpace(email) &&
        !string.IsNullOrWhiteSpace(responsiblePerson) &&
        !string.IsNullOrWhiteSpace(dataProtectionContact);
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Legal"]</span>
    <h1 class="headline-md">@T["Legal Notice"]</h1>
    @if (hasCoreProviderData)
    {
        <p class="body-lg">@T["This legal notice is populated from the configured operator details for Darwin Lingua."]</p>
        <p class="body-sm">@T["The release owner must review the configured details before broad public launch."]</p>
    }
    else
    {
        <p class="body-lg">@T["This legal notice is missing required operator configuration. Do not launch production without reviewed provider details."]</p>
        <p class="body-sm">@T["The public legal notice is prepared for German provider-information requirements. Real operator data must be configured before production use."]</p>
    }
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Provider information"]</h2>
        <dl class="definition-list">
            <dt>@T["Provider name"]</dt>
            <dd>@providerName</dd>
            <dt>@T["Address"]</dt>
            <dd>@address</dd>
            <dt>@T["Email"]</dt>
            <dd>@email</dd>
            @if (!string.IsNullOrWhiteSpace(phone))
            {
                <dt>@T["Phone"]</dt>
                <dd>@phone</dd>
            }
        </dl>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Responsible and registration details"]</h2>
        <dl class="definition-list">
            <dt>@T["Responsible person"]</dt>
            <dd>@responsiblePerson</dd>
            @if (!string.IsNullOrWhiteSpace(registerInfo))
            {
                <dt>@T["Register information"]</dt>
                <dd>@registerInfo</dd>
            }
            @if (!string.IsNullOrWhiteSpace(vatId))
            {
                <dt>@T["VAT ID"]</dt>
                <dd>@vatId</dd>
            }
            <dt>@T["Data protection contact"]</dt>
            <dd>@dataProtectionContact</dd>
        </dl>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Legal review status"]</h2>
        <ul class="feature-list">
            <li>@T["This page is a Web legal baseline, not final legal advice."]</li>
            <li>@T["Operator information is read from application configuration and must stay current."]</li>
            <li>@T["Terms, Privacy, Cookie/Storage Notice, and Sensitive Educational Language policy require owner review before release."]</li>
        </ul>
    </article>

    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Related pages"]</h2>
        <ul class="feature-list">
            <li><a asp-controller="Home" asp-action="Terms">@T["Terms of Use"]</a></li>
            <li><a asp-controller="Home" asp-action="Privacy">@T["Privacy Policy"]</a></li>
            <li><a asp-controller="Home" asp-action="Cookies">@T["Cookie / Storage Notice"]</a></li>
            <li><a asp-controller="Home" asp-action="Contact">@T["Contact"]</a></li>
        </ul>
    </article>
</section>
