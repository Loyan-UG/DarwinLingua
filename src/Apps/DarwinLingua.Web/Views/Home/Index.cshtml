@model DarwinLingua.Web.Models.HomePageViewModel
@{
    ViewData["Title"] = T["Home"];
}

<section class="hero">
    <div class="hero__content">
        <span class="eyebrow">@T["German for real work"]</span>
        <h1 class="headline-xl">@T["Build the vocabulary you actually need for meetings, systems, and daily decisions."]</h1>
        <p class="body-lg">
            @T["Darwin Lingua turns German study into a focused workflow: curated workplace collections, CEFR-aware browsing, searchable word detail, pronunciation support, favorites, and recent activity in one calm learning space."]
        </p>
        <div class="action-row">
            <a class="button button--primary" asp-controller="Browse" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Start learning"]</a>
            <a class="button button--secondary" asp-controller="Collections" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Explore collections"]</a>
            <a class="button button--secondary" asp-controller="Search" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Search vocabulary"]</a>
        </div>
    </div>
    <div class="hero__aside">
        <div class="hero-preview">
            <img src="~/images/logo.png" alt="" />
            <div>
                <span class="eyebrow">@T["Today's focus"]</span>
                <strong>@T["Project communication"]</strong>
                <p>@T["Practice the words, phrases, and examples that show up in planning, reporting, and team coordination."]</p>
            </div>
        </div>
        <div class="hero-stats">
            <span><strong>A1-C1</strong> @T["CEFR levels"]</span>
            <span><strong>@T["Workplace"]</strong> @T["Collections"]</span>
            <span><strong>@T["Personal"]</strong> @T["progress"]</span>
        </div>
    </div>
</section>

<section class="content-band stack-lg">
    <div class="section-heading">
        <div>
            <span class="eyebrow">@T["Guided study"]</span>
            <h2 class="headline-md">@T["Featured collections"]</h2>
        </div>
        <a class="button button--secondary" asp-controller="Collections" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Browse all collections"]</a>
    </div>

    @if (Model.FeaturedCollections.Count == 0)
    {
        <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Collections are being prepared"].Value, T["Curated study paths will appear here as soon as they are available for your account."].Value)' />
    }
    else
    {
        <section class="grid-two-col">
            @foreach (var collection in Model.FeaturedCollections)
            {
                <partial name="~/Views/Shared/_WordCollectionCard.cshtml" model="collection" />
            }
        </section>
    }
</section>

<section class="grid-three-col">
    <article class="panel stack-md">
        <span class="eyebrow">@T["Browse"]</span>
        <h2 class="headline-sm">@T["Find the right words fast"]</h2>
        <p>@T["Filter by CEFR level, topic, and learning context so every session starts from a useful set of vocabulary."]</p>
        <a class="text-link" asp-controller="Browse" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Open browse"]</a>
    </article>
    <article class="panel stack-md">
        <span class="eyebrow">@T["Practice"]</span>
        <h2 class="headline-sm">@T["Keep useful words close"]</h2>
        <p>@T["Mark favorites, revisit recent words, hear pronunciation, and keep your practice tied to real examples."]</p>
        <a class="text-link" asp-controller="Favorites" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["View favorites"]</a>
    </article>
    <article class="panel stack-md">
        <span class="eyebrow">@T["Connect"]</span>
        <h2 class="headline-sm">@T["Prepare for conversation"]</h2>
        <p>@T["Use starters, dialogues, events, and partner matching to move vocabulary from recognition into speaking."]</p>
        <a class="text-link" asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Open dialogues"]</a>
    </article>
</section>

<section class="content-band stack-lg">
    <div class="section-heading">
        <div>
            <span class="eyebrow">@T["Continue"]</span>
            <h2 class="headline-md">@T["Pick up where you left off"]</h2>
        </div>
        <a class="button button--secondary" asp-controller="Recent" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Open history"]</a>
    </div>
    <div
        hx-get="@Url.Action("Panel", "Recent")"
        hx-trigger="load"
        hx-target="this"
        hx-swap="innerHTML">
        <p class="body-lg">@T["Loading your recent words..."]</p>
    </div>
</section>
