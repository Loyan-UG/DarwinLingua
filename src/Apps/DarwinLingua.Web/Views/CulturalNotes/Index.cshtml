@model DarwinLingua.Web.Models.CulturalNoteIndexPageViewModel
@{
    ViewData["Title"] = T["Cultural Notes"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Resources"]</span>
    <h1 class="headline-md">@T["Cultural Notes"]</h1>
    <p class="body-lg">@T["German communication norms, social expectations, and practical cultural context for learners."]</p>
    <form class="search-form" method="get" asp-controller="CulturalNotes" asp-action="Index">
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search cultural notes"]" aria-label="@T["Search cultural notes"]" />
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in Model.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.SelectedCefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
            }
        </select>
        <select class="search-input" name="category" aria-label="@T["Category"]">
            <option value="">@T["All categories"]</option>
            @foreach (string category in Model.Categories)
            {
                <option value="@category" selected="@(string.Equals(Model.SelectedCategory, category, StringComparison.OrdinalIgnoreCase))">@T[category]</option>
            }
        </select>
        <button type="submit" class="button button--secondary">@T["Filter"]</button>
    </form>
</section>

@if (Model.Notes.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Cultural notes are being prepared"].Value, T["Dynamic cultural notes will appear here after the first validated cultural-note package is imported."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var note in Model.Notes)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@note.CefrLevel · @T[note.Category]</span>
                <h2 class="headline-sm"><a asp-controller="CulturalNotes" asp-action="Detail" asp-route-slug="@note.Slug">@note.Title</a></h2>
                <p>@note.ShortDescription</p>
                <p>@note.Context</p>
                @if (note.HasSensitivityWarning)
                {
                    <p class="status-badge status-badge--warning">@T["Sensitive topic"]</p>
                }
                <a class="button button--secondary" asp-controller="CulturalNotes" asp-action="Detail" asp-route-slug="@note.Slug">@T["Open cultural note"]</a>
            </article>
        }
    </section>
}
