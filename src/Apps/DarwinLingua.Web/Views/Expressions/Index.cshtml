@model DarwinLingua.Web.Models.ExpressionIndexPageViewModel
@{
    ViewData["Title"] = T["Everyday Expressions"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Everyday Expressions"]</span>
    <h1 class="headline-md">@T["Idioms, phrases, and everyday German usage"]</h1>
    <p class="body-lg">@T["Learn what common German expressions really mean, when they fit, and when they need extra care."]</p>

    <form class="search-form" method="get" asp-controller="Expressions" asp-action="Index">
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search expressions"]" aria-label="@T["Search expressions"]" />
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in Model.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.SelectedCefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
            }
        </select>
        <select class="search-input" name="expressionType" aria-label="@T["Expression type"]">
            <option value="">@T["All expression types"]</option>
            @foreach (string expressionType in Model.ExpressionTypes)
            {
                <option value="@expressionType" selected="@(string.Equals(Model.SelectedExpressionType, expressionType, StringComparison.OrdinalIgnoreCase))">@T[expressionType]</option>
            }
        </select>
        <select class="search-input" name="register" aria-label="@T["Expression register"]">
            <option value="">@T["All registers"]</option>
            @foreach (string register in Model.Registers)
            {
                <option value="@register" selected="@(string.Equals(Model.SelectedRegister, register, StringComparison.OrdinalIgnoreCase))">@T[register]</option>
            }
        </select>
        <select class="search-input" name="category" aria-label="@T["Category"]">
            <option value="">@T["All categories"]</option>
            @foreach (string category in Model.Categories)
            {
                <option value="@category" selected="@(string.Equals(Model.SelectedCategory, category, StringComparison.OrdinalIgnoreCase))">@T[category]</option>
            }
        </select>
        <select class="search-input" name="topic" aria-label="@T["Topic"]">
            <option value="">@T["All topics"]</option>
            @foreach (string topicKey in Model.TopicKeys)
            {
                <option value="@topicKey" selected="@(string.Equals(Model.SelectedTopicKey, topicKey, StringComparison.OrdinalIgnoreCase))">@topicKey</option>
            }
        </select>
        <label class="checkbox-row">
            <input type="checkbox" name="includeRisky" value="true" checked="@Model.IncludeRisky" />
            <span>@T["Include risky expressions"]</span>
        </label>
        <button type="submit" class="button button--secondary">@T["Filter"]</button>
    </form>
</section>

@if (Model.Expressions.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Expressions are being prepared"].Value, T["Dynamic Everyday Expressions content will appear here after the first validated expression package is imported."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var expression in Model.Expressions)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@expression.CefrLevel · @T[expression.ExpressionType] · @T[expression.Register]</span>
                <h2 class="headline-sm">
                    <a asp-controller="Expressions" asp-action="Detail" asp-route-slug="@expression.Slug">@expression.ExpressionText</a>
                </h2>
                <p>@expression.ActualMeaning</p>
                @if (!string.IsNullOrWhiteSpace(expression.LiteralMeaning))
                {
                    <p><strong>@T["Literal meaning"]:</strong> @expression.LiteralMeaning</p>
                }
                @if (expression.IsRisky || expression.WarningTypes.Count > 0)
                {
                    <p class="status-pill status-pill--warning">@T["Tone warning"]</p>
                }
                <div class="action-row">
                    <a class="button button--secondary" asp-controller="Expressions" asp-action="Detail" asp-route-slug="@expression.Slug">@T["Open Expression"]</a>
                </div>
            </article>
        }
    </section>
}
