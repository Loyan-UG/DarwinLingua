@model DarwinLingua.Web.Models.RecentActivityPageViewModel
@{
    ViewData["Title"] = T["Recent"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Recent activity"]</span>
    <h1 class="headline-md">@T["Recently viewed words"]</h1>
    <p class="body-lg">@T["Return to words you opened recently and continue your study without searching again."]</p>
</section>

@if (Model.LearningProgress is not null)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Learning progress"]</h2>
        <div class="meta-grid">
            <div class="meta-chip">
                <strong>@T["Tracked"]</strong>
                <span>@Model.LearningProgress.TotalTracked</span>
            </div>
            <div class="meta-chip">
                <strong>@T["In progress"]</strong>
                <span>@Model.LearningProgress.InProgressCount</span>
            </div>
            <div class="meta-chip">
                <strong>@T["Completed"]</strong>
                <span>@Model.LearningProgress.CompletedCount</span>
            </div>
            <div class="meta-chip">
                <strong>@T["Needs review"]</strong>
                <span>@Model.LearningProgress.NeedsReviewCount</span>
            </div>
        </div>
    </section>
}

@if (Model.Recommendations.Count > 0)
{
    <section class="panel stack-md">
        <div>
            <span class="eyebrow">@T["Personalized practice"]</span>
            <h2 class="headline-sm">@T["Recommended next steps"]</h2>
        </div>
        <div class="grid-two-col">
            @foreach (var recommendation in Model.Recommendations)
            {
                <article class="stack-sm">
                    <div class="eyebrow">@recommendation.RecommendationType.Replace("-", " ")@(!string.IsNullOrWhiteSpace(recommendation.CefrLevel) ? $" · {recommendation.CefrLevel}" : string.Empty)</div>
                    <h3 class="headline-sm">@recommendation.Title</h3>
                    <p class="body-sm">@recommendation.Reason</p>
                    <a class="button button--secondary button--compact" href="@recommendation.Url">@T["Open"]</a>
                </article>
            }
        </div>
    </section>
}

<partial name="_RecentActivityPanel" model="Model" />
