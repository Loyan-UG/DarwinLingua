@model DarwinLingua.Web.Models.OrganizerEventEditPageViewModel
@{
    ViewData["Title"] = Model.IsNew ? T["New event for {0}", Model.Profile.DisplayName] : T["Edit {0}", Model.Input.Name];
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Profile.DisplayName · @Model.Profile.PlanKey</span>
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="OrganizerDashboard" asp-action="Index">@T["Dashboard"]</a>
            <a class="button button--secondary button--compact" asp-controller="OrganizerProfiles" asp-action="Detail" asp-route-targetLearningLanguageCode="@ContentLanguageRequirements.DefaultTargetLearningLanguageCode" asp-route-slug="@Model.Profile.Slug">@T["Organizer page"]</a>
        </div>
    </div>
    <h1 class="headline-md">@(Model.IsNew ? T["New event"] : T["Edit event"])</h1>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Event listing"]</h2>
    <form method="post" class="form-grid">
        @Html.AntiForgeryToken()
        <label class="field">
            <span>@T["Slug"]</span>
            @if (Model.IsNew)
            {
                <input name="Slug" value="@Model.Input.Slug" placeholder="@T["berlin-cafe-a1"]" />
            }
            else
            {
                <input name="Slug" value="@Model.Input.Slug" readonly />
            }
        </label>
        <label class="field">
            <span>@T["Name"]</span>
            <input name="Name" value="@Model.Input.Name" />
        </label>
        <label class="field field--wide">
            <span>@T["Description"]</span>
            <textarea name="Description" rows="6">@Model.Input.Description</textarea>
        </label>
        <label class="field">
            <span>@T["City"]</span>
            <input name="City" value="@Model.Input.City" />
        </label>
        <label class="field">
            <span>@T["Country or region"]</span>
            <input name="CountryRegion" value="@Model.Input.CountryRegion" />
        </label>
        <label class="field">
            <span>@T["Approximate location"]</span>
            <input name="ApproximateLocation" value="@Model.Input.ApproximateLocation" />
        </label>
        <label class="field">
            <span>@T["Category"]</span>
            <input name="Category" value="@Model.Input.Category" placeholder="@T["Conversation cafe"]" />
        </label>
        <label class="field">
            <span>@T["Supported levels"]</span>
            <input name="SupportedLearnerLevels" value="@Model.Input.SupportedLearnerLevels" placeholder="@T["A1, A2"]" />
        </label>
        <label class="field">
            <span>@T["Helper languages"]</span>
            <input name="HelperLanguageCodes" value="@Model.Input.HelperLanguageCodes" placeholder="@T["en, fa"]" />
        </label>
        <label class="field">
            <span>@T["External link"]</span>
            <input name="ExternalLink" value="@Model.Input.ExternalLink" />
        </label>
        <label class="field">
            <span>@T["Contact method"]</span>
            <input name="ContactMethod" value="@Model.Input.ContactMethod" />
        </label>
        <label class="field">
            <span>@T["Schedule"]</span>
            <input name="ScheduleText" value="@Model.Input.ScheduleText" />
        </label>
        <label class="field">
            <span>@T["Recurrence rule"]</span>
            <input name="RecurrenceRule" value="@Model.Input.RecurrenceRule" placeholder="@T["Weekly, Tuesday, 18:00"]" />
        </label>
        <label class="field">
            <span>@T["Capacity"]</span>
            <input name="Capacity" value="@Model.Input.Capacity" type="number" min="1" />
        </label>
        <label class="field">
            <span>@T["Price type"]</span>
            <input name="PriceType" value="@Model.Input.PriceType" placeholder="@T["Free, paid, donation"]" />
        </label>
        <label class="field">
            <span>@T["Preparation pack slugs"]</span>
            <input name="LinkedEventPreparationPackSlugs" value="@Model.Input.LinkedEventPreparationPackSlugs" placeholder="@T["a1-cafe-first-meeting-prep"]" />
        </label>
        <label class="field">
            <span>@T["Online"]</span>
            <select name="IsOnline">
                <option value="false" selected="@(!Model.Input.IsOnline)">@T["In person"]</option>
                <option value="true" selected="@Model.Input.IsOnline">@T["Online"]</option>
            </select>
        </label>
        <div class="action-row">
            <button type="submit" class="button button--primary">@T["Save event"]</button>
        </div>
    </form>
</section>
