@model DarwinLingua.Web.Models.OrganizerDashboardViewModel
@{
    ViewData["Title"] = T["Organizer dashboard"];
}

<section class="panel stack-lg">
    <partial name="~/Views/Shared/_SectionHeading.cshtml" model='new DarwinLingua.Web.Models.SectionHeadingViewModel(T["Organizer dashboard"].Value, T["Owned profiles"].Value, T["Manage reviewed organizer listings assigned to your account."].Value)' />
    @if (!string.IsNullOrWhiteSpace(TempData["StatusMessage"] as string))
    {
        <div class="status-banner status-banner--success">@TempData["StatusMessage"]</div>
    }
    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"] as string))
    {
        <div class="status-banner status-banner--error">@TempData["ErrorMessage"]</div>
    }
</section>

@if (Model.Profiles.Count == 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["No assigned profiles"]</h2>
        <p>@T["No organizer profiles are assigned to {0} yet.", Model.OwnerEmail]</p>
    </section>
}
else
{
    <section class="grid-two-col">
        @foreach (var item in Model.Profiles)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@item.Profile.OrganizerType · @item.Profile.VerificationStatus</span>
                <h2 class="headline-sm">
                    <a asp-controller="OrganizerProfiles" asp-action="Detail" asp-route-slug="@item.Profile.Slug">@item.Profile.DisplayName</a>
                </h2>
                <p>@item.Profile.Description</p>
                <dl class="detail-list">
                    <div>
                        <dt>@T["Events"]</dt>
                        <dd>@T["{0} active", item.Analytics.ActiveEventCount] · @T["{0} archived", item.Analytics.ArchivedEventCount]</dd>
                    </div>
                    <div>
                        <dt>@T["Plan"]</dt>
                        <dd>@item.Plan.PlanKey · @T["{0}/{1} active events", item.Analytics.ActiveEventCount, item.Plan.ActiveEventLimit]</dd>
                    </div>
                    @if (item.CanUseAnalytics)
                    {
                        <div>
                            <dt>@T["Mode"]</dt>
                            <dd>@T["{0} online", item.Analytics.OnlineEventCount] · @T["{0} in person", item.Analytics.InPersonEventCount]</dd>
                        </div>
                        <div>
                            <dt>@T["Capacity"]</dt>
                            <dd>@(item.Analytics.TotalCapacity == 0 ? T["Not set"] : item.Analytics.TotalCapacity.ToString())</dd>
                        </div>
                    }
                </dl>
                <div class="chip-grid">
                    @foreach (string feature in item.Plan.EnabledFeatures)
                    {
                        <span class="chip-link chip-link--static">@feature</span>
                    }
                </div>
                <div class="chip-grid">
                    @foreach (string level in item.Profile.SupportedLearnerLevels)
                    {
                        <span class="chip-link">@level</span>
                    }
                    @foreach (string languageCode in item.Profile.HelperLanguageCodes)
                    {
                        <span class="chip-link">@languageCode</span>
                    }
                </div>
                <div class="detail-toolbar__actions">
                    <a class="button button--secondary button--compact" asp-controller="OrganizerDashboard" asp-action="EditProfile" asp-route-slug="@item.Profile.Slug">@T["Edit profile"]</a>
                    @if (item.CanCreateMoreActiveEvents)
                    {
                        <a class="button button--secondary button--compact" asp-controller="OrganizerDashboard" asp-action="NewEvent" asp-route-profileSlug="@item.Profile.Slug">@T["New event"]</a>
                    }
                    else
                    {
                        <span class="button button--secondary button--compact">@T["Event limit reached"]</span>
                    }
                </div>
                @if (item.Events.Count > 0)
                {
                    <div class="stack-sm">
                        <h3 class="headline-sm">@T["Events"]</h3>
                        @foreach (var conversationEvent in item.Events)
                        {
                            item.RsvpSummaries.TryGetValue(conversationEvent.Slug, out var rsvpSummary);
                            item.EventRsvps.TryGetValue(conversationEvent.Slug, out var eventRsvps);
                            <div class="detail-toolbar">
                                <span>
                                    @conversationEvent.Name · @conversationEvent.PublicationStatus
                                    @if (rsvpSummary is not null)
                                    {
                                        <span> · @T["{0} going", rsvpSummary.GoingCount] · @T["{0} interested", rsvpSummary.InterestedCount]</span>
                                    }
                                </span>
                                <div class="detail-toolbar__actions">
                                    <a class="button button--secondary button--compact" asp-controller="OrganizerDashboard" asp-action="EditEvent" asp-route-profileSlug="@item.Profile.Slug" asp-route-eventSlug="@conversationEvent.Slug">@T["Edit event"]</a>
                                    @if (string.Equals(conversationEvent.PublicationStatus, "Active", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form method="post" asp-controller="OrganizerDashboard" asp-action="SetEventPublicationStatus" asp-route-profileSlug="@item.Profile.Slug" asp-route-eventSlug="@conversationEvent.Slug" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="PublicationStatus" value="Archived" />
                                            <button type="submit" class="button button--secondary button--compact">@T["Deactivate"]</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-controller="OrganizerDashboard" asp-action="SetEventPublicationStatus" asp-route-profileSlug="@item.Profile.Slug" asp-route-eventSlug="@conversationEvent.Slug" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="PublicationStatus" value="Active" />
                                            <button type="submit" class="button button--secondary button--compact">@T["Activate"]</button>
                                        </form>
                                    }
                                </div>
                            </div>
                            @if (item.CanUseRsvpManagement && eventRsvps is { Count: > 0 })
                            {
                                <ul class="feature-list">
                                    @foreach (var rsvp in eventRsvps)
                                    {
                                        <li>
                                            <span>@rsvp.ParticipantName · @rsvp.ParticipantEmail · @rsvp.Status</span>
                                            <form method="post" asp-controller="OrganizerDashboard" asp-action="SetRsvpStatus" asp-route-profileSlug="@item.Profile.Slug" asp-route-eventSlug="@conversationEvent.Slug" asp-route-rsvpId="@rsvp.Id" class="inline-form">
                                                @Html.AntiForgeryToken()
                                                <select name="Status">
                                                    <option value="going" selected="@(rsvp.Status == "going")">@T["Going"]</option>
                                                    <option value="interested" selected="@(rsvp.Status == "interested")">@T["Interested"]</option>
                                                    <option value="cancelled" selected="@(rsvp.Status == "cancelled")">@T["Cancelled"]</option>
                                                    <option value="attended" selected="@(rsvp.Status == "attended")">@T["Attended"]</option>
                                                    <option value="no-show" selected="@(rsvp.Status == "no-show")">@T["No-show"]</option>
                                                </select>
                                                <button type="submit" class="button button--secondary button--compact">@T["Update"]</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                    </div>
                }
            </article>
        }
    </section>
}
