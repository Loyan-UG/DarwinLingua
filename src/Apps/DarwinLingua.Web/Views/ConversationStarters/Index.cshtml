@model DarwinLingua.Web.Models.ConversationStarterIndexPageViewModel
@{
    ViewData["Title"] = T["Conversation Starters"];
    string targetLearningLanguageCode = LearningRouteConventions.ResolveTargetLearningLanguageCode(Context);
    string FormatCefrLevel(string level) => LearningPortalFilterConventions.FormatCefrLevelOption(level, targetLearningLanguageCode, key => T[key].Value);
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Conversation Starters"]</span>
    <h1 class="headline-md">@T["Openers for real conversations"]</h1>
    <p class="body-lg">@T["Practice short German phrases by situation, tone, goal, and topic."]</p>
</section>

<section class="panel stack-md">
    <form class="filter-bar" method="get">
        <label>
            <span>@T["CEFR"]</span>
            <select name="cefrLevel">
                <option value="">@T["All"]</option>
                @foreach (string level in LearningPortalFilterConventions.GetCefrLevelDefinitions(targetLearningLanguageCode).Select(level => level.Code))
                {
                    <option value="@level" selected="@(string.Equals(Model.Filter.CefrLevel, level, StringComparison.OrdinalIgnoreCase))">@FormatCefrLevel(level)</option>
                }
            </select>
        </label>
        <label>
            <span>@T["Situation"]</span>
            <input name="situation" value="@Model.Filter.Situation" placeholder="@T["cafe"]" />
        </label>
        <label>
            <span>@T["Tone"]</span>
            <input name="tone" value="@Model.Filter.Tone" placeholder="@T["friendly"]" />
        </label>
        <label>
            <span>@T["Goal"]</span>
            <input name="conversationGoal" value="@Model.Filter.ConversationGoal" placeholder="@T["introduction"]" />
        </label>
        <label>
            <span>@T["Topic"]</span>
            <input name="topicKey" value="@Model.Filter.TopicKey" placeholder="@T["everyday-life"]" />
        </label>
        <button class="button button--secondary" type="submit">@T["Filter"]</button>
    </form>
</section>

@if (Model.StarterPacks.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Conversation starters are being prepared"].Value, T["Short phrase sets will appear here when they are ready for practice."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var starterPack in Model.StarterPacks)
        {
            <article class="panel stack-md">
                <div class="action-row collection-card__meta">
                    <span class="eyebrow">@FormatCefrLevel(starterPack.CefrLevel) · @starterPack.Situation · @starterPack.Tone</span>
                    <span>@T["{0} topics", starterPack.TopicKeys.Count]</span>
                </div>
                <h2 class="headline-sm">
                    <a asp-controller="ConversationStarters" asp-route-targetLearningLanguageCode="@targetLearningLanguageCode" asp-action="Detail" asp-route-slug="@starterPack.Slug">@starterPack.Title</a>
                </h2>
                <p>@starterPack.Description</p>
                <p class="body-lg">@starterPack.ConversationGoal</p>
                @if (starterPack.TopicKeys.Count > 0)
                {
                    <div class="chip-grid">
                        @foreach (string topicKey in starterPack.TopicKeys)
                        {
                            <a class="chip-link" asp-controller="Browse" asp-route-targetLearningLanguageCode="@targetLearningLanguageCode" asp-action="Topic" asp-route-id="@topicKey">@topicKey</a>
                        }
                    </div>
                }
                <div class="action-row">
                    <a class="button button--secondary" asp-controller="ConversationStarters" asp-route-targetLearningLanguageCode="@targetLearningLanguageCode" asp-action="Detail" asp-route-slug="@starterPack.Slug">@T["Open starters"]</a>
                </div>
            </article>
        }
    </section>
}
