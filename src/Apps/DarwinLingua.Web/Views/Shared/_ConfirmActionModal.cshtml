@model DarwinLingua.Web.Models.AsyncStatePanelViewModel

<dialog id="rollback-confirmation" class="confirm-modal">
    <div class="panel stack-md">
        <span class="eyebrow">Confirmation</span>
        <h2 class="headline-sm">@Model.Title</h2>
        <p class="body-lg">@Model.Body</p>
        <div class="action-row">
            <button type="button" class="button button--secondary" data-modal-close="rollback-confirmation">Cancel</button>
            <button type="button" class="button button--primary" data-modal-close="rollback-confirmation">Acknowledge</button>
        </div>
    </div>
</dialog>
