<nav class="mobile-nav" aria-label="@T["Mobile"]">
    <span class="eyebrow">@T["Learn"]</span>
    <a asp-area="" asp-controller="Browse" asp-action="Index">@T["Browse"]</a>
    <a asp-area="" asp-controller="Grammar" asp-action="Index">@T["Grammar Guide"]</a>
    <a asp-area="" asp-controller="Expressions" asp-action="Index">@T["Everyday Expressions"]</a>
    <a asp-area="" asp-controller="Courses" asp-action="Index">@T["Courses"]</a>
    <a asp-area="" asp-controller="Collections" asp-action="Index">@T["Collections"]</a>
    <a asp-area="" asp-controller="Search" asp-action="Index">@T["Search"]</a>
    <span class="eyebrow">@T["Practice"]</span>
    <a asp-area="" asp-controller="Exercises" asp-action="Index">@T["Exercises"]</a>
    <a asp-area="" asp-controller="Favorites" asp-action="Index">@T["Favorites"]</a>
    <a asp-area="" asp-controller="Recent" asp-action="Index">@T["Recent"]</a>
    <span class="eyebrow">@T["Speak"]</span>
    <a asp-area="" asp-controller="TalkTopics" asp-action="Index">@T["Talk Topics"]</a>
    <span class="eyebrow">@T["Prepare"]</span>
    <a asp-area="" asp-controller="Dialogues" asp-action="Index">@T["Dialogues"]</a>
    <a asp-area="" asp-controller="ConversationStarters" asp-action="Index">@T["Conversation Starters"]</a>
    <a asp-area="" asp-controller="ExamPrep" asp-action="Index">@T["Exam Prep"]</a>
    <span class="eyebrow">@T["Resources"]</span>
    <a asp-area="" asp-controller="ConversationEvents" asp-action="Index">@T["Events"]</a>
    <a asp-area="" asp-controller="OrganizerProfiles" asp-action="Index">@T["Organizers"]</a>
    <a asp-area="" asp-controller="WritingTemplates" asp-action="Index">@T["Writing Templates"]</a>
    <a asp-area="" asp-controller="CulturalNotes" asp-action="Index">@T["Life in Germany"]</a>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-area="" asp-controller="PartnerMatching" asp-action="Index">@T["Partners"]</a>
        <a asp-area="" asp-controller="OrganizerDashboard" asp-action="Index">@T["Organizer dashboard"]</a>
        <a class="nav-icon-link" asp-area="" asp-controller="Settings" asp-action="Index" aria-label="@T["Settings"]" title="@T["Settings"]">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z" />
                <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.88l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 0-.35 1.02V21a2 2 0 1 1-4 0v-.09A1.7 1.7 0 0 0 8.6 19.4a1.7 1.7 0 0 0-1.88.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.6-1 1.7 1.7 0 0 0-1.02-.35H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.6 8.6a1.7 1.7 0 0 0-.34-1.88l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.6 1.7 1.7 0 0 0 .35-1.02V3a2 2 0 1 1 4 0v.09A1.7 1.7 0 0 0 15.4 4.6a1.7 1.7 0 0 0 1.88-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9c.17.38.4.72.6 1 .3.36.7.57 1.02.57H21a2 2 0 1 1 0 4h-.09A1.7 1.7 0 0 0 19.4 15Z" />
            </svg>
            <span class="sr-only">@T["Settings"]</span>
        </a>
        <details class="account-menu">
            <summary class="nav-icon-link" aria-label="@T["Account menu"]" title="@T["Account"]">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 21a8 8 0 0 0-16 0" />
                    <path d="M12 13a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z" />
                </svg>
                <span class="sr-only">@T["Account"]</span>
            </summary>
            <div class="account-menu__panel">
                <a asp-area="" asp-controller="Account" asp-action="Index">@T["Account"]</a>
                <a asp-area="" asp-controller="Billing" asp-action="Index">@T["Billing"]</a>
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" class="inline-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="account-menu__button">@T["Sign out"]</button>
                </form>
            </div>
        </details>
        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">@T["Admin"]</a>
        }
    }
    else
    {
        <a asp-area="Identity" asp-page="/Account/Login">@T["Sign in"]</a>
    }
</nav>
