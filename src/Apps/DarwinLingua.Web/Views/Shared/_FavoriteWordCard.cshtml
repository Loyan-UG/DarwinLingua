@model DarwinLingua.Learning.Application.Models.FavoriteWordListItemModel

<article class="panel stack-md" data-word-card data-word-id="@Model.PublicId">
    <div class="eyebrow">@Model.CefrLevel · @Model.PartOfSpeech</div>
    <h3 class="headline-sm">@Model.Lemma</h3>
    @if (!string.IsNullOrWhiteSpace(Model.Article))
    {
        <p>@Model.Article</p>
    }
    @if (!string.IsNullOrWhiteSpace(Model.PrimaryMeaning))
    {
        <p class="body-lg">@Model.PrimaryMeaning</p>
    }
    <div class="action-row">
        <button type="button" class="button button--secondary button--compact" data-speak-text="@Model.Lemma" data-speak-lang="de-DE">Speak</button>
        <a class="button button--secondary" data-word-link data-word-id="@Model.PublicId" asp-controller="Words" asp-action="Detail" asp-route-id="@Model.PublicId">Open word</a>
    </div>
</article>
