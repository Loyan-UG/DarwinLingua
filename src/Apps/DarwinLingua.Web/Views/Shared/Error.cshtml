@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="panel stack-lg auth-intro">
    <span class="eyebrow">Darwin Lingua</span>
    <h1 class="headline-md">@Model.Title</h1>
    <p class="body-lg">@Model.Message</p>

    @if (Model.ShowRequestId)
    {
        <p class="status-banner">
            Reference: <code>@Model.RequestId</code>
        </p>
    }

    <div class="action-row">
        <a class="button button--primary" asp-controller="Home" asp-action="Index">Home</a>
        <a class="button button--secondary" asp-controller="Browse" asp-action="Index">Browse words</a>
    </div>
</section>
