<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Darwin Lingua</title>
    <meta name="description" content="Darwin Lingua helps learners build practical German vocabulary for work, conversation, and everyday decisions." />
    <meta name="theme-color" content="#f6f1e8" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <link rel="icon" type="image/svg+xml" href="~/icons/favicon.svg" />
    <link rel="icon" type="image/svg+xml" href="~/icons/icon-192.svg" />
    <link rel="apple-touch-icon" href="~/icons/icon-192.svg" />
    <link rel="stylesheet" href="~/css/tailwind.generated.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DarwinLingua.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="shell-backdrop" aria-hidden="true"></div>
    <header class="shell-header">
        <div class="shell-container shell-nav">
            <partial name="_AppHeader" />
            <nav class="shell-links" aria-label="Primary">
                <a asp-area="" asp-controller="Browse" asp-action="Index">Browse</a>
                <a asp-area="" asp-controller="Collections" asp-action="Index">Collections</a>
                <a asp-area="" asp-controller="Scenarios" asp-action="Index">Scenarios</a>
                <a asp-area="" asp-controller="Search" asp-action="Index">Search</a>
                <a asp-area="" asp-controller="Favorites" asp-action="Index">Favorites</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-area="" asp-controller="Billing" asp-action="Index">Billing</a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                }
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-area="" asp-controller="Account" asp-action="Index">Account</a>
                    <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" class="inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-button">Sign out</button>
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login">Sign in</a>
                    <a asp-area="Identity" asp-page="/Account/Register">Register</a>
                }
            </nav>
        </div>
    </header>
    <div class="shell-container">
        <partial name="_MobileNav" />
        <div id="install-banner" class="install-banner" hidden>
            <div>
                <strong>Install Darwin Lingua</strong>
                <p>Add this site to your device for an app-like learner experience.</p>
            </div>
            <button id="install-button" type="button" class="button button--primary">Install</button>
        </div>
        <main role="main" class="shell-main">
            @RenderBody()
        </main>
    </div>

    <footer class="shell-footer">
        <div class="shell-container shell-footer__inner">
            <div>
                <strong>Darwin Lingua</strong>
                <p>Copyright &copy; @DateTime.UtcNow.Year Shahram Vafadar. All rights reserved.</p>
            </div>
            <div class="shell-footer__actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-area="" asp-controller="Account" asp-action="Index">Account</a>
                }
                <a asp-area="" asp-controller="Browse" asp-action="Index">Browse</a>
                <a asp-area="" asp-controller="Collections" asp-action="Index">Collections</a>
                <a asp-area="" asp-controller="Scenarios" asp-action="Index">Scenarios</a>
                <a asp-area="" asp-controller="ConversationStarters" asp-action="Index">Starters</a>
                <a asp-area="" asp-controller="ConversationEvents" asp-action="Index">Events</a>
                <a asp-area="" asp-controller="OrganizerProfiles" asp-action="Index">Organizers</a>
                <a asp-area="" asp-controller="Recent" asp-action="Index">Recent</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-area="" asp-controller="PartnerMatching" asp-action="Index">Partners</a>
                    <a asp-area="" asp-controller="OrganizerDashboard" asp-action="Index">Organizer dashboard</a>
                    <a asp-area="" asp-controller="Billing" asp-action="Index">Billing</a>
                }
                <a asp-area="" asp-controller="Settings" asp-action="Index">Settings</a>
                <a asp-area="" asp-controller="Home" asp-action="Install">Install guide</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                }
            </div>
        </div>
    </footer>
    <script src="~/js/htmx.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
