@model DarwinLingua.Web.Models.ConversationEventDetailPageViewModel
@{
    ViewData["Title"] = Model.Event.Name;
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Event.Category · @(Model.Event.IsOnline ? T["Online"] : Model.Event.City ?? Model.Event.CountryRegion)</span>
        <div class="detail-toolbar__actions">
            <a class="button button--secondary button--compact" asp-controller="ConversationEvents" asp-action="Index">@T["All events"]</a>
        </div>
    </div>
    <h1 class="headline-md">@Model.Event.Name</h1>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="status-banner status-banner--error">@Model.ErrorMessage</div>
    }
    <p class="body-lg">@Model.Event.Description</p>
    <dl class="detail-list">
        <div>
            <dt>@T["Organizer"]</dt>
            <dd>
                @if (!string.IsNullOrWhiteSpace(Model.Event.OrganizerProfileSlug))
                {
                    <a asp-controller="OrganizerProfiles" asp-action="Detail" asp-route-slug="@Model.Event.OrganizerProfileSlug">@Model.Event.OrganizerName</a>
                }
                else
                {
                    @Model.Event.OrganizerName
                }
            </dd>
        </div>
        <div>
            <dt>@T["Schedule"]</dt>
            <dd>@Model.Event.ScheduleText</dd>
        </div>
        @if (Model.Event.StartsAtUtc.HasValue)
        {
            <div>
                <dt>@T["Start"]</dt>
                <dd>@Model.Event.StartsAtUtc.Value.ToString("yyyy-MM-dd HH:mm 'UTC'", System.Globalization.CultureInfo.InvariantCulture)</dd>
            </div>
        }
        @if (Model.Event.EndsAtUtc.HasValue)
        {
            <div>
                <dt>@T["End"]</dt>
                <dd>@Model.Event.EndsAtUtc.Value.ToString("yyyy-MM-dd HH:mm 'UTC'", System.Globalization.CultureInfo.InvariantCulture)</dd>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Event.RecurrenceRule))
        {
            <div>
                <dt>@T["Recurrence"]</dt>
                <dd>@Model.Event.RecurrenceRule</dd>
            </div>
        }
        <div>
            <dt>@T["Location"]</dt>
            <dd>@(Model.Event.IsOnline ? T["Online"] : Model.Event.ApproximateLocation ?? Model.Event.City ?? Model.Event.CountryRegion)</dd>
        </div>
        @if (Model.Event.Capacity.HasValue)
        {
            <div>
                <dt>@T["Capacity"]</dt>
                <dd>@T["{0} seats", Model.Event.Capacity.Value]</dd>
            </div>
        }
        <div>
            <dt>@T["Price"]</dt>
            <dd>@Model.Event.PriceType</dd>
        </div>
        <div>
            <dt>@T["Verification"]</dt>
            <dd>@Model.Event.VerificationStatus</dd>
        </div>
    </dl>
    <div class="chip-grid">
        @foreach (string level in Model.Event.SupportedLearnerLevels)
        {
            <span class="chip-link">@level</span>
        }
        @foreach (string languageCode in Model.Event.HelperLanguageCodes)
        {
            <span class="chip-link">@languageCode</span>
        }
    </div>
    <div class="detail-toolbar__actions">
        @if (!string.IsNullOrWhiteSpace(Model.Event.ExternalLink))
        {
            <a class="button button--primary button--compact" href="@Model.Event.ExternalLink" rel="noopener noreferrer" target="_blank">@T["Register"]</a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Event.ContactMethod))
        {
            <span class="button button--secondary button--compact">@Model.Event.ContactMethod</span>
        }
    </div>
    <form method="post" asp-controller="Moderation" asp-action="Report" class="panel report-panel stack-sm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TargetType" value="conversation-event" />
        <input type="hidden" name="TargetKey" value="@Model.Event.Slug" />
        <input type="hidden" name="ReturnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
        <label class="form-field">
            <span>@T["Report this event"]</span>
            <select name="Reason">
                <option value="inaccurate-listing">@T["Inaccurate listing"]</option>
                <option value="spam">@T["Spam"]</option>
                <option value="unsafe-contact">@T["Unsafe contact"]</option>
                <option value="other">@T["Other"]</option>
            </select>
        </label>
        <label class="form-field">
            <span>@T["Report details"]</span>
            <textarea name="Details" rows="2" maxlength="2000"></textarea>
        </label>
        <button type="submit" class="button button--secondary button--compact">@T["Send report"]</button>
    </form>
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["RSVP"]</h2>
    <p class="body-lg">@T["Save your interest or attendance so the organizer can plan capacity."]</p>
    <dl class="detail-list">
        <div>
            <dt>@T["Interested"]</dt>
            <dd>@Model.RsvpSummary.InterestedCount</dd>
        </div>
        <div>
            <dt>@T["Going"]</dt>
            <dd>@Model.RsvpSummary.GoingCount</dd>
        </div>
        @if (Model.RsvpSummary.RemainingCapacity.HasValue)
        {
            <div>
                <dt>@T["Remaining"]</dt>
                <dd>@T["{0} of {1}", Model.RsvpSummary.RemainingCapacity.Value, Model.RsvpSummary.Capacity]</dd>
            </div>
        }
    </dl>
    <form method="post" asp-action="Rsvp" asp-route-slug="@Model.Event.Slug" class="form-grid">
        @Html.AntiForgeryToken()
        <label class="field">
            <span>@T["Name"]</span>
            <input name="ParticipantName" value="@Model.Input.ParticipantName" />
        </label>
        <label class="field">
            <span>@T["Email"]</span>
            <input name="ParticipantEmail" value="@Model.Input.ParticipantEmail" type="email" />
        </label>
        <label class="field">
            <span>@T["Status"]</span>
            <select name="Status">
                <option value="interested" selected="@(Model.Input.Status == "interested")">@T["Interested"]</option>
                <option value="going" selected="@(Model.Input.Status == "going")">@T["Going"]</option>
                <option value="cancelled" selected="@(Model.Input.Status == "cancelled")">@T["Cancel"]</option>
            </select>
        </label>
        <div class="action-row">
            <button type="submit" class="button button--primary">@T["Save RSVP"]</button>
        </div>
    </form>
</section>

@if (Model.PreparationPacks.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Prepare for this event"]</h2>
        <div class="grid-two-col">
            @foreach (var preparationPack in Model.PreparationPacks)
            {
                <article class="panel stack-md">
                    <span class="eyebrow">@preparationPack.CefrLevel · @preparationPack.EventType · @preparationPack.Category</span>
                    <h3 class="headline-sm">
                        <a asp-controller="EventPreparationPacks" asp-action="Detail" asp-route-slug="@preparationPack.Slug">@preparationPack.Title</a>
                    </h3>
                    <p>@preparationPack.Description</p>
                    <a class="button button--secondary button--compact" asp-controller="EventPreparationPacks" asp-action="Detail" asp-route-slug="@preparationPack.Slug">@T["Prepare for this event"]</a>
                </article>
            }
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.Event.SourceName) || Model.Event.LastVerifiedAtUtc.HasValue)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Listing information"]</h2>
        <p>
            @if (!string.IsNullOrWhiteSpace(Model.Event.SourceUrl))
            {
                <a href="@Model.Event.SourceUrl" rel="noopener noreferrer" target="_blank">@Model.Event.SourceName</a>
            }
            else
            {
                @Model.Event.SourceName
            }
            @if (Model.Event.LastVerifiedAtUtc.HasValue)
            {
                <span> · @T["verified {0}", Model.Event.LastVerifiedAtUtc.Value.ToString("yyyy-MM-dd")]</span>
            }
        </p>
    </section>
}
