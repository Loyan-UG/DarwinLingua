@model DarwinLingua.Web.Models.WordDetailPageViewModel
@{
    ViewData["Title"] = Model.Word.Lemma;
    string requestPath = $"{Context.Request.Path}{Context.Request.QueryString}";
    string summaryLine = string.Join(" · ", new[]
    {
        Model.Word.Article,
        Model.Word.PluralForm,
        Model.Word.InfinitiveForm,
        Model.Word.PronunciationIpa,
        Model.Word.SyllableBreak
    }.Where(static value => !string.IsNullOrWhiteSpace(value)));
}

<section class="panel stack-lg">
    <span class="eyebrow">@Model.Word.CefrLevel · @Model.Word.PartOfSpeech</span>
    <h1 class="headline-md">@Model.Word.Lemma</h1>
    @if (!string.IsNullOrWhiteSpace(summaryLine))
    {
        <p class="body-lg">@summaryLine</p>
    }

    <div class="meta-grid">
        <div class="meta-chip">
            <strong>Viewed</strong>
            <span>@Model.WordState.ViewCount times</span>
        </div>
        @if (Model.WordState.LastViewedAtUtc is DateTime lastViewedAtUtc)
        {
            <div class="meta-chip">
                <strong>Last viewed</strong>
                <span>@lastViewedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
            </div>
        }
        @if (Model.WordState.IsKnown)
        {
            <div class="meta-chip">
                <strong>Status</strong>
                <span>Known</span>
            </div>
        }
        @if (Model.WordState.IsDifficult)
        {
            <div class="meta-chip">
                <strong>Focus</strong>
                <span>Difficult</span>
            </div>
        }
    </div>

    <div class="action-row">
        <form method="post" asp-action="ToggleFavorite" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Word.PublicId" />
            <input type="hidden" name="returnUrl" value="@requestPath" />
            <button type="submit" class="button @(Model.IsFavorite ? "button--primary" : "button--secondary")">
                @(Model.IsFavorite ? "Favorited" : "Add to favorites")
            </button>
        </form>
        <form method="post" asp-action="ToggleKnown" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Word.PublicId" />
            <input type="hidden" name="returnUrl" value="@requestPath" />
            <button type="submit" class="button @(Model.WordState.IsKnown ? "button--primary" : "button--secondary")">
                @(Model.WordState.IsKnown ? "Known" : "Mark known")
            </button>
        </form>
        <form method="post" asp-action="ToggleDifficult" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Word.PublicId" />
            <input type="hidden" name="returnUrl" value="@requestPath" />
            <button type="submit" class="button @(Model.WordState.IsDifficult ? "button--primary" : "button--secondary")">
                @(Model.WordState.IsDifficult ? "Difficult" : "Mark difficult")
            </button>
        </form>
        <a class="button button--secondary" asp-controller="Favorites" asp-action="Index">Favorites</a>
    </div>
</section>

@if (Model.Word.LexicalForms.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Word forms</h2>
        <div class="stack-md">
            @foreach (var form in Model.Word.LexicalForms)
            {
                <div class="detail-row">
                    <strong>@form.PartOfSpeech@(form.IsPrimary ? " · primary" : string.Empty)</strong>
                    <span>@string.Join(" · ", new[] { form.Article, form.PluralForm, form.InfinitiveForm }.Where(static value => !string.IsNullOrWhiteSpace(value)))</span>
                </div>
            }
        </div>
    </section>
}

@if (Model.Word.Senses.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Meanings and examples</h2>
        <div class="stack-md">
            @foreach (var sense in Model.Word.Senses)
            {
                <article class="panel stack-md">
                    @if (!string.IsNullOrWhiteSpace(sense.ShortDefinitionDe))
                    {
                        <strong>@sense.ShortDefinitionDe</strong>
                    }
                    @if (!string.IsNullOrWhiteSpace(sense.PrimaryMeaning))
                    {
                        <p class="body-lg">@sense.PrimaryMeaning</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(sense.SecondaryMeaning))
                    {
                        <p>@sense.SecondaryMeaning</p>
                    }
                    @if (sense.Examples.Count > 0)
                    {
                        <ul class="feature-list">
                            @foreach (var example in sense.Examples)
                            {
                                <li>
                                    <strong>@example.GermanText</strong>
                                    @if (!string.IsNullOrWhiteSpace(example.PrimaryMeaning))
                                    {
                                        <div>@example.PrimaryMeaning</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(example.SecondaryMeaning))
                                    {
                                        <div>@example.SecondaryMeaning</div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.Word.UsageLabels.Count > 0 || Model.Word.ContextLabels.Count > 0 || Model.Word.GrammarNotes.Count > 0)
{
    <section class="grid-two-col">
        @if (Model.Word.UsageLabels.Count > 0 || Model.Word.ContextLabels.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Labels</h2>
                <div class="chip-grid">
                    @foreach (string usageLabel in Model.Word.UsageLabels)
                    {
                        <span class="chip-link chip-link--static">@usageLabel</span>
                    }
                    @foreach (string contextLabel in Model.Word.ContextLabels)
                    {
                        <span class="chip-link chip-link--static">@contextLabel</span>
                    }
                </div>
            </article>
        }
        @if (Model.Word.GrammarNotes.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Grammar notes</h2>
                <ul class="feature-list">
                    @foreach (string grammarNote in Model.Word.GrammarNotes)
                    {
                        <li>@grammarNote</li>
                    }
                </ul>
            </article>
        }
    </section>
}

@if (Model.Word.Collocations.Count > 0 || Model.Word.WordFamilies.Count > 0)
{
    <section class="grid-two-col">
        @if (Model.Word.Collocations.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Collocations</h2>
                <ul class="feature-list">
                    @foreach (var collocation in Model.Word.Collocations)
                    {
                        <li>
                            <strong>@collocation.Text</strong>
                            @if (!string.IsNullOrWhiteSpace(collocation.Meaning))
                            {
                                <div>@collocation.Meaning</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
        @if (Model.Word.WordFamilies.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Word family</h2>
                <ul class="feature-list">
                    @foreach (var familyMember in Model.Word.WordFamilies)
                    {
                        <li>
                            <strong>@familyMember.Lemma</strong>
                            <div>@familyMember.RelationLabel</div>
                            @if (!string.IsNullOrWhiteSpace(familyMember.Note))
                            {
                                <div>@familyMember.Note</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
    </section>
}

@if (Model.Word.Synonyms.Count > 0 || Model.Word.Antonyms.Count > 0)
{
    <section class="grid-two-col">
        @if (Model.Word.Synonyms.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Synonyms</h2>
                <ul class="feature-list">
                    @foreach (var synonym in Model.Word.Synonyms)
                    {
                        <li>
                            <strong>@synonym.Lemma</strong>
                            @if (!string.IsNullOrWhiteSpace(synonym.Note))
                            {
                                <div>@synonym.Note</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
        @if (Model.Word.Antonyms.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Antonyms</h2>
                <ul class="feature-list">
                    @foreach (var antonym in Model.Word.Antonyms)
                    {
                        <li>
                            <strong>@antonym.Lemma</strong>
                            @if (!string.IsNullOrWhiteSpace(antonym.Note))
                            {
                                <div>@antonym.Note</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
    </section>
}

@if (Model.Word.Topics.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Topics</h2>
        <div class="chip-grid">
            @foreach (string topic in Model.Word.Topics)
            {
                <a class="chip-link" asp-controller="Browse" asp-action="Topic" asp-route-id="@topic">@topic</a>
            }
        </div>
    </section>
}
