@model DarwinLingua.Web.Models.WordDetailPageViewModel
@{
    ViewData["Title"] = Model.Content.Word.Lemma;
    string summaryLine = string.Join(" · ", new[]
    {
        Model.Content.Word.Article,
        Model.Content.Word.PluralForm,
        Model.Content.Word.InfinitiveForm,
        Model.Content.Word.PronunciationIpa,
        Model.Content.Word.SyllableBreak
    }.Where(static value => !string.IsNullOrWhiteSpace(value)));
}

<section class="panel stack-lg">
    <span class="eyebrow">@Model.Content.Word.CefrLevel · @Model.Content.Word.PartOfSpeech</span>
    <h1 class="headline-md">@Model.Content.Word.Lemma</h1>
    @if (!string.IsNullOrWhiteSpace(summaryLine))
    {
        <p class="body-lg">@summaryLine</p>
    }
    <partial name="_InteractionPanel" model="Model.Content.Interaction" />
</section>

@if (Model.Content.Word.LexicalForms.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Word forms</h2>
        <div class="stack-md">
            @foreach (var form in Model.Content.Word.LexicalForms)
            {
                <div class="detail-row">
                    <strong>@form.PartOfSpeech@(form.IsPrimary ? " · primary" : string.Empty)</strong>
                    <span>@string.Join(" · ", new[] { form.Article, form.PluralForm, form.InfinitiveForm }.Where(static value => !string.IsNullOrWhiteSpace(value)))</span>
                </div>
            }
        </div>
    </section>
}

@if (Model.Content.Word.Senses.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Meanings and examples</h2>
        <div class="stack-md">
            @foreach (var sense in Model.Content.Word.Senses)
            {
                <article class="panel stack-md">
                    @if (!string.IsNullOrWhiteSpace(sense.ShortDefinitionDe))
                    {
                        <strong>@sense.ShortDefinitionDe</strong>
                    }
                    @if (!string.IsNullOrWhiteSpace(sense.PrimaryMeaning))
                    {
                        <p class="body-lg">@sense.PrimaryMeaning</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(sense.SecondaryMeaning))
                    {
                        <p>@sense.SecondaryMeaning</p>
                    }
                    @if (sense.Examples.Count > 0)
                    {
                        <ul class="feature-list">
                            @foreach (var example in sense.Examples)
                            {
                                <li>
                                    <strong>@example.GermanText</strong>
                                    @if (!string.IsNullOrWhiteSpace(example.PrimaryMeaning))
                                    {
                                        <div>@example.PrimaryMeaning</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(example.SecondaryMeaning))
                                    {
                                        <div>@example.SecondaryMeaning</div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.Content.Word.UsageLabels.Count > 0 || Model.Content.Word.ContextLabels.Count > 0 || Model.Content.Word.GrammarNotes.Count > 0)
{
    <section class="grid-two-col">
        @if (Model.Content.Word.UsageLabels.Count > 0 || Model.Content.Word.ContextLabels.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Labels</h2>
                <div class="chip-grid">
                    @foreach (string usageLabel in Model.Content.Word.UsageLabels)
                    {
                        <span class="chip-link chip-link--static">@usageLabel</span>
                    }
                    @foreach (string contextLabel in Model.Content.Word.ContextLabels)
                    {
                        <span class="chip-link chip-link--static">@contextLabel</span>
                    }
                </div>
            </article>
        }
        @if (Model.Content.Word.GrammarNotes.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Grammar notes</h2>
                <ul class="feature-list">
                    @foreach (string grammarNote in Model.Content.Word.GrammarNotes)
                    {
                        <li>@grammarNote</li>
                    }
                </ul>
            </article>
        }
    </section>
}

@if (Model.Content.Word.Collocations.Count > 0 || Model.Content.Word.WordFamilies.Count > 0)
{
    <section class="grid-two-col">
        @if (Model.Content.Word.Collocations.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Collocations</h2>
                <ul class="feature-list">
                    @foreach (var collocation in Model.Content.Word.Collocations)
                    {
                        <li>
                            <strong>@collocation.Text</strong>
                            @if (!string.IsNullOrWhiteSpace(collocation.Meaning))
                            {
                                <div>@collocation.Meaning</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
        @if (Model.Content.Word.WordFamilies.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Word family</h2>
                <ul class="feature-list">
                    @foreach (var familyMember in Model.Content.Word.WordFamilies)
                    {
                        <li>
                            <strong>@familyMember.Lemma</strong>
                            <div>@familyMember.RelationLabel</div>
                            @if (!string.IsNullOrWhiteSpace(familyMember.Note))
                            {
                                <div>@familyMember.Note</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
    </section>
}

@if (Model.Content.Word.Synonyms.Count > 0 || Model.Content.Word.Antonyms.Count > 0)
{
    <section class="grid-two-col">
        @if (Model.Content.Word.Synonyms.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Synonyms</h2>
                <ul class="feature-list">
                    @foreach (var synonym in Model.Content.Word.Synonyms)
                    {
                        <li>
                            <strong>@synonym.Lemma</strong>
                            @if (!string.IsNullOrWhiteSpace(synonym.Note))
                            {
                                <div>@synonym.Note</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
        @if (Model.Content.Word.Antonyms.Count > 0)
        {
            <article class="panel stack-md">
                <h2 class="headline-sm">Antonyms</h2>
                <ul class="feature-list">
                    @foreach (var antonym in Model.Content.Word.Antonyms)
                    {
                        <li>
                            <strong>@antonym.Lemma</strong>
                            @if (!string.IsNullOrWhiteSpace(antonym.Note))
                            {
                                <div>@antonym.Note</div>
                            }
                        </li>
                    }
                </ul>
            </article>
        }
    </section>
}

@if (Model.Content.Word.Topics.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">Topics</h2>
        <div class="chip-grid">
            @foreach (string topic in Model.Content.Word.Topics)
            {
                <a class="chip-link" asp-controller="Browse" asp-action="Topic" asp-route-id="@topic">@topic</a>
            }
        </div>
    </section>
}
