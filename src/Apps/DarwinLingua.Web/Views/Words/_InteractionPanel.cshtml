@model DarwinLingua.Web.Models.WordInteractionPanelViewModel

<div id="word-interaction-panel" class="stack-lg">
    @if (!string.IsNullOrWhiteSpace(Model.FavoriteLockedMessage))
    {
        <div class="panel panel--muted">
            <strong>@T["Favorites need account access"]</strong>
            <p>@Model.FavoriteLockedMessage</p>
        </div>
    }

    @if (Model.WordState.IsKnown || Model.WordState.IsDifficult)
    {
        <div class="meta-grid">
            @if (Model.WordState.IsKnown)
            {
                <div class="meta-chip">
                    <strong>@T["Status"]</strong>
                    <span>@T["Known"]</span>
                </div>
            }
            @if (Model.WordState.IsDifficult)
            {
                <div class="meta-chip">
                    <strong>@T["Focus"]</strong>
                    <span>@T["Difficult"]</span>
                </div>
            }
        </div>
    }

    <div class="action-row">
        <form method="post" asp-action="ToggleKnown" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.WordPublicId" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button
                type="submit"
                class="button @(Model.WordState.IsKnown ? "button--primary" : "button--secondary")"
                hx-post="@Url.Action("ToggleKnown", "Words")"
                hx-target="#word-interaction-panel"
                hx-swap="outerHTML">
                @(Model.WordState.IsKnown ? T["Known"] : T["Mark known"])
            </button>
        </form>
        <form method="post" asp-action="ToggleDifficult" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.WordPublicId" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button
                type="submit"
                class="button @(Model.WordState.IsDifficult ? "button--primary" : "button--secondary")"
                hx-post="@Url.Action("ToggleDifficult", "Words")"
                hx-target="#word-interaction-panel"
                hx-swap="outerHTML">
                @(Model.WordState.IsDifficult ? T["Difficult"] : T["Mark difficult"])
            </button>
        </form>
        <a class="button button--secondary" asp-controller="Favorites" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Open favorites"]</a>
    </div>
</div>
