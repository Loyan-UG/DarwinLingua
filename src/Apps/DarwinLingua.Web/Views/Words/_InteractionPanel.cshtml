@model DarwinLingua.Web.Models.WordInteractionPanelViewModel

<div id="word-interaction-panel" class="stack-lg">
    <div class="meta-grid">
        <div class="meta-chip">
            <strong>Viewed</strong>
            <span>@Model.WordState.ViewCount times</span>
        </div>
        @if (Model.WordState.LastViewedAtUtc is DateTime lastViewedAtUtc)
        {
            <div class="meta-chip">
                <strong>Last viewed</strong>
                <span>@lastViewedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
            </div>
        }
        @if (Model.WordState.IsKnown)
        {
            <div class="meta-chip">
                <strong>Status</strong>
                <span>Known</span>
            </div>
        }
        @if (Model.WordState.IsDifficult)
        {
            <div class="meta-chip">
                <strong>Focus</strong>
                <span>Difficult</span>
            </div>
        }
    </div>

    <div class="action-row">
        <form method="post" asp-action="ToggleFavorite" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.WordPublicId" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button
                type="submit"
                class="button @(Model.IsFavorite ? "button--primary" : "button--secondary")"
                hx-post="@Url.Action("ToggleFavorite", "Words")"
                hx-target="#word-interaction-panel"
                hx-swap="outerHTML">
                @(Model.IsFavorite ? "Favorited" : "Add to favorites")
            </button>
        </form>
        <form method="post" asp-action="ToggleKnown" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.WordPublicId" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button
                type="submit"
                class="button @(Model.WordState.IsKnown ? "button--primary" : "button--secondary")"
                hx-post="@Url.Action("ToggleKnown", "Words")"
                hx-target="#word-interaction-panel"
                hx-swap="outerHTML">
                @(Model.WordState.IsKnown ? "Known" : "Mark known")
            </button>
        </form>
        <form method="post" asp-action="ToggleDifficult" class="inline-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.WordPublicId" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button
                type="submit"
                class="button @(Model.WordState.IsDifficult ? "button--primary" : "button--secondary")"
                hx-post="@Url.Action("ToggleDifficult", "Words")"
                hx-target="#word-interaction-panel"
                hx-swap="outerHTML">
                @(Model.WordState.IsDifficult ? "Difficult" : "Mark difficult")
            </button>
        </form>
        <a class="button button--secondary" asp-controller="Favorites" asp-action="Index">Favorites</a>
    </div>
</div>
