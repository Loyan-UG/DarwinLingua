@model DarwinLingua.Web.Models.WritingTemplateIndexPageViewModel
@{
    ViewData["Title"] = T["Writing Templates"];
    string targetLearningLanguageCode = LearningRouteConventions.ResolveTargetLearningLanguageCode(Context);
    string FormatCefrLevel(string level) => LearningPortalFilterConventions.FormatCefrLevelOption(level, targetLearningLanguageCode, key => T[key].Value);
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
    string secondaryMeaningDirection = string.IsNullOrWhiteSpace(Model.SecondaryMeaningLanguageCode)
        ? "ltr"
        : TextDirection.FromLanguageCode(Model.SecondaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Resources"]</span>
    <h1 class="headline-md">@T["Writing Templates"]</h1>
    <p class="body-lg">@T["Practical German message and exam-writing templates with variables, examples, and linked learning content."]</p>
    <form class="search-form" method="get" asp-controller="WritingTemplates" asp-route-targetLearningLanguageCode="@targetLearningLanguageCode" asp-action="Index">
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search writing templates"]" aria-label="@T["Search writing templates"]" />
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in Model.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.SelectedCefrLevel, level, StringComparison.OrdinalIgnoreCase))">@FormatCefrLevel(level)</option>
            }
        </select>
        <select class="search-input" name="category" aria-label="@T["Category"]">
            <option value="">@T["All categories"]</option>
            @foreach (string category in Model.Categories)
            {
                <option value="@category" selected="@(string.Equals(Model.SelectedCategory, category, StringComparison.OrdinalIgnoreCase))">@T[category]</option>
            }
        </select>
        <select class="search-input" name="register" aria-label="@T["Register"]">
            <option value="">@T["All registers"]</option>
            @foreach (string register in Model.Registers)
            {
                <option value="@register" selected="@(string.Equals(Model.SelectedRegister, register, StringComparison.OrdinalIgnoreCase))">@T[register == "workplace" ? "Workplace" : register]</option>
            }
        </select>
        <button type="submit" class="button button--secondary">@T["Filter"]</button>
    </form>
</section>

@if (Model.Templates.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Writing templates are being prepared"].Value, T["Dynamic writing templates will appear here after the first validated template package is imported."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var template in Model.Templates)
        {
            var primaryTemplate = template.Template;
            var secondaryTemplate = template.SecondaryLanguageTemplate;
            <article class="panel stack-md">
                <span class="eyebrow">@FormatCefrLevel(primaryTemplate.CefrLevel) · @T[primaryTemplate.Category] · @T[primaryTemplate.Register == "workplace" ? "Workplace" : primaryTemplate.Register]</span>
                <h2 class="headline-sm"><a asp-controller="WritingTemplates" asp-route-targetLearningLanguageCode="@targetLearningLanguageCode" asp-action="Detail" asp-route-slug="@primaryTemplate.Slug">@primaryTemplate.Title</a></h2>
                <p>@primaryTemplate.ShortDescription</p>
                @if (!string.IsNullOrWhiteSpace(primaryTemplate.LearnerLanguageTitle) ||
                    !string.IsNullOrWhiteSpace(primaryTemplate.LearnerLanguageShortDescription) ||
                    !string.IsNullOrWhiteSpace(secondaryTemplate?.LearnerLanguageTitle) ||
                    !string.IsNullOrWhiteSpace(secondaryTemplate?.LearnerLanguageShortDescription))
                {
                    <div class="learning-helper">
                        @if (!string.IsNullOrWhiteSpace(primaryTemplate.LearnerLanguageTitle))
                        {
                            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> <strong>@primaryTemplate.LearnerLanguageTitle</strong></p>
                        }
                        @if (!string.IsNullOrWhiteSpace(primaryTemplate.LearnerLanguageShortDescription))
                        {
                            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @primaryTemplate.LearnerLanguageShortDescription</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(secondaryTemplate?.LearnerLanguageTitle))
                        {
                            <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> <strong>@secondaryTemplate.LearnerLanguageTitle</strong></p>
                        }
                        @if (!string.IsNullOrWhiteSpace(secondaryTemplate?.LearnerLanguageShortDescription))
                        {
                            <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @secondaryTemplate.LearnerLanguageShortDescription</p>
                        }
                    </div>
                }
                <p>@primaryTemplate.Situation</p>
                @if (!string.IsNullOrWhiteSpace(primaryTemplate.LearnerLanguageSituation))
                {
                    <p class="meaning-line text-muted" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @primaryTemplate.LearnerLanguageSituation</p>
                }
                @if (!string.IsNullOrWhiteSpace(secondaryTemplate?.LearnerLanguageSituation))
                {
                    <p class="meaning-line text-muted" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @secondaryTemplate.LearnerLanguageSituation</p>
                }
                <a class="button button--secondary" asp-controller="WritingTemplates" asp-route-targetLearningLanguageCode="@targetLearningLanguageCode" asp-action="Detail" asp-route-slug="@primaryTemplate.Slug">@T["Open writing template"]</a>
            </article>
        }
    </section>
}
