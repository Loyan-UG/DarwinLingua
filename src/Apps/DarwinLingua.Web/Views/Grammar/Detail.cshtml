@using DarwinLingua.SharedKernel.Lexicon
@model DarwinLingua.Web.Models.GrammarDetailPageViewModel
@{
    ViewData["Title"] = Model.GrammarTopic.Title;
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
}

<section class="grammar-detail-hero">
    <div class="grammar-detail-hero__main">
        <div class="detail-toolbar">
            <span class="eyebrow">@Model.GrammarTopic.CefrLevel · @T[Model.GrammarTopic.GrammarCategory]</span>
            <div class="detail-toolbar__actions">
                <a class="button button--secondary button--compact" asp-controller="Grammar" asp-action="Index">@T["All Grammar Topics"]</a>
            </div>
        </div>
        <h1 class="headline-md">@Model.GrammarTopic.Title</h1>
        <p class="body-lg">@Model.GrammarTopic.ShortDescription</p>
        @if (Model.GrammarTopic.TopicKeys.Count > 0)
        {
            <div class="chip-grid">
                @foreach (string topicKey in Model.GrammarTopic.TopicKeys)
                {
                    <span class="chip-link">@topicKey</span>
                }
            </div>
        }
    </div>
    <aside class="grammar-detail-hero__summary" aria-label="@T["Topic summary"]">
        <div>
            <span>@T["Sections"]</span>
            <strong>@Model.GrammarTopic.Sections.Count</strong>
        </div>
        <div>
            <span>@T["Examples"]</span>
            <strong>@Model.GrammarTopic.Examples.Count</strong>
        </div>
        <div>
            <span>@T["Common mistakes"]</span>
            <strong>@Model.GrammarTopic.CommonMistakes.Count</strong>
        </div>
    </aside>
</section>

@if (Model.GrammarTopic.Sections.Count > 0)
{
    <section class="grammar-detail-layout">
        <aside class="grammar-topic-nav panel" aria-label="@T["Lesson sections"]">
            <h2 class="eyebrow">@T["Explanation"]</h2>
            <ol>
                @foreach (var grammarSection in Model.GrammarTopic.Sections)
                {
                    <li><a href="#section-@grammarSection.SectionKey">@grammarSection.Heading</a></li>
                }
            </ol>
        </aside>
        <div class="grammar-topic-content" dir="@primaryMeaningDirection">
            @foreach (var grammarSection in Model.GrammarTopic.Sections)
            {
                <article class="grammar-section panel" id="section-@grammarSection.SectionKey">
                    <header class="grammar-section__header">
                        <span class="eyebrow">@T["Explanation"]</span>
                        <h3 class="headline-sm">@grammarSection.Heading</h3>
                    </header>
                    @if (grammarSection.Blocks.Count > 0)
                    {
                        foreach (var block in grammarSection.Blocks)
                        {
                            switch (block.Type)
                            {
                                case "paragraph":
                                    if (!string.IsNullOrWhiteSpace(block.Text))
                                    {
                                        <p class="grammar-paragraph">@block.Text</p>
                                    }
                                    break;
                                case "table":
                                    <figure class="grammar-table-wrap">
                                        @if (!string.IsNullOrWhiteSpace(block.Caption))
                                        {
                                            <figcaption>@block.Caption</figcaption>
                                        }
                                        <table class="grammar-table">
                                            <thead>
                                                <tr>
                                                    @foreach (string column in block.Columns)
                                                    {
                                                        <th>@column</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in block.Rows)
                                                {
                                                    <tr>
                                                        @foreach (string cell in row)
                                                        {
                                                            <td>@cell</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </figure>
                                    break;
                                case "callout":
                                    if (!string.IsNullOrWhiteSpace(block.Text))
                                    {
                                        <aside class="grammar-callout grammar-callout--@block.Style">@block.Text</aside>
                                    }
                                    break;
                                case "rule-list":
                                case "example-list":
                                    <ul class="grammar-bullet-list">
                                        @foreach (string item in block.Items)
                                        {
                                            <li>@item</li>
                                        }
                                    </ul>
                                    break;
                                case "mistake-pair":
                                    <div class="grammar-mistake-pair">
                                        @if (!string.IsNullOrWhiteSpace(block.Wrong))
                                        {
                                            <p><strong>@T["Avoid"]:</strong> <span class="dialogue-german-text">@block.Wrong</span></p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(block.Correct))
                                        {
                                            <p><strong>@T["Use"]:</strong> <span class="dialogue-german-text">@block.Correct</span></p>
                                        }
                                    </div>
                                    break;
                                case "image-slot":
                                    <div class="grammar-image-slot">
                                        <span class="eyebrow">@T["Image"]</span>
                                    </div>
                                    break;
                            }
                        }
                    }
                    else
                    {
                        foreach (string paragraph in grammarSection.Explanation.Split(["\r\n\r\n", "\n\n"], StringSplitOptions.RemoveEmptyEntries))
                        {
                            <p class="grammar-paragraph">@paragraph.Trim()</p>
                        }
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.GrammarTopic.Examples.Count > 0)
{
    <section class="panel grammar-reference-section">
        <div class="section-heading">
            <h2 class="headline-sm">@T["German examples"]</h2>
            <span class="eyebrow">@Model.GrammarTopic.Examples.Count</span>
        </div>
        <div class="grammar-example-grid">
            @foreach (var example in Model.GrammarTopic.Examples)
            {
                <article class="grammar-example-card">
                    <strong class="dialogue-german-text">@example.GermanText</strong>
                    @if (!string.IsNullOrWhiteSpace(example.Translation))
                    {
                        <div class="dialogue-translation-line" dir="@primaryMeaningDirection">
                            <span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span>
                            <span>@example.Translation</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(example.Note))
                    {
                        <p>@example.Note</p>
                    }
                </article>
            }
        </div>
    </section>
}

@if (Model.GrammarTopic.RuleSummaries.Count > 0)
{
    <section class="panel grammar-reference-section">
        <div class="section-heading">
            <h2 class="headline-sm">@T["Mini rules"]</h2>
            <span class="eyebrow">@Model.GrammarTopic.RuleSummaries.Count</span>
        </div>
        <ul class="grammar-rule-grid" dir="@primaryMeaningDirection">
            @foreach (var rule in Model.GrammarTopic.RuleSummaries)
            {
                <li>@rule.Text</li>
            }
        </ul>
    </section>
}

@if (Model.GrammarTopic.CommonMistakes.Count > 0)
{
    <section class="panel grammar-reference-section">
        <div class="section-heading">
            <h2 class="headline-sm">@T["Common mistakes"]</h2>
            <span class="eyebrow">@Model.GrammarTopic.CommonMistakes.Count</span>
        </div>
        <div class="grammar-mistake-grid">
            @foreach (var mistake in Model.GrammarTopic.CommonMistakes)
            {
                <article class="grammar-mistake-card">
                    <p><strong>@T["Avoid"]:</strong> <span class="dialogue-german-text">@mistake.WrongText</span></p>
                    <p><strong>@T["Use"]:</strong> <span class="dialogue-german-text">@mistake.CorrectedText</span></p>
                    <p dir="@primaryMeaningDirection">@mistake.Explanation</p>
                </article>
            }
        </div>
    </section>
}

@if (Model.GrammarTopic.ExceptionNotes.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Exceptions"]</h2>
        <ul class="stack-sm" dir="@primaryMeaningDirection">
            @foreach (var note in Model.GrammarTopic.ExceptionNotes)
            {
                <li>@note.Text</li>
            }
        </ul>
    </section>
}

@if (Model.GrammarTopic.LinkedWords.Count > 0 || Model.GrammarTopic.LinkedDialogueSlugs.Count > 0 || Model.GrammarTopic.LinkedTalkTopicSlugs.Count > 0 || Model.GrammarTopic.LinkedExerciseSlugs.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Linked practice"]</h2>
        @if (Model.GrammarTopic.LinkedWords.Count > 0)
        {
            <h3 class="eyebrow">@T["Words"]</h3>
            <p>
                @for (int index = 0; index < Model.GrammarTopic.LinkedWords.Count; index++)
                {
                    var word = Model.GrammarTopic.LinkedWords[index];
                    if (!string.IsNullOrWhiteSpace(word.WordSlug))
                    {
                        <a asp-controller="Words" asp-action="Detail" asp-route-slug="@word.WordSlug">@word.Lemma</a>
                    }
                    else
                    {
                        <span>@word.Lemma</span>
                    }
                    @if (index < Model.GrammarTopic.LinkedWords.Count - 1)
                    {
                        <span>, </span>
                    }
                }
            </p>
        }
        @if (Model.GrammarTopic.LinkedDialogueSlugs.Count > 0)
        {
            <h3 class="eyebrow">@T["Dialogues"]</h3>
            <div class="chip-grid">
                @foreach (string slug in Model.GrammarTopic.LinkedDialogueSlugs)
                {
                    <a class="chip-link" asp-controller="Dialogues" asp-action="Detail" asp-route-slug="@slug">@slug</a>
                }
            </div>
        }
        @if (Model.GrammarTopic.LinkedTalkTopicSlugs.Count > 0)
        {
            <h3 class="eyebrow">@T["Talk Topics"]</h3>
            <div class="chip-grid">
                @foreach (string slug in Model.GrammarTopic.LinkedTalkTopicSlugs)
                {
                    <a class="chip-link" asp-controller="TalkTopics" asp-action="Detail" asp-route-slug="@slug">@slug</a>
                }
            </div>
        }
        @if (Model.GrammarTopic.LinkedExerciseSlugs.Count > 0)
        {
            <h3 class="eyebrow">@T["Exercises"]</h3>
            <div class="chip-grid">
                @foreach (string slug in Model.GrammarTopic.LinkedExerciseSlugs)
                {
                    <a class="chip-link" asp-controller="Exercises" asp-action="Detail" asp-route-slug="@slug">@slug</a>
                }
            </div>
        }
    </section>
}

@if (Model.GrammarTopic.PrerequisiteSlugs.Count > 0 || Model.GrammarTopic.RelatedTopicSlugs.Count > 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Next topics"]</h2>
        @if (Model.GrammarTopic.PrerequisiteSlugs.Count > 0)
        {
            <h3 class="eyebrow">@T["Prerequisites"]</h3>
            <div class="chip-grid">
                @foreach (string slug in Model.GrammarTopic.PrerequisiteSlugs)
                {
                    <a class="chip-link" asp-controller="Grammar" asp-action="Detail" asp-route-slug="@slug">@slug</a>
                }
            </div>
        }
        @if (Model.GrammarTopic.RelatedTopicSlugs.Count > 0)
        {
            <h3 class="eyebrow">@T["Related grammar"]</h3>
            <div class="chip-grid">
                @foreach (string slug in Model.GrammarTopic.RelatedTopicSlugs)
                {
                    <a class="chip-link" asp-controller="Grammar" asp-action="Detail" asp-route-slug="@slug">@slug</a>
                }
            </div>
        }
    </section>
}
