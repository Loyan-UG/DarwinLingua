@model DarwinLingua.Web.Models.GrammarIndexPageViewModel
@{
    ViewData["Title"] = T["Grammar Guide"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Grammar Guide"]</span>
    <h1 class="headline-md">@T["Grammar topics for structured German learning"]</h1>
    <p class="body-lg">@T["Review grammar explanations in your learning language while keeping German examples at the center."]</p>

    <form class="search-form" method="get" asp-controller="Grammar" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search grammar"]" aria-label="@T["Search grammar"]" />
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in Model.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.SelectedCefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
            }
        </select>
        <select class="search-input" name="grammarCategory" aria-label="@T["Grammar category"]">
            <option value="">@T["All grammar categories"]</option>
            @foreach (string category in Model.GrammarCategories)
            {
                <option value="@category" selected="@(string.Equals(Model.SelectedGrammarCategory, category, StringComparison.OrdinalIgnoreCase))">@T[category]</option>
            }
        </select>
        <select class="search-input" name="topic" aria-label="@T["Topic"]">
            <option value="">@T["All topics"]</option>
            @foreach (string topicKey in Model.TopicKeys)
            {
                <option value="@topicKey" selected="@(string.Equals(Model.SelectedTopicKey, topicKey, StringComparison.OrdinalIgnoreCase))">@topicKey</option>
            }
        </select>
        <button type="submit" class="button button--secondary">@T["Filter"]</button>
    </form>
</section>

@if (Model.GrammarTopics.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Grammar topics are being prepared"].Value, T["Dynamic Grammar Guide content will appear here after the first validated grammar package is imported."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var topic in Model.GrammarTopics)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@topic.CefrLevel · @T[topic.GrammarCategory]</span>
                <h2 class="headline-sm">
                    <a asp-controller="Grammar" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Detail" asp-route-slug="@topic.Slug">@topic.Title</a>
                </h2>
                <p>@topic.ShortDescription</p>
                @if (topic.TopicKeys.Count > 0)
                {
                    <div class="chip-grid">
                        @foreach (string topicKey in topic.TopicKeys)
                        {
                            <a class="chip-link" asp-controller="Grammar" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index" asp-route-topic="@topicKey">@topicKey</a>
                        }
                    </div>
                }
                <div class="action-row">
                    <a class="button button--secondary" asp-controller="Grammar" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Detail" asp-route-slug="@topic.Slug">@T["Open Grammar Topic"]</a>
                </div>
            </article>
        }
    </section>
}
