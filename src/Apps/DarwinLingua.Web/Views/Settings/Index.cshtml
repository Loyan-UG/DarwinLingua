@model DarwinLingua.Web.Models.SettingsPageViewModel
@{
    ViewData["Title"] = T["Settings"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Settings"]</span>
    <h1 class="headline-md">@T["Language preferences"]</h1>
    <p class="body-lg">@T["These preferences keep the language you are learning separate from the interface language and helper translations."]</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-banner--success">@Model.StatusMessage</div>
    }

    <form class="stack-lg" method="post" asp-action="Update">
        @Html.AntiForgeryToken()
        <section class="settings-preference-group">
            <div class="settings-preference-group__intro">
                <span class="eyebrow">@T["Learning language"]</span>
                <h2 class="headline-sm">@T["I want to learn"]</h2>
                <p class="body-sm">@T["This controls which authored learning content, courses, search results, progress, and country guidance you see."]</p>
            </div>
            <label class="field">
                <span>@T["Target learning language"]</span>
                <select asp-for="Input.TargetLearningLanguageCode" asp-items="Model.TargetLearningLanguageOptions"></select>
                <small class="body-sm">@T["Pilot and planned languages stay disabled until reviewed content is available."]</small>
                <span asp-validation-for="Input.TargetLearningLanguageCode" class="validation-message"></span>
            </label>
        </section>

        <section class="settings-preference-group">
            <div class="settings-preference-group__intro">
                <span class="eyebrow">@T["Interface and helper languages"]</span>
                <h2 class="headline-sm">@T["Show and explain"]</h2>
                <p class="body-sm">@T["UI language changes site chrome. Meaning languages explain learning content without replacing the target-language source."]</p>
            </div>
        <div class="form-grid">
            <label class="field">
                <span>@T["UI language"]</span>
                <select asp-for="Input.UiLanguageCode" asp-items="Model.UiLanguageOptions"></select>
                <small class="body-sm">@T["Used for interface text where localization is available."]</small>
                <span asp-validation-for="Input.UiLanguageCode" class="validation-message"></span>
            </label>

            <label class="field">
                <span>@T["Primary meaning language"]</span>
                <select asp-for="Input.PrimaryMeaningLanguageCode" asp-items="Model.MeaningLanguageOptions"></select>
                <small class="body-sm">@T["Shown first in word details, search results, and learning cards."]</small>
                <span asp-validation-for="Input.PrimaryMeaningLanguageCode" class="validation-message"></span>
            </label>

            <label class="field">
                <span>@T["Secondary meaning language"]</span>
                <select asp-for="Input.SecondaryMeaningLanguageCode" asp-items="Model.SecondaryMeaningLanguageOptions" disabled="@(!Model.CanUseDualMeaningLanguage)"></select>
                <small class="body-sm">@T["Optional second meaning column for comparison. It appears beside the primary helper language on supported learning pages."]</small>
                @if (!Model.CanUseDualMeaningLanguage && !string.IsNullOrWhiteSpace(Model.DualMeaningLanguageLockedMessage))
                {
                <span class="validation-message">@Model.DualMeaningLanguageLockedMessage <a asp-controller="Billing" asp-action="Index">@T["View billing"]</a></span>
            }
            </label>
        </div>
        </section>

        <section class="settings-preference-group">
            <div class="settings-preference-group__intro">
                <span class="eyebrow">@T["Content safety"]</span>
                <h2 class="headline-sm">@T["Sensitive educational language"]</h2>
            </div>
            <div class="form-grid">
            <input type="hidden" asp-for="Input.AdultContentAccessState" />
            <label class="field field--checkbox">
                <input asp-for="Input.AllowsRudeSlangContent" />
                <span>@T["Show sensitive educational language"]</span>
                <small class="body-sm">@T["Sensitive Educational Language may include rude words, insults, slang, and mild relationship or emotional expressions for learning and comprehension."]</small>
                <small class="body-sm">@T["It does not show pornographic or explicit adult content and it does not verify age."]</small>
                <small class="body-sm">@T["Sensitive entries include warnings and should be used carefully."]</small>
            </label>
        </div>
        </section>

        <div class="action-row">
            <button type="submit" class="button button--primary">@T["Save preferences"]</button>
            <a class="button button--secondary" asp-controller="Account" asp-action="Index">@T["Back to account"]</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
