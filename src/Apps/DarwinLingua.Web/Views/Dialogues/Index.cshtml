@model DarwinLingua.Web.Models.DialogueIndexPageViewModel
@{
    ViewData["Title"] = T["Dialogues"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Dialogues"]</span>
    <h1 class="headline-md">@T["Practical German dialogues"]</h1>
    <p class="body-lg">@T["Practice dialogue, useful phrases, and quick checks for real-life tasks."]</p>
    @if (Model.TopicKeys.Count > 0)
    {
        <div class="chip-grid">
            <a class="chip-link @(string.IsNullOrWhiteSpace(Model.Filter.TopicKey) ? "is-active" : string.Empty)"
               asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)"
               asp-action="Index"
               asp-route-cefrLevel="@Model.Filter.CefrLevel"
               asp-route-category="@Model.Filter.Category"
               asp-route-examProfile="@Model.Filter.ExamProfile"
               asp-route-skillFocus="@Model.Filter.SkillFocus"
               asp-route-taskType="@Model.Filter.TaskType"
               asp-route-q="@Model.Filter.Query">@T["All topics"]</a>
            @foreach (string topicKey in Model.TopicKeys)
            {
                <a class="chip-link @(string.Equals(Model.Filter.TopicKey, topicKey, StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty)"
                   asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)"
                   asp-action="Index"
                   asp-route-topic="@topicKey"
                   asp-route-cefrLevel="@Model.Filter.CefrLevel"
                   asp-route-category="@Model.Filter.Category"
                   asp-route-examProfile="@Model.Filter.ExamProfile"
                   asp-route-skillFocus="@Model.Filter.SkillFocus"
                   asp-route-taskType="@Model.Filter.TaskType"
                   asp-route-q="@Model.Filter.Query">@topicKey</a>
            }
        </div>
    }
    <form class="search-form" method="get" asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in LearningPortalFilterConventions.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.Filter.CefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
            }
        </select>
        <input class="search-input" type="text" name="category" value="@Model.Filter.Category" placeholder="@T["Category"]" />
        <input class="search-input" type="text" name="examProfile" value="@Model.Filter.ExamProfile" placeholder="@T["Exam profile"]" />
        <input class="search-input" type="text" name="skillFocus" value="@Model.Filter.SkillFocus" placeholder="@T["Skill focus"]" />
        <input class="search-input" type="text" name="taskType" value="@Model.Filter.TaskType" placeholder="@T["Task type"]" />
        @if (!string.IsNullOrWhiteSpace(Model.Filter.TopicKey))
        {
            <input type="hidden" name="topic" value="@Model.Filter.TopicKey" />
        }
        <input class="search-input" type="search" name="q" value="@Model.Filter.Query" placeholder="@T["Search dialogues"]" />
        <button type="submit" class="button button--secondary">@T["Search"]</button>
    </form>
</section>

@if (Model.Dialogues.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Dialogues are being prepared"].Value, T["Guided practice dialogues will appear here when they are ready for study."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var dialogue in Model.Dialogues)
        {
            <article class="panel stack-md">
                <div class="action-row collection-card__meta">
                    <span class="eyebrow">@dialogue.CefrLevel · @dialogue.Category</span>
                    <span>@dialogue.TaskType · @dialogue.Register</span>
                </div>
                <h2 class="headline-sm">
                    <a asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Detail" asp-route-slug="@dialogue.Slug">@dialogue.Title</a>
                </h2>
                <p>@dialogue.Description</p>
                <p class="body-lg">@dialogue.LearnerGoal</p>
                @if (dialogue.TopicKeys.Count > 0)
                {
                    <div class="chip-grid">
                        @foreach (string topicKey in dialogue.TopicKeys)
                        {
                            <a class="chip-link" asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index" asp-route-topic="@topicKey">@topicKey</a>
                        }
                    </div>
                }
                @if (dialogue.ExamProfiles.Count > 0 || dialogue.SkillFocus.Count > 0)
                {
                    <div class="chip-grid">
                        @foreach (string examProfile in dialogue.ExamProfiles.Take(3))
                        {
                            <a class="chip-link" asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index" asp-route-examProfile="@examProfile">@examProfile</a>
                        }
                        @foreach (string focus in dialogue.SkillFocus.Take(3))
                        {
                            <a class="chip-link" asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index" asp-route-skillFocus="@focus">@focus</a>
                        }
                    </div>
                }
                <div class="action-row">
                    <a class="button button--secondary" asp-controller="Dialogues" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Detail" asp-route-slug="@dialogue.Slug">@T["Open dialogue"]</a>
                </div>
            </article>
        }
    </section>
}
