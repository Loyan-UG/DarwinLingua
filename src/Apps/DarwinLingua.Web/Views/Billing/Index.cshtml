@model DarwinLingua.Web.Models.BillingPageViewModel
@{
    ViewData["Title"] = T["Billing"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Billing"]</span>
    <h1 class="headline-md">@T["Plan and access"]</h1>
    <p class="body-lg">@T["Manage your learning access, premium features, and secure subscription checkout."]</p>
    @if (TempData["BillingStatus"] is string statusMessage)
    {
        <div class="status-banner">@statusMessage</div>
    }
    <div class="grid-two-col">
        <article class="panel stack-md plan-card">
            <h2 class="headline-sm">@T["Current plan"]</h2>
            <div class="plan-card__tier">@Model.Entitlement.Tier</div>
            <ul class="feature-list">
                @if (Model.Entitlement.TrialEndsAtUtc is not null)
                {
                    <li>@T["Trial ends"]: @Model.Entitlement.TrialEndsAtUtc.Value.UtcDateTime.ToString("u")</li>
                }
                @if (Model.Entitlement.PremiumEndsAtUtc is not null)
                {
                    <li>@T["Premium renews or expires"]: @Model.Entitlement.PremiumEndsAtUtc.Value.UtcDateTime.ToString("u")</li>
                }
                @if (!string.IsNullOrWhiteSpace(Model.BillingStatus))
                {
                    <li>@T["Billing status"]: @Model.BillingStatus</li>
                }
                @if (Model.CurrentPeriodEndsAtUtc is not null)
                {
                    <li>@T["Current billing period ends"]: @Model.CurrentPeriodEndsAtUtc.Value.UtcDateTime.ToString("u")</li>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ProviderSubscriptionId))
                {
                    <li>@T["Stripe subscription"]: @Model.ProviderSubscriptionId</li>
                }
            </ul>
            <div class="chip-grid">
                @foreach (var feature in Model.Entitlement.EnabledFeatures)
                {
                    <span class="chip-link chip-link--static">@feature</span>
                }
            </div>
        </article>
        <article class="panel stack-md plan-card plan-card--premium">
            <h2 class="headline-sm">@T["Premium monthly"]</h2>
            <p class="body-sm">@T["Unlock favorites, second meaning language, collections, topics, advanced practice, conversation tools, and premium learning workflows."]</p>
            @if (!Model.StripeEnabled)
            {
                <div class="alert alert--danger">@T["Online checkout is not enabled in this environment. Your current access remains unchanged."]</div>
            }
            else if (!Model.StripeConfigured)
            {
                <div class="alert alert--danger">@T["Stripe checkout is enabled but not fully configured. A secret key, webhook secret, and monthly price id are required."]</div>
            }
            else if (Model.CanStartCheckout)
            {
                <form method="post" asp-controller="Billing" asp-action="StartStripeCheckout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="button button--primary">@T["Continue to Stripe"]</button>
                </form>
            }
            else
            {
                <p class="body-sm">@T["Premium access is active."]</p>
                @if (Model.CanManageStripeSubscription)
                {
                    <form method="post" asp-controller="Billing" asp-action="OpenStripePortal">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="button button--secondary">@T["Manage in Stripe"]</button>
                    </form>
                }
                else
                {
                    <p class="body-sm">@T["Subscription management will be available after your premium subscription is linked."]</p>
                }
            }
        </article>
    </div>
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["What Premium adds"]</h2>
        <ul class="feature-list">
            <li>@T["Dual meaning languages on supported learning pages."]</li>
            <li>@T["Favorites, collections, topic browsing, and recent review workflows."]</li>
            <li>@T["Advanced practice, conversation starters, event preparation, and partner tools."]</li>
            <li>@T["Stripe subscription management when a customer record is linked."]</li>
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Billing safety"]</h2>
        <ul class="feature-list">
            <li>@T["Checkout is handled by Stripe; card details are not stored in Darwin Lingua."]</li>
            <li>@T["Subscription changes are applied from Stripe success return and signed webhooks."]</li>
            <li>@T["Payment action, premium activation, and premium end notifications are sent by email."]</li>
        </ul>
    </article>
</section>

<section class="panel stack-md">
    <div class="section-heading">
        <div>
            <span class="eyebrow">@T["Billing activity"]</span>
            <h2 class="headline-sm">@T["Recent Stripe events"]</h2>
        </div>
    </div>
    @if (Model.RecentEvents.Count == 0)
    {
        <p class="body-sm">@T["No Stripe billing events have been recorded for this account yet."]</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@T["Provider"]</th>
                        <th>@T["Event"]</th>
                        <th>@T["Status"]</th>
                        <th>@T["Created"]</th>
                        <th>@T["Processed"]</th>
                        <th>@T["Issue"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentEvents)
                    {
                        <tr>
                            <td>@item.ProviderName</td>
                            <td>@item.EventType</td>
                            <td>@item.Status</td>
                            <td>@item.CreatedAtUtc.UtcDateTime.ToString("u")</td>
                            <td>@(item.ProcessedAtUtc?.UtcDateTime.ToString("u") ?? "-")</td>
                            <td>@(item.ErrorSummary ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
