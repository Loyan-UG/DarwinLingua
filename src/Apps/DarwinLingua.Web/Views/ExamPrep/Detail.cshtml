@model DarwinLingua.Web.Models.ExamPrepDetailPageViewModel
@{
    ViewData["Title"] = Model.Unit.Title;
    string targetLearningLanguageCode = LearningRouteConventions.ResolveTargetLearningLanguageCode(Context);
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <span class="eyebrow">@Model.Unit.CefrLevel · @Model.Unit.ExamProfileKey · @T[Model.Unit.ExamSection] · @T[Model.Unit.TaskType]</span>
    <h1 class="headline-md">@Model.Unit.Title</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Unit.LearnerLanguageTitle))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Unit.LearnerLanguageTitle</p>
    }
    <p class="body-lg">@Model.Unit.ShortDescription</p>
    @if (!string.IsNullOrWhiteSpace(Model.Unit.LearnerLanguageShortDescription))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Unit.LearnerLanguageShortDescription</p>
    }
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Task explanation"]</h2>
    <p>@Model.Unit.Explanation</p>
    @if (!string.IsNullOrWhiteSpace(Model.Unit.LearnerLanguageExplanation))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Unit.LearnerLanguageExplanation</p>
    }
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Strategy notes"]</h2>
        <ul>
            @for (int index = 0; index < Model.Unit.StrategyNotes.Count; index++)
            {
                <li>
                    <span>@Model.Unit.StrategyNotes[index]</span>
                    @if (index >= 0 && index < Model.Unit.LearnerLanguageStrategyNotes.Count && !string.IsNullOrWhiteSpace(Model.Unit.LearnerLanguageStrategyNotes[index]))
                    {
                        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Unit.LearnerLanguageStrategyNotes[index]</p>
                    }
                </li>
            }
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Scoring checklist"]</h2>
        <ul>
            @for (int index = 0; index < Model.Unit.Checklist.Count; index++)
            {
                <li>
                    <span>@Model.Unit.Checklist[index]</span>
                    @if (index >= 0 && index < Model.Unit.LearnerLanguageChecklist.Count && !string.IsNullOrWhiteSpace(Model.Unit.LearnerLanguageChecklist[index]))
                    {
                        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Unit.LearnerLanguageChecklist[index]</p>
                    }
                </li>
            }
        </ul>
    </article>
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Linked practice materials"]</h2>
    <div class="grid-two-col">
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Dialogues"].Value, Model.Unit.LinkedDialogueSlugs, "dialogue", targetLearningLanguageCode, (string?)null)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Writing Templates"].Value, Model.Unit.LinkedWritingTemplateSlugs, "writing-template", targetLearningLanguageCode, (string?)null)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Grammar Guide"].Value, Model.Unit.LinkedGrammarTopicSlugs, "grammar-topic", targetLearningLanguageCode, (string?)null)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Exercises"].Value, Model.Unit.LinkedExerciseSlugs, "exercise", targetLearningLanguageCode, (string?)null)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Roleplays"].Value, Model.Unit.LinkedRoleplaySlugs, "roleplay", targetLearningLanguageCode, (string?)null)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Talk Topics"].Value, Model.Unit.LinkedTalkTopicSlugs, "talk-topic", targetLearningLanguageCode, (string?)null)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Everyday Expressions"].Value, Model.Unit.LinkedExpressionSlugs, "expression", targetLearningLanguageCode, (string?)null)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Course Lessons"].Value, Model.Unit.LinkedCourseLessonSlugs, "course-lesson", targetLearningLanguageCode, (string?)null)' />
    </div>
</section>
