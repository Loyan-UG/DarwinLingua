@model DarwinLingua.Web.Models.ExamPrepIndexPageViewModel
@{
    var selectedProfile = Model.Profiles.FirstOrDefault(profile => string.Equals(Model.SelectedProfile, profile.Key, StringComparison.OrdinalIgnoreCase));
    ViewData["Title"] = selectedProfile is null ? T["Exam Prep"].Value : $"{selectedProfile.DisplayName} - {T["Exam Prep"].Value}";
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <span class="eyebrow">@(selectedProfile is null ? T["Prepare"].Value : $"{T["Prepare"].Value} · {selectedProfile.CefrRange}")</span>
    @if (selectedProfile is null)
    {
        <h1 class="headline-md">@T["Exam Prep"]</h1>
        <p class="body-lg">@T["Original German exam-preparation units linked to practice, dialogues, grammar, writing templates, and speaking topics."]</p>
    }
    else
    {
        <h1 class="headline-md">@selectedProfile.DisplayName</h1>
        @if (!string.IsNullOrWhiteSpace(selectedProfile.LearnerLanguageDisplayName))
        {
            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @selectedProfile.LearnerLanguageDisplayName</p>
        }
        <p class="body-lg">@selectedProfile.Description</p>
        @if (!string.IsNullOrWhiteSpace(selectedProfile.LearnerLanguageDescription))
        {
            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @selectedProfile.LearnerLanguageDescription</p>
        }
    }
    <form class="search-form" method="get" asp-controller="ExamPrep" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search exam prep"]" aria-label="@T["Search exam prep"]" />
        <select class="search-input" name="examProfile" aria-label="@T["Exam profile"]">
            <option value="">@T["All exam profiles"]</option>
            @foreach (var profile in Model.Profiles)
            {
                <option value="@profile.Key" selected="@(string.Equals(Model.SelectedProfile, profile.Key, StringComparison.OrdinalIgnoreCase))">@profile.DisplayName</option>
            }
        </select>
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in Model.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.SelectedCefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
            }
        </select>
        <select class="search-input" name="section" aria-label="@T["Exam section"]">
            <option value="">@T["All sections"]</option>
            @foreach (string examSection in Model.Sections)
            {
                <option value="@examSection" selected="@(string.Equals(Model.SelectedSection, examSection, StringComparison.OrdinalIgnoreCase))">@T[examSection]</option>
            }
        </select>
        <select class="search-input" name="skillFocus" aria-label="@T["Skill focus"]">
            <option value="">@T["All skills"]</option>
            @foreach (string skill in Model.SkillFocuses)
            {
                <option value="@skill" selected="@(string.Equals(Model.SelectedSkillFocus, skill, StringComparison.OrdinalIgnoreCase))">@T[skill]</option>
            }
        </select>
        <button type="submit" class="button button--secondary">@T["Filter"]</button>
    </form>
</section>

@if (selectedProfile is null && Model.Profiles.Count > 0)
{
    <section class="grid-two-col">
        @foreach (var profile in Model.Profiles)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@profile.CefrRange</span>
                <h2 class="headline-sm"><a asp-controller="ExamPrep" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Profile" asp-route-examProfileKey="@profile.Key">@profile.DisplayName</a></h2>
                @if (!string.IsNullOrWhiteSpace(profile.LearnerLanguageDisplayName))
                {
                    <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @profile.LearnerLanguageDisplayName</p>
                }
                <p>@profile.Description</p>
                @if (!string.IsNullOrWhiteSpace(profile.LearnerLanguageDescription))
                {
                    <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @profile.LearnerLanguageDescription</p>
                }
            </article>
        }
    </section>
}

@if (Model.Units.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Exam prep units are being prepared"].Value, T["Dynamic exam-preparation units will appear here after the first validated exam-prep package is imported."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var unit in Model.Units)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@unit.CefrLevel · @unit.ExamProfileKey · @T[unit.ExamSection]</span>
                <h2 class="headline-sm"><a asp-controller="ExamPrep" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Detail" asp-route-slug="@unit.Slug">@unit.Title</a></h2>
                @if (!string.IsNullOrWhiteSpace(unit.LearnerLanguageTitle))
                {
                    <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @unit.LearnerLanguageTitle</p>
                }
                <p>@unit.ShortDescription</p>
                @if (!string.IsNullOrWhiteSpace(unit.LearnerLanguageShortDescription))
                {
                    <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @unit.LearnerLanguageShortDescription</p>
                }
                <p>@T[unit.TaskType] · @T[unit.SkillFocus]</p>
                <a class="button button--secondary" asp-controller="ExamPrep" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Detail" asp-route-slug="@unit.Slug">@T["Open exam prep"]</a>
            </article>
        }
    </section>
}
