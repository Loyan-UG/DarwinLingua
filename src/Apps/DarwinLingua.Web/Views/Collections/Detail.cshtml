@model DarwinLingua.Web.Models.WordCollectionDetailPageViewModel
@{
    ViewData["Title"] = Model.Collection.Name;
}

<section class="panel collection-hero stack-lg">
    @if (!string.IsNullOrWhiteSpace(Model.Collection.ImageUrl))
    {
        <img class="collection-hero__image" src="@Model.Collection.ImageUrl" alt="@Model.Collection.Name" loading="eager" />
    }
    <div class="collection-hero__content stack-md">
        <div class="action-row collection-card__meta">
            <div class="chip-grid">
                @foreach (string level in Model.Collection.CefrLevels)
                {
                    <span class="chip-link chip-link--static">@level</span>
                }
            </div>
            <span class="eyebrow">@T["{0} words", Model.Collection.WordCount]</span>
        </div>
        <h1 class="headline-md">@Model.Collection.Name</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Collection.Description))
        {
            <p class="body-lg">@Model.Collection.Description</p>
        }
        <div class="action-row">
            <a class="button button--secondary" asp-controller="Collections" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Back to collections"]</a>
            <a class="button button--secondary" asp-controller="Browse" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-action="Index">@T["Browse catalog"]</a>
        </div>
    </div>
</section>

@if (Model.Words.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["This collection is being prepared"].Value, T["Words will appear here when the collection is ready for study."].Value)' />
}
else
{
    <section class="panel stack-md">
        <span class="eyebrow">@T["Collection words"]</span>
        <h2 class="headline-sm">@T["Practice this set"]</h2>
        <p class="body-lg">@T["Open any word to hear pronunciation, review meanings, and continue through the set at your own pace."]</p>
    </section>

    <section class="grid-two-col" data-word-list-container>
        @foreach (var word in Model.Words)
        {
            <partial name="~/Views/Shared/_WordCard.cshtml" model="word" />
        }
    </section>
}
