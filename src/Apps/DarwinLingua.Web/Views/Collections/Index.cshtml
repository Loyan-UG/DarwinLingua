@model DarwinLingua.Web.Models.WordCollectionIndexPageViewModel
@{
    ViewData["Title"] = "Collections";
}

<section class="panel stack-lg">
    <span class="eyebrow">Collections</span>
    <h1 class="headline-md">Curated study paths</h1>
    <p class="body-lg">
        Study focused sets built around workplace situations, systems, everyday communication, and practical German topics.
    </p>
</section>

@if (Model.Collections.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel("Collections are being prepared", "Curated study paths will appear here as soon as they are available for your account.")' />
}
else
{
    <section class="grid-two-col">
        @foreach (var collection in Model.Collections)
        {
            <partial name="~/Views/Shared/_WordCollectionCard.cshtml" model="collection" />
        }
    </section>
}
