@model DarwinLingua.Web.Models.WordCollectionIndexPageViewModel
@{
    ViewData["Title"] = T["Collections"];
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Collections"]</span>
    <h1 class="headline-md">@T["Curated study paths"]</h1>
    <p class="body-lg">
        @T["Study focused sets built around workplace situations, systems, everyday communication, and practical German topics."]
    </p>
</section>

@if (Model.Collections.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Collections are being prepared"].Value, T["Curated study paths will appear here as soon as they are available for your account."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var collection in Model.Collections)
        {
            <partial name="~/Views/Shared/_WordCollectionCard.cshtml" model="collection" />
        }
    </section>
}
