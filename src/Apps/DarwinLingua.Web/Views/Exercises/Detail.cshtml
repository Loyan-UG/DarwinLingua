@model DarwinLingua.Web.Models.ExerciseRunnerPageViewModel
@{
    ViewData["Title"] = Model.Exercise.Title;
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <div class="detail-toolbar">
        <span class="eyebrow">@Model.Exercise.CefrLevel · @T[Model.Exercise.ExerciseType] · @T[Model.Exercise.TargetSkill]</span>
        <a class="button button--secondary button--compact" asp-controller="Exercises" asp-action="Index">@T["All exercise sets"]</a>
    </div>
    <h1 class="headline-md">@Model.Exercise.Title</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Exercise.LearnerLanguageTitle))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Exercise.LearnerLanguageTitle</p>
    }
    <p class="body-lg">@Model.Exercise.Instruction</p>
    @if (!string.IsNullOrWhiteSpace(Model.Exercise.LearnerLanguageInstruction))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Exercise.LearnerLanguageInstruction</p>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Exercise.Hint))
    {
        <p><strong>@T["Hint"]:</strong> @Model.Exercise.Hint</p>
        @if (!string.IsNullOrWhiteSpace(Model.Exercise.LearnerLanguageHint))
        {
            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Exercise.LearnerLanguageHint</p>
        }
    }
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Prompt"]</h2>
    <form class="stack-md" method="post" asp-controller="Exercises" asp-action="Submit" asp-route-slug="@Model.Exercise.Slug">
        @Html.AntiForgeryToken()
        @if (!string.IsNullOrWhiteSpace(Model.Prompt.Stem))
        {
            <p class="body-lg">@Model.Prompt.Stem</p>
        }
        @if (Model.Prompt.HasOptions)
        {
            <fieldset class="form-field">
                <legend>@T["Choose answer"]</legend>
                <div class="stack-sm">
                    @foreach (var option in Model.Prompt.Options)
                    {
                        <label class="choice-row">
                            <input type="checkbox" name="selectedOptionIds" value="@option.Id" />
                            <span>@option.Text</span>
                        </label>
                    }
                </div>
            </fieldset>
        }
        else if (Model.Exercise.ExerciseType is "fill-in-the-blank" or "conjugation" or "translation-controlled")
        {
            <label class="form-field">
                <span>@T["Answer"]</span>
                <input name="answer" autocomplete="off" />
            </label>
        }
        else if (Model.Exercise.ExerciseType == "error-correction")
        {
            <label class="form-field">
                <span>@T["Corrected text"]</span>
                <textarea name="correctedText" rows="3"></textarea>
            </label>
        }
        else if (Model.Exercise.ExerciseType == "sentence-ordering")
        {
            <label class="form-field">
                <span>@T["Ordered segments"]</span>
                <textarea name="orderedSegmentsText" rows="6" placeholder="@T["One segment per line"]"></textarea>
            </label>
        }
        else if (Model.Exercise.ExerciseType == "matching")
        {
            <label class="form-field">
                <span>@T["Matched pairs"]</span>
                <textarea name="pairsText" rows="6" placeholder="@T["One pair per line"]"></textarea>
            </label>
        }
        <button class="button button--primary" type="submit">@T["Check answer"]</button>
    </form>
</section>

@if (Model.Result is not null)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@(Model.Result.IsCorrect ? T["correct"] : T["Try again"])</h2>
        <p>@Model.Result.Explanation</p>
        @if (!string.IsNullOrWhiteSpace(Model.Result.LearnerLanguageExplanation))
        {
            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Result.LearnerLanguageExplanation</p>
        }
        @if (!Model.Result.IsCorrect && !string.IsNullOrWhiteSpace(Model.Result.CommonMistakeNote))
        {
            <p><strong>@T["Common mistake"]:</strong> @Model.Result.CommonMistakeNote</p>
            @if (!string.IsNullOrWhiteSpace(Model.Result.LearnerLanguageCommonMistakeNote))
            {
                <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Result.LearnerLanguageCommonMistakeNote</p>
            }
        }
    </section>
}
