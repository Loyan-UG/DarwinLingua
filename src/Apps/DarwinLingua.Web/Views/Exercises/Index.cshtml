@model DarwinLingua.Web.Models.ExerciseIndexPageViewModel
@{
    ViewData["Title"] = T["Exercises"];
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Practice"]</span>
    <h1 class="headline-md">@T["Exercise sets"]</h1>
    <p class="body-lg">@T["Practice with reusable exercises linked to grammar, vocabulary, expressions, dialogues, and lessons."]</p>
    <form class="search-form" method="get" asp-controller="Exercises" asp-action="Index">
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search exercises"]" aria-label="@T["Search exercises"]" />
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in Model.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.SelectedCefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
            }
        </select>
        <button type="submit" class="button button--secondary">@T["Filter"]</button>
    </form>
</section>

@if (Model.ExerciseSets.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Exercises are being prepared"].Value, T["Dynamic exercises will appear here after the first validated exercise package is imported."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var set in Model.ExerciseSets)
        {
            <article class="panel stack-md">
                <span class="eyebrow">@set.CefrLevel · @T[set.OwnerType]</span>
                <h2 class="headline-sm"><a asp-controller="Exercises" asp-action="Set" asp-route-slug="@set.Slug">@set.Title</a></h2>
                @if (!string.IsNullOrWhiteSpace(set.LearnerLanguageTitle))
                {
                    <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @set.LearnerLanguageTitle</p>
                }
                <p>@set.Description</p>
                @if (!string.IsNullOrWhiteSpace(set.LearnerLanguageDescription))
                {
                    <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @set.LearnerLanguageDescription</p>
                }
                <p>@T["{0} exercises", set.ExerciseCount]</p>
                <a class="button button--secondary" asp-controller="Exercises" asp-action="Set" asp-route-slug="@set.Slug">@T["Open exercise set"]</a>
            </article>
        }
    </section>
}
