@model DarwinLingua.Web.Models.PartnerMatchingPageViewModel
@{
    ViewData["Title"] = T["Partners"];
    IReadOnlyList<DarwinLingua.SharedKernel.Globalization.LearningLevelDefinition> levelDefinitions =
        DarwinLingua.Web.Models.LearningPortalFilterConventions.CefrLevelDefinitions;
    IReadOnlyDictionary<string, DarwinLingua.SharedKernel.Globalization.LearningLevelDefinition> levelDefinitionsByCode =
        levelDefinitions.ToDictionary(static level => level.Code, StringComparer.OrdinalIgnoreCase);
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Practice partners"]</span>
    <h1 class="headline-md">@T["Find conversation partners"]</h1>
    <p class="body-lg">@T["Send request-based introductions without open chat. Contact details appear only after a request is accepted."]</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert--success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert--danger">@Model.ErrorMessage</div>
    }
</section>

<section class="panel stack-lg">
    <form method="get" asp-action="Index" class="stack-md">
        <div class="grid-two-col">
            <label class="form-field">
                <span>@T["City or region"]</span>
                <input asp-for="Search.CityRegion" name="CityRegion" />
            </label>
            <label class="form-field">
                <span>@T["Interaction"]</span>
                <select asp-for="Search.InteractionPreference" name="InteractionPreference">
                    <option value="">@T["Any"]</option>
                    <option value="both">@T["Online and in-person"]</option>
                    <option value="online">@T["Online"]</option>
                    <option value="in-person">@T["In-person"]</option>
                </select>
            </label>
            <label class="form-field">
                <span>@T["Learning level"]</span>
                <select asp-for="Search.LearningLevel" name="LearningLevel">
                    <option value="">@T["Any"]</option>
                    @foreach (var level in levelDefinitions)
                    {
                        <option value="@level.Code">@level.Code · @level.DisplayTitle</option>
                    }
                </select>
            </label>
            <label class="form-field">
                <span>@T["Helper language"]</span>
                <input asp-for="Search.HelperLanguageCode" name="HelperLanguageCode" placeholder="en" />
            </label>
        </div>
        <label class="form-field">
            <span>@T["Goal keyword"]</span>
            <input asp-for="Search.GoalKeyword" name="GoalKeyword" />
        </label>
        <div class="action-row">
            <button type="submit" class="button button--primary">@T["Search"]</button>
            <a class="button button--secondary" asp-controller="LearnerConversationProfiles" asp-action="Edit">@T["Edit my profile"]</a>
        </div>
    </form>
</section>

<section class="stack-lg">
    <div class="section-heading">
        <span class="eyebrow">@T["Matches"]</span>
        <h2 class="headline-sm">@T["{0} profiles", Model.Matches.Count]</h2>
    </div>
    @if (Model.Matches.Count == 0)
    {
        <article class="panel stack-sm">
            <p class="body-sm">@T["No matching profiles were found."]</p>
        </article>
    }
    else
    {
        <div class="card-grid">
            @foreach (var profile in Model.Matches)
            {
                <article class="panel stack-md">
                    <div>
                        <h3 class="headline-sm">@profile.DisplayName</h3>
                        <p class="body-sm">@profile.CityRegion</p>
                    </div>
                    <div class="chip-grid">
                        <span class="chip-link chip-link--static">@(levelDefinitionsByCode.TryGetValue(profile.LearningLevel, out var levelDefinition) ? $"{levelDefinition.Code} · {levelDefinition.DisplayTitle}" : profile.LearningLevel)</span>
                        <span class="chip-link chip-link--static">@profile.InteractionPreference</span>
                        <span class="chip-link chip-link--static">@profile.Visibility</span>
                    </div>
                    <p class="body-sm">@profile.ConversationGoals</p>
                    <p class="body-sm">@T["Helper languages"]: @string.Join(", ", profile.HelperLanguageCodes)</p>
                    <form method="post" asp-action="RequestPartner" class="stack-sm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetLearnerProfileId" value="@profile.ProfileId" />
                        <label class="form-field">
                            <span>@T["Opener"]</span>
                            <select name="OpenerTemplateKey">
                                <option value="practice-goals">@T["Compare practice goals"]</option>
                                <option value="same-city">@T["Same city practice"]</option>
                                <option value="online-practice">@T["Online practice"]</option>
                                <option value="event-follow-up">@T["Event follow-up"]</option>
                            </select>
                        </label>
                        <label class="form-field">
                            <span>@T["Short note"]</span>
                            <textarea name="Note" rows="3" maxlength="500"></textarea>
                        </label>
                        <button type="submit" class="button button--secondary">@T["Send request"]</button>
                    </form>
                    <form method="post" asp-controller="Moderation" asp-action="Report" class="stack-sm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetType" value="learner-profile" />
                        <input type="hidden" name="TargetKey" value="@profile.ProfileId" />
                        <input type="hidden" name="ReturnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                        <label class="form-field">
                            <span>@T["Report reason"]</span>
                            <select name="Reason">
                                <option value="spam">@T["Spam"]</option>
                                <option value="harassment">@T["Harassment"]</option>
                                <option value="unsafe-contact">@T["Unsafe contact"]</option>
                                <option value="impersonation">@T["Impersonation"]</option>
                                <option value="other">@T["Other"]</option>
                            </select>
                        </label>
                        <label class="form-field">
                            <span>@T["Report details"]</span>
                            <textarea name="Details" rows="2" maxlength="2000"></textarea>
                        </label>
                        <button type="submit" class="button button--secondary">@T["Report profile"]</button>
                    </form>
                    <form method="post" asp-controller="Moderation" asp-action="Block" class="inline-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetLearnerProfileId" value="@profile.ProfileId" />
                        <input type="hidden" name="ReturnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                        <button type="submit" class="button button--secondary">@T["Block profile"]</button>
                    </form>
                </article>
            }
        </div>
    }
</section>

<section class="panel stack-lg">
    <div class="section-heading">
        <span class="eyebrow">@T["Requests"]</span>
        <h2 class="headline-sm">@T["{0} recent requests", Model.Requests.Count]</h2>
    </div>
    @if (Model.Requests.Count == 0)
    {
        <p class="body-sm">@T["No partner requests yet."]</p>
    }
    else
    {
        <div class="stack-md">
            @foreach (var request in Model.Requests)
            {
                <article class="panel stack-sm">
                    <div class="grid-two-col">
                        <div>
                            <h3 class="headline-sm">@request.OtherDisplayName</h3>
                            <p class="body-sm">@request.Direction · @request.Status · @request.OtherCityRegion</p>
                            <p class="body-sm">@T["Opener"]: @request.OpenerTemplateKey</p>
                            @if (!string.IsNullOrWhiteSpace(request.Note))
                            {
                                <p class="body-sm">@request.Note</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(request.ContactEmail))
                            {
                                <p class="body-sm">@T["Contact"]: @request.ContactEmail</p>
                            }
                            <form method="post" asp-controller="Moderation" asp-action="Report" class="stack-sm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="TargetType" value="partner-request" />
                                <input type="hidden" name="TargetKey" value="@request.Id" />
                                <input type="hidden" name="ReportedUserEmail" value="@request.ContactEmail" />
                                <input type="hidden" name="ReturnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                                <label class="form-field">
                                    <span>@T["Report reason"]</span>
                                    <select name="Reason">
                                        <option value="spam">@T["Spam"]</option>
                                        <option value="harassment">@T["Harassment"]</option>
                                        <option value="unsafe-contact">@T["Unsafe contact"]</option>
                                        <option value="other">@T["Other"]</option>
                                    </select>
                                </label>
                                <label class="form-field">
                                    <span>@T["Report details"]</span>
                                    <textarea name="Details" rows="2" maxlength="2000"></textarea>
                                </label>
                                <button type="submit" class="button button--secondary">@T["Report request"]</button>
                            </form>
                            @if (!string.IsNullOrWhiteSpace(request.ContactEmail))
                            {
                                <form method="post" asp-controller="Moderation" asp-action="Block" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="BlockedEmail" value="@request.ContactEmail" />
                                    <input type="hidden" name="SourcePartnerRequestId" value="@request.Id" />
                                    <input type="hidden" name="ReturnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                                    <button type="submit" class="button button--secondary">@T["Block learner"]</button>
                                </form>
                            }
                        </div>
                        <div class="stack-sm">
                            <span class="body-sm">@T["Expires"]: @request.ExpiresAtUtc.ToString("u")</span>
                            @if (request.Status == "pending" && request.Direction == "incoming")
                            {
                                <form method="post" asp-action="UpdateState" asp-route-requestId="@request.Id" class="action-row">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" name="actionName" value="accept" class="button button--primary">@T["Accept"]</button>
                                    <button type="submit" name="actionName" value="decline" class="button button--secondary">@T["Decline"]</button>
                                    <button type="submit" name="actionName" value="block" class="button button--secondary">@T["Block"]</button>
                                </form>
                            }
                            @if (request.Status == "pending" && request.Direction == "outgoing")
                            {
                                <form method="post" asp-action="UpdateState" asp-route-requestId="@request.Id" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" name="actionName" value="cancel" class="button button--secondary">@T["Cancel"]</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
