@model (string Title, IReadOnlyList<string> Slugs, string ContentType, string TargetLearningLanguageCode)

<div class="stack-sm">
    <h3>@Model.Title</h3>
    @if (Model.Slugs.Count == 0)
    {
        <p>@T["None linked"]</p>
    }
    else
    {
        <ul>
            @foreach (string slug in Model.Slugs)
            {
                string? href = LearningContentLinkResolver.ResolveHref(Model.ContentType, slug, Model.TargetLearningLanguageCode);
                <li>
                    @if (!string.IsNullOrWhiteSpace(href))
                    {
                        <a href="@href">@slug</a>
                    }
                    else
                    {
                        <span>@slug</span>
                    }
                </li>
            }
        </ul>
    }
</div>
