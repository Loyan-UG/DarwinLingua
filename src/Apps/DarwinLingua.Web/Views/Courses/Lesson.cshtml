@model DarwinLingua.Web.Models.CourseLessonPageViewModel
@{
    ViewData["Title"] = Model.Lesson.Title;
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
    var activityBlocks = Model.Lesson.ActivityBlocks
        .OrderBy(static activity => activity.SortOrder)
        .ToArray();
}

<section class="panel stack-lg">
    <span class="eyebrow">@Model.Lesson.CefrLevel · @T["Lesson"] @Model.Lesson.LessonNumber · @T["{0} minutes", Model.Lesson.EstimatedMinutes]</span>
    <h1 class="headline-md">@Model.Lesson.Title</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Lesson.LearnerLanguageTitle))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Lesson.LearnerLanguageTitle</p>
    }
    <p class="body-lg">@Model.Lesson.ShortDescription</p>
    @if (!string.IsNullOrWhiteSpace(Model.Lesson.LearnerLanguageShortDescription))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Lesson.LearnerLanguageShortDescription</p>
    }
    @if (Model.Progress is not null)
    {
        <div class="course-progress-panel" aria-label="@T["Learning progress"]">
            <div class="chip-grid">
                <span class="chip-link chip-link--static">@T["Current progress"]: @T[Model.Progress.State]</span>
            </div>
            <form class="course-progress-actions" method="post" asp-controller="Courses" asp-action="UpdateLessonProgress" asp-route-courseSlug="@Model.Lesson.CoursePathSlug" asp-route-lessonSlug="@Model.Lesson.Slug">
                @Html.AntiForgeryToken()
                <button class="button button--secondary button--compact" type="submit" name="state" value="in-progress">@T["Continue later"]</button>
                <button class="button button--primary button--compact" type="submit" name="state" value="completed">@T["Mark completed"]</button>
                <button class="button button--secondary button--compact" type="submit" name="state" value="needs-review">@T["Review again"]</button>
            </form>
        </div>
    }
    <p>@Model.Lesson.Narrative</p>
    @if (!string.IsNullOrWhiteSpace(Model.Lesson.LearnerLanguageNarrative))
    {
        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Lesson.LearnerLanguageNarrative</p>
    }
</section>

@if (activityBlocks.Length > 0)
{
    <section class="panel lesson-flow stack-md" aria-labelledby="lesson-flow-title">
        <div class="lesson-flow__header">
            <div>
                <span class="eyebrow">@T["Lesson"]</span>
                <h2 id="lesson-flow-title" class="headline-sm">@T["Lesson flow"]</h2>
            </div>
            <span class="chip-link chip-link--static">@T["{0} activities", activityBlocks.Length]</span>
        </div>
        <ol class="lesson-flow__list">
            @for (int index = 0; index < activityBlocks.Length; index++)
            {
                var activity = activityBlocks[index];
                string? targetHref = CourseActivityTargetLinkResolver.ResolveHref(activity, Model.Lesson.CoursePathSlug);
                <li class="lesson-flow__item">
                    <div class="lesson-flow__step" aria-label="@T["Step {0}", index + 1]">@(index + 1)</div>
                    <div class="lesson-flow__body">
                        <div class="lesson-flow__meta">
                            <span class="lesson-flow__kind">@activity.Kind</span>
                            <span>@T["{0} minutes", activity.EstimatedMinutes]</span>
                            <span class="lesson-flow__badge @(activity.IsRequired ? "lesson-flow__badge--required" : "lesson-flow__badge--optional")">
                                @(activity.IsRequired ? T["Required"] : T["Optional"])
                            </span>
                        </div>
                        <h3 class="lesson-flow__title">@activity.Title</h3>
                        @if (!string.IsNullOrWhiteSpace(activity.LearnerLanguageTitle))
                        {
                            <p class="meaning-line lesson-flow__translation" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @activity.LearnerLanguageTitle</p>
                        }
                        <p class="lesson-flow__instruction">@activity.Instruction</p>
                        @if (!string.IsNullOrWhiteSpace(activity.LearnerLanguageInstruction))
                        {
                            <p class="meaning-line lesson-flow__translation" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @activity.LearnerLanguageInstruction</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(targetHref))
                        {
                            <a class="button button--secondary button--compact lesson-flow__action" href="@targetHref">@T["Open activity"]</a>
                        }
                    </div>
                </li>
            }
        </ol>
    </section>
}

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Learning goals"]</h2>
        <ul>
            @for (int index = 0; index < Model.Lesson.LearningGoals.Count; index++)
            {
                <li>
                    @Model.Lesson.LearningGoals[index]
                    @if (Model.Lesson.LearnerLanguageLearningGoals.Count > index)
                    {
                        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Lesson.LearnerLanguageLearningGoals[index]</p>
                    }
                </li>
            }
        </ul>
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Review"]</h2>
        <p>@(Model.Lesson.ReviewSummary ?? T["Review is not available for this lesson yet."].Value)</p>
        @if (!string.IsNullOrWhiteSpace(Model.Lesson.LearnerLanguageReviewSummary))
        {
            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Lesson.LearnerLanguageReviewSummary</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Lesson.HomeworkTask))
        {
            <h3>@T["Practice task"]</h3>
            <p>@Model.Lesson.HomeworkTask</p>
            @if (!string.IsNullOrWhiteSpace(Model.Lesson.LearnerLanguageHomeworkTask))
            {
                <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Lesson.LearnerLanguageHomeworkTask</p>
            }
        }
    </article>
</section>

@if (activityBlocks.Length == 0)
{
    <section class="panel stack-md">
        <h2 class="headline-sm">@T["Linked content"]</h2>
        <div class="grid-two-col">
            <partial name="_SlugList" model='(T["Grammar Guide"].Value, Model.Lesson.LinkedGrammarTopicSlugs, "grammar-topic")' />
            <partial name="_SlugList" model='(T["Words"].Value, Model.Lesson.LinkedWordSlugs, "word")' />
            <partial name="_SlugList" model='(T["Everyday Expressions"].Value, Model.Lesson.LinkedExpressionSlugs, "expression")' />
            <partial name="_SlugList" model='(T["Dialogues"].Value, Model.Lesson.LinkedDialogueSlugs, "dialogue")' />
            <partial name="_SlugList" model='(T["Talk Topics"].Value, Model.Lesson.LinkedTalkTopicSlugs, "talk-topic")' />
            <partial name="_SlugList" model='(T["Exercise sets"].Value, Model.Lesson.LinkedExerciseSetSlugs, "exercise-set")' />
        </div>
    </section>
}

<nav class="pagination-nav" aria-label="@T["Lesson navigation"]">
    @if (Model.Lesson.PrerequisiteLessonSlugs.Count > 0)
    {
        <span>@T["Prerequisites"]: @string.Join(", ", Model.Lesson.PrerequisiteLessonSlugs)</span>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Lesson.NextLessonSlug))
    {
        <a class="button button--secondary" asp-controller="Courses" asp-action="Lesson" asp-route-courseSlug="@Model.Lesson.CoursePathSlug" asp-route-lessonSlug="@Model.Lesson.NextLessonSlug">@T["Next lesson"]</a>
    }
</nav>
