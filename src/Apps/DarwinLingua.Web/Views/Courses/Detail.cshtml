@model DarwinLingua.Web.Models.CourseDetailPageViewModel
@{
    ViewData["Title"] = Model.Course.Title;
}

<section class="panel stack-lg">
    <span class="eyebrow">@(Model.Course.CefrLevel ?? Model.Course.CefrRange)</span>
    <h1 class="headline-md">@Model.Course.Title</h1>
    <p class="body-lg">@Model.Course.Description</p>
</section>

<section class="stack-lg">
    @foreach (var module in Model.Course.Modules)
    {
        <article class="panel stack-md">
            <span class="eyebrow">@T["Module"] @module.ModuleNumber · @module.CefrLevel</span>
            <h2 class="headline-sm">@module.Title</h2>
            <p>@module.Description</p>
            @if (module.Lessons.Count == 0)
            {
                <p>@T["No lessons have been imported for this module yet."]</p>
            }
            else
            {
                <ol class="stack-sm">
                    @foreach (var lesson in module.Lessons)
                    {
                        <li>
                            <a asp-controller="Courses" asp-action="Lesson" asp-route-courseSlug="@lesson.CoursePathSlug" asp-route-lessonSlug="@lesson.Slug">@lesson.LessonNumber. @lesson.Title</a>
                            <small>@lesson.CefrLevel · @T["{0} minutes", lesson.EstimatedMinutes]</small>
                            <p>@lesson.ShortDescription</p>
                        </li>
                    }
                </ol>
            }
        </article>
    }
</section>
