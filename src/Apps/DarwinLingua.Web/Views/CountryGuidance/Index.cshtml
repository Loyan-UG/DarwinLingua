@model DarwinLingua.Web.Models.CountryGuidanceNoteIndexPageViewModel
@{
    ViewData["Title"] = T["Life in Germany"];
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
    string secondaryMeaningDirection = string.IsNullOrWhiteSpace(Model.SecondaryMeaningLanguageCode)
        ? "ltr"
        : TextDirection.FromLanguageCode(Model.SecondaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <span class="eyebrow">@T["Resources"]</span>
    <h1 class="headline-md">@T["Life in Germany"]</h1>
    <p class="body-lg">@T["Culture, law, society, everyday systems, and civic knowledge for living in Germany."]</p>
    <form class="search-form" method="get" asp-controller="CountryGuidance" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-route-countryContextCode="@Model.CountryContextCode.ToLowerInvariant()" asp-action="Index">
        <input class="search-input" type="search" name="q" value="@Model.Query" placeholder="@T["Search Life in Germany"]" aria-label="@T["Search Life in Germany"]" />
        <select class="search-input" name="cefrLevel" aria-label="@T["CEFR level"]">
            <option value="">@T["All levels"]</option>
            @foreach (string level in Model.CefrLevels)
            {
                <option value="@level" selected="@(string.Equals(Model.SelectedCefrLevel, level, StringComparison.OrdinalIgnoreCase))">@level</option>
            }
        </select>
        <select class="search-input" name="category" aria-label="@T["Category"]">
            <option value="">@T["All categories"]</option>
            @foreach (string category in Model.Categories)
            {
                <option value="@category" selected="@(string.Equals(Model.SelectedCategory, category, StringComparison.OrdinalIgnoreCase))">@T[category]</option>
            }
        </select>
        <button type="submit" class="button button--secondary">@T["Filter"]</button>
    </form>
</section>

@if (Model.Notes.Count == 0)
{
    <partial name="~/Views/Shared/_AsyncStatePanel.cshtml" model='new DarwinLingua.Web.Models.AsyncStatePanelViewModel(T["Life in Germany content is being prepared"].Value, T["Culture, law, society, and civic knowledge notes will appear here after the first validated package is imported."].Value)' />
}
else
{
    <section class="grid-two-col">
        @foreach (var noteViewModel in Model.Notes)
        {
            var note = noteViewModel.Note;
            var secondaryNote = noteViewModel.SecondaryLanguageNote;
            <article class="panel stack-md">
                <span class="eyebrow">@note.CefrLevel · @T[note.Category]</span>
                <h2 class="headline-sm"><a asp-controller="CountryGuidance" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-route-countryContextCode="@Model.CountryContextCode.ToLowerInvariant()" asp-action="Detail" asp-route-slug="@note.Slug">@note.Title</a></h2>
                <p>@note.ShortDescription</p>
                @if (!string.IsNullOrWhiteSpace(note.LearnerLanguageTitle) ||
                    !string.IsNullOrWhiteSpace(note.LearnerLanguageShortDescription) ||
                    !string.IsNullOrWhiteSpace(secondaryNote?.LearnerLanguageTitle) ||
                    !string.IsNullOrWhiteSpace(secondaryNote?.LearnerLanguageShortDescription))
                {
                    <div class="learning-helper">
                        @if (!string.IsNullOrWhiteSpace(note.LearnerLanguageTitle))
                        {
                            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> <strong>@note.LearnerLanguageTitle</strong></p>
                        }
                        @if (!string.IsNullOrWhiteSpace(note.LearnerLanguageShortDescription))
                        {
                            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @note.LearnerLanguageShortDescription</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(secondaryNote?.LearnerLanguageTitle))
                        {
                            <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> <strong>@secondaryNote.LearnerLanguageTitle</strong></p>
                        }
                        @if (!string.IsNullOrWhiteSpace(secondaryNote?.LearnerLanguageShortDescription))
                        {
                            <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @secondaryNote.LearnerLanguageShortDescription</p>
                        }
                    </div>
                }
                <p>@note.Context</p>
                @if (!string.IsNullOrWhiteSpace(note.LearnerLanguageContext))
                {
                    <p class="meaning-line text-muted" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @note.LearnerLanguageContext</p>
                }
                @if (!string.IsNullOrWhiteSpace(secondaryNote?.LearnerLanguageContext))
                {
                    <p class="meaning-line text-muted" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @secondaryNote.LearnerLanguageContext</p>
                }
                @if (note.HasSensitivityWarning)
                {
                    <p class="status-badge status-badge--warning">@T["Sensitive topic"]</p>
                }
                <a class="button button--secondary" asp-controller="CountryGuidance" asp-route-targetLearningLanguageCode="@LearningRouteConventions.ResolveTargetLearningLanguageCode(Context)" asp-route-countryContextCode="@Model.CountryContextCode.ToLowerInvariant()" asp-action="Detail" asp-route-slug="@note.Slug">@T["Open note"]</a>
            </article>
        }
    </section>
}
