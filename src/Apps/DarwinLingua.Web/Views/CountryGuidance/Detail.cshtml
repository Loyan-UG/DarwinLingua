@model DarwinLingua.Web.Models.CountryGuidanceNoteDetailPageViewModel
@{
    ViewData["Title"] = Model.Note.Title;
    string targetLearningLanguageCode = LearningRouteConventions.ResolveTargetLearningLanguageCode(Context);
    string primaryMeaningDirection = TextDirection.FromLanguageCode(Model.PrimaryMeaningLanguageCode);
    string secondaryMeaningDirection = string.IsNullOrWhiteSpace(Model.SecondaryMeaningLanguageCode)
        ? "ltr"
        : TextDirection.FromLanguageCode(Model.SecondaryMeaningLanguageCode);
}

<section class="panel stack-lg">
    <span class="eyebrow">@Model.Note.CefrLevel · @T[Model.Note.Category]</span>
    <h1 class="headline-md">@Model.Note.Title</h1>
    <p class="body-lg">@Model.Note.ShortDescription</p>
    <p><strong>@T["Context"]:</strong> @Model.Note.Context</p>
    @if (!string.IsNullOrWhiteSpace(Model.Note.LearnerLanguageTitle) ||
        !string.IsNullOrWhiteSpace(Model.Note.LearnerLanguageShortDescription) ||
        !string.IsNullOrWhiteSpace(Model.Note.LearnerLanguageContext) ||
        !string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote?.LearnerLanguageTitle) ||
        !string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote?.LearnerLanguageShortDescription) ||
        !string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote?.LearnerLanguageContext))
    {
        <div class="learning-helper">
            @if (!string.IsNullOrWhiteSpace(Model.Note.LearnerLanguageTitle))
            {
                <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> <strong>@Model.Note.LearnerLanguageTitle</strong></p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Note.LearnerLanguageShortDescription))
            {
                <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Note.LearnerLanguageShortDescription</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Note.LearnerLanguageContext))
            {
                <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Note.LearnerLanguageContext</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote?.LearnerLanguageTitle))
            {
                <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> <strong>@Model.SecondaryLanguageNote.LearnerLanguageTitle</strong></p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote?.LearnerLanguageShortDescription))
            {
                <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @Model.SecondaryLanguageNote.LearnerLanguageShortDescription</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote?.LearnerLanguageContext))
            {
                <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @Model.SecondaryLanguageNote.LearnerLanguageContext</p>
            }
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Note.SensitivityWarning))
    {
        <p class="status-badge status-badge--warning">@Model.Note.SensitivityWarning</p>
        @if (!string.IsNullOrWhiteSpace(Model.Note.LearnerLanguageSensitivityWarning))
        {
            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Note.LearnerLanguageSensitivityWarning</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote?.LearnerLanguageSensitivityWarning))
        {
            <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @Model.SecondaryLanguageNote.LearnerLanguageSensitivityWarning</p>
        }
    }
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Practical explanation"]</h2>
    @for (int index = 0; index < Model.Note.Sections.Count; index++)
    {
        <p>@Model.Note.Sections[index]</p>
        @if (Model.Note.LearnerLanguageSections.Count > index)
        {
            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Note.LearnerLanguageSections[index]</p>
        }
        @if (Model.SecondaryLanguageNote?.LearnerLanguageSections.Count > index)
        {
            <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @Model.SecondaryLanguageNote.LearnerLanguageSections[index]</p>
        }
    }
</section>

<section class="grid-two-col">
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Examples"]</h2>
        @if (Model.Note.Examples.Count == 0)
        {
            <p>@T["No examples"]</p>
        }
        else
        {
            <ul>
                @for (int exampleIndex = 0; exampleIndex < Model.Note.Examples.Count; exampleIndex++)
                {
                    var example = Model.Note.Examples[exampleIndex];
                    <li>
                        <strong>@example.GermanText</strong>
                        @if (!string.IsNullOrWhiteSpace(example.Explanation))
                        {
                            <span>@example.Explanation</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(example.LearnerLanguageExplanation))
                        {
                            <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @example.LearnerLanguageExplanation</p>
                        }
                        @if (Model.SecondaryLanguageNote?.Examples.Count > exampleIndex &&
                            !string.IsNullOrWhiteSpace(Model.SecondaryLanguageNote.Examples[exampleIndex].LearnerLanguageExplanation))
                        {
                            <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @Model.SecondaryLanguageNote.Examples[exampleIndex].LearnerLanguageExplanation</p>
                        }
                    </li>
                }
            </ul>
        }
    </article>
    <article class="panel stack-md">
        <h2 class="headline-sm">@T["Do and don't notes"]</h2>
        <h3>@T["Do"]</h3>
        <ul>
            @for (int index = 0; index < Model.Note.DoNotes.Count; index++)
            {
                <li>
                    @Model.Note.DoNotes[index]
                    @if (Model.Note.LearnerLanguageDoNotes.Count > index)
                    {
                        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Note.LearnerLanguageDoNotes[index]</p>
                    }
                    @if (Model.SecondaryLanguageNote?.LearnerLanguageDoNotes.Count > index)
                    {
                        <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @Model.SecondaryLanguageNote.LearnerLanguageDoNotes[index]</p>
                    }
                </li>
            }
        </ul>
        <h3>@T["Don't"]</h3>
        <ul>
            @for (int index = 0; index < Model.Note.DontNotes.Count; index++)
            {
                <li>
                    @Model.Note.DontNotes[index]
                    @if (Model.Note.LearnerLanguageDontNotes.Count > index)
                    {
                        <p class="meaning-line" dir="@primaryMeaningDirection"><span class="meaning-block__label">@Model.PrimaryMeaningLanguageCode</span> @Model.Note.LearnerLanguageDontNotes[index]</p>
                    }
                    @if (Model.SecondaryLanguageNote?.LearnerLanguageDontNotes.Count > index)
                    {
                        <p class="meaning-line" dir="@secondaryMeaningDirection"><span class="meaning-block__label">@Model.SecondaryMeaningLanguageCode</span> @Model.SecondaryLanguageNote.LearnerLanguageDontNotes[index]</p>
                    }
                </li>
            }
        </ul>
    </article>
</section>

<section class="panel stack-md">
    <h2 class="headline-sm">@T["Linked content"]</h2>
    <div class="grid-two-col">
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Dialogues"].Value, Model.Note.LinkedDialogueSlugs, "dialogue", targetLearningLanguageCode, Model.Note.CountryContextCode)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Everyday Expressions"].Value, Model.Note.LinkedExpressionSlugs, "expression", targetLearningLanguageCode, Model.Note.CountryContextCode)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Writing Templates"].Value, Model.Note.LinkedWritingTemplateSlugs, "writing-template", targetLearningLanguageCode, Model.Note.CountryContextCode)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Talk Topics"].Value, Model.Note.LinkedTalkTopicSlugs, "talk-topic", targetLearningLanguageCode, Model.Note.CountryContextCode)' />
        <partial name="~/Views/WritingTemplates/_SlugList.cshtml" model='(T["Course Lessons"].Value, Model.Note.LinkedCourseLessonSlugs, "course-lesson", targetLearningLanguageCode, Model.Note.CountryContextCode)' />
    </div>
</section>
