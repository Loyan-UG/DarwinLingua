<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:segmentedControl="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Controls.CefrQuickFilterView">
    <VerticalStackLayout Spacing="12">
        <Label x:Name="CaptionLabel"
               Style="{DynamicResource Caption}" />
        <segmentedControl:SfSegmentedControl x:Name="SegmentedControl"
                                             HeightRequest="58"
                                             SelectionMode="Single"
                                             SelectionChanged="OnSegmentedControlSelectionChanged">
            <segmentedControl:SfSegmentedControl.SelectionIndicatorSettings>
                <segmentedControl:SelectionIndicatorSettings SelectionIndicatorPlacement="Fill"
                                                             Background="{AppThemeBinding Light=#10212B, Dark=#E8F3F1}" />
            </segmentedControl:SfSegmentedControl.SelectionIndicatorSettings>
        </segmentedControl:SfSegmentedControl>
    </VerticalStackLayout>
</ContentView>
