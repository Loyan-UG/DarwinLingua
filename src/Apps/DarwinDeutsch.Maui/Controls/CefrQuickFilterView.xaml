<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Controls.CefrQuickFilterView">
    <VerticalStackLayout Spacing="12">
        <Label x:Name="CaptionLabel"
               Style="{DynamicResource Caption}" />
        <Grid ColumnDefinitions="*,*,*"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="10"
              RowSpacing="10">
            <Button x:Name="A1Button" Grid.Row="0" Grid.Column="0" Text="A1" Clicked="OnCefrButtonClicked" />
            <Button x:Name="A2Button" Grid.Row="0" Grid.Column="1" Text="A2" Clicked="OnCefrButtonClicked" />
            <Button x:Name="B1Button" Grid.Row="0" Grid.Column="2" Text="B1" Clicked="OnCefrButtonClicked" />
            <Button x:Name="B2Button" Grid.Row="1" Grid.Column="0" Text="B2" Clicked="OnCefrButtonClicked" />
            <Button x:Name="C1Button" Grid.Row="1" Grid.Column="1" Text="C1" Clicked="OnCefrButtonClicked" />
            <Button x:Name="C2Button" Grid.Row="1" Grid.Column="2" Text="C2" Clicked="OnCefrButtonClicked" />
        </Grid>
    </VerticalStackLayout>
</ContentView>
