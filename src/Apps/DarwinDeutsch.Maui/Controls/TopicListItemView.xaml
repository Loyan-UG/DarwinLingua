<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Controls.TopicListItemView">
    <Border Margin="0,0,0,10"
            Padding="16"
            Stroke="{AppThemeBinding Light=#D8C9F4, Dark=#293342}"
            StrokeShape="RoundRectangle 22"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#111923}">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="14">
            <Border Grid.Column="0"
                    Padding="10,6"
                    VerticalOptions="Start"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{AppThemeBinding Light=#F1EAFE, Dark=#232C3A}">
                <Label x:Name="TopicKeyLabel"
                       FontAttributes="Bold"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light=#190649, Dark=White}" />
            </Border>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="4">
                <Label x:Name="DisplayNameLabel"
                       Style="{DynamicResource Title2}"
                       TextColor="{AppThemeBinding Light=#190649, Dark=White}" />
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>
