<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cards="clr-namespace:Syncfusion.Maui.Toolkit.Cards;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Controls.TopicListItemView">
    <cards:SfCardView Margin="0,0,0,10"
                      BorderColor="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                      BorderWidth="1"
                      CornerRadius="4">
        <Grid Padding="16"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="14"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#111923}">
            <Border Grid.Column="0"
                    Padding="10,6"
                    VerticalOptions="Start"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{AppThemeBinding Light=#E6F3EF, Dark=#22313B}">
                <Label x:Name="TopicKeyLabel"
                       FontAttributes="Bold"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light=#10212B, Dark=White}" />
            </Border>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="6">
                <Label x:Name="DisplayNameLabel"
                       Style="{DynamicResource Title2}"
                       TextColor="{AppThemeBinding Light=#10212B, Dark=White}" />
            </VerticalStackLayout>
        </Grid>
    </cards:SfCardView>
</ContentView>
