<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Controls.ActionBlockView">
    <Border Padding="16"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=#DFD8F7, Dark=#141414}">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <Label x:Name="CaptionLabel"
                   Grid.Column="0"
                   Style="{DynamicResource Title2}"
                   VerticalOptions="Center" />
            <Button x:Name="ActionButton"
                    Grid.Column="1"
                    Clicked="OnActionButtonClicked" />
        </Grid>
    </Border>
</ContentView>
