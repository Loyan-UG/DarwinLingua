<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkitButton="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkitCard="clr-namespace:Syncfusion.Maui.Toolkit.Cards;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Controls.ActionBlockView">
    <toolkitCard:SfCardView Style="{StaticResource SyncfusionCardShellStyle}">
        <VerticalStackLayout Spacing="14"
                             Padding="18"
                             BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#10161E}">
            <Label x:Name="CaptionLabel"
                   Style="{DynamicResource Title2}"
                   TextColor="{AppThemeBinding Light=#10212B, Dark=White}" />
            <toolkitButton:SfButton x:Name="ActionButton"
                                    Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                    Clicked="OnActionButtonClicked" />
        </VerticalStackLayout>
    </toolkitCard:SfCardView>
</ContentView>
