<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shimmer="clr-namespace:Syncfusion.Maui.Toolkit.Shimmer;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Controls.LoadingStateView">
    <Grid x:Name="RootLayout"
          IsVisible="False">
        <HorizontalStackLayout x:Name="InlineLoadingLayout"
                               Spacing="8"
                               IsVisible="False">
            <shimmer:SfShimmer x:Name="InlineLoadingShimmer"
                               WidthRequest="18"
                               HeightRequest="18"
                               IsActive="False"
                               Style="{StaticResource SyncfusionInlineShimmerStyle}">
                <shimmer:SfShimmer.CustomView>
                    <Border Style="{StaticResource AppStatusBadgeBorderStyle}"
                            Padding="0"
                            StrokeShape="RoundRectangle 9"
                            WidthRequest="18"
                            HeightRequest="18" />
                </shimmer:SfShimmer.CustomView>
            </shimmer:SfShimmer>

            <Label x:Name="MessageLabel"
                   Style="{DynamicResource Body}" />
        </HorizontalStackLayout>

        <VerticalStackLayout x:Name="ListSkeletonLayout"
                             Spacing="10"
                             IsVisible="False">
            <shimmer:SfShimmer x:Name="ListSkeletonShimmer"
                               HeightRequest="212"
                               IsActive="False"
                               RepeatCount="3"
                               Type="Article"
                               Style="{StaticResource SyncfusionInlineShimmerStyle}" />
        </VerticalStackLayout>

        <VerticalStackLayout x:Name="WordCardsSkeletonLayout"
                             Spacing="10"
                             IsVisible="False">
            <shimmer:SfShimmer x:Name="WordCardsSkeletonShimmer"
                               HeightRequest="320"
                               IsActive="False"
                               Style="{StaticResource SyncfusionInlineShimmerStyle}">
                <shimmer:SfShimmer.CustomView>
                    <VerticalStackLayout Spacing="10">
                        <Border Style="{StaticResource AppSectionCardBorderStyle}"
                                Padding="16">
                            <VerticalStackLayout Spacing="10">
                                <Border HeightRequest="20"
                                        WidthRequest="130"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="16"
                                        WidthRequest="220"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="28"
                                        WidthRequest="90"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource AppSectionCardBorderStyle}"
                                Padding="16">
                            <VerticalStackLayout Spacing="10">
                                <Border HeightRequest="20"
                                        WidthRequest="160"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="16"
                                        WidthRequest="200"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="28"
                                        WidthRequest="110"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </shimmer:SfShimmer.CustomView>
            </shimmer:SfShimmer>
        </VerticalStackLayout>

        <VerticalStackLayout x:Name="TopicCardsSkeletonLayout"
                             Spacing="10"
                             IsVisible="False">
            <shimmer:SfShimmer x:Name="TopicCardsSkeletonShimmer"
                               HeightRequest="260"
                               IsActive="False"
                               Style="{StaticResource SyncfusionInlineShimmerStyle}">
                <shimmer:SfShimmer.CustomView>
                    <VerticalStackLayout Spacing="10">
                        <Border Style="{StaticResource AppSectionCardBorderStyle}"
                                Padding="16">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="14">
                                <Border HeightRequest="28"
                                        WidthRequest="54"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="8">
                                    <Border HeightRequest="20"
                                            WidthRequest="180"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                            StrokeShape="RoundRectangle 4" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AppSectionCardBorderStyle}"
                                Padding="16">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="14">
                                <Border HeightRequest="28"
                                        WidthRequest="48"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="8">
                                    <Border HeightRequest="20"
                                            WidthRequest="210"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                            StrokeShape="RoundRectangle 4" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </shimmer:SfShimmer.CustomView>
            </shimmer:SfShimmer>
        </VerticalStackLayout>

        <VerticalStackLayout x:Name="DetailSkeletonLayout"
                             Spacing="18"
                             IsVisible="False">
            <shimmer:SfShimmer x:Name="DetailSkeletonShimmer"
                               HeightRequest="560"
                               IsActive="False"
                               Style="{StaticResource SyncfusionInlineShimmerStyle}">
                <shimmer:SfShimmer.CustomView>
                    <VerticalStackLayout Padding="24"
                                         Spacing="18">
                        <Border Style="{StaticResource AppHeroPanelBorderStyle}"
                                Padding="22">
                            <VerticalStackLayout Spacing="14">
                                <Border HeightRequest="30"
                                        WidthRequest="180"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="18"
                                        WidthRequest="120"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <HorizontalStackLayout Spacing="10">
                                    <Border HeightRequest="40"
                                            WidthRequest="48"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                            StrokeShape="RoundRectangle 4" />
                                    <Border HeightRequest="40"
                                            WidthRequest="48"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                            StrokeShape="RoundRectangle 4" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Border HeightRequest="44"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                    StrokeShape="RoundRectangle 4" />
                            <Border Grid.Column="1"
                                    HeightRequest="44"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                    StrokeShape="RoundRectangle 4" />
                        </Grid>

                        <Border Style="{StaticResource AppSectionCardBorderStyle}"
                                Padding="20">
                            <VerticalStackLayout Spacing="12">
                                <Border HeightRequest="18"
                                        WidthRequest="110"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="16"
                                        WidthRequest="240"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource AppSectionCardBorderStyle}"
                                Padding="20">
                            <VerticalStackLayout Spacing="12">
                                <Border HeightRequest="20"
                                        WidthRequest="130"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="16"
                                        WidthRequest="260"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="16"
                                        WidthRequest="220"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                                <Border HeightRequest="16"
                                        WidthRequest="180"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E3ECE9, Dark=#23313D}"
                                        StrokeShape="RoundRectangle 4" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </shimmer:SfShimmer.CustomView>
            </shimmer:SfShimmer>
        </VerticalStackLayout>
    </Grid>
</ContentView>
