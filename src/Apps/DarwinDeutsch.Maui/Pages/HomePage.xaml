<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             xmlns:expander="clr-namespace:Syncfusion.Maui.Toolkit.Expander;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Pages.HomePage">
    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18">
            <Border Padding="24"
                    Style="{StaticResource AppHeroPanelBorderStyle}">
                <Grid ColumnDefinitions="84,*"
                      ColumnSpacing="16">
                    <Border Grid.Column="0"
                            Padding="12"
                            StrokeShape="RoundRectangle 4"
                            Style="{StaticResource AppInsetPanelBorderStyle}">
                        <Grid>
                            <Label x:Name="LogoPlaceholderLabel"
                                   Style="{DynamicResource Caption}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="8"
                                         VerticalOptions="Center">
                        <Label x:Name="AppNameLabel"
                               Style="{DynamicResource SubHeadline}"
                               SemanticProperties.HeadingLevel="Level1" />
                        <Label x:Name="AppSubtitleLabel"
                               Style="{DynamicResource Body}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <expander:SfExpander IsExpanded="True"
                                 Style="{StaticResource SyncfusionSectionExpanderStyle}">
                <expander:SfExpander.Header>
                    <Grid Padding="20">
                        <Label x:Name="ExploreSectionLabel"
                               Style="{DynamicResource Title2}" />
                    </Grid>
                </expander:SfExpander.Header>
                <expander:SfExpander.Content>
                    <Border Padding="20"
                            Style="{StaticResource AppSectionCardBorderStyle}">
                        <VerticalStackLayout Spacing="16">
                            <controls:CefrQuickFilterView x:Name="CefrQuickFilterView"
                                                          LevelSelected="OnCefrLevelSelected" />

                            <HorizontalStackLayout x:Name="CefrNavigationStatusLayout"
                                                   Spacing="10"
                                                   IsVisible="False">
                                <ActivityIndicator x:Name="CefrNavigationActivityIndicator"
                                                   WidthRequest="18"
                                                   HeightRequest="18"
                                                   IsRunning="False"
                                                   VerticalOptions="Center" />
                                <Label x:Name="CefrNavigationStatusLabel"
                                       Style="{DynamicResource Body}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <VerticalStackLayout Spacing="12">
                                <controls:ActionBlockView x:Name="PracticeActionBlockView"
                                                          ActionInvoked="OnPracticeActionInvoked" />

                                <controls:ActionBlockView x:Name="SearchActionBlockView"
                                                          ActionInvoked="OnSearchActionInvoked" />

                                <controls:ActionBlockView x:Name="BrowseTopicsActionBlockView"
                                                          ActionInvoked="OnBrowseTopicsActionInvoked" />

                                <controls:ActionBlockView x:Name="CollectionsActionBlockView"
                                                          ActionInvoked="OnCollectionsActionInvoked" />

                                <controls:ActionBlockView x:Name="FavoritesActionBlockView"
                                                          ActionInvoked="OnFavoritesActionInvoked" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </expander:SfExpander.Content>
            </expander:SfExpander>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
