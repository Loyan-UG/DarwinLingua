<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             xmlns:accordion="clr-namespace:Syncfusion.Maui.Toolkit.Accordion;assembly=Syncfusion.Maui.Toolkit"
             xmlns:chips="clr-namespace:Syncfusion.Maui.Toolkit.Chips;assembly=Syncfusion.Maui.Toolkit"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.WordDetailPage">
    <ScrollView>
        <ScrollView.GestureRecognizers>
            <SwipeGestureRecognizer Direction="Left"
                                    Swiped="OnDetailSwipeLeft" />
            <SwipeGestureRecognizer Direction="Right"
                                    Swiped="OnDetailSwipeRight" />
        </ScrollView.GestureRecognizers>
        <VerticalStackLayout Padding="24" Spacing="18">
            <controls:LoadingStateView x:Name="LoadingStateView"
                                       LoadingMode="DetailSkeleton"
                                       Message="Loading word details..." />

            <VerticalStackLayout x:Name="ContentStackLayout"
                                 Spacing="18">
            <Border Padding="22"
                    Style="{StaticResource AppHeroPanelBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="HeadlineLabel"
                           Style="{DynamicResource Headline}"
                           HorizontalOptions="Start"
                           HorizontalTextAlignment="Start"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label x:Name="MetadataLabel"
                           Style="{DynamicResource Body}" />

                    <HorizontalStackLayout Spacing="10">
                        <buttons:SfButton x:Name="SpeakWordButton"
                                          Style="{StaticResource SyncfusionIconActionButtonStyle}"
                                          Clicked="OnSpeakWordButtonClicked"
                                          IsVisible="False" />
                        <buttons:SfButton x:Name="FavoriteButton"
                                          Style="{StaticResource SyncfusionFavoriteToggleButtonStyle}"
                                          IsCheckable="True"
                                          Clicked="OnFavoriteButtonClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Grid x:Name="CefrNavigationTopGrid"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="10"
                  IsVisible="False">
                <buttons:SfButton x:Name="PreviousWordButtonTop"
                                  Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                  Clicked="OnPreviousWordButtonClicked" />
                <buttons:SfButton x:Name="ShowWordListButtonTop"
                                  Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                  Grid.Column="1"
                                  Clicked="OnShowWordListButtonClicked" />
                <buttons:SfButton x:Name="NextWordButtonTop"
                                  Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                  Grid.Column="2"
                                  Clicked="OnNextWordButtonClicked" />
            </Grid>

            <Border x:Name="SwipeHintBorder"
                    Padding="10,6"
                    HorizontalOptions="Start"
                    IsVisible="False"
                    Style="{StaticResource AppMetadataBadgeBorderStyle}">
                <Label x:Name="SwipeHintLabel"
                       Style="{DynamicResource Caption}" />
            </Border>

            <Grid x:Name="SwipeAffordanceGrid"
                  ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="10"
                  IsVisible="False"
                  VerticalOptions="Center">
                <Border x:Name="SwipePreviousHintBorder"
                        Padding="10,6"
                        Style="{StaticResource AppMetadataBadgeBorderStyle}">
                    <Label x:Name="SwipePreviousHintLabel"
                           Style="{DynamicResource Caption}" />
                </Border>

                <Label x:Name="SwipeAffordanceLabel"
                       Grid.Column="1"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Style="{DynamicResource Caption}" />

                <Border x:Name="SwipeNextHintBorder"
                        Grid.Column="2"
                        Padding="10,6"
                        Style="{StaticResource AppMetadataBadgeBorderStyle}">
                    <Label x:Name="SwipeNextHintLabel"
                           Style="{DynamicResource Caption}" />
                </Border>
            </Grid>

            <Label x:Name="AudioStatusLabel"
                   Style="{DynamicResource Caption}"
                   IsVisible="False" />

            <Border Padding="20"
                    Style="{StaticResource AppSectionCardBorderStyle}">
                <controls:DetailSectionView x:Name="LearningStateSectionView" />
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <buttons:SfButton x:Name="KnownButton"
                                  Style="{StaticResource SyncfusionKnownToggleButtonStyle}"
                                  IsCheckable="True"
                                  Clicked="OnKnownButtonClicked" />
                <buttons:SfButton x:Name="DifficultButton"
                                  Style="{StaticResource SyncfusionDifficultToggleButtonStyle}"
                                  IsCheckable="True"
                                  Grid.Column="1"
                                  Clicked="OnDifficultButtonClicked" />
            </Grid>

            <VerticalStackLayout x:Name="SensesContainer"
                                 Spacing="16" />

            <Border x:Name="UsageLabelsBorder"
                    Padding="20"
                    Style="{StaticResource AppSectionCardBorderStyle}"
                    IsVisible="False">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="UsageLabelsHeadingLabel"
                           Style="{DynamicResource Title2}" />
                    <chips:SfChipGroup x:Name="UsageLabelsChipGroup"
                                       Style="{StaticResource SyncfusionLexicalChipGroupStyle}">
                        <chips:SfChipGroup.ChipLayout>
                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Start" />
                        </chips:SfChipGroup.ChipLayout>
                        <chips:SfChipGroup.ItemTemplate>
                            <DataTemplate>
                                <chips:SfChip Text="{Binding .}" />
                            </DataTemplate>
                        </chips:SfChipGroup.ItemTemplate>
                    </chips:SfChipGroup>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ContextLabelsBorder"
                    Padding="20"
                    Style="{StaticResource AppSectionCardBorderStyle}"
                    IsVisible="False">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="ContextLabelsHeadingLabel"
                           Style="{DynamicResource Title2}" />
                    <chips:SfChipGroup x:Name="ContextLabelsChipGroup"
                                       Style="{StaticResource SyncfusionLexicalChipGroupStyle}">
                        <chips:SfChipGroup.ChipLayout>
                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Start" />
                        </chips:SfChipGroup.ChipLayout>
                        <chips:SfChipGroup.ItemTemplate>
                            <DataTemplate>
                                <chips:SfChip Text="{Binding .}" />
                            </DataTemplate>
                        </chips:SfChipGroup.ItemTemplate>
                    </chips:SfChipGroup>
                </VerticalStackLayout>
            </Border>

            <accordion:SfAccordion ExpandMode="SingleOrNone"
                                   ItemSpacing="10"
                                   AnimationDuration="140">
                <accordion:SfAccordion.Items>
                    <accordion:AccordionItem x:Name="GrammarNotesBorder"
                                             IsExpanded="False"
                                             IsVisible="False">
                        <accordion:AccordionItem.Header>
                            <Grid Padding="20">
                                <Label x:Name="GrammarNotesHeadingLabel"
                                       Style="{DynamicResource Title2}" />
                            </Grid>
                        </accordion:AccordionItem.Header>
                        <accordion:AccordionItem.Content>
                            <Border Padding="20"
                                    Style="{StaticResource AppSectionCardBorderStyle}">
                                <VerticalStackLayout x:Name="GrammarNotesStackLayout"
                                                     Spacing="10" />
                            </Border>
                        </accordion:AccordionItem.Content>
                    </accordion:AccordionItem>

                    <accordion:AccordionItem x:Name="CollocationsBorder"
                                             IsExpanded="False"
                                             IsVisible="False">
                        <accordion:AccordionItem.Header>
                            <Grid Padding="20">
                                <Label x:Name="CollocationsHeadingLabel"
                                       Style="{DynamicResource Title2}" />
                            </Grid>
                        </accordion:AccordionItem.Header>
                        <accordion:AccordionItem.Content>
                            <Border Padding="20"
                                    Style="{StaticResource AppSectionCardBorderStyle}">
                                <VerticalStackLayout x:Name="CollocationsStackLayout"
                                                     Spacing="10" />
                            </Border>
                        </accordion:AccordionItem.Content>
                    </accordion:AccordionItem>

                    <accordion:AccordionItem x:Name="WordFamiliesBorder"
                                             IsExpanded="False"
                                             IsVisible="False">
                        <accordion:AccordionItem.Header>
                            <Grid Padding="20">
                                <Label x:Name="WordFamiliesHeadingLabel"
                                       Style="{DynamicResource Title2}" />
                            </Grid>
                        </accordion:AccordionItem.Header>
                        <accordion:AccordionItem.Content>
                            <Border Padding="20"
                                    Style="{StaticResource AppSectionCardBorderStyle}">
                                <VerticalStackLayout x:Name="WordFamiliesStackLayout"
                                                     Spacing="10" />
                            </Border>
                        </accordion:AccordionItem.Content>
                    </accordion:AccordionItem>

                    <accordion:AccordionItem x:Name="LexicalRelationsBorder"
                                             IsExpanded="False"
                                             IsVisible="False">
                        <accordion:AccordionItem.Header>
                            <Grid Padding="20">
                                <Label x:Name="LexicalRelationsHeadingLabel"
                                       Style="{DynamicResource Title2}" />
                            </Grid>
                        </accordion:AccordionItem.Header>
                        <accordion:AccordionItem.Content>
                            <Border Padding="20"
                                    Style="{StaticResource AppSectionCardBorderStyle}">
                                <VerticalStackLayout Spacing="14">
                                    <VerticalStackLayout x:Name="SynonymsSectionStackLayout"
                                                         Spacing="10"
                                                         IsVisible="False">
                                        <Label x:Name="SynonymsHeadingLabel"
                                               Style="{DynamicResource Body}" />
                                        <VerticalStackLayout x:Name="SynonymsStackLayout"
                                                             Spacing="8" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout x:Name="AntonymsSectionStackLayout"
                                                         Spacing="10"
                                                         IsVisible="False">
                                        <Label x:Name="AntonymsHeadingLabel"
                                               Style="{DynamicResource Body}" />
                                        <VerticalStackLayout x:Name="AntonymsStackLayout"
                                                             Spacing="8" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </accordion:AccordionItem.Content>
                    </accordion:AccordionItem>
                </accordion:SfAccordion.Items>
            </accordion:SfAccordion>

            <Border Padding="20"
                    Style="{StaticResource AppSectionCardBorderStyle}">
                <controls:DetailSectionView x:Name="TopicsSectionView" />
            </Border>

            <Label x:Name="EmptyStateLabel"
                   Style="{DynamicResource Body}"
                   IsVisible="False" />

            <Grid x:Name="CefrNavigationBottomGrid"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="10"
                  IsVisible="False">
                <buttons:SfButton x:Name="PreviousWordButtonBottom"
                                  Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                  Clicked="OnPreviousWordButtonClicked" />
                <buttons:SfButton x:Name="ShowWordListButtonBottom"
                                  Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                  Grid.Column="1"
                                  Clicked="OnShowWordListButtonClicked" />
                <buttons:SfButton x:Name="NextWordButtonBottom"
                                  Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                  Grid.Column="2"
                                  Clicked="OnNextWordButtonClicked" />
            </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
