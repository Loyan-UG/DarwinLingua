<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Pages.WordDetailPage">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label x:Name="HeadlineLabel"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1" />

            <Button x:Name="SpeakWordButton"
                    Clicked="OnSpeakWordButtonClicked"
                    IsVisible="False" />

            <Label x:Name="MetadataLabel"
                   Style="{StaticResource Body}" />

            <Button x:Name="FavoriteButton"
                    Clicked="OnFavoriteButtonClicked" />

            <Label x:Name="AudioStatusLabel"
                   Style="{StaticResource Body}"
                   TextColor="{StaticResource Gray500}"
                   IsVisible="False" />

            <Label x:Name="LearningStateCaptionLabel"
                   Style="{StaticResource Title2}" />

            <Label x:Name="LearningStateValueLabel"
                   Style="{StaticResource Body}"
                   LineBreakMode="WordWrap" />

            <HorizontalStackLayout Spacing="12">
                <Button x:Name="KnownButton"
                        Clicked="OnKnownButtonClicked" />
                <Button x:Name="DifficultButton"
                        Clicked="OnDifficultButtonClicked" />
            </HorizontalStackLayout>

            <Label x:Name="TopicsCaptionLabel"
                   Style="{StaticResource Title2}" />

            <Label x:Name="TopicsValueLabel"
                   Style="{StaticResource Body}"
                   LineBreakMode="WordWrap" />

            <Label x:Name="EmptyStateLabel"
                   Style="{StaticResource Body}"
                   IsVisible="False" />

            <VerticalStackLayout x:Name="SensesContainer"
                                 Spacing="16" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
