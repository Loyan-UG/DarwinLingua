<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Pages.SearchWordsPage">
    <Grid Padding="24"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="18">
        <Border Grid.Row="0"
                Padding="24"
                Style="{StaticResource AppHeroPanelBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Border Style="{StaticResource AppStatusBadgeBorderStyle}">
                    <Label x:Name="StatusBadgeLabel"
                           Style="{DynamicResource Caption}" />
                </Border>
                <Label x:Name="HeadlineLabel"
                       Style="{DynamicResource Headline}"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label x:Name="DescriptionLabel"
                       Style="{DynamicResource Body}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Padding="20"
                Style="{StaticResource AppSectionCardBorderStyle}">
            <VerticalStackLayout Spacing="12">
                <Label x:Name="SearchSectionLabel"
                       Style="{DynamicResource Title2}" />
                <inputLayout:SfTextInputLayout x:Name="SearchInputLayout"
                                               Style="{StaticResource SyncfusionTextInputLayoutStyle}"
                                               ShowLeadingView="True">
                    <inputLayout:SfTextInputLayout.LeadingView>
                        <Label FontSize="18"
                               Text="&#x1F50D;"
                               TextColor="{AppThemeBinding Light=#5B6B79, Dark=#9FB0BE}"
                               VerticalTextAlignment="Center" />
                    </inputLayout:SfTextInputLayout.LeadingView>
                    <Entry x:Name="SearchEntry"
                           ClearButtonVisibility="WhileEditing"
                           ReturnType="Search"
                           TextChanged="OnSearchEntryTextChanged"
                           Completed="OnSearchEntryCompleted" />
                </inputLayout:SfTextInputLayout>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="2"
                Padding="20"
                Style="{StaticResource AppSectionCardBorderStyle}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                  RowSpacing="12">
                <Label x:Name="ResultsSectionLabel"
                       Grid.Row="0"
                       Style="{DynamicResource Title2}" />

                <controls:LoadingStateView x:Name="LoadingStateView"
                                           Grid.Row="1" />

                <Label x:Name="EmptyStateLabel"
                       Grid.Row="2"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <Label x:Name="ErrorStateLabel"
                       Grid.Row="3"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <CollectionView x:Name="WordsCollectionView"
                                Grid.Row="4"
                                SelectionMode="Single"
                                SelectionChanged="OnWordsSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <controls:WordListItemView Lemma="{Binding Lemma}"
                                                       PrimaryMeaning="{Binding PrimaryMeaning}"
                                                       MetadataLine="{Binding MetadataLine}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
