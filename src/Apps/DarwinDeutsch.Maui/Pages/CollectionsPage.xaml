<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.CollectionsPage">
    <Grid Padding="24"
          RowDefinitions="Auto,Auto,Auto,Auto,*"
          RowSpacing="12">
        <Label x:Name="HeadlineLabel"
               Grid.Row="0"
               Style="{DynamicResource Headline}"
               SemanticProperties.HeadingLevel="Level1" />

        <Label x:Name="DescriptionLabel"
               Grid.Row="1"
               Style="{DynamicResource Body}"
               LineBreakMode="WordWrap" />

        <controls:LoadingStateView x:Name="LoadingStateView"
                                   Grid.Row="2"
                                   LoadingMode="TopicCardsSkeleton" />

        <Label x:Name="EmptyStateLabel"
               Grid.Row="3"
               Style="{DynamicResource Body}"
               IsVisible="False" />

        <CollectionView x:Name="CollectionsCollectionView"
                        Grid.Row="4"
                        SelectionMode="Single"
                        SelectionChanged="OnCollectionsSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="16"
                            Style="{StaticResource AppSectionCardBorderStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Name}"
                                   Style="{DynamicResource Title2}" />
                            <Label Text="{Binding Description}"
                                   Style="{DynamicResource Body}"
                                   IsVisible="{Binding HasDescription}" />
                            <Label Text="{Binding Summary}"
                                   Style="{DynamicResource Caption}" />
                            <Label Text="{Binding Preview}"
                                   Style="{DynamicResource Body}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
