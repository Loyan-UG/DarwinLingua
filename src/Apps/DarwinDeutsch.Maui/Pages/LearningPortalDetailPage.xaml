<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.LearningPortalDetailPage">
    <Grid Padding="24"
          RowDefinitions="Auto,*"
          RowSpacing="12">
        <controls:LoadingStateView x:Name="LoadingStateView"
                                   Grid.Row="0"
                                   LoadingMode="TopicCardsSkeleton" />
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ContentLayout"
                                 Spacing="14" />
        </ScrollView>
    </Grid>
</ContentPage>
