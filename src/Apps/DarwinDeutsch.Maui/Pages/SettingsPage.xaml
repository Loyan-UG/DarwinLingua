<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             xmlns:chips="clr-namespace:Syncfusion.Maui.Toolkit.Chips;assembly=Syncfusion.Maui.Toolkit"
             xmlns:expander="clr-namespace:Syncfusion.Maui.Toolkit.Expander;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Pages.SettingsPage">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Border Padding="24"
                    Style="{StaticResource AppHeroPanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="HeadlineLabel"
                           Style="{DynamicResource Headline}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label x:Name="DescriptionLabel"
                           Style="{DynamicResource Body}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <expander:SfExpander IsExpanded="True"
                                 Style="{StaticResource SyncfusionSectionExpanderStyle}">
                <expander:SfExpander.Header>
                    <Grid Padding="20">
                        <Label x:Name="ContentUpdatesSectionLabel"
                               Style="{DynamicResource Title2}" />
                    </Grid>
                </expander:SfExpander.Header>
                <expander:SfExpander.Content>
                    <Border Padding="20"
                            Style="{StaticResource AppSectionCardBorderStyle}">
                        <VerticalStackLayout Spacing="16">
                            <Label x:Name="RemoteContentUpdatesSectionLabel"
                                   Style="{DynamicResource Caption}" />
                            <buttons:SfButton x:Name="ApplyRemoteUpdateButton"
                                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                              Clicked="OnApplyRemoteUpdateButtonClicked" />
                            <controls:DetailSectionView x:Name="RemoteContentUpdateStatusSectionView" />
                            <controls:DetailSectionView x:Name="RemoteContentUpdateDetailsSectionView" />

                            <Label x:Name="CatalogAreaUpdatesSectionLabel"
                                   Style="{DynamicResource Caption}" />
                            <buttons:SfButton x:Name="ApplyCatalogAreaUpdateButton"
                                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                              Clicked="OnApplyCatalogAreaUpdateButtonClicked" />
                            <controls:DetailSectionView x:Name="CatalogAreaUpdateSectionView" />

                            <Label x:Name="CefrLevelUpdatesSectionLabel"
                                   Style="{DynamicResource Caption}" />
                            <chips:SfChipGroup x:Name="CefrLevelChipGroup"
                                               Style="{StaticResource SyncfusionChipGroupSelectionStyle}"
                                               ChoiceMode="Single"
                                               DisplayMemberPath="Level"
                                               SelectionChanged="OnCefrLevelChipGroupSelectionChanged" />
                            <controls:DetailSectionView x:Name="SelectedCefrUpdateSectionView" />
                            <buttons:SfButton x:Name="ApplySelectedCefrLevelUpdateButton"
                                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                              Clicked="OnApplySelectedCefrLevelUpdateButtonClicked" />

                            <Label x:Name="PackagedSeedUpdatesSectionLabel"
                                   Style="{DynamicResource Caption}" />
                            <buttons:SfButton x:Name="ApplySeedUpdateButton"
                                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                              Clicked="OnApplySeedUpdateButtonClicked" />
                            <controls:DetailSectionView x:Name="ContentUpdateStatusSectionView" />
                            <controls:DetailSectionView x:Name="ContentUpdateDetailsSectionView" />
                        </VerticalStackLayout>
                    </Border>
                </expander:SfExpander.Content>
            </expander:SfExpander>

            <Border Padding="20"
                    Style="{StaticResource AppSectionCardBorderStyle}">
                <VerticalStackLayout Spacing="18">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="LanguagePickerCaptionLabel"
                               Style="{DynamicResource Caption}" />
                        <Picker x:Name="LanguagePicker"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedIndexChanged="OnLanguagePickerSelectedIndexChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="PrimaryMeaningLanguageCaptionLabel"
                               Style="{DynamicResource Caption}" />
                        <Picker x:Name="PrimaryMeaningLanguagePicker"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedIndexChanged="OnPrimaryMeaningLanguagePickerSelectedIndexChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="SecondaryMeaningLanguageCaptionLabel"
                               Style="{DynamicResource Caption}" />
                        <Picker x:Name="SecondaryMeaningLanguagePicker"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedIndexChanged="OnSecondaryMeaningLanguagePickerSelectedIndexChanged" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <expander:SfExpander IsExpanded="False"
                                 Style="{StaticResource SyncfusionSectionExpanderStyle}">
                <expander:SfExpander.Header>
                    <Grid Padding="20">
                        <Label x:Name="AboutSectionLabel"
                               Style="{DynamicResource Title2}" />
                    </Grid>
                </expander:SfExpander.Header>
                <expander:SfExpander.Content>
                    <Border Padding="20"
                            Style="{StaticResource AppSectionCardBorderStyle}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="AboutSummaryLabel"
                                   Style="{DynamicResource Body}"
                                   LineBreakMode="WordWrap" />
                            <buttons:SfButton x:Name="OpenAboutButton"
                                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                              Clicked="OnOpenAboutButtonClicked" />
                        </VerticalStackLayout>
                    </Border>
                </expander:SfExpander.Content>
            </expander:SfExpander>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
