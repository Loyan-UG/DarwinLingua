<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.SettingsPage">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Border Padding="24"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{AppThemeBinding Light=#E8F3F1, Dark=#16212B}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="HeadlineLabel"
                           Style="{DynamicResource Headline}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label x:Name="DescriptionLabel"
                           Style="{DynamicResource Body}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="20"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <VerticalStackLayout Spacing="18">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="LanguagePickerCaptionLabel"
                               Style="{DynamicResource Caption}" />
                        <Picker x:Name="LanguagePicker"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedIndexChanged="OnLanguagePickerSelectedIndexChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="PrimaryMeaningLanguageCaptionLabel"
                               Style="{DynamicResource Caption}" />
                        <Picker x:Name="PrimaryMeaningLanguagePicker"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedIndexChanged="OnPrimaryMeaningLanguagePickerSelectedIndexChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="SecondaryMeaningLanguageCaptionLabel"
                               Style="{DynamicResource Caption}" />
                        <Picker x:Name="SecondaryMeaningLanguagePicker"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedIndexChanged="OnSecondaryMeaningLanguagePickerSelectedIndexChanged" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label x:Name="AppInfoSectionLabel"
                   Style="{DynamicResource Title2}" />

            <Border Padding="20"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <VerticalStackLayout Spacing="16">
                    <controls:DetailSectionView x:Name="CurrentLanguageSectionView" />
                    <controls:DetailSectionView x:Name="MeaningLanguagesSectionView" />
                    <controls:DetailSectionView x:Name="SupportedLanguagesSectionView" />
                    <controls:DetailSectionView x:Name="CurrentFeaturesSectionView" />
                    <controls:DetailSectionView x:Name="FutureFeaturesSectionView" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ContentUpdatesSectionLabel"
                   Style="{DynamicResource Title2}" />

            <Border Padding="20"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <VerticalStackLayout Spacing="16">
                    <Label x:Name="RemoteContentUpdatesSectionLabel"
                           Style="{DynamicResource Caption}" />
                    <controls:DetailSectionView x:Name="RemoteContentUpdateStatusSectionView" />
                    <controls:DetailSectionView x:Name="RemoteContentUpdateDetailsSectionView" />
                    <controls:DetailSectionView x:Name="RemoteContentUpdateDiagnosticsSectionView" />
                    <controls:DetailSectionView x:Name="RemoteContentUpdateHistorySectionView" />

                    <Button x:Name="ApplyRemoteUpdateButton"
                            Clicked="OnApplyRemoteUpdateButtonClicked" />

                    <Label x:Name="CatalogAreaUpdatesSectionLabel"
                           Style="{DynamicResource Caption}" />
                    <controls:DetailSectionView x:Name="CatalogAreaUpdateSectionView" />
                    <Button x:Name="ApplyCatalogAreaUpdateButton"
                            Clicked="OnApplyCatalogAreaUpdateButtonClicked" />

                    <Label x:Name="CefrLevelUpdatesSectionLabel"
                           Style="{DynamicResource Caption}" />
                    <controls:DetailSectionView x:Name="CefrA1UpdateSectionView" />
                    <Button x:Name="ApplyCefrA1UpdateButton"
                            CommandParameter="A1"
                            Clicked="OnApplyCefrLevelUpdateButtonClicked" />
                    <controls:DetailSectionView x:Name="CefrA2UpdateSectionView" />
                    <Button x:Name="ApplyCefrA2UpdateButton"
                            CommandParameter="A2"
                            Clicked="OnApplyCefrLevelUpdateButtonClicked" />
                    <controls:DetailSectionView x:Name="CefrB1UpdateSectionView" />
                    <Button x:Name="ApplyCefrB1UpdateButton"
                            CommandParameter="B1"
                            Clicked="OnApplyCefrLevelUpdateButtonClicked" />
                    <controls:DetailSectionView x:Name="CefrB2UpdateSectionView" />
                    <Button x:Name="ApplyCefrB2UpdateButton"
                            CommandParameter="B2"
                            Clicked="OnApplyCefrLevelUpdateButtonClicked" />
                    <controls:DetailSectionView x:Name="CefrC1UpdateSectionView" />
                    <Button x:Name="ApplyCefrC1UpdateButton"
                            CommandParameter="C1"
                            Clicked="OnApplyCefrLevelUpdateButtonClicked" />
                    <controls:DetailSectionView x:Name="CefrC2UpdateSectionView" />
                    <Button x:Name="ApplyCefrC2UpdateButton"
                            CommandParameter="C2"
                            Clicked="OnApplyCefrLevelUpdateButtonClicked" />

                    <BoxView HeightRequest="1"
                             Margin="0,4,0,0"
                             BackgroundColor="{AppThemeBinding Light=#D9E2EC, Dark=#243447}" />

                    <Label x:Name="PackagedSeedUpdatesSectionLabel"
                           Style="{DynamicResource Caption}" />
                    <controls:DetailSectionView x:Name="ContentUpdateStatusSectionView" />
                    <controls:DetailSectionView x:Name="ContentUpdateDetailsSectionView" />
                    <controls:DetailSectionView x:Name="ContentUpdateDiagnosticsSectionView" />

                    <Button x:Name="ApplySeedUpdateButton"
                            Clicked="OnApplySeedUpdateButtonClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
