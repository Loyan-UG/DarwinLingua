<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.LearningPortalSearchPage">
    <Grid Padding="24"
          RowDefinitions="Auto,Auto,Auto,Auto,*"
          RowSpacing="12">
        <Label x:Name="HeadlineLabel"
               Grid.Row="0"
               Style="{DynamicResource Headline}"
               SemanticProperties.HeadingLevel="Level1" />
        <SearchBar x:Name="QuerySearchBar"
                   Grid.Row="1"
                   SearchButtonPressed="OnSearchRequested"
                   TextChanged="OnSearchTextChanged" />
        <controls:LoadingStateView x:Name="LoadingStateView"
                                   Grid.Row="2"
                                   LoadingMode="TopicCardsSkeleton" />
        <Label x:Name="EmptyStateLabel"
               Grid.Row="3"
               Style="{DynamicResource Body}"
               IsVisible="False" />
        <CollectionView x:Name="ResultsCollectionView"
                        Grid.Row="4"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="16"
                            Style="{StaticResource AppSectionCardBorderStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Title}"
                                   Style="{DynamicResource Title2}" />
                            <Label Text="{Binding ShortSnippet}"
                                   Style="{DynamicResource Body}"
                                   LineBreakMode="WordWrap" />
                            <Label Text="{Binding MetadataLine}"
                                   Style="{DynamicResource Caption}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
