<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             x:Class="DarwinDeutsch.Maui.Pages.AboutPage"
             BackgroundColor="{DynamicResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,40"
                             Spacing="20">
            <Border Padding="24"
                    Style="{StaticResource AppHeroPanelBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="HeadlineLabel"
                           Style="{DynamicResource Title1}" />
                    <Label x:Name="SummaryLabel"
                           Style="{DynamicResource Body}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="20"
                    Style="{StaticResource AppSectionCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="FeaturesSectionLabel"
                           Style="{DynamicResource Title3}" />
                    <Label x:Name="FeaturesBodyLabel"
                           Style="{DynamicResource Body}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="20"
                    Style="{StaticResource AppSectionCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="DeveloperSectionLabel"
                           Style="{DynamicResource Title3}" />
                    <Label x:Name="DeveloperValueLabel"
                           Style="{DynamicResource Body}" />
                    <buttons:SfButton x:Name="OpenGitHubButton"
                                      Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                      Clicked="OnOpenGitHubButtonClicked" />
                    <buttons:SfButton x:Name="ContactButton"
                                      Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                      Clicked="OnContactButtonClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
