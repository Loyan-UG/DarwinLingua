<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.ScenarioDetailPage">
    <Grid Padding="24"
          RowDefinitions="Auto,*"
          RowSpacing="12">
        <controls:LoadingStateView x:Name="LoadingStateView"
                                   Grid.Row="0"
                                   LoadingMode="DetailSkeleton" />

        <ScrollView Grid.Row="1"
                    x:Name="ContentScrollView"
                    IsVisible="False">
            <VerticalStackLayout Spacing="14">
                <Border Padding="20"
                        Style="{StaticResource AppHeroPanelBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="MetadataLabel"
                               Style="{DynamicResource Caption}" />
                        <Label x:Name="HeadlineLabel"
                               Style="{DynamicResource Headline}"
                               SemanticProperties.HeadingLevel="Level1" />
                        <Label x:Name="DescriptionLabel"
                               Style="{DynamicResource Body}"
                               LineBreakMode="WordWrap" />
                        <Label x:Name="GoalLabel"
                               Style="{DynamicResource Body}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="EmptyStateLabel"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <Border x:Name="StarterPacksSection"
                        Padding="16"
                        Style="{StaticResource AppSectionCardBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Conversation starters"
                               Style="{DynamicResource Title2}" />
                        <CollectionView x:Name="StarterPacksCollectionView"
                                        SelectionMode="Single"
                                        SelectionChanged="OnStarterPacksSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            Style="{StaticResource AppSectionCardBorderStyle}">
                                        <VerticalStackLayout Spacing="7">
                                            <Label Text="{Binding Title}"
                                                   Style="{DynamicResource Title2}" />
                                            <Label Text="{Binding Description}"
                                                   Style="{DynamicResource Body}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding MetadataLine}"
                                                   Style="{DynamicResource Caption}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="EventPreparationPacksSection"
                        Padding="16"
                        Style="{StaticResource AppSectionCardBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Preparation packs"
                               Style="{DynamicResource Title2}" />
                        <CollectionView x:Name="EventPreparationPacksCollectionView"
                                        SelectionMode="Single"
                                        SelectionChanged="OnEventPreparationPacksSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            Style="{StaticResource AppSectionCardBorderStyle}">
                                        <VerticalStackLayout Spacing="7">
                                            <Label Text="{Binding Title}"
                                                   Style="{DynamicResource Title2}" />
                                            <Label Text="{Binding Description}"
                                                   Style="{DynamicResource Body}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding MetadataLine}"
                                                   Style="{DynamicResource Caption}" />
                                            <Label Text="{Binding LinkedStarterPacksLine}"
                                                   Style="{DynamicResource Caption}"
                                                   IsVisible="{Binding HasLinkedStarterPacks}"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="DialogueSection"
                        Padding="16"
                        Style="{StaticResource AppSectionCardBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Dialogue"
                               Style="{DynamicResource Title2}" />
                        <CollectionView x:Name="DialogueTurnsCollectionView"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            Style="{StaticResource AppSectionCardBorderStyle}">
                                        <VerticalStackLayout Spacing="7">
                                            <Label Text="{Binding SpeakerRole}"
                                                   Style="{DynamicResource Caption}" />
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <Label Text="{Binding BaseText}"
                                                       Style="{DynamicResource Title2}"
                                                       LineBreakMode="WordWrap" />
                                                <Button Grid.Column="1"
                                                        Text="Speak"
                                                        Clicked="OnSpeakItemClicked" />
                                            </Grid>
                                            <Label Text="{Binding PrimaryMeaning}"
                                                   Style="{DynamicResource Body}"
                                                   IsVisible="{Binding HasPrimaryMeaning}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding SecondaryMeaning}"
                                                   Style="{DynamicResource Body}"
                                                   IsVisible="{Binding HasSecondaryMeaning}"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="PhrasesSection"
                        Padding="16"
                        Style="{StaticResource AppSectionCardBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Useful phrases"
                               Style="{DynamicResource Title2}" />
                        <CollectionView x:Name="PhrasesCollectionView"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            Style="{StaticResource AppSectionCardBorderStyle}">
                                        <VerticalStackLayout Spacing="7">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <Label Text="{Binding BaseText}"
                                                       Style="{DynamicResource Title2}"
                                                       LineBreakMode="WordWrap" />
                                                <Button Grid.Column="1"
                                                        Text="Speak"
                                                        Clicked="OnSpeakItemClicked" />
                                            </Grid>
                                            <Label Text="{Binding PrimaryMeaning}"
                                                   Style="{DynamicResource Body}"
                                                   IsVisible="{Binding HasPrimaryMeaning}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding SecondaryMeaning}"
                                                   Style="{DynamicResource Body}"
                                                   IsVisible="{Binding HasSecondaryMeaning}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding UsageNote}"
                                                   Style="{DynamicResource Caption}"
                                                   IsVisible="{Binding HasUsageNote}"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="QuestionsSection"
                        Padding="16"
                        Style="{StaticResource AppSectionCardBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Quick check"
                               Style="{DynamicResource Title2}" />
                        <CollectionView x:Name="QuestionsCollectionView"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            Style="{StaticResource AppSectionCardBorderStyle}">
                                        <VerticalStackLayout Spacing="7">
                                            <Label Text="{Binding Prompt}"
                                                   Style="{DynamicResource Title2}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding PrimaryMeaning}"
                                                   Style="{DynamicResource Body}"
                                                   IsVisible="{Binding HasPrimaryMeaning}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding SecondaryMeaning}"
                                                   Style="{DynamicResource Body}"
                                                   IsVisible="{Binding HasSecondaryMeaning}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding AnswerSummary}"
                                                   Style="{DynamicResource Body}"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
